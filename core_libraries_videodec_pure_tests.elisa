include "../compiler/runtime/elisacore_std/elisacore_runtime.elisa"
include "./core/libraries/videodec/videodec.elisa"

@test
def videodec_v1_contracts() -> void:
    can Abort.Panic:
        cfg: mutable OrbisVideodecConfigInfo = zeroed
        res: mutable OrbisVideodecResourceInfo = zeroed
        ctrl: mutable OrbisVideodecCtrl = zeroed

        assert sceVideodecQueryResourceInfo(null, res.ref[mutable OrbisVideodecResourceInfo&]) == ORBIS_VIDEODEC_ERROR_ARGUMENT_POINTER

        cfg.thisSize <- size_of(OrbisVideodecConfigInfo).u64()
        cfg.maxFrameWidth <- 1920
        cfg.maxFrameHeight <- 1080
        res.thisSize <- size_of(OrbisVideodecResourceInfo).u64()
        assert sceVideodecQueryResourceInfo(cfg.ref[OrbisVideodecConfigInfo&], res.ref[mutable OrbisVideodecResourceInfo&]) == ORBIS_OK
        assert res.cpuMemorySize == VIDEODEC_16_MB
        assert res.frameBufferAlignment == 0x100u32

        assert sceVideodecCreateDecoder(cfg.ref[OrbisVideodecConfigInfo&], res.ref[OrbisVideodecResourceInfo&], ctrl.ref[mutable OrbisVideodecCtrl&]) == ORBIS_OK
        assert ctrl.thisSize == size_of(OrbisVideodecCtrl).u64()
        assert ctrl.handle != null
        assert ctrl.version == 1u64

        input: mutable OrbisVideodecInputData = zeroed
        frame: mutable OrbisVideodecFrameBuffer = zeroed
        picture: mutable OrbisVideodecPictureInfo = zeroed
        frame.thisSize <- size_of(OrbisVideodecFrameBuffer).u64()
        assert sceVideodecDecode(ctrl.ref[mutable OrbisVideodecCtrl&], input.ref[OrbisVideodecInputData&], frame.ref[mutable OrbisVideodecFrameBuffer&], picture.ref[mutable OrbisVideodecPictureInfo&]) == ORBIS_VIDEODEC_ERROR_AU_POINTER
        assert picture.thisSize == size_of(OrbisVideodecPictureInfo).u64()
        assert picture.isValid == 0u32
        assert picture.isErrorPic == 1u32

        picture.thisSize <- size_of(OrbisVideodecPictureInfo).u64()
        assert sceVideodecFlush(ctrl.ref[mutable OrbisVideodecCtrl&], frame.ref[mutable OrbisVideodecFrameBuffer&], picture.ref[mutable OrbisVideodecPictureInfo&]) == ORBIS_OK
        assert sceVideodecReset(ctrl.ref[mutable OrbisVideodecCtrl&]) == ORBIS_OK
        assert sceVideodecDeleteDecoder(ctrl.ref[mutable OrbisVideodecCtrl&]) == ORBIS_OK
        assert sceVideodecReset(ctrl.ref[mutable OrbisVideodecCtrl&]) == ORBIS_VIDEODEC_ERROR_HANDLE

@test
def videodec2_contracts() -> void:
    can Abort.Panic:
        compute_mem: mutable OrbisVideodec2ComputeMemoryInfo = zeroed
        assert sceVideodec2QueryComputeMemoryInfo(null) == ORBIS_VIDEODEC2_ERROR_ARGUMENT_POINTER
        compute_mem.thisSize <- size_of(OrbisVideodec2ComputeMemoryInfo).u64()
        assert sceVideodec2QueryComputeMemoryInfo(compute_mem.ref[mutable OrbisVideodec2ComputeMemoryInfo&]) == ORBIS_OK
        assert compute_mem.cpuGpuMemorySize == VIDEODEC_16_MB

        compute_cfg: mutable OrbisVideodec2ComputeConfigInfo = zeroed
        queue: mutable OrbisVideodec2ComputeQueue = null
        compute_cfg.thisSize <- size_of(OrbisVideodec2ComputeConfigInfo).u64()
        assert sceVideodec2AllocateComputeQueue(compute_cfg.ref[OrbisVideodec2ComputeConfigInfo&], compute_mem.ref[OrbisVideodec2ComputeMemoryInfo&], queue.ref[mutable OrbisVideodec2ComputeQueue&]) == ORBIS_VIDEODEC2_ERROR_MEMORY_POINTER
        compute_mem.cpuGpuMemory <- 0x7000usize as void&?
        assert sceVideodec2AllocateComputeQueue(compute_cfg.ref[OrbisVideodec2ComputeConfigInfo&], compute_mem.ref[OrbisVideodec2ComputeMemoryInfo&], queue.ref[mutable OrbisVideodec2ComputeQueue&]) == ORBIS_OK
        assert queue == compute_mem.cpuGpuMemory

        cfg: mutable OrbisVideodec2DecoderConfigInfo = zeroed
        mem: mutable OrbisVideodec2DecoderMemoryInfo = zeroed
        decoder: mutable OrbisVideodec2Decoder = null
        cfg.thisSize <- size_of(OrbisVideodec2DecoderConfigInfo).u64()
        mem.thisSize <- size_of(OrbisVideodec2DecoderMemoryInfo).u64()
        assert sceVideodec2QueryDecoderMemoryInfo(cfg.ref[OrbisVideodec2DecoderConfigInfo&], mem.ref[mutable OrbisVideodec2DecoderMemoryInfo&]) == ORBIS_OK
        assert mem.maxFrameBufferSize == VIDEODEC_16_MB
        assert sceVideodec2CreateDecoder(cfg.ref[OrbisVideodec2DecoderConfigInfo&], mem.ref[OrbisVideodec2DecoderMemoryInfo&], decoder.ref[mutable OrbisVideodec2Decoder&]) == ORBIS_OK
        assert decoder != null

        input: mutable OrbisVideodec2InputData = zeroed
        frame: mutable OrbisVideodec2FrameBuffer = zeroed
        output: mutable OrbisVideodec2OutputInfo = zeroed
        input.thisSize <- size_of(OrbisVideodec2InputData).u64()
        frame.thisSize <- size_of(OrbisVideodec2FrameBuffer).u64()
        output.thisSize <- size_of(OrbisVideodec2OutputInfo).u64()
        assert sceVideodec2Decode(decoder, input.ref[OrbisVideodec2InputData&], frame.ref[mutable OrbisVideodec2FrameBuffer&], output.ref[mutable OrbisVideodec2OutputInfo&]) == ORBIS_VIDEODEC2_ERROR_ACCESS_UNIT_POINTER
        assert output.isValid == false
        assert output.isErrorFrame == true
        assert output.pictureCount == 0u8
        assert sceVideodec2Flush(decoder, frame.ref[mutable OrbisVideodec2FrameBuffer&], output.ref[mutable OrbisVideodec2OutputInfo&]) == ORBIS_OK
        assert sceVideodec2Reset(decoder) == ORBIS_OK
        assert sceVideodec2DeleteDecoder(decoder) == ORBIS_OK
        assert sceVideodec2Reset(decoder) == ORBIS_VIDEODEC2_ERROR_DECODER_INSTANCE
