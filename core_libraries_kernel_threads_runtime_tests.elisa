@test
def runtime_posix_sem_wait_post_try_timed_getvalue() -> void:
    can Abort.Panic:
        elisa_kernel_test_slots_reset()
        rt_sem <- null
        rt_assert_zero(posix_sem_init(rt_sem, 0, 0u32))
        if posix_sem_trywait(rt_sem) != -1:
            panic("sem trywait should fail on empty semaphore")
        thread: mutable void&? = null
        rt_assert_zero(posix_pthread_create(thread, null, rt_posix_sem_wait_entry.cast[void&], null))
        rt_wait_slot(0, 1)
        elisa_kernel_test_sleep_usec(10000u64)
        rt_assert_eq_i64(elisa_kernel_test_slot_get(1), 0)
        rt_assert_zero(posix_sem_post(rt_sem))
        rt_wait_slot(1, 1)
        assert rt_join(thread) == null
        if posix_sem_timedwait(rt_sem, null) != -1:
            panic("sem timedwait should time out on empty semaphore")
        rt_assert_zero(posix_sem_post(rt_sem))
        value: mutable int = -1
        rt_assert_zero(posix_sem_getvalue(rt_sem, value.ref[mutable int&]))
        if value != 1:
            panic("sem getvalue should reflect post")
        rt_assert_zero(posix_sem_destroy(rt_sem))

@test
def runtime_event_flag_wait_set_clear_cancel() -> void:
    can Abort.Panic:
        elisa_kernel_test_slots_reset()
        rt_event_flag_id <- -1
        rt_assert_zero(sceKernelCreateEventFlag(rt_event_flag_id, "runtime-event", 0u32, 0u64, null))
        thread: mutable void&? = null
        rt_assert_zero(posix_pthread_create(thread, null, rt_event_wait_entry.cast[void&], 0x01u32 as void&?))
        rt_wait_slot(0, 1)
        elisa_kernel_test_sleep_usec(10000u64)
        rt_assert_eq_i64(elisa_kernel_test_slot_get(1), 0)
        rt_assert_zero(sceKernelSetEventFlag(rt_event_flag_id, 0x1u64))
        elisa_kernel_test_sleep_usec(10000u64)
        rt_assert_eq_i64(elisa_kernel_test_slot_get(1), 0)
        rt_assert_zero(sceKernelSetEventFlag(rt_event_flag_id, 0x2u64))
        rt_wait_slot(1, 3)
        if rt_join(thread) != null:
            panic("event waiter should return null")

        out_bits: mutable u64 = 0u64
        rt_assert_zero(sceKernelSetEventFlag(rt_event_flag_id, 0xfu64))
        rt_assert_zero(sceKernelPollEventFlag(rt_event_flag_id, 0x4u64, 0x22u32, out_bits))
        if out_bits != 0xfu64:
            panic("event clear-pattern should report original bits")
        rt_assert_zero(sceKernelPollEventFlag(rt_event_flag_id, 0x8u64, 0x12u32, out_bits))
        if out_bits != 0xbu64:
            panic("event clear-all should report post-clear bits")
        timeout: mutable u32 = 1000u32
        rt_assert_eq_int(sceKernelWaitEventFlag(rt_event_flag_id, 0x80u64, 0x02u32, null, timeout), ORBIS_KERNEL_ERROR_ETIMEDOUT)
        if timeout != 0u32:
            panic("event timeout should be zeroed")
        waiters: mutable int = -1
        rt_assert_zero(sceKernelCancelEventFlag(rt_event_flag_id, 0u64, waiters.ref[mutable int&]))
        if waiters != 0:
            panic("event cancel should report zero waiters")
        rt_assert_zero(sceKernelDeleteEventFlag(rt_event_flag_id))

@test
def runtime_event_flag_single_mode_rejects_second_waiter() -> void:
    can Abort.Panic:
        elisa_kernel_test_slots_reset()
        rt_event_flag_id <- -1
        rt_assert_zero(sceKernelCreateEventFlag(rt_event_flag_id, "runtime-event-single", 0x10u32, 0u64, null))
        thread: mutable void&? = null
        rt_assert_zero(posix_pthread_create(thread, null, rt_event_wait_entry.cast[void&], 0x01u32 as void&?))
        rt_wait_slot(0, 1)
        result_bits: mutable u64 = 0u64
        timeout: mutable u32 = 1000u32
        rt_assert_eq_int(sceKernelWaitEventFlag(rt_event_flag_id, 0x3u64, 0x01u32, result_bits, timeout), ORBIS_KERNEL_ERROR_EPERM)
        rt_assert_zero(sceKernelSetEventFlag(rt_event_flag_id, 0x3u64))
        rt_wait_slot(1, 3)
        assert rt_join(thread) == null
        rt_assert_zero(sceKernelDeleteEventFlag(rt_event_flag_id))

