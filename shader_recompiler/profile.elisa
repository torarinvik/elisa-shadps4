#
# Native Elisa port of shader_recompiler/profile.h: device/driver capability
# profile consumed by the recompiler. supported_spirv defaults to SPIR-V 1.0
# (0x00010000); all other fields default to zero.

struct Profile:
    max_ubo_size: mutable u64
    max_viewport_width: mutable u32
    max_viewport_height: mutable u32
    max_shared_memory_size: mutable u32
    supported_spirv: mutable u32
    subgroup_size: mutable u32
    support_int8: mutable bool
    support_int16: mutable bool
    support_int64: mutable bool
    support_float16: mutable bool
    support_float64: mutable bool
    supports_denorm_behavior_independence: mutable bool
    supports_rounding_mode_independence: mutable bool
    support_fp16_denorm_preserve: mutable bool
    support_fp16_denorm_flush: mutable bool
    support_fp16_round_to_zero: mutable bool
    support_fp32_denorm_preserve: mutable bool
    support_fp32_denorm_flush: mutable bool
    support_fp32_round_to_zero: mutable bool
    support_fp64_denorm_preserve: mutable bool
    support_fp64_denorm_flush: mutable bool
    support_fp64_round_to_zero: mutable bool
    support_fp16_signed_zero_inf_nan_preserve: mutable bool
    support_fp32_signed_zero_inf_nan_preserve: mutable bool
    support_fp64_signed_zero_inf_nan_preserve: mutable bool
    support_legacy_vertex_attributes: mutable bool
    supports_image_load_store_lod: mutable bool
    supports_native_cube_calc: mutable bool
    supports_trinary_minmax: mutable bool
    supports_buffer_fp32_atomic_min_max: mutable bool
    supports_image_fp32_atomic_min_max: mutable bool
    supports_buffer_int64_atomics: mutable bool
    supports_shared_int64_atomics: mutable bool
    supports_workgroup_explicit_memory_layout: mutable bool
    supports_amd_shader_explicit_vertex_parameter: mutable bool
    supports_fragment_shader_barycentric: mutable bool
    supports_shader_stencil_export: mutable bool
    has_incomplete_fragment_shader_barycentric: mutable bool
    has_broken_spirv_clamp: mutable bool
    lower_left_origin_mode: mutable bool
    needs_manual_interpolation: mutable bool
    needs_lds_barriers: mutable bool
    needs_buffer_offsets: mutable bool
    needs_unorm_fixup: mutable bool
    needs_clip_distance_emulation: mutable bool

const SHADER_PROFILE_DEFAULT_SPIRV: u32 = 0x00010000u32

def Profile_Default() -> Profile:
    out: mutable Profile = zeroed
    out.supported_spirv <- SHADER_PROFILE_DEFAULT_SPIRV
    return out
