    return SpirvEmitUnaryOp(ctx, SPIRV_OP_CONVERT_U_TO_F, ctx.f32_id, value)

# Signed integer -> F64.
def SpirvEmitConvertF64S8(ctx: mutable SpirvEmitContext&, value: u32) -> u32:
    return SpirvEmitUnaryOp(ctx, SPIRV_OP_CONVERT_S_TO_F, ctx.f64_id, SpirvEmitExtractS8(ctx, value))

