    return SpirvEmitUnaryOp(ctx, SPIRV_OP_U_CONVERT, ctx.u32_id, SpirvEmitUnaryOp(ctx, SPIRV_OP_CONVERT_F_TO_U, ctx.u16_id, value))

def SpirvEmitConvertU16F64(ctx: mutable SpirvEmitContext&, value: u32) -> u32:
    return SpirvEmitUnaryOp(ctx, SPIRV_OP_U_CONVERT, ctx.u32_id, SpirvEmitUnaryOp(ctx, SPIRV_OP_CONVERT_F_TO_U, ctx.u16_id, value))

def SpirvEmitConvertU32F32(ctx: mutable SpirvEmitContext&, value: u32) -> u32:
    return SpirvEmitUnaryOp(ctx, SPIRV_OP_CONVERT_F_TO_U, ctx.u32_id, value)

