def SpirvEmitIMul32(ctx: mutable SpirvEmitContext&, a: u32, b: u32) -> u32:
    return SpirvEmitBinaryOp(ctx, SPIRV_OP_I_MUL, ctx.u32_id, a, b)

def SpirvEmitSDiv32(ctx: mutable SpirvEmitContext&, a: u32, b: u32) -> u32:
    return SpirvEmitBinaryOp(ctx, SPIRV_OP_S_DIV, ctx.u32_id, a, b)

def SpirvEmitUDiv32(ctx: mutable SpirvEmitContext&, a: u32, b: u32) -> u32:
    return SpirvEmitBinaryOp(ctx, SPIRV_OP_U_DIV, ctx.u32_id, a, b)

def SpirvEmitSMod32(ctx: mutable SpirvEmitContext&, a: u32, b: u32) -> u32:
    return SpirvEmitBinaryOp(ctx, SPIRV_OP_S_MOD, ctx.u32_id, a, b)

def SpirvEmitUMod32(ctx: mutable SpirvEmitContext&, a: u32, b: u32) -> u32:
    return SpirvEmitBinaryOp(ctx, SPIRV_OP_U_MOD, ctx.u32_id, a, b)

def SpirvEmitINeg32(ctx: mutable SpirvEmitContext&, value: u32) -> u32:
    return SpirvEmitUnaryOp(ctx, SPIRV_OP_S_NEGATE, ctx.u32_id, value)

def SpirvEmitIAbs32(ctx: mutable SpirvEmitContext&, value: u32) -> u32:
    return SpirvEmitExtInstUnary(ctx, ctx.u32_id, GLSL_STD_450_SABS, value)

# Shifts (U32 result type).
def SpirvEmitShiftLeftLogical32(ctx: mutable SpirvEmitContext&, base: u32, shift: u32) -> u32:
    return SpirvEmitBinaryOp(ctx, SPIRV_OP_SHIFT_LEFT_LOGICAL, ctx.u32_id, base, shift)

