# ------------------------------------------------------------
# emit_spirv_bitwise_conversion.cpp: bitcasts + pack/unpack.
# ------------------------------------------------------------

def SpirvEmitBitCastU16F16(ctx: mutable SpirvEmitContext&, value: u32) -> u32:
    return SpirvEmitBitcast(ctx, ctx.u16_id, value)

def SpirvEmitBitCastU32F32(ctx: mutable SpirvEmitContext&, value: u32) -> u32:
    return SpirvEmitBitcast(ctx, ctx.u32_id, value)

def SpirvEmitBitCastF16U16(ctx: mutable SpirvEmitContext&, value: u32) -> u32:
    return SpirvEmitBitcast(ctx, ctx.f16_id, value)

def SpirvEmitBitCastF32U32(ctx: mutable SpirvEmitContext&, value: u32) -> u32:
    return SpirvEmitBitcast(ctx, ctx.f32_id, value)

# 2x32 <-> 64-bit packing is a plain reinterpret.
def SpirvEmitPackUint2x32(ctx: mutable SpirvEmitContext&, value: u32) -> u32:
    return SpirvEmitBitcast(ctx, ctx.u64_id, value)

def SpirvEmitUnpackUint2x32(ctx: mutable SpirvEmitContext&, value: u32) -> u32:
    return SpirvEmitBitcast(ctx, ctx.u32x2_id, value)

def SpirvEmitPackDouble2x32(ctx: mutable SpirvEmitContext&, value: u32) -> u32:
    return SpirvEmitBitcast(ctx, ctx.f64_id, value)

def SpirvEmitUnpackDouble2x32(ctx: mutable SpirvEmitContext&, value: u32) -> u32:
    return SpirvEmitBitcast(ctx, ctx.u32x2_id, value)

# Normalized / half packing via GLSL.std.450.
def SpirvEmitPackUnorm2x16(ctx: mutable SpirvEmitContext&, value: u32) -> u32:
    return SpirvEmitExtInstUnary(ctx, ctx.u32_id, GLSL_STD_450_PACK_UNORM2X16, value)

def SpirvEmitUnpackUnorm2x16(ctx: mutable SpirvEmitContext&, value: u32) -> u32:
    return SpirvEmitExtInstUnary(ctx, ctx.f32x2_id, GLSL_STD_450_UNPACK_UNORM2X16, value)

def SpirvEmitPackSnorm2x16(ctx: mutable SpirvEmitContext&, value: u32) -> u32:
    return SpirvEmitExtInstUnary(ctx, ctx.u32_id, GLSL_STD_450_PACK_SNORM2X16, value)

def SpirvEmitUnpackSnorm2x16(ctx: mutable SpirvEmitContext&, value: u32) -> u32:
    return SpirvEmitExtInstUnary(ctx, ctx.f32x2_id, GLSL_STD_450_UNPACK_SNORM2X16, value)

def SpirvEmitPackHalf2x16(ctx: mutable SpirvEmitContext&, value: u32) -> u32:
    return SpirvEmitExtInstUnary(ctx, ctx.u32_id, GLSL_STD_450_PACK_HALF2X16, value)

def SpirvEmitUnpackHalf2x16(ctx: mutable SpirvEmitContext&, value: u32) -> u32:
    return SpirvEmitExtInstUnary(ctx, ctx.f32x2_id, GLSL_STD_450_UNPACK_HALF2X16, value)

def SpirvEmitPackUnorm4x8(ctx: mutable SpirvEmitContext&, value: u32) -> u32:
    return SpirvEmitExtInstUnary(ctx, ctx.u32_id, GLSL_STD_450_PACK_UNORM4X8, value)

def SpirvEmitUnpackUnorm4x8(ctx: mutable SpirvEmitContext&, value: u32) -> u32:
    return SpirvEmitExtInstUnary(ctx, ctx.f32x4_id, GLSL_STD_450_UNPACK_UNORM4X8, value)

def SpirvEmitPackSnorm4x8(ctx: mutable SpirvEmitContext&, value: u32) -> u32:
    return SpirvEmitExtInstUnary(ctx, ctx.u32_id, GLSL_STD_450_PACK_SNORM4X8, value)

def SpirvEmitUnpackSnorm4x8(ctx: mutable SpirvEmitContext&, value: u32) -> u32:
    return SpirvEmitExtInstUnary(ctx, ctx.f32x4_id, GLSL_STD_450_UNPACK_SNORM4X8, value)

# Manual two-component 16-bit pack/unpack via bit fields.
def SpirvEmitPackUint2x16(ctx: mutable SpirvEmitContext&, value: u32) -> u32:
    unpacked: u32 = SpirvEmitBitcast(ctx, ctx.u32x2_id, value)
    x: u32 = SpirvEmitCompositeExtract(ctx, ctx.u32_id, unpacked, 0u32)
    y: u32 = SpirvEmitCompositeExtract(ctx, ctx.u32_id, unpacked, 1u32)
    off16: u32 = SpirvEmitConstU32(ctx, 16u32)
    size16: u32 = SpirvEmitConstU32(ctx, 16u32)
    return SpirvEmitBitFieldInsert(ctx, x, y, off16, size16)

def SpirvEmitUnpackUint2x16(ctx: mutable SpirvEmitContext&, value: u32) -> u32:
    off0: u32 = SpirvEmitConstU32(ctx, 0u32)
    size16: u32 = SpirvEmitConstU32(ctx, 16u32)
    x: u32 = SpirvEmitBitFieldUExtract(ctx, value, off0, size16)
    off16: u32 = SpirvEmitConstU32(ctx, 16u32)
    size16b: u32 = SpirvEmitConstU32(ctx, 16u32)
    y: u32 = SpirvEmitBitFieldUExtract(ctx, value, off16, size16b)
    unpacked: u32 = SpirvEmitCompositeConstruct2(ctx, ctx.u32x2_id, x, y)
    return SpirvEmitBitcast(ctx, ctx.f32x2_id, unpacked)

def SpirvEmitPackSint2x16(ctx: mutable SpirvEmitContext&, value: u32) -> u32:
    return SpirvEmitPackUint2x16(ctx, value)

def SpirvEmitUnpackSint2x16(ctx: mutable SpirvEmitContext&, value: u32) -> u32:
    off0: u32 = SpirvEmitConstU32(ctx, 0u32)
    size16: u32 = SpirvEmitConstU32(ctx, 16u32)
    x: u32 = SpirvEmitBitFieldSExtract(ctx, value, off0, size16)
    off16: u32 = SpirvEmitConstU32(ctx, 16u32)
    size16b: u32 = SpirvEmitConstU32(ctx, 16u32)
    y: u32 = SpirvEmitBitFieldSExtract(ctx, value, off16, size16b)
    unpacked: u32 = SpirvEmitCompositeConstruct2(ctx, ctx.u32x2_id, x, y)
    return SpirvEmitBitcast(ctx, ctx.f32x2_id, unpacked)

# Manual four-component 8-bit pack/unpack.
def SpirvEmitPackUint4x8(ctx: mutable SpirvEmitContext&, value: u32) -> u32:
    unpacked: u32 = SpirvEmitBitcast(ctx, ctx.u32x4_id, value)
    x: u32 = SpirvEmitCompositeExtract(ctx, ctx.u32_id, unpacked, 0u32)
    y: u32 = SpirvEmitCompositeExtract(ctx, ctx.u32_id, unpacked, 1u32)
    z: u32 = SpirvEmitCompositeExtract(ctx, ctx.u32_id, unpacked, 2u32)
    w: u32 = SpirvEmitCompositeExtract(ctx, ctx.u32_id, unpacked, 3u32)
    r1: u32 = SpirvEmitBitFieldInsert(ctx, x, y, SpirvEmitConstU32(ctx, 8u32), SpirvEmitConstU32(ctx, 8u32))
    r2: u32 = SpirvEmitBitFieldInsert(ctx, r1, z, SpirvEmitConstU32(ctx, 16u32), SpirvEmitConstU32(ctx, 8u32))
    return SpirvEmitBitFieldInsert(ctx, r2, w, SpirvEmitConstU32(ctx, 24u32), SpirvEmitConstU32(ctx, 8u32))

def SpirvEmitUnpackUint4x8(ctx: mutable SpirvEmitContext&, value: u32) -> u32:
    x: u32 = SpirvEmitBitFieldUExtract(ctx, value, SpirvEmitConstU32(ctx, 0u32), SpirvEmitConstU32(ctx, 8u32))
    y: u32 = SpirvEmitBitFieldUExtract(ctx, value, SpirvEmitConstU32(ctx, 8u32), SpirvEmitConstU32(ctx, 8u32))
    z: u32 = SpirvEmitBitFieldUExtract(ctx, value, SpirvEmitConstU32(ctx, 16u32), SpirvEmitConstU32(ctx, 8u32))
    w: u32 = SpirvEmitBitFieldUExtract(ctx, value, SpirvEmitConstU32(ctx, 24u32), SpirvEmitConstU32(ctx, 8u32))
    unpacked: u32 = SpirvEmitCompositeConstruct4(ctx, ctx.u32x4_id, x, y, z, w)
    return SpirvEmitBitcast(ctx, ctx.f32x4_id, unpacked)

def SpirvEmitPackSint4x8(ctx: mutable SpirvEmitContext&, value: u32) -> u32:
    return SpirvEmitPackUint4x8(ctx, value)

def SpirvEmitUnpackSint4x8(ctx: mutable SpirvEmitContext&, value: u32) -> u32:
    x: u32 = SpirvEmitBitFieldSExtract(ctx, value, SpirvEmitConstU32(ctx, 0u32), SpirvEmitConstU32(ctx, 8u32))
    y: u32 = SpirvEmitBitFieldSExtract(ctx, value, SpirvEmitConstU32(ctx, 8u32), SpirvEmitConstU32(ctx, 8u32))
    z: u32 = SpirvEmitBitFieldSExtract(ctx, value, SpirvEmitConstU32(ctx, 16u32), SpirvEmitConstU32(ctx, 8u32))
    w: u32 = SpirvEmitBitFieldSExtract(ctx, value, SpirvEmitConstU32(ctx, 24u32), SpirvEmitConstU32(ctx, 8u32))
    unpacked: u32 = SpirvEmitCompositeConstruct4(ctx, ctx.u32x4_id, x, y, z, w)
    return SpirvEmitBitcast(ctx, ctx.f32x4_id, unpacked)

# Raw 2_10_10_10 integer pack/unpack (the normalized unorm/snorm variants need
# F32x4 constant composites + a helper and are deferred to module assembly).
def SpirvEmitPackUint2_10_10_10(ctx: mutable SpirvEmitContext&, value: u32) -> u32:
    unpacked: u32 = SpirvEmitBitcast(ctx, ctx.u32x4_id, value)
    x: u32 = SpirvEmitCompositeExtract(ctx, ctx.u32_id, unpacked, 0u32)
    y: u32 = SpirvEmitCompositeExtract(ctx, ctx.u32_id, unpacked, 1u32)
    z: u32 = SpirvEmitCompositeExtract(ctx, ctx.u32_id, unpacked, 2u32)
    w: u32 = SpirvEmitCompositeExtract(ctx, ctx.u32_id, unpacked, 3u32)
    r1: u32 = SpirvEmitBitFieldInsert(ctx, x, y, SpirvEmitConstU32(ctx, 10u32), SpirvEmitConstU32(ctx, 10u32))
    r2: u32 = SpirvEmitBitFieldInsert(ctx, r1, z, SpirvEmitConstU32(ctx, 20u32), SpirvEmitConstU32(ctx, 10u32))
    return SpirvEmitBitFieldInsert(ctx, r2, w, SpirvEmitConstU32(ctx, 30u32), SpirvEmitConstU32(ctx, 2u32))

def SpirvEmitUnpackUint2_10_10_10(ctx: mutable SpirvEmitContext&, value: u32) -> u32:
    x: u32 = SpirvEmitBitFieldUExtract(ctx, value, SpirvEmitConstU32(ctx, 0u32), SpirvEmitConstU32(ctx, 10u32))
    y: u32 = SpirvEmitBitFieldUExtract(ctx, value, SpirvEmitConstU32(ctx, 10u32), SpirvEmitConstU32(ctx, 10u32))
    z: u32 = SpirvEmitBitFieldUExtract(ctx, value, SpirvEmitConstU32(ctx, 20u32), SpirvEmitConstU32(ctx, 10u32))
    w: u32 = SpirvEmitBitFieldUExtract(ctx, value, SpirvEmitConstU32(ctx, 30u32), SpirvEmitConstU32(ctx, 2u32))
    unpacked: u32 = SpirvEmitCompositeConstruct4(ctx, ctx.u32x4_id, x, y, z, w)
    return SpirvEmitBitcast(ctx, ctx.f32x4_id, unpacked)

def SpirvEmitPackSint2_10_10_10(ctx: mutable SpirvEmitContext&, value: u32) -> u32:
    return SpirvEmitPackUint2_10_10_10(ctx, value)

def SpirvEmitUnpackSint2_10_10_10(ctx: mutable SpirvEmitContext&, value: u32) -> u32:
    x: u32 = SpirvEmitBitFieldSExtract(ctx, value, SpirvEmitConstU32(ctx, 0u32), SpirvEmitConstU32(ctx, 10u32))
    y: u32 = SpirvEmitBitFieldSExtract(ctx, value, SpirvEmitConstU32(ctx, 10u32), SpirvEmitConstU32(ctx, 10u32))
    z: u32 = SpirvEmitBitFieldSExtract(ctx, value, SpirvEmitConstU32(ctx, 20u32), SpirvEmitConstU32(ctx, 10u32))
    w: u32 = SpirvEmitBitFieldSExtract(ctx, value, SpirvEmitConstU32(ctx, 30u32), SpirvEmitConstU32(ctx, 2u32))
    unpacked: u32 = SpirvEmitCompositeConstruct4(ctx, ctx.u32x4_id, x, y, z, w)
    return SpirvEmitBitcast(ctx, ctx.f32x4_id, unpacked)

# emit_spirv_special.cpp: zero-operand void instructions (1 word).
def SpirvEmitVoidOp(ctx: mutable SpirvEmitContext&, opcode: u16) -> void:
    SpirvEmitContext_AppendWord(ctx, SpirvWord(opcode, 1u16))

# EmitDiscard: OpDemoteToHelperInvocationEXT.
def SpirvEmitDiscard(ctx: mutable SpirvEmitContext&) -> void:
    SpirvEmitVoidOp(ctx, SPIRV_OP_DEMOTE_TO_HELPER_INVOCATION)

# EmitEmitVertex / EmitEmitPrimitive: geometry-shader stream control.
def SpirvEmitEmitVertex(ctx: mutable SpirvEmitContext&) -> void:
    SpirvEmitVoidOp(ctx, SPIRV_OP_EMIT_VERTEX)

def SpirvEmitEmitPrimitive(ctx: mutable SpirvEmitContext&) -> void:
    SpirvEmitVoidOp(ctx, SPIRV_OP_END_PRIMITIVE)

# OpLabel <ResultId> (2 words). Begins a basic block; tracks last_label.
def SpirvEmitLabel(ctx: mutable SpirvEmitContext&, label_id: u32) -> void:
    SpirvEmitContext_AppendWord(ctx, SpirvWord(SPIRV_OP_LABEL, 2u16))
    SpirvEmitContext_AppendWord(ctx, label_id)
    ctx.last_label <- label_id

# OpBranch <TargetLabel> (2 words).
def SpirvEmitBranch(ctx: mutable SpirvEmitContext&, target: u32) -> void:
    SpirvEmitContext_AppendWord(ctx, SpirvWord(SPIRV_OP_BRANCH, 2u16))
    SpirvEmitContext_AppendWord(ctx, target)

# OpSelectionMerge <MergeBlock> <SelectionControl> (3 words).
def SpirvEmitSelectionMerge(ctx: mutable SpirvEmitContext&, merge_block: u32, control: u32) -> void:
    SpirvEmitContext_AppendWord(ctx, SpirvWord(SPIRV_OP_SELECTION_MERGE, 3u16))
    SpirvEmitContext_AppendWord(ctx, merge_block)
    SpirvEmitContext_AppendWord(ctx, control)

# OpBranchConditional <Condition> <TrueLabel> <FalseLabel> (4 words).
def SpirvEmitBranchConditional(ctx: mutable SpirvEmitContext&, condition: u32, true_label: u32, false_label: u32) -> void:
    SpirvEmitContext_AppendWord(ctx, SpirvWord(SPIRV_OP_BRANCH_CONDITIONAL, 4u16))
    SpirvEmitContext_AppendWord(ctx, condition)
    SpirvEmitContext_AppendWord(ctx, true_label)
    SpirvEmitContext_AppendWord(ctx, false_label)

# EmitDiscardCond: guarded demote-to-helper. Reserves a kill and merge block,
# emits a selection-merge + conditional branch, then demotes inside the kill
# block before falling through to the merge block.
def SpirvEmitDiscardCond(ctx: mutable SpirvEmitContext&, condition: u32) -> void:
    kill_label: u32 = SpirvEmitContext_AllocateId(ctx)
    merge_label: u32 = SpirvEmitContext_AllocateId(ctx)
    SpirvEmitSelectionMerge(ctx, merge_label, SPIRV_SELECTION_CONTROL_NONE)
    SpirvEmitBranchConditional(ctx, condition, kill_label, merge_label)
    SpirvEmitLabel(ctx, kill_label)
    SpirvEmitDiscard(ctx)
    SpirvEmitBranch(ctx, merge_label)
    SpirvEmitLabel(ctx, merge_label)

# ============================================================
# SpirvModule: an Elisa port of the sirit SPIR-V builder. Mirrors
# Sirit::Module: per-section instruction streams, a monotonic id bound, a
# declaration dedup table (types/constants), and Assemble() that emits the
# header and concatenates the sections in canonical SPIR-V order.
# ============================================================

struct SpirvDeclRecord:
    start: mutable usize
    len: mutable usize
    id: mutable u32

struct SpirvModule:
    version: mutable u32
    bound: mutable u32
    addressing_model: mutable u32
    memory_model: mutable u32
    capabilities: mutable darray[u32]
    ext_inst_imports: mutable darray[u32]
    entry_points: mutable darray[u32]
    execution_modes: mutable darray[u32]
    debug: mutable darray[u32]
    annotations: mutable darray[u32]
    declarations: mutable darray[u32]
    global_variables: mutable darray[u32]
    code: mutable darray[u32]
    decls_index: mutable darray[SpirvDeclRecord]

def SpirvModule_Default() -> SpirvModule:
    m: mutable SpirvModule = zeroed
    m.version <- SPIRV_VERSION_1_6
    return m

def SpirvModule_AllocId(m: mutable SpirvModule&) -> u32:
    m.bound <- m.bound + 1u32
    return m.bound

def SpirvMod_Push(stream: mutable darray[u32]&, w: u32) -> void:
    can Memory.Allocate, Abort.Panic:
        owner: mutable Arena& = scratch_arena.ref[mutable Arena&]
        in owner:
            stream.push(w)

def SpirvMod_PushRec(recs: mutable darray[SpirvDeclRecord]&, rec: SpirvDeclRecord) -> void:
    can Memory.Allocate, Abort.Panic:
        owner: mutable Arena& = scratch_arena.ref[mutable Arena&]
        in owner:
            recs.push(rec)

def SpirvMod_AppendStream(out: mutable darray[u32]&, src: darray[u32]) -> void:
    for i in 0..<src.count:
        SpirvMod_Push(out, src[i])

# Compare a candidate declaration word-range against a stored record, ignoring
# the result-id slot (sirit normalizes the id to 0 before comparing).
def SpirvMod_DeclEquals(decls: darray[u32], rec: SpirvDeclRecord, cand_start: usize, cand_len: usize, id_offset: usize) -> bool:
    if rec.len != cand_len:
        return false
    for i in 0..<cand_len:
        if i != id_offset:
            if decls[rec.start + i] != decls[cand_start + i]:
                return false
    return true

# Begin a declaration: allocate the id and write opcode + optional result-type
# + result-id, returning the stream offset where it started. Operands are then
# pushed by the caller; SpirvMod_DedupDecl finalizes (keeping or rewinding).
def SpirvMod_BeginDecl(m: mutable SpirvModule&, opcode: u16, result_type: u32, word_count: u16) -> u32:
    has_rt: bool = result_type != 0u32
    new_id: u32 = SpirvModule_AllocId(m)
    SpirvMod_Push(m.declarations, SpirvWord(opcode, word_count))
    if has_rt:
        SpirvMod_Push(m.declarations, result_type)
    SpirvMod_Push(m.declarations, new_id)
    return new_id

# Finalize a just-written declaration: dedup against prior declarations and
# either keep it (recording the range) or rewind and reuse the existing id.
def SpirvMod_DedupDecl(m: mutable SpirvModule&, start: usize, new_id: u32, rt_words: usize) -> u32:
    cand_len: usize = m.declarations.count - start
    id_offset: usize = 1usize + rt_words
    for j in 0..<m.decls_index.count:
        rec: SpirvDeclRecord = m.decls_index[j]
        if SpirvMod_DeclEquals(m.declarations, rec, start, cand_len, id_offset):
            m.declarations.count <- start
            m.bound <- m.bound - 1u32
            return rec.id
    SpirvMod_PushRec(m.decls_index, SpirvDeclRecord(start, cand_len, new_id))
    return new_id

def SpirvMod_RtWords(result_type: u32) -> usize:
    if result_type != 0u32:
        return 1usize
    return 0usize

# Arity-specific declaration emitters (avoid darray-literal operands, which
# would require an active arena scope at every call site).
def SpirvMod_Decl0(m: mutable SpirvModule&, opcode: u16, result_type: u32) -> u32:
    rt: usize = SpirvMod_RtWords(result_type)
    start: usize = m.declarations.count
    id: u32 = SpirvMod_BeginDecl(m, opcode, result_type, (2usize + rt).u16())
    return SpirvMod_DedupDecl(m, start, id, rt)

def SpirvMod_Decl1(m: mutable SpirvModule&, opcode: u16, result_type: u32, a: u32) -> u32:
    rt: usize = SpirvMod_RtWords(result_type)
    start: usize = m.declarations.count
    id: u32 = SpirvMod_BeginDecl(m, opcode, result_type, (3usize + rt).u16())
    SpirvMod_Push(m.declarations, a)
    return SpirvMod_DedupDecl(m, start, id, rt)

def SpirvMod_Decl2(m: mutable SpirvModule&, opcode: u16, result_type: u32, a: u32, b: u32) -> u32:
    rt: usize = SpirvMod_RtWords(result_type)
    start: usize = m.declarations.count
    id: u32 = SpirvMod_BeginDecl(m, opcode, result_type, (4usize + rt).u16())
    SpirvMod_Push(m.declarations, a)
    SpirvMod_Push(m.declarations, b)
    return SpirvMod_DedupDecl(m, start, id, rt)

def SpirvMod_Decl4(m: mutable SpirvModule&, opcode: u16, result_type: u32, a: u32, b: u32, c: u32, d: u32) -> u32:
    rt: usize = SpirvMod_RtWords(result_type)
    start: usize = m.declarations.count
    id: u32 = SpirvMod_BeginDecl(m, opcode, result_type, (6usize + rt).u16())
    SpirvMod_Push(m.declarations, a)
    SpirvMod_Push(m.declarations, b)
    SpirvMod_Push(m.declarations, c)
    SpirvMod_Push(m.declarations, d)
    return SpirvMod_DedupDecl(m, start, id, rt)

# --- Type declarations (no result-type word; deduped). ---
def SpirvModule_TypeVoid(m: mutable SpirvModule&) -> u32:
    return SpirvMod_Decl0(m, SPIRV_OP_TYPE_VOID, 0u32)

def SpirvModule_TypeBool(m: mutable SpirvModule&) -> u32:
    return SpirvMod_Decl0(m, SPIRV_OP_TYPE_BOOL, 0u32)

def SpirvModule_TypeInt(m: mutable SpirvModule&, width: u32, signedness: u32) -> u32:
    return SpirvMod_Decl2(m, SPIRV_OP_TYPE_INT, 0u32, width, signedness)

def SpirvModule_TypeFloat(m: mutable SpirvModule&, width: u32) -> u32:
    return SpirvMod_Decl1(m, SPIRV_OP_TYPE_FLOAT, 0u32, width)

def SpirvModule_TypeVector(m: mutable SpirvModule&, component_type: u32, count: u32) -> u32:
    return SpirvMod_Decl2(m, SPIRV_OP_TYPE_VECTOR, 0u32, component_type, count)

def SpirvModule_TypePointer(m: mutable SpirvModule&, storage_class: u32, type_id: u32) -> u32:
    return SpirvMod_Decl2(m, SPIRV_OP_TYPE_POINTER, 0u32, storage_class, type_id)

def SpirvModule_TypeStruct2(m: mutable SpirvModule&, a: u32, b: u32) -> u32:
    return SpirvMod_Decl2(m, SPIRV_OP_TYPE_STRUCT, 0u32, a, b)

# --- Constant declarations (result-type word present; deduped). ---
def SpirvModule_ConstantTrue(m: mutable SpirvModule&, type_id: u32) -> u32:
    return SpirvMod_Decl0(m, SPIRV_OP_CONSTANT_TRUE, type_id)

def SpirvModule_ConstantFalse(m: mutable SpirvModule&, type_id: u32) -> u32:
    return SpirvMod_Decl0(m, SPIRV_OP_CONSTANT_FALSE, type_id)

def SpirvModule_Constant32(m: mutable SpirvModule&, type_id: u32, value: u32) -> u32:
    return SpirvMod_Decl1(m, SPIRV_OP_CONSTANT, type_id, value)

def SpirvModule_ConstantComposite4(m: mutable SpirvModule&, type_id: u32, a: u32, b: u32, c: u32, d: u32) -> u32:
    return SpirvMod_Decl4(m, SPIRV_OP_CONSTANT_COMPOSITE, type_id, a, b, c, d)

# --- Capabilities / ext-inst imports. ---
def SpirvModule_AddCapability(m: mutable SpirvModule&, capability: u32) -> void:
    SpirvMod_Push(m.capabilities, capability)

# OpExtInstImport: <ResultId> <Name...>. The name is passed pre-packed into
# little-endian words; returns the import's result id.
def SpirvModule_AddExtInstImport(m: mutable SpirvModule&, name_words: darray[u32]) -> u32:
    id: u32 = SpirvModule_AllocId(m)
    word_count: u16 = (2usize + name_words.count).u16()
    SpirvMod_Push(m.ext_inst_imports, SpirvWord(SPIRV_OP_EXT_INST_IMPORT, word_count))
    SpirvMod_Push(m.ext_inst_imports, id)
    for i in 0..<name_words.count:
        SpirvMod_Push(m.ext_inst_imports, name_words[i])
    return id

# --- Function-body emission (the `code` stream; no dedup). ---
def SpirvModule_EmitCodeBinary(m: mutable SpirvModule&, opcode: u16, result_type: u32, lhs: u32, rhs: u32) -> u32:
    result_id: u32 = SpirvModule_AllocId(m)
    SpirvMod_Push(m.code, SpirvWord(opcode, 5u16))
    SpirvMod_Push(m.code, result_type)
    SpirvMod_Push(m.code, result_id)
    SpirvMod_Push(m.code, lhs)
    SpirvMod_Push(m.code, rhs)
    return result_id

# Assemble: header + sections in canonical SPIR-V order (mirrors Module::Assemble).
def SpirvModule_Assemble(m: SpirvModule) -> darray[u32]:
    out: mutable darray[u32] = zeroed
    SpirvMod_Push(out, SPIRV_MAGIC)
    SpirvMod_Push(out, m.version)
    SpirvMod_Push(out, SPIRV_GENERATOR_SHADPS4_ELISA)
    SpirvMod_Push(out, m.bound + 1u32)
    SpirvMod_Push(out, SPIRV_SCHEMA_RESERVED)
    for i in 0..<m.capabilities.count:
        SpirvMod_Push(out, SpirvWord(SPIRV_OP_CAPABILITY, 2u16))
        SpirvMod_Push(out, m.capabilities[i])
    SpirvMod_AppendStream(out, m.ext_inst_imports)
    SpirvMod_Push(out, SpirvWord(SPIRV_OP_MEMORY_MODEL, 3u16))
    SpirvMod_Push(out, m.addressing_model)
    SpirvMod_Push(out, m.memory_model)
    SpirvMod_AppendStream(out, m.entry_points)
    SpirvMod_AppendStream(out, m.execution_modes)
    SpirvMod_AppendStream(out, m.debug)
    SpirvMod_AppendStream(out, m.annotations)
    SpirvMod_AppendStream(out, m.declarations)
    SpirvMod_AppendStream(out, m.global_variables)
    SpirvMod_AppendStream(out, m.code)
    return out

def SpirvBackend_EmitWordsViaFfi(profile: void&?, runtime_info: void&?, program: void&?, bindings: mutable void&?, out_words: mutable void&?, out_word_count: mutable usize&) -> int:
    return elisa_spirv_backend_emit_words(profile, runtime_info, program, bindings, out_words, out_word_count)

def SpirvBackend_EmitAuxTessWordsViaFfi(aux_type: u32, vs_info: void&?, fs_info: void&?, out_words: mutable void&?, out_word_count: mutable usize&) -> int:
    return elisa_spirv_backend_emit_aux_tess_words(aux_type, vs_info, fs_info, out_words, out_word_count)

def SpirvBackend_FreeWordsViaFfi(words: mutable void&?) -> void:
    elisa_spirv_backend_free_words(words)

def SpirvEmitMinimalModule(binding: mutable ShaderBackendBindings&) -> SpirvEmitResult:
    ctx: mutable SpirvEmitContext = SpirvEmitContext_Default()
    SpirvEmitContext_DefineArithmeticTypes(ctx)
    _unified: u32 = ShaderBackendBindings_AllocateUnified(binding)
    _buffer: u32 = ShaderBackendBindings_AllocateBuffer(binding)
    can Memory.Allocate, Abort.Panic:
        SpirvEmitHeader(ctx)
    return SpirvEmitResult(ctx.words, ctx.next_id, true)
