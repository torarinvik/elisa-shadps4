    return SpirvEmitBufferAtomicU32(ctx, SPIRV_OP_ATOMIC_I_SUB, handle, address, value, false)

def SpirvEmitBufferAtomicSMin32(ctx: mutable SpirvEmitContext&, handle: u32, address: u32, value: u32) -> u32:
    return SpirvEmitBufferAtomicU32(ctx, SPIRV_OP_ATOMIC_S_MIN, handle, address, value, false)

def SpirvEmitBufferAtomicSMin64(ctx: mutable SpirvEmitContext&, handle: u32, address: u32, value: u32) -> u32:
