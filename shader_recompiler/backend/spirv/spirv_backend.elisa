    return SpirvEmitUnaryOp(ctx, SPIRV_OP_CONVERT_U_TO_F, ctx.f64_id, value)

def SpirvEmitConvertF64U64(ctx: mutable SpirvEmitContext&, value: u32) -> u32:
    return SpirvEmitUnaryOp(ctx, SPIRV_OP_CONVERT_U_TO_F, ctx.f64_id, value)

# emit_spirv_special.cpp: zero-operand void instructions (1 word).
def SpirvEmitVoidOp(ctx: mutable SpirvEmitContext&, opcode: u16) -> void:
    SpirvEmitContext_AppendWord(ctx, SpirvWord(opcode, 1u16))

# EmitDiscard: OpDemoteToHelperInvocationEXT.
def SpirvEmitDiscard(ctx: mutable SpirvEmitContext&) -> void:
    SpirvEmitVoidOp(ctx, SPIRV_OP_DEMOTE_TO_HELPER_INVOCATION)

# EmitEmitVertex / EmitEmitPrimitive: geometry-shader stream control.
def SpirvEmitEmitVertex(ctx: mutable SpirvEmitContext&) -> void:
    SpirvEmitVoidOp(ctx, SPIRV_OP_EMIT_VERTEX)

def SpirvEmitEmitPrimitive(ctx: mutable SpirvEmitContext&) -> void:
    SpirvEmitVoidOp(ctx, SPIRV_OP_END_PRIMITIVE)

# OpLabel <ResultId> (2 words). Begins a basic block; tracks last_label.
def SpirvEmitLabel(ctx: mutable SpirvEmitContext&, label_id: u32) -> void:
    SpirvEmitContext_AppendWord(ctx, SpirvWord(SPIRV_OP_LABEL, 2u16))
    SpirvEmitContext_AppendWord(ctx, label_id)
    ctx.last_label <- label_id

# OpBranch <TargetLabel> (2 words).
def SpirvEmitBranch(ctx: mutable SpirvEmitContext&, target: u32) -> void:
    SpirvEmitContext_AppendWord(ctx, SpirvWord(SPIRV_OP_BRANCH, 2u16))
    SpirvEmitContext_AppendWord(ctx, target)

# OpSelectionMerge <MergeBlock> <SelectionControl> (3 words).
def SpirvEmitSelectionMerge(ctx: mutable SpirvEmitContext&, merge_block: u32, control: u32) -> void:
    SpirvEmitContext_AppendWord(ctx, SpirvWord(SPIRV_OP_SELECTION_MERGE, 3u16))
    SpirvEmitContext_AppendWord(ctx, merge_block)
    SpirvEmitContext_AppendWord(ctx, control)

# OpBranchConditional <Condition> <TrueLabel> <FalseLabel> (4 words).
def SpirvEmitBranchConditional(ctx: mutable SpirvEmitContext&, condition: u32, true_label: u32, false_label: u32) -> void:
    SpirvEmitContext_AppendWord(ctx, SpirvWord(SPIRV_OP_BRANCH_CONDITIONAL, 4u16))
    SpirvEmitContext_AppendWord(ctx, condition)
    SpirvEmitContext_AppendWord(ctx, true_label)
    SpirvEmitContext_AppendWord(ctx, false_label)

# EmitDiscardCond: guarded demote-to-helper. Reserves a kill and merge block,
# emits a selection-merge + conditional branch, then demotes inside the kill
# block before falling through to the merge block.
def SpirvEmitDiscardCond(ctx: mutable SpirvEmitContext&, condition: u32) -> void:
    kill_label: u32 = SpirvEmitContext_AllocateId(ctx)
    merge_label: u32 = SpirvEmitContext_AllocateId(ctx)
    SpirvEmitSelectionMerge(ctx, merge_label, SPIRV_SELECTION_CONTROL_NONE)
    SpirvEmitBranchConditional(ctx, condition, kill_label, merge_label)
    SpirvEmitLabel(ctx, kill_label)
    SpirvEmitDiscard(ctx)
    SpirvEmitBranch(ctx, merge_label)
    SpirvEmitLabel(ctx, merge_label)

def SpirvBackend_EmitWordsViaFfi(profile: void&?, runtime_info: void&?, program: void&?, bindings: mutable void&?, out_words: mutable void&?, out_word_count: mutable usize&) -> int:
    return elisa_spirv_backend_emit_words(profile, runtime_info, program, bindings, out_words, out_word_count)

def SpirvBackend_EmitAuxTessWordsViaFfi(aux_type: u32, vs_info: void&?, fs_info: void&?, out_words: mutable void&?, out_word_count: mutable usize&) -> int:
    return elisa_spirv_backend_emit_aux_tess_words(aux_type, vs_info, fs_info, out_words, out_word_count)

def SpirvBackend_FreeWordsViaFfi(words: mutable void&?) -> void:
    elisa_spirv_backend_free_words(words)

def SpirvEmitMinimalModule(binding: mutable ShaderBackendBindings&) -> SpirvEmitResult:
    ctx: mutable SpirvEmitContext = SpirvEmitContext_Default()
    SpirvEmitContext_DefineArithmeticTypes(ctx)
    _unified: u32 = ShaderBackendBindings_AllocateUnified(binding)
    _buffer: u32 = ShaderBackendBindings_AllocateBuffer(binding)
    can Memory.Allocate, Abort.Panic:
        SpirvEmitHeader(ctx)
    return SpirvEmitResult(ctx.words, ctx.next_id, true)
