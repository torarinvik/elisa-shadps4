def SpirvEmitFOrdGreaterThan(ctx: mutable SpirvEmitContext&, lhs: u32, rhs: u32) -> u32:
    return SpirvEmitBinaryOp(ctx, SPIRV_OP_F_ORD_GREATER_THAN, ctx.u1_id, lhs, rhs)

def SpirvEmitFUnordGreaterThan(ctx: mutable SpirvEmitContext&, lhs: u32, rhs: u32) -> u32:
    return SpirvEmitBinaryOp(ctx, SPIRV_OP_F_UNORD_GREATER_THAN, ctx.u1_id, lhs, rhs)

def SpirvEmitFOrdLessThanEqual(ctx: mutable SpirvEmitContext&, lhs: u32, rhs: u32) -> u32:
    return SpirvEmitBinaryOp(ctx, SPIRV_OP_F_ORD_LESS_THAN_EQUAL, ctx.u1_id, lhs, rhs)

def SpirvEmitFUnordLessThanEqual(ctx: mutable SpirvEmitContext&, lhs: u32, rhs: u32) -> u32:
    return SpirvEmitBinaryOp(ctx, SPIRV_OP_F_UNORD_LESS_THAN_EQUAL, ctx.u1_id, lhs, rhs)

def SpirvEmitFOrdGreaterThanEqual(ctx: mutable SpirvEmitContext&, lhs: u32, rhs: u32) -> u32:
    return SpirvEmitBinaryOp(ctx, SPIRV_OP_F_ORD_GREATER_THAN_EQUAL, ctx.u1_id, lhs, rhs)

def SpirvEmitFUnordGreaterThanEqual(ctx: mutable SpirvEmitContext&, lhs: u32, rhs: u32) -> u32:
    return SpirvEmitBinaryOp(ctx, SPIRV_OP_F_UNORD_GREATER_THAN_EQUAL, ctx.u1_id, lhs, rhs)

def SpirvEmitFPIsNan(ctx: mutable SpirvEmitContext&, value: u32) -> u32:
    return SpirvEmitUnaryOp(ctx, SPIRV_OP_IS_NAN, ctx.u1_id, value)

def SpirvEmitFPIsInf(ctx: mutable SpirvEmitContext&, value: u32) -> u32:
    return SpirvEmitUnaryOp(ctx, SPIRV_OP_IS_INF, ctx.u1_id, value)

# Generic quaternary op: <ResultType> <ResultId> <Op1>..<Op4> (7 words).
def SpirvEmitQuaternaryOp(ctx: mutable SpirvEmitContext&, opcode: u16, result_type: u32, a: u32, b: u32, c: u32, d: u32) -> u32:
    result_id: u32 = SpirvEmitContext_AllocateId(ctx)
    SpirvEmitContext_AppendWord(ctx, SpirvWord(opcode, 7u16))
    SpirvEmitContext_AppendWord(ctx, result_type)
    SpirvEmitContext_AppendWord(ctx, result_id)
    SpirvEmitContext_AppendWord(ctx, a)
    SpirvEmitContext_AppendWord(ctx, b)
    SpirvEmitContext_AppendWord(ctx, c)
    SpirvEmitContext_AppendWord(ctx, d)
    return result_id

# emit_spirv_integer.cpp: 32-bit integer arithmetic (U32 result type).
def SpirvEmitIAdd32(ctx: mutable SpirvEmitContext&, a: u32, b: u32) -> u32:
    return SpirvEmitBinaryOp(ctx, SPIRV_OP_I_ADD, ctx.u32_id, a, b)

def SpirvEmitISub32(ctx: mutable SpirvEmitContext&, a: u32, b: u32) -> u32:
