# OpCompositeConstruct: <ResultType> <ResultId> <Constituents...>. Word count
# is 3 + constituent count. The C++ uses ConstantComposite when all args are
# immediates; this models the runtime (non-constant) OpCompositeConstruct path.
def SpirvEmitCompositeConstruct2(ctx: mutable SpirvEmitContext&, result_type: u32, e1: u32, e2: u32) -> u32:
    result_id: u32 = SpirvEmitContext_AllocateId(ctx)
    SpirvEmitContext_AppendWord(ctx, SpirvWord(SPIRV_OP_COMPOSITE_CONSTRUCT, 5u16))
    SpirvEmitContext_AppendWord(ctx, result_type)
    SpirvEmitContext_AppendWord(ctx, result_id)
    SpirvEmitContext_AppendWord(ctx, e1)
    SpirvEmitContext_AppendWord(ctx, e2)
    return result_id

def SpirvEmitCompositeConstruct3(ctx: mutable SpirvEmitContext&, result_type: u32, e1: u32, e2: u32, e3: u32) -> u32:
    result_id: u32 = SpirvEmitContext_AllocateId(ctx)
    SpirvEmitContext_AppendWord(ctx, SpirvWord(SPIRV_OP_COMPOSITE_CONSTRUCT, 6u16))
    SpirvEmitContext_AppendWord(ctx, result_type)
    SpirvEmitContext_AppendWord(ctx, result_id)
    SpirvEmitContext_AppendWord(ctx, e1)
    SpirvEmitContext_AppendWord(ctx, e2)
    SpirvEmitContext_AppendWord(ctx, e3)
    return result_id

def SpirvEmitCompositeConstruct4(ctx: mutable SpirvEmitContext&, result_type: u32, e1: u32, e2: u32, e3: u32, e4: u32) -> u32:
    result_id: u32 = SpirvEmitContext_AllocateId(ctx)
    SpirvEmitContext_AppendWord(ctx, SpirvWord(SPIRV_OP_COMPOSITE_CONSTRUCT, 7u16))
    SpirvEmitContext_AppendWord(ctx, result_type)
    SpirvEmitContext_AppendWord(ctx, result_id)
    SpirvEmitContext_AppendWord(ctx, e1)
    SpirvEmitContext_AppendWord(ctx, e2)
    SpirvEmitContext_AppendWord(ctx, e3)
    SpirvEmitContext_AppendWord(ctx, e4)
    return result_id

# OpCompositeExtract: <ResultType> <ResultId> <Composite> <Index> (5 words).
def SpirvEmitCompositeExtract(ctx: mutable SpirvEmitContext&, result_type: u32, composite: u32, index: u32) -> u32:
    result_id: u32 = SpirvEmitContext_AllocateId(ctx)
    SpirvEmitContext_AppendWord(ctx, SpirvWord(SPIRV_OP_COMPOSITE_EXTRACT, 5u16))
    SpirvEmitContext_AppendWord(ctx, result_type)
    SpirvEmitContext_AppendWord(ctx, result_id)
    SpirvEmitContext_AppendWord(ctx, composite)
    SpirvEmitContext_AppendWord(ctx, index)
    return result_id

# OpCompositeInsert: <ResultType> <ResultId> <Object> <Composite> <Index> (6 words).
def SpirvEmitCompositeInsert(ctx: mutable SpirvEmitContext&, result_type: u32, object: u32, composite: u32, index: u32) -> u32:
    result_id: u32 = SpirvEmitContext_AllocateId(ctx)
    SpirvEmitContext_AppendWord(ctx, SpirvWord(SPIRV_OP_COMPOSITE_INSERT, 6u16))
    SpirvEmitContext_AppendWord(ctx, result_type)
    SpirvEmitContext_AppendWord(ctx, result_id)
    SpirvEmitContext_AppendWord(ctx, object)
    SpirvEmitContext_AppendWord(ctx, composite)
    SpirvEmitContext_AppendWord(ctx, index)
    return result_id

# OpVectorShuffle: <ResultType> <ResultId> <Vec1> <Vec2> <Components...>.
# Word count is 5 + component count.
def SpirvEmitVectorShuffle2(ctx: mutable SpirvEmitContext&, result_type: u32, v1: u32, v2: u32, c0: u32, c1: u32) -> u32:
    result_id: u32 = SpirvEmitContext_AllocateId(ctx)
    SpirvEmitContext_AppendWord(ctx, SpirvWord(SPIRV_OP_VECTOR_SHUFFLE, 7u16))
    SpirvEmitContext_AppendWord(ctx, result_type)
    SpirvEmitContext_AppendWord(ctx, result_id)
    SpirvEmitContext_AppendWord(ctx, v1)
    SpirvEmitContext_AppendWord(ctx, v2)
    SpirvEmitContext_AppendWord(ctx, c0)
    SpirvEmitContext_AppendWord(ctx, c1)
    return result_id

def SpirvEmitVectorShuffle3(ctx: mutable SpirvEmitContext&, result_type: u32, v1: u32, v2: u32, c0: u32, c1: u32, c2: u32) -> u32:
    result_id: u32 = SpirvEmitContext_AllocateId(ctx)
    SpirvEmitContext_AppendWord(ctx, SpirvWord(SPIRV_OP_VECTOR_SHUFFLE, 8u16))
    SpirvEmitContext_AppendWord(ctx, result_type)
    SpirvEmitContext_AppendWord(ctx, result_id)
    SpirvEmitContext_AppendWord(ctx, v1)
    SpirvEmitContext_AppendWord(ctx, v2)
    SpirvEmitContext_AppendWord(ctx, c0)
    SpirvEmitContext_AppendWord(ctx, c1)
    SpirvEmitContext_AppendWord(ctx, c2)
    return result_id

def SpirvEmitVectorShuffle4(ctx: mutable SpirvEmitContext&, result_type: u32, v1: u32, v2: u32, c0: u32, c1: u32, c2: u32, c3: u32) -> u32:
    result_id: u32 = SpirvEmitContext_AllocateId(ctx)
    SpirvEmitContext_AppendWord(ctx, SpirvWord(SPIRV_OP_VECTOR_SHUFFLE, 9u16))
    SpirvEmitContext_AppendWord(ctx, result_type)
    SpirvEmitContext_AppendWord(ctx, result_id)
    SpirvEmitContext_AppendWord(ctx, v1)
    SpirvEmitContext_AppendWord(ctx, v2)
    SpirvEmitContext_AppendWord(ctx, c0)
    SpirvEmitContext_AppendWord(ctx, c1)
    SpirvEmitContext_AppendWord(ctx, c2)
    SpirvEmitContext_AppendWord(ctx, c3)
    return result_id

# Typed U32 vector composites.
def SpirvEmitCompositeConstructU32x2(ctx: mutable SpirvEmitContext&, e1: u32, e2: u32) -> u32:
    return SpirvEmitCompositeConstruct2(ctx, ctx.u32x2_id, e1, e2)

def SpirvEmitCompositeConstructU32x3(ctx: mutable SpirvEmitContext&, e1: u32, e2: u32, e3: u32) -> u32:
    return SpirvEmitCompositeConstruct3(ctx, ctx.u32x3_id, e1, e2, e3)

def SpirvEmitCompositeConstructU32x4(ctx: mutable SpirvEmitContext&, e1: u32, e2: u32, e3: u32, e4: u32) -> u32:
    return SpirvEmitCompositeConstruct4(ctx, ctx.u32x4_id, e1, e2, e3, e4)

def SpirvEmitCompositeExtractU32(ctx: mutable SpirvEmitContext&, composite: u32, index: u32) -> u32:
    return SpirvEmitCompositeExtract(ctx, ctx.u32_id, composite, index)

def SpirvEmitCompositeInsertU32x2(ctx: mutable SpirvEmitContext&, composite: u32, object: u32, index: u32) -> u32:
    return SpirvEmitCompositeInsert(ctx, ctx.u32x2_id, object, composite, index)

def SpirvEmitCompositeInsertU32x4(ctx: mutable SpirvEmitContext&, composite: u32, object: u32, index: u32) -> u32:
    return SpirvEmitCompositeInsert(ctx, ctx.u32x4_id, object, composite, index)

# Typed F32 vector composites.
def SpirvEmitCompositeConstructF32x2(ctx: mutable SpirvEmitContext&, e1: u32, e2: u32) -> u32:
    return SpirvEmitCompositeConstruct2(ctx, ctx.f32x2_id, e1, e2)

def SpirvEmitCompositeConstructF32x3(ctx: mutable SpirvEmitContext&, e1: u32, e2: u32, e3: u32) -> u32:
    return SpirvEmitCompositeConstruct3(ctx, ctx.f32x3_id, e1, e2, e3)

def SpirvEmitCompositeConstructF32x4(ctx: mutable SpirvEmitContext&, e1: u32, e2: u32, e3: u32, e4: u32) -> u32:
    return SpirvEmitCompositeConstruct4(ctx, ctx.f32x4_id, e1, e2, e3, e4)

def SpirvEmitCompositeExtractF32(ctx: mutable SpirvEmitContext&, composite: u32, index: u32) -> u32:
    return SpirvEmitCompositeExtract(ctx, ctx.f32_id, composite, index)

def SpirvEmitCompositeInsertF32x4(ctx: mutable SpirvEmitContext&, composite: u32, object: u32, index: u32) -> u32:
    return SpirvEmitCompositeInsert(ctx, ctx.f32x4_id, object, composite, index)

def SpirvEmitCompositeShuffleF32x4(ctx: mutable SpirvEmitContext&, c1: u32, c2: u32, comp0: u32, comp1: u32, comp2: u32, comp3: u32) -> u32:
    return SpirvEmitVectorShuffle4(ctx, ctx.f32x4_id, c1, c2, comp0, comp1, comp2, comp3)

# ------------------------------------------------------------
# emit_spirv_integer.cpp completions: 64-bit ops + extended multiply / 64-bit
# bit-scan decompositions (now that u64 and the result struct types exist).
# ------------------------------------------------------------

def SpirvEmitIAdd64(ctx: mutable SpirvEmitContext&, a: u32, b: u32) -> u32:
    return SpirvEmitBinaryOp(ctx, SPIRV_OP_I_ADD, ctx.u64_id, a, b)

def SpirvEmitISub64(ctx: mutable SpirvEmitContext&, a: u32, b: u32) -> u32:
    return SpirvEmitBinaryOp(ctx, SPIRV_OP_I_SUB, ctx.u64_id, a, b)

def SpirvEmitIMul64(ctx: mutable SpirvEmitContext&, a: u32, b: u32) -> u32:
    return SpirvEmitBinaryOp(ctx, SPIRV_OP_I_MUL, ctx.u64_id, a, b)

def SpirvEmitINeg64(ctx: mutable SpirvEmitContext&, value: u32) -> u32:
    return SpirvEmitUnaryOp(ctx, SPIRV_OP_S_NEGATE, ctx.u64_id, value)

def SpirvEmitShiftLeftLogical64(ctx: mutable SpirvEmitContext&, base: u32, shift: u32) -> u32:
    return SpirvEmitBinaryOp(ctx, SPIRV_OP_SHIFT_LEFT_LOGICAL, ctx.u64_id, base, shift)

def SpirvEmitShiftRightLogical64(ctx: mutable SpirvEmitContext&, base: u32, shift: u32) -> u32:
    return SpirvEmitBinaryOp(ctx, SPIRV_OP_SHIFT_RIGHT_LOGICAL, ctx.u64_id, base, shift)

def SpirvEmitShiftRightArithmetic64(ctx: mutable SpirvEmitContext&, base: u32, shift: u32) -> u32:
    return SpirvEmitBinaryOp(ctx, SPIRV_OP_SHIFT_RIGHT_ARITHMETIC, ctx.u64_id, base, shift)

def SpirvEmitBitwiseAnd64(ctx: mutable SpirvEmitContext&, a: u32, b: u32) -> u32:
    return SpirvEmitBinaryOp(ctx, SPIRV_OP_BITWISE_AND, ctx.u64_id, a, b)

def SpirvEmitBitwiseOr64(ctx: mutable SpirvEmitContext&, a: u32, b: u32) -> u32:
    return SpirvEmitBinaryOp(ctx, SPIRV_OP_BITWISE_OR, ctx.u64_id, a, b)

# EmitSMulHi: signed multiply-extended, take the high word and reinterpret U32.
def SpirvEmitSMulHi(ctx: mutable SpirvEmitContext&, a: u32, b: u32) -> u32:
    signed_a: u32 = SpirvEmitBitcast(ctx, ctx.s32_id, a)
    signed_b: u32 = SpirvEmitBitcast(ctx, ctx.s32_id, b)
    mul_ext: u32 = SpirvEmitBinaryOp(ctx, SPIRV_OP_S_MUL_EXTENDED, ctx.full_result_i32x2, signed_a, signed_b)
    signed_hi: u32 = SpirvEmitCompositeExtract(ctx, ctx.s32_id, mul_ext, 1u32)
    return SpirvEmitBitcast(ctx, ctx.u32_id, signed_hi)

# EmitUMulHi: unsigned multiply-extended, take the high word.
def SpirvEmitUMulHi(ctx: mutable SpirvEmitContext&, a: u32, b: u32) -> u32:
    mul_ext: u32 = SpirvEmitBinaryOp(ctx, SPIRV_OP_U_MUL_EXTENDED, ctx.full_result_u32x2, a, b)
    return SpirvEmitCompositeExtract(ctx, ctx.u32_id, mul_ext, 1u32)

# EmitIAddCarry32: add-with-carry, producing the {result, carry} struct.
def SpirvEmitIAddCarry32(ctx: mutable SpirvEmitContext&, a: u32, b: u32) -> u32:
    return SpirvEmitBinaryOp(ctx, SPIRV_OP_I_ADD_CARRY, ctx.full_result_u32x2, a, b)

# EmitBitCount64: Vulkan restricts bit ops to 32-bit; decompose into lo/hi and
# add the two 32-bit popcounts.
def SpirvEmitBitCount64(ctx: mutable SpirvEmitContext&, value: u32) -> u32:
    unpacked: u32 = SpirvEmitBitcast(ctx, ctx.u32x2_id, value)
    lo: u32 = SpirvEmitCompositeExtract(ctx, ctx.u32_id, unpacked, 0u32)
    hi: u32 = SpirvEmitCompositeExtract(ctx, ctx.u32_id, unpacked, 1u32)
    lo_count: u32 = SpirvEmitBitCount32(ctx, lo)
    hi_count: u32 = SpirvEmitBitCount32(ctx, hi)
    return SpirvEmitIAdd32(ctx, lo_count, hi_count)

# EmitFindUMsb64: decompose, find the MSB of the high word and shift, else the
# low word's MSB. (value == 0 is handled by the IR emitter.)
def SpirvEmitFindUMsb64(ctx: mutable SpirvEmitContext&, value: u32) -> u32:
    unpacked: u32 = SpirvEmitBitcast(ctx, ctx.u32x2_id, value)
    hi: u32 = SpirvEmitCompositeExtract(ctx, ctx.u32_id, unpacked, 1u32)
    lo: u32 = SpirvEmitCompositeExtract(ctx, ctx.u32_id, unpacked, 0u32)
    hi_msb: u32 = SpirvEmitFindUMsb32(ctx, hi)
    lo_msb: u32 = SpirvEmitFindUMsb32(ctx, lo)
    neg_one: u32 = SpirvEmitConstU32(ctx, 0xFFFFFFFFu32)
    found_hi: u32 = SpirvEmitINotEqual32(ctx, hi_msb, neg_one)
    thirty_two: u32 = SpirvEmitConstU32(ctx, 32u32)
    shifted_hi: u32 = SpirvEmitIAdd32(ctx, hi_msb, thirty_two)
    return SpirvEmitOpSelect(ctx, ctx.u32_id, found_hi, shifted_hi, lo_msb)

# EmitFindILsb64: decompose, prefer the low word's LSB, else the high word's.
def SpirvEmitFindILsb64(ctx: mutable SpirvEmitContext&, value: u32) -> u32:
    unpacked: u32 = SpirvEmitBitcast(ctx, ctx.u32x2_id, value)
    lo: u32 = SpirvEmitCompositeExtract(ctx, ctx.u32_id, unpacked, 0u32)
    hi: u32 = SpirvEmitCompositeExtract(ctx, ctx.u32_id, unpacked, 1u32)
    lo_lsb: u32 = SpirvEmitFindILsb32(ctx, lo)
    hi_lsb: u32 = SpirvEmitFindILsb32(ctx, hi)
    neg_one: u32 = SpirvEmitConstU32(ctx, 0xFFFFFFFFu32)
    found_lo: u32 = SpirvEmitINotEqual32(ctx, lo_lsb, neg_one)
    return SpirvEmitOpSelect(ctx, ctx.u32_id, found_lo, lo_lsb, hi_lsb)

# ------------------------------------------------------------
# emit_spirv_shared_memory.cpp: workgroup-memory load/store via OpAccessChain.
# ------------------------------------------------------------

# OpLoad: <ResultType> <ResultId> <Pointer> (4 words).
def SpirvEmitLoad(ctx: mutable SpirvEmitContext&, result_type: u32, pointer: u32) -> u32:
    return SpirvEmitUnaryOp(ctx, SPIRV_OP_LOAD, result_type, pointer)

# OpStore: <Pointer> <Object> (3 words, no result id).
def SpirvEmitStore(ctx: mutable SpirvEmitContext&, pointer: u32, value: u32) -> void:
    SpirvEmitContext_AppendWord(ctx, SpirvWord(SPIRV_OP_STORE, 3u16))
    SpirvEmitContext_AppendWord(ctx, pointer)
    SpirvEmitContext_AppendWord(ctx, value)

# OpAccessChain: <ResultType> <ResultId> <Base> <Indexes...>.
def SpirvEmitAccessChain1(ctx: mutable SpirvEmitContext&, result_type: u32, base: u32, index: u32) -> u32:
    result_id: u32 = SpirvEmitContext_AllocateId(ctx)
    SpirvEmitContext_AppendWord(ctx, SpirvWord(SPIRV_OP_ACCESS_CHAIN, 5u16))
    SpirvEmitContext_AppendWord(ctx, result_type)
    SpirvEmitContext_AppendWord(ctx, result_id)
    SpirvEmitContext_AppendWord(ctx, base)
    SpirvEmitContext_AppendWord(ctx, index)
    return result_id

def SpirvEmitAccessChain2(ctx: mutable SpirvEmitContext&, result_type: u32, base: u32, i0: u32, i1: u32) -> u32:
    result_id: u32 = SpirvEmitContext_AllocateId(ctx)
    SpirvEmitContext_AppendWord(ctx, SpirvWord(SPIRV_OP_ACCESS_CHAIN, 6u16))
    SpirvEmitContext_AppendWord(ctx, result_type)
    SpirvEmitContext_AppendWord(ctx, result_id)
    SpirvEmitContext_AppendWord(ctx, base)
    SpirvEmitContext_AppendWord(ctx, i0)
    SpirvEmitContext_AppendWord(ctx, i1)
    return result_id

# EmitContext::EmitSharedMemoryAccess: a multi-type shared block is a layout
# struct, so it needs the leading u32_zero member index; a single-type block
# is indexed directly.
def SpirvEmitSharedMemoryAccess(ctx: mutable SpirvEmitContext&, result_type: u32, shared_mem: u32, index: u32) -> u32:
    if ctx.shared_memory_is_layered:
        return SpirvEmitAccessChain2(ctx, result_type, shared_mem, ctx.u32_zero_value, index)
    return SpirvEmitAccessChain1(ctx, result_type, shared_mem, index)

# Load/Write shared U16/U32/U64: shift the byte offset to an element index,
# form the access chain, then load/store.
def SpirvEmitLoadSharedU16(ctx: mutable SpirvEmitContext&, offset: u32) -> u32:
    shift_id: u32 = SpirvEmitConstU32(ctx, 1u32)
    index: u32 = SpirvEmitShiftRightLogical32(ctx, offset, shift_id)
    pointer: u32 = SpirvEmitSharedMemoryAccess(ctx, ctx.shared_u16, ctx.shared_memory_u16, index)
    return SpirvEmitLoad(ctx, ctx.u16_id, pointer)

def SpirvEmitLoadSharedU32(ctx: mutable SpirvEmitContext&, offset: u32) -> u32:
    shift_id: u32 = SpirvEmitConstU32(ctx, 2u32)
    index: u32 = SpirvEmitShiftRightLogical32(ctx, offset, shift_id)
    pointer: u32 = SpirvEmitSharedMemoryAccess(ctx, ctx.shared_u32, ctx.shared_memory_u32, index)
    return SpirvEmitLoad(ctx, ctx.u32_id, pointer)

def SpirvEmitLoadSharedU64(ctx: mutable SpirvEmitContext&, offset: u32) -> u32:
    shift_id: u32 = SpirvEmitConstU32(ctx, 3u32)
    index: u32 = SpirvEmitShiftRightLogical32(ctx, offset, shift_id)
    pointer: u32 = SpirvEmitSharedMemoryAccess(ctx, ctx.shared_u64, ctx.shared_memory_u64, index)
    return SpirvEmitLoad(ctx, ctx.u64_id, pointer)

def SpirvEmitWriteSharedU16(ctx: mutable SpirvEmitContext&, offset: u32, value: u32) -> void:
    shift_id: u32 = SpirvEmitConstU32(ctx, 1u32)
    index: u32 = SpirvEmitShiftRightLogical32(ctx, offset, shift_id)
    pointer: u32 = SpirvEmitSharedMemoryAccess(ctx, ctx.shared_u16, ctx.shared_memory_u16, index)
    SpirvEmitStore(ctx, pointer, value)

def SpirvEmitWriteSharedU32(ctx: mutable SpirvEmitContext&, offset: u32, value: u32) -> void:
    shift_id: u32 = SpirvEmitConstU32(ctx, 2u32)
    index: u32 = SpirvEmitShiftRightLogical32(ctx, offset, shift_id)
    pointer: u32 = SpirvEmitSharedMemoryAccess(ctx, ctx.shared_u32, ctx.shared_memory_u32, index)
    SpirvEmitStore(ctx, pointer, value)

def SpirvEmitWriteSharedU64(ctx: mutable SpirvEmitContext&, offset: u32, value: u32) -> void:
    shift_id: u32 = SpirvEmitConstU32(ctx, 3u32)
    index: u32 = SpirvEmitShiftRightLogical32(ctx, offset, shift_id)
    pointer: u32 = SpirvEmitSharedMemoryAccess(ctx, ctx.shared_u64, ctx.shared_memory_u64, index)
    SpirvEmitStore(ctx, pointer, value)

# ------------------------------------------------------------
# emit_spirv_atomic.cpp (shared-memory atomics). Buffer/image atomics need the
# buffer/image context state and are deferred to that port.
# ------------------------------------------------------------

# Atomic binary op: <ResultType> <ResultId> <Pointer> <Scope> <Semantics>
# <Value> (7 words).
def SpirvEmitAtomicBinary(ctx: mutable SpirvEmitContext&, opcode: u16, result_type: u32, pointer: u32, scope: u32, semantics: u32, value: u32) -> u32:
    result_id: u32 = SpirvEmitContext_AllocateId(ctx)
    SpirvEmitContext_AppendWord(ctx, SpirvWord(opcode, 7u16))
    SpirvEmitContext_AppendWord(ctx, result_type)
    SpirvEmitContext_AppendWord(ctx, result_id)
    SpirvEmitContext_AppendWord(ctx, pointer)
    SpirvEmitContext_AppendWord(ctx, scope)
    SpirvEmitContext_AppendWord(ctx, semantics)
    SpirvEmitContext_AppendWord(ctx, value)
    return result_id

# Atomic increment/decrement: <ResultType> <ResultId> <Pointer> <Scope>
# <Semantics> (6 words).
def SpirvEmitAtomicIncDec(ctx: mutable SpirvEmitContext&, opcode: u16, result_type: u32, pointer: u32, scope: u32, semantics: u32) -> u32:
    result_id: u32 = SpirvEmitContext_AllocateId(ctx)
    SpirvEmitContext_AppendWord(ctx, SpirvWord(opcode, 6u16))
    SpirvEmitContext_AppendWord(ctx, result_type)
    SpirvEmitContext_AppendWord(ctx, result_id)
    SpirvEmitContext_AppendWord(ctx, pointer)
    SpirvEmitContext_AppendWord(ctx, scope)
    SpirvEmitContext_AppendWord(ctx, semantics)
    return result_id

# AtomicArgs: device scope (a fresh ConstU32) + the u32-zero semantics mask.
def SpirvEmitAtomicScope(ctx: mutable SpirvEmitContext&) -> u32:
    return SpirvEmitConstU32(ctx, SPIRV_SCOPE_DEVICE)

# Shared-memory atomic on a U32 element: shift offset to index, access chain,
# then the atomic op (device scope, relaxed semantics).
def SpirvEmitSharedAtomicU32(ctx: mutable SpirvEmitContext&, opcode: u16, offset: u32, value: u32) -> u32:
    shift_id: u32 = SpirvEmitConstU32(ctx, 2u32)
    index: u32 = SpirvEmitShiftRightLogical32(ctx, offset, shift_id)
    pointer: u32 = SpirvEmitSharedMemoryAccess(ctx, ctx.shared_u32, ctx.shared_memory_u32, index)
    atomic_scope: u32 = SpirvEmitAtomicScope(ctx)
    return SpirvEmitAtomicBinary(ctx, opcode, ctx.u32_id, pointer, atomic_scope, ctx.u32_zero_value, value)

def SpirvEmitSharedAtomicU64(ctx: mutable SpirvEmitContext&, opcode: u16, offset: u32, value: u32) -> u32:
    shift_id: u32 = SpirvEmitConstU32(ctx, 3u32)
    index: u32 = SpirvEmitShiftRightLogical32(ctx, offset, shift_id)
    pointer: u32 = SpirvEmitSharedMemoryAccess(ctx, ctx.shared_u64, ctx.shared_memory_u64, index)
    atomic_scope: u32 = SpirvEmitAtomicScope(ctx)
    return SpirvEmitAtomicBinary(ctx, opcode, ctx.u64_id, pointer, atomic_scope, ctx.u32_zero_value, value)

def SpirvEmitSharedAtomicU32IncDec(ctx: mutable SpirvEmitContext&, opcode: u16, offset: u32) -> u32:
    shift_id: u32 = SpirvEmitConstU32(ctx, 2u32)
    index: u32 = SpirvEmitShiftRightLogical32(ctx, offset, shift_id)
    pointer: u32 = SpirvEmitSharedMemoryAccess(ctx, ctx.shared_u32, ctx.shared_memory_u32, index)
    atomic_scope: u32 = SpirvEmitAtomicScope(ctx)
    return SpirvEmitAtomicIncDec(ctx, opcode, ctx.u32_id, pointer, atomic_scope, ctx.u32_zero_value)

def SpirvEmitSharedAtomicU64IncDec(ctx: mutable SpirvEmitContext&, opcode: u16, offset: u32) -> u32:
    shift_id: u32 = SpirvEmitConstU32(ctx, 3u32)
    index: u32 = SpirvEmitShiftRightLogical32(ctx, offset, shift_id)
    pointer: u32 = SpirvEmitSharedMemoryAccess(ctx, ctx.shared_u64, ctx.shared_memory_u64, index)
    atomic_scope: u32 = SpirvEmitAtomicScope(ctx)
    return SpirvEmitAtomicIncDec(ctx, opcode, ctx.u64_id, pointer, atomic_scope, ctx.u32_zero_value)

# The named shared-atomic emitters (32- and 64-bit), one per atomic opcode.
def SpirvEmitSharedAtomicIAdd32(ctx: mutable SpirvEmitContext&, offset: u32, value: u32) -> u32:
    return SpirvEmitSharedAtomicU32(ctx, SPIRV_OP_ATOMIC_I_ADD, offset, value)

def SpirvEmitSharedAtomicIAdd64(ctx: mutable SpirvEmitContext&, offset: u32, value: u32) -> u32:
    return SpirvEmitSharedAtomicU64(ctx, SPIRV_OP_ATOMIC_I_ADD, offset, value)

def SpirvEmitSharedAtomicISub32(ctx: mutable SpirvEmitContext&, offset: u32, value: u32) -> u32:
    return SpirvEmitSharedAtomicU32(ctx, SPIRV_OP_ATOMIC_I_SUB, offset, value)

def SpirvEmitSharedAtomicISub64(ctx: mutable SpirvEmitContext&, offset: u32, value: u32) -> u32:
    return SpirvEmitSharedAtomicU64(ctx, SPIRV_OP_ATOMIC_I_SUB, offset, value)

def SpirvEmitSharedAtomicSMin32(ctx: mutable SpirvEmitContext&, offset: u32, value: u32) -> u32:
    return SpirvEmitSharedAtomicU32(ctx, SPIRV_OP_ATOMIC_S_MIN, offset, value)

def SpirvEmitSharedAtomicSMin64(ctx: mutable SpirvEmitContext&, offset: u32, value: u32) -> u32:
    return SpirvEmitSharedAtomicU64(ctx, SPIRV_OP_ATOMIC_S_MIN, offset, value)

