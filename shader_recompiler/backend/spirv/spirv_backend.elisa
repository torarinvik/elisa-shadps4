# Image atomics: form an OpImageTexelPointer into the storage image, then atomic.
def SpirvEmitImageAtomicU32(ctx: mutable SpirvEmitContext&, opcode: u16, handle: u32, coords: u32, value: u32) -> u32:
    tex: SpirvTextureDefinition = ctx.images[(handle & 0xFFFFu32).usize()]
    sample0: u32 = SpirvEmitConstU32(ctx, 0u32)
    pointer: u32 = SpirvEmitTernaryOp(ctx, SPIRV_OP_IMAGE_TEXEL_POINTER, ctx.image_u32, tex.id, coords, sample0)
    atomic_scope: u32 = SpirvEmitAtomicScope(ctx)
    return SpirvEmitAtomicBinary(ctx, opcode, ctx.u32_id, pointer, atomic_scope, ctx.u32_zero_value, value)

def SpirvEmitImageAtomicU32CmpSwap(ctx: mutable SpirvEmitContext&, handle: u32, coords: u32, value: u32, cmp_value: u32) -> u32:
    tex: SpirvTextureDefinition = ctx.images[(handle & 0xFFFFu32).usize()]
    sample0: u32 = SpirvEmitConstU32(ctx, 0u32)
    pointer: u32 = SpirvEmitTernaryOp(ctx, SPIRV_OP_IMAGE_TEXEL_POINTER, ctx.image_u32, tex.id, coords, sample0)
    atomic_scope: u32 = SpirvEmitAtomicScope(ctx)
    return SpirvEmitAtomicCompareExchange(ctx, ctx.u32_id, pointer, atomic_scope, ctx.u32_zero_value, ctx.u32_zero_value, value, cmp_value)

def SpirvEmitImageAtomicIAdd32(ctx: mutable SpirvEmitContext&, handle: u32, coords: u32, value: u32) -> u32:
    return SpirvEmitImageAtomicU32(ctx, SPIRV_OP_ATOMIC_I_ADD, handle, coords, value)

def SpirvEmitImageAtomicSMin32(ctx: mutable SpirvEmitContext&, handle: u32, coords: u32, value: u32) -> u32:
    return SpirvEmitImageAtomicU32(ctx, SPIRV_OP_ATOMIC_S_MIN, handle, coords, value)

def SpirvEmitImageAtomicUMin32(ctx: mutable SpirvEmitContext&, handle: u32, coords: u32, value: u32) -> u32:
    return SpirvEmitImageAtomicU32(ctx, SPIRV_OP_ATOMIC_U_MIN, handle, coords, value)

def SpirvEmitImageAtomicSMax32(ctx: mutable SpirvEmitContext&, handle: u32, coords: u32, value: u32) -> u32:
    return SpirvEmitImageAtomicU32(ctx, SPIRV_OP_ATOMIC_S_MAX, handle, coords, value)

def SpirvEmitImageAtomicUMax32(ctx: mutable SpirvEmitContext&, handle: u32, coords: u32, value: u32) -> u32:
    return SpirvEmitImageAtomicU32(ctx, SPIRV_OP_ATOMIC_U_MAX, handle, coords, value)

def SpirvEmitImageAtomicAnd32(ctx: mutable SpirvEmitContext&, handle: u32, coords: u32, value: u32) -> u32:
    return SpirvEmitImageAtomicU32(ctx, SPIRV_OP_ATOMIC_AND, handle, coords, value)

def SpirvEmitImageAtomicOr32(ctx: mutable SpirvEmitContext&, handle: u32, coords: u32, value: u32) -> u32:
    return SpirvEmitImageAtomicU32(ctx, SPIRV_OP_ATOMIC_OR, handle, coords, value)

def SpirvEmitImageAtomicXor32(ctx: mutable SpirvEmitContext&, handle: u32, coords: u32, value: u32) -> u32:
    return SpirvEmitImageAtomicU32(ctx, SPIRV_OP_ATOMIC_XOR, handle, coords, value)

def SpirvEmitImageAtomicExchange32(ctx: mutable SpirvEmitContext&, handle: u32, coords: u32, value: u32) -> u32:
    return SpirvEmitImageAtomicU32(ctx, SPIRV_OP_ATOMIC_EXCHANGE, handle, coords, value)

# ------------------------------------------------------------
# emit_spirv_image.cpp emission primitives. The IR-driven offset/derivative
# resolution (ImageOperands::AddOffset reads IR::Value/Inst) and the named
# EmitImageSample* wrappers belong with the IR->SPIR-V dispatch port; these are
# the reusable, IR-independent emitters built on an explicit operand list.
# ------------------------------------------------------------

# ImageOperands: an accumulated operand-mask + trailing operand ids, mirroring
# the C++ ImageOperands helper.
struct SpirvImageOperands:
    mask: mutable u32
    operands: mutable darray[u32]

def SpirvImageOperands_Default() -> SpirvImageOperands:
    r: mutable SpirvImageOperands = zeroed
    return r

# Add a single operand under a mask bit (ignored when the value id is invalid).
def SpirvImageOperands_Add1(ops: mutable SpirvImageOperands&, mask_bit: u32, value: u32) -> void:
    if value != 0u32:
        ops.mask <- ops.mask | mask_bit
        can Memory.Allocate, Abort.Panic:
            owner: mutable Arena& = scratch_arena.ref[mutable Arena&]
            in owner:
                ops.operands.push(value)

# Add a paired operand (e.g. Grad dx/dy) under a mask bit.
def SpirvImageOperands_Add2(ops: mutable SpirvImageOperands&, mask_bit: u32, v1: u32, v2: u32) -> void:
    ops.mask <- ops.mask | mask_bit
    can Memory.Allocate, Abort.Panic:
        owner: mutable Arena& = scratch_arena.ref[mutable Arena&]
        in owner:
            ops.operands.push(v1)
            ops.operands.push(v2)

# Trailing word count contributed by the image operands (mask word + operands).
def SpirvImageOperands_TailWords(ops: SpirvImageOperands) -> usize:
    if ops.mask != 0u32:
        return 1usize + ops.operands.count
    return 0usize

def SpirvEmitImageOperandsTail(ctx: mutable SpirvEmitContext&, ops: SpirvImageOperands) -> void:
    if ops.mask != 0u32:
        SpirvEmitContext_AppendWord(ctx, ops.mask)
        for i in 0..<ops.operands.count:
            SpirvEmitContext_AppendWord(ctx, ops.operands[i])

# OpSampledImage: <ResultType> <ResultId> <Image> <Sampler> (5 words).
def SpirvEmitSampledImage(ctx: mutable SpirvEmitContext&, result_type: u32, image: u32, sampler: u32) -> u32:
    return SpirvEmitBinaryOp(ctx, SPIRV_OP_SAMPLED_IMAGE, result_type, image, sampler)

# OpImageSample{Implicit,Explicit}Lod: <ResultType> <ResultId> <SampledImage>
# <Coordinate> [<ImageOperands> <Operands...>] (5 + tail words).
def SpirvEmitImageSampleLod(ctx: mutable SpirvEmitContext&, opcode: u16, result_type: u32, sampled_image: u32, coords: u32, ops: SpirvImageOperands) -> u32:
    result_id: u32 = SpirvEmitContext_AllocateId(ctx)
    word_count: u16 = (5usize + SpirvImageOperands_TailWords(ops)).u16()
    SpirvEmitContext_AppendWord(ctx, SpirvWord(opcode, word_count))
    SpirvEmitContext_AppendWord(ctx, result_type)
    SpirvEmitContext_AppendWord(ctx, result_id)
    SpirvEmitContext_AppendWord(ctx, sampled_image)
    SpirvEmitContext_AppendWord(ctx, coords)
    SpirvEmitImageOperandsTail(ctx, ops)
    return result_id

def SpirvEmitImageSampleImplicitLod(ctx: mutable SpirvEmitContext&, result_type: u32, sampled_image: u32, coords: u32, ops: SpirvImageOperands) -> u32:
    return SpirvEmitImageSampleLod(ctx, SPIRV_OP_IMAGE_SAMPLE_IMPLICIT_LOD, result_type, sampled_image, coords, ops)

def SpirvEmitImageSampleExplicitLod(ctx: mutable SpirvEmitContext&, result_type: u32, sampled_image: u32, coords: u32, ops: SpirvImageOperands) -> u32:
    return SpirvEmitImageSampleLod(ctx, SPIRV_OP_IMAGE_SAMPLE_EXPLICIT_LOD, result_type, sampled_image, coords, ops)

# OpImageSampleDref{Implicit,Explicit}Lod: extra Dref operand before the mask.
def SpirvEmitImageSampleDrefLod(ctx: mutable SpirvEmitContext&, opcode: u16, result_type: u32, sampled_image: u32, coords: u32, dref: u32, ops: SpirvImageOperands) -> u32:
    result_id: u32 = SpirvEmitContext_AllocateId(ctx)
    word_count: u16 = (6usize + SpirvImageOperands_TailWords(ops)).u16()
    SpirvEmitContext_AppendWord(ctx, SpirvWord(opcode, word_count))
    SpirvEmitContext_AppendWord(ctx, result_type)
    SpirvEmitContext_AppendWord(ctx, result_id)
    SpirvEmitContext_AppendWord(ctx, sampled_image)
    SpirvEmitContext_AppendWord(ctx, coords)
    SpirvEmitContext_AppendWord(ctx, dref)
    SpirvEmitImageOperandsTail(ctx, ops)
    return result_id

# OpImageFetch / OpImageRead: <ResultType> <ResultId> <Image> <Coordinate>
# [<ImageOperands> <Operands...>] (5 + tail words).
def SpirvEmitImageFetchOrRead(ctx: mutable SpirvEmitContext&, opcode: u16, result_type: u32, image: u32, coords: u32, ops: SpirvImageOperands) -> u32:
    result_id: u32 = SpirvEmitContext_AllocateId(ctx)
    word_count: u16 = (5usize + SpirvImageOperands_TailWords(ops)).u16()
    SpirvEmitContext_AppendWord(ctx, SpirvWord(opcode, word_count))
    SpirvEmitContext_AppendWord(ctx, result_type)
    SpirvEmitContext_AppendWord(ctx, result_id)
    SpirvEmitContext_AppendWord(ctx, image)
    SpirvEmitContext_AppendWord(ctx, coords)
    SpirvEmitImageOperandsTail(ctx, ops)
    return result_id

def SpirvEmitImageFetch(ctx: mutable SpirvEmitContext&, result_type: u32, image: u32, coords: u32, ops: SpirvImageOperands) -> u32:
    return SpirvEmitImageFetchOrRead(ctx, SPIRV_OP_IMAGE_FETCH, result_type, image, coords, ops)

def SpirvEmitImageRead(ctx: mutable SpirvEmitContext&, result_type: u32, image: u32, coords: u32, ops: SpirvImageOperands) -> u32:
    return SpirvEmitImageFetchOrRead(ctx, SPIRV_OP_IMAGE_READ, result_type, image, coords, ops)

# OpImageWrite: <Image> <Coordinate> <Texel> [<ImageOperands> <Operands...>]
# (4 + tail words, no result id).
def SpirvEmitImageWrite(ctx: mutable SpirvEmitContext&, image: u32, coords: u32, texel: u32, ops: SpirvImageOperands) -> void:
    word_count: u16 = (4usize + SpirvImageOperands_TailWords(ops)).u16()
    SpirvEmitContext_AppendWord(ctx, SpirvWord(SPIRV_OP_IMAGE_WRITE, word_count))
    SpirvEmitContext_AppendWord(ctx, image)
    SpirvEmitContext_AppendWord(ctx, coords)
    SpirvEmitContext_AppendWord(ctx, texel)
    SpirvEmitImageOperandsTail(ctx, ops)

# OpImageGather: extra Component operand before the mask.
def SpirvEmitImageGather(ctx: mutable SpirvEmitContext&, result_type: u32, sampled_image: u32, coords: u32, component: u32, ops: SpirvImageOperands) -> u32:
    result_id: u32 = SpirvEmitContext_AllocateId(ctx)
    word_count: u16 = (6usize + SpirvImageOperands_TailWords(ops)).u16()
    SpirvEmitContext_AppendWord(ctx, SpirvWord(SPIRV_OP_IMAGE_GATHER, word_count))
    SpirvEmitContext_AppendWord(ctx, result_type)
    SpirvEmitContext_AppendWord(ctx, result_id)
    SpirvEmitContext_AppendWord(ctx, sampled_image)
    SpirvEmitContext_AppendWord(ctx, coords)
    SpirvEmitContext_AppendWord(ctx, component)
    SpirvEmitImageOperandsTail(ctx, ops)
    return result_id

# OpImageDrefGather: extra Dref operand before the mask.
def SpirvEmitImageDrefGather(ctx: mutable SpirvEmitContext&, result_type: u32, sampled_image: u32, coords: u32, dref: u32, ops: SpirvImageOperands) -> u32:
    result_id: u32 = SpirvEmitContext_AllocateId(ctx)
    word_count: u16 = (6usize + SpirvImageOperands_TailWords(ops)).u16()
    SpirvEmitContext_AppendWord(ctx, SpirvWord(SPIRV_OP_IMAGE_DREF_GATHER, word_count))
    SpirvEmitContext_AppendWord(ctx, result_type)
    SpirvEmitContext_AppendWord(ctx, result_id)
    SpirvEmitContext_AppendWord(ctx, sampled_image)
    SpirvEmitContext_AppendWord(ctx, coords)
    SpirvEmitContext_AppendWord(ctx, dref)
    SpirvEmitImageOperandsTail(ctx, ops)
    return result_id

# Image queries.
def SpirvEmitImageQuerySizeLod(ctx: mutable SpirvEmitContext&, result_type: u32, image: u32, lod: u32) -> u32:
    return SpirvEmitBinaryOp(ctx, SPIRV_OP_IMAGE_QUERY_SIZE_LOD, result_type, image, lod)

def SpirvEmitImageQuerySize(ctx: mutable SpirvEmitContext&, result_type: u32, image: u32) -> u32:
    return SpirvEmitUnaryOp(ctx, SPIRV_OP_IMAGE_QUERY_SIZE, result_type, image)

def SpirvEmitImageQueryLevels(ctx: mutable SpirvEmitContext&, result_type: u32, image: u32) -> u32:
    return SpirvEmitUnaryOp(ctx, SPIRV_OP_IMAGE_QUERY_LEVELS, result_type, image)

def SpirvEmitImageQueryLod(ctx: mutable SpirvEmitContext&, result_type: u32, sampled_image: u32, coords: u32) -> u32:
    return SpirvEmitBinaryOp(ctx, SPIRV_OP_IMAGE_QUERY_LOD, result_type, sampled_image, coords)

# ------------------------------------------------------------
# emit_spirv_convert.cpp: width/format conversions (all 4-word unary ops).
# ------------------------------------------------------------

# Anonymous-namespace narrowing helpers used to truncate before SToF/UToF.
def SpirvEmitExtractU16(ctx: mutable SpirvEmitContext&, value: u32) -> u32:
    return SpirvEmitUnaryOp(ctx, SPIRV_OP_U_CONVERT, ctx.u16_id, value)

def SpirvEmitExtractS16(ctx: mutable SpirvEmitContext&, value: u32) -> u32:
    return SpirvEmitUnaryOp(ctx, SPIRV_OP_S_CONVERT, ctx.s16_id, value)

def SpirvEmitExtractU8(ctx: mutable SpirvEmitContext&, value: u32) -> u32:
    return SpirvEmitUnaryOp(ctx, SPIRV_OP_U_CONVERT, ctx.u8_id, value)

def SpirvEmitExtractS8(ctx: mutable SpirvEmitContext&, value: u32) -> u32:
    return SpirvEmitUnaryOp(ctx, SPIRV_OP_S_CONVERT, ctx.s8_id, value)

# Float -> signed integer. S16 narrows through an intermediate FToS to U16.
def SpirvEmitConvertS16F32(ctx: mutable SpirvEmitContext&, value: u32) -> u32:
    return SpirvEmitUnaryOp(ctx, SPIRV_OP_S_CONVERT, ctx.u32_id, SpirvEmitUnaryOp(ctx, SPIRV_OP_CONVERT_F_TO_S, ctx.u16_id, value))

def SpirvEmitConvertS16F64(ctx: mutable SpirvEmitContext&, value: u32) -> u32:
    return SpirvEmitUnaryOp(ctx, SPIRV_OP_S_CONVERT, ctx.u32_id, SpirvEmitUnaryOp(ctx, SPIRV_OP_CONVERT_F_TO_S, ctx.u16_id, value))

