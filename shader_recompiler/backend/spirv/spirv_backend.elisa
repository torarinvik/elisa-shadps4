def SpirvEmitBufferAtomicSMax32(ctx: mutable SpirvEmitContext&, handle: u32, address: u32, value: u32) -> u32:
    return SpirvEmitBufferAtomicU32(ctx, SPIRV_OP_ATOMIC_S_MAX, handle, address, value, false)

def SpirvEmitBufferAtomicSMax64(ctx: mutable SpirvEmitContext&, handle: u32, address: u32, value: u32) -> u32:
