global mutable g_spirv_backend_use_ffi_bridge: bool = false

def SpirvBackend_SetUseFfiBridge(enabled: bool) -> void:
    g_spirv_backend_use_ffi_bridge <- enabled

struct SpirvVectorIds:
    ids: mutable u32[4]

# Mirrors Shader::Backend::SPIRV::EmitContext. The arithmetic type ids are
# allocated in exactly the order of EmitContext::DefineArithmeticTypes so that
# every downstream emit op references the same ids as the C++ backend. Emitting
# the OpType*/OpConstant declaration words is deferred to module assembly.
struct SpirvEmitContext:
    next_id: mutable u32
    last_label: mutable u32
    interfaces: mutable darray[u32]
    words: mutable darray[u32]
    # Feature flags (gate optional fp16/fp64/dma types, like Info::uses_*).
    uses_fp16: mutable bool
    uses_fp64: mutable bool
    uses_dma: mutable bool
    # Scalar types.
    void_id: mutable u32
    u1_id: mutable u32
    u8_id: mutable u32
    s8_id: mutable u32
    u16_id: mutable u32
    s16_id: mutable u32
    f16_id: mutable u32
    f64_id: mutable u32
    f32_id: mutable u32
    s32_id: mutable u32
    u32_id: mutable u32
    u64_id: mutable u32
    # Vector types (component counts 2..4).
    f16x2_id: mutable u32
    f16x3_id: mutable u32
    f16x4_id: mutable u32
    f64x2_id: mutable u32
    f64x3_id: mutable u32
    f64x4_id: mutable u32
    f32x2_id: mutable u32
    f32x3_id: mutable u32
    f32x4_id: mutable u32
    s32x2_id: mutable u32
    s32x3_id: mutable u32
    s32x4_id: mutable u32
    u32x2_id: mutable u32
    u32x3_id: mutable u32
    u32x4_id: mutable u32
    u1x2_id: mutable u32
    u1x3_id: mutable u32
    u1x4_id: mutable u32
    # Struct result types.
    full_result_i32x2: mutable u32
    full_result_u32x2: mutable u32
    frexp_result_f32: mutable u32
    frexp_result_f64: mutable u32
    # Common constants.
    pi_x2: mutable u32
    true_value: mutable u32
    false_value: mutable u32
    u8_one_value: mutable u32
    u8_zero_value: mutable u32
    u16_zero_value: mutable u32
    u32_one_value: mutable u32
    u32_zero_value: mutable u32
    f32_zero_value: mutable u32
    u64_one_value: mutable u32
    u64_zero_value: mutable u32
    # Pointer types for input/output scalars + physical storage.
    input_f32: mutable u32
    input_u32: mutable u32
    input_s32: mutable u32
    output_f32: mutable u32
    output_u32: mutable u32
    output_s32: mutable u32
    physical_pointer_type_u32: mutable u32
    # Misc imports / interface ids defined outside the arithmetic-type section.
    subgroup_local_invocation_id: mutable u32
    glsl_std_450_id: mutable u32

struct SpirvEmitResult:
    words: mutable darray[u32]
    bound: mutable u32
    ok: mutable bool

def SpirvVectorIds_Default() -> SpirvVectorIds:
    return SpirvVectorIds([0u32, 0u32, 0u32, 0u32])

def SpirvVectorIds_Get(vector: SpirvVectorIds, index: u32) -> u32:
    if index < 1u32 or index > 4u32:
        return SPIRV_INVALID_ID
    return vector.ids[(index - 1u32).usize()]

def SpirvVectorIds_Set(vector: mutable SpirvVectorIds&, index: u32, value: u32) -> bool:
    if index < 1u32 or index > 4u32:
        return false
    vector.ids[(index - 1u32).usize()] <- value
    return true

def SpirvGetInputPrimitiveExecutionMode(primitive_type: u32) -> u32:
    if g_spirv_backend_use_ffi_bridge:
        return elisa_spirv_backend_input_primitive_mode(primitive_type)
    if primitive_type == AMDGPU_PRIMITIVE_POINT_LIST:
        return SPIRV_EXECUTION_MODE_INPUT_POINTS
    if primitive_type == AMDGPU_PRIMITIVE_LINE_LIST or primitive_type == AMDGPU_PRIMITIVE_LINE_STRIP:
        return SPIRV_EXECUTION_MODE_INPUT_LINES
    if primitive_type == AMDGPU_PRIMITIVE_TRIANGLE_LIST or primitive_type == AMDGPU_PRIMITIVE_TRIANGLE_STRIP or primitive_type == AMDGPU_PRIMITIVE_RECT_LIST:
        return SPIRV_EXECUTION_MODE_TRIANGLES
    if primitive_type == AMDGPU_PRIMITIVE_ADJ_TRIANGLE_LIST:
        return SPIRV_EXECUTION_MODE_INPUT_TRIANGLES_ADJACENCY
    if primitive_type == AMDGPU_PRIMITIVE_ADJ_LINE_LIST:
        return SPIRV_EXECUTION_MODE_INPUT_LINES_ADJACENCY
    return 0u32

def SpirvGetOutputPrimitiveExecutionMode(output_type: u32) -> u32:
    if g_spirv_backend_use_ffi_bridge:
        return elisa_spirv_backend_output_primitive_mode(output_type)
    if output_type == AMDGPU_GS_OUTPUT_POINT_LIST:
        return SPIRV_EXECUTION_MODE_OUTPUT_VERTICES
    if output_type == AMDGPU_GS_OUTPUT_LINE_STRIP:
        return SPIRV_EXECUTION_MODE_OUTPUT_LINE_STRIP
    if output_type == AMDGPU_GS_OUTPUT_TRIANGLE_STRIP:
        return SPIRV_EXECUTION_MODE_OUTPUT_TRIANGLE_STRIP
    return 0u32

def SpirvEmitContext_Default() -> SpirvEmitContext:
    ctx: mutable SpirvEmitContext = zeroed
    ctx.next_id <- 1u32
    return ctx

def SpirvEmitContext_AllocateId(ctx: mutable SpirvEmitContext&) -> u32:
    id: u32 = ctx.next_id
    ctx.next_id <- ctx.next_id + 1u32
    return id

# EmitContext::DefineArithmeticTypes. Allocates the scalar/vector/struct types,
# common constants, and input/output pointer types in the exact order of the
# C++ so downstream emit ops reference matching ids. fp16/fp64/dma types are
# only allocated when the corresponding feature flag is set (Info::uses_*).
def SpirvEmitContext_DefineArithmeticTypes(ctx: mutable SpirvEmitContext&) -> void:
    ctx.void_id <- SpirvEmitContext_AllocateId(ctx)
    ctx.u1_id <- SpirvEmitContext_AllocateId(ctx)
    ctx.u8_id <- SpirvEmitContext_AllocateId(ctx)
    ctx.s8_id <- SpirvEmitContext_AllocateId(ctx)
    ctx.u16_id <- SpirvEmitContext_AllocateId(ctx)
    ctx.s16_id <- SpirvEmitContext_AllocateId(ctx)
    if ctx.uses_fp16:
        ctx.f16_id <- SpirvEmitContext_AllocateId(ctx)
    if ctx.uses_fp64:
        ctx.f64_id <- SpirvEmitContext_AllocateId(ctx)
    ctx.f32_id <- SpirvEmitContext_AllocateId(ctx)
    ctx.s32_id <- SpirvEmitContext_AllocateId(ctx)
    ctx.u32_id <- SpirvEmitContext_AllocateId(ctx)
    ctx.u64_id <- SpirvEmitContext_AllocateId(ctx)
    # Vector types, component counts 2..4 (matches the C++ for-loop order).
    if ctx.uses_fp16:
        ctx.f16x2_id <- SpirvEmitContext_AllocateId(ctx)
    if ctx.uses_fp64:
        ctx.f64x2_id <- SpirvEmitContext_AllocateId(ctx)
    ctx.f32x2_id <- SpirvEmitContext_AllocateId(ctx)
    ctx.s32x2_id <- SpirvEmitContext_AllocateId(ctx)
    ctx.u32x2_id <- SpirvEmitContext_AllocateId(ctx)
    ctx.u1x2_id <- SpirvEmitContext_AllocateId(ctx)
    if ctx.uses_fp16:
        ctx.f16x3_id <- SpirvEmitContext_AllocateId(ctx)
    if ctx.uses_fp64:
        ctx.f64x3_id <- SpirvEmitContext_AllocateId(ctx)
    ctx.f32x3_id <- SpirvEmitContext_AllocateId(ctx)
    ctx.s32x3_id <- SpirvEmitContext_AllocateId(ctx)
    ctx.u32x3_id <- SpirvEmitContext_AllocateId(ctx)
    ctx.u1x3_id <- SpirvEmitContext_AllocateId(ctx)
    if ctx.uses_fp16:
        ctx.f16x4_id <- SpirvEmitContext_AllocateId(ctx)
    if ctx.uses_fp64:
        ctx.f64x4_id <- SpirvEmitContext_AllocateId(ctx)
    ctx.f32x4_id <- SpirvEmitContext_AllocateId(ctx)
    ctx.s32x4_id <- SpirvEmitContext_AllocateId(ctx)
    ctx.u32x4_id <- SpirvEmitContext_AllocateId(ctx)
    ctx.u1x4_id <- SpirvEmitContext_AllocateId(ctx)
    # Common constants.
    ctx.true_value <- SpirvEmitContext_AllocateId(ctx)
    ctx.false_value <- SpirvEmitContext_AllocateId(ctx)
    ctx.u8_one_value <- SpirvEmitContext_AllocateId(ctx)
    ctx.u8_zero_value <- SpirvEmitContext_AllocateId(ctx)
    ctx.u16_zero_value <- SpirvEmitContext_AllocateId(ctx)
    ctx.u32_one_value <- SpirvEmitContext_AllocateId(ctx)
    ctx.u32_zero_value <- SpirvEmitContext_AllocateId(ctx)
    ctx.f32_zero_value <- SpirvEmitContext_AllocateId(ctx)
    ctx.u64_one_value <- SpirvEmitContext_AllocateId(ctx)
    ctx.u64_zero_value <- SpirvEmitContext_AllocateId(ctx)
    ctx.pi_x2 <- SpirvEmitContext_AllocateId(ctx)
    # Input/output scalar pointer types.
    ctx.input_f32 <- SpirvEmitContext_AllocateId(ctx)
    ctx.input_u32 <- SpirvEmitContext_AllocateId(ctx)
    ctx.input_s32 <- SpirvEmitContext_AllocateId(ctx)
    ctx.output_f32 <- SpirvEmitContext_AllocateId(ctx)
    ctx.output_u32 <- SpirvEmitContext_AllocateId(ctx)
    ctx.output_s32 <- SpirvEmitContext_AllocateId(ctx)
    # Struct result types.
    ctx.full_result_i32x2 <- SpirvEmitContext_AllocateId(ctx)
    ctx.full_result_u32x2 <- SpirvEmitContext_AllocateId(ctx)
    ctx.frexp_result_f32 <- SpirvEmitContext_AllocateId(ctx)
    if ctx.uses_fp64:
        ctx.frexp_result_f64 <- SpirvEmitContext_AllocateId(ctx)
    if ctx.uses_dma:
        ctx.physical_pointer_type_u32 <- SpirvEmitContext_AllocateId(ctx)

# Subgroup invocation-id input variable (defined in EmitContext::DefineInputs).
def SpirvEmitContext_DefineWarpInputs(ctx: mutable SpirvEmitContext&) -> void:
    if ctx.subgroup_local_invocation_id == 0u32:
        ctx.subgroup_local_invocation_id <- SpirvEmitContext_AllocateId(ctx)

def SpirvTypeId(ctx: SpirvEmitContext, ir_type: u32) -> u32:
    if ir_type == SHADER_IR_TYPE_U1:
        return ctx.u1_id
    if ir_type == SHADER_IR_TYPE_U32:
        return ctx.u32_id
    if ir_type == SHADER_IR_TYPE_F32:
        return ctx.f32_id
    return SPIRV_INVALID_ID

def SpirvEmitContext_AddLabel(ctx: mutable SpirvEmitContext&) -> u32:
    label: u32 = SpirvEmitContext_AllocateId(ctx)
    ctx.last_label <- label
    return label

def SpirvEmitContext_AddInterface(ctx: mutable SpirvEmitContext&, id: u32) -> void:
    can Memory.Allocate, Abort.Panic:
        owner: mutable Arena& = scratch_arena.ref[mutable Arena&]
        in owner:
            ctx.interfaces.push(id)

def SpirvWord(opcode: u16, word_count: u16) -> u32:
    return (word_count.u32() << 16) | opcode.u32()

def SpirvEmitContext_AppendWord(ctx: mutable SpirvEmitContext&, word: u32) -> void:
    can Memory.Allocate, Abort.Panic:
        owner: mutable Arena& = scratch_arena.ref[mutable Arena&]
        in owner:
            ctx.words.push(word)

def SpirvEmitHeader(ctx: mutable SpirvEmitContext&) -> void:
    can Memory.Allocate, Abort.Panic:
        SpirvEmitContext_AppendWord(ctx, SPIRV_MAGIC)
        SpirvEmitContext_AppendWord(ctx, SPIRV_VERSION_1_6)
        SpirvEmitContext_AppendWord(ctx, SPIRV_GENERATOR_SHADPS4_ELISA)
        SpirvEmitContext_AppendWord(ctx, ctx.next_id)
        SpirvEmitContext_AppendWord(ctx, SPIRV_SCHEMA_RESERVED)

# ------------------------------------------------------------
# IR -> SPIR-V instruction emitters (ported from backend/spirv/emit_spirv_*.cpp).
# ------------------------------------------------------------

# Generic unary op: <ResultType> <ResultId> <Operand> (4 words).
def SpirvEmitUnaryOp(ctx: mutable SpirvEmitContext&, opcode: u16, result_type: u32, operand: u32) -> u32:
    result_id: u32 = SpirvEmitContext_AllocateId(ctx)
    SpirvEmitContext_AppendWord(ctx, SpirvWord(opcode, 4u16))
    SpirvEmitContext_AppendWord(ctx, result_type)
    SpirvEmitContext_AppendWord(ctx, result_id)
    SpirvEmitContext_AppendWord(ctx, operand)
    return result_id

# Generic binary op: <ResultType> <ResultId> <Operand1> <Operand2> (5 words).
def SpirvEmitBinaryOp(ctx: mutable SpirvEmitContext&, opcode: u16, result_type: u32, lhs: u32, rhs: u32) -> u32:
    result_id: u32 = SpirvEmitContext_AllocateId(ctx)
    SpirvEmitContext_AppendWord(ctx, SpirvWord(opcode, 5u16))
    SpirvEmitContext_AppendWord(ctx, result_type)
    SpirvEmitContext_AppendWord(ctx, result_id)
    SpirvEmitContext_AppendWord(ctx, lhs)
    SpirvEmitContext_AppendWord(ctx, rhs)
    return result_id

# emit_spirv_logical.cpp: boolean logic, all producing the U1 scalar type.
def SpirvEmitLogicalOr(ctx: mutable SpirvEmitContext&, a: u32, b: u32) -> u32:
    return SpirvEmitBinaryOp(ctx, SPIRV_OP_LOGICAL_OR, ctx.u1_id, a, b)

def SpirvEmitLogicalAnd(ctx: mutable SpirvEmitContext&, a: u32, b: u32) -> u32:
    return SpirvEmitBinaryOp(ctx, SPIRV_OP_LOGICAL_AND, ctx.u1_id, a, b)

def SpirvEmitLogicalXor(ctx: mutable SpirvEmitContext&, a: u32, b: u32) -> u32:
    return SpirvEmitBinaryOp(ctx, SPIRV_OP_LOGICAL_NOT_EQUAL, ctx.u1_id, a, b)

def SpirvEmitLogicalNot(ctx: mutable SpirvEmitContext&, value: u32) -> u32:
    return SpirvEmitUnaryOp(ctx, SPIRV_OP_LOGICAL_NOT, ctx.u1_id, value)

# OpSelect: <ResultType> <ResultId> <Condition> <Object1> <Object2> (6 words).
# Mirrors EmitContext::OpSelect used by emit_spirv_select.cpp.
def SpirvEmitOpSelect(ctx: mutable SpirvEmitContext&, result_type: u32, condition: u32, true_value: u32, false_value: u32) -> u32:
    result_id: u32 = SpirvEmitContext_AllocateId(ctx)
    SpirvEmitContext_AppendWord(ctx, SpirvWord(SPIRV_OP_SELECT, 6u16))
    SpirvEmitContext_AppendWord(ctx, result_type)
    SpirvEmitContext_AppendWord(ctx, result_id)
    SpirvEmitContext_AppendWord(ctx, condition)
    SpirvEmitContext_AppendWord(ctx, true_value)
    SpirvEmitContext_AppendWord(ctx, false_value)
    return result_id

# emit_spirv_select.cpp: EmitSelectU1 / EmitSelectU32 / EmitSelectF32 select
# between two values of the scalar result type on a boolean condition.
def SpirvEmitSelectU1(ctx: mutable SpirvEmitContext&, condition: u32, true_value: u32, false_value: u32) -> u32:
    return SpirvEmitOpSelect(ctx, ctx.u1_id, condition, true_value, false_value)

def SpirvEmitSelectU32(ctx: mutable SpirvEmitContext&, condition: u32, true_value: u32, false_value: u32) -> u32:
    return SpirvEmitOpSelect(ctx, ctx.u32_id, condition, true_value, false_value)

def SpirvEmitSelectF32(ctx: mutable SpirvEmitContext&, condition: u32, true_value: u32, false_value: u32) -> u32:
    return SpirvEmitOpSelect(ctx, ctx.f32_id, condition, true_value, false_value)

# OpUndef: <ResultType> <ResultId> (3 words). Produces an undefined value of
# the given scalar type. Mirrors EmitContext::OpUndef.
def SpirvEmitOpUndef(ctx: mutable SpirvEmitContext&, result_type: u32) -> u32:
    result_id: u32 = SpirvEmitContext_AllocateId(ctx)
    SpirvEmitContext_AppendWord(ctx, SpirvWord(SPIRV_OP_UNDEF, 3u16))
    SpirvEmitContext_AppendWord(ctx, result_type)
    SpirvEmitContext_AppendWord(ctx, result_id)
    return result_id

# emit_spirv_undefined.cpp: EmitUndefU1 / EmitUndefU32 are the only legal
# variants; U8/U16/U64 are UNREACHABLE in the C++ backend.
def SpirvEmitUndefU1(ctx: mutable SpirvEmitContext&) -> u32:
    return SpirvEmitOpUndef(ctx, ctx.u1_id)

def SpirvEmitUndefU32(ctx: mutable SpirvEmitContext&) -> u32:
    return SpirvEmitOpUndef(ctx, ctx.u32_id)

# OpConstant: <ResultType=u32> <ResultId> <Value> (4 words). Mirrors
# EmitContext::ConstU32 (without the C++ constant-dedup cache).
def SpirvEmitConstU32(ctx: mutable SpirvEmitContext&, value: u32) -> u32:
    result_id: u32 = SpirvEmitContext_AllocateId(ctx)
    SpirvEmitContext_AppendWord(ctx, SpirvWord(SPIRV_OP_CONSTANT, 4u16))
    SpirvEmitContext_AppendWord(ctx, ctx.u32_id)
    SpirvEmitContext_AppendWord(ctx, result_id)
    SpirvEmitContext_AppendWord(ctx, value)
    return result_id

# OpMemoryBarrier: <Memory> <Semantics> (3 words, no result id).
def SpirvEmitMemoryBarrier(ctx: mutable SpirvEmitContext&, scope: u32, semantics: u32) -> void:
    mem_id: u32 = SpirvEmitConstU32(ctx, scope)
    sem_id: u32 = SpirvEmitConstU32(ctx, semantics)
    SpirvEmitContext_AppendWord(ctx, SpirvWord(SPIRV_OP_MEMORY_BARRIER, 3u16))
    SpirvEmitContext_AppendWord(ctx, mem_id)
    SpirvEmitContext_AppendWord(ctx, sem_id)

# OpControlBarrier: <Execution> <Memory> <Semantics> (4 words, no result id).
def SpirvEmitControlBarrier(ctx: mutable SpirvEmitContext&, execution: u32, memory: u32, semantics: u32) -> void:
    exec_id: u32 = SpirvEmitConstU32(ctx, execution)
    mem_id: u32 = SpirvEmitConstU32(ctx, memory)
    sem_id: u32 = SpirvEmitConstU32(ctx, semantics)
    SpirvEmitContext_AppendWord(ctx, SpirvWord(SPIRV_OP_CONTROL_BARRIER, 4u16))
    SpirvEmitContext_AppendWord(ctx, exec_id)
    SpirvEmitContext_AppendWord(ctx, mem_id)
    SpirvEmitContext_AppendWord(ctx, sem_id)

# emit_spirv_barriers.cpp: combined semantics used by the memory-barrier helper.
def SpirvMemoryBarrierSemantics() -> u32:
    return SPIRV_MEM_SEM_ACQUIRE_RELEASE | SPIRV_MEM_SEM_UNIFORM_MEMORY | SPIRV_MEM_SEM_WORKGROUP_MEMORY | SPIRV_MEM_SEM_ATOMIC_COUNTER_MEMORY | SPIRV_MEM_SEM_IMAGE_MEMORY

# EmitBarrier: workgroup execution barrier. TessellationControl uses an
# Invocation memory scope with no semantics; everything else uses a workgroup
# acquire/release on workgroup memory.
def SpirvEmitBarrier(ctx: mutable SpirvEmitContext&, is_tessellation_control: bool) -> void:
    execution: u32 = SPIRV_SCOPE_WORKGROUP
    memory: mutable u32 = SPIRV_SCOPE_WORKGROUP
    semantics: mutable u32 = SPIRV_MEM_SEM_ACQUIRE_RELEASE | SPIRV_MEM_SEM_WORKGROUP_MEMORY
    if is_tessellation_control:
        memory <- SPIRV_SCOPE_INVOCATION
        semantics <- SPIRV_MEM_SEM_NONE
    SpirvEmitControlBarrier(ctx, execution, memory, semantics)

def SpirvEmitWorkgroupMemoryBarrier(ctx: mutable SpirvEmitContext&) -> void:
    SpirvEmitMemoryBarrier(ctx, SPIRV_SCOPE_WORKGROUP, SpirvMemoryBarrierSemantics())

def SpirvEmitDeviceMemoryBarrier(ctx: mutable SpirvEmitContext&) -> void:
    SpirvEmitMemoryBarrier(ctx, SPIRV_SCOPE_DEVICE, SpirvMemoryBarrierSemantics())

# Generic ternary op: <ResultType> <ResultId> <Op1> <Op2> <Op3> (6 words).
def SpirvEmitTernaryOp(ctx: mutable SpirvEmitContext&, opcode: u16, result_type: u32, a: u32, b: u32, c: u32) -> u32:
    result_id: u32 = SpirvEmitContext_AllocateId(ctx)
    SpirvEmitContext_AppendWord(ctx, SpirvWord(opcode, 6u16))
    SpirvEmitContext_AppendWord(ctx, result_type)
    SpirvEmitContext_AppendWord(ctx, result_id)
    SpirvEmitContext_AppendWord(ctx, a)
    SpirvEmitContext_AppendWord(ctx, b)
    SpirvEmitContext_AppendWord(ctx, c)
    return result_id

# SubgroupScope: ctx.ConstU32(spv::Scope::Subgroup).
def SpirvSubgroupScope(ctx: mutable SpirvEmitContext&) -> u32:
    return SpirvEmitConstU32(ctx, SPIRV_SCOPE_SUBGROUP)

# EmitLaneId: OpLoad U32 from the SubgroupLocalInvocationId pointer.
def SpirvEmitLaneId(ctx: mutable SpirvEmitContext&) -> u32:
    return SpirvEmitUnaryOp(ctx, SPIRV_OP_LOAD, ctx.u32_id, ctx.subgroup_local_invocation_id)

# EmitQuadShuffle: OpGroupNonUniformQuadBroadcast U32 Subgroup value index.
def SpirvEmitQuadShuffle(ctx: mutable SpirvEmitContext&, value: u32, index: u32) -> u32:
    sg_scope: u32 = SpirvSubgroupScope(ctx)
    return SpirvEmitTernaryOp(ctx, SPIRV_OP_GROUP_NON_UNIFORM_QUAD_BROADCAST, ctx.u32_id, sg_scope, value, index)

# EmitReadFirstLane: OpGroupNonUniformBroadcastFirst U32 Subgroup value.
def SpirvEmitReadFirstLane(ctx: mutable SpirvEmitContext&, value: u32) -> u32:
    sg_scope: u32 = SpirvSubgroupScope(ctx)
    return SpirvEmitBinaryOp(ctx, SPIRV_OP_GROUP_NON_UNIFORM_BROADCAST_FIRST, ctx.u32_id, sg_scope, value)

# EmitReadLane: OpGroupNonUniformBroadcast U32 Subgroup value lane.
def SpirvEmitReadLane(ctx: mutable SpirvEmitContext&, value: u32, lane: u32) -> u32:
    sg_scope: u32 = SpirvSubgroupScope(ctx)
    return SpirvEmitTernaryOp(ctx, SPIRV_OP_GROUP_NON_UNIFORM_BROADCAST, ctx.u32_id, sg_scope, value, lane)

# EmitBallot: OpGroupNonUniformBallot uvec4 Subgroup bit.
def SpirvEmitBallot(ctx: mutable SpirvEmitContext&, bit: u32) -> u32:
    sg_scope: u32 = SpirvSubgroupScope(ctx)
    return SpirvEmitBinaryOp(ctx, SPIRV_OP_GROUP_NON_UNIFORM_BALLOT, ctx.u32x4_id, sg_scope, bit)

# EmitBallotFindLsb: OpGroupNonUniformBallotFindLSB U32 Subgroup mask.
def SpirvEmitBallotFindLsb(ctx: mutable SpirvEmitContext&, mask: u32) -> u32:
    sg_scope: u32 = SpirvSubgroupScope(ctx)
    return SpirvEmitBinaryOp(ctx, SPIRV_OP_GROUP_NON_UNIFORM_BALLOT_FIND_LSB, ctx.u32_id, sg_scope, mask)

# EmitGroupAny: OpGroupNonUniformAny U1 Subgroup bit.
def SpirvEmitGroupAny(ctx: mutable SpirvEmitContext&, bit: u32) -> u32:
    sg_scope: u32 = SpirvSubgroupScope(ctx)
    return SpirvEmitBinaryOp(ctx, SPIRV_OP_GROUP_NON_UNIFORM_ANY, ctx.u1_id, sg_scope, bit)

# emit_spirv_floating_point.cpp: GLSL.std.450 import id, allocated lazily.
def SpirvEmitContext_DefineExtInst(ctx: mutable SpirvEmitContext&) -> void:
    if ctx.glsl_std_450_id == 0u32:
        ctx.glsl_std_450_id <- SpirvEmitContext_AllocateId(ctx)

# OpExtInst: <ResultType> <ResultId> <Set> <Instruction> <Operands...>.
# Word count is 5 + operand count.
def SpirvEmitExtInstUnary(ctx: mutable SpirvEmitContext&, result_type: u32, instruction: u32, a: u32) -> u32:
    result_id: u32 = SpirvEmitContext_AllocateId(ctx)
    SpirvEmitContext_AppendWord(ctx, SpirvWord(SPIRV_OP_EXT_INST, 6u16))
    SpirvEmitContext_AppendWord(ctx, result_type)
    SpirvEmitContext_AppendWord(ctx, result_id)
    SpirvEmitContext_AppendWord(ctx, ctx.glsl_std_450_id)
    SpirvEmitContext_AppendWord(ctx, instruction)
    SpirvEmitContext_AppendWord(ctx, a)
    return result_id

def SpirvEmitExtInstBinary(ctx: mutable SpirvEmitContext&, result_type: u32, instruction: u32, a: u32, b: u32) -> u32:
    result_id: u32 = SpirvEmitContext_AllocateId(ctx)
    SpirvEmitContext_AppendWord(ctx, SpirvWord(SPIRV_OP_EXT_INST, 7u16))
    SpirvEmitContext_AppendWord(ctx, result_type)
    SpirvEmitContext_AppendWord(ctx, result_id)
    SpirvEmitContext_AppendWord(ctx, ctx.glsl_std_450_id)
    SpirvEmitContext_AppendWord(ctx, instruction)
    SpirvEmitContext_AppendWord(ctx, a)
    SpirvEmitContext_AppendWord(ctx, b)
    return result_id

def SpirvEmitExtInstTernary(ctx: mutable SpirvEmitContext&, result_type: u32, instruction: u32, a: u32, b: u32, c: u32) -> u32:
    result_id: u32 = SpirvEmitContext_AllocateId(ctx)
    SpirvEmitContext_AppendWord(ctx, SpirvWord(SPIRV_OP_EXT_INST, 8u16))
    SpirvEmitContext_AppendWord(ctx, result_type)
    SpirvEmitContext_AppendWord(ctx, result_id)
    SpirvEmitContext_AppendWord(ctx, ctx.glsl_std_450_id)
    SpirvEmitContext_AppendWord(ctx, instruction)
    SpirvEmitContext_AppendWord(ctx, a)
    SpirvEmitContext_AppendWord(ctx, b)
    SpirvEmitContext_AppendWord(ctx, c)
    return result_id

# Core 32-bit float arithmetic. The C++ wraps add/sub/mul/div/fma in a
# NoContraction decoration (emitted into a separate annotations stream); the
# arithmetic instruction word-stream is identical, so the decoration is omitted.
def SpirvEmitFPAdd32(ctx: mutable SpirvEmitContext&, a: u32, b: u32) -> u32:
    return SpirvEmitBinaryOp(ctx, SPIRV_OP_F_ADD, ctx.f32_id, a, b)

def SpirvEmitFPSub32(ctx: mutable SpirvEmitContext&, a: u32, b: u32) -> u32:
    return SpirvEmitBinaryOp(ctx, SPIRV_OP_F_SUB, ctx.f32_id, a, b)

def SpirvEmitFPMul32(ctx: mutable SpirvEmitContext&, a: u32, b: u32) -> u32:
    return SpirvEmitBinaryOp(ctx, SPIRV_OP_F_MUL, ctx.f32_id, a, b)

def SpirvEmitFPDiv32(ctx: mutable SpirvEmitContext&, a: u32, b: u32) -> u32:
    return SpirvEmitBinaryOp(ctx, SPIRV_OP_F_DIV, ctx.f32_id, a, b)

def SpirvEmitFPNeg32(ctx: mutable SpirvEmitContext&, value: u32) -> u32:
    return SpirvEmitUnaryOp(ctx, SPIRV_OP_F_NEGATE, ctx.f32_id, value)

# 32-bit float transcendental / min-max via GLSL.std.450.
def SpirvEmitFPAbs32(ctx: mutable SpirvEmitContext&, value: u32) -> u32:
    return SpirvEmitExtInstUnary(ctx, ctx.f32_id, GLSL_STD_450_FABS, value)

def SpirvEmitFPSqrt32(ctx: mutable SpirvEmitContext&, value: u32) -> u32:
    return SpirvEmitExtInstUnary(ctx, ctx.f32_id, GLSL_STD_450_SQRT, value)

def SpirvEmitFPExp2(ctx: mutable SpirvEmitContext&, value: u32) -> u32:
    return SpirvEmitExtInstUnary(ctx, ctx.f32_id, GLSL_STD_450_EXP2, value)

def SpirvEmitFPLog2(ctx: mutable SpirvEmitContext&, value: u32) -> u32:
    return SpirvEmitExtInstUnary(ctx, ctx.f32_id, GLSL_STD_450_LOG2, value)

def SpirvEmitFPFloor32(ctx: mutable SpirvEmitContext&, value: u32) -> u32:
    return SpirvEmitExtInstUnary(ctx, ctx.f32_id, GLSL_STD_450_FLOOR, value)

def SpirvEmitFPFract32(ctx: mutable SpirvEmitContext&, value: u32) -> u32:
    return SpirvEmitExtInstUnary(ctx, ctx.f32_id, GLSL_STD_450_FRACT, value)

def SpirvEmitFPMax32(ctx: mutable SpirvEmitContext&, a: u32, b: u32) -> u32:
    return SpirvEmitExtInstBinary(ctx, ctx.f32_id, GLSL_STD_450_FMAX, a, b)

def SpirvEmitFPMin32(ctx: mutable SpirvEmitContext&, a: u32, b: u32) -> u32:
    return SpirvEmitExtInstBinary(ctx, ctx.f32_id, GLSL_STD_450_FMIN, a, b)

def SpirvEmitFPPow32(ctx: mutable SpirvEmitContext&, x: u32, y: u32) -> u32:
    return SpirvEmitExtInstBinary(ctx, ctx.f32_id, GLSL_STD_450_POW, x, y)

def SpirvEmitFPFma32(ctx: mutable SpirvEmitContext&, a: u32, b: u32, c: u32) -> u32:
    return SpirvEmitExtInstTernary(ctx, ctx.f32_id, GLSL_STD_450_FMA, a, b, c)

# EmitFPMinTri32 / FPMaxTri32 fallback (no AMD trinary minmax support): nested
# GLSL FMin/FMax. Matches the !supports_trinary_minmax path of the C++.
def SpirvEmitFPMinTri32(ctx: mutable SpirvEmitContext&, a: u32, b: u32, c: u32) -> u32:
    inner: u32 = SpirvEmitFPMin32(ctx, b, c)
    return SpirvEmitFPMin32(ctx, a, inner)

def SpirvEmitFPMaxTri32(ctx: mutable SpirvEmitContext&, a: u32, b: u32, c: u32) -> u32:
    inner: u32 = SpirvEmitFPMax32(ctx, b, c)
    return SpirvEmitFPMax32(ctx, a, inner)

# OpConstant of an f32 (value passed as its 32-bit bit pattern). The C++
# ConstF32 dedups into the constants section; this models the value word.
def SpirvEmitConstF32(ctx: mutable SpirvEmitContext&, bits: u32) -> u32:
    result_id: u32 = SpirvEmitContext_AllocateId(ctx)
    SpirvEmitContext_AppendWord(ctx, SpirvWord(SPIRV_OP_CONSTANT, 4u16))
    SpirvEmitContext_AppendWord(ctx, ctx.f32_id)
    SpirvEmitContext_AppendWord(ctx, result_id)
    SpirvEmitContext_AppendWord(ctx, bits)
    return result_id

# OpBitcast: <ResultType> <ResultId> <Operand> (4 words).
def SpirvEmitBitcast(ctx: mutable SpirvEmitContext&, result_type: u32, value: u32) -> u32:
    return SpirvEmitUnaryOp(ctx, SPIRV_OP_BITCAST, result_type, value)

# --- 64-bit float arithmetic (require uses_fp64 so f64_id is defined). ---
def SpirvEmitFPAbs64(ctx: mutable SpirvEmitContext&, value: u32) -> u32:
    return SpirvEmitExtInstUnary(ctx, ctx.f64_id, GLSL_STD_450_FABS, value)

def SpirvEmitFPNeg64(ctx: mutable SpirvEmitContext&, value: u32) -> u32:
    return SpirvEmitUnaryOp(ctx, SPIRV_OP_F_NEGATE, ctx.f64_id, value)

def SpirvEmitFPAdd64(ctx: mutable SpirvEmitContext&, a: u32, b: u32) -> u32:
    return SpirvEmitBinaryOp(ctx, SPIRV_OP_F_ADD, ctx.f64_id, a, b)

def SpirvEmitFPMul64(ctx: mutable SpirvEmitContext&, a: u32, b: u32) -> u32:
    return SpirvEmitBinaryOp(ctx, SPIRV_OP_F_MUL, ctx.f64_id, a, b)

def SpirvEmitFPDiv64(ctx: mutable SpirvEmitContext&, a: u32, b: u32) -> u32:
    return SpirvEmitBinaryOp(ctx, SPIRV_OP_F_DIV, ctx.f64_id, a, b)

def SpirvEmitFPMax64(ctx: mutable SpirvEmitContext&, a: u32, b: u32) -> u32:
    return SpirvEmitExtInstBinary(ctx, ctx.f64_id, GLSL_STD_450_FMAX, a, b)

def SpirvEmitFPMin64(ctx: mutable SpirvEmitContext&, a: u32, b: u32) -> u32:
    return SpirvEmitExtInstBinary(ctx, ctx.f64_id, GLSL_STD_450_FMIN, a, b)

def SpirvEmitFPFma64(ctx: mutable SpirvEmitContext&, a: u32, b: u32, c: u32) -> u32:
    return SpirvEmitExtInstTernary(ctx, ctx.f64_id, GLSL_STD_450_FMA, a, b, c)

# --- Sin/Cos: GLSL Sin/Cos of (pi_x2 * value). ---
def SpirvEmitFPSin(ctx: mutable SpirvEmitContext&, value: u32) -> u32:
    scaled: u32 = SpirvEmitFPMul32(ctx, ctx.pi_x2, value)
    return SpirvEmitExtInstUnary(ctx, ctx.f32_id, GLSL_STD_450_SIN, scaled)

def SpirvEmitFPCos(ctx: mutable SpirvEmitContext&, value: u32) -> u32:
    scaled: u32 = SpirvEmitFPMul32(ctx, ctx.pi_x2, value)
    return SpirvEmitExtInstUnary(ctx, ctx.f32_id, GLSL_STD_450_COS, scaled)

# --- Misc GLSL transcendental / rounding ops. ---
def SpirvEmitFPLdexp(ctx: mutable SpirvEmitContext&, value: u32, exp: u32) -> u32:
    return SpirvEmitExtInstBinary(ctx, ctx.f32_id, GLSL_STD_450_LDEXP, value, exp)

def SpirvEmitFPRecipSqrt32(ctx: mutable SpirvEmitContext&, value: u32) -> u32:
    return SpirvEmitExtInstUnary(ctx, ctx.f32_id, GLSL_STD_450_INVERSE_SQRT, value)

def SpirvEmitFPRecipSqrt64(ctx: mutable SpirvEmitContext&, value: u32) -> u32:
    return SpirvEmitExtInstUnary(ctx, ctx.f64_id, GLSL_STD_450_INVERSE_SQRT, value)

def SpirvEmitFPRoundEven32(ctx: mutable SpirvEmitContext&, value: u32) -> u32:
    return SpirvEmitExtInstUnary(ctx, ctx.f32_id, GLSL_STD_450_ROUND_EVEN, value)

def SpirvEmitFPRoundEven64(ctx: mutable SpirvEmitContext&, value: u32) -> u32:
    return SpirvEmitExtInstUnary(ctx, ctx.f64_id, GLSL_STD_450_ROUND_EVEN, value)

def SpirvEmitFPCeil32(ctx: mutable SpirvEmitContext&, value: u32) -> u32:
    return SpirvEmitExtInstUnary(ctx, ctx.f32_id, GLSL_STD_450_CEIL, value)

def SpirvEmitFPCeil64(ctx: mutable SpirvEmitContext&, value: u32) -> u32:
    return SpirvEmitExtInstUnary(ctx, ctx.f64_id, GLSL_STD_450_CEIL, value)

def SpirvEmitFPTrunc32(ctx: mutable SpirvEmitContext&, value: u32) -> u32:
    return SpirvEmitExtInstUnary(ctx, ctx.f32_id, GLSL_STD_450_TRUNC, value)

def SpirvEmitFPTrunc64(ctx: mutable SpirvEmitContext&, value: u32) -> u32:
    return SpirvEmitExtInstUnary(ctx, ctx.f64_id, GLSL_STD_450_TRUNC, value)

def SpirvEmitFPFloor64(ctx: mutable SpirvEmitContext&, value: u32) -> u32:
    return SpirvEmitExtInstUnary(ctx, ctx.f64_id, GLSL_STD_450_FLOOR, value)

def SpirvEmitFPFract64(ctx: mutable SpirvEmitContext&, value: u32) -> u32:
    return SpirvEmitExtInstUnary(ctx, ctx.f64_id, GLSL_STD_450_FRACT, value)

def SpirvEmitFPClamp32(ctx: mutable SpirvEmitContext&, value: u32, min_v: u32, max_v: u32) -> u32:
    return SpirvEmitExtInstTernary(ctx, ctx.f32_id, GLSL_STD_450_FCLAMP, value, min_v, max_v)

def SpirvEmitFPClamp64(ctx: mutable SpirvEmitContext&, value: u32, min_v: u32, max_v: u32) -> u32:
    return SpirvEmitExtInstTernary(ctx, ctx.f64_id, GLSL_STD_450_FCLAMP, value, min_v, max_v)

# Frexp: GLSL FrexpStruct returns {significand, exponent}; extract component 0
# for the significand, component 1 (S32) bitcast to U32 for the exponent.
def SpirvEmitFPFrexpSig32(ctx: mutable SpirvEmitContext&, value: u32) -> u32:
    frexp: u32 = SpirvEmitExtInstUnary(ctx, ctx.frexp_result_f32, GLSL_STD_450_FREXP_STRUCT, value)
    return SpirvEmitCompositeExtract(ctx, ctx.f32_id, frexp, 0u32)

def SpirvEmitFPFrexpExp32(ctx: mutable SpirvEmitContext&, value: u32) -> u32:
    frexp: u32 = SpirvEmitExtInstUnary(ctx, ctx.frexp_result_f32, GLSL_STD_450_FREXP_STRUCT, value)
    exp_s32: u32 = SpirvEmitCompositeExtract(ctx, ctx.s32_id, frexp, 1u32)
    return SpirvEmitBitcast(ctx, ctx.u32_id, exp_s32)

# Float comparisons (ordered / unordered). The IR 16/32/64 variants all emit
# the same instruction (result type U1; operand width carried by the operands).
def SpirvEmitFOrdEqual(ctx: mutable SpirvEmitContext&, lhs: u32, rhs: u32) -> u32:
    return SpirvEmitBinaryOp(ctx, SPIRV_OP_F_ORD_EQUAL, ctx.u1_id, lhs, rhs)

def SpirvEmitFUnordEqual(ctx: mutable SpirvEmitContext&, lhs: u32, rhs: u32) -> u32:
    return SpirvEmitBinaryOp(ctx, SPIRV_OP_F_UNORD_EQUAL, ctx.u1_id, lhs, rhs)

def SpirvEmitFOrdNotEqual(ctx: mutable SpirvEmitContext&, lhs: u32, rhs: u32) -> u32:
    return SpirvEmitBinaryOp(ctx, SPIRV_OP_F_ORD_NOT_EQUAL, ctx.u1_id, lhs, rhs)

def SpirvEmitFUnordNotEqual(ctx: mutable SpirvEmitContext&, lhs: u32, rhs: u32) -> u32:
    return SpirvEmitBinaryOp(ctx, SPIRV_OP_F_UNORD_NOT_EQUAL, ctx.u1_id, lhs, rhs)

def SpirvEmitFOrdLessThan(ctx: mutable SpirvEmitContext&, lhs: u32, rhs: u32) -> u32:
    return SpirvEmitBinaryOp(ctx, SPIRV_OP_F_ORD_LESS_THAN, ctx.u1_id, lhs, rhs)

def SpirvEmitFUnordLessThan(ctx: mutable SpirvEmitContext&, lhs: u32, rhs: u32) -> u32:
