def SpirvEmitShiftRightArithmetic32(ctx: mutable SpirvEmitContext&, base: u32, shift: u32) -> u32:
    return SpirvEmitBinaryOp(ctx, SPIRV_OP_SHIFT_RIGHT_ARITHMETIC, ctx.u32_id, base, shift)

# Bitwise (U32 result type).
def SpirvEmitBitwiseAnd32(ctx: mutable SpirvEmitContext&, a: u32, b: u32) -> u32:
    return SpirvEmitBinaryOp(ctx, SPIRV_OP_BITWISE_AND, ctx.u32_id, a, b)

def SpirvEmitBitwiseOr32(ctx: mutable SpirvEmitContext&, a: u32, b: u32) -> u32:
    return SpirvEmitBinaryOp(ctx, SPIRV_OP_BITWISE_OR, ctx.u32_id, a, b)

def SpirvEmitBitwiseXor32(ctx: mutable SpirvEmitContext&, a: u32, b: u32) -> u32:
    return SpirvEmitBinaryOp(ctx, SPIRV_OP_BITWISE_XOR, ctx.u32_id, a, b)

def SpirvEmitBitwiseNot32(ctx: mutable SpirvEmitContext&, value: u32) -> u32:
