# OpAtomicCompareExchange: <ResultType> <ResultId> <Pointer> <Scope>
# <EqualSemantics> <UnequalSemantics> <Value> <Comparator> (9 words).
def SpirvEmitAtomicCompareExchange(ctx: mutable SpirvEmitContext&, result_type: u32, pointer: u32, scope: u32, eq_sem: u32, uneq_sem: u32, value: u32, comparator: u32) -> u32:
    result_id: u32 = SpirvEmitContext_AllocateId(ctx)
    SpirvEmitContext_AppendWord(ctx, SpirvWord(SPIRV_OP_ATOMIC_COMPARE_EXCHANGE, 9u16))
    SpirvEmitContext_AppendWord(ctx, result_type)
    SpirvEmitContext_AppendWord(ctx, result_id)
    SpirvEmitContext_AppendWord(ctx, pointer)
    SpirvEmitContext_AppendWord(ctx, scope)
    SpirvEmitContext_AppendWord(ctx, eq_sem)
    SpirvEmitContext_AppendWord(ctx, uneq_sem)
    SpirvEmitContext_AppendWord(ctx, value)
    SpirvEmitContext_AppendWord(ctx, comparator)
    return result_id

# Registration helpers (stand in for the Info-driven DefineBuffers /
# DefineImagesAndSamplers, which decode resource descriptors).
def SpirvEmitContext_PushBuffer(ctx: mutable SpirvEmitContext&, buf: SpirvBufferDefinition) -> usize:
    can Memory.Allocate, Abort.Panic:
        owner: mutable Arena& = scratch_arena.ref[mutable Arena&]
        in owner:
            ctx.buffers.push(buf)
    return ctx.buffers.count - 1usize

def SpirvEmitContext_PushImage(ctx: mutable SpirvEmitContext&, tex: SpirvTextureDefinition) -> usize:
    can Memory.Allocate, Abort.Panic:
        owner: mutable Arena& = scratch_arena.ref[mutable Arena&]
        in owner:
            ctx.images.push(tex)
    return ctx.images.count - 1usize

# Buffer atomic on a 32-bit element (U32 or, with is_float, F32). Adds the
# per-buffer byte offset to the address, forms the storage access chain, then
# the atomic op (device scope, relaxed semantics). Mirrors BufferAtomicU32.
def SpirvEmitBufferAtomicU32(ctx: mutable SpirvEmitContext&, opcode: u16, handle: u32, address: u32, value: u32, is_float: bool) -> u32:
    buf: SpirvBufferDefinition = ctx.buffers[handle.usize()]
    result_type: mutable u32 = ctx.u32_id
    ptr_kind: mutable u32 = SPIRV_POINTER_TYPE_U32
    if is_float:
        result_type <- ctx.f32_id
        ptr_kind <- SPIRV_POINTER_TYPE_F32
    addr: mutable u32 = address
    offset: u32 = buf.offsets[SPIRV_POINTER_SIZE_B32.usize()]
    if offset != 0u32:
        addr <- SpirvEmitIAdd32(ctx, addr, offset)
    base_id: u32 = buf.alias_ids[ptr_kind.usize()]
    pointer_type: u32 = buf.alias_ptrs[ptr_kind.usize()]
    ptr: u32 = SpirvEmitAccessChain2(ctx, pointer_type, base_id, ctx.u32_zero_value, addr)
    atomic_scope: u32 = SpirvEmitAtomicScope(ctx)
    return SpirvEmitAtomicBinary(ctx, opcode, result_type, ptr, atomic_scope, ctx.u32_zero_value, value)

def SpirvEmitBufferAtomicU64(ctx: mutable SpirvEmitContext&, opcode: u16, handle: u32, address: u32, value: u32) -> u32:
    buf: SpirvBufferDefinition = ctx.buffers[handle.usize()]
    addr: mutable u32 = address
    offset: u32 = buf.offsets[SPIRV_POINTER_SIZE_B64.usize()]
    if offset != 0u32:
        addr <- SpirvEmitIAdd32(ctx, addr, offset)
    base_id: u32 = buf.alias_ids[SPIRV_POINTER_TYPE_U64.usize()]
    pointer_type: u32 = buf.alias_ptrs[SPIRV_POINTER_TYPE_U64.usize()]
    ptr: u32 = SpirvEmitAccessChain2(ctx, pointer_type, base_id, ctx.u32_zero_value, addr)
    atomic_scope: u32 = SpirvEmitAtomicScope(ctx)
    return SpirvEmitAtomicBinary(ctx, opcode, ctx.u64_id, ptr, atomic_scope, ctx.u32_zero_value, value)

def SpirvEmitBufferAtomicU32IncDec(ctx: mutable SpirvEmitContext&, opcode: u16, handle: u32, address: u32) -> u32:
    buf: SpirvBufferDefinition = ctx.buffers[handle.usize()]
    addr: mutable u32 = address
    offset: u32 = buf.offsets[SPIRV_POINTER_SIZE_B32.usize()]
    if offset != 0u32:
        addr <- SpirvEmitIAdd32(ctx, addr, offset)
    base_id: u32 = buf.alias_ids[SPIRV_POINTER_TYPE_U32.usize()]
    pointer_type: u32 = buf.alias_ptrs[SPIRV_POINTER_TYPE_U32.usize()]
    ptr: u32 = SpirvEmitAccessChain2(ctx, pointer_type, base_id, ctx.u32_zero_value, addr)
    atomic_scope: u32 = SpirvEmitAtomicScope(ctx)
    return SpirvEmitAtomicIncDec(ctx, opcode, ctx.u32_id, ptr, atomic_scope, ctx.u32_zero_value)

def SpirvEmitBufferAtomicU32CmpSwap(ctx: mutable SpirvEmitContext&, handle: u32, address: u32, value: u32, cmp_value: u32) -> u32:
    buf: SpirvBufferDefinition = ctx.buffers[handle.usize()]
    addr: mutable u32 = address
    offset: u32 = buf.offsets[SPIRV_POINTER_SIZE_B32.usize()]
    if offset != 0u32:
        addr <- SpirvEmitIAdd32(ctx, addr, offset)
    base_id: u32 = buf.alias_ids[SPIRV_POINTER_TYPE_U32.usize()]
    pointer_type: u32 = buf.alias_ptrs[SPIRV_POINTER_TYPE_U32.usize()]
    ptr: u32 = SpirvEmitAccessChain2(ctx, pointer_type, base_id, ctx.u32_zero_value, addr)
    atomic_scope: u32 = SpirvEmitAtomicScope(ctx)
    return SpirvEmitAtomicCompareExchange(ctx, ctx.u32_id, ptr, atomic_scope, ctx.u32_zero_value, ctx.u32_zero_value, value, cmp_value)

# Named buffer-atomic emitters (integer; FP-atomic min/max/cmpswap fallbacks
# need profile flags + extension opcodes and are deferred).
def SpirvEmitBufferAtomicIAdd32(ctx: mutable SpirvEmitContext&, handle: u32, address: u32, value: u32) -> u32:
    return SpirvEmitBufferAtomicU32(ctx, SPIRV_OP_ATOMIC_I_ADD, handle, address, value, false)

def SpirvEmitBufferAtomicIAdd64(ctx: mutable SpirvEmitContext&, handle: u32, address: u32, value: u32) -> u32:
