# Bit-field ops. Insert takes four operands; the extracts take three.
def SpirvEmitBitFieldInsert(ctx: mutable SpirvEmitContext&, base: u32, insert: u32, offset: u32, count: u32) -> u32:
    return SpirvEmitQuaternaryOp(ctx, SPIRV_OP_BIT_FIELD_INSERT, ctx.u32_id, base, insert, offset, count)

def SpirvEmitBitFieldSExtract(ctx: mutable SpirvEmitContext&, base: u32, offset: u32, count: u32) -> u32:
    return SpirvEmitTernaryOp(ctx, SPIRV_OP_BIT_FIELD_S_EXTRACT, ctx.u32_id, base, offset, count)

def SpirvEmitBitFieldUExtract(ctx: mutable SpirvEmitContext&, base: u32, offset: u32, count: u32) -> u32:
    return SpirvEmitTernaryOp(ctx, SPIRV_OP_BIT_FIELD_U_EXTRACT, ctx.u32_id, base, offset, count)

# Bit-scan ops via GLSL.std.450 (U32 result type).
def SpirvEmitFindSMsb32(ctx: mutable SpirvEmitContext&, value: u32) -> u32:
    return SpirvEmitExtInstUnary(ctx, ctx.u32_id, GLSL_STD_450_FIND_SMSB, value)

def SpirvEmitFindUMsb32(ctx: mutable SpirvEmitContext&, value: u32) -> u32:
    return SpirvEmitExtInstUnary(ctx, ctx.u32_id, GLSL_STD_450_FIND_UMSB, value)

def SpirvEmitFindILsb32(ctx: mutable SpirvEmitContext&, value: u32) -> u32:
    return SpirvEmitExtInstUnary(ctx, ctx.u32_id, GLSL_STD_450_FIND_ILSB, value)

# Integer min/max via GLSL.std.450 (U32 result type).
def SpirvEmitSMin32(ctx: mutable SpirvEmitContext&, a: u32, b: u32) -> u32:
    return SpirvEmitExtInstBinary(ctx, ctx.u32_id, GLSL_STD_450_SMIN, a, b)

def SpirvEmitUMin32(ctx: mutable SpirvEmitContext&, a: u32, b: u32) -> u32:
    return SpirvEmitExtInstBinary(ctx, ctx.u32_id, GLSL_STD_450_UMIN, a, b)

def SpirvEmitSMax32(ctx: mutable SpirvEmitContext&, a: u32, b: u32) -> u32:
    return SpirvEmitExtInstBinary(ctx, ctx.u32_id, GLSL_STD_450_SMAX, a, b)

def SpirvEmitUMax32(ctx: mutable SpirvEmitContext&, a: u32, b: u32) -> u32:
    return SpirvEmitExtInstBinary(ctx, ctx.u32_id, GLSL_STD_450_UMAX, a, b)

# Clamp via GLSL.std.450 (no has_broken_spirv_clamp fallback modeled).
def SpirvEmitSClamp32(ctx: mutable SpirvEmitContext&, value: u32, min_v: u32, max_v: u32) -> u32:
    return SpirvEmitExtInstTernary(ctx, ctx.u32_id, GLSL_STD_450_SCLAMP, value, min_v, max_v)

def SpirvEmitUClamp32(ctx: mutable SpirvEmitContext&, value: u32, min_v: u32, max_v: u32) -> u32:
    return SpirvEmitExtInstTernary(ctx, ctx.u32_id, GLSL_STD_450_UCLAMP, value, min_v, max_v)

# Trinary min/max fallback (no AMD trinary minmax support): nested GLSL ops.
def SpirvEmitSMinTri32(ctx: mutable SpirvEmitContext&, a: u32, b: u32, c: u32) -> u32:
    return SpirvEmitSMin32(ctx, a, SpirvEmitSMin32(ctx, b, c))

def SpirvEmitUMinTri32(ctx: mutable SpirvEmitContext&, a: u32, b: u32, c: u32) -> u32:
    return SpirvEmitUMin32(ctx, a, SpirvEmitUMin32(ctx, b, c))

def SpirvEmitSMaxTri32(ctx: mutable SpirvEmitContext&, a: u32, b: u32, c: u32) -> u32:
    return SpirvEmitSMax32(ctx, a, SpirvEmitSMax32(ctx, b, c))

def SpirvEmitUMaxTri32(ctx: mutable SpirvEmitContext&, a: u32, b: u32, c: u32) -> u32:
    return SpirvEmitUMax32(ctx, a, SpirvEmitUMax32(ctx, b, c))

