    return SpirvEmitUnaryOp(ctx, SPIRV_OP_CONVERT_S_TO_F, ctx.f64_id, SpirvEmitExtractS16(ctx, value))

def SpirvEmitConvertF64S32(ctx: mutable SpirvEmitContext&, value: u32) -> u32:
    return SpirvEmitUnaryOp(ctx, SPIRV_OP_CONVERT_S_TO_F, ctx.f64_id, value)

def SpirvEmitConvertF64S64(ctx: mutable SpirvEmitContext&, value: u32) -> u32:
    return SpirvEmitUnaryOp(ctx, SPIRV_OP_CONVERT_S_TO_F, ctx.f64_id, value)

# Unsigned integer -> F64.
def SpirvEmitConvertF64U8(ctx: mutable SpirvEmitContext&, value: u32) -> u32:
    return SpirvEmitUnaryOp(ctx, SPIRV_OP_CONVERT_U_TO_F, ctx.f64_id, SpirvEmitExtractU8(ctx, value))

def SpirvEmitConvertF64U16(ctx: mutable SpirvEmitContext&, value: u32) -> u32:
    return SpirvEmitUnaryOp(ctx, SPIRV_OP_CONVERT_U_TO_F, ctx.f64_id, SpirvEmitExtractU16(ctx, value))

