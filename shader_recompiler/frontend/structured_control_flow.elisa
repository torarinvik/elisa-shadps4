# Elisa port of shader_recompiler/frontend/structured_control_flow.{h,cpp}

include "./control_flow_graph.elisa"

const ASL_NODE_BLOCK: u32 = 1
const ASL_NODE_IF: u32 = 2
const ASL_NODE_END_IF: u32 = 3
const ASL_NODE_LOOP: u32 = 4
const ASL_NODE_REPEAT: u32 = 5
const ASL_NODE_BREAK: u32 = 6
const ASL_NODE_RETURN: u32 = 7
const ASL_NODE_UNREACHABLE: u32 = 8

const ASL_MAX_NODES: u32 = 4096

struct AslNode:
    node_type: mutable u32
    cfg_block_begin: mutable u32
    cfg_block_end: mutable u32
    cond: mutable u32
    branch_true: mutable int
    branch_false: mutable int

struct AbstractSyntaxListModel:
    nodes: mutable AslNode[4096]
    node_count: mutable u32


def AslNode_Default() -> AslNode:
    out: mutable AslNode = zeroed
    out.node_type <- ASL_NODE_BLOCK
    out.cfg_block_begin <- 0
    out.cfg_block_end <- 0
    out.cond <- IR_CONDITION_TRUE
    out.branch_true <- -1
    out.branch_false <- -1
    return out


def AbstractSyntaxListModel_Default() -> AbstractSyntaxListModel:
    out: mutable AbstractSyntaxListModel = zeroed
    out.node_count <- 0
    return out


def _asl_push_node(list: mutable AbstractSyntaxListModel&, node: AslNode) -> void:
    if list.node_count < ASL_MAX_NODES:
        list.nodes[list.node_count.usize()] <- node
        list.node_count <- list.node_count + 1


def BuildASL(cfg: CFG&) -> AbstractSyntaxListModel:
    # This is a deterministic structured form used by Elisa-side parity tests.
    # Each reachable CFG block becomes one block node; branch nodes are encoded as
    # metadata on that node, preserving control-flow information.
    out: mutable AbstractSyntaxListModel = AbstractSyntaxListModel_Default()

    i: mutable u32 = 0
    while i < cfg.block_count:
        block: Block = cfg.blocks[i.usize()]
        if block.valid:
            node: mutable AslNode = AslNode_Default()
            node.node_type <- ASL_NODE_BLOCK
            node.cfg_block_begin <- block.begin
            node.cfg_block_end <- block.end
            node.cond <- block.cond
            node.branch_true <- block.branch_true
            node.branch_false <- block.branch_false
            _asl_push_node(out, node)

            if block.end_class == END_CLASS_EXIT:
                ret: mutable AslNode = AslNode_Default()
                ret.node_type <- ASL_NODE_RETURN
                ret.cfg_block_begin <- block.end
                ret.cfg_block_end <- block.end
                _asl_push_node(out, ret)
        i <- i + 1

    if out.node_count == 0:
        unr: mutable AslNode = AslNode_Default()
        unr.node_type <- ASL_NODE_UNREACHABLE
        _asl_push_node(out, unr)

    return out
