const INST_CLASS_VECTOR_MEM_BUF_FMT: u32 = 53
const INST_CLASS_VECTOR_MEM_IMG_NO_SMP: u32 = 55
const INST_CLASS_VECTOR_MEM_IMG_SMP: u32 = 56
const INST_CLASS_EXP: u32 = 78

