const OPCODE_V_DIV_SCALE_F64: u32 = 925
const OPCODE_V_MAD_U64_U32: u32 = 933
const OPCODE_V_MAD_I64_I32: u32 = 934

const OPCODE_S_LOAD_DWORDX4: u32 = 1588
const OPCODE_S_LSHL_B32: u32 = 30
const OPCODE_S_ANDN2_B64: u32 = 21
const OPCODE_S_BFM_B32: u32 = 36
const OPCODE_BUFFER_LOAD_DWORD: u32 = 1886
const OPCODE_IMAGE_GATHER4_C: u32 = 2068
const OPCODE_IMAGE_GATHER4_C_O: u32 = 2084

struct InputModifiers:
    neg: mutable bool
    neg_hi: mutable bool
    abs: mutable bool
    sext: mutable bool

struct OutputModifiers:
    clamp: mutable bool
    multiplier: mutable f32

struct OperandSelection:
    op_sel: mutable bool
    op_sel_hi: mutable bool

struct DppOperation:
    op: mutable u32
    value: mutable u16
    bc: mutable bool
    row_mask: mutable u8
    bank_mask: mutable u8

struct InstOperand:
    dpp: mutable DppOperation
    output_modifier: mutable OutputModifiers
    field: mutable u32
    type_: mutable u32
    sdwa_dst: mutable u32
    sdwa_sel: mutable u32
    code: mutable u32
    refined_sgpr: mutable GcnScalarRegisterIndex
    refined_vgpr: mutable GcnVectorRegisterIndex
    refined_scalar_selector: mutable GcnScalarOperandSelector
    refined_vector_selector: mutable GcnVectorOperandSelector
    input_modifier: mutable InputModifiers
    op_sel: mutable OperandSelection
    has_dpp: mutable bool
    has_refined_sgpr: mutable bool
    has_refined_vgpr: mutable bool
    has_refined_scalar_selector: mutable bool
    has_refined_vector_selector: mutable bool


def InstOperand_SetScalarRegisterCode(op: mutable InstOperand&, index: GcnScalarRegisterIndex) -> void:
    op.code <- index
    op.has_refined_sgpr <- true
    op.refined_sgpr <- index


def InstOperand_SetVectorRegisterCode(op: mutable InstOperand&, index: GcnVectorRegisterIndex) -> void:
    op.code <- index
    op.has_refined_vgpr <- true
    op.refined_vgpr <- index


def InstOperand_SetScalarSelectorCode(op: mutable InstOperand&, selector: GcnScalarOperandSelector) -> void:
    op.code <- selector
    op.has_refined_scalar_selector <- true
    op.refined_scalar_selector <- selector


def InstOperand_SetVectorSelectorCode(op: mutable InstOperand&, selector: GcnVectorOperandSelector) -> void:
    op.code <- selector
    op.has_refined_vector_selector <- true
    op.refined_vector_selector <- selector


def InstOperand_SetVectorSelectorAsCode(op: mutable InstOperand&, selector: GcnVectorOperandSelector) -> void:
    op.has_refined_vector_selector <- true
    op.refined_vector_selector <- selector
    if op.field == OPERAND_FIELD_VECTOR_GPR:
        op.code <- selector - OPERAND_FIELD_RANGE_VECTOR_GPR_MIN
    else:
        op.code <- selector


def InstOperand_ClearRegisterProofs(op: mutable InstOperand&) -> void:
    op.has_refined_sgpr <- false
    op.has_refined_vgpr <- false
    op.has_refined_scalar_selector <- false
    op.has_refined_vector_selector <- false


def InstOperand_RefinedScalarRegister(op: InstOperand&) -> GcnScalarRegisterIndex:
    return op.refined_sgpr


def InstOperand_RefinedVectorRegister(op: InstOperand&) -> GcnVectorRegisterIndex:
    return op.refined_vgpr


def InstOperand_RefinedScalarSelector(op: InstOperand&) -> GcnScalarOperandSelector:
    return op.refined_scalar_selector


def InstOperand_RefinedVectorSelector(op: InstOperand&) -> GcnVectorOperandSelector:
    return op.refined_vector_selector

struct GcnInst:
    control_sopk_simm: mutable int
    control_sopp_simm: mutable int
    src: mutable InstOperand[4]
    dst: mutable InstOperand[2]
    opcode: mutable u32
    encoding: mutable u32
    inst_class: mutable u32
    category: mutable u32
    length: mutable u32
    src_count: mutable u32
    dst_count: mutable u32

    control_smrd_offset: mutable u32
    control_smrd_count: mutable u32
    control_mubuf_offset: mutable u32
    control_mubuf_count: mutable u32
    control_mubuf_size: mutable u32
    control_mtbuf_offset: mutable u32
    control_mtbuf_count: mutable u32
    control_mtbuf_dfmt: mutable u32
    control_mtbuf_nfmt: mutable u32
    control_mimg_dmask: mutable u32
    control_mimg_mod: mutable u32
    control_ds_offset0: mutable u32
    control_ds_offset1: mutable u32
    control_ds_size: mutable u32
    control_vintrp_chan: mutable u32
    control_vintrp_attr: mutable u32
    control_exp_en: mutable u32
    control_exp_target: mutable u32

    control_smrd_imm: mutable bool
    control_mubuf_offen: mutable bool
    control_mubuf_idxen: mutable bool
    control_mubuf_glc: mutable bool
    control_mubuf_lds: mutable bool
    control_mubuf_slc: mutable bool
    control_mubuf_tfe: mutable bool
    control_mtbuf_offen: mutable bool
    control_mtbuf_idxen: mutable bool
    control_mtbuf_glc: mutable bool
    control_mtbuf_slc: mutable bool
    control_mtbuf_tfe: mutable bool
    control_mimg_unrm: mutable bool
    control_mimg_glc: mutable bool
    control_mimg_da: mutable bool
    control_mimg_r128: mutable bool
    control_mimg_tfe: mutable bool
    control_mimg_lwe: mutable bool
    control_mimg_slc: mutable bool
    control_ds_gds: mutable bool
    control_ds_dual: mutable bool
    control_ds_sign: mutable bool
    control_ds_relative: mutable bool
    control_ds_stride: mutable bool
    control_exp_compr: mutable bool
    control_exp_done: mutable bool
    control_exp_vm: mutable bool


def InstOperand_Default() -> InstOperand:
    out: mutable InstOperand = zeroed
    out.field <- OPERAND_FIELD_UNDEFINED
    out.type_ <- SCALAR_TYPE_UNDEFINED
    out.code <- 0xFFFFFFFF
    return out


def GcnScalarRegisterIndex_Try(value: u32) -> GcnScalarRegisterIndexOptional:
    out: mutable GcnScalarRegisterIndexOptional = zeroed
    if value <= 127:
        out.has_value <- true
        out.value <- value
    return out


def GcnVectorRegisterIndex_Try(value: u32) -> GcnVectorRegisterIndexOptional:
    out: mutable GcnVectorRegisterIndexOptional = zeroed
    if value <= 255:
        out.has_value <- true
        out.value <- value
    return out


def GcnScalarRegisterPairIndex_Try(value: u32) -> GcnScalarRegisterPairIndexOptional:
    out: mutable GcnScalarRegisterPairIndexOptional = zeroed
    if value <= 126:
        out.has_value <- true
        out.value <- value
    return out


def GcnVectorRegisterPairIndex_Try(value: u32) -> GcnVectorRegisterPairIndexOptional:
    out: mutable GcnVectorRegisterPairIndexOptional = zeroed
    if value <= 254:
        out.has_value <- true
        out.value <- value
    return out


def GcnScalarOperandSelector_Try(value: u32) -> GcnScalarOperandSelectorOptional:
    out: mutable GcnScalarOperandSelectorOptional = zeroed
    if value <= 255:
        out.has_value <- true
        out.value <- value
    return out


def GcnVectorOperandSelector_Try(value: u32) -> GcnVectorOperandSelectorOptional:
    out: mutable GcnVectorOperandSelectorOptional = zeroed
    if value <= 511:
        out.has_value <- true
        out.value <- value
    return out


def InstOperand_TryScalarRegisterIndex(op: InstOperand&) -> GcnScalarOperandRegisterIndexOptional:
    out: mutable GcnScalarOperandRegisterIndexOptional = zeroed
    if op.field == OPERAND_FIELD_SCALAR_GPR and op.has_refined_sgpr and op.refined_sgpr <= OPERAND_FIELD_RANGE_SCALAR_GPR_MAX:
        out.has_value <- true
        out.value <- op.refined_sgpr
    return out


def InstOperand_TryVectorRegisterIndex(op: InstOperand&) -> GcnVectorRegisterIndexOptional:
    out: mutable GcnVectorRegisterIndexOptional = zeroed
    if op.field == OPERAND_FIELD_VECTOR_GPR and op.has_refined_vgpr:
        out.has_value <- true
        out.value <- op.refined_vgpr
    return out


def InstOperand_TryScalarOperandSelector(op: InstOperand&) -> GcnScalarOperandSelectorOptional:
    out: mutable GcnScalarOperandSelectorOptional = zeroed
    if op.has_refined_scalar_selector:
        out.has_value <- true
        out.value <- op.refined_scalar_selector
    return out


def InstOperand_TryVectorOperandSelector(op: InstOperand&) -> GcnVectorOperandSelectorOptional:
    out: mutable GcnVectorOperandSelectorOptional = zeroed
    if op.has_refined_vector_selector:
        out.has_value <- true
        out.value <- op.refined_vector_selector
    return out


def GcnReadScalarRegister(idx: GcnScalarRegisterIndex, sgprs: array[u32, 128]&) -> u32:
    return sgprs[idx]


def GcnWriteScalarRegister(idx: GcnScalarRegisterIndex, sgprs: mutable array[u32, 128]&, value: u32) -> void:
    sgprs[idx] <- value


def GcnReadVectorRegister(idx: GcnVectorRegisterIndex, vgprs: array[u32, 256]&) -> u32:
    return vgprs[idx]


def GcnWriteVectorRegister(idx: GcnVectorRegisterIndex, vgprs: mutable array[u32, 256]&, value: u32) -> void:
    vgprs[idx] <- value


def GcnInst_Default() -> GcnInst:
    out: mutable GcnInst = zeroed
    out.opcode <- 0xFFFFFFFF
    out.inst_class <- INST_CLASS_UNDEFINED
    out.category <- INST_CATEGORY_UNDEFINED
    out.length <- 4
    i: mutable u32 = 0
    while i < GCN_MAX_SRC_COUNT:
        out.src[i.usize()] <- InstOperand_Default()
        i <- i + 1
    j: mutable u32 = 0
    while j < GCN_MAX_DST_COUNT:
        out.dst[j.usize()] <- InstOperand_Default()
        j <- j + 1
    return out


def GcnInst_BranchTarget(inst: GcnInst&, pc: u32) -> u32:
    simm_bytes: i64 = inst.control_sopp_simm.i64() * 4
    target: i64 = pc.i64() + simm_bytes + 4
    return target.u32()


def GcnInst_IsUnconditionalBranch(inst: GcnInst&) -> bool:
    return inst.opcode == OPCODE_S_BRANCH or inst.opcode == OPCODE_S_SETPC_B64


def GcnInst_IsFork(inst: GcnInst&) -> bool:
    return inst.opcode == OPCODE_S_CBRANCH_I_FORK or inst.opcode == OPCODE_S_CBRANCH_G_FORK or inst.opcode == OPCODE_S_CBRANCH_JOIN


def GcnInst_IsConditionalBranch(inst: GcnInst&) -> bool:
    if inst.opcode == OPCODE_S_CBRANCH_SCC0:
        return true
    if inst.opcode == OPCODE_S_CBRANCH_SCC1:
        return true
    if inst.opcode == OPCODE_S_CBRANCH_VCCZ:
        return true
    if inst.opcode == OPCODE_S_CBRANCH_VCCNZ:
        return true
    if inst.opcode == OPCODE_S_CBRANCH_EXECZ:
        return true
    if inst.opcode == OPCODE_S_CBRANCH_EXECNZ:
        return true
    return false


def GcnInst_IsTerminateInstruction(inst: GcnInst&) -> bool:
    return GcnInst_IsUnconditionalBranch(inst) or GcnInst_IsConditionalBranch(inst) or GcnInst_IsFork(inst) or inst.opcode == OPCODE_S_ENDPGM


def GcnInst_IsCmpx(inst: GcnInst&) -> bool:
    if inst.opcode >= OPCODE_V_CMPX_F_F32 and inst.opcode <= OPCODE_V_CMPX_T_F32:
        return true
    if inst.opcode >= OPCODE_V_CMPX_F_F64 and inst.opcode <= OPCODE_V_CMPX_T_F64:
        return true
    if inst.opcode >= OPCODE_V_CMPSX_F_F32 and inst.opcode <= OPCODE_V_CMPSX_T_F32:
        return true
    if inst.opcode >= OPCODE_V_CMPSX_F_F64 and inst.opcode <= OPCODE_V_CMPSX_T_F64:
        return true
    if inst.opcode >= OPCODE_V_CMPX_F_I32 and inst.opcode <= OPCODE_V_CMPX_CLASS_F32:
        return true
    if inst.opcode >= OPCODE_V_CMPX_F_I64 and inst.opcode <= OPCODE_V_CMPX_CLASS_F64:
        return true
    if inst.opcode >= OPCODE_V_CMPX_F_U32 and inst.opcode <= OPCODE_V_CMPX_T_U32:
        return true
    if inst.opcode >= OPCODE_V_CMPX_F_U64 and inst.opcode <= OPCODE_V_CMPX_T_U64:
        return true
    return false
