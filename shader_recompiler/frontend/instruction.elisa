const OPCODE_V_CMPX_F_U32: u32 = 373
const OPCODE_V_CMPX_T_U32: u32 = 380
const OPCODE_V_CMPX_F_U64: u32 = 405
const OPCODE_V_CMPX_T_U64: u32 = 412

const OPCODE_V_READLANE_B32: u32 = 414
const OPCODE_V_WRITELANE_B32: u32 = 415
const OPCODE_V_MADMK_F32: u32 = 445
const OPCODE_V_MADAK_F32: u32 = 446
