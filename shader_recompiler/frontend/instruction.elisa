# Elisa port of shader_recompiler/frontend/instruction.{h,cpp}

const GCN_MAX_SRC_COUNT: u32 = 4u32
const GCN_MAX_DST_COUNT: u32 = 2u32

const OPERAND_FIELD_UNDEFINED: u32 = 0xFFFFFFFFu32
const OPERAND_FIELD_SCALAR_GPR: u32 = 0u32
const OPERAND_FIELD_EXEC_LO: u32 = 126u32
const OPERAND_FIELD_CONST_ZERO: u32 = 128u32
const OPERAND_FIELD_SIGNED_CONST_INT_POS: u32 = 129u32
const OPERAND_FIELD_SIGNED_CONST_INT_NEG: u32 = 193u32
const OPERAND_FIELD_LITERAL_CONST: u32 = 255u32
const OPERAND_FIELD_VECTOR_GPR: u32 = 256u32
const OPERAND_FIELD_VCC_LO: u32 = 106u32

const OPERAND_FIELD_RANGE_SCALAR_GPR_MIN: u32 = 0u32
const OPERAND_FIELD_RANGE_SCALAR_GPR_MAX: u32 = 103u32
const OPERAND_FIELD_RANGE_SIGNED_CONST_POS_MIN: u32 = 129u32
const OPERAND_FIELD_RANGE_SIGNED_CONST_POS_MAX: u32 = 192u32
const OPERAND_FIELD_RANGE_SIGNED_CONST_NEG_MIN: u32 = 193u32
const OPERAND_FIELD_RANGE_SIGNED_CONST_NEG_MAX: u32 = 208u32
const OPERAND_FIELD_RANGE_CONST_FLOAT_MIN: u32 = 240u32
const OPERAND_FIELD_RANGE_VECTOR_GPR_MIN: u32 = 256u32
const OPERAND_FIELD_RANGE_VECTOR_GPR_MAX: u32 = 511u32

const SCALAR_TYPE_UNDEFINED: u32 = 0u32
const SCALAR_TYPE_UINT32: u32 = 3u32
const SCALAR_TYPE_UINT64: u32 = 4u32
const SCALAR_TYPE_SINT32: u32 = 6u32
const SCALAR_TYPE_SINT64: u32 = 7u32
const SCALAR_TYPE_ANY: u32 = 9u32

const INST_CLASS_UNDEFINED: u32 = 0u32
const INST_CLASS_SCALAR_ARITH: u32 = 1u32
const INST_CLASS_SCALAR_MOV: u32 = 3u32
const INST_CLASS_SCALAR_MEM_RD: u32 = 50u32
const INST_CLASS_VECTOR_MEM_BUF_NO_FMT: u32 = 52u32
const INST_CLASS_VECTOR_MEM_BUF_FMT: u32 = 53u32
const INST_CLASS_EXPORT: u32 = 55u32

const INST_CATEGORY_UNDEFINED: u32 = 0u32
const INST_CATEGORY_SCALAR_ALU: u32 = 1u32
const INST_CATEGORY_SCALAR_MEMORY: u32 = 2u32
const INST_CATEGORY_VECTOR_MEMORY: u32 = 4u32
const INST_CATEGORY_FLOW_CONTROL: u32 = 5u32

const IR_CONDITION_FALSE: u32 = 0u32
const IR_CONDITION_TRUE: u32 = 1u32
const IR_CONDITION_SCC0: u32 = 2u32
const IR_CONDITION_SCC1: u32 = 3u32
const IR_CONDITION_VCCZ: u32 = 4u32
const IR_CONDITION_VCCNZ: u32 = 5u32
const IR_CONDITION_EXECZ: u32 = 6u32
const IR_CONDITION_EXECNZ: u32 = 7u32

const END_CLASS_BRANCH: u32 = 0u32
const END_CLASS_EXIT: u32 = 1u32

const OPCODE_S_CBRANCH_G_FORK: u32 = 43u32
const OPCODE_S_MOVK_I32: u32 = 45u32
const OPCODE_S_ADDK_I32: u32 = 60u32
const OPCODE_S_CBRANCH_I_FORK: u32 = 62u32
const OPCODE_S_MOV_B32: u32 = 70u32
const OPCODE_S_SETPC_B64: u32 = 99u32
const OPCODE_S_CBRANCH_JOIN: u32 = 117u32
const OPCODE_S_ENDPGM: u32 = 139u32
const OPCODE_S_BRANCH: u32 = 140u32
const OPCODE_S_CBRANCH_SCC0: u32 = 142u32
const OPCODE_S_CBRANCH_SCC1: u32 = 143u32
const OPCODE_S_CBRANCH_VCCZ: u32 = 144u32
const OPCODE_S_CBRANCH_VCCNZ: u32 = 145u32
const OPCODE_S_CBRANCH_EXECZ: u32 = 146u32
const OPCODE_S_CBRANCH_EXECNZ: u32 = 147u32

const OPCODE_V_CMPX_F_F32: u32 = 181u32
const OPCODE_V_CMPX_T_F32: u32 = 196u32
const OPCODE_V_CMPX_F_F64: u32 = 213u32
const OPCODE_V_CMPX_T_F64: u32 = 228u32
const OPCODE_V_CMPSX_F_F32: u32 = 245u32
const OPCODE_V_CMPSX_T_F32: u32 = 260u32
const OPCODE_V_CMPSX_F_F64: u32 = 277u32
const OPCODE_V_CMPSX_T_F64: u32 = 292u32
const OPCODE_V_CMPX_F_I32: u32 = 309u32
const OPCODE_V_CMPX_CLASS_F32: u32 = 317u32
const OPCODE_V_CMPX_F_I64: u32 = 341u32
const OPCODE_V_CMPX_CLASS_F64: u32 = 349u32
const OPCODE_V_CMPX_F_U32: u32 = 373u32
const OPCODE_V_CMPX_T_U32: u32 = 380u32
const OPCODE_V_CMPX_F_U64: u32 = 405u32
const OPCODE_V_CMPX_T_U64: u32 = 412u32

const OPCODE_V_READLANE_B32: u32 = 414u32
const OPCODE_V_WRITELANE_B32: u32 = 415u32
const OPCODE_V_ADD_I32: u32 = 450u32
const OPCODE_V_READFIRSTLANE_B32: u32 = 475u32

const OPCODE_S_LOAD_DWORDX4: u32 = 1588u32
const OPCODE_S_LSHL_B32: u32 = 30u32
const OPCODE_S_BFM_B32: u32 = 36u32
const OPCODE_BUFFER_LOAD_DWORD: u32 = 1886u32

struct InputModifiers:
    neg: mutable bool
    neg_hi: mutable bool
    abs: mutable bool
    sext: mutable bool

struct OutputModifiers:
    clamp: mutable bool
    multiplier: mutable f32

struct OperandSelection:
    op_sel: mutable bool
    op_sel_hi: mutable bool

struct DppOperation:
    op: mutable u32
    value: mutable u16
    bc: mutable bool
    row_mask: mutable u8
    bank_mask: mutable u8

struct InstOperand:
    field: mutable u32
    type_: mutable u32
    input_modifier: mutable InputModifiers
    output_modifier: mutable OutputModifiers
    op_sel: mutable OperandSelection
    sdwa_dst: mutable u32
    sdwa_sel: mutable u32
    has_dpp: mutable bool
    dpp: mutable DppOperation
    code: mutable u32

struct GcnInst:
    opcode: mutable u32
    encoding: mutable u32
    inst_class: mutable u32
    category: mutable u32
    length: mutable u32
    src_count: mutable u32
    dst_count: mutable u32

    control_sopk_simm: mutable int
    control_sopp_simm: mutable int
    control_smrd_offset: mutable u32
    control_smrd_imm: mutable bool
    control_smrd_count: mutable u32
    control_mubuf_offset: mutable u32
    control_mubuf_count: mutable u32
    control_mubuf_size: mutable u32
    control_mtbuf_offset: mutable u32
    control_mtbuf_count: mutable u32
    control_mtbuf_dfmt: mutable u32
    control_mtbuf_nfmt: mutable u32
    control_exp_en: mutable u32
    control_exp_target: mutable u32

    src: mutable InstOperand[4]
    dst: mutable InstOperand[2]


def InstOperand_Default() -> InstOperand:
    out: mutable InstOperand = zeroed
    out.field <- OPERAND_FIELD_UNDEFINED
    out.type_ <- SCALAR_TYPE_UNDEFINED
    out.code <- 0xFFFFFFFFu32
    return out


def GcnInst_Default() -> GcnInst:
    out: mutable GcnInst = zeroed
    out.opcode <- 0xFFFFFFFFu32
    out.inst_class <- INST_CLASS_UNDEFINED
    out.category <- INST_CATEGORY_UNDEFINED
    out.length <- 4u32
    i: mutable u32 = 0u32
    while i < GCN_MAX_SRC_COUNT:
        out.src[i.usize()] <- InstOperand_Default()
        i <- i + 1u32
    j: mutable u32 = 0u32
    while j < GCN_MAX_DST_COUNT:
        out.dst[j.usize()] <- InstOperand_Default()
        j <- j + 1u32
    return out


def GcnInst_BranchTarget(inst: GcnInst&, pc: u32) -> u32:
    simm_bytes: i64 = inst.control_sopp_simm.i64() * 4i64
    target: i64 = pc.i64() + simm_bytes + 4i64
    return target.u32()


def GcnInst_IsUnconditionalBranch(inst: GcnInst&) -> bool:
    return inst.opcode == OPCODE_S_BRANCH or inst.opcode == OPCODE_S_SETPC_B64


def GcnInst_IsFork(inst: GcnInst&) -> bool:
    return inst.opcode == OPCODE_S_CBRANCH_I_FORK or inst.opcode == OPCODE_S_CBRANCH_G_FORK or inst.opcode == OPCODE_S_CBRANCH_JOIN


def GcnInst_IsConditionalBranch(inst: GcnInst&) -> bool:
    if inst.opcode == OPCODE_S_CBRANCH_SCC0:
        return true
    if inst.opcode == OPCODE_S_CBRANCH_SCC1:
        return true
    if inst.opcode == OPCODE_S_CBRANCH_VCCZ:
        return true
    if inst.opcode == OPCODE_S_CBRANCH_VCCNZ:
        return true
    if inst.opcode == OPCODE_S_CBRANCH_EXECZ:
        return true
    if inst.opcode == OPCODE_S_CBRANCH_EXECNZ:
        return true
    return false


def GcnInst_IsTerminateInstruction(inst: GcnInst&) -> bool:
    return GcnInst_IsUnconditionalBranch(inst) or GcnInst_IsConditionalBranch(inst) or GcnInst_IsFork(inst) or inst.opcode == OPCODE_S_ENDPGM


def GcnInst_IsCmpx(inst: GcnInst&) -> bool:
    if inst.opcode >= OPCODE_V_CMPX_F_F32 and inst.opcode <= OPCODE_V_CMPX_T_F32:
        return true
    if inst.opcode >= OPCODE_V_CMPX_F_F64 and inst.opcode <= OPCODE_V_CMPX_T_F64:
        return true
    if inst.opcode >= OPCODE_V_CMPSX_F_F32 and inst.opcode <= OPCODE_V_CMPSX_T_F32:
        return true
    if inst.opcode >= OPCODE_V_CMPSX_F_F64 and inst.opcode <= OPCODE_V_CMPSX_T_F64:
        return true
    if inst.opcode >= OPCODE_V_CMPX_F_I32 and inst.opcode <= OPCODE_V_CMPX_CLASS_F32:
        return true
    if inst.opcode >= OPCODE_V_CMPX_F_I64 and inst.opcode <= OPCODE_V_CMPX_CLASS_F64:
        return true
    if inst.opcode >= OPCODE_V_CMPX_F_U32 and inst.opcode <= OPCODE_V_CMPX_T_U32:
        return true
    if inst.opcode >= OPCODE_V_CMPX_F_U64 and inst.opcode <= OPCODE_V_CMPX_T_U64:
        return true
    return false
