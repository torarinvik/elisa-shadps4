# Elisa port of shader_recompiler/frontend/instruction.{h,cpp}

include "./std_decode.elisa"

const GCN_MAX_SRC_COUNT: u32 = 4
const GCN_MAX_DST_COUNT: u32 = 2

const OPERAND_FIELD_UNDEFINED: u32 = 0xFFFFFFFF
const OPERAND_FIELD_SCALAR_GPR: u32 = 0
const OPERAND_FIELD_VCC_LO: u32 = 106
const OPERAND_FIELD_EXEC_LO: u32 = 126
const OPERAND_FIELD_CONST_ZERO: u32 = 128
const OPERAND_FIELD_SIGNED_CONST_INT_POS: u32 = 129
const OPERAND_FIELD_SIGNED_CONST_INT_NEG: u32 = 193
const OPERAND_FIELD_SDWA: u32 = 249
const OPERAND_FIELD_DPP: u32 = 250
const OPERAND_FIELD_LITERAL_CONST: u32 = 255
const OPERAND_FIELD_VECTOR_GPR: u32 = 256

const OPERAND_FIELD_RANGE_SCALAR_GPR_MIN: u32 = 0
const OPERAND_FIELD_RANGE_SCALAR_GPR_MAX: u32 = 103
const OPERAND_FIELD_RANGE_SIGNED_CONST_POS_MIN: u32 = 129
const OPERAND_FIELD_RANGE_SIGNED_CONST_POS_MAX: u32 = 192
const OPERAND_FIELD_RANGE_SIGNED_CONST_NEG_MIN: u32 = 193
const OPERAND_FIELD_RANGE_SIGNED_CONST_NEG_MAX: u32 = 208
const OPERAND_FIELD_RANGE_CONST_FLOAT_MIN: u32 = 240
const OPERAND_FIELD_RANGE_VECTOR_GPR_MIN: u32 = 256
const OPERAND_FIELD_RANGE_VECTOR_GPR_MAX: u32 = 511

type GcnScalarRegisterIndex = u32 is InRange[0, 127]
type GcnVectorRegisterIndex = u32 is InRange[0, 255]
type GcnScalarRegisterPairIndex = u32 is InRange[0, 126]
type GcnVectorRegisterPairIndex = u32 is InRange[0, 254]
type GcnScalarOperandRegisterIndex = u32 is InRange[0, 103]
type GcnScalarOperandSelector = u32 is InRange[0, 255]
type GcnVectorOperandSelector = u32 is InRange[0, 511]

struct GcnScalarRegisterIndexOptional:
    has_value: mutable bool
    value: mutable GcnScalarRegisterIndex

struct GcnVectorRegisterIndexOptional:
    has_value: mutable bool
    value: mutable GcnVectorRegisterIndex

struct GcnScalarRegisterPairIndexOptional:
    has_value: mutable bool
    value: mutable GcnScalarRegisterPairIndex

struct GcnVectorRegisterPairIndexOptional:
    has_value: mutable bool
    value: mutable GcnVectorRegisterPairIndex

struct GcnScalarOperandRegisterIndexOptional:
    has_value: mutable bool
    value: mutable GcnScalarOperandRegisterIndex

struct GcnScalarOperandSelectorOptional:
    has_value: mutable bool
    value: mutable GcnScalarOperandSelector

struct GcnVectorOperandSelectorOptional:
    has_value: mutable bool
    value: mutable GcnVectorOperandSelector

