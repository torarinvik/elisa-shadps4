# Elisa port of shader_recompiler/frontend/format.cpp

include "./instruction.elisa"

const INST_ENCODING_SOP1: u32 = 3196059648u32
const INST_ENCODING_SOPP: u32 = 3212836864u32
const INST_ENCODING_SOPC: u32 = 3204448256u32
const INST_ENCODING_VOP1: u32 = 2113929216u32
const INST_ENCODING_VOPC: u32 = 2080374784u32
const INST_ENCODING_VOP3: u32 = 3489660928u32
const INST_ENCODING_EXP: u32 = 4160749568u32
const INST_ENCODING_VOP3P: u32 = 3422552064u32
const INST_ENCODING_VINTRP: u32 = 3355443200u32
const INST_ENCODING_DS: u32 = 3623878656u32
const INST_ENCODING_MUBUF: u32 = 3758096384u32
const INST_ENCODING_MTBUF: u32 = 3892314112u32
const INST_ENCODING_MIMG: u32 = 4026531840u32
const INST_ENCODING_SMRD: u32 = 3221225472u32
const INST_ENCODING_SOPK: u32 = 2952790016u32
const INST_ENCODING_SOP2: u32 = 2147483648u32
const INST_ENCODING_VOP2: u32 = 0u32
const INST_ENCODING_ILLEGAL: u32 = 1u32

struct InstFormat:
    inst_class: mutable u32
    inst_category: mutable u32
    src_count: mutable u32
    dst_count: mutable u32
    src_type: mutable u32
    dst_type: mutable u32


def InstFormat_Default() -> InstFormat:
    out: mutable InstFormat = zeroed
    out.inst_class <- INST_CLASS_UNDEFINED
    out.inst_category <- INST_CATEGORY_UNDEFINED
    out.src_type <- SCALAR_TYPE_UNDEFINED
    out.dst_type <- SCALAR_TYPE_UNDEFINED
    return out


def InstFormat_Make(inst_class: u32, inst_category: u32, src_count: u32, dst_count: u32, src_type: u32, dst_type: u32) -> InstFormat:
    out: mutable InstFormat = zeroed
    out.inst_class <- inst_class
    out.inst_category <- inst_category
    out.src_count <- src_count
    out.dst_count <- dst_count
    out.src_type <- src_type
    out.dst_type <- dst_type
    return out


def InstructionFormat(encoding: u32, opcode: u32) -> InstFormat:
    # This is a focused parity port for frontend decode/copy/fetch/control-flow usage.
    if encoding == INST_ENCODING_SOP2:
        if opcode == 0u32:
            return InstFormat_Make(INST_CLASS_SCALAR_ARITH, INST_CATEGORY_SCALAR_ALU, 2u32, 1u32, SCALAR_TYPE_UINT32, SCALAR_TYPE_UINT32)
        if opcode == 1u32:
            return InstFormat_Make(INST_CLASS_SCALAR_ARITH, INST_CATEGORY_SCALAR_ALU, 2u32, 1u32, SCALAR_TYPE_UINT32, SCALAR_TYPE_UINT32)
        if opcode == 30u32:
            return InstFormat_Make(INST_CLASS_SCALAR_ARITH, INST_CATEGORY_SCALAR_ALU, 2u32, 1u32, SCALAR_TYPE_UINT32, SCALAR_TYPE_UINT32)
        if opcode == 36u32:
            return InstFormat_Make(INST_CLASS_SCALAR_ARITH, INST_CATEGORY_SCALAR_ALU, 2u32, 1u32, SCALAR_TYPE_UINT32, SCALAR_TYPE_UINT32)
        if opcode == 21u32:
            return InstFormat_Make(INST_CLASS_SCALAR_ARITH, INST_CATEGORY_SCALAR_ALU, 2u32, 1u32, SCALAR_TYPE_UINT64, SCALAR_TYPE_UINT64)

    if encoding == INST_ENCODING_SOPK:
        if opcode == 0u32:
            return InstFormat_Make(INST_CLASS_SCALAR_MOV, INST_CATEGORY_SCALAR_ALU, 0u32, 1u32, SCALAR_TYPE_SINT32, SCALAR_TYPE_SINT32)
        if opcode == 15u32:
            return InstFormat_Make(INST_CLASS_SCALAR_ARITH, INST_CATEGORY_SCALAR_ALU, 0u32, 1u32, SCALAR_TYPE_SINT32, SCALAR_TYPE_SINT32)

    if encoding == INST_ENCODING_SOP1:
        if opcode == 3u32:
            return InstFormat_Make(INST_CLASS_SCALAR_MOV, INST_CATEGORY_SCALAR_ALU, 1u32, 1u32, SCALAR_TYPE_UINT32, SCALAR_TYPE_UINT32)
        if opcode == 4u32:
            return InstFormat_Make(INST_CLASS_SCALAR_MOV, INST_CATEGORY_SCALAR_ALU, 1u32, 1u32, SCALAR_TYPE_UINT64, SCALAR_TYPE_UINT64)
        if opcode == 31u32:
            return InstFormat_Make(INST_CLASS_SCALAR_MOV, INST_CATEGORY_FLOW_CONTROL, 1u32, 1u32, SCALAR_TYPE_UINT64, SCALAR_TYPE_UINT64)
        if opcode == 32u32:
            return InstFormat_Make(INST_CLASS_SCALAR_MOV, INST_CATEGORY_FLOW_CONTROL, 1u32, 1u32, SCALAR_TYPE_UINT64, SCALAR_TYPE_UINT64)
        if opcode == 36u32:
            return InstFormat_Make(INST_CLASS_SCALAR_ARITH, INST_CATEGORY_SCALAR_ALU, 1u32, 1u32, SCALAR_TYPE_UINT64, SCALAR_TYPE_UINT64)

    if encoding == INST_ENCODING_SOPP:
        if opcode == 1u32:
            return InstFormat_Make(INST_CLASS_SCALAR_MOV, INST_CATEGORY_FLOW_CONTROL, 0u32, 0u32, SCALAR_TYPE_UNDEFINED, SCALAR_TYPE_UNDEFINED)
        if opcode == 2u32:
            return InstFormat_Make(INST_CLASS_SCALAR_MOV, INST_CATEGORY_FLOW_CONTROL, 0u32, 0u32, SCALAR_TYPE_UNDEFINED, SCALAR_TYPE_UNDEFINED)
        if opcode >= 4u32 and opcode <= 9u32:
            return InstFormat_Make(INST_CLASS_SCALAR_MOV, INST_CATEGORY_FLOW_CONTROL, 0u32, 0u32, SCALAR_TYPE_UNDEFINED, SCALAR_TYPE_UNDEFINED)

    if encoding == INST_ENCODING_VOP2:
        if opcode == 1u32:
            return InstFormat_Make(INST_CLASS_SCALAR_MOV, INST_CATEGORY_SCALAR_ALU, 2u32, 1u32, SCALAR_TYPE_UINT32, SCALAR_TYPE_UINT32)
        if opcode == 2u32:
            return InstFormat_Make(INST_CLASS_SCALAR_MOV, INST_CATEGORY_SCALAR_ALU, 2u32, 1u32, SCALAR_TYPE_UINT32, SCALAR_TYPE_UINT32)
        if opcode == 37u32:
            return InstFormat_Make(INST_CLASS_SCALAR_ARITH, INST_CATEGORY_SCALAR_ALU, 2u32, 1u32, SCALAR_TYPE_SINT32, SCALAR_TYPE_SINT32)

    if encoding == INST_ENCODING_SMRD:
        if opcode == 2u32:
            return InstFormat_Make(INST_CLASS_SCALAR_MEM_RD, INST_CATEGORY_SCALAR_MEMORY, 1u32, 1u32, SCALAR_TYPE_UINT32, SCALAR_TYPE_UINT32)

    if encoding == INST_ENCODING_MUBUF:
        if opcode >= 0u32 and opcode <= 3u32:
            return InstFormat_Make(INST_CLASS_VECTOR_MEM_BUF_FMT, INST_CATEGORY_VECTOR_MEMORY, 4u32, 1u32, SCALAR_TYPE_UINT32, SCALAR_TYPE_UINT32)
        if opcode == 12u32:
            return InstFormat_Make(INST_CLASS_VECTOR_MEM_BUF_NO_FMT, INST_CATEGORY_VECTOR_MEMORY, 4u32, 1u32, SCALAR_TYPE_UINT32, SCALAR_TYPE_UINT32)

    if encoding == INST_ENCODING_MTBUF:
        if opcode >= 0u32 and opcode <= 3u32:
            return InstFormat_Make(INST_CLASS_VECTOR_MEM_BUF_FMT, INST_CATEGORY_VECTOR_MEMORY, 4u32, 1u32, SCALAR_TYPE_UINT32, SCALAR_TYPE_UINT32)

    if encoding == INST_ENCODING_EXP:
        if opcode == 0u32:
            return InstFormat_Make(INST_CLASS_EXPORT, INST_CATEGORY_FLOW_CONTROL, 4u32, 0u32, SCALAR_TYPE_UINT32, SCALAR_TYPE_UNDEFINED)

    return InstFormat_Default()
