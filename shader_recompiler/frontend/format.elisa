def InstructionFormat(encoding: u32, opcode: u32) -> InstFormat:
    if encoding == INST_ENCODING_SOP1:
        return _fmt_InstructionFormatSOP1(opcode)
    if encoding == INST_ENCODING_SOPP:
        return _fmt_InstructionFormatSOPP(opcode)
    if encoding == INST_ENCODING_SOPC:
        return _fmt_InstructionFormatSOPC(opcode)
    if encoding == INST_ENCODING_VOP1:
        return _fmt_InstructionFormatVOP1(opcode)
    if encoding == INST_ENCODING_VOPC:
        return _fmt_InstructionFormatVOPC(opcode)
    if encoding == INST_ENCODING_VOP3:
        return _fmt_InstructionFormatVOP3(opcode)
    if encoding == INST_ENCODING_VOP3P:
        return _fmt_InstructionFormatVOP3P(opcode)
    if encoding == INST_ENCODING_EXP:
        return _fmt_InstructionFormatEXP(opcode)
    if encoding == INST_ENCODING_VINTRP:
        return _fmt_InstructionFormatVINTRP(opcode)
    if encoding == INST_ENCODING_DS:
        return _fmt_InstructionFormatDS(opcode)
    if encoding == INST_ENCODING_MUBUF:
        return _fmt_InstructionFormatMUBUF(opcode)
    if encoding == INST_ENCODING_MTBUF:
        return _fmt_InstructionFormatMTBUF(opcode)
    if encoding == INST_ENCODING_MIMG:
        return _fmt_InstructionFormatMIMG(opcode)
    if encoding == INST_ENCODING_SMRD:
        return _fmt_InstructionFormatSMRD(opcode)
    if encoding == INST_ENCODING_SOPK:
        return _fmt_InstructionFormatSOPK(opcode)
    if encoding == INST_ENCODING_SOP2:
        return _fmt_InstructionFormatSOP2(opcode)
    if encoding == INST_ENCODING_VOP2:
        return _fmt_InstructionFormatVOP2(opcode)
    return InstFormat_Default()
