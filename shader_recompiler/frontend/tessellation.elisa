# Native Elisa port of shader_recompiler/frontend/tessellation.h: the
# tessellation data constant buffer layout and the dword-field name attributes.

struct TessellationDataConstantBuffer:
    ls_stride: mutable u32
    hs_cp_stride: mutable u32
    num_patches: mutable u32
    hs_output_base: mutable u32
    patch_const_size: mutable u32
    patch_const_base: mutable u32
    patch_output_size: mutable u32
    off_chip_tessellation_factor_threshold: mutable f32
    first_edge_tess_factor_index: mutable u32

# TessConstantAttribute: names for the dword fields above (sequential indices).
const TESS_CONST_ATTR_LS_STRIDE: u32 = 0
const TESS_CONST_ATTR_HS_CP_STRIDE: u32 = 1
const TESS_CONST_ATTR_HS_NUM_PATCH: u32 = 2
const TESS_CONST_ATTR_HS_OUTPUT_BASE: u32 = 3
const TESS_CONST_ATTR_PATCH_CONST_SIZE: u32 = 4
const TESS_CONST_ATTR_PATCH_CONST_BASE: u32 = 5
const TESS_CONST_ATTR_PATCH_OUTPUT_SIZE: u32 = 6
const TESS_CONST_ATTR_OFF_CHIP_TESSELLATION_FACTOR_THRESHOLD: u32 = 7
const TESS_CONST_ATTR_FIRST_EDGE_TESS_FACTOR_INDEX: u32 = 8
