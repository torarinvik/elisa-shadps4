def S_ADDK_I32(t: void&?, inst: void&?) -> void:
    can Translate.Emit:
        dst_op: void&? = gcn_inst_dst(inst, 0u32)
        old_val: void&? = scalar_get_src(t, dst_op)
        simm16: i32 = inst_sopk_simm16(inst)
        result: void&? = ir_iadd(t, old_val, ir_imm32_u(t, simm16.u32()))
        scalar_set_dst(t, dst_op, result)

def S_MULK_I32(t: void&?, inst: void&?) -> void:
    can Translate.Emit:
        dst_op: void&? = gcn_inst_dst(inst, 0u32)
        old_val: void&? = scalar_get_src(t, dst_op)
        simm16: i32 = inst_sopk_simm16(inst)
        result: void&? = ir_imul(t, old_val, ir_imm32_u(t, simm16.u32()))
        scalar_set_dst(t, dst_op, result)
