# Vector interpolation instruction translation (VINTRP).

const Opcode_V_INTERP_P1_F32:  int = 0
const Opcode_V_INTERP_P2_F32:  int = 1
const Opcode_V_INTERP_MOV_F32: int = 2

# Interpolation mode constants
const InterpMode_Perspective:      int = 0
const InterpMode_Linear:           int = 1
const InterpMode_Flat:             int = 2
const InterpMode_None:             int = 3

# Default (invalid) barycentrics value
const DefaultBary_Val: f32 = 0.0

extern vintrp_get_attrib_component(t: void&?, inst: void&?) -> void&? can[Translate.Emit, Unsafe.RawExtern]
extern vintrp_get_attrib_index(t: void&?, inst: void&?) -> void&? can[Translate.Emit, Unsafe.RawExtern]
extern vintrp_get_interp_mode(t: void&?, attrib: void&?) -> int can[Unsafe.RawExtern]
extern vintrp_is_manual_mode(t: void&?, attrib: void&?) -> bool can[Unsafe.RawExtern]
extern vintrp_get_bary_i(t: void&?) -> void&? can[Translate.Emit, Unsafe.RawExtern]
extern vintrp_get_bary_j(t: void&?) -> void&? can[Translate.Emit, Unsafe.RawExtern]
extern vintrp_get_attrib_p0(t: void&?, attrib: void&?, comp: u32) -> void&? can[Translate.Emit, Unsafe.RawExtern]
extern vintrp_get_attrib_p10(t: void&?, attrib: void&?, comp: u32) -> void&? can[Translate.Emit, Unsafe.RawExtern]
extern vintrp_get_attrib_p20(t: void&?, attrib: void&?, comp: u32) -> void&? can[Translate.Emit, Unsafe.RawExtern]

def vintrp_component_code(t: void&?, inst: void&?) -> u32:
    can Translate.Emit:
        # VINTRP components are attribute lanes, not register indices. Keep the
        # selector as an operand handle until this local IR ABI boundary.
        comp_op: void&? = vintrp_get_attrib_component(t, inst)
        return compat_vector_operand_selector(comp_op)

def EmitVectorInterpolation(t: void&?, inst: void&?) -> void:
    can Translate.Emit:
        op: int = gcn_inst_opcode(inst)
        if op == Opcode_V_INTERP_P1_F32:
            V_INTERP_P1_F32(t, inst)
            return
        if op == Opcode_V_INTERP_P2_F32:
            V_INTERP_P2_F32(t, inst)
            return
        if op == Opcode_V_INTERP_MOV_F32:
            V_INTERP_MOV_F32(t, inst)
            return
        valu_log_missing_opcode(t, inst)

def V_INTERP_P1_F32(t: void&?, inst: void&?) -> void:
    can Translate.Emit:
        attrib: void&? = vintrp_get_attrib_index(t, inst)
        comp: u32 = vintrp_component_code(t, inst)
        is_manual: bool = vintrp_is_manual_mode(t, attrib)
        dst_op: void&? = gcn_inst_dst(inst, 0)

        if is_manual:
            bary_i: void&? = vintrp_get_bary_i(t)
            p0: void&? = vintrp_get_attrib_p0(t, attrib, comp)
            p10: void&? = vintrp_get_attrib_p10(t, attrib, comp)
            result: void&? = ir_fp_fma_f32(t, ir_fp_sub_f32(t, p10, p0), bary_i, p0)
            valu_set_dst_f32(t, dst_op, result)
        else:
            valu_set_dst_f32(t, dst_op, ir_imm32_f(t, DefaultBary_Val))

def V_INTERP_P2_F32(t: void&?, inst: void&?) -> void:
    can Translate.Emit:
        attrib: void&? = vintrp_get_attrib_index(t, inst)
        comp: u32 = vintrp_component_code(t, inst)
        is_manual: bool = vintrp_is_manual_mode(t, attrib)
        dst_op: void&? = gcn_inst_dst(inst, 0)

        if not is_manual:
            result: void&? = ir_get_attribute(t, attrib, comp)
            valu_set_dst_f32(t, dst_op, result)
        else:
            bary_j: void&? = vintrp_get_bary_j(t)
            p0: void&? = vintrp_get_attrib_p0(t, attrib, comp)
            p20: void&? = vintrp_get_attrib_p20(t, attrib, comp)
            vdst: void&? = valu_get_src_f32(t, dst_op)
            result: void&? = ir_fp_fma_f32(t, ir_fp_sub_f32(t, p20, p0), bary_j, vdst)
            valu_set_dst_f32(t, dst_op, result)

def V_INTERP_MOV_F32(t: void&?, inst: void&?) -> void:
    can Translate.Emit:
        attrib: void&? = vintrp_get_attrib_index(t, inst)
        comp: u32 = vintrp_component_code(t, inst)
        interp_mode: int = vintrp_get_interp_mode(t, attrib)
        dst_op: void&? = gcn_inst_dst(inst, 0)

        if interp_mode == InterpMode_Flat:
            valu_set_dst_f32(t, dst_op, ir_get_attribute(t, attrib, comp))
        else:
            result: void&? = ir_get_attribute(t, attrib, comp)
            valu_set_dst_f32(t, dst_op, result)
