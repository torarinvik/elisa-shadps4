def V_CVT_F16_F32(t: void&?, inst: void&?) -> void:
    can Translate.Emit:
        src0: void&? = valu_get_src_f32(t, gcn_inst_src(inst, 0))
        support_f16: bool = profile_support_float16(t)
        result: mutable void&? = null
        if support_f16:
            f16: void&? = ir_fp_convert(t, 16, src0)
            result <- ir_u_convert(t, 32, ir_bit_cast_f16_to_u16(t, f16))
        else:
            packed_val: void&? = ir_pack2x16(t, NumFmt_Float, ir_composite_construct2(t, src0, ir_imm32_f(t, 0.0)))
            result <- ir_bit_field_extract(t, packed_val, ir_imm32_u(t, 0), ir_imm32_u(t, 16), false)
        valu_set_dst_u32(t, gcn_inst_dst(inst, 0), result)

def V_CVT_F32_F16(t: void&?, inst: void&?) -> void:
    can Translate.Emit:
        src0: void&? = valu_get_src_u32(t, gcn_inst_src(inst, 0))
        support_f16: bool = profile_support_float16(t)
        result: mutable void&? = null
        if support_f16:
            u16: void&? = ir_u_convert(t, 16, src0)
            result <- ir_fp_convert(t, 32, ir_bit_cast_u16_to_f16(t, u16))
        else:
            unpacked: void&? = ir_unpack2x16(t, NumFmt_Float, src0)
            result <- ir_composite_extract(t, unpacked, 0)
        valu_set_dst_f32(t, gcn_inst_dst(inst, 0), result)

def V_CVT_RPI_I32_F32(t: void&?, inst: void&?) -> void:
    can Translate.Emit:
        src0: void&? = valu_get_src_f32(t, gcn_inst_src(inst, 0))
        valu_set_dst_u32(t, gcn_inst_dst(inst, 0), ir_convert_f_to_i(t, 32, true, ir_fp_floor_f32(t, ir_fp_add_f32(t, src0, ir_imm32_f(t, 0.5)))))

