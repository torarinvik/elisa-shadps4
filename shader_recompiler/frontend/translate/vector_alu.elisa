# Vector ALU instruction translation for GCN → IR.

# GetSrc / SetDst shims for vector operands
extern valu_get_src_f32(t: void&?, operand: void&?) -> void&? can[Unsafe.RawExtern]
extern valu_get_src_u32(t: void&?, operand: void&?) -> void&? can[Unsafe.RawExtern]
extern valu_get_src_f64(t: void&?, operand: void&?) -> void&? can[Unsafe.RawExtern]
extern valu_get_src_u64(t: void&?, operand: void&?) -> void&? can[Unsafe.RawExtern]
extern valu_get_src16_f32(t: void&?, operand: void&?) -> void&? can[Unsafe.RawExtern]
extern valu_get_src16_u32(t: void&?, operand: void&?) -> void&? can[Unsafe.RawExtern]
extern valu_get_src16_u32_signed(t: void&?, operand: void&?) -> void&? can[Unsafe.RawExtern]
extern valu_get_src_mix(t: void&?, operand: void&?) -> void&? can[Unsafe.RawExtern]
extern valu_get_src_pk_f32(t: void&?, operand: void&?) -> void&? can[Unsafe.RawExtern]
extern valu_get_src_pk_u32(t: void&?, operand: void&?) -> void&? can[Unsafe.RawExtern]
extern valu_get_src_pk_u32_signed(t: void&?, operand: void&?) -> void&? can[Unsafe.RawExtern]
extern valu_set_dst_u32(t: void&?, operand: void&?, val: void&?) -> void can[Unsafe.RawExtern]
extern valu_set_dst_f32(t: void&?, operand: void&?, val: void&?) -> void can[Unsafe.RawExtern]
extern valu_set_dst1(t: void&?, operand: void&?, val: void&?) -> void can[Unsafe.RawExtern]
extern valu_set_dst64(t: void&?, operand: void&?, val: void&?) -> void can[Unsafe.RawExtern]
extern valu_set_dst16_f32(t: void&?, operand: void&?, val: void&?) -> void can[Unsafe.RawExtern]
extern valu_set_dst16_u32(t: void&?, operand: void&?, val: void&?) -> void can[Unsafe.RawExtern]
extern valu_set_dst16_u32_signed(t: void&?, operand: void&?, val: void&?) -> void can[Unsafe.RawExtern]

# Packed operand pair helpers (returns two-element handle)
extern valu_pk_first(pair: void&?) -> void&? can[Unsafe.RawExtern]
extern valu_pk_second(pair: void&?) -> void&? can[Unsafe.RawExtern]
extern valu_set_dst_pk_f32(t: void&?, operand: void&?, lo: void&?, hi: void&?) -> void can[Unsafe.RawExtern]
extern valu_set_dst_pk_u32(t: void&?, operand: void&?, lo: void&?, hi: void&?) -> void can[Unsafe.RawExtern]
extern valu_set_dst_pk_u32_signed(t: void&?, operand: void&?, lo: void&?, hi: void&?) -> void can[Unsafe.RawExtern]

extern valu_log_missing_opcode(t: void&?, inst: void&?) -> void can[Unsafe.RawExtern]

# Number format constants (AmdGpu::NumberFormat)
const NumFmt_Unorm: int = 1
const NumFmt_Snorm: int = 2
const NumFmt_Float: int = 9
const NumFmt_Uint:  int = 4
const NumFmt_Sint:  int = 5

def EmitVectorAlu(t: void&?, inst: void&?) -> void:
    can Translate.Emit:
        op: int = gcn_inst_opcode(inst)
        # dispatch is handled entirely by C++ side via translator_translate;
        # individual handlers below are called from C++ or from tests.
        valu_log_missing_opcode(t, inst)

# ---------------------------------------------------------------------------
# VOP2
# ---------------------------------------------------------------------------

def V_CNDMASK_B32(t: void&?, inst: void&?) -> void:
    can Translate.Emit:
        src2_op: void&? = gcn_inst_src(inst, 2)
        flag: mutable void&? = null
        if operand_field_is_scalar_gpr(src2_op):
            flag <- ir_get_thread_bit_scalar_reg(t, operand_code(src2_op))
        else:
            flag <- ir_get_vcc(t)
        src0: void&? = valu_get_src_f32(t, gcn_inst_src(inst, 0))
        src1: void&? = valu_get_src_f32(t, gcn_inst_src(inst, 1))
        result: void&? = ir_select(t, flag, src1, src0)
        valu_set_dst_u32(t, gcn_inst_dst(inst, 0), result)

def V_ADD_F32(t: void&?, inst: void&?) -> void:
    can Translate.Emit:
        valu_set_dst_f32(t, gcn_inst_dst(inst, 0), ir_fp_add_f32(t, valu_get_src_f32(t, gcn_inst_src(inst, 0)), valu_get_src_f32(t, gcn_inst_src(inst, 1))))

def V_ADD_F64(t: void&?, inst: void&?) -> void:
    can Translate.Emit:
        valu_set_dst64(t, gcn_inst_dst(inst, 0), ir_fp_add_f64(t, valu_get_src_f64(t, gcn_inst_src(inst, 0)), valu_get_src_f64(t, gcn_inst_src(inst, 1))))

def V_SUB_F32(t: void&?, inst: void&?) -> void:
    can Translate.Emit:
        valu_set_dst_f32(t, gcn_inst_dst(inst, 0), ir_fp_sub_f32(t, valu_get_src_f32(t, gcn_inst_src(inst, 0)), valu_get_src_f32(t, gcn_inst_src(inst, 1))))

def V_SUBREV_F32(t: void&?, inst: void&?) -> void:
    can Translate.Emit:
        valu_set_dst_f32(t, gcn_inst_dst(inst, 0), ir_fp_sub_f32(t, valu_get_src_f32(t, gcn_inst_src(inst, 1)), valu_get_src_f32(t, gcn_inst_src(inst, 0))))

def V_MUL_F32(t: void&?, inst: void&?) -> void:
    can Translate.Emit:
        valu_set_dst_f32(t, gcn_inst_dst(inst, 0), ir_fp_mul_f32(t, valu_get_src_f32(t, gcn_inst_src(inst, 0)), valu_get_src_f32(t, gcn_inst_src(inst, 1))))

def V_MUL_LEGACY_F32(t: void&?, inst: void&?) -> void:
    can Translate.Emit:
        src0: void&? = valu_get_src_f32(t, gcn_inst_src(inst, 0))
        src1: void&? = valu_get_src_f32(t, gcn_inst_src(inst, 1))
        zero: void&? = ir_imm32_f(t, 0.0)
        src0_zero: void&? = ir_fp_equal_f32(t, src0, zero)
        src1_zero: void&? = ir_fp_equal_f32(t, src1, zero)
        either_zero: void&? = ir_logical_or(t, src0_zero, src1_zero)
        valu_set_dst_f32(t, gcn_inst_dst(inst, 0), ir_select(t, either_zero, zero, ir_fp_mul_f32(t, src0, src1)))

def V_MUL_I32_I24(t: void&?, is_signed: bool, inst: void&?) -> void:
    can Translate.Emit:
        src0: void&? = ir_bit_field_extract(t, valu_get_src_u32(t, gcn_inst_src(inst, 0)), ir_imm32_u(t, 0), ir_imm32_u(t, 24), is_signed)
        src1: void&? = ir_bit_field_extract(t, valu_get_src_u32(t, gcn_inst_src(inst, 1)), ir_imm32_u(t, 0), ir_imm32_u(t, 24), is_signed)
        valu_set_dst_u32(t, gcn_inst_dst(inst, 0), ir_imul(t, src0, src1))

def V_MIN_F32(t: void&?, is_legacy: bool, inst: void&?) -> void:
    can Translate.Emit:
        src0: void&? = valu_get_src_f32(t, gcn_inst_src(inst, 0))
        src1: void&? = valu_get_src_f32(t, gcn_inst_src(inst, 1))
        fpmin: void&? = ir_fp_min_f32(t, src0, src1)
        result: mutable void&? = fpmin
        if is_legacy:
            nan_cond: void&? = ir_logical_or(t, ir_fp_is_nan_f32(t, src0), ir_fp_is_nan_f32(t, src1))
            result <- ir_select(t, nan_cond, src1, fpmin)
        valu_set_dst_f32(t, gcn_inst_dst(inst, 0), result)

def V_MAX_F32(t: void&?, inst: void&?) -> void:
    can Translate.Emit:
        valu_set_dst_f32(t, gcn_inst_dst(inst, 0), ir_fp_max_f32(t, valu_get_src_f32(t, gcn_inst_src(inst, 0)), valu_get_src_f32(t, gcn_inst_src(inst, 1))))

def V_MAX_F32_LEGACY(t: void&?, inst: void&?) -> void:
    can Translate.Emit:
        src0: void&? = valu_get_src_f32(t, gcn_inst_src(inst, 0))
        src1: void&? = valu_get_src_f32(t, gcn_inst_src(inst, 1))
        fpmax: void&? = ir_fp_max_f32(t, src0, src1)
        nan_cond: void&? = ir_logical_or(t, ir_fp_is_nan_f32(t, src0), ir_fp_is_nan_f32(t, src1))
        valu_set_dst_f32(t, gcn_inst_dst(inst, 0), ir_select(t, nan_cond, src1, fpmax))

def V_MIN_I32(t: void&?, inst: void&?) -> void:
    can Translate.Emit:
        valu_set_dst_u32(t, gcn_inst_dst(inst, 0), ir_smin(t, valu_get_src_u32(t, gcn_inst_src(inst, 0)), valu_get_src_u32(t, gcn_inst_src(inst, 1))))

def V_MIN_U32(t: void&?, inst: void&?) -> void:
    can Translate.Emit:
        valu_set_dst_u32(t, gcn_inst_dst(inst, 0), ir_imin(t, valu_get_src_u32(t, gcn_inst_src(inst, 0)), valu_get_src_u32(t, gcn_inst_src(inst, 1)), false))

def V_MAX_U32(t: void&?, is_signed: bool, inst: void&?) -> void:
    can Translate.Emit:
        valu_set_dst_u32(t, gcn_inst_dst(inst, 0), ir_imax(t, valu_get_src_u32(t, gcn_inst_src(inst, 0)), valu_get_src_u32(t, gcn_inst_src(inst, 1)), is_signed))

def V_LSHR_B32(t: void&?, inst: void&?) -> void:
    can Translate.Emit:
        src0: void&? = valu_get_src_u32(t, gcn_inst_src(inst, 0))
        src1: void&? = valu_get_src_u32(t, gcn_inst_src(inst, 1))
        valu_set_dst_u32(t, gcn_inst_dst(inst, 0), ir_shift_right_logical(t, src0, ir_bitwise_and(t, src1, ir_imm32_u(t, 0x1F))))

def V_LSHRREV_B32(t: void&?, inst: void&?) -> void:
    can Translate.Emit:
        src0: void&? = valu_get_src_u32(t, gcn_inst_src(inst, 0))
        src1: void&? = valu_get_src_u32(t, gcn_inst_src(inst, 1))
        valu_set_dst_u32(t, gcn_inst_dst(inst, 0), ir_shift_right_logical(t, src1, ir_bitwise_and(t, src0, ir_imm32_u(t, 0x1F))))

def V_ASHR_I32(t: void&?, inst: void&?) -> void:
    can Translate.Emit:
        src0: void&? = valu_get_src_u32(t, gcn_inst_src(inst, 0))
        src1: void&? = valu_get_src_u32(t, gcn_inst_src(inst, 1))
        valu_set_dst_u32(t, gcn_inst_dst(inst, 0), ir_shift_right_arithmetic(t, src0, ir_bitwise_and(t, src1, ir_imm32_u(t, 0x1F))))

def V_ASHRREV_I32(t: void&?, inst: void&?) -> void:
    can Translate.Emit:
        src0: void&? = valu_get_src_u32(t, gcn_inst_src(inst, 0))
        src1: void&? = valu_get_src_u32(t, gcn_inst_src(inst, 1))
        valu_set_dst_u32(t, gcn_inst_dst(inst, 0), ir_shift_right_arithmetic(t, src1, ir_bitwise_and(t, src0, ir_imm32_u(t, 0x1F))))

def V_LSHL_B32(t: void&?, inst: void&?) -> void:
    can Translate.Emit:
        src0: void&? = valu_get_src_u32(t, gcn_inst_src(inst, 0))
        src1: void&? = valu_get_src_u32(t, gcn_inst_src(inst, 1))
        valu_set_dst_u32(t, gcn_inst_dst(inst, 0), ir_shift_left_logical(t, src0, ir_bitwise_and(t, src1, ir_imm32_u(t, 0x1F))))

def V_LSHLREV_B32(t: void&?, inst: void&?) -> void:
    can Translate.Emit:
        src0: void&? = valu_get_src_u32(t, gcn_inst_src(inst, 0))
        src1: void&? = valu_get_src_u32(t, gcn_inst_src(inst, 1))
        valu_set_dst_u32(t, gcn_inst_dst(inst, 0), ir_shift_left_logical(t, src1, ir_bitwise_and(t, src0, ir_imm32_u(t, 0x1F))))

def V_AND_B32(t: void&?, inst: void&?) -> void:
    can Translate.Emit:
        valu_set_dst_u32(t, gcn_inst_dst(inst, 0), ir_bitwise_and(t, valu_get_src_u32(t, gcn_inst_src(inst, 0)), valu_get_src_u32(t, gcn_inst_src(inst, 1))))

def V_OR_B32(t: void&?, is_xor: bool, inst: void&?) -> void:
    can Translate.Emit:
        src0: void&? = valu_get_src_u32(t, gcn_inst_src(inst, 0))
        src1: void&? = valu_get_src_u32(t, gcn_inst_src(inst, 1))
        result: mutable void&? = null
        if is_xor:
            result <- ir_bitwise_xor(t, src0, src1)
        else:
            result <- ir_bitwise_or(t, src0, src1)
        valu_set_dst_u32(t, gcn_inst_dst(inst, 0), result)

def V_BFM_B32(t: void&?, inst: void&?) -> void:
    can Translate.Emit:
        src0: void&? = ir_bit_field_extract(t, valu_get_src_u32(t, gcn_inst_src(inst, 0)), ir_imm32_u(t, 0), ir_imm32_u(t, 4), false)
        src1: void&? = ir_bit_field_extract(t, valu_get_src_u32(t, gcn_inst_src(inst, 1)), ir_imm32_u(t, 0), ir_imm32_u(t, 4), false)
        ones: void&? = ir_isub(t, ir_shift_left_logical(t, ir_imm32_u(t, 1), src0), ir_imm32_u(t, 1))
        valu_set_dst_u32(t, gcn_inst_dst(inst, 0), ir_shift_left_logical(t, ones, src1))

def V_MAC_F32(t: void&?, inst: void&?) -> void:
    can Translate.Emit:
        dst_op: void&? = gcn_inst_dst(inst, 0)
        valu_set_dst_f32(t, dst_op, ir_fp_fma_f32(t, valu_get_src_f32(t, gcn_inst_src(inst, 0)), valu_get_src_f32(t, gcn_inst_src(inst, 1)), valu_get_src_f32(t, dst_op)))

def V_MADMK_F32(t: void&?, inst: void&?) -> void:
    can Translate.Emit:
        src0: void&? = valu_get_src_f32(t, gcn_inst_src(inst, 0))
        src1: void&? = valu_get_src_f32(t, gcn_inst_src(inst, 1))
        k: void&? = valu_get_src_f32(t, gcn_inst_src(inst, 2))
        valu_set_dst_f32(t, gcn_inst_dst(inst, 0), ir_fp_fma_f32(t, src0, k, src1))

def V_BCNT_U32_B32(t: void&?, inst: void&?) -> void:
    can Translate.Emit:
        src0: void&? = valu_get_src_u32(t, gcn_inst_src(inst, 0))
        src1: void&? = valu_get_src_u32(t, gcn_inst_src(inst, 1))
        valu_set_dst_u32(t, gcn_inst_dst(inst, 0), ir_iadd(t, ir_bit_count(t, src0), src1))

def V_ADD_I32(t: void&?, inst: void&?) -> void:
    can Translate.Emit:
        result: void&? = ir_iadd(t, valu_get_src_u32(t, gcn_inst_src(inst, 0)), valu_get_src_u32(t, gcn_inst_src(inst, 1)))
        valu_set_dst_u32(t, gcn_inst_dst(inst, 0), result)

def V_SUB_I32(t: void&?, inst: void&?) -> void:
    can Translate.Emit:
        src0: void&? = valu_get_src_u32(t, gcn_inst_src(inst, 0))
        src1: void&? = valu_get_src_u32(t, gcn_inst_src(inst, 1))
        result: void&? = ir_isub(t, src0, src1)
        valu_set_dst_u32(t, gcn_inst_dst(inst, 0), result)
        did_underflow: void&? = ir_igreater_than(t, src1, src0, false)
        V_set_carry_out(t, gcn_inst_dst(inst, 1), inst, did_underflow)

def V_SUBREV_I32(t: void&?, inst: void&?) -> void:
    can Translate.Emit:
        src0: void&? = valu_get_src_u32(t, gcn_inst_src(inst, 0))
        src1: void&? = valu_get_src_u32(t, gcn_inst_src(inst, 1))
        result: void&? = ir_isub(t, src1, src0)
        valu_set_dst_u32(t, gcn_inst_dst(inst, 0), result)
        did_underflow: void&? = ir_igreater_than(t, src0, src1, false)
        V_set_carry_out(t, gcn_inst_dst(inst, 1), inst, did_underflow)

def V_ADDC_U32(t: void&?, inst: void&?) -> void:
    can Translate.Emit:
        src0: void&? = valu_get_src_u32(t, gcn_inst_src(inst, 0))
        src1: void&? = valu_get_src_u32(t, gcn_inst_src(inst, 1))
        carry: void&? = V_get_carry_in(t, inst)
        tmp1: void&? = ir_iadd_carry(t, src0, src1)
        r1: void&? = ir_composite_extract(t, tmp1, 0)
        c1: void&? = ir_composite_extract(t, tmp1, 1)
        tmp2: void&? = ir_iadd_carry(t, r1, carry)
        r2: void&? = ir_composite_extract(t, tmp2, 0)
        c2: void&? = ir_composite_extract(t, tmp2, 1)
        valu_set_dst_u32(t, gcn_inst_dst(inst, 0), r2)
        overflow: void&? = ir_inot_equal(t, ir_bitwise_or(t, c1, c2), ir_imm32_u(t, 0))
        V_set_carry_out(t, gcn_inst_dst(inst, 1), inst, overflow)

def V_SUBB_U32(t: void&?, inst: void&?) -> void:
    can Translate.Emit:
        src0: void&? = valu_get_src_u32(t, gcn_inst_src(inst, 0))
        src1: void&? = valu_get_src_u32(t, gcn_inst_src(inst, 1))
        carry: void&? = V_get_carry_in(t, inst)
        valu_set_dst_u32(t, gcn_inst_dst(inst, 0), ir_isub(t, ir_isub(t, src0, src1), carry))

def V_SUBBREV_U32(t: void&?, inst: void&?) -> void:
    can Translate.Emit:
        src0: void&? = valu_get_src_u32(t, gcn_inst_src(inst, 0))
        src1: void&? = valu_get_src_u32(t, gcn_inst_src(inst, 1))
        carry: void&? = V_get_carry_in(t, inst)
        valu_set_dst_u32(t, gcn_inst_dst(inst, 0), ir_isub(t, ir_isub(t, src1, src0), carry))

def V_LDEXP_F32(t: void&?, inst: void&?) -> void:
    can Translate.Emit:
        valu_set_dst_f32(t, gcn_inst_dst(inst, 0), ir_fp_ldexp_f32(t, valu_get_src_f32(t, gcn_inst_src(inst, 0)), valu_get_src_u32(t, gcn_inst_src(inst, 1))))

def V_CVT_PKNORM_U16_F32(t: void&?, inst: void&?) -> void:
    can Translate.Emit:
        vec: void&? = ir_composite_construct2(t, valu_get_src_f32(t, gcn_inst_src(inst, 0)), valu_get_src_f32(t, gcn_inst_src(inst, 1)))
        valu_set_dst_u32(t, gcn_inst_dst(inst, 0), ir_pack2x16(t, NumFmt_Unorm, vec))

def V_CVT_PKNORM_I16_F32(t: void&?, inst: void&?) -> void:
    can Translate.Emit:
        vec: void&? = ir_composite_construct2(t, valu_get_src_f32(t, gcn_inst_src(inst, 0)), valu_get_src_f32(t, gcn_inst_src(inst, 1)))
        valu_set_dst_u32(t, gcn_inst_dst(inst, 0), ir_pack2x16(t, NumFmt_Snorm, vec))

def V_CVT_PKRTZ_F16_F32(t: void&?, inst: void&?) -> void:
    can Translate.Emit:
        vec: void&? = ir_composite_construct2(t, valu_get_src_f32(t, gcn_inst_src(inst, 0)), valu_get_src_f32(t, gcn_inst_src(inst, 1)))
        valu_set_dst_u32(t, gcn_inst_dst(inst, 0), ir_pack2x16(t, NumFmt_Float, vec))

def V_CVT_PKACCUM_U8_F32(t: void&?, inst: void&?) -> void:
    can Translate.Emit:
        value: void&? = ir_bitwise_and(t, ir_convert_f_to_u(t, 32, valu_get_src_f32(t, gcn_inst_src(inst, 0))), ir_imm32_u(t, 0xFF))
        accum: void&? = ir_shift_left_logical(t, valu_get_src_u32(t, gcn_inst_src(inst, 1)), ir_imm32_u(t, 8))
        valu_set_dst_u32(t, gcn_inst_dst(inst, 0), ir_bitwise_or(t, accum, value))

# F16 VOP2
def V_ADD_F16(t: void&?, inst: void&?) -> void:
    can Translate.Emit:
        valu_set_dst16_f32(t, gcn_inst_dst(inst, 0), ir_fp_add_f32(t, valu_get_src16_f32(t, gcn_inst_src(inst, 0)), valu_get_src16_f32(t, gcn_inst_src(inst, 1))))

def V_SUB_F16(t: void&?, inst: void&?) -> void:
    can Translate.Emit:
        valu_set_dst16_f32(t, gcn_inst_dst(inst, 0), ir_fp_sub_f32(t, valu_get_src16_f32(t, gcn_inst_src(inst, 0)), valu_get_src16_f32(t, gcn_inst_src(inst, 1))))

def V_MUL_F16(t: void&?, inst: void&?) -> void:
    can Translate.Emit:
        valu_set_dst16_f32(t, gcn_inst_dst(inst, 0), ir_fp_mul_f32(t, valu_get_src16_f32(t, gcn_inst_src(inst, 0)), valu_get_src16_f32(t, gcn_inst_src(inst, 1))))

def V_MAX_F16(t: void&?, inst: void&?) -> void:
    can Translate.Emit:
        valu_set_dst16_f32(t, gcn_inst_dst(inst, 0), ir_fp_max_f32(t, valu_get_src16_f32(t, gcn_inst_src(inst, 0)), valu_get_src16_f32(t, gcn_inst_src(inst, 1))))

def V_MIN_F16(t: void&?, inst: void&?) -> void:
    can Translate.Emit:
        valu_set_dst16_f32(t, gcn_inst_dst(inst, 0), ir_fp_min_f32(t, valu_get_src16_f32(t, gcn_inst_src(inst, 0)), valu_get_src16_f32(t, gcn_inst_src(inst, 1))))

# ---------------------------------------------------------------------------
# VOP1
