        src2: void&? = valu_get_src_u64(t, gcn_inst_src(inst, 2))
        mul_lo: void&? = ir_imul(t, src0, src1)
        mul64: void&? = ir_pack_uint2x32(t, ir_composite_construct2(t, mul_lo, ir_imm32_u(t, 0)))
