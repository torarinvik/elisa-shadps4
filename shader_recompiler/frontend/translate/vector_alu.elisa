def V_MAD_F32(t: void&?, inst: void&?) -> void:
    can Translate.Emit:
        valu_set_dst_f32(t, gcn_inst_dst(inst, 0), ir_fp_fma_f32(t, valu_get_src_f32(t, gcn_inst_src(inst, 0)), valu_get_src_f32(t, gcn_inst_src(inst, 1)), valu_get_src_f32(t, gcn_inst_src(inst, 2))))

def V_MAD_I32_I24(t: void&?, is_signed: bool, inst: void&?) -> void:
    can Translate.Emit:
        src0: void&? = ir_bit_field_extract(t, valu_get_src_u32(t, gcn_inst_src(inst, 0)), ir_imm32_u(t, 0), ir_imm32_u(t, 24), is_signed)
        src1: void&? = ir_bit_field_extract(t, valu_get_src_u32(t, gcn_inst_src(inst, 1)), ir_imm32_u(t, 0), ir_imm32_u(t, 24), is_signed)
        src2: void&? = valu_get_src_u32(t, gcn_inst_src(inst, 2))
        valu_set_dst_u32(t, gcn_inst_dst(inst, 0), ir_iadd(t, ir_imul(t, src0, src1), src2))

def V_BFE_U32(t: void&?, is_signed: bool, inst: void&?) -> void:
    can Translate.Emit:
        src0: void&? = valu_get_src_u32(t, gcn_inst_src(inst, 0))
        src1: void&? = valu_get_src_u32(t, gcn_inst_src(inst, 1))
        src2: void&? = valu_get_src_u32(t, gcn_inst_src(inst, 2))
        valu_set_dst_u32(t, gcn_inst_dst(inst, 0), ir_bit_field_extract(t, src0, src1, src2, is_signed))

def V_BFI_B32(t: void&?, inst: void&?) -> void:
    can Translate.Emit:
        src0: void&? = valu_get_src_u32(t, gcn_inst_src(inst, 0))
        src1: void&? = valu_get_src_u32(t, gcn_inst_src(inst, 1))
        src2: void&? = valu_get_src_u32(t, gcn_inst_src(inst, 2))
        valu_set_dst_u32(t, gcn_inst_dst(inst, 0), ir_bitwise_or(t, ir_bitwise_and(t, src0, src1), ir_bitwise_and(t, ir_bitwise_not(t, src0), src2)))

