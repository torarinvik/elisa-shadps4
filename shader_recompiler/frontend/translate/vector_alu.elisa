def V_RCP_F32(t: void&?, inst: void&?) -> void:
    can Translate.Emit:
        valu_set_dst_f32(t, gcn_inst_dst(inst, 0), ir_fp_recip_f32(t, valu_get_src_f32(t, gcn_inst_src(inst, 0))))

def V_RCP_LEGACY_F32(t: void&?, inst: void&?) -> void:
    can Translate.Emit:
        src0: void&? = valu_get_src_f32(t, gcn_inst_src(inst, 0))
        result: void&? = ir_fp_recip_f32(t, src0)
        inf: void&? = ir_fp_is_inf_f32(t, result)
        raw: void&? = ir_convert_f_to_u(t, 32, result)
        sign_bit: void&? = ir_shift_right_logical(t, raw, ir_imm32_u(t, 31))
        sign_set: void&? = ir_inot_equal(t, sign_bit, ir_imm32_u(t, 0))
        inf_result: void&? = ir_select(t, sign_set, ir_imm32_f(t, -0.0), ir_imm32_f(t, 0.0))
        valu_set_dst_f32(t, gcn_inst_dst(inst, 0), ir_select(t, inf, inf_result, result))

