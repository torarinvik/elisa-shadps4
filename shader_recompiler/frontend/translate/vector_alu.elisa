def V_FFBH_U32(t: void&?, inst: void&?) -> void:
    can Translate.Emit:
        src0: void&? = valu_get_src_u32(t, gcn_inst_src(inst, 0))
        msb: void&? = ir_find_u_msb(t, src0)
        pos: void&? = ir_isub(t, ir_imm32_u(t, 31), msb)
        cond: void&? = ir_inot_equal(t, src0, ir_imm32_u(t, 0))
        valu_set_dst_u32(t, gcn_inst_dst(inst, 0), ir_select(t, cond, pos, ir_imm32_u(t, 0xFFFFFFFF)))

def V_FFBL_B32(t: void&?, inst: void&?) -> void:
    can Translate.Emit:
        valu_set_dst_u32(t, gcn_inst_dst(inst, 0), ir_find_i_lsb(t, valu_get_src_u32(t, gcn_inst_src(inst, 0))))

def V_FFBH_I32(t: void&?, inst: void&?) -> void:
    can Translate.Emit:
        src0: void&? = valu_get_src_u32(t, gcn_inst_src(inst, 0))
        msb: void&? = ir_find_s_msb(t, src0)
        pos: void&? = ir_isub(t, ir_imm32_u(t, 31), msb)
        minus_one: void&? = ir_imm32_u(t, 0xFFFFFFFF)
        cond: void&? = ir_logical_and(t, ir_inot_equal(t, src0, ir_imm32_u(t, 0)), ir_inot_equal(t, src0, minus_one))
        valu_set_dst_u32(t, gcn_inst_dst(inst, 0), ir_select(t, cond, pos, minus_one))

