        src0: void&? = valu_get_src_mix(t, gcn_inst_src(inst, 0))
        src1: void&? = valu_get_src_mix(t, gcn_inst_src(inst, 1))
        src2: void&? = valu_get_src_mix(t, gcn_inst_src(inst, 2))
        valu_set_dst_f32(t, gcn_inst_dst(inst, 0), ir_fp_fma_f32(t, src0, src1, src2))

def V_MAD_MIXLO_F16(t: void&?, inst: void&?) -> void:
    can Translate.Emit:
        src0: void&? = valu_get_src_mix(t, gcn_inst_src(inst, 0))
        src1: void&? = valu_get_src_mix(t, gcn_inst_src(inst, 1))
        src2: void&? = valu_get_src_mix(t, gcn_inst_src(inst, 2))
        result: void&? = ir_fp_fma_f32(t, src0, src1, src2)
        f16: void&? = ir_fp_convert(t, 16, result)
        u16: void&? = ir_bit_cast_f16_to_u16(t, f16)
        dst_op: void&? = gcn_inst_dst(inst, 0)
        old_val: void&? = valu_get_src_u32(t, dst_op)
        new_val: void&? = ir_bit_field_insert(t, old_val, ir_u_convert(t, 32, u16), ir_imm32_u(t, 0), ir_imm32_u(t, 16))
        valu_set_dst_u32(t, dst_op, new_val)

def V_MAD_MIXHI_F16(t: void&?, inst: void&?) -> void:
    can Translate.Emit:
        src0: void&? = valu_get_src_mix(t, gcn_inst_src(inst, 0))
        src1: void&? = valu_get_src_mix(t, gcn_inst_src(inst, 1))
        src2: void&? = valu_get_src_mix(t, gcn_inst_src(inst, 2))
        result: void&? = ir_fp_fma_f32(t, src0, src1, src2)
        f16: void&? = ir_fp_convert(t, 16, result)
        u16: void&? = ir_bit_cast_f16_to_u16(t, f16)
        dst_op: void&? = gcn_inst_dst(inst, 0)
        old_val: void&? = valu_get_src_u32(t, dst_op)
        new_val: void&? = ir_bit_field_insert(t, old_val, ir_u_convert(t, 32, u16), ir_imm32_u(t, 16), ir_imm32_u(t, 16))
        valu_set_dst_u32(t, dst_op, new_val)

# ---------------------------------------------------------------------------
# Carry helpers
# ---------------------------------------------------------------------------

def V_get_carry_in(t: void&?, inst: void&?) -> void&?:
    can Translate.Emit:
        src_count: u32 = gcn_inst_src_count(inst)
        if src_count == 3:
            return ir_select(t, scalar_get_src1(t, gcn_inst_src(inst, 2)), ir_imm32_u(t, 1), ir_imm32_u(t, 0))
        return ir_select(t, ir_get_vcc(t), ir_imm32_u(t, 1), ir_imm32_u(t, 0))

def V_set_carry_out(t: void&?, dst1_op: void&?, inst: void&?, carry: void&?) -> void:
    can Translate.Emit:
        dst_count: u32 = gcn_inst_dst_count(inst)
        if dst_count == 2:
            valu_set_dst1(t, dst1_op, carry)
        else:
            ir_set_vcc(t, carry)

# ---------------------------------------------------------------------------
# Cube map helpers
# ---------------------------------------------------------------------------

extern valu_select_cube_result(t: void&?, x: void&?, y: void&?, z: void&?, xr: void&?, yr: void&?, zr: void&?) -> void&? can[Translate.Emit, Unsafe.RawExtern]

def V_CUBEID_F32(t: void&?, inst: void&?) -> void:
    can Translate.Emit:
        x: void&? = valu_get_src_f32(t, gcn_inst_src(inst, 0))
        y: void&? = valu_get_src_f32(t, gcn_inst_src(inst, 1))
        z: void&? = valu_get_src_f32(t, gcn_inst_src(inst, 2))
        result: mutable void&? = null
        if profile_supports_native_cube_calc(t):
            result <- ir_cube_face_index(t, ir_composite_construct3(t, x, y, z))
        else:
            xn: void&? = ir_fp_less_than_f32(t, x, ir_imm32_f(t, 0.0))
            yn: void&? = ir_fp_less_than_f32(t, y, ir_imm32_f(t, 0.0))
            zn: void&? = ir_fp_less_than_f32(t, z, ir_imm32_f(t, 0.0))
            xf: void&? = ir_select(t, xn, ir_imm32_f(t, 1.0), ir_imm32_f(t, 0.0))
            yf: void&? = ir_select(t, yn, ir_imm32_f(t, 3.0), ir_imm32_f(t, 2.0))
            zf: void&? = ir_select(t, zn, ir_imm32_f(t, 5.0), ir_imm32_f(t, 4.0))
            result <- valu_select_cube_result(t, x, y, z, xf, yf, zf)
        valu_set_dst_f32(t, gcn_inst_dst(inst, 0), result)

def V_CUBESC_F32(t: void&?, inst: void&?) -> void:
    can Translate.Emit:
        x: void&? = valu_get_src_f32(t, gcn_inst_src(inst, 0))
        y: void&? = valu_get_src_f32(t, gcn_inst_src(inst, 1))
        z: void&? = valu_get_src_f32(t, gcn_inst_src(inst, 2))
        xn: void&? = ir_fp_less_than_f32(t, x, ir_imm32_f(t, 0.0))
        zn: void&? = ir_fp_less_than_f32(t, z, ir_imm32_f(t, 0.0))
        xsc: void&? = ir_select(t, xn, z, ir_fp_neg_f32(t, z))
        ysc: void&? = x
        zsc: void&? = ir_select(t, zn, ir_fp_neg_f32(t, x), x)
        valu_set_dst_f32(t, gcn_inst_dst(inst, 0), valu_select_cube_result(t, x, y, z, xsc, ysc, zsc))

def V_CUBETC_F32(t: void&?, inst: void&?) -> void:
    can Translate.Emit:
        x: void&? = valu_get_src_f32(t, gcn_inst_src(inst, 0))
        y: void&? = valu_get_src_f32(t, gcn_inst_src(inst, 1))
        z: void&? = valu_get_src_f32(t, gcn_inst_src(inst, 2))
        yn: void&? = ir_fp_less_than_f32(t, y, ir_imm32_f(t, 0.0))
        xztc: void&? = ir_fp_neg_f32(t, y)
        ytc: void&? = ir_select(t, yn, ir_fp_neg_f32(t, z), z)
        valu_set_dst_f32(t, gcn_inst_dst(inst, 0), valu_select_cube_result(t, x, y, z, xztc, ytc, xztc))

def V_CUBEMA_F32(t: void&?, inst: void&?) -> void:
    can Translate.Emit:
        x: void&? = valu_get_src_f32(t, gcn_inst_src(inst, 0))
        y: void&? = valu_get_src_f32(t, gcn_inst_src(inst, 1))
        z: void&? = valu_get_src_f32(t, gcn_inst_src(inst, 2))
        two: void&? = ir_imm32_f(t, 2.0)
        valu_set_dst_f32(t, gcn_inst_dst(inst, 0), valu_select_cube_result(t, x, y, z, ir_fp_mul_f32(t, x, two), ir_fp_mul_f32(t, y, two), ir_fp_mul_f32(t, z, two)))

# Lane ops (V_READFIRSTLANE_B32 / V_READLANE_B32 / V_WRITELANE_B32) are defined
# in data_share.elisa, which writes the correct scalar destination for the
# read-lane ops. The duplicate copies that previously lived here (writing a
# vector dst) collided with those and have been removed.
