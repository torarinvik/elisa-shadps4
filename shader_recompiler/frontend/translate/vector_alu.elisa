# ---------------------------------------------------------------------------
# VOPC
# ---------------------------------------------------------------------------

def V_CMP_F32(t: void&?, op: int, set_exec: bool, inst: void&?) -> void:
    can Translate.Emit:
        src0: void&? = valu_get_src_f32(t, gcn_inst_src(inst, 0))
        src1: void&? = valu_get_src_f32(t, gcn_inst_src(inst, 1))
        result: mutable void&? = null
        if op == ConditionOp_F:
            result <- ir_imm1(t, false)
        if op == ConditionOp_TRU:
            result <- ir_imm1(t, true)
        if op == ConditionOp_EQ:
            result <- ir_fp_equal_f32(t, src0, src1)
        if op == ConditionOp_LG:
            result <- ir_fp_not_equal_f32(t, src0, src1)
        if op == ConditionOp_GT:
            result <- ir_fp_greater_than_f32(t, src0, src1)
        if op == ConditionOp_LT:
            result <- ir_fp_less_than_f32(t, src0, src1)
        if op == ConditionOp_LE:
            result <- ir_fp_less_than_equal_f32(t, src0, src1)
        if op == ConditionOp_GE:
            result <- ir_fp_greater_than_equal_f32(t, src0, src1)
        if op == ConditionOp_U:
            result <- ir_logical_or(t, ir_fp_is_nan_f32(t, src0), ir_fp_is_nan_f32(t, src1))
        if set_exec:
            ir_set_exec(t, result)
        dst1_op: void&? = gcn_inst_dst(inst, 1)
        if operand_field_is_undefined(dst1_op):
            ir_set_vcc(t, result)
        else:
            valu_set_dst1(t, dst1_op, result)

def V_CMP_F64(t: void&?, op: int, set_exec: bool, inst: void&?) -> void:
    can Translate.Emit:
        src0: void&? = valu_get_src_f64(t, gcn_inst_src(inst, 0))
        src1: void&? = valu_get_src_f64(t, gcn_inst_src(inst, 1))
        result: mutable void&? = null
        if op == ConditionOp_F:
            result <- ir_imm1(t, false)
        if op == ConditionOp_EQ:
            result <- ir_fp_equal_f64(t, src0, src1)
        if op == ConditionOp_LG:
            result <- ir_fp_not_equal_f64(t, src0, src1)
        if op == ConditionOp_GT:
            result <- ir_fp_greater_than_f64(t, src0, src1)
        if op == ConditionOp_LT:
            result <- ir_fp_less_than_f64(t, src0, src1)
        if op == ConditionOp_LE:
            result <- ir_fp_less_than_equal_f64(t, src0, src1)
        if op == ConditionOp_GE:
            result <- ir_fp_greater_than_equal_f64(t, src0, src1)
        if op == ConditionOp_U:
            result <- ir_logical_or(t, ir_fp_is_nan_f32(t, src0), ir_fp_is_nan_f32(t, src1))
        if set_exec:
            ir_set_exec(t, result)
        dst1_op: void&? = gcn_inst_dst(inst, 1)
        if operand_field_is_undefined(dst1_op):
            ir_set_vcc(t, result)
        else:
            valu_set_dst1(t, dst1_op, result)

def V_CMP_U32(t: void&?, op: int, is_signed: bool, set_exec: bool, inst: void&?) -> void:
    can Translate.Emit:
        src0: void&? = valu_get_src_u32(t, gcn_inst_src(inst, 0))
        src1: void&? = valu_get_src_u32(t, gcn_inst_src(inst, 1))
        result: mutable void&? = null
        if op == ConditionOp_F:
            result <- ir_imm1(t, false)
        if op == ConditionOp_TRU:
            result <- ir_imm1(t, true)
        if op == ConditionOp_EQ:
            result <- ir_iequal(t, src0, src1)
        if op == ConditionOp_LG:
            result <- ir_inot_equal(t, src0, src1)
        if op == ConditionOp_GT:
            result <- ir_igreater_than(t, src0, src1, is_signed)
        if op == ConditionOp_LT:
            result <- ir_iless_than(t, src0, src1, is_signed)
        if op == ConditionOp_LE:
            result <- ir_iless_than_equal(t, src0, src1, is_signed)
        if op == ConditionOp_GE:
            result <- ir_igreater_than_equal(t, src0, src1, is_signed)
        if set_exec:
            ir_set_exec(t, result)
        dst1_op: void&? = gcn_inst_dst(inst, 1)
        if operand_field_is_undefined(dst1_op):
            ir_set_vcc(t, result)
        else:
            valu_set_dst1(t, dst1_op, result)

extern valu_v_cmp_u64(t: void&?, op: int, is_signed: bool, set_exec: bool, inst: void&?) -> void can[Translate.Emit, Unsafe.RawExtern]
extern valu_v_cmp_class_f32(t: void&?, inst: void&?) -> void can[Translate.Emit, Unsafe.RawExtern]

