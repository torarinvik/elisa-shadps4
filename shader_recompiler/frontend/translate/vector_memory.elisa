# Vector memory instruction translation (MUBUF, MTBUF, MIMG).

# DataFormat constant for FormatInvalid
const DataFmt_FormatInvalid: int = 0

def BUFFER_LOAD(t: void&?, num_dwords: u32, is_inst_typed: bool, is_buffer_typed: bool, inst: void&?, scalar_width: u32, is_signed: bool) -> void:
    can Translate.Emit:
        idxen: bool = gcn_inst_control_mubuf_idxen(inst)
        offen: bool = gcn_inst_control_mubuf_offen(inst)
        vaddr_code: u32 = operand_code(gcn_inst_src(inst, 0u32))
        sharp_code: u32 = operand_code(gcn_inst_src(inst, 2u32)) * 4u32

        index: mutable void&? = null
        voffset_code: mutable u32 = vaddr_code
        if idxen:
            index <- ir_get_vector_reg_u32(t, vaddr_code)
            voffset_code <- vaddr_code + 1u32
        else:
            index <- ir_imm32_u(t, 0u32)

        voffset: mutable void&? = null
        if offen:
            voffset <- ir_get_vector_reg_u32(t, voffset_code)
        else:
            voffset <- ir_imm32_u(t, 0u32)

        soffset: void&? = valu_get_src_u32(t, gcn_inst_src(inst, 3u32))
        address: void&? = ir_composite_construct3(t, index, voffset, soffset)

        buf_info: void&? = buffer_inst_info_new()
        buffer_inst_info_set_index_enable(buf_info, idxen)
        buffer_inst_info_set_voffset_enable(buf_info, offen)
        buffer_inst_info_set_inst_offset(buf_info, gcn_inst_control_mubuf_offset(inst))
        buffer_inst_info_set_globally_coherent(buf_info, gcn_inst_control_mubuf_glc(inst))
        buffer_inst_info_set_system_coherent(buf_info, gcn_inst_control_mubuf_slc(inst))
        typed: bool = is_inst_typed or is_buffer_typed
        buffer_inst_info_set_typed(buf_info, typed)
        if is_inst_typed:
            buffer_inst_info_set_inst_data_fmt(buf_info, gcn_inst_control_mtbuf_dfmt(inst))
            buffer_inst_info_set_inst_num_fmt(buf_info, gcn_inst_control_mtbuf_nfmt(inst))
        else:
            buffer_inst_info_set_inst_data_fmt(buf_info, DataFmt_FormatInvalid)
        buffer_inst_info_set_pc(buf_info, gcn_inst_pc(inst))

        handle: void&? = ir_composite_construct4(t, ir_get_scalar_reg(t, sharp_code), ir_get_scalar_reg(t, sharp_code + 1u32), ir_get_scalar_reg(t, sharp_code + 2u32), ir_get_scalar_reg(t, sharp_code + 3u32))
        dst_code: u32 = operand_code(gcn_inst_src(inst, 1u32))

        if typed:
            value: void&? = ir_load_buffer_format(t, handle, address, buf_info)
            i: mutable u32 = 0u32
            while i < num_dwords:
                ir_set_vector_reg_f32(t, dst_code + i, ir_composite_extract(t, value, i))
                i <- i + 1u32
        else:
            value: mutable void&? = null
            if scalar_width == 8u32:
                byte_val: void&? = ir_load_buffer_u8(t, handle, address, buf_info)
                if is_signed:
                    value <- ir_s_convert(t, 32u32, byte_val)
                else:
                    value <- ir_u_convert(t, 32u32, byte_val)
            if scalar_width == 16u32:
                short_val: void&? = ir_load_buffer_u16(t, handle, address, buf_info)
                if is_signed:
                    value <- ir_s_convert(t, 32u32, short_val)
                else:
                    value <- ir_u_convert(t, 32u32, short_val)
            if scalar_width == 32u32:
                value <- ir_load_buffer_u32(t, num_dwords, handle, address, buf_info)
            if num_dwords == 1u32:
                ir_set_vector_reg_u32(t, dst_code, value)
            else:
                i: mutable u32 = 0u32
                while i < num_dwords:
                    ir_set_vector_reg_u32(t, dst_code + i, ir_composite_extract(t, value, i))
                    i <- i + 1u32
        buffer_inst_info_delete(buf_info)

def BUFFER_STORE(t: void&?, num_dwords: u32, is_inst_typed: bool, is_buffer_typed: bool, inst: void&?, scalar_width: u32) -> void:
    can Translate.Emit:
        idxen: bool = gcn_inst_control_mubuf_idxen(inst)
        offen: bool = gcn_inst_control_mubuf_offen(inst)
        vaddr_code: u32 = operand_code(gcn_inst_src(inst, 0u32))
        sharp_code: u32 = operand_code(gcn_inst_src(inst, 2u32)) * 4u32

        index: mutable void&? = null
        voffset_code: mutable u32 = vaddr_code
        if idxen:
            index <- ir_get_vector_reg_u32(t, vaddr_code)
            voffset_code <- vaddr_code + 1u32
        else:
            index <- ir_imm32_u(t, 0u32)

        voffset: mutable void&? = null
        if offen:
            voffset <- ir_get_vector_reg_u32(t, voffset_code)
        else:
            voffset <- ir_imm32_u(t, 0u32)

        soffset: void&? = valu_get_src_u32(t, gcn_inst_src(inst, 3u32))
        address: void&? = ir_composite_construct3(t, index, voffset, soffset)

        buf_info: void&? = buffer_inst_info_new()
        buffer_inst_info_set_index_enable(buf_info, idxen)
        buffer_inst_info_set_voffset_enable(buf_info, offen)
        buffer_inst_info_set_inst_offset(buf_info, gcn_inst_control_mubuf_offset(inst))
        buffer_inst_info_set_globally_coherent(buf_info, gcn_inst_control_mubuf_glc(inst))
        buffer_inst_info_set_system_coherent(buf_info, gcn_inst_control_mubuf_slc(inst))
        typed: bool = is_inst_typed or is_buffer_typed
        buffer_inst_info_set_typed(buf_info, typed)
        if is_inst_typed:
            buffer_inst_info_set_inst_data_fmt(buf_info, gcn_inst_control_mtbuf_dfmt(inst))
            buffer_inst_info_set_inst_num_fmt(buf_info, gcn_inst_control_mtbuf_nfmt(inst))
        else:
            buffer_inst_info_set_inst_data_fmt(buf_info, DataFmt_FormatInvalid)
        buffer_inst_info_set_pc(buf_info, gcn_inst_pc(inst))

        handle: void&? = ir_composite_construct4(t, ir_get_scalar_reg(t, sharp_code), ir_get_scalar_reg(t, sharp_code + 1u32), ir_get_scalar_reg(t, sharp_code + 2u32), ir_get_scalar_reg(t, sharp_code + 3u32))
        src_code: u32 = operand_code(gcn_inst_src(inst, 1u32))

        if typed:
            comps: mutable void&? = null
            comps0: void&? = ir_get_vector_reg_f32(t, src_code)
            comps1: mutable void&? = ir_imm32_f(t, 0.0f32)
            comps2: mutable void&? = ir_imm32_f(t, 0.0f32)
            comps3: mutable void&? = ir_imm32_f(t, 0.0f32)
            if num_dwords >= 2u32:
                comps1 <- ir_get_vector_reg_f32(t, src_code + 1u32)
            if num_dwords >= 3u32:
                comps2 <- ir_get_vector_reg_f32(t, src_code + 2u32)
            if num_dwords >= 4u32:
                comps3 <- ir_get_vector_reg_f32(t, src_code + 3u32)
            val: void&? = ir_composite_construct4(t, comps0, comps1, comps2, comps3)
            ir_store_buffer_format(t, handle, address, val, buf_info)
        else:
            value: mutable void&? = null
            if num_dwords == 1u32:
                value <- ir_get_vector_reg_u32(t, src_code)
            else:
                c0: void&? = ir_get_vector_reg_u32(t, src_code)
                c1: mutable void&? = ir_imm32_u(t, 0u32)
                c2: mutable void&? = ir_imm32_u(t, 0u32)
                c3: mutable void&? = ir_imm32_u(t, 0u32)
                if num_dwords >= 2u32:
                    c1 <- ir_get_vector_reg_u32(t, src_code + 1u32)
                if num_dwords >= 3u32:
                    c2 <- ir_get_vector_reg_u32(t, src_code + 2u32)
                if num_dwords >= 4u32:
                    c3 <- ir_get_vector_reg_u32(t, src_code + 3u32)
                value <- ir_composite_construct4(t, c0, c1, c2, c3)
            if scalar_width != 32u32:
                value <- ir_u_convert(t, scalar_width, value)
            if scalar_width == 8u32:
                ir_store_buffer_u8(t, handle, address, value, buf_info)
            if scalar_width == 16u32:
                ir_store_buffer_u16(t, handle, address, value, buf_info)
            if scalar_width == 32u32:
                ir_store_buffer_u32(t, num_dwords, handle, address, value, buf_info)
        buffer_inst_info_delete(buf_info)

def BUFFER_ATOMIC_U32(t: void&?, op: int, inst: void&?) -> void:
    can Translate.Emit:
        idxen: bool = gcn_inst_control_mubuf_idxen(inst)
        offen: bool = gcn_inst_control_mubuf_offen(inst)
        vaddr_code: u32 = operand_code(gcn_inst_src(inst, 0u32))
        vdata_code: u32 = operand_code(gcn_inst_src(inst, 1u32))
        srsrc_code: u32 = operand_code(gcn_inst_src(inst, 2u32)) * 4u32

        index: mutable void&? = null
        voffset_code: mutable u32 = vaddr_code
        if idxen:
            index <- ir_get_vector_reg_u32(t, vaddr_code)
            voffset_code <- vaddr_code + 1u32
        else:
            index <- ir_imm32_u(t, 0u32)
        voffset: mutable void&? = null
        if offen:
            voffset <- ir_get_vector_reg_u32(t, voffset_code)
        else:
            voffset <- ir_imm32_u(t, 0u32)

        soffset: void&? = valu_get_src_u32(t, gcn_inst_src(inst, 3u32))
        address: void&? = ir_composite_construct3(t, index, voffset, soffset)

        buf_info: void&? = buffer_inst_info_new()
        buffer_inst_info_set_index_enable(buf_info, idxen)
        buffer_inst_info_set_voffset_enable(buf_info, offen)
        buffer_inst_info_set_inst_offset(buf_info, gcn_inst_control_mubuf_offset(inst))
        buffer_inst_info_set_globally_coherent(buf_info, gcn_inst_control_mubuf_glc(inst))
        buffer_inst_info_set_system_coherent(buf_info, gcn_inst_control_mubuf_slc(inst))
        buffer_inst_info_set_pc(buf_info, gcn_inst_pc(inst))

        vdata: void&? = ir_get_vector_reg_u32(t, vdata_code)
        handle: void&? = ir_composite_construct4(t, ir_get_scalar_reg(t, srsrc_code), ir_get_scalar_reg(t, srsrc_code + 1u32), ir_get_scalar_reg(t, srsrc_code + 2u32), ir_get_scalar_reg(t, srsrc_code + 3u32))

        original_val: mutable void&? = null
        if op == AtomicOp_Swap:
            original_val <- ir_buffer_atomic_swap(t, handle, address, vdata, buf_info)
        if op == AtomicOp_CmpSwap:
            cmp: void&? = ir_get_vector_reg_u32(t, vdata_code + 1u32)
            original_val <- ir_buffer_atomic_cmp_swap(t, handle, address, vdata, cmp, buf_info)
        if op == AtomicOp_Add:
            original_val <- ir_buffer_atomic_iadd(t, handle, address, vdata, buf_info)
        if op == AtomicOp_Smin:
            original_val <- ir_buffer_atomic_imin(t, handle, address, vdata, true, buf_info)
        if op == AtomicOp_Umin:
            original_val <- ir_buffer_atomic_imin(t, handle, address, vdata, false, buf_info)
        if op == AtomicOp_Smax:
            original_val <- ir_buffer_atomic_imax(t, handle, address, vdata, true, buf_info)
        if op == AtomicOp_Umax:
            original_val <- ir_buffer_atomic_imax(t, handle, address, vdata, false, buf_info)
        if op == AtomicOp_And:
            original_val <- ir_buffer_atomic_and(t, handle, address, vdata, buf_info)
        if op == AtomicOp_Or:
            original_val <- ir_buffer_atomic_or(t, handle, address, vdata, buf_info)
        if op == AtomicOp_Xor:
            original_val <- ir_buffer_atomic_xor(t, handle, address, vdata, buf_info)
        if op == AtomicOp_Inc:
            original_val <- ir_buffer_atomic_inc(t, handle, address, buf_info)
        if op == AtomicOp_Dec:
            original_val <- ir_buffer_atomic_dec(t, handle, address, buf_info)
        if op == AtomicOp_Fmin:
            original_val <- ir_buffer_atomic_fmin(t, handle, address, vdata, buf_info)
        if op == AtomicOp_Fmax:
            original_val <- ir_buffer_atomic_fmax(t, handle, address, vdata, buf_info)
        if op == AtomicOp_FCmpSwap:
            cmp: void&? = ir_get_vector_reg_f32(t, vdata_code + 1u32)
            vdata_f32: void&? = ir_get_vector_reg_f32(t, vdata_code)
            original_val <- ir_buffer_atomic_fcmp_swap(t, handle, address, vdata_f32, cmp, buf_info)

        if gcn_inst_control_mubuf_glc(inst):
            ir_set_vector_reg_u32(t, vdata_code, original_val)
        buffer_inst_info_delete(buf_info)

def IMAGE_LOAD(t: void&?, has_mip: bool, inst: void&?) -> void:
    can Translate.Emit:
        addr_code: u32 = operand_code(gcn_inst_src(inst, 0u32))
        dest_code: mutable u32 = operand_code(gcn_inst_dst(inst, 0u32))
        tsharp_code: u32 = operand_code(gcn_inst_src(inst, 2u32)) * 4u32
        dmask: u32 = gcn_inst_control_mimg_dmask(inst)

        handle: void&? = ir_get_scalar_reg(t, tsharp_code)
        body: void&? = ir_composite_construct4(t, ir_get_vector_reg_u32(t, addr_code), ir_get_vector_reg_u32(t, addr_code + 1u32), ir_get_vector_reg_u32(t, addr_code + 2u32), ir_get_vector_reg_u32(t, addr_code + 3u32))

        info: void&? = texture_inst_info_new()
        texture_inst_info_set_has_lod(info, has_mip)
        texture_inst_info_set_is_array(info, gcn_inst_control_mimg_da(inst))
        texture_inst_info_set_is_r128(info, gcn_inst_control_mimg_r128(inst))

        texel: void&? = ir_image_read(t, handle, body, info)

        i: mutable u32 = 0u32
        while i < 4u32:
            if (dmask >> i) & 1u32 != 0u32:
                ir_set_vector_reg_f32(t, dest_code, ir_composite_extract(t, texel, i))
                dest_code <- dest_code + 1u32
            i <- i + 1u32
        texture_inst_info_delete(info)

def IMAGE_STORE(t: void&?, has_mip: bool, inst: void&?) -> void:
    can Translate.Emit:
        addr_code: u32 = operand_code(gcn_inst_src(inst, 0u32))
        data_code: mutable u32 = operand_code(gcn_inst_dst(inst, 0u32))
        tsharp_code: u32 = operand_code(gcn_inst_src(inst, 2u32)) * 4u32
        dmask: u32 = gcn_inst_control_mimg_dmask(inst)

        handle: void&? = ir_get_scalar_reg(t, tsharp_code)
        body: void&? = ir_composite_construct4(t, ir_get_vector_reg_u32(t, addr_code), ir_get_vector_reg_u32(t, addr_code + 1u32), ir_get_vector_reg_u32(t, addr_code + 2u32), ir_get_vector_reg_u32(t, addr_code + 3u32))

        info: void&? = texture_inst_info_new()
        texture_inst_info_set_has_lod(info, has_mip)
        texture_inst_info_set_is_array(info, gcn_inst_control_mimg_da(inst))
        texture_inst_info_set_is_r128(info, gcn_inst_control_mimg_r128(inst))

        c0: mutable void&? = ir_imm32_f(t, 0.0f32)
        c1: mutable void&? = ir_imm32_f(t, 0.0f32)
        c2: mutable void&? = ir_imm32_f(t, 0.0f32)
        c3: mutable void&? = ir_imm32_f(t, 0.0f32)
        slot: mutable u32 = 0u32
        i: mutable u32 = 0u32
        while i < 4u32:
            if (dmask >> i) & 1u32 != 0u32:
                val: void&? = ir_get_vector_reg_f32(t, data_code)
                data_code <- data_code + 1u32
                if slot == 0u32:
                    c0 <- val
                if slot == 1u32:
                    c1 <- val
                if slot == 2u32:
                    c2 <- val
                if slot == 3u32:
                    c3 <- val
                slot <- slot + 1u32
            i <- i + 1u32
        val: void&? = ir_composite_construct4(t, c0, c1, c2, c3)
        ir_image_write(t, handle, body, val, info)
        texture_inst_info_delete(info)

def IMAGE_GET_RESINFO(t: void&?, inst: void&?) -> void:
    can Translate.Emit:
        dst_code: mutable u32 = operand_code(gcn_inst_dst(inst, 0u32))
        tsharp_code: u32 = operand_code(gcn_inst_src(inst, 2u32)) * 4u32
        dmask: u32 = gcn_inst_control_mimg_dmask(inst)
        flags: void&? = image_res_flags(dmask)
        has_mips: bool = image_res_has_mip_count(flags)
        lod: void&? = ir_get_vector_reg_u32(t, operand_code(gcn_inst_src(inst, 0u32)))
        tsharp: void&? = ir_get_scalar_reg(t, tsharp_code)

        info: void&? = texture_inst_info_new()
        texture_inst_info_set_is_array(info, gcn_inst_control_mimg_da(inst))
        texture_inst_info_set_is_r128(info, gcn_inst_control_mimg_r128(inst))

        size: void&? = ir_image_query_dimension(t, tsharp, lod, ir_imm1(t, has_mips), info)
        if image_res_has_width(flags):
            ir_set_vector_reg_u32(t, dst_code, ir_composite_extract(t, size, 0u32))
            dst_code <- dst_code + 1u32
        if image_res_has_height(flags):
            ir_set_vector_reg_u32(t, dst_code, ir_composite_extract(t, size, 1u32))
            dst_code <- dst_code + 1u32
        if image_res_has_depth(flags):
            ir_set_vector_reg_u32(t, dst_code, ir_composite_extract(t, size, 2u32))
            dst_code <- dst_code + 1u32
        if has_mips:
            ir_set_vector_reg_u32(t, dst_code, ir_composite_extract(t, size, 3u32))
        texture_inst_info_delete(info)

def IMAGE_ATOMIC(t: void&?, op: int, inst: void&?) -> void:
    can Translate.Emit:
        val_code: u32 = operand_code(gcn_inst_dst(inst, 0u32))
        addr_code: u32 = operand_code(gcn_inst_src(inst, 0u32))
        tsharp_code: u32 = operand_code(gcn_inst_src(inst, 2u32)) * 4u32

        info: void&? = texture_inst_info_new()
        texture_inst_info_set_is_array(info, gcn_inst_control_mimg_da(inst))
        texture_inst_info_set_is_r128(info, gcn_inst_control_mimg_r128(inst))

        value: void&? = ir_get_vector_reg_u32(t, val_code)
        handle: void&? = ir_get_scalar_reg(t, tsharp_code)
        body: void&? = ir_composite_construct4(t, ir_get_vector_reg_u32(t, addr_code), ir_get_vector_reg_u32(t, addr_code + 1u32), ir_get_vector_reg_u32(t, addr_code + 2u32), ir_get_vector_reg_u32(t, addr_code + 3u32))

        prev: mutable void&? = null
        if op == AtomicOp_Swap:
            prev <- ir_image_atomic_exchange(t, handle, body, value)
        if op == AtomicOp_CmpSwap:
            cmp: void&? = ir_get_vector_reg_u32(t, val_code + 1u32)
            prev <- ir_image_atomic_cmp_swap(t, handle, body, value, cmp, info)
        if op == AtomicOp_Add:
            prev <- ir_image_atomic_iadd(t, handle, body, value, info)
        if op == AtomicOp_Smin:
            prev <- ir_image_atomic_imin(t, handle, body, value, true, info)
        if op == AtomicOp_Umin:
            prev <- ir_image_atomic_umin(t, handle, body, value, info)
        if op == AtomicOp_Smax:
            prev <- ir_image_atomic_imax(t, handle, body, value, true, info)
        if op == AtomicOp_Umax:
            prev <- ir_image_atomic_umax(t, handle, body, value, info)
        if op == AtomicOp_Fmax:
            prev <- ir_image_atomic_fmax(t, handle, body, value, info)
        if op == AtomicOp_Fmin:
            prev <- ir_image_atomic_fmin(t, handle, body, value, info)
        if op == AtomicOp_And:
            prev <- ir_image_atomic_and(t, handle, body, value, info)
        if op == AtomicOp_Or:
            prev <- ir_image_atomic_or(t, handle, body, value, info)
        if op == AtomicOp_Xor:
            prev <- ir_image_atomic_xor(t, handle, body, value, info)
        if op == AtomicOp_Inc:
            prev <- ir_image_atomic_inc(t, handle, body, value, info)
        if op == AtomicOp_Dec:
            prev <- ir_image_atomic_dec(t, handle, body, value, info)

        if gcn_inst_control_mimg_glc(inst):
            ir_set_vector_reg_u32(t, val_code, prev)
        texture_inst_info_delete(info)

def IMAGE_SAMPLE(t: void&?, inst: void&?) -> void:
    can Translate.Emit:
        addr_code: u32 = operand_code(gcn_inst_src(inst, 0u32))
        dest_code: mutable u32 = operand_code(gcn_inst_dst(inst, 0u32))
        tsharp_code: u32 = operand_code(gcn_inst_src(inst, 2u32)) * 4u32
        sampler_code: u32 = operand_code(gcn_inst_src(inst, 3u32)) * 4u32
        dmask: u32 = gcn_inst_control_mimg_dmask(inst)
        mod: u32 = gcn_inst_control_mimg_mod(inst)
        flags: void&? = mimg_modifier_flags(mod)
        is_pcf: bool = mimg_modifier_test_pcf(flags)

        texel: void&? = emit_image_sample_raw(t, inst, tsharp_code, sampler_code, addr_code, false)
        i: mutable u32 = 0u32
        while i < 4u32:
            if (dmask >> i) & 1u32 != 0u32:
                value: mutable void&? = null
                if is_pcf:
                    if i < 3u32:
                        value <- texel
                    else:
                        value <- ir_imm32_f(t, 1.0f32)
                else:
                    value <- ir_composite_extract(t, texel, i)
                ir_set_vector_reg_f32(t, dest_code, value)
                dest_code <- dest_code + 1u32
            i <- i + 1u32

def IMAGE_GATHER(t: void&?, inst: void&?) -> void:
    can Translate.Emit:
        addr_code: u32 = operand_code(gcn_inst_src(inst, 0u32))
        dest_code: mutable u32 = operand_code(gcn_inst_dst(inst, 0u32))
        tsharp_code: u32 = operand_code(gcn_inst_src(inst, 2u32)) * 4u32
        sampler_code: u32 = operand_code(gcn_inst_src(inst, 3u32)) * 4u32

        texel: void&? = emit_image_sample_raw(t, inst, tsharp_code, sampler_code, addr_code, true)
        i: mutable u32 = 0u32
        while i < 4u32:
            ir_set_vector_reg_f32(t, dest_code, ir_composite_extract(t, texel, i))
            dest_code <- dest_code + 1u32
            i <- i + 1u32

def IMAGE_GET_LOD(t: void&?, inst: void&?) -> void:
    can Translate.Emit:
        dst_code: mutable u32 = operand_code(gcn_inst_dst(inst, 0u32))
        addr_code: u32 = operand_code(gcn_inst_src(inst, 0u32))
        tsharp_code: u32 = operand_code(gcn_inst_src(inst, 2u32)) * 4u32

        info: void&? = texture_inst_info_new()
        texture_inst_info_set_is_array(info, gcn_inst_control_mimg_da(inst))
        texture_inst_info_set_is_r128(info, gcn_inst_control_mimg_r128(inst))

        handle: void&? = ir_get_scalar_reg(t, tsharp_code)
        body: void&? = ir_composite_construct4(t, ir_get_vector_reg_f32(t, addr_code), ir_get_vector_reg_f32(t, addr_code + 1u32), ir_get_vector_reg_f32(t, addr_code + 2u32), ir_get_vector_reg_f32(t, addr_code + 3u32))
        lod: void&? = ir_image_query_lod(t, handle, body, info)
        ir_set_vector_reg_f32(t, dst_code, ir_composite_extract(t, lod, 0u32))
        ir_set_vector_reg_f32(t, dst_code + 1u32, ir_composite_extract(t, lod, 1u32))
        texture_inst_info_delete(info)

def emit_image_sample_raw(t: void&?, inst: void&?, tsharp_code: u32, sampler_code: u32, addr_code: u32, gather: bool) -> void&?:
    can Translate.Emit:
        mod: u32 = gcn_inst_control_mimg_mod(inst)
        flags: void&? = mimg_modifier_flags(mod)

        info: void&? = texture_inst_info_new()
        texture_inst_info_set_is_depth(info, mimg_modifier_test_pcf(flags))
        texture_inst_info_set_has_bias(info, mimg_modifier_test_lod_bias(flags))
        texture_inst_info_set_has_lod_clamp(info, mimg_modifier_test_lod_clamp(flags))
        texture_inst_info_set_force_level0(info, mimg_modifier_test_level0(flags))
        texture_inst_info_set_has_offset(info, mimg_modifier_test_offset(flags))
        texture_inst_info_set_has_lod(info, mimg_modifier_any_lod(flags))
        texture_inst_info_set_is_array(info, gcn_inst_control_mimg_da(inst))
        texture_inst_info_set_is_unnormalized(info, gcn_inst_control_mimg_unrm(inst))
        texture_inst_info_set_is_r128(info, gcn_inst_control_mimg_r128(inst))
        texture_inst_info_set_pc(info, gcn_inst_pc(inst))

        if gather:
            texture_inst_info_set_gather_comp(info, mimg_bit_width_minus1(gcn_inst_control_mimg_dmask(inst)))
            texture_inst_info_set_is_gather(info, true)
        else:
            texture_inst_info_set_has_derivatives(info, mimg_modifier_test_derivative(flags))

        image_handle: void&? = ir_get_scalar_reg(t, tsharp_code)
        sampler_handle: void&? = ir_composite_construct4(t, ir_get_scalar_reg(t, sampler_code), ir_get_scalar_reg(t, sampler_code + 1u32), ir_get_scalar_reg(t, sampler_code + 2u32), ir_get_scalar_reg(t, sampler_code + 3u32))

        num_addr_regs: mutable u32 = 4u32
        if mimg_modifier_test_offset(flags):
            num_addr_regs <- num_addr_regs + 1u32
        if mimg_modifier_test_lod_bias(flags):
            num_addr_regs <- num_addr_regs + 1u32
        if mimg_modifier_test_pcf(flags):
            num_addr_regs <- num_addr_regs + 1u32
        if mimg_modifier_test_derivative(flags):
            num_addr_regs <- num_addr_regs + 6u32

        get_addr: void&? = null  # inline below
        a0: void&? = if num_addr_regs >= 1u32: ir_get_vector_reg_f32(t, addr_code) else ir_imm32_f(t, 0.0f32)
        a1: void&? = if num_addr_regs >= 2u32: ir_get_vector_reg_f32(t, addr_code + 1u32) else ir_imm32_f(t, 0.0f32)
        a2: void&? = if num_addr_regs >= 3u32: ir_get_vector_reg_f32(t, addr_code + 2u32) else ir_imm32_f(t, 0.0f32)
        a3: void&? = if num_addr_regs >= 4u32: ir_get_vector_reg_f32(t, addr_code + 3u32) else ir_imm32_f(t, 0.0f32)
        a4: void&? = if num_addr_regs >= 5u32: ir_get_vector_reg_f32(t, addr_code + 4u32) else ir_imm32_f(t, 0.0f32)
        a5: void&? = if num_addr_regs >= 6u32: ir_get_vector_reg_f32(t, addr_code + 5u32) else ir_imm32_f(t, 0.0f32)
        a6: void&? = if num_addr_regs >= 7u32: ir_get_vector_reg_f32(t, addr_code + 6u32) else ir_imm32_f(t, 0.0f32)
        a7: void&? = if num_addr_regs >= 8u32: ir_get_vector_reg_f32(t, addr_code + 7u32) else ir_imm32_f(t, 0.0f32)
        a8: void&? = if num_addr_regs >= 9u32: ir_get_vector_reg_f32(t, addr_code + 8u32) else ir_imm32_f(t, 0.0f32)
        a9: void&? = if num_addr_regs >= 10u32: ir_get_vector_reg_f32(t, addr_code + 9u32) else ir_imm32_f(t, 0.0f32)
        a10: void&? = if num_addr_regs >= 11u32: ir_get_vector_reg_f32(t, addr_code + 10u32) else ir_imm32_f(t, 0.0f32)
        a11: void&? = if num_addr_regs >= 12u32: ir_get_vector_reg_f32(t, addr_code + 11u32) else ir_imm32_f(t, 0.0f32)
        a12: void&? = if num_addr_regs >= 13u32: ir_get_vector_reg_f32(t, addr_code + 12u32) else ir_imm32_f(t, 0.0f32)

        addr1: void&? = ir_composite_construct4(t, a0, a1, a2, a3)
        addr2: void&? = ir_composite_construct4(t, a4, a5, a6, a7)
        addr3: void&? = ir_composite_construct4(t, a8, a9, a10, a11)

        texel: void&? = ir_image_sample_raw(t, image_handle, sampler_handle, addr1, addr2, addr3, a12, info)
        texture_inst_info_delete(info)
        return texel

def EmitVectorMemory(t: void&?, inst: void&?) -> void:
    can Translate.Emit:
        op: int = gcn_inst_opcode(inst)
        # TBUFFER_LOAD_FORMAT_X/XY/XYZ/XYZW
        if op == 0:
            BUFFER_LOAD(t, 1u32, true, false, inst, 32u32, false)
            return
        if op == 1:
            BUFFER_LOAD(t, 2u32, true, false, inst, 32u32, false)
            return
        if op == 2:
            BUFFER_LOAD(t, 3u32, true, false, inst, 32u32, false)
            return
        if op == 3:
            BUFFER_LOAD(t, 4u32, true, false, inst, 32u32, false)
            return
        # BUFFER_LOAD_FORMAT_X/XY/XYZ/XYZW
        if op == 4:
            BUFFER_LOAD(t, 1u32, false, true, inst, 32u32, false)
            return
        if op == 5:
            BUFFER_LOAD(t, 2u32, false, true, inst, 32u32, false)
            return
        if op == 6:
            BUFFER_LOAD(t, 3u32, false, true, inst, 32u32, false)
            return
        if op == 7:
            BUFFER_LOAD(t, 4u32, false, true, inst, 32u32, false)
            return
        # BUFFER_LOAD_UBYTE/SBYTE/USHORT/SSHORT
        if op == 8:
            BUFFER_LOAD(t, 1u32, false, false, inst, 8u32, false)
            return
        if op == 9:
            BUFFER_LOAD(t, 1u32, false, false, inst, 8u32, true)
            return
        if op == 10:
            BUFFER_LOAD(t, 1u32, false, false, inst, 16u32, false)
            return
        if op == 11:
            BUFFER_LOAD(t, 1u32, false, false, inst, 16u32, true)
            return
        # BUFFER_LOAD_DWORD/DWORDX2/DWORDX3/DWORDX4
        if op == 12:
            BUFFER_LOAD(t, 1u32, false, false, inst, 32u32, false)
            return
        if op == 13:
            BUFFER_LOAD(t, 2u32, false, false, inst, 32u32, false)
            return
        if op == 14:
            BUFFER_LOAD(t, 3u32, false, false, inst, 32u32, false)
            return
        if op == 15:
            BUFFER_LOAD(t, 4u32, false, false, inst, 32u32, false)
            return
        # BUFFER_STORE_FORMAT_X/XY/XYZ/XYZW
        if op == 16:
            BUFFER_STORE(t, 1u32, false, true, inst, 32u32)
            return
        if op == 17:
            BUFFER_STORE(t, 2u32, false, true, inst, 32u32)
            return
        if op == 18:
            BUFFER_STORE(t, 3u32, false, true, inst, 32u32)
            return
        if op == 19:
            BUFFER_STORE(t, 4u32, false, true, inst, 32u32)
            return
        # TBUFFER_STORE_FORMAT_X/XY/XYZ/XYZW
        if op == 20:
            BUFFER_STORE(t, 1u32, true, false, inst, 32u32)
            return
        if op == 21:
            BUFFER_STORE(t, 2u32, true, false, inst, 32u32)
            return
        if op == 22:
            BUFFER_STORE(t, 3u32, true, false, inst, 32u32)
            return
        if op == 23:
            BUFFER_STORE(t, 4u32, true, false, inst, 32u32)
            return
        # BUFFER_STORE_BYTE/SHORT/DWORD/DWORDX2/DWORDX3/DWORDX4
        if op == 24:
            BUFFER_STORE(t, 1u32, false, false, inst, 8u32)
            return
        if op == 25:
            BUFFER_STORE(t, 1u32, false, false, inst, 16u32)
            return
        if op == 26:
            BUFFER_STORE(t, 1u32, false, false, inst, 32u32)
            return
        if op == 27:
            BUFFER_STORE(t, 2u32, false, false, inst, 32u32)
            return
        if op == 28:
            BUFFER_STORE(t, 3u32, false, false, inst, 32u32)
            return
        if op == 29:
            BUFFER_STORE(t, 4u32, false, false, inst, 32u32)
            return
        # BUFFER_ATOMIC variants
        if op == 30:
            BUFFER_ATOMIC_U32(t, AtomicOp_Add, inst)
            return
        if op == 31:
            BUFFER_ATOMIC_U32(t, AtomicOp_Swap, inst)
            return
        if op == 32:
            BUFFER_ATOMIC_U32(t, AtomicOp_CmpSwap, inst)
            return
        if op == 33:
            BUFFER_ATOMIC_U32(t, AtomicOp_Smin, inst)
            return
        if op == 34:
            BUFFER_ATOMIC_U32(t, AtomicOp_Umin, inst)
            return
        if op == 35:
            BUFFER_ATOMIC_U32(t, AtomicOp_Smax, inst)
            return
        if op == 36:
            BUFFER_ATOMIC_U32(t, AtomicOp_Umax, inst)
            return
        if op == 37:
            BUFFER_ATOMIC_U32(t, AtomicOp_And, inst)
            return
        if op == 38:
            BUFFER_ATOMIC_U32(t, AtomicOp_Or, inst)
            return
        if op == 39:
            BUFFER_ATOMIC_U32(t, AtomicOp_Xor, inst)
            return
        if op == 40:
            BUFFER_ATOMIC_U32(t, AtomicOp_Inc, inst)
            return
        if op == 41:
            BUFFER_ATOMIC_U32(t, AtomicOp_Dec, inst)
            return
        if op == 42:
            BUFFER_ATOMIC_U32(t, AtomicOp_Fmin, inst)
            return
        if op == 43:
            BUFFER_ATOMIC_U32(t, AtomicOp_Fmax, inst)
            return
        if op == 44:
            BUFFER_ATOMIC_U32(t, AtomicOp_FCmpSwap, inst)
            return
        # IMAGE_LOAD / IMAGE_STORE
        if op == 50:
            IMAGE_LOAD(t, false, inst)
            return
        if op == 51:
            IMAGE_LOAD(t, true, inst)
            return
        if op == 52:
            IMAGE_STORE(t, false, inst)
            return
        if op == 53:
            IMAGE_STORE(t, true, inst)
            return
        # IMAGE_GET_RESINFO
        if op == 54:
            IMAGE_GET_RESINFO(t, inst)
            return
        # IMAGE_ATOMIC variants
        if op == 55:
            IMAGE_ATOMIC(t, AtomicOp_Swap, inst)
            return
        if op == 56:
            IMAGE_ATOMIC(t, AtomicOp_CmpSwap, inst)
            return
        if op == 57:
            IMAGE_ATOMIC(t, AtomicOp_Add, inst)
            return
        if op == 58:
            IMAGE_ATOMIC(t, AtomicOp_Smin, inst)
            return
        if op == 59:
            IMAGE_ATOMIC(t, AtomicOp_Umin, inst)
            return
        if op == 60:
            IMAGE_ATOMIC(t, AtomicOp_Fmin, inst)
            return
        if op == 61:
            IMAGE_ATOMIC(t, AtomicOp_Smax, inst)
            return
        if op == 62:
            IMAGE_ATOMIC(t, AtomicOp_Fmax, inst)
            return
        if op == 63:
            IMAGE_ATOMIC(t, AtomicOp_Umax, inst)
            return
        if op == 64:
            IMAGE_ATOMIC(t, AtomicOp_And, inst)
            return
        if op == 65:
            IMAGE_ATOMIC(t, AtomicOp_Or, inst)
            return
        if op == 66:
            IMAGE_ATOMIC(t, AtomicOp_Xor, inst)
            return
        if op == 67:
            IMAGE_ATOMIC(t, AtomicOp_Inc, inst)
            return
        if op == 68:
            IMAGE_ATOMIC(t, AtomicOp_Dec, inst)
            return
        # IMAGE_SAMPLE / IMAGE_GATHER
        if op >= 70 and op <= 84:
            IMAGE_SAMPLE(t, inst)
            return
        if op >= 85 and op <= 93:
            IMAGE_GATHER(t, inst)
            return
        # IMAGE_GET_LOD
        if op == 94:
            IMAGE_GET_LOD(t, inst)
            return
        valu_log_missing_opcode(t, inst)
