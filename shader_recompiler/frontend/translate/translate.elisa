# Translator top-level entry points (wraps C++ Translator::Translate)
def Translator_Translate(translator: void&?, inst: void&?) -> void:
    can Translate.Emit:
        translator_translate(translator, inst)

def Translator_New(info: void&?, runtime_info: void&?, profile: void&?) -> void&?:
    can Translate.Emit:
        return translator_new(info, runtime_info, profile)

def Translator_Delete(translator: void&?) -> void:
    translator_delete(translator)
