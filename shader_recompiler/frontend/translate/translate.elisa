# Enums
# ---------------------------------------------------------------------------

const ConditionOp_F:   int = 0
const ConditionOp_LT:  int = 1
const ConditionOp_EQ:  int = 2
const ConditionOp_LE:  int = 3
const ConditionOp_GT:  int = 4
const ConditionOp_LG:  int = 5
const ConditionOp_GE:  int = 6
const ConditionOp_U:   int = 7
const ConditionOp_TRU: int = 8

const AtomicOp_Swap:     int = 0
const AtomicOp_CmpSwap:  int = 1
const AtomicOp_FCmpSwap: int = 2
const AtomicOp_Add:      int = 3
const AtomicOp_Smin:     int = 4
const AtomicOp_Umin:     int = 5
const AtomicOp_Smax:     int = 6
const AtomicOp_Umax:     int = 7
const AtomicOp_And:      int = 8
const AtomicOp_Or:       int = 9
const AtomicOp_Xor:      int = 10
const AtomicOp_Inc:      int = 11
const AtomicOp_Dec:      int = 12
const AtomicOp_Fmin:     int = 13
const AtomicOp_Fmax:     int = 14

const NegateMode_None: int = 0
const NegateMode_Src0: int = 1
const NegateMode_Src1: int = 2
const NegateMode_Both: int = 3

# ---------------------------------------------------------------------------
# C shim externs for IR emitter operations
# All IR operations are opaque C++ side; we call them through thin C shims.
# The translator state (ir, info, runtime_info, profile, vgpr_map, pc) is
# allocated on the C++ side and passed as an opaque handle.
# ---------------------------------------------------------------------------

extern translator_new(info: void&?, runtime_info: void&?, profile: void&?) -> void&? can[Translate.Emit, Unsafe.RawExtern]
extern translator_delete(t: void&?) -> void can[Unsafe.RawExtern]
extern translator_translate(t: void&?, inst: void&?) -> void can[Translate.Emit, Unsafe.RawExtern]

# IR emitter — scalar register access
extern ir_get_scalar_reg(t: void&?, reg: u32) -> void&? can[Translate.Emit, Unsafe.RawExtern]
extern ir_set_scalar_reg(t: void&?, reg: u32, val: void&?) -> void can[Translate.Emit, Unsafe.RawExtern]
extern ir_get_thread_bit_scalar_reg(t: void&?, reg: u32) -> void&? can[Translate.Emit, Unsafe.RawExtern]
extern ir_set_thread_bit_scalar_reg(t: void&?, reg: u32, val: void&?) -> void can[Translate.Emit, Unsafe.RawExtern]

# IR emitter — vector register access
extern ir_get_vector_reg_u32(t: void&?, reg: u32) -> void&? can[Translate.Emit, Unsafe.RawExtern]
extern ir_get_vector_reg_f32(t: void&?, reg: u32) -> void&? can[Translate.Emit, Unsafe.RawExtern]
extern ir_set_vector_reg_u32(t: void&?, reg: u32, val: void&?) -> void can[Translate.Emit, Unsafe.RawExtern]
extern ir_set_vector_reg_f32(t: void&?, reg: u32, val: void&?) -> void can[Translate.Emit, Unsafe.RawExtern]

def compat_vgpr_reg_index(operand: void&?) -> u32:
    if operand_has_refined_vgpr(operand):
        return operand_refined_vgpr(operand)
    return operand_code(operand)

def compat_sgpr_reg_index(operand: void&?) -> u32:
    if operand_has_refined_sgpr(operand):
        return operand_refined_sgpr(operand)
    return operand_code(operand)

def compat_scalar_operand_selector(operand: void&?) -> u32:
    if operand_has_refined_scalar_selector(operand):
        return operand_refined_scalar_selector(operand)
    return operand_code(operand)

def compat_vector_operand_selector(operand: void&?) -> u32:
    if operand_has_refined_vector_selector(operand):
        return operand_refined_vector_selector(operand)
    return operand_code(operand)

def refined_vgpr_reg_index(operand: void&?) -> u32:
    assert(operand_has_refined_vgpr(operand))
    return operand_refined_vgpr(operand)

def refined_sgpr_reg_index(operand: void&?) -> u32:
    assert(operand_has_refined_sgpr(operand))
    return operand_refined_sgpr(operand)

def refined_scalar_operand_selector(operand: void&?) -> u32:
    assert(operand_has_refined_scalar_selector(operand))
    return operand_refined_scalar_selector(operand)

def refined_vector_operand_selector(operand: void&?) -> u32:
    assert(operand_has_refined_vector_selector(operand))
    return operand_refined_vector_selector(operand)

def descriptor_sgpr_lane(operand: void&?, lane: u32) -> u32:
    return compat_sgpr_reg_index(operand) * 4 + lane

def refined_descriptor_sgpr_lane(operand: void&?, lane: u32) -> u32:
    return refined_sgpr_reg_index(operand) * 4 + lane

def get_sgpr(t: void&?, reg: u32) -> void&?:
    can Translate.Emit:
        return ir_get_scalar_reg(t, reg)

def set_sgpr(t: void&?, reg: u32, val: void&?) -> void:
    can Translate.Emit:
        ir_set_scalar_reg(t, reg, val)

def get_thread_bit_sgpr(t: void&?, reg: u32) -> void&?:
    can Translate.Emit:
        return ir_get_thread_bit_scalar_reg(t, reg)

def set_thread_bit_sgpr(t: void&?, reg: u32, val: void&?) -> void:
    can Translate.Emit:
        ir_set_thread_bit_scalar_reg(t, reg, val)

def get_vgpr_u32(t: void&?, reg: u32) -> void&?:
    can Translate.Emit:
        return ir_get_vector_reg_u32(t, reg)

def get_vgpr_f32(t: void&?, reg: u32) -> void&?:
    can Translate.Emit:
        return ir_get_vector_reg_f32(t, reg)

def set_vgpr_u32(t: void&?, reg: u32, val: void&?) -> void:
    can Translate.Emit:
        ir_set_vector_reg_u32(t, reg, val)

def set_vgpr_f32(t: void&?, reg: u32, val: void&?) -> void:
    can Translate.Emit:
        ir_set_vector_reg_f32(t, reg, val)

def vgpr_u32_at(t: void&?, operand: void&?, offset: u32) -> void&?:
    can Translate.Emit:
        return get_vgpr_u32(t, compat_vgpr_reg_index(operand) + offset)

def vgpr_f32_at(t: void&?, operand: void&?, offset: u32) -> void&?:
    can Translate.Emit:
        return get_vgpr_f32(t, compat_vgpr_reg_index(operand) + offset)

def set_vgpr_u32_at(t: void&?, operand: void&?, offset: u32, val: void&?) -> void:
    can Translate.Emit:
        set_vgpr_u32(t, compat_vgpr_reg_index(operand) + offset, val)

def set_vgpr_f32_at(t: void&?, operand: void&?, offset: u32, val: void&?) -> void:
    can Translate.Emit:
        set_vgpr_f32(t, compat_vgpr_reg_index(operand) + offset, val)

def sgpr_at(t: void&?, operand: void&?, offset: u32) -> void&?:
    can Translate.Emit:
        return get_sgpr(t, compat_sgpr_reg_index(operand) + offset)

def set_sgpr_at(t: void&?, operand: void&?, offset: u32, val: void&?) -> void:
    can Translate.Emit:
        set_sgpr(t, compat_sgpr_reg_index(operand) + offset, val)

def refined_vgpr_u32_at(t: void&?, operand: void&?, offset: u32) -> void&?:
    can Translate.Emit:
        return get_vgpr_u32(t, refined_vgpr_reg_index(operand) + offset)

def refined_set_vgpr_u32_at(t: void&?, operand: void&?, offset: u32, val: void&?) -> void:
    can Translate.Emit:
        set_vgpr_u32(t, refined_vgpr_reg_index(operand) + offset, val)

def refined_sgpr_at(t: void&?, operand: void&?, offset: u32) -> void&?:
    can Translate.Emit:
        return get_sgpr(t, refined_sgpr_reg_index(operand) + offset)

def refined_set_sgpr_at(t: void&?, operand: void&?, offset: u32, val: void&?) -> void:
    can Translate.Emit:
        set_sgpr(t, refined_sgpr_reg_index(operand) + offset, val)

def sgpr_resource_at(t: void&?, operand: void&?, offset: u32) -> void&?:
    can Translate.Emit:
        return get_sgpr(t, descriptor_sgpr_lane(operand, offset))

def thread_bit_sgpr(t: void&?, operand: void&?) -> void&?:
    can Translate.Emit:
        return get_thread_bit_sgpr(t, compat_sgpr_reg_index(operand))

