def ShaderIrOpcode_NumArgsOf(op: u32) -> u32:
    if op < 400:
        return IR_OPCODE_NUM_ARGS_TABLE[op.usize()]
    return 0

def ShaderIrOpcode_TypeOf(op: u32) -> u32:
    if op < 400:
        return IR_OPCODE_TYPE_TABLE[op.usize()]
    return IR_TYPE_VOID
