const IR_ATTRIBUTE_NUM_RENDER_TARGETS: usize = 8
const IR_ATTRIBUTE_NUM_PARAMS: usize = 32

def ShaderIrAttribute_IsPosition(attribute: u64) -> bool:
    return attribute >= IR_ATTRIBUTE_POSITION0 and attribute <= IR_ATTRIBUTE_POSITION3

def ShaderIrAttribute_IsTessCoord(attribute: u64) -> bool:
    return attribute >= IR_ATTRIBUTE_TESSELLATIONEVALUATIONPOINTU and attribute <= IR_ATTRIBUTE_TESSELLATIONEVALUATIONPOINTV

def ShaderIrAttribute_IsParam(attribute: u64) -> bool:
    return attribute >= IR_ATTRIBUTE_PARAM0 and attribute <= IR_ATTRIBUTE_PARAM31

def ShaderIrAttribute_IsMrt(attribute: u64) -> bool:
    return attribute >= IR_ATTRIBUTE_RENDERTARGET0 and attribute <= IR_ATTRIBUTE_RENDERTARGET7

def ShaderIrAttribute_IsBarycentricCoord(attribute: u64) -> bool:
    return attribute >= IR_ATTRIBUTE_BARYCOORDNOPERSP and attribute <= IR_ATTRIBUTE_BARYCOORDSMOOTHSAMPLE

def ShaderIrAttribute_Add(attribute: u64, num: int) -> u64:
    result: int = attribute.int() + num
    if result > IR_ATTRIBUTE_PARAM31.int():
        assert false
    if result < IR_ATTRIBUTE_RENDERTARGET0.int():
        assert false
    return result.u64()

def ShaderIrAttribute_NameOf(attribute: u64) -> static u8&:
