def ShaderIrEmitter_FPMul(program: mutable ShaderIrProgram&, emitter: mutable ShaderIrEmitter&, a: ShaderIrValue, b: ShaderIrValue) -> ShaderIrValue:
    args: mutable ShaderIrValue[6] = zeroed
    args[0] <- a
    args[1] <- b
    if a.type_bits == IR_TYPE_F32 and b.type_bits == IR_TYPE_F32:
