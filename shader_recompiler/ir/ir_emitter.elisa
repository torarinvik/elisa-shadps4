    args[0] <- handle
    args[1] <- coords
    args[2] <- derivatives_dx
    args[3] <- derivatives_dy
    args[4] <- offset
    args[5] <- lod_clamp
    return ShaderIrEmitter_Emit(program.ref[mutable ShaderIrProgram&], emitter.ref[mutable ShaderIrEmitter&], IR_OPCODE_IMAGEGRADIENT, 0u64, args, 6u32)

def ShaderIrEmitter_ImageRead(program: mutable ShaderIrProgram&, emitter: mutable ShaderIrEmitter&, handle: ShaderIrValue, coords: ShaderIrValue, lod: ShaderIrValue, multisampling: ShaderIrValue, info: ShaderIrValue) -> ShaderIrValue:
    args: mutable ShaderIrValue[6] = zeroed
    args[0] <- handle
    args[1] <- coords
    args[2] <- lod
    args[3] <- multisampling
    return ShaderIrEmitter_Emit(program.ref[mutable ShaderIrProgram&], emitter.ref[mutable ShaderIrEmitter&], IR_OPCODE_IMAGEREAD, 0u64, args, 4u32)

def ShaderIrEmitter_ImageWrite(program: mutable ShaderIrProgram&, emitter: mutable ShaderIrEmitter&, handle: ShaderIrValue, coords: ShaderIrValue, lod: ShaderIrValue, multisampling: ShaderIrValue, color: ShaderIrValue, info: ShaderIrValue) -> ShaderIrValue:
    args: mutable ShaderIrValue[6] = zeroed
    args[0] <- handle
    args[1] <- coords
    args[2] <- lod
    args[3] <- multisampling
    args[4] <- color
    return ShaderIrEmitter_Emit(program.ref[mutable ShaderIrProgram&], emitter.ref[mutable ShaderIrEmitter&], IR_OPCODE_IMAGEWRITE, 0u64, args, 5u32)

def ShaderIrEmitter_CubeFaceIndex(program: mutable ShaderIrProgram&, emitter: mutable ShaderIrEmitter&, cube_coords: ShaderIrValue) -> ShaderIrValue:
    args: mutable ShaderIrValue[6] = zeroed
    args[0] <- cube_coords
    return ShaderIrEmitter_Emit(program.ref[mutable ShaderIrProgram&], emitter.ref[mutable ShaderIrEmitter&], IR_OPCODE_CUBEFACEINDEX, 0u64, args, 1u32)

def ShaderIrEmitter_DebugPrint(program: mutable ShaderIrProgram&, emitter: mutable ShaderIrEmitter&, fmt: ShaderIrValue, format_args: ShaderIrValue) -> ShaderIrValue:
    _ = program
    _ = emitter
    _ = fmt
    _ = format_args
    return ShaderIrValue_Empty()

def ShaderIrEmitter_EmitVertex(program: mutable ShaderIrProgram&, emitter: mutable ShaderIrEmitter&) -> ShaderIrValue:
    args: mutable ShaderIrValue[6] = zeroed
    return ShaderIrEmitter_Emit(program.ref[mutable ShaderIrProgram&], emitter.ref[mutable ShaderIrEmitter&], IR_OPCODE_EMITVERTEX, 0u64, args, 0u32)

def ShaderIrEmitter_EmitPrimitive(program: mutable ShaderIrProgram&, emitter: mutable ShaderIrEmitter&) -> ShaderIrValue:
    args: mutable ShaderIrValue[6] = zeroed
    return ShaderIrEmitter_Emit(program.ref[mutable ShaderIrProgram&], emitter.ref[mutable ShaderIrEmitter&], IR_OPCODE_EMITPRIMITIVE, 0u64, args, 0u32)
