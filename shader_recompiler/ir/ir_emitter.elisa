    if fmt == IR_NUMFMT_UINT:
        return ShaderIrEmitter_Emit(program, emitter, IR_OPCODE_PACKUINT2X16, 0, args, 1)
    if fmt == IR_NUMFMT_SINT:
        return ShaderIrEmitter_Emit(program, emitter, IR_OPCODE_PACKSINT2X16, 0, args, 1)
    if fmt == IR_NUMFMT_FLOAT:
        return ShaderIrEmitter_Emit(program, emitter, IR_OPCODE_PACKHALF2X16, 0, args, 1)
    return ShaderIrValue_Empty()

