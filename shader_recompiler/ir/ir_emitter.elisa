def ShaderIrEmitter_FPOrdered(program: mutable ShaderIrProgram&, emitter: mutable ShaderIrEmitter&, lhs: ShaderIrValue, rhs: ShaderIrValue) -> ShaderIrValue:
    if lhs.type_bits != rhs.type_bits:
        return ShaderIrValue_Empty()
    lhs_nan: ShaderIrValue = ShaderIrEmitter_FPIsNan(program, emitter, lhs)
    rhs_nan: ShaderIrValue = ShaderIrEmitter_FPIsNan(program, emitter, rhs)
    lhs_not_nan: ShaderIrValue = ShaderIrEmitter_LogicalNot(program, emitter, lhs_nan)
    rhs_not_nan: ShaderIrValue = ShaderIrEmitter_LogicalNot(program, emitter, rhs_nan)
    return ShaderIrEmitter_LogicalAnd(program, emitter, lhs_not_nan, rhs_not_nan)

def ShaderIrEmitter_FPUnordered(program: mutable ShaderIrProgram&, emitter: mutable ShaderIrEmitter&, lhs: ShaderIrValue, rhs: ShaderIrValue) -> ShaderIrValue:
    if lhs.type_bits != rhs.type_bits:
        return ShaderIrValue_Empty()
    lhs_nan: ShaderIrValue = ShaderIrEmitter_FPIsNan(program, emitter, lhs)
    rhs_nan: ShaderIrValue = ShaderIrEmitter_FPIsNan(program, emitter, rhs)
    return ShaderIrEmitter_LogicalOr(program, emitter, lhs_nan, rhs_nan)

