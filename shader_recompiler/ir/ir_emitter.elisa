include "./microinstruction.elisa"

struct ShaderIrEmitter:
    block_index: mutable u32
    insertion_index: mutable u32

def ShaderIrEmitter_New(block_index: u32) -> ShaderIrEmitter:
    return ShaderIrEmitter(block_index, 0u32)

def ShaderIrEmitter_NewAt(block_index: u32, insertion_index: u32) -> ShaderIrEmitter:
    return ShaderIrEmitter(block_index, insertion_index)

def ShaderIrEmitter_Emit(program: mutable ShaderIrProgram&, emitter: mutable ShaderIrEmitter&, opcode: u32, flags_u64: u64, args: ShaderIrValue[6], arg_count: u32) -> ShaderIrValue:
    block_index: u32 = emitter.block_index
    assert block_index < program.block_count
    block: mutable ShaderIrBlock& = program.blocks[block_index.usize()].ref[mutable ShaderIrBlock&]
    insert_at: u32 = emitter.insertion_index
    if insert_at > block.inst_count:
        insert_at <- block.inst_count
    _ = ShaderIrProgram_PrependInst(program.ref[mutable ShaderIrProgram&], block_index, insert_at, opcode, args, arg_count, flags_u64)
    emitter.insertion_index <- insert_at + 1u32
    if ShaderIrOpcode_TypeOf(opcode) == IR_TYPE_VOID:
        return ShaderIrValue_Empty()
    return ShaderIrValue_FromInst(block_index, insert_at)

def ShaderIrEmitter_EmitNoFlags(program: mutable ShaderIrProgram&, emitter: mutable ShaderIrEmitter&, opcode: u32, args: ShaderIrValue[6], arg_count: u32) -> ShaderIrValue:
    return ShaderIrEmitter_Emit(program.ref[mutable ShaderIrProgram&], emitter.ref[mutable ShaderIrEmitter&], opcode, 0u64, args, arg_count)

def ShaderIrEmitter_Imm1(value: bool) -> ShaderIrValue:
    return ShaderIrValue_FromU1(value)

def ShaderIrEmitter_Imm8(value: u8) -> ShaderIrValue:
    return ShaderIrValue_FromU8(value)

def ShaderIrEmitter_Imm16(value: u16) -> ShaderIrValue:
    return ShaderIrValue_FromU16(value)

def ShaderIrEmitter_Imm32FromU32(value: u32) -> ShaderIrValue:
    return ShaderIrValue_FromU32(value)

def ShaderIrEmitter_Imm32FromI32(value: i32) -> ShaderIrValue:
    return ShaderIrValue_FromU32(value.u32())

def ShaderIrEmitter_Imm32FromF32(value: f32) -> ShaderIrValue:
    return ShaderIrValue_FromF32(value)

def ShaderIrEmitter_Imm64FromU64(value: u64) -> ShaderIrValue:
    return ShaderIrValue_FromU64(value)

def ShaderIrEmitter_Imm64FromI64(value: i64) -> ShaderIrValue:
    return ShaderIrValue_FromU64(value.u64())

def ShaderIrEmitter_Imm64FromF64(value: f64) -> ShaderIrValue:
    return ShaderIrValue_FromF64(value)

def ShaderIrEmitter_Imm32(value: ShaderIrValue) -> ShaderIrValue:
    if value.type_bits == IR_TYPE_U32:
        return value
    if value.type_bits == IR_TYPE_U1:
        if value.imm_u1:
            return ShaderIrValue_FromU32(1u32)
        return ShaderIrValue_FromU32(0u32)
    if value.type_bits == IR_TYPE_F32:
        return ShaderIrValue_FromF32(value.imm_f32)
    return ShaderIrValue_FromU32(0u32)

def ShaderIrEmitter_Imm64(value: ShaderIrValue) -> ShaderIrValue:
    if value.type_bits == IR_TYPE_U64:
        return value
    if value.type_bits == IR_TYPE_F64:
        return ShaderIrValue_FromF64(value.imm_f64)
    return ShaderIrValue_FromU64(0u64)

def ShaderIrEmitter_ConditionRef(program: mutable ShaderIrProgram&, emitter: mutable ShaderIrEmitter&, value: ShaderIrValue) -> ShaderIrValue:
    args: mutable ShaderIrValue[6] = zeroed
    args[0] <- value
    return ShaderIrEmitter_Emit(program.ref[mutable ShaderIrProgram&], emitter.ref[mutable ShaderIrEmitter&], IR_OPCODE_CONDITIONREF, 0u64, args, 1u32)

