def ShaderIrEmitter_ReadConst(program: mutable ShaderIrProgram&, emitter: mutable ShaderIrEmitter&, base: ShaderIrValue, offset: ShaderIrValue) -> ShaderIrValue:
    args: mutable ShaderIrValue[6] = zeroed
