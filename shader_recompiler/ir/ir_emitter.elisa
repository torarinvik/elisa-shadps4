def ShaderIrEmitter_FPEqual(program: mutable ShaderIrProgram&, emitter: mutable ShaderIrEmitter&, lhs: ShaderIrValue, rhs: ShaderIrValue, ordered: ShaderIrValue) -> ShaderIrValue:
    ordered_bool: bool = ShaderIrEmitter_ValueToBool(ordered)
    args: mutable ShaderIrValue[6] = zeroed
    args[0] <- lhs
    args[1] <- rhs
    if lhs.type_bits != rhs.type_bits:
        return ShaderIrValue_Empty()
    if lhs.type_bits == IR_TYPE_F32:
        if ordered_bool:
            return ShaderIrEmitter_Emit(program, emitter, IR_OPCODE_FPORDEQUAL32, 0, args, 2)
        return ShaderIrEmitter_Emit(program, emitter, IR_OPCODE_FPUNORDEQUAL32, 0, args, 2)
    if lhs.type_bits == IR_TYPE_F64:
        if ordered_bool:
            return ShaderIrEmitter_Emit(program, emitter, IR_OPCODE_FPORDEQUAL64, 0, args, 2)
        return ShaderIrEmitter_Emit(program, emitter, IR_OPCODE_FPUNORDEQUAL64, 0, args, 2)
    return ShaderIrValue_Empty()

