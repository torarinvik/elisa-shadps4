    args[0] <- id
    return ShaderIrEmitter_Emit(program, emitter, IR_OPCODE_GETGOTOVARIABLE, 0, args, 1)

def ShaderIrEmitter_Condition(program: mutable ShaderIrProgram&, emitter: mutable ShaderIrEmitter&, cond: ShaderIrValue) -> ShaderIrValue:
    cond_id: u32 = ShaderIrEmitter_ValueToU32(cond)
    if cond_id == IR_CONDITION_FALSE:
        return ShaderIrEmitter_Imm1(false)
    if cond_id == IR_CONDITION_TRUE:
        return ShaderIrEmitter_Imm1(true)
    if cond_id == IR_CONDITION_SCC0:
        return ShaderIrEmitter_LogicalNot(program, emitter, ShaderIrEmitter_GetScc(program, emitter))
    if cond_id == IR_CONDITION_SCC1:
        return ShaderIrEmitter_GetScc(program, emitter)
    if cond_id == IR_CONDITION_VCCZ:
        return ShaderIrEmitter_LogicalNot(program, emitter, ShaderIrEmitter_GetVcc(program, emitter))
    if cond_id == IR_CONDITION_VCCNZ:
        return ShaderIrEmitter_GetVcc(program, emitter)
    if cond_id == IR_CONDITION_EXECZ:
        return ShaderIrEmitter_LogicalNot(program, emitter, ShaderIrEmitter_GetExec(program, emitter))
    if cond_id == IR_CONDITION_EXECNZ:
        return ShaderIrEmitter_GetExec(program, emitter)
    return ShaderIrEmitter_Imm1(false)

def ShaderIrEmitter_SetGotoVariable(program: mutable ShaderIrProgram&, emitter: mutable ShaderIrEmitter&, id: ShaderIrValue, value: ShaderIrValue) -> ShaderIrValue:
