def ShaderIrEmitter_LoadBufferU32(program: mutable ShaderIrProgram&, emitter: mutable ShaderIrEmitter&, num_dwords: ShaderIrValue, handle: ShaderIrValue, address: ShaderIrValue, info: ShaderIrValue) -> ShaderIrValue:
    flags_u64: u64 = ShaderIrEmitter_ValueToU64(info)
    dwords: u32 = ShaderIrEmitter_ValueToU32(num_dwords)
    args: mutable ShaderIrValue[6] = zeroed
    args[0] <- handle
    args[1] <- address
    if (dwords == 1u32):
        return ShaderIrEmitter_Emit(program.ref[mutable ShaderIrProgram&], emitter.ref[mutable ShaderIrEmitter&], IR_OPCODE_LOADBUFFERU32, flags_u64, args, 2u32)
    if (dwords == 2u32):
