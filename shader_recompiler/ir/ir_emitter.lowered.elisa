def ShaderIrEmitter_SetScalarReg(program: mutable ShaderIrProgram&, emitter: mutable ShaderIrEmitter&, reg: ShaderIrValue, value: ShaderIrValue) -> ShaderIrValue:
    typed_value: mutable ShaderIrValue = value
    if (value.type_bits == IR_TYPE_F32):
        cast_args: mutable ShaderIrValue[6] = zeroed
        cast_args[0] <- value
        typed_value <- ShaderIrEmitter_Emit(program.ref[mutable ShaderIrProgram&], emitter.ref[mutable ShaderIrEmitter&], IR_OPCODE_BITCASTU32F32, 0u64, cast_args, 1u32)
    args: mutable ShaderIrValue[6] = zeroed
    args[0] <- reg
    args[1] <- typed_value
    return ShaderIrEmitter_Emit(program.ref[mutable ShaderIrProgram&], emitter.ref[mutable ShaderIrEmitter&], IR_OPCODE_SETSCALARREGISTER, 0u64, args, 2u32)

