        return ShaderIrValue_Empty()
    args: mutable ShaderIrValue[6] = zeroed
    args[0] <- condition
    args[1] <- true_value
    args[2] <- false_value
    if (true_value.type_bits == IR_TYPE_U1):
        return ShaderIrEmitter_Emit(program.ref[mutable ShaderIrProgram&], emitter.ref[mutable ShaderIrEmitter&], IR_OPCODE_SELECTU1, 0u64, args, 3u32)
    if (true_value.type_bits == IR_TYPE_U32):
        return ShaderIrEmitter_Emit(program.ref[mutable ShaderIrProgram&], emitter.ref[mutable ShaderIrEmitter&], IR_OPCODE_SELECTU32, 0u64, args, 3u32)
    if (true_value.type_bits == IR_TYPE_F32):
        return ShaderIrEmitter_Emit(program.ref[mutable ShaderIrProgram&], emitter.ref[mutable ShaderIrEmitter&], IR_OPCODE_SELECTF32, 0u64, args, 3u32)
    return ShaderIrValue_Empty()

