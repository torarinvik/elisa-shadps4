def ShaderIrEmitter_Select(program: mutable ShaderIrProgram&, emitter: mutable ShaderIrEmitter&, condition: ShaderIrValue, true_value: ShaderIrValue, false_value: ShaderIrValue) -> ShaderIrValue:
