def ShaderIrEmitter_LoadShared(program: mutable ShaderIrProgram&, emitter: mutable ShaderIrEmitter&, bit_size: ShaderIrValue, is_signed: ShaderIrValue, offset: ShaderIrValue, is_gds: ShaderIrValue) -> ShaderIrValue:
    flags_u64: u64 = ShaderIrEmitter_ValueToU64(is_gds)
    bits: u32 = ShaderIrEmitter_ValueToU32(bit_size)
    args: mutable ShaderIrValue[6] = zeroed
    args[0] <- offset
    if (bits == 16u32):
        return ShaderIrEmitter_Emit(program.ref[mutable ShaderIrProgram&], emitter.ref[mutable ShaderIrEmitter&], IR_OPCODE_LOADSHAREDU16, flags_u64, args, 1u32)
    if (bits == 32u32):
        return ShaderIrEmitter_Emit(program.ref[mutable ShaderIrProgram&], emitter.ref[mutable ShaderIrEmitter&], IR_OPCODE_LOADSHAREDU32, flags_u64, args, 1u32)
    if (bits == 64u32):
        return ShaderIrEmitter_Emit(program.ref[mutable ShaderIrProgram&], emitter.ref[mutable ShaderIrEmitter&], IR_OPCODE_LOADSHAREDU64, flags_u64, args, 1u32)
    return ShaderIrValue_Empty()

