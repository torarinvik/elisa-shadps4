def ShaderIrEmitter_CompositeConstruct(program: mutable ShaderIrProgram&, emitter: mutable ShaderIrEmitter&, e1: ShaderIrValue, e2: ShaderIrValue) -> ShaderIrValue:
    args: mutable ShaderIrValue[6] = zeroed
    args[0] <- e1
    args[1] <- e2
    if (e1.type_bits != e2.type_bits):
        return ShaderIrValue_Empty()
    if (e1.type_bits == IR_TYPE_U32):
        return ShaderIrEmitter_Emit(program.ref[mutable ShaderIrProgram&], emitter.ref[mutable ShaderIrEmitter&], IR_OPCODE_COMPOSITECONSTRUCTU32X2, 0u64, args, 2u32)
    if (e1.type_bits == IR_TYPE_U32X2):
        return ShaderIrEmitter_Emit(program.ref[mutable ShaderIrProgram&], emitter.ref[mutable ShaderIrEmitter&], IR_OPCODE_COMPOSITECONSTRUCTU32X2X2, 0u64, args, 2u32)
    if (e1.type_bits == IR_TYPE_F32):
