def ShaderIrEmitter_Condition(program: mutable ShaderIrProgram&, emitter: mutable ShaderIrEmitter&, cond: ShaderIrValue) -> ShaderIrValue:
    cond_id: u32 = ShaderIrEmitter_ValueToU32(cond)
    if (cond_id == IR_CONDITION_FALSE):
        return ShaderIrEmitter_Imm1(false)
    if (cond_id == IR_CONDITION_TRUE):
        return ShaderIrEmitter_Imm1(true)
    if (cond_id == IR_CONDITION_SCC0):
        return ShaderIrEmitter_LogicalNot(program.ref[mutable ShaderIrProgram&], emitter.ref[mutable ShaderIrEmitter&], ShaderIrEmitter_GetScc(program.ref[mutable ShaderIrProgram&], emitter.ref[mutable ShaderIrEmitter&]))
    if (cond_id == IR_CONDITION_SCC1):
        return ShaderIrEmitter_GetScc(program.ref[mutable ShaderIrProgram&], emitter.ref[mutable ShaderIrEmitter&])
    if (cond_id == IR_CONDITION_VCCZ):
        return ShaderIrEmitter_LogicalNot(program.ref[mutable ShaderIrProgram&], emitter.ref[mutable ShaderIrEmitter&], ShaderIrEmitter_GetVcc(program.ref[mutable ShaderIrProgram&], emitter.ref[mutable ShaderIrEmitter&]))
    if (cond_id == IR_CONDITION_VCCNZ):
        return ShaderIrEmitter_GetVcc(program.ref[mutable ShaderIrProgram&], emitter.ref[mutable ShaderIrEmitter&])
    if (cond_id == IR_CONDITION_EXECZ):
        return ShaderIrEmitter_LogicalNot(program.ref[mutable ShaderIrProgram&], emitter.ref[mutable ShaderIrEmitter&], ShaderIrEmitter_GetExec(program.ref[mutable ShaderIrProgram&], emitter.ref[mutable ShaderIrEmitter&]))
    if (cond_id == IR_CONDITION_EXECNZ):
        return ShaderIrEmitter_GetExec(program.ref[mutable ShaderIrProgram&], emitter.ref[mutable ShaderIrEmitter&])
    return ShaderIrEmitter_Imm1(false)

