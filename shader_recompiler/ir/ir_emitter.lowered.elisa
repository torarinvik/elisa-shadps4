        return ShaderIrEmitter_Emit(program.ref[mutable ShaderIrProgram&], emitter.ref[mutable ShaderIrEmitter&], IR_OPCODE_SHAREDATOMICUMIN32, flags_u64, args, 2u32)
    if (data.type_bits == IR_TYPE_U64):
        if signed_op:
            return ShaderIrEmitter_Emit(program.ref[mutable ShaderIrProgram&], emitter.ref[mutable ShaderIrEmitter&], IR_OPCODE_SHAREDATOMICSMIN64, flags_u64, args, 2u32)
        return ShaderIrEmitter_Emit(program.ref[mutable ShaderIrProgram&], emitter.ref[mutable ShaderIrEmitter&], IR_OPCODE_SHAREDATOMICUMIN64, flags_u64, args, 2u32)
    return ShaderIrValue_Empty()

