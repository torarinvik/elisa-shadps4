def ShaderIrEmitter_DebugPrint(program: mutable ShaderIrProgram&, emitter: mutable ShaderIrEmitter&, fmt: ShaderIrValue, format_args: ShaderIrValue) -> ShaderIrValue:
    arg_count: u64 = 0u64
    if (format_args.type_bits != IR_TYPE_VOID):
        arg_count <- 1u64
    args: mutable ShaderIrValue[6] = zeroed
    args[0] <- fmt
    args[1] <- format_args
    args[2] <- ShaderIrValue_Empty()
    args[3] <- ShaderIrValue_Empty()
    args[4] <- ShaderIrValue_Empty()
    return ShaderIrEmitter_Emit(program.ref[mutable ShaderIrProgram&], emitter.ref[mutable ShaderIrEmitter&], IR_OPCODE_DEBUGPRINT, arg_count, args, 5u32)

