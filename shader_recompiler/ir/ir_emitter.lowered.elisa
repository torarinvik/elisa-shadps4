def ShaderIrEmitter_FPOrdered(program: mutable ShaderIrProgram&, emitter: mutable ShaderIrEmitter&, lhs: ShaderIrValue, rhs: ShaderIrValue) -> ShaderIrValue:
    if (lhs.type_bits != rhs.type_bits):
        return ShaderIrValue_Empty()
    lhs_nan: ShaderIrValue = ShaderIrEmitter_FPIsNan(program.ref[mutable ShaderIrProgram&], emitter.ref[mutable ShaderIrEmitter&], lhs)
    rhs_nan: ShaderIrValue = ShaderIrEmitter_FPIsNan(program.ref[mutable ShaderIrProgram&], emitter.ref[mutable ShaderIrEmitter&], rhs)
    lhs_not_nan: ShaderIrValue = ShaderIrEmitter_LogicalNot(program.ref[mutable ShaderIrProgram&], emitter.ref[mutable ShaderIrEmitter&], lhs_nan)
    rhs_not_nan: ShaderIrValue = ShaderIrEmitter_LogicalNot(program.ref[mutable ShaderIrProgram&], emitter.ref[mutable ShaderIrEmitter&], rhs_nan)
    return ShaderIrEmitter_LogicalAnd(program.ref[mutable ShaderIrProgram&], emitter.ref[mutable ShaderIrEmitter&], lhs_not_nan, rhs_not_nan)

def ShaderIrEmitter_FPUnordered(program: mutable ShaderIrProgram&, emitter: mutable ShaderIrEmitter&, lhs: ShaderIrValue, rhs: ShaderIrValue) -> ShaderIrValue:
