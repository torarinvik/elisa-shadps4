struct PersistentSrtInfo:
    walker_func: mutable u64
    walker_func_size: mutable u32
    flattened_bufsize_dw: mutable u32


def PersistentSrtInfo_Default() -> PersistentSrtInfo:
    return PersistentSrtInfo(0, 0, 16)
