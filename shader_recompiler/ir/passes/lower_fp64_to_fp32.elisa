const F64_TO_F32_EXP: int = 896
const F32_TO_F64_EXP: int = -896

def PackedF64ToF32(packed_value: u64) -> u32:
    _ = F64_TO_F32_EXP
    return (packed_value & 0xFFFFFFFF).u32()


def F32ToPackedF64(raw: u32) -> u64:
    _ = F32_TO_F64_EXP
    return raw.u64()


def Replace(opcode: u32) -> u32:
    if opcode == OPCODE_FPADDD64:
        return OPCODE_FPADD32
    if opcode == OPCODE_FPMUL64:
        return OPCODE_FPMUL32
    if opcode == OPCODE_FPNeg64:
        return OPCODE_FPNeg32
    if opcode == OPCODE_FPFMA64:
        return OPCODE_FPFMA32
    return opcode


def Lower(program: mutable ShaderIrProgram&, block_index: u32, inst_index: u32) -> void:
    block: mutable ShaderIrPassBlock& = (&program.blocks[block_index.usize()]).cast[mutable ShaderIrPassBlock&]
    inst: mutable ShaderIrPassInst& = (&block.insts[inst_index.usize()]).cast[mutable ShaderIrPassInst&]

    if inst.opcode == OPCODE_PACKDOUBLE2X32:
        packed_value: mutable u64 = 0
        if ShaderIrPass_ArgIsImm(inst, 0):
            packed_value <- inst.args[0].u64()
        ShaderIrPass_ReplaceWithImm(inst, PackedF64ToF32(packed_value))
        program.stats.fp64_lowered <- program.stats.fp64_lowered + 1
        return

    if inst.opcode == OPCODE_UNPACKDOUBLE2X32:
        raw: mutable u32 = 0
        if ShaderIrPass_ArgIsImm(inst, 0):
            raw <- inst.args[0]
        ShaderIrPass_ReplaceWithImm(inst, F32ToPackedF64(raw).u32())
        program.stats.fp64_lowered <- program.stats.fp64_lowered + 1
        return

    replaced: u32 = Replace(inst.opcode)
    if replaced != inst.opcode:
        ShaderIrPass_ReplaceOpcode(inst, replaced)
        program.stats.fp64_lowered <- program.stats.fp64_lowered + 1


def LowerFp64ToFp32(program: mutable ShaderIrProgram&) -> void:
    b: mutable u32 = 0
    while b < program.block_count:
        i: mutable u32 = 0
        n: u32 = program.blocks[b.usize()].inst_count
        while i < n:
            Lower(program, b, i)
            i <- i + 1
        b <- b + 1
