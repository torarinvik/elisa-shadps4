include "./pass_model.elisa"

def DeadCodeEliminationPass(program: mutable ShaderIrProgram&) -> void:
    block_it: mutable u32 = 0u32
    while block_it < program.post_order_count:
        block_index: u32 = program.post_order[block_it.usize()]
        if block_index < program.block_count:
            block: mutable ShaderIrPassBlock& = program.blocks[block_index.usize()].ref[mutable ShaderIrPassBlock&]
            i: mutable u32 = block.inst_count
            while i > 0u32:
                i <- i - 1u32
                inst: ShaderIrPassInst = block.insts[i.usize()]
                if not inst.has_uses and not inst.has_side_effects:
                    _ = ShaderIrPassBlock_RemoveInstAt(block, i)
                    program.stats.dead_code_removed <- program.stats.dead_code_removed + 1u32
        block_it <- block_it + 1u32
