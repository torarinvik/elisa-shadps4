include "./pass_model.elisa"

const MAX_FLATTEN_READCONSTS: u32 = 512u32

global mutable g_srt_codegen_size: u32 = 0u32

def RegisterWalkerCode(ptr: void&?, size: u32) -> u64:
    _ = ptr
    g_srt_codegen_size <- g_srt_codegen_size + size
    return g_srt_codegen_size.u64()


def DumpSrtProgram(info: ShaderIrInfo&, code: void&?, codesize: u32) -> void:
    _ = info
    _ = code
    _ = codesize


def SrtWalkerSignalHandler(context: void&?, fault_address: void&?) -> bool:
    _ = context
    _ = fault_address
    return g_srt_codegen_size > 0u32

struct FlattenPassInfo:
    readconst_count: mutable u32
    readconst_ids: mutable u32[512]
    readconst_sources: mutable u32[512]
    readconst_offsets: mutable u32[512]
    dst_off_dw: mutable u32


def GetUsesAsPointer(pass_info: mutable FlattenPassInfo&, inst_id: u32) -> bool:
    i: mutable u32 = 0u32
    while i < pass_info.readconst_count:
        if pass_info.readconst_sources[i.usize()] == inst_id:
            return true
        i <- i + 1u32
    return false


def DeduplicateInstruction(pass_info: mutable FlattenPassInfo&, source_key: u32) -> u32:
    i: mutable u32 = 0u32
    while i < pass_info.readconst_count:
        if pass_info.readconst_sources[i.usize()] == source_key:
            return pass_info.readconst_ids[i.usize()]
        i <- i + 1u32
    return IR_PASS_INVALID_ID


def PushPtr(pass_info: mutable FlattenPassInfo&, off_dw: u32) -> void:
    pass_info.dst_off_dw <- pass_info.dst_off_dw + off_dw


def PopPtr(pass_info: mutable FlattenPassInfo&) -> void:
    if pass_info.dst_off_dw > 16u32:
        pass_info.dst_off_dw <- pass_info.dst_off_dw - 1u32


def GenerateSrtProgram(info: mutable ShaderIrInfo&, pass_info: mutable FlattenPassInfo&) -> void:
    if pass_info.readconst_count == 0u32:
        return
    _ = RegisterWalkerCode(null, pass_info.readconst_count * 4u32)
    info.srt_walker_generated <- true
    info.srt_flattened_bufsize_dw <- pass_info.dst_off_dw


def FlattenExtendedUserdataPass(program: mutable ShaderIrProgram&) -> void:
    pass_info: mutable FlattenPassInfo = zeroed
    pass_info.dst_off_dw <- 16u32

    if program.post_order_count == 0u32:
        return

    rev: mutable u32 = program.post_order_count
    while rev > 0u32:
        rev <- rev - 1u32
        block_index: u32 = program.post_order[rev.usize()]
        if block_index >= program.block_count:
            continue
        block: mutable ShaderIrPassBlock& = program.blocks[block_index.usize()].ref[mutable ShaderIrPassBlock&]
        i: mutable u32 = 0u32
        while i < block.inst_count:
            inst: mutable ShaderIrPassInst& = block.insts[i.usize()].ref[mutable ShaderIrPassInst&]
            if inst.opcode == OPCODE_READCONST and ShaderIrPass_ArgIsImm(inst, 1u32):
                source_key: u32 = inst.args[0] ^ (inst.args[1] << 16u32)
                existing_id: u32 = DeduplicateInstruction(pass_info.ref[mutable FlattenPassInfo&], source_key)
                if existing_id != IR_PASS_INVALID_ID:
                    eb: mutable u32 = 0u32
                    ei: mutable u32 = 0u32
                    if ShaderIrProgram_FindInst(program, existing_id, eb.ref[mutable u32&], ei.ref[mutable u32&]):
                        inst.flags_u32 <- program.blocks[eb.usize()].insts[ei.usize()].flags_u32
                    i <- i + 1u32
                    continue

                if pass_info.readconst_count < MAX_FLATTEN_READCONSTS:
                    pass_info.readconst_ids[pass_info.readconst_count.usize()] <- inst.id
                    pass_info.readconst_sources[pass_info.readconst_count.usize()] <- source_key
                    pass_info.readconst_offsets[pass_info.readconst_count.usize()] <- inst.args[1]
                    inst.flags_u32 <- pass_info.dst_off_dw
                    pass_info.dst_off_dw <- pass_info.dst_off_dw + 1u32
                    pass_info.readconst_count <- pass_info.readconst_count + 1u32
                    program.stats.flatten_readconsts <- program.stats.flatten_readconsts + 1u32
            i <- i + 1u32

    GenerateSrtProgram(program.info.ref[mutable ShaderIrInfo&], pass_info.ref[mutable FlattenPassInfo&])
