# Large opcode metadata tables (NameOf / ArgTypeOf). Split out of opcodes.elisa
# because they are not on the hot IR include path and their size (esp. the
# ~9k-line ArgTypeOf) made native object codegen pathologically slow / unstable.
# Include this file only where opcode names / arg-type metadata are needed.

include "./opcodes.elisa"

def ShaderIrOpcode_NameOf(op: u32) -> static u8&:
    if op == IR_OPCODE_PHI:
        return "Phi"
    if op == IR_OPCODE_IDENTITY:
        return "Identity"
    if op == IR_OPCODE_VOID:
        return "Void"
    if op == IR_OPCODE_CONDITIONREF:
        return "ConditionRef"
    if op == IR_OPCODE_REFERENCE:
        return "Reference"
