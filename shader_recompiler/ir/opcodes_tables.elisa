def ShaderIrOpcode_ArgTypeOf(op: u32, arg_index: u32) -> u32:
    if op == IR_OPCODE_PHI:
        return IR_TYPE_VOID
    if op == IR_OPCODE_IDENTITY:
        if arg_index == 0:
            return IR_TYPE_OPAQUE
        return IR_TYPE_VOID
    if op == IR_OPCODE_VOID:
        return IR_TYPE_VOID
    if op == IR_OPCODE_CONDITIONREF:
        if arg_index == 0:
            return IR_TYPE_U1
        return IR_TYPE_VOID
    if op == IR_OPCODE_REFERENCE:
        if arg_index == 0:
            return IR_TYPE_OPAQUE
        return IR_TYPE_VOID
    if op == IR_OPCODE_PHIMOVE:
        if arg_index == 0:
            return IR_TYPE_OPAQUE
        if arg_index == 1:
            return IR_TYPE_OPAQUE
        return IR_TYPE_VOID
    if op == IR_OPCODE_PROLOGUE:
        return IR_TYPE_VOID
    if op == IR_OPCODE_EPILOGUE:
        return IR_TYPE_VOID
    if op == IR_OPCODE_DISCARD:
        return IR_TYPE_VOID
    if op == IR_OPCODE_DISCARDCOND:
        if arg_index == 0:
            return IR_TYPE_U1
        return IR_TYPE_VOID
