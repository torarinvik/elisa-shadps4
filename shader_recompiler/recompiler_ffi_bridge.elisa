const ELISA_RECOMPILER_BRIDGE_OK: int = 0
const ELISA_RECOMPILER_BRIDGE_INVALID_ARGS: int = -1
const ELISA_RECOMPILER_BRIDGE_ALLOC_FAILED: int = -2
const ELISA_RECOMPILER_BRIDGE_EXCEPTION: int = -3

const ELISA_RECOMPILER_PROGRAM_MAGIC_LIVE: u64 = 0x454c49534150524fu64
const ELISA_RECOMPILER_PROGRAM_MAGIC_FREED: u64 = 0x454c495341505246u64
const ELISA_RECOMPILER_PROGRAM_STATUS_INVALID: int = -1
const ELISA_RECOMPILER_PROGRAM_STATUS_PLACEHOLDER: int = 1
const ELISA_RECOMPILER_PROGRAM_STATUS_FREED: int = 2
const ELISA_RECOMPILER_PROGRAM_STATUS_TRANSLATED: int = 3
const ELISA_RECOMPILER_PROGRAM_STATUS_FAILED_WITH_DIAGNOSTIC: int = 4

const ELISA_RECOMPILER_STAGE_FRAGMENT: int = 0
const ELISA_RECOMPILER_STAGE_VERTEX: int = 1
const ELISA_RECOMPILER_STAGE_GEOMETRY: int = 2
const ELISA_RECOMPILER_STAGE_EXPORT: int = 3
const ELISA_RECOMPILER_STAGE_HULL: int = 4
const ELISA_RECOMPILER_STAGE_LOCAL: int = 5
const ELISA_RECOMPILER_STAGE_COMPUTE: int = 6

const ELISA_RECOMPILER_LOGICAL_STAGE_FRAGMENT: int = 0
const ELISA_RECOMPILER_LOGICAL_STAGE_TESSELLATION_CONTROL: int = 1
const ELISA_RECOMPILER_LOGICAL_STAGE_TESSELLATION_EVALUATION: int = 2
const ELISA_RECOMPILER_LOGICAL_STAGE_VERTEX: int = 3
const ELISA_RECOMPILER_LOGICAL_STAGE_GEOMETRY: int = 4
const ELISA_RECOMPILER_LOGICAL_STAGE_COMPUTE: int = 5

# Diagnostic codes returned by elisa_shader_recompiler_program_diagnostic_code.
# UNSUPPORTED: the native translation path was unavailable for this build or host.
# EXCEPTION: C++ exception was caught during a real translation attempt.
const ELISA_RECOMPILER_DIAGNOSTIC_NONE: int = 0
const ELISA_RECOMPILER_DIAGNOSTIC_UNSUPPORTED: int = 1
const ELISA_RECOMPILER_DIAGNOSTIC_REAL_LINK_NOT_AVAILABLE: int = 1
const ELISA_RECOMPILER_DIAGNOSTIC_EXCEPTION: int = 2
const ELISA_SPIRV_MAGIC: u32 = 0x07230203u32

struct ShaderRecompilerTranslateMetadata:
    stage: mutable u32
    logical_stage: mutable u32

@c_abi(c)
extern elisa_shader_recompiler_translate_program(code_words: u32&?, code_word_count: usize, metadata: mutable ShaderRecompilerTranslateMetadata&?, out_program: mutable void&?&) -> int

@c_abi(c)
extern elisa_shader_recompiler_free_program(program: mutable void&?) -> void

@c_abi(c)
extern elisa_shader_recompiler_program_magic(program: mutable void&?) -> u64

@c_abi(c)
extern elisa_shader_recompiler_program_input_hash(program: mutable void&?) -> u64

@c_abi(c)
extern elisa_shader_recompiler_program_input_word_count(program: mutable void&?) -> u64

@c_abi(c)
extern elisa_shader_recompiler_program_stage_type(program: mutable void&?) -> u32

@c_abi(c)
extern elisa_shader_recompiler_program_has_stage_type(program: mutable void&?) -> u32

@c_abi(c)
extern elisa_shader_recompiler_program_output_byte_size(program: mutable void&?) -> u64

@c_abi(c)
extern elisa_shader_recompiler_program_output_hash(program: mutable void&?) -> u64

@c_abi(c)
extern elisa_shader_recompiler_program_output_word_count(program: mutable void&?) -> u64

@c_abi(c)
extern elisa_shader_recompiler_program_output_word_at(program: mutable void&?, word_index: u64) -> u32

@c_abi(c)
extern elisa_shader_recompiler_program_status(program: mutable void&?) -> int

@c_abi(c)
extern elisa_shader_recompiler_program_diagnostic_code(program: mutable void&?) -> int
