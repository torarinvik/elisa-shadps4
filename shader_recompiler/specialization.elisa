#
# Native Elisa port of the small specialization-key structs from
# shader_recompiler/specialization.h. These structs (plus their C++
# operator==, ported as free Equal functions) are used as keys for caching
# shader permutations.
#
# Ported: VsAttribSpecialization, BufferSpecialization, ImageSpecialization,
#         FMaskSpecialization, SamplerSpecialization.
#
# DEFERRED: the large StageSpecialization struct is NOT ported here. It depends
# on RuntimeInfo, fetch_shader, and deferred GetSharp accessors and will be
# ported separately once those dependencies land.
#
# Modeling notes:
# - C++ enum-typed fields (AmdGpu::NumberClass, CompMapping, NumberConversion,
#   ImageType) are modeled as plain u32; AmdGpu register files are NOT included.
# - C++ bitfields are modeled as ordinary u32 fields (no bit-packing). Parity
#   here is about the VALUES and the equality logic, not the bit layout.

struct VsAttribSpecialization:
    divisor: mutable u32
    num_class: mutable u32      # AmdGpu::NumberClass
    dst_select: mutable u32     # AmdGpu::CompMapping

# operator== is default in C++: all fields equal.
def VsAttribSpecialization_Equal(a: VsAttribSpecialization&, b: VsAttribSpecialization&) -> bool:
    return a.divisor == b.divisor and a.num_class == b.num_class and a.dst_select == b.dst_select

struct BufferSpecialization:
    stride: mutable u32         # bitfield :14
    is_storage: mutable u32     # bitfield :1
    is_formatted: mutable u32   # bitfield :1
    swizzle_enable: mutable u32 # bitfield :1
    data_format: mutable u32    # bitfield :6
    num_format: mutable u32     # bitfield :4
    index_stride: mutable u32   # bitfield :2
    element_size: mutable u32   # bitfield :2
    dst_select: mutable u32     # AmdGpu::CompMapping
    num_conversion: mutable u32 # AmdGpu::NumberConversion

# Custom operator==: the formatted-only fields are compared only when
# is_formatted is set, and the swizzle-only fields only when swizzle_enable is
# set (C++ uses !is_formatted / !swizzle_enable as short-circuit guards).
def BufferSpecialization_Equal(a: BufferSpecialization&, b: BufferSpecialization&) -> bool:
    return a.stride == b.stride and a.is_storage == b.is_storage and a.is_formatted == b.is_formatted and a.swizzle_enable == b.swizzle_enable and ( (a.is_formatted == 0u32) or (a.data_format == b.data_format and a.num_format == b.num_format and a.dst_select == b.dst_select and a.num_conversion == b.num_conversion) ) and ( (a.swizzle_enable == 0u32) or (a.index_stride == b.index_stride and a.element_size == b.element_size) )

struct ImageSpecialization:
    type: mutable u32           # AmdGpu::ImageType; C++ default is AmdGpu::ImageType::Color2D
    is_integer: mutable bool
    is_storage: mutable bool
    is_cube: mutable bool
    is_srgb: mutable bool
    dst_select: mutable u32     # AmdGpu::CompMapping
    num_conversion: mutable u32 # AmdGpu::NumberConversion
    num_bindings: mutable u32

# operator== is default in C++: all fields equal.
def ImageSpecialization_Equal(a: ImageSpecialization&, b: ImageSpecialization&) -> bool:
    return a.type == b.type and a.is_integer == b.is_integer and a.is_storage == b.is_storage and a.is_cube == b.is_cube and a.is_srgb == b.is_srgb and a.dst_select == b.dst_select and a.num_conversion == b.num_conversion and a.num_bindings == b.num_bindings

struct FMaskSpecialization:
    width: mutable u32
    height: mutable u32

# operator== is default in C++: all fields equal.
def FMaskSpecialization_Equal(a: FMaskSpecialization&, b: FMaskSpecialization&) -> bool:
    return a.width == b.width and a.height == b.height

struct SamplerSpecialization:
    force_unnormalized: mutable bool    # C++ u8 :1 (0/1)
    force_degamma: mutable bool         # C++ u8 :1 (0/1)

# operator== is default in C++: all fields equal.
def SamplerSpecialization_Equal(a: SamplerSpecialization&, b: SamplerSpecialization&) -> bool:
    return a.force_unnormalized == b.force_unnormalized and a.force_degamma == b.force_degamma
