include "./recompiler_ffi_bridge.elisa"

@link_name(ElisaGuestExec_EmitCusaArtifactKV)
extern c_GuestExec_EmitCusaArtifactKV(key: static u8&?, value: u64) -> void

global mutable g_shader_artifact_translate_attempted_emitted: bool = false
global mutable g_shader_artifact_path_bridge_emitted: bool = false
global mutable g_shader_artifact_result_ok_emitted: bool = false
global mutable g_shader_artifact_output_nonzero_emitted: bool = false
global mutable g_shader_artifact_status_emitted: bool = false

def ShaderRecompiler_ResetArtifactState() -> void:
    g_shader_artifact_translate_attempted_emitted <- false
    g_shader_artifact_path_bridge_emitted <- false
    g_shader_artifact_result_ok_emitted <- false
    g_shader_artifact_output_nonzero_emitted <- false
    g_shader_artifact_status_emitted <- false

def ShaderRecompiler_TranslateProgramViaFfi(code_words: u32&?, code_word_count: usize, metadata: mutable ShaderRecompilerTranslateMetadata&?, out_program: mutable void&?&) -> int:
    rc: int = elisa_shader_recompiler_translate_program(code_words, code_word_count, metadata, out_program)
    if not g_shader_artifact_translate_attempted_emitted:
        c_GuestExec_EmitCusaArtifactKV("shader_translate_attempted", 1u64)
        g_shader_artifact_translate_attempted_emitted <- true
    if rc == ELISA_RECOMPILER_BRIDGE_OK and not g_shader_artifact_path_bridge_emitted:
        c_GuestExec_EmitCusaArtifactKV("shader_translate_path_bridge", 1u64)
        g_shader_artifact_path_bridge_emitted <- true
    if rc == ELISA_RECOMPILER_BRIDGE_OK and not g_shader_artifact_result_ok_emitted:
        c_GuestExec_EmitCusaArtifactKV("shader_translate_result_ok", 1u64)
        g_shader_artifact_result_ok_emitted <- true
    if rc == ELISA_RECOMPILER_BRIDGE_OK and not g_shader_artifact_status_emitted:
        status: int = elisa_shader_recompiler_program_status(out_program[0])
        c_GuestExec_EmitCusaArtifactKV("shader_translate_status", status.u64())
        g_shader_artifact_status_emitted <- true
    if rc == ELISA_RECOMPILER_BRIDGE_OK and not g_shader_artifact_output_nonzero_emitted:
        byte_size: u64 = elisa_shader_recompiler_program_output_byte_size(out_program[0])
        if byte_size > 0u64:
            c_GuestExec_EmitCusaArtifactKV("shader_translate_output_nonzero", 1u64)
            g_shader_artifact_output_nonzero_emitted <- true
    return rc

def ShaderRecompiler_FreeProgramViaFfi(program: mutable void&?) -> void:
    elisa_shader_recompiler_free_program(program)
