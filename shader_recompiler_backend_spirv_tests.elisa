include "./shader_recompiler/backend/spirv/spirv_backend.elisa"
include "../compiler/runtime/elisacore_std/elisacore_runtime.elisa"

@test
def spirv_backend_primitive_modes_match_cpp_switches() -> void:
    can Abort.Panic:
        assert SpirvGetInputPrimitiveExecutionMode(AMDGPU_PRIMITIVE_POINT_LIST) == SPIRV_EXECUTION_MODE_INPUT_POINTS
        assert SpirvGetInputPrimitiveExecutionMode(AMDGPU_PRIMITIVE_LINE_LIST) == SPIRV_EXECUTION_MODE_INPUT_LINES
        assert SpirvGetInputPrimitiveExecutionMode(AMDGPU_PRIMITIVE_LINE_STRIP) == SPIRV_EXECUTION_MODE_INPUT_LINES
        assert SpirvGetInputPrimitiveExecutionMode(AMDGPU_PRIMITIVE_TRIANGLE_LIST) == SPIRV_EXECUTION_MODE_TRIANGLES
        assert SpirvGetInputPrimitiveExecutionMode(AMDGPU_PRIMITIVE_TRIANGLE_STRIP) == SPIRV_EXECUTION_MODE_TRIANGLES
        assert SpirvGetInputPrimitiveExecutionMode(AMDGPU_PRIMITIVE_RECT_LIST) == SPIRV_EXECUTION_MODE_TRIANGLES
        assert SpirvGetInputPrimitiveExecutionMode(AMDGPU_PRIMITIVE_ADJ_TRIANGLE_LIST) == SPIRV_EXECUTION_MODE_INPUT_TRIANGLES_ADJACENCY
        assert SpirvGetInputPrimitiveExecutionMode(AMDGPU_PRIMITIVE_ADJ_LINE_LIST) == SPIRV_EXECUTION_MODE_INPUT_LINES_ADJACENCY
        assert SpirvGetInputPrimitiveExecutionMode(AMDGPU_PRIMITIVE_TRIANGLE_FAN) == 0u32

@test
def spirv_backend_output_modes_match_cpp_switches() -> void:
    can Abort.Panic:
        assert SpirvGetOutputPrimitiveExecutionMode(AMDGPU_GS_OUTPUT_POINT_LIST) == SPIRV_EXECUTION_MODE_OUTPUT_VERTICES
        assert SpirvGetOutputPrimitiveExecutionMode(AMDGPU_GS_OUTPUT_LINE_STRIP) == SPIRV_EXECUTION_MODE_OUTPUT_LINE_STRIP
        assert SpirvGetOutputPrimitiveExecutionMode(AMDGPU_GS_OUTPUT_TRIANGLE_STRIP) == SPIRV_EXECUTION_MODE_OUTPUT_TRIANGLE_STRIP
        assert SpirvGetOutputPrimitiveExecutionMode(99u32) == 0u32

@test
def spirv_backend_vector_ids_are_one_based_like_cpp() -> void:
    can Abort.Panic:
        ids: mutable SpirvVectorIds = SpirvVectorIds_Default()
        assert SpirvVectorIds_Set(ids, 1u32, 11u32) == true
        assert SpirvVectorIds_Set(ids, 4u32, 44u32) == true
        assert SpirvVectorIds_Set(ids, 0u32, 99u32) == false
        assert SpirvVectorIds_Get(ids, 1u32) == 11u32
        assert SpirvVectorIds_Get(ids, 4u32) == 44u32
        assert SpirvVectorIds_Get(ids, 5u32) == SPIRV_INVALID_ID

@test
def spirv_backend_binding_and_header_are_deterministic() -> void:
    can Abort.Panic, Memory.Allocate:
        binding: mutable ShaderBackendBindings = ShaderBackendBindings_Default()
        result: SpirvEmitResult = SpirvEmitMinimalModule(binding)
        assert result.ok == true
        assert result.words.count == 5
        assert result.words[0] == SPIRV_MAGIC
        assert result.words[1] == SPIRV_VERSION_1_6
        assert result.words[3] == result.bound
        assert binding.unified == 1u32
        assert binding.buffer == 1u32
        assert binding.user_data == 0u32

@test
def spirv_backend_core_type_ids_follow_context_allocation_order() -> void:
    can Abort.Panic:
        ctx: mutable SpirvEmitContext = SpirvEmitContext_Default()
        SpirvEmitContext_DefineCoreTypes(ctx)
        assert ctx.void_id == 1u32
        assert ctx.u1_id == 2u32
        assert ctx.u32_id == 3u32
        assert SpirvTypeId(ctx, SHADER_IR_TYPE_U1) == 2u32
        assert SpirvTypeId(ctx, SHADER_IR_TYPE_U32) == 3u32
        assert SpirvTypeId(ctx, SHADER_IR_TYPE_VOID) == SPIRV_INVALID_ID

@test
def spirv_backend_word_packs_count_and_opcode() -> void:
    can Abort.Panic:
        assert SpirvWord(19u16, 2u16) == 0x00020013u32
