include "../compiler/runtime/elisacore_std/elisacore_runtime.elisa"
include "./core/libraries/system/commondialog.elisa"
include "./core/libraries/system/msgdialog.elisa"
include "./core/libraries/system/userservice.elisa"
include "./core/libraries/system/systemservice.elisa"

@test
def system_stub_contracts() -> void:
    can Abort.Panic:
        assert sceCommonDialogInitialize() == ORBIS_OK.u32()
        assert sceCommonDialogIsUsed() == false
        assert sceMsgDialogInitialize() == ORBIS_OK.u32()
        assert sceMsgDialogGetStatus() == ORBIS_COMMON_DIALOG_STATUS_FINISHED

        u: mutable int = -123
        assert sceUserServiceGetInitialUser(u.ref[mutable int&]) == ORBIS_OK

        assert sceUserServiceGetLoginUserIdList(null) == ORBIS_OK

        assert sceSystemServiceReceiveEvent(null) == ORBIS_OK
