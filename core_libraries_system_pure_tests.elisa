include "../compiler/runtime/elisacore_std/elisacore_runtime.elisa"
include "./core/libraries/system/commondialog.elisa"
include "./core/libraries/system/msgdialog.elisa"
include "./core/libraries/system/userservice.elisa"
include "./core/libraries/system/systemservice.elisa"

@test
def system_stub_contracts() -> void:
    can Abort.Panic:
        assert sceCommonDialogInitialize() == ORBIS_OK.u32()
        assert sceCommonDialogIsUsed() == false
        assert sceCommonDialogInitialize() == ORBIS_COMMON_DIALOG_ERROR_ALREADY_SYSTEM_INITIALIZED.u32()
        assert sceMsgDialogInitialize() == ORBIS_OK.u32()
        assert sceMsgDialogGetStatus() == ORBIS_COMMON_DIALOG_STATUS_INITIALIZED
        assert sceMsgDialogInitialize() == ORBIS_COMMON_DIALOG_ERROR_ALREADY_INITIALIZED.u32()

        assert sceMsgDialogProgressBarSetValue(ORBIS_MSG_DIALOG_PROGRESSBAR_TARGET_DEFAULT.int(), 10.u32()) == ORBIS_COMMON_DIALOG_ERROR_NOT_RUNNING.u32()
        progress_param: mutable ProgressBarParam = zeroed
        msg_param: mutable OrbisParam = zeroed
        msg_param.mode <- MSG_DIALOG_MODE_PROGRESS_BAR
        msg_param.prog_bar_param <- progress_param.ref[mutable ProgressBarParam&]
        assert sceMsgDialogOpen(msg_param.ref[mutable void&]) == ORBIS_OK.u32()
        assert sceMsgDialogGetStatus() == ORBIS_COMMON_DIALOG_STATUS_RUNNING
        assert sceMsgDialogProgressBarSetValue(1, 10.u32()) == ORBIS_COMMON_DIALOG_ERROR_PARAM_INVALID.u32()
        assert sceMsgDialogProgressBarSetValue(ORBIS_MSG_DIALOG_PROGRESSBAR_TARGET_DEFAULT.int(), 10.u32()) == ORBIS_OK.u32()
        assert MsgDialog_GetProgressValueForTests() == 10.u32()
        assert sceMsgDialogProgressBarInc(ORBIS_MSG_DIALOG_PROGRESSBAR_TARGET_DEFAULT.int(), 7.u32()) == ORBIS_OK.u32()
        assert MsgDialog_GetProgressValueForTests() == 17.u32()
        assert sceMsgDialogClose() == ORBIS_OK.u32()
        assert sceMsgDialogGetStatus() == ORBIS_COMMON_DIALOG_STATUS_FINISHED
        msg_result: mutable DialogResult = zeroed
        assert sceMsgDialogGetResult(msg_result.ref[mutable u32&]) == ORBIS_OK.u32()
        assert msg_result.result == ORBIS_COMMON_DIALOG_RESULT_OK
        assert sceMsgDialogTerminate() == ORBIS_OK.u32()
        assert sceMsgDialogGetStatus() == ORBIS_COMMON_DIALOG_STATUS_NONE

        u: mutable int = -123
        assert sceUserServiceGetInitialUser(u.ref[mutable int&]) == ORBIS_OK
        assert u == 1

        assert sceUserServiceGetLoginUserIdList(null) == ORBIS_USER_SERVICE_ERROR_INVALID_ARGUMENT

        assert sceSystemServiceReceiveEvent(null) == ORBIS_SYSTEM_SERVICE_ERROR_PARAMETER
        assert sceSystemServiceLoadExec(null, null) == ORBIS_SYSTEM_SERVICE_ERROR_PARAMETER

        ue: mutable OrbisUserServiceEvent = zeroed
        assert sceUserServiceGetEvent(null) == ORBIS_USER_SERVICE_ERROR_NO_EVENT
        assert sceUserServiceGetEvent(ue.ref[mutable void&]) == ORBIS_USER_SERVICE_ERROR_NO_EVENT
        UserService_PushEventForTests(3, 1)
        assert sceUserServiceGetEvent(ue.ref[mutable void&]) == ORBIS_OK
        assert ue.event == 3
        assert ue.user_id == 1
        assert sceUserServiceGetEvent(ue.ref[mutable void&]) == ORBIS_USER_SERVICE_ERROR_NO_EVENT

        c: mutable u32 = 99
        assert sceUserServiceGetUserColor(ORBIS_USER_SERVICE_USER_ID_INVALID, c.ref[mutable u32&]) == ORBIS_USER_SERVICE_ERROR_INVALID_ARGUMENT
        assert sceUserServiceGetUserColor(1, c.ref[mutable u32&]) == ORBIS_OK

        name_buf: mutable u8[8] = zeroed
        assert sceUserServiceGetUserName(1, name_buf[0].ref[mutable u8&], 5) == ORBIS_USER_SERVICE_ERROR_BUFFER_TOO_SHORT
        assert sceUserServiceGetUserName(1, name_buf[0].ref[mutable u8&], 8) == ORBIS_OK
        assert name_buf[0] == 'U'.u8()
        assert name_buf[1] == 's'.u8()
        assert name_buf[2] == 'e'.u8()
        assert name_buf[3] == 'r'.u8()
        assert name_buf[4] == '1'.u8()
        assert name_buf[5] == 0.u8()
        assert sceUserServiceGetUserName(ORBIS_USER_SERVICE_USER_ID_SYSTEM, name_buf[0].ref[mutable u8&], 8) == ORBIS_OK
        assert name_buf[4] == '1'.u8()

        s: mutable OrbisSystemServiceStatus = zeroed
        assert sceSystemServiceGetStatus(s.ref[mutable u32&]) == ORBIS_OK
        assert s.event_num == 0
        assert s.is_cpu_mode7_cpu_normal == true

        se: mutable OrbisSystemServiceEvent = zeroed
        assert sceSystemServiceReceiveEvent(se.ref[mutable void&]) == ORBIS_SYSTEM_SERVICE_ERROR_NO_EVENT
        SystemService_PushEventForTests(9)
        SystemService_PushEventForTests(11)
        assert sceSystemServiceGetStatus(s.ref[mutable u32&]) == ORBIS_OK
        assert s.event_num == 2
        assert sceSystemServiceReceiveEvent(se.ref[mutable void&]) == ORBIS_OK
        assert se.event_type == 9
        assert sceSystemServiceReceiveEvent(se.ref[mutable void&]) == ORBIS_OK
        assert se.event_type == 11
        assert sceSystemServiceReceiveEvent(se.ref[mutable void&]) == ORBIS_SYSTEM_SERVICE_ERROR_NO_EVENT

        param_v: mutable int = -1
        assert sceSystemServiceParamGetInt(9999, param_v.ref[mutable int&]) == ORBIS_OK
        assert param_v == 0

        assert SystemService_IsSplashVisibleForTests() == true
        assert sceSystemServiceHideSplashScreen() == ORBIS_OK
        assert SystemService_IsSplashVisibleForTests() == false
