include "../compiler/runtime/elisacore_std/elisacore_runtime.elisa"
include "./core/libraries/voice/voice.elisa"

@test
def voice_stub_surface_and_output_defaults() -> void:
    can Abort.Panic:
        bitrate: mutable u32 = 0u32
        info: mutable OrbisVoicePortInfo = zeroed

        assert sceVoiceConnectIPortToOPort() == ORBIS_OK
        assert sceVoiceCreatePort() == ORBIS_OK
        assert sceVoiceDeletePort() == ORBIS_OK
        assert sceVoiceDisconnectIPortFromOPort() == ORBIS_OK
        assert sceVoiceEnd() == ORBIS_OK

        assert sceVoiceGetBitRate(1u32, bitrate.ref[mutable u32&]) == ORBIS_OK

        assert sceVoiceGetMuteFlag() == ORBIS_OK
        assert sceVoiceGetPortAttr() == ORBIS_OK

        assert sceVoiceGetPortInfo(3u32, info.ref[mutable OrbisVoicePortInfo&]) == ORBIS_OK
        assert info.port_type == 0
        assert info.state == 0
        assert info.byte_count == 0u32
        assert info.frame_size == 1u32
        assert info.edge_count == 0u16
        assert info.reserved == 0u16

        assert sceVoiceGetResourceInfo() == ORBIS_OK
        assert sceVoiceGetVolume() == ORBIS_OK
        assert sceVoiceInit() == ORBIS_OK
        assert sceVoiceInitHQ() == ORBIS_OK
        assert sceVoicePausePort() == ORBIS_OK
        assert sceVoicePausePortAll() == ORBIS_OK
        assert sceVoiceReadFromOPort() == ORBIS_OK
        assert sceVoiceResetPort() == ORBIS_OK
        assert sceVoiceResumePort() == ORBIS_OK
        assert sceVoiceResumePortAll() == ORBIS_OK
        assert sceVoiceSetBitRate() == ORBIS_OK
        assert sceVoiceSetMuteFlag() == ORBIS_OK
        assert sceVoiceSetMuteFlagAll() == ORBIS_OK
        assert sceVoiceSetThreadsParams() == ORBIS_OK
        assert sceVoiceSetVolume() == ORBIS_OK
        assert sceVoiceStart() == ORBIS_OK
        assert sceVoiceStop() == ORBIS_OK
        assert sceVoiceUpdatePort() == ORBIS_OK
        assert sceVoiceVADAdjustment() == ORBIS_OK
        assert sceVoiceVADSetVersion() == ORBIS_OK
        assert sceVoiceWriteToIPort() == ORBIS_OK
