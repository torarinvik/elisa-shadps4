include "../compiler/runtime/elisacore_std/elisacore_runtime.elisa"
include "./core/libraries/ngs2/ngs2.elisa"

@test
def ngs2_system_rack_basic_contracts() -> void:
    can Abort.Panic:
        system: mutable u64 = 0
        rack: mutable u64 = 0
        voice: mutable u64 = 0
        flags: mutable u32 = 0u32
        user_data: mutable usize = 0
        system_info: OrbisNgs2SystemInfo = zeroed
        rack_info: OrbisNgs2RackInfo = zeroed
        wave_info: OrbisNgs2WaveformInfo = zeroed
        one_byte: mutable u8 = 1u8

        assert sceNgs2SystemCreate(null, null, system.ref[mutable u64&]) == ORBIS_NGS2_ERROR_INVALID_BUFFER_INFO

        buffer_info: mutable OrbisNgs2ContextBufferInfo = zeroed
        buffer_info.user_data <- 77
        assert sceNgs2SystemCreate(null, buffer_info.ref[OrbisNgs2ContextBufferInfo&], system.ref[mutable u64&]) == ORBIS_OK

        assert sceNgs2SystemEnumHandles(system.ref[mutable u64&], 1u32) == 1
        assert sceNgs2SystemGetUserData(system, user_data.ref[mutable usize&]) == ORBIS_OK
        assert user_data == 77
        assert sceNgs2SystemSetUserData(system, 123) == ORBIS_OK
        assert sceNgs2SystemGetUserData(system, user_data.ref[mutable usize&]) == ORBIS_OK
        assert user_data == 123

        assert sceNgs2RackCreate(0, 0, null, null, rack.ref[mutable u64&]) == ORBIS_NGS2_ERROR_INVALID_SYSTEM_HANDLE
        assert sceNgs2RackCreate(system, 0, null, null, rack.ref[mutable u64&]) == ORBIS_OK
        assert sceNgs2RackSetUserData(rack, 456) == ORBIS_OK
        assert sceNgs2RackGetUserData(rack, user_data.ref[mutable usize&]) == ORBIS_OK
        assert user_data == 456

        assert sceNgs2RackGetVoiceHandle(rack, 0u32, voice.ref[mutable u64&]) == ORBIS_OK
        assert sceNgs2SystemEnumRackHandles(system, rack.ref[mutable u64&], 1u32) == 1
        assert sceNgs2VoiceGetStateFlags(voice, flags.ref[mutable u32&]) == ORBIS_OK
        assert sceNgs2VoiceGetStateFlags(0, flags.ref[mutable u32&]) == ORBIS_NGS2_ERROR_INVALID_VOICE_HANDLE

        assert sceNgs2SystemRender(system, null, 0u32) == ORBIS_OK
        assert sceNgs2SystemGetInfo(system, system_info.ref[mutable OrbisNgs2SystemInfo&], 1) == ORBIS_OK
        assert system_info.system_handle == system
        assert system_info.rack_count == 1u32
        assert system_info.render_count == 1
        assert sceNgs2RackGetInfo(rack, rack_info.ref[mutable OrbisNgs2RackInfo&], 1) == ORBIS_OK
        assert rack_info.rack_handle == rack
        assert rack_info.owner_system_handle == system
        assert rack_info.render_count == 1u64

        assert sceNgs2ParseWaveformData(one_byte.ref[mutable u8&], 1, wave_info.ref[mutable OrbisNgs2WaveformInfo&]) == ORBIS_OK
        assert wave_info.format.num_channels == 1u32
        assert wave_info.format.sample_rate == 48000u32
        assert wave_info.num_blocks == 1u32

        assert sceNgs2RackDestroy(rack, null) == ORBIS_OK
        assert sceNgs2SystemDestroy(system, null) == ORBIS_OK
