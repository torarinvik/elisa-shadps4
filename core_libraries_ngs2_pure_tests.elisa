include "../compiler/runtime/elisacore_std/elisacore_runtime.elisa"
include "./core/libraries/ngs2/ngs2.elisa"

@test
def ngs2_system_rack_basic_contracts() -> void:
    can Abort.Panic:
        system: mutable u64 = 0
        rack: mutable u64 = 0
        voice: mutable u64 = 0
        voice_again: mutable u64 = 0
        voice_1: mutable u64 = 0
        owner_rack: mutable u64 = 0
        owner_index: mutable u32 = 0u32
        flags: mutable u32 = 0u32
        user_data: mutable usize = 0
        system_info: OrbisNgs2SystemInfo = zeroed
        rack_info: OrbisNgs2RackInfo = zeroed
        wave_info: OrbisNgs2WaveformInfo = zeroed
        one_byte: mutable u8 = 1u8
        query_size: mutable usize = 0
        rack_query_size_default: mutable usize = 0
        rack_query_size_custom: mutable usize = 0
        out_destroy_system_info: mutable OrbisNgs2ContextBufferInfo = zeroed
        out_destroy_rack_info: mutable OrbisNgs2ContextBufferInfo = zeroed

        assert sceNgs2SystemCreate(null, null, system.ref[mutable u64&]) == ORBIS_NGS2_ERROR_INVALID_BUFFER_INFO

        buffer_info: mutable OrbisNgs2ContextBufferInfo = zeroed
        buffer_info.user_data <- 77
        assert sceNgs2SystemCreate(null, buffer_info.ref[OrbisNgs2ContextBufferInfo&], system.ref[mutable u64&]) == ORBIS_NGS2_ERROR_INVALID_BUFFER_ADDRESS
        assert sceNgs2SystemQueryBufferSize(null, query_size.ref[mutable usize&]) == ORBIS_OK
        assert query_size == 8
        buffer_info.host_buffer <- one_byte.ref[mutable u8&]
        buffer_info.host_buffer_size <- 7
        assert sceNgs2SystemCreate(null, buffer_info.ref[OrbisNgs2ContextBufferInfo&], system.ref[mutable u64&]) == ORBIS_NGS2_ERROR_INVALID_BUFFER_SIZE
        buffer_info.host_buffer_size <- query_size

        bad_option: mutable OrbisNgs2SystemOption = zeroed
        bad_option.size <- 64
        bad_option.max_grain_samples <- 63u32
        bad_option.num_grain_samples <- 256u32
        bad_option.sample_rate <- 48000u32
        assert sceNgs2SystemCreate(bad_option.ref[OrbisNgs2SystemOption&], buffer_info.ref[OrbisNgs2ContextBufferInfo&], system.ref[mutable u64&]) == ORBIS_NGS2_ERROR_INVALID_MAX_GRAIN_SAMPLES
        bad_option.max_grain_samples <- 512u32
        bad_option.sample_rate <- 12345u32
        assert sceNgs2SystemCreate(bad_option.ref[OrbisNgs2SystemOption&], buffer_info.ref[OrbisNgs2ContextBufferInfo&], system.ref[mutable u64&]) == ORBIS_NGS2_ERROR_INVALID_SAMPLE_RATE

        assert sceNgs2SystemCreate(null, buffer_info.ref[OrbisNgs2ContextBufferInfo&], system.ref[mutable u64&]) == ORBIS_OK

        assert sceNgs2SystemEnumHandles(system.ref[mutable u64&], 1u32) == 1
        assert sceNgs2SystemGetUserData(system, user_data.ref[mutable usize&]) == ORBIS_OK
        assert user_data == 77
        assert sceNgs2SystemSetUserData(system, 123) == ORBIS_OK
        assert sceNgs2SystemGetUserData(system, user_data.ref[mutable usize&]) == ORBIS_OK
        assert user_data == 123

        assert sceNgs2RackCreate(0, 0, null, null, rack.ref[mutable u64&]) == ORBIS_NGS2_ERROR_INVALID_SYSTEM_HANDLE
        assert sceNgs2RackQueryBufferSize(0u32, null, rack_query_size_default.ref[mutable usize&]) == ORBIS_OK
        assert rack_query_size_default > 0
        rack_option: mutable OrbisNgs2RackOption = zeroed
        rack_option.max_voices <- 8u32
        assert sceNgs2RackQueryBufferSize(0u32, rack_option.ref[OrbisNgs2RackOption&], rack_query_size_custom.ref[mutable usize&]) == ORBIS_OK
        assert rack_query_size_custom < rack_query_size_default
        assert sceNgs2RackCreate(system, 0, null, null, rack.ref[mutable u64&]) == ORBIS_OK
        assert sceNgs2RackSetUserData(rack, 456) == ORBIS_OK
        assert sceNgs2RackGetUserData(rack, user_data.ref[mutable usize&]) == ORBIS_OK
        assert user_data == 456

        assert sceNgs2RackGetVoiceHandle(rack, 0u32, voice.ref[mutable u64&]) == ORBIS_OK
        assert sceNgs2RackGetVoiceHandle(rack, 0u32, voice_again.ref[mutable u64&]) == ORBIS_OK
        assert voice_again == voice
        assert sceNgs2RackGetVoiceHandle(rack, 1u32, voice_1.ref[mutable u64&]) == ORBIS_OK
        assert voice_1 != voice
        assert sceNgs2RackGetVoiceHandle(rack, 64u32, voice_again.ref[mutable u64&]) == ORBIS_NGS2_ERROR_INVALID_VOICE_INDEX
        assert sceNgs2SystemEnumRackHandles(system, rack.ref[mutable u64&], 1u32) == 1
        assert sceNgs2VoiceGetStateFlags(voice, flags.ref[mutable u32&]) == ORBIS_OK
        assert sceNgs2VoiceGetOwner(voice_1, owner_rack.ref[mutable u64&], owner_index.ref[mutable u32&]) == ORBIS_OK
        assert owner_rack == rack
        assert owner_index == 1u32
        assert sceNgs2VoiceGetStateFlags(0, flags.ref[mutable u32&]) == ORBIS_NGS2_ERROR_INVALID_VOICE_HANDLE

        assert sceNgs2SystemRender(system, null, 0u32) == ORBIS_OK
        assert sceNgs2SystemGetInfo(system, system_info.ref[mutable OrbisNgs2SystemInfo&], size_of(OrbisNgs2SystemInfo)) == ORBIS_OK
        assert system_info.system_handle == system
        assert system_info.rack_count == 1u32
        assert system_info.render_count == 1
        assert sceNgs2RackGetInfo(rack, rack_info.ref[mutable OrbisNgs2RackInfo&], size_of(OrbisNgs2RackInfo)) == ORBIS_OK
        assert rack_info.rack_handle == rack
        assert rack_info.owner_system_handle == system
        assert rack_info.render_count == 1u64

        assert sceNgs2ParseWaveformData(one_byte.ref[mutable u8&], 1, wave_info.ref[mutable OrbisNgs2WaveformInfo&]) == ORBIS_OK
        assert wave_info.format.num_channels == 1u32
        assert wave_info.format.sample_rate == 48000u32
        assert wave_info.num_blocks == 1u32
        assert wave_info.a_block0.data_size == 1u32
        assert wave_info.a_block0.num_repeats == 1u32

        assert sceNgs2RackDestroy(rack, out_destroy_rack_info.ref[mutable OrbisNgs2ContextBufferInfo&]) == ORBIS_OK
        assert sceNgs2SystemDestroy(system, out_destroy_system_info.ref[mutable OrbisNgs2ContextBufferInfo&]) == ORBIS_OK
        assert out_destroy_system_info.user_data == 123

@test
def ngs2_multiple_systems_and_racks_are_tracked() -> void:
    can Abort.Panic:
        one_byte: mutable u8 = 1u8
        buffer_info: mutable OrbisNgs2ContextBufferInfo = zeroed
        buffer_info.host_buffer <- one_byte.ref[mutable u8&]
        buffer_info.host_buffer_size <- 8

        system_a: mutable u64 = 0
        system_b: mutable u64 = 0
        rack_a0: mutable u64 = 0
        rack_a1: mutable u64 = 0
        rack_b0: mutable u64 = 0
        voice_a: mutable u64 = 0
        voice_b: mutable u64 = 0
        owner: mutable u64 = 0
        index: mutable u32 = 0u32
        info_a: OrbisNgs2SystemInfo = zeroed
        info_b: OrbisNgs2SystemInfo = zeroed
        rack_info: OrbisNgs2RackInfo = zeroed
        handles: mutable u64[4] = zeroed

        buffer_info.user_data <- 101
        assert sceNgs2SystemCreate(null, buffer_info.ref[OrbisNgs2ContextBufferInfo&], system_a.ref[mutable u64&]) == ORBIS_OK
        buffer_info.user_data <- 202
        assert sceNgs2SystemCreate(null, buffer_info.ref[OrbisNgs2ContextBufferInfo&], system_b.ref[mutable u64&]) == ORBIS_OK
        assert system_a != system_b

        assert sceNgs2RackCreate(system_a, 10u32, null, null, rack_a0.ref[mutable u64&]) == ORBIS_OK
        assert sceNgs2RackCreate(system_a, 11u32, null, null, rack_a1.ref[mutable u64&]) == ORBIS_OK
        assert sceNgs2RackCreate(system_b, 20u32, null, null, rack_b0.ref[mutable u64&]) == ORBIS_OK

        assert sceNgs2SystemEnumHandles(handles[0].ref[mutable u64&], 4u32) >= 2
        assert sceNgs2SystemEnumRackHandles(system_a, handles[0].ref[mutable u64&], 4u32) == 2
        assert sceNgs2SystemEnumRackHandles(system_b, handles[0].ref[mutable u64&], 4u32) == 1

        assert sceNgs2RackGetVoiceHandle(rack_a1, 3u32, voice_a.ref[mutable u64&]) == ORBIS_OK
        assert sceNgs2RackGetVoiceHandle(rack_b0, 3u32, voice_b.ref[mutable u64&]) == ORBIS_OK
        assert voice_a != voice_b
        assert sceNgs2VoiceGetOwner(voice_a, owner.ref[mutable u64&], index.ref[mutable u32&]) == ORBIS_OK
        assert owner == rack_a1
        assert index == 3u32
        assert sceNgs2VoiceGetOwner(voice_b, owner.ref[mutable u64&], index.ref[mutable u32&]) == ORBIS_OK
        assert owner == rack_b0
        assert index == 3u32

        assert sceNgs2SystemRender(system_a, null, 0u32) == ORBIS_OK
        assert sceNgs2SystemGetInfo(system_a, info_a.ref[mutable OrbisNgs2SystemInfo&], size_of(OrbisNgs2SystemInfo)) == ORBIS_OK
        assert sceNgs2SystemGetInfo(system_b, info_b.ref[mutable OrbisNgs2SystemInfo&], size_of(OrbisNgs2SystemInfo)) == ORBIS_OK
        assert info_a.rack_count == 2u32
        assert info_b.rack_count == 1u32
        assert info_a.render_count == 1
        assert info_b.render_count == 0
        assert sceNgs2RackGetInfo(rack_a0, rack_info.ref[mutable OrbisNgs2RackInfo&], size_of(OrbisNgs2RackInfo)) == ORBIS_OK
        assert rack_info.render_count == 1u64
        assert sceNgs2RackGetInfo(rack_b0, rack_info.ref[mutable OrbisNgs2RackInfo&], size_of(OrbisNgs2RackInfo)) == ORBIS_OK
        assert rack_info.render_count == 0u64

        assert sceNgs2SystemDestroy(system_a, null) == ORBIS_OK
        assert sceNgs2RackGetInfo(rack_a0, rack_info.ref[mutable OrbisNgs2RackInfo&], size_of(OrbisNgs2RackInfo)) == ORBIS_NGS2_ERROR_INVALID_RACK_HANDLE
        assert sceNgs2VoiceGetOwner(voice_a, owner.ref[mutable u64&], index.ref[mutable u32&]) == ORBIS_NGS2_ERROR_INVALID_VOICE_HANDLE
        assert sceNgs2SystemGetInfo(system_b, info_b.ref[mutable OrbisNgs2SystemInfo&], size_of(OrbisNgs2SystemInfo)) == ORBIS_OK
        assert sceNgs2SystemDestroy(system_b, null) == ORBIS_OK
