include "./common_test_harness.elisa"
include "./core/libraries/ngs2/ngs2.elisa"

@test("ngs2_system_rack_basic_contracts")
def ngs2_system_rack_basic_contracts() -> void:
    var system: u64 = 0
    var rack: u64 = 0
    var voice: u64 = 0

    var rc = sceNgs2SystemCreate(null, null, 0, &system)
    expect_eq_s32(ORBIS_OK, rc)

    rc = sceNgs2RackCreate(system, 0, null, null, 0, &rack)
    expect_eq_s32(ORBIS_OK, rc)

    rc = sceNgs2RackGetVoiceHandle(rack, 0, &voice)
    expect_eq_s32(ORBIS_OK, rc)

    var flags: u32 = 0
    rc = sceNgs2VoiceGetStateFlags(voice, &flags)
    expect_eq_s32(ORBIS_OK, rc)

    rc = sceNgs2RackDestroy(rack, null)
    expect_eq_s32(ORBIS_OK, rc)

    rc = sceNgs2SystemDestroy(system, null)
    expect_eq_s32(ORBIS_OK, rc)
