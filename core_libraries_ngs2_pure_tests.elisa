include "../compiler/runtime/elisacore_std/elisacore_runtime.elisa"
include "./core/libraries/ngs2/ngs2.elisa"

@test
def ngs2_system_rack_basic_contracts() -> void:
    can Abort.Panic:
        system: mutable u64 = 0
        rack: mutable u64 = 0
        voice: mutable u64 = 0
        flags: mutable u32 = 0u32

        assert sceNgs2SystemCreate(null, null, system.ref[mutable u64&]) == ORBIS_NGS2_ERROR_INVALID_BUFFER_INFO

        buffer_info: OrbisNgs2ContextBufferInfo = zeroed
        assert sceNgs2SystemCreate(null, buffer_info.ref[OrbisNgs2ContextBufferInfo&], system.ref[mutable u64&]) == ORBIS_OK

        assert sceNgs2SystemEnumHandles(system.ref[mutable u64&], 1u32) == 1
        assert sceNgs2RackCreate(0, 0, null, null, rack.ref[mutable u64&]) == ORBIS_NGS2_ERROR_INVALID_SYSTEM_HANDLE
        assert sceNgs2RackCreate(system, 0, null, null, rack.ref[mutable u64&]) == ORBIS_OK

        assert sceNgs2RackGetVoiceHandle(rack, 0u32, voice.ref[mutable u64&]) == ORBIS_OK
        assert sceNgs2SystemEnumRackHandles(system, rack.ref[mutable u64&], 1u32) == 1
        assert sceNgs2VoiceGetStateFlags(voice, flags.ref[mutable u32&]) == ORBIS_OK
        assert sceNgs2VoiceGetStateFlags(0, flags.ref[mutable u32&]) == ORBIS_NGS2_ERROR_INVALID_VOICE_HANDLE

        assert sceNgs2RackDestroy(rack, null) == ORBIS_OK
        assert sceNgs2SystemDestroy(system, null) == ORBIS_OK
