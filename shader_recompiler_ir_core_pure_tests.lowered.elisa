def ShaderIrEmitter_Pack2x16(program: mutable ShaderIrProgram&, emitter: mutable ShaderIrEmitter&, number_format: ShaderIrValue, vector: ShaderIrValue) -> ShaderIrValue:
    fmt: u32 = ShaderIrEmitter_ValueToU32(number_format)
    args: mutable ShaderIrValue[6] = zeroed
    args[0] <- vector
    if (fmt == IR_NUMFMT_UNORM):
        return ShaderIrEmitter_Emit(program.cast[mutable ShaderIrProgram&], emitter.cast[mutable ShaderIrEmitter&], IR_OPCODE_PACKUNORM2X16, 0, args, 1)
    if (fmt == IR_NUMFMT_SNORM):
        return ShaderIrEmitter_Emit(program.cast[mutable ShaderIrProgram&], emitter.cast[mutable ShaderIrEmitter&], IR_OPCODE_PACKSNORM2X16, 0, args, 1)
    if (fmt == IR_NUMFMT_UINT):
        return ShaderIrEmitter_Emit(program.cast[mutable ShaderIrProgram&], emitter.cast[mutable ShaderIrEmitter&], IR_OPCODE_PACKUINT2X16, 0, args, 1)
    if (fmt == IR_NUMFMT_SINT):
        return ShaderIrEmitter_Emit(program.cast[mutable ShaderIrProgram&], emitter.cast[mutable ShaderIrEmitter&], IR_OPCODE_PACKSINT2X16, 0, args, 1)
    if (fmt == IR_NUMFMT_FLOAT):
        return ShaderIrEmitter_Emit(program.cast[mutable ShaderIrProgram&], emitter.cast[mutable ShaderIrEmitter&], IR_OPCODE_PACKHALF2X16, 0, args, 1)
    return ShaderIrValue_Empty()

def ShaderIrEmitter_Unpack2x16(program: mutable ShaderIrProgram&, emitter: mutable ShaderIrEmitter&, number_format: ShaderIrValue, value: ShaderIrValue) -> ShaderIrValue:
    fmt: u32 = ShaderIrEmitter_ValueToU32(number_format)
