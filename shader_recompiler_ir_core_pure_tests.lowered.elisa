def ShaderIrEmitter_ConvertSToF(program: mutable ShaderIrProgram&, emitter: mutable ShaderIrEmitter&, dest_bitsize: ShaderIrValue, src_bitsize: ShaderIrValue, value: ShaderIrValue) -> ShaderIrValue:
    dst: u32 = ShaderIrEmitter_ValueToU32(dest_bitsize)
    src: u32 = ShaderIrEmitter_ValueToU32(src_bitsize)
    args: mutable ShaderIrValue[6] = zeroed
    args[0] <- value
    if ((dst == 32) and (src == 32)):
        return ShaderIrEmitter_Emit(program.cast[mutable ShaderIrProgram&], emitter.cast[mutable ShaderIrEmitter&], IR_OPCODE_CONVERTF32S32, 0, args, 1)
    if ((dst == 64) and (src == 32)):
        return ShaderIrEmitter_Emit(program.cast[mutable ShaderIrProgram&], emitter.cast[mutable ShaderIrEmitter&], IR_OPCODE_CONVERTF64S32, 0, args, 1)
    return ShaderIrValue_Empty()

def ShaderIrEmitter_ConvertUToF(program: mutable ShaderIrProgram&, emitter: mutable ShaderIrEmitter&, dest_bitsize: ShaderIrValue, src_bitsize: ShaderIrValue, value: ShaderIrValue) -> ShaderIrValue:
    dst: u32 = ShaderIrEmitter_ValueToU32(dest_bitsize)
    src: u32 = ShaderIrEmitter_ValueToU32(src_bitsize)
    args: mutable ShaderIrValue[6] = zeroed
    args[0] <- value
    if (dst == 32):
        if (src == 16):
            return ShaderIrEmitter_Emit(program.cast[mutable ShaderIrProgram&], emitter.cast[mutable ShaderIrEmitter&], IR_OPCODE_CONVERTF32U16, 0, args, 1)
        if (src == 32):
            return ShaderIrEmitter_Emit(program.cast[mutable ShaderIrProgram&], emitter.cast[mutable ShaderIrEmitter&], IR_OPCODE_CONVERTF32U32, 0, args, 1)
    if ((dst == 64) and (src == 32)):
        return ShaderIrEmitter_Emit(program.cast[mutable ShaderIrProgram&], emitter.cast[mutable ShaderIrEmitter&], IR_OPCODE_CONVERTF64U32, 0, args, 1)
    return ShaderIrValue_Empty()

def ShaderIrEmitter_ConvertIToF(program: mutable ShaderIrProgram&, emitter: mutable ShaderIrEmitter&, dest_bitsize: ShaderIrValue, src_bitsize: ShaderIrValue, is_signed: ShaderIrValue, value: ShaderIrValue) -> ShaderIrValue:
    if ShaderIrEmitter_ValueToBool(is_signed):
