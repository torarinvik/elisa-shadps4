def ShaderIrEmitter_Select(program: mutable ShaderIrProgram&, emitter: mutable ShaderIrEmitter&, condition: ShaderIrValue, true_value: ShaderIrValue, false_value: ShaderIrValue) -> ShaderIrValue:
    if (true_value.type_bits != false_value.type_bits):
        return ShaderIrValue_Empty()
    args: mutable ShaderIrValue[6] = zeroed
    args[0] <- condition
    args[1] <- true_value
    args[2] <- false_value
    if (true_value.type_bits == IR_TYPE_U1):
        return ShaderIrEmitter_Emit(program.cast[mutable ShaderIrProgram&], emitter.cast[mutable ShaderIrEmitter&], IR_OPCODE_SELECTU1, 0, args, 3)
    if (true_value.type_bits == IR_TYPE_U32):
        return ShaderIrEmitter_Emit(program.cast[mutable ShaderIrProgram&], emitter.cast[mutable ShaderIrEmitter&], IR_OPCODE_SELECTU32, 0, args, 3)
    if (true_value.type_bits == IR_TYPE_F32):
        return ShaderIrEmitter_Emit(program.cast[mutable ShaderIrProgram&], emitter.cast[mutable ShaderIrEmitter&], IR_OPCODE_SELECTF32, 0, args, 3)
    return ShaderIrValue_Empty()

