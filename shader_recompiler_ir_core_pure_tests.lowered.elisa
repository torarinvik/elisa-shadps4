        return ShaderIrValue_Empty()
    if (e1.type_bits == IR_TYPE_U32):
        return ShaderIrEmitter_Emit(program.cast[mutable ShaderIrProgram&], emitter.cast[mutable ShaderIrEmitter&], IR_OPCODE_COMPOSITECONSTRUCTU32X2, 0, args, 2)
    if (e1.type_bits == IR_TYPE_U32X2):
        return ShaderIrEmitter_Emit(program.cast[mutable ShaderIrProgram&], emitter.cast[mutable ShaderIrEmitter&], IR_OPCODE_COMPOSITECONSTRUCTU32X2X2, 0, args, 2)
    if (e1.type_bits == IR_TYPE_F32):
        return ShaderIrEmitter_Emit(program.cast[mutable ShaderIrProgram&], emitter.cast[mutable ShaderIrEmitter&], IR_OPCODE_COMPOSITECONSTRUCTF32X2, 0, args, 2)
    if (e1.type_bits == IR_TYPE_F32X2):
        return ShaderIrEmitter_Emit(program.cast[mutable ShaderIrProgram&], emitter.cast[mutable ShaderIrEmitter&], IR_OPCODE_COMPOSITECONSTRUCTF32X2X2, 0, args, 2)
    return ShaderIrValue_Empty()

