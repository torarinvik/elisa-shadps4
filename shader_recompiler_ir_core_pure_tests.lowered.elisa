def ShaderIrOpcode_ArgTypeOf(op: u32, arg_index: u32) -> u32:
    if (op == IR_OPCODE_PHI):
        return IR_TYPE_VOID
    if (op == IR_OPCODE_IDENTITY):
        if (arg_index == 0):
            return IR_TYPE_OPAQUE
        return IR_TYPE_VOID
    if (op == IR_OPCODE_VOID):
        return IR_TYPE_VOID
    if (op == IR_OPCODE_CONDITIONREF):
        if (arg_index == 0):
            return IR_TYPE_U1
        return IR_TYPE_VOID
    if (op == IR_OPCODE_REFERENCE):
        if (arg_index == 0):
            return IR_TYPE_OPAQUE
        return IR_TYPE_VOID
    if (op == IR_OPCODE_PHIMOVE):
        if (arg_index == 0):
            return IR_TYPE_OPAQUE
        if (arg_index == 1):
            return IR_TYPE_OPAQUE
        return IR_TYPE_VOID
    if (op == IR_OPCODE_PROLOGUE):
        return IR_TYPE_VOID
    if (op == IR_OPCODE_EPILOGUE):
        return IR_TYPE_VOID
    if (op == IR_OPCODE_DISCARD):
        return IR_TYPE_VOID
    if (op == IR_OPCODE_DISCARDCOND):
        if (arg_index == 0):
            return IR_TYPE_U1
        return IR_TYPE_VOID
    if (op == IR_OPCODE_DEBUGPRINT):
        if (arg_index == 0):
            return IR_TYPE_STRINGLITERAL
        if (arg_index == 1):
            return IR_TYPE_OPAQUE
        if (arg_index == 2):
            return IR_TYPE_OPAQUE
        if (arg_index == 3):
            return IR_TYPE_OPAQUE
        if (arg_index == 4):
            return IR_TYPE_OPAQUE
        return IR_TYPE_VOID
    if (op == IR_OPCODE_READCONST):
        if (arg_index == 0):
            return IR_TYPE_U32X2
        if (arg_index == 1):
            return IR_TYPE_U32
        return IR_TYPE_VOID
    if (op == IR_OPCODE_READCONSTBUFFER):
        if (arg_index == 0):
            return IR_TYPE_OPAQUE
        if (arg_index == 1):
            return IR_TYPE_U32
        return IR_TYPE_VOID
    if (op == IR_OPCODE_BARRIER):
        return IR_TYPE_VOID
    if (op == IR_OPCODE_WORKGROUPMEMORYBARRIER):
        return IR_TYPE_VOID
    if (op == IR_OPCODE_DEVICEMEMORYBARRIER):
        return IR_TYPE_VOID
    if (op == IR_OPCODE_EMITVERTEX):
        return IR_TYPE_VOID
    if (op == IR_OPCODE_EMITPRIMITIVE):
        return IR_TYPE_VOID
    if (op == IR_OPCODE_LOADSHAREDU16):
        if (arg_index == 0):
            return IR_TYPE_U32
        return IR_TYPE_VOID
    if (op == IR_OPCODE_LOADSHAREDU32):
        if (arg_index == 0):
            return IR_TYPE_U32
        return IR_TYPE_VOID
