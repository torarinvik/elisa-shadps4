extern mutex_destroy(mu: mutable Mutex&) -> void can[Memory.Release]

extern ctx_mutex_lock(mutex: void&) -> int can[Sync.Lock]

extern ctx_mutex_unlock(mutex: void&) -> int can[Sync.Unlock]

extern condvar_init(out: mutable CondVar&) -> void can[Memory.Allocate]

extern condvar_destroy(cv: mutable CondVar&) -> void can[Memory.Release]

