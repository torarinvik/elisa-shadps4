    return ShaderIrEmitter_ConvertUToF(program.cast[mutable ShaderIrProgram&], emitter.cast[mutable ShaderIrEmitter&], dest_bitsize, src_bitsize, value)

def ShaderIrEmitter_UConvert(program: mutable ShaderIrProgram&, emitter: mutable ShaderIrEmitter&, result_bitsize: ShaderIrValue, value: ShaderIrValue) -> ShaderIrValue:
    dst: u32 = ShaderIrEmitter_ValueToU32(result_bitsize)
    args: mutable ShaderIrValue[6] = zeroed
    args[0] <- value
    if ((dst == 8) and (value.type_bits == IR_TYPE_U32)):
        return ShaderIrEmitter_Emit(program.cast[mutable ShaderIrProgram&], emitter.cast[mutable ShaderIrEmitter&], IR_OPCODE_CONVERTU8U32, 0, args, 1)
    if ((dst == 16) and (value.type_bits == IR_TYPE_U32)):
        return ShaderIrEmitter_Emit(program.cast[mutable ShaderIrProgram&], emitter.cast[mutable ShaderIrEmitter&], IR_OPCODE_CONVERTU16U32, 0, args, 1)
    if (dst == 32):
        if (value.type_bits == IR_TYPE_U8):
            return ShaderIrEmitter_Emit(program.cast[mutable ShaderIrProgram&], emitter.cast[mutable ShaderIrEmitter&], IR_OPCODE_CONVERTU32U8, 0, args, 1)
        if (value.type_bits == IR_TYPE_U16):
            return ShaderIrEmitter_Emit(program.cast[mutable ShaderIrProgram&], emitter.cast[mutable ShaderIrEmitter&], IR_OPCODE_CONVERTU32U16, 0, args, 1)
    return ShaderIrValue_Empty()

def ShaderIrEmitter_SConvert(program: mutable ShaderIrProgram&, emitter: mutable ShaderIrEmitter&, result_bitsize: ShaderIrValue, value: ShaderIrValue) -> ShaderIrValue:
    dst: u32 = ShaderIrEmitter_ValueToU32(result_bitsize)
    args: mutable ShaderIrValue[6] = zeroed
    args[0] <- value
    if (dst == 32):
        if (value.type_bits == IR_TYPE_U8):
            return ShaderIrEmitter_Emit(program.cast[mutable ShaderIrProgram&], emitter.cast[mutable ShaderIrEmitter&], IR_OPCODE_CONVERTS32S8, 0, args, 1)
        if (value.type_bits == IR_TYPE_U16):
            return ShaderIrEmitter_Emit(program.cast[mutable ShaderIrProgram&], emitter.cast[mutable ShaderIrEmitter&], IR_OPCODE_CONVERTS32S16, 0, args, 1)
    return ShaderIrValue_Empty()

def ShaderIrEmitter_FPConvert(program: mutable ShaderIrProgram&, emitter: mutable ShaderIrEmitter&, result_bitsize: ShaderIrValue, value: ShaderIrValue) -> ShaderIrValue:
    dst: u32 = ShaderIrEmitter_ValueToU32(result_bitsize)
    args: mutable ShaderIrValue[6] = zeroed
    args[0] <- value
    if ((dst == 16) and (value.type_bits == IR_TYPE_F32)):
        return ShaderIrEmitter_Emit(program.cast[mutable ShaderIrProgram&], emitter.cast[mutable ShaderIrEmitter&], IR_OPCODE_CONVERTF16F32, 0, args, 1)
    if (dst == 32):
        if (value.type_bits == IR_TYPE_F16):
            return ShaderIrEmitter_Emit(program.cast[mutable ShaderIrProgram&], emitter.cast[mutable ShaderIrEmitter&], IR_OPCODE_CONVERTF32F16, 0, args, 1)
        if (value.type_bits == IR_TYPE_F64):
            return ShaderIrEmitter_Emit(program.cast[mutable ShaderIrProgram&], emitter.cast[mutable ShaderIrEmitter&], IR_OPCODE_CONVERTF32F64, 0, args, 1)
    if ((dst == 64) and (value.type_bits == IR_TYPE_F32)):
        return ShaderIrEmitter_Emit(program.cast[mutable ShaderIrProgram&], emitter.cast[mutable ShaderIrEmitter&], IR_OPCODE_CONVERTF64F32, 0, args, 1)
    return ShaderIrValue_Empty()

