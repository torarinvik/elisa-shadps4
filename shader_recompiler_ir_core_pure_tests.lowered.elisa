struct ShaderIrBlockList:
    count: mutable u32
    blocks: mutable u32[256]

def ShaderIrBlockList_New() -> ShaderIrBlockList:
    return zeroed

def ShaderIrPostOrder(program: ShaderIrProgram&, root: ShaderIrAbstractSyntaxNode) -> ShaderIrBlockList:
    out: mutable ShaderIrBlockList = ShaderIrBlockList_New()
    assert((root.node_type == IR_ASL_NODE_BLOCK))
    first_block: u32 = root.block
    visited: mutable bool[256] = zeroed
    block_stack: mutable u32[512] = zeroed
    stack_count: mutable u32 = 0
    visited[first_block.usize()] <- true
    block_stack[stack_count.usize()] <- first_block
    stack_count <- (stack_count + 1)
    while (stack_count > 0):
        current: u32 = block_stack[((stack_count - 1)).usize()]
        stack_count <- (stack_count - 1)
        branch_added: mutable bool = false
        block: ShaderIrBlock = program.blocks[current.usize()]
        i: mutable u32 = 0
        while (i < block.imm_successor_count):
            succ: u32 = block.imm_successors[i.usize()]
            if (not visited[succ.usize()]):
                visited[succ.usize()] <- true
                block_stack[stack_count.usize()] <- current
                stack_count <- (stack_count + 1)
                block_stack[stack_count.usize()] <- succ
                stack_count <- (stack_count + 1)
                branch_added <- true
                break
            i <- (i + 1)
        if (not branch_added):
            out.blocks[out.count.usize()] <- current
            out.count <- (out.count + 1)
    return out

@test
def shader_ir_type_attribute_patch_opcode_core_parity() -> void:
    can Abort.Panic:
        assert((ShaderIrType_NameOf(IR_TYPE_VOID) == "Void"))
        assert(ShaderIrType_AreTypesCompatible(IR_TYPE_OPAQUE, IR_TYPE_U32))
        assert(ShaderIrType_AreTypesCompatible(IR_TYPE_U32, IR_TYPE_U32))
        assert((not ShaderIrType_AreTypesCompatible(IR_TYPE_U32, IR_TYPE_F32)))
        assert(ShaderIrAttribute_IsPosition(IR_ATTRIBUTE_POSITION0))
        assert(ShaderIrAttribute_IsParam(IR_ATTRIBUTE_PARAM31))
        assert(ShaderIrAttribute_IsMrt(IR_ATTRIBUTE_RENDERTARGET7))
        assert((ShaderIrAttribute_NameOf(IR_ATTRIBUTE_SAMPLEINDEX) == "SampleIndex"))
        assert(ShaderIrPatch_IsGeneric(IR_PATCH_COMPONENT0))
        assert((ShaderIrPatch_GenericPatchIndex(IR_PATCH_COMPONENT7) == 0))
        assert((ShaderIrPatch_GenericPatchElement(IR_PATCH_COMPONENT7) == 1))
        assert((ShaderIrPatch_NameOf(IR_PATCH_TESSELLATIONLODLEFT) == "TessellationLodLeft"))
        assert((IR_OPCODE_COUNT > 300))
        assert((ShaderIrOpcode_NameOf(IR_OPCODE_IADD32) == "IAdd32"))
        assert((ShaderIrOpcode_TypeOf(IR_OPCODE_IADD32) == IR_TYPE_U32))
        assert((ShaderIrOpcode_NumArgsOf(IR_OPCODE_IADD32) == 2))
        assert((ShaderIrOpcode_ArgTypeOf(IR_OPCODE_IADD32, 0) == IR_TYPE_U32))

@test
def shader_ir_value_block_program_and_postorder_core_parity() -> void:
    can Abort.Panic:
        info: ShaderIrProgramInfo = ShaderIrProgramInfo(1, 0x1122)
        program: mutable ShaderIrProgram = ShaderIrProgram_New(info)
        b0: u32 = ShaderIrProgram_AddBlock(program.cast[mutable ShaderIrProgram&])
        b1: u32 = ShaderIrProgram_AddBlock(program.cast[mutable ShaderIrProgram&])
        b2: u32 = ShaderIrProgram_AddBlock(program.cast[mutable ShaderIrProgram&])
        args: mutable ShaderIrValue[6] = zeroed
        args[0] <- ShaderIrValue_FromU32(2)
        args[1] <- ShaderIrValue_FromU32(3)
        i0: u32 = ShaderIrProgram_AppendInst(program.cast[mutable ShaderIrProgram&], b0, IR_OPCODE_IADD32, args, 2, 0)
        _ = i0
        ShaderIrBlock_AddBranch(program.blocks[b0.usize()].cast[mutable ShaderIrBlock&], b1, program.blocks[b1.usize()].cast[mutable ShaderIrBlock&])
        ShaderIrBlock_AddBranch(program.blocks[b1.usize()].cast[mutable ShaderIrBlock&], b2, program.blocks[b2.usize()].cast[mutable ShaderIrBlock&])
        root: ShaderIrAbstractSyntaxNode = ShaderIrAbstractSyntaxNode_Block(b0)
        order: ShaderIrBlockList = ShaderIrPostOrder(program, root)
        assert((order.count == 3))
        assert((ShaderIrBlock_Size(program.blocks[b0.usize()]) == 1))
        assert((ShaderIrOpcode_NameOf(program.blocks[b0.usize()].insts[0].opcode) == "IAdd32"))

@test
def shader_ir_microinstruction_and_emitter_core_parity() -> void:
    can Abort.Panic:
        info: ShaderIrProgramInfo = ShaderIrProgramInfo(2, 0x3344)
        program: mutable ShaderIrProgram = ShaderIrProgram_New(info)
        b0: u32 = ShaderIrProgram_AddBlock(program.cast[mutable ShaderIrProgram&])
        emitter: mutable ShaderIrEmitter = ShaderIrEmitter_New(b0)
        v1: ShaderIrValue = ShaderIrEmitter_Imm32FromU32(1)
        v2: ShaderIrValue = ShaderIrEmitter_Imm32FromU32(2)
        _ = v2
        args: mutable ShaderIrValue[6] = zeroed
        args[0] <- v1
        _ = ShaderIrEmitter_EmitNoFlags(program.cast[mutable ShaderIrProgram&], emitter.cast[mutable ShaderIrEmitter&], IR_OPCODE_GETSCC, args, 0)
        _ = ShaderIrEmitter_Prologue(program.cast[mutable ShaderIrProgram&], emitter.cast[mutable ShaderIrEmitter&])
        _ = ShaderIrEmitter_Discard_2(program.cast[mutable ShaderIrProgram&], emitter.cast[mutable ShaderIrEmitter&], ShaderIrValue_FromU1(true))
        inst: ShaderIrInst = program.blocks[b0.usize()].insts[1]
        assert(ShaderIrInst_MayHaveSideEffects(inst))
        args_id: mutable ShaderIrValue[6] = zeroed
        args_id[0] <- ShaderIrValue_FromU32(77)
        id_idx: u32 = ShaderIrProgram_AppendInst(program.cast[mutable ShaderIrProgram&], b0, IR_OPCODE_IDENTITY, args_id, 1, 0)
        args_use: mutable ShaderIrValue[6] = zeroed
        args_use[0] <- ShaderIrValue_FromInst(b0, id_idx)
        args_use[1] <- ShaderIrValue_FromU32(1)
        use_idx: u32 = ShaderIrProgram_AppendInst(program.cast[mutable ShaderIrProgram&], b0, IR_OPCODE_IADD32, args_use, 2, 0)
        _ = use_idx
        ShaderIrProgram_RecomputeUses(program.cast[mutable ShaderIrProgram&])
        assert((program.blocks[b0.usize()].insts[id_idx.usize()].use_count > 0))
        ShaderIrInst_ReplaceUsesWithAndRemove(program.cast[mutable ShaderIrProgram&], b0, id_idx, ShaderIrValue_FromU32(99))
        assert((program.blocks[b0.usize()].insts[id_idx.usize()].opcode == IR_OPCODE_VOID))
