    if (bits == 32):
        if (value.type_bits == IR_TYPE_F32):
            return ShaderIrEmitter_Emit(program.cast[mutable ShaderIrProgram&], emitter.cast[mutable ShaderIrEmitter&], IR_OPCODE_CONVERTS32F32, 0, args, 1)
        if (value.type_bits == IR_TYPE_F64):
            return ShaderIrEmitter_Emit(program.cast[mutable ShaderIrProgram&], emitter.cast[mutable ShaderIrEmitter&], IR_OPCODE_CONVERTS32F64, 0, args, 1)
    return ShaderIrValue_Empty()

