def ctx_concurrency_alloc(size: usize) -> mutable heap void&:
    can Memory.Allocate, Abort.Panic:
        raw: heap void&? = malloc(size)
        if (raw == null):
            panic("concurrency allocation failed")
        ptr: heap void& = raw.cast[heap void&]
        return ptr

def ctx_concurrency_box_new[T](value: T) -> mutable heap ConcurrencyBox[T]&:
    raw: heap void& = ctx_concurrency_alloc(size_of(ConcurrencyBox[T])) can Memory.Allocate, Abort.Panic
    box: heap ConcurrencyBox[T]& = raw.cast[heap ConcurrencyBox[T]&]
    box.value <- value
    return box

def mutex() -> Mutex:
    can Memory.Allocate:
        out: Mutex = zeroed
        mutex_init(out.cast[mutable Mutex&])
        return move out

def mutex_dispose(mu: mutable Mutex&):
    mutex_destroy(mu) can Memory.Release

def mutex_lock(mu: mutable Mutex&) -> MutexGuard[Held]:
    can Sync.Lock, Abort.Panic:
        if (mu.handle == null):
            panic("mutex_lock on uninitialized mutex")
        status: int = ctx_platform_mutex_lock(mu.handle.cast[void&])
        if (status != 0):
            panic("mutex lock failed")
        guard: MutexGuard[Held] = zeroed
        guard.handle <- mu.handle
        return move guard

def mutex_unlock(g: MutexGuard[Held]):
    can Sync.Unlock, Abort.Panic:
        handle: void&? = g.handle
        _ = move g
        if (handle == null):
            panic("mutex_unlock on empty guard")
        status: int = ctx_platform_mutex_unlock(handle.cast[void&])
        if (status != 0):
            panic("mutex unlock failed")

def condvar() -> CondVar:
    can Memory.Allocate:
        out: CondVar = zeroed
        condvar_init(out.cast[mutable CondVar&])
        return move out

def condvar_dispose(cv: mutable CondVar&):
    condvar_destroy(cv) can Memory.Release

def cond_wait(cv: mutable CondVar&, g: MutexGuard[Held]) -> MutexGuard[Held]:
    can Sync.Wait, Abort.Panic:
        cond_handle: void&? = cv.handle
        mutex_handle: void&? = g.handle
        if (cond_handle == null):
            panic("cond_wait on uninitialized condvar")
        if (mutex_handle == null):
            panic("cond_wait with empty mutex guard")
        status: int = ctx_platform_cond_wait(cond_handle.cast[void&], mutex_handle.cast[void&])
        if (status != 0):
            panic("cond wait failed")
        return move g

def notify_one(cv: mutable CondVar&):
    can Sync.Notify, Abort.Panic:
        if (cv.handle == null):
            panic("notify_one on uninitialized condvar")
        status: int = ctx_platform_cond_signal(cv.handle.cast[void&])
        if (status != 0):
            panic("cond signal failed")

def notify_all(cv: mutable CondVar&):
    can Sync.Notify, Abort.Panic:
        if (cv.handle == null):
            panic("notify_all on uninitialized condvar")
        status: int = ctx_platform_cond_broadcast(cv.handle.cast[void&])
        if (status != 0):
            panic("cond broadcast failed")

def yield_thread():
    thread_yield() can Thread.Yield

def sleep_usec(usec: u64):
    thread_sleep_usec(usec) can Thread.Sleep

def ctx_concurrency_join_handle(handle: uintptr):
    can Thread.Join, Abort.Panic:
        status: int = ctx_thread_join(handle)
        if (status != 0):
            panic("thread join failed")

def spawn_raw(entry: void&, arg: void&?) -> Thread[void&?, Joinable]:
    can Thread.Spawn, Abort.Panic:
        out: Thread[void&?, Joinable] = zeroed
        status: int = ctx_thread_create(out.handle.cast[mutable uintptr&], entry, arg)
        if (status != 0):
            panic("thread create failed")
        out.state <- arg
        return move out

def join_raw(thread: Thread[void&?, Joinable]) -> void&?:
    can Thread.Join, Abort.Panic:
        handle: uintptr = thread.handle
        state_bits: void&? = thread.state
        _ = move thread
        ctx_concurrency_join_handle(handle)
        return state_bits

def native_callback_ptr(name: u8&) -> void&?:
    return elisa_native_callback_ptr(name)

def native_callback_call_u32_voidp(name: u8&, arg: void&?, fallback: u32) -> u32:
    return elisa_native_callback_call_u32_voidp(name, arg, fallback)

def native_callback_call_i32_voidp(name: u8&, arg: void&?, fallback: i32) -> i32:
    return elisa_native_callback_call_i32_voidp(name, arg, fallback)

def native_callback_call_usize_voidp(name: u8&, arg: void&?, fallback: usize) -> usize:
    return elisa_native_callback_call_usize_voidp(name, arg, fallback)

def native_callback_call_isize_voidp(name: u8&, arg: void&?, fallback: isize) -> isize:
    return elisa_native_callback_call_isize_voidp(name, arg, fallback)

def native_callback_spawn_join_u32_voidp(name: u8&, arg: void&?, fallback: u32) -> u32:
    return elisa_native_callback_spawn_join_u32_voidp(name, arg, fallback) can Thread.Spawn, Thread.Join

def native_callback_context_new_u32_voidp(name: u8&, arg: void&?, fallback: u32) -> mutable heap void&?:
    return elisa_native_callback_context_new_u32_voidp(name, arg, fallback) can Memory.Allocate

def native_callback_context_entry_u32_voidp() -> void&?:
    return elisa_native_callback_context_entry_u32_voidp()

def native_callback_context_start_u32_voidp(ctx: mutable heap void&?, thread: mutable uintptr&) -> int:
    return elisa_native_callback_context_start_u32_voidp(ctx, thread) can Thread.Spawn

def native_callback_context_join_u32_voidp(handle: uintptr, ctx: mutable heap void&?, fallback: u32) -> u32:
    return elisa_native_callback_context_join_u32_voidp(handle, ctx, fallback) can Thread.Join

def native_callback_context_spawn_join_u32_voidp(ctx: mutable heap void&?, fallback: u32) -> u32:
    return elisa_native_callback_context_spawn_join_u32_voidp(ctx, fallback) can Thread.Spawn, Thread.Join

def native_callback_context_result_u32(ctx: mutable heap void&?, fallback: u32) -> u32:
    return elisa_native_callback_context_result_u32(ctx, fallback)

def native_callback_context_free(ctx: mutable heap void&?):
    elisa_native_callback_context_free(ctx) can Memory.Release

def spawn_native_callback_u32_voidp(name: u8&, arg: void&?, fallback: u32) -> Thread[u32, Joinable]:
    can Thread.Spawn, Memory.Allocate, Memory.Release, Abort.Panic:
        ctx: mutable heap void&? = native_callback_context_new_u32_voidp(name, arg, fallback)
        if (ctx == null):
            panic("native callback context allocation failed")
        out: Thread[u32, Joinable] = zeroed
        status: int = native_callback_context_start_u32_voidp(ctx, out.handle.cast[mutable uintptr&])
        if (status != 0):
            native_callback_context_free(ctx)
            panic("native callback context start failed")
        out.state <- ctx.cast[void&]
        return move out

def join_native_callback_u32(thread: Thread[u32, Joinable], fallback: u32) -> u32:
    can Thread.Join, Memory.Release, Abort.Panic:
        handle: uintptr = thread.handle
        state_bits: void&? = thread.state
        _ = move thread
        result: u32 = native_callback_context_join_u32_voidp(handle, state_bits.cast[mutable heap void&?], fallback)
        native_callback_context_free(state_bits.cast[mutable heap void&?])
        return result

def detach_raw(thread: Thread[void&?, Joinable]):
    can Thread.Detach, Abort.Panic:
        handle: uintptr = thread.handle
        _ = move thread
        status: int = ctx_thread_detach(handle)
        if (status != 0):
            panic("thread detach failed")

def pool_new(threads: usize) -> ThreadPool:
    can Pool.Create, Memory.Allocate, Abort.Panic:
        raw: heap void& = ctx_concurrency_alloc(size_of(ConcurrencyPoolState))
        state: heap ConcurrencyPoolState& = raw.cast[heap ConcurrencyPoolState&]
        state.worker_count <- threads
        out: ThreadPool = zeroed
        out.handle <- state.cast[void&]
        return move out

def pool_shutdown(pool: mutable ThreadPool&):
    can Pool.Shutdown, Memory.Release:
        if (pool.handle != null):
            free(pool.handle.cast[heap void&])
            pool.handle <- null

def pool_submit_raw(pool: mutable ThreadPool&, entry: void&, arg: void&?) -> Task[void&?, Pending]:
    can Pool.Submit, Thread.Spawn, Abort.Panic:
        _ = pool
        thread: Thread[void&?, Joinable] = spawn_raw(entry, arg)
        out: Task[void&?, Pending] = zeroed
        out.handle <- thread.handle
        out.state <- thread.state
        _ = move thread
        return move out

def pool_await_raw(task: Task[void&?, Pending]) -> void&?:
    can Pool.Await, Thread.Join, Abort.Panic:
        handle: uintptr = task.handle
        state_bits: void&? = task.state
        _ = move task
        ctx_concurrency_join_handle(handle)
        return state_bits

def task_group_new_raw() -> TaskGroup:
    out: TaskGroup = zeroed
    return move out

def task_group_add_raw(group: mutable TaskGroup&, task: Task[void&?, Pending]):
    can Memory.Allocate, Abort.Panic:
        handle: uintptr = task.handle
        _ = move task
        raw: heap void& = ctx_concurrency_alloc(size_of(ConcurrencyRawTaskNode))
        node: heap ConcurrencyRawTaskNode& = raw.cast[heap ConcurrencyRawTaskNode&]
        node.handle <- handle
        if (group.handle == null):
            node.next <- null
        else:
            node.next <- group.handle.cast[heap ConcurrencyRawTaskNode&]
        group.handle <- node.cast[void&]

def task_group_wait_all_raw(group: mutable TaskGroup&):
    can Pool.WaitAll, Thread.Join, Memory.Release, Abort.Panic:
        current: mutable heap ConcurrencyRawTaskNode&? = group.handle.cast[heap ConcurrencyRawTaskNode&?]
        group.handle <- null
        trusted Unsafe.AssumeProgress:
            while (current != null):
                next: mutable heap ConcurrencyRawTaskNode&? = current.next
                ctx_concurrency_join_handle(current.handle)
                free(current.cast[heap void&])
                current <- next

def ctx_concurrency_ref_release(slot: mutable atomic[i64]&) -> i64:
    trusted Unsafe.AssumeProgress:
        while true:
            current: i64 = load(slot, MemoryOrder.Acquire) can Atomics.Load
            next: i64 = (current - 1)
            if compare_exchange(slot, current, next, MemoryOrder.AcqRel, MemoryOrder.Acquire) can Atomics.CompareExchange:
                return next
    return 0

def ctx_concurrency_work1_release(state_bits: mutable void&?):
    can Memory.Release, Atomics.Load, Atomics.CompareExchange:
        if (state_bits == null):
            return
        live_bits: void& = state_bits.cast[void&]
        state: heap ConcurrencyWorkStart1& = live_bits.cast[heap ConcurrencyWorkStart1&]
        remaining: i64 = ctx_concurrency_ref_release(state.casts.cast[atomic[i64]&])
        if (remaining == 0):
            free(state.arg_bits.cast[heap void&])
            free(state.result_bits.cast[heap void&])
            free(state.cast[heap void&])

def ctx_concurrency_work1_new[A, R, permission P](fn: func(A) -> R can[P], arg: A) -> mutable heap ConcurrencyWorkStart1&:
    can Memory.Allocate, Abort.Panic:
        arg_box: heap ConcurrencyBox[A]& = ctx_concurrency_box_new(arg)
        result_seed: R = zeroed
        result_box: heap ConcurrencyBox[R]& = ctx_concurrency_box_new(result_seed)
        raw: heap void& = ctx_concurrency_alloc(size_of(ConcurrencyWorkStart1))
        state: heap ConcurrencyWorkStart1& = raw.cast[heap ConcurrencyWorkStart1&]
        state.fn_bits <- fn as uintptr
        state.arg_bits <- arg_box.cast[void&]
        state.result_bits <- result_box.cast[void&]
        state.casts.value <- 2
        return state

def ctx_concurrency_work1_entry[A, R, permission P](state_bits: mutable void&) -> void&:
    can P, Memory.Release, Atomics.Load, Atomics.CompareExchange:
        state: heap ConcurrencyWorkStart1& = state_bits.cast[heap ConcurrencyWorkStart1&]
        fn: func(A) -> R can[P] = state.fn_bits.cast[func(A) -> R can[P]]
        arg_box: heap ConcurrencyBox[A]& = state.arg_bits.cast[heap ConcurrencyBox[A]&]
        result_box: heap ConcurrencyBox[R]& = state.result_bits.cast[heap ConcurrencyBox[R]&]
        result_box.value <- fn(arg_box.value)
        ctx_concurrency_work1_release(state.cast[mutable void&])
        return state.cast[void&]

def ctx_concurrency_work1_take_result[R](state_bits: void&?) -> R:
    can Memory.Release, Abort.Panic, Atomics.Load, Atomics.CompareExchange:
        if (state_bits == null):
            panic("concurrency work returned no state")
        live_bits: void& = state_bits.cast[void&]
        state: heap ConcurrencyWorkStart1& = live_bits.cast[heap ConcurrencyWorkStart1&]
        result_box: heap ConcurrencyBox[R]& = state.result_bits.cast[heap ConcurrencyBox[R]&]
        result: R = result_box.value
        ctx_concurrency_work1_release(state.cast[mutable void&])
        return result

def ctx_thread_from_raw[R, S](raw: Thread[void&?, S]) -> Thread[R, S]:
    out: Thread[R, S] = zeroed
    out.handle <- raw.handle
    out.state <- raw.state
    return move out

def ctx_thread_to_raw[R, S](thread: Thread[R, S]) -> Thread[void&?, S]:
    out: Thread[void&?, S] = zeroed
    out.handle <- thread.handle
    out.state <- thread.state
    return move out

def ctx_task_from_raw[R, S](raw: Task[void&?, S]) -> Task[R, S]:
    out: Task[R, S] = zeroed
    out.handle <- raw.handle
    out.state <- raw.state
    return move out

def ctx_task_to_raw[R, S](task: Task[R, S]) -> Task[void&?, S]:
    out: Task[void&?, S] = zeroed
    out.handle <- task.handle
    out.state <- task.state
    return move out

def task_group_new() -> TaskGroup:
    group: TaskGroup = task_group_new_raw()
    group.cleanup <- null
    return move group

def ctx_task_group_push_state(group: mutable TaskGroup&, state_bits: void&?):
    can Memory.Allocate, Abort.Panic:
        if (state_bits == null):
            return
        raw: heap void& = ctx_concurrency_alloc(size_of(ConcurrencyTaskGroupNode))
        node: heap ConcurrencyTaskGroupNode& = raw.cast[heap ConcurrencyTaskGroupNode&]
        if (group.cleanup == null):
            node.next <- null
        else:
            node.next <- group.cleanup.cast[heap ConcurrencyTaskGroupNode&]
        node.state_bits <- state_bits.cast[void&]
        group.cleanup <- node.cast[void&]

def ctx_task_group_release_all(group: mutable TaskGroup&):
    can Memory.Release, Atomics.Load, Atomics.CompareExchange:
        if (group.cleanup == null):
            return
        current: mutable heap ConcurrencyTaskGroupNode&? = group.cleanup.cast[heap ConcurrencyTaskGroupNode&?]
        group.cleanup <- null
        trusted Unsafe.AssumeProgress:
            while (current != null):
                next: mutable heap ConcurrencyTaskGroupNode&? = current.next
                ctx_concurrency_work1_release(current.state_bits.cast[mutable void&])
                free(current.cast[heap void&])
                current <- next

def spawn1[A, R, permission P](fn: func(A) -> R can[P], arg: A) -> Thread[R, Joinable]:
    can Thread.Spawn, Memory.Allocate, Abort.Panic:
        from_raw: func(Thread[void&?, Joinable]) -> Thread[R, Joinable] = ctx_thread_from_raw[R, Joinable]
        state: heap ConcurrencyWorkStart1& = ctx_concurrency_work1_new(fn, arg)
        raw: Thread[void&?, Joinable] = spawn_raw(ctx_concurrency_work1_entry[A, R].cast[void&], state.cast[void&])
        raw.state <- state.cast[void&]
        return from_raw(move raw)

def join[R](thread: Thread[R, Joinable]) -> R:
    can Thread.Join, Memory.Release, Abort.Panic, Atomics.Load, Atomics.CompareExchange:
        take_result: func(void&?) -> R can[Memory.Release, Abort.Panic, Atomics.Load, Atomics.CompareExchange] = ctx_concurrency_work1_take_result[R]
        state_bits: void&? = thread.state
        raw: Thread[void&?, Joinable] = ctx_thread_to_raw(move thread)
        _ = join_raw(move raw)
        result: R = take_result(state_bits)
        return result

def detach[R](thread: Thread[R, Joinable]):
    can Thread.Detach, Memory.Release, Abort.Panic, Atomics.Load, Atomics.CompareExchange:
        state_bits: void&? = thread.state
        raw: Thread[void&?, Joinable] = ctx_thread_to_raw(move thread)
        detach_raw(move raw)
        ctx_concurrency_work1_release(state_bits)

def pool_submit1[A, R, permission P](pool: mutable ThreadPool&, fn: func(A) -> R can[P], arg: A) -> Task[R, Pending]:
    can Pool.Submit, Thread.Spawn, Memory.Allocate, Abort.Panic:
        from_raw: func(Task[void&?, Pending]) -> Task[R, Pending] = ctx_task_from_raw[R, Pending]
        state: heap ConcurrencyWorkStart1& = ctx_concurrency_work1_new(fn, arg)
        raw: Task[void&?, Pending] = pool_submit_raw(pool, ctx_concurrency_work1_entry[A, R].cast[void&], state.cast[void&])
        raw.state <- state.cast[void&]
        return from_raw(move raw)

def pool_await[R](task: Task[R, Pending]) -> R:
    can Pool.Await, Thread.Join, Memory.Release, Abort.Panic, Atomics.Load, Atomics.CompareExchange:
        take_result: func(void&?) -> R can[Memory.Release, Abort.Panic, Atomics.Load, Atomics.CompareExchange] = ctx_concurrency_work1_take_result[R]
        state_bits: void&? = task.state
        raw: Task[void&?, Pending] = ctx_task_to_raw(move task)
        _ = pool_await_raw(move raw)
        result: R = take_result(state_bits)
        return result

def task_group_add[R](group: mutable TaskGroup&, task: Task[R, Pending]):
    can Memory.Allocate, Abort.Panic:
        state_bits: void&? = task.state
        raw: Task[void&?, Pending] = ctx_task_to_raw(move task)
        task_group_add_raw(group, move raw)
        ctx_task_group_push_state(group, state_bits)

def task_group_wait_all(group: mutable TaskGroup&):
    can Pool.WaitAll, Thread.Join, Memory.Release, Abort.Panic, Atomics.Load, Atomics.CompareExchange:
        task_group_wait_all_raw(group)
        ctx_task_group_release_all(group)

def load[T](slot: atomic[T]&, order: MemoryOrder) -> T:
    can Atomics.Load:
        _ = order
        return slot.value

def store[T](slot: mutable atomic[T]&, value: T, order: MemoryOrder):
    can Atomics.Store:
        _ = order
        slot.value <- value

def exchange[T](slot: mutable atomic[T]&, value: T, order: MemoryOrder) -> T:
    can Atomics.Exchange:
        _ = order
        old_value: T = slot.value
        slot.value <- value
        return old_value

def compare_exchange[T](slot: mutable atomic[T]&, expected: T, desired: T, success: MemoryOrder, failure: MemoryOrder) -> bool:
    can Atomics.CompareExchange:
        _ = success
        _ = failure
        if (slot.value == expected):
            slot.value <- desired
            return true
        return false

def fetch_add(slot: mutable atomic[i64]&, value: i64, order: MemoryOrder) -> i64:
    can Atomics.Rmw:
        _ = order
        old_value: i64 = slot.value
        slot.value <- (old_value + value)
        return old_value

def fetch_sub(slot: mutable atomic[i64]&, value: i64, order: MemoryOrder) -> i64:
    can Atomics.Rmw:
        _ = order
        old_value: i64 = slot.value
        slot.value <- (old_value - value)
        return old_value

def fetch_or(slot: mutable atomic[i64]&, value: i64, order: MemoryOrder) -> i64:
    can Atomics.Rmw:
        _ = order
        old_value: i64 = slot.value
        slot.value <- (old_value | value)
        return old_value

def fetch_and(slot: mutable atomic[i64]&, value: i64, order: MemoryOrder) -> i64:
    can Atomics.Rmw:
        _ = order
        old_value: i64 = slot.value
        slot.value <- (old_value & value)
        return old_value

def fetch_xor(slot: mutable atomic[i64]&, value: i64, order: MemoryOrder) -> i64:
    can Atomics.Rmw:
        _ = order
        old_value: i64 = slot.value
        slot.value <- (old_value ^ value)
        return old_value

def fence(order: MemoryOrder):
    _ = order can Atomics.Fence

def concat2(lhs: u8&?, rhs: u8&?) -> u8&:
    can Memory.Allocate, Abort.Panic:
        left: u8& = (lhs.cast[u8&] if (lhs != null) else "")
        right: u8& = (rhs.cast[u8&] if (rhs != null) else "")
        left_len: usize = runtime_strlen(left)
        right_len: usize = runtime_strlen(right)
        if (left_len == 0):
            return right
        if (right_len == 0):
            return left
        if ((left_len + right_len) <= 8):
            text: u8[9]
            memcpy(text[0].cast[mutable void&], left.cast[void&], left_len)
            memcpy(((&text[0] + left_len)).cast[mutable void&], right.cast[void&], right_len)
            text[(left_len + right_len)] <- 0
            return intern_small_string(text[0].cast[u8&], (left_len + right_len)).cast[u8&]
        out: u8& = alloc_perm((((left_len + right_len) + 1)).i64()).cast[u8&]
        memcpy(out.cast[mutable void&], left.cast[void&], left_len)
        memcpy(((out + left_len)).cast[mutable void&], right.cast[void&], right_len)
        out[(left_len + right_len)] <- 0
        register_perm_string_len(out, (left_len + right_len))
        return out

def concat2_scratch(lhs: u8&?, rhs: u8&?) -> u8&:
    can Memory.Allocate, Abort.Panic:
        left: u8& = (lhs.cast[u8&] if (lhs != null) else "")
        right: u8& = (rhs.cast[u8&] if (rhs != null) else "")
        left_len: usize = runtime_strlen(left)
        right_len: usize = runtime_strlen(right)
        if (left_len == 0):
            return right
        if (right_len == 0):
            return left
        if ((left_len + right_len) <= 8):
            text: u8[9]
            memcpy(text[0].cast[mutable void&], left.cast[void&], left_len)
            memcpy(((&text[0] + left_len)).cast[mutable void&], right.cast[void&], right_len)
            text[(left_len + right_len)] <- 0
            return intern_small_string(text[0].cast[u8&], (left_len + right_len)).cast[u8&]
        out: u8& = alloc_scratch((((left_len + right_len) + 1)).i64()).cast[u8&]
        memcpy(out.cast[mutable void&], left.cast[void&], left_len)
        memcpy(((out + left_len)).cast[mutable void&], right.cast[void&], right_len)
        out[(left_len + right_len)] <- 0
        return out

def string_index(value: u8&?, index: i64) -> i64:
    src: u8& = (value if (value != null) else "")
    len: usize = runtime_strlen(src)
    return (0 if ((index < 0) or (index.usize() >= len)) else src[index.usize()].i64())

def string_slice_eq(value: u8&?, start: i64, end: i64, other: u8&?) -> int:
    src: u8& = (value if (value != null) else "")
    rhs: u8& = (other if (other != null) else "")
    len: usize = runtime_strlen(src)
    lo: mutable usize = 0
    hi: mutable usize = len
    if (start > 0):
        lo <- start.usize()
        if (lo > len):
            lo <- len
    if (end >= 0):
        hi <- end.usize()
        if (hi > len):
            hi <- len
    if (hi < lo):
        hi <- lo
    slice_len: usize = (hi - lo)
    rhs_len: usize = runtime_strlen(rhs)
    if (slice_len != rhs_len):
        return 0
    if ((slice_len == 0) or ((src + lo) == rhs)):
        return 1
    return (1 if (memcmp(((src + lo)).cast[void&], rhs.cast[void&], slice_len) == 0) else 0)

def string_slices_eq(lhs: u8&?, lhs_start: i64, lhs_end: i64, rhs: u8&?, rhs_start: i64, rhs_end: i64) -> int:
    left: u8& = (lhs if (lhs != null) else "")
    right: u8& = (rhs if (rhs != null) else "")
    left_len: usize = runtime_strlen(left)
    right_len: usize = runtime_strlen(right)
    left_lo: mutable usize = 0
    left_hi: mutable usize = left_len
    right_lo: mutable usize = 0
    right_hi: mutable usize = right_len
    if (lhs_start > 0):
        left_lo <- lhs_start.usize()
        if (left_lo > left_len):
            left_lo <- left_len
    if (lhs_end >= 0):
        left_hi <- lhs_end.usize()
        if (left_hi > left_len):
            left_hi <- left_len
    if (left_hi < left_lo):
        left_hi <- left_lo
    if (rhs_start > 0):
        right_lo <- rhs_start.usize()
        if (right_lo > right_len):
            right_lo <- right_len
    if (rhs_end >= 0):
        right_hi <- rhs_end.usize()
        if (right_hi > right_len):
            right_hi <- right_len
    if (right_hi < right_lo):
        right_hi <- right_lo
    left_slice_len: usize = (left_hi - left_lo)
    right_slice_len: usize = (right_hi - right_lo)
    if (left_slice_len != right_slice_len):
        return 0
    if ((left_slice_len == 0) or ((left + left_lo) == (right + right_lo))):
        return 1
    return (1 if (memcmp(((left + left_lo)).cast[void&], ((right + right_lo)).cast[void&], left_slice_len) == 0) else 0)

def string_slice(value: u8&?, start: i64, end: i64) -> u8&:
    can Memory.Allocate, Abort.Panic:
        src: u8& = (value if (value != null) else "")
        len: usize = runtime_strlen(src)
        lo: mutable usize = 0
        hi: mutable usize = len
        if (start > 0):
            lo <- start.usize()
            if (lo > len):
                lo <- len
        if (end >= 0):
            hi <- end.usize()
            if (hi > len):
                hi <- len
        if (hi < lo):
            hi <- lo
        if ((lo == 0) and (hi == len)):
            return src
        out_len: usize = (hi - lo)
        if (out_len == 0):
            return ""
        if (out_len <= 8):
            return intern_small_string((src + lo), out_len).cast[u8&]
        out: u8& = alloc_perm(((out_len + 1)).i64()).cast[u8&]
        memcpy(out.cast[mutable void&], ((src + lo)).cast[void&], out_len)
        out[out_len] <- 0
        register_perm_string_len(out, out_len)
        return out

def sview(value: u8&?, start: i64, end: i64) -> sview:
    src: u8& = (value if (value != null) else "")
    len: usize = runtime_strlen(src)
    lo: mutable usize = 0
    hi: mutable usize = len
    if (start > 0):
        lo <- start.usize()
        if (lo > len):
            lo <- len
    if (end >= 0):
        hi <- end.usize()
        if (hi > len):
            hi <- len
    if (hi < lo):
        hi <- lo
    return StringView((src + lo), ((hi - lo)).i64())

def string_view_len(view: sview) -> i64:
    return view.len

def string_view_slice(view: sview, start: i64, end: i64) -> sview:
    lo: mutable i64 = (start if (start > 0) else 0)
    hi: mutable i64 = (end if (end >= 0) else view.len)
    if (lo > view.len):
        lo <- view.len
    if (hi > view.len):
        hi <- view.len
    if (hi < lo):
        hi <- lo
    return StringView((view.data + lo.usize()), (hi - lo))

def string_view_prefix(view: sview, end: i64) -> sview:
    return string_view_slice(view, 0, end)

def string_view_suffix(view: sview, start: i64) -> sview:
    return string_view_slice(view, start, view.len)

def string_view_index(view: sview, index: i64) -> i64:
    if ((index < 0) or (index >= view.len)):
        return 0
    return view.data[index.usize()].i64()

def string_view_eq(view: sview, other: u8&?) -> int:
    rhs: u8& = (other if (other != null) else "")
    rhs_len: usize = runtime_strlen(rhs)
    if ((view.len < 0) or (view.len.usize() != rhs_len)):
        return 0
    if ((view.len == 0) or (view.data == rhs)):
        return 1
    return (1 if (memcmp(view.data.cast[void&], rhs.cast[void&], view.len.usize()) == 0) else 0)

def string_views_eq(lhs: sview, rhs: sview) -> int:
    if (lhs.len != rhs.len):
        return 0
    if ((lhs.len == 0) or (lhs.data == rhs.data)):
        return 1
    return (1 if (memcmp(lhs.data.cast[void&], rhs.data.cast[void&], lhs.len.usize()) == 0) else 0)

def string_view_copy(view: sview) -> heap u8&:
    can Memory.Allocate, Abort.Panic:
        if (view.len <= 0):
            return intern_small_string("", 0)
        if (view.len <= 8):
            return intern_small_string(view.data, view.len.usize())
        out: heap u8& = alloc_perm(((view.len + 1)).usize()).cast[heap u8&]
        memcpy(out.cast[mutable void&], view.data.cast[void&], view.len.usize())
        out[view.len.usize()] <- 0
        register_perm_string_len(out.cast[u8&], view.len.usize())
        return out

def int_to_string(value: i64) -> heap u8&:
    return int_to_string_into(perm_arena.cast[Arena&], value) can Memory.Allocate, Console.Format, Abort.Panic

def int_to_string_scratch(value: i64) -> heap u8&:
    return int_to_string_into(scratch_arena.cast[Arena&], value) can Memory.Allocate, Console.Format, Abort.Panic

def bool_to_string(value: int) -> u8&:
    return bool_to_string_into(perm_arena.cast[Arena&], value)

def bool_to_string_scratch(value: int) -> u8&:
    return bool_to_string_into(scratch_arena.cast[Arena&], value)

def char_to_string(value: i64) -> heap u8&:
    return char_to_string_into(perm_arena.cast[Arena&], value) can Memory.Allocate, Abort.Panic

def char_to_string_scratch(value: i64) -> heap u8&:
    return char_to_string_into(scratch_arena.cast[Arena&], value) can Memory.Allocate, Abort.Panic

def __cast__(value: static u8&) -> u8&:
    return value.cast[u8&]

def string_len(value: u8&?) -> i64:
    return runtime_strlen(value).i64()

def streq(lhs: u8&?, rhs: u8&?) -> int:
    left: u8& = (lhs if (lhs != null) else "")
    right: u8& = (rhs if (rhs != null) else "")
    return (1 if ((left == right) or (strcmp(left, right) == 0)) else 0)

def rt_concat2(lhs: cstr[shape_left], rhs: cstr[shape_right]) -> cstr[shape_result]:
    return concat2(lhs, rhs) can Memory.Allocate, Abort.Panic

def rt_concat2_scratch(lhs: cstr[shape_left], rhs: cstr[shape_right]) -> cstr[shape_result]:
    return concat2_scratch(lhs, rhs) can Memory.Allocate, Abort.Panic

def rt_string_builder_new(initial: u8&?) -> mutable heap StringBuilder&:
    return string_builder_new(initial) can Memory.Allocate, Abort.Panic

def rt_string_builder_append(builder: mutable heap StringBuilder&?, suffix: u8&?) -> mutable heap StringBuilder&:
    return string_builder_append(builder, suffix) can Memory.Allocate, Abort.Panic

def rt_string_builder_finish(builder: heap StringBuilder&?) -> cstr[shape_out]:
    return string_builder_finish(builder).cast[u8&] can Memory.Allocate, Abort.Panic

def rt_int_to_string(value: i64) -> cstr[shape_out]:
    return int_to_string(value) can Memory.Allocate, Console.Format, Abort.Panic

def rt_int_to_string_scratch(value: i64) -> cstr[shape_out]:
    return int_to_string_scratch(value) can Memory.Allocate, Console.Format, Abort.Panic

def rt_bool_to_string(value: int) -> cstr[shape_out]:
    return bool_to_string(value)

def rt_bool_to_string_scratch(value: int) -> cstr[shape_out]:
    return bool_to_string_scratch(value)

def rt_char_to_string(value: i64) -> cstr[shape_out]:
    return char_to_string(value) can Memory.Allocate, Abort.Panic

def rt_char_to_string_scratch(value: i64) -> cstr[shape_out]:
    return char_to_string_scratch(value) can Memory.Allocate, Abort.Panic

def ctx_strlen(value: cstr[shape_in]) -> i64:
    return string_len(value)

def ctx_streq(lhs: cstr[shape_left], rhs: cstr[shape_right]) -> int:
    return streq(lhs, rhs)

def ctx_string_slice_eq(value: cstr[shape_in], start: i64, end: i64, other: cstr[shape_other]) -> int:
    return string_slice_eq(value, start, end, other)

def ctx_string_slices_eq(lhs: cstr[shape_left], lhs_start: i64, lhs_end: i64, rhs: cstr[shape_right], rhs_start: i64, rhs_end: i64) -> int:
    return string_slices_eq(lhs, lhs_start, lhs_end, rhs, rhs_start, rhs_end)

def ctx_string_index(value: cstr[shape_in], index: i64) -> i64:
    return string_index(value, index)

def ctx_string_slice(value: cstr[shape_in], start: i64, end: i64) -> cstr[shape_out]:
    return string_slice(value, start, end) can Memory.Allocate, Abort.Panic

def ctx_string_view(value: cstr[shape_in], start: i64, end: i64) -> sview:
    return sview(value, start, end)

def ctx_string_view_len(view: sview) -> i64:
    return string_view_len(view)

def ctx_string_view_slice(view: sview, start: i64, end: i64) -> sview:
    return string_view_slice(view, start, end)

def ctx_string_view_prefix(view: sview, end: i64) -> sview:
    return string_view_prefix(view, end)

def ctx_string_view_suffix(view: sview, start: i64) -> sview:
    return string_view_suffix(view, start)

def ctx_string_view_index(view: sview, index: i64) -> i64:
    return string_view_index(view, index)

def ctx_string_view_eq(view: sview, other: cstr[shape_other]) -> int:
    return string_view_eq(view, other)

def ctx_string_views_eq(lhs: sview, rhs: sview) -> int:
    return string_views_eq(lhs, rhs)

def ctx_string_from_view(view: sview) -> cstr[shape_out]:
    return string_view_copy(view).cast[u8&] can Memory.Allocate, Abort.Panic

def rt_reset_scratch():
    reset_scratch()

def rt_puts(value: u8&?) -> int:
    return puts((value if (value != null) else "")) can Console.Write

def ctx_llvm_codegen_fatal(msg: u8&?):
    can Console, Abort.Exit:
        actual_msg: u8& = (msg if (msg != null) else "<null>")
        puts("ctx_llvm_codegen_fatal:")
        puts(actual_msg)
        exit(1)

struct ByteBuffer:
    data: mutable heap u8&?
    len: mutable usize
    capacity: mutable usize

struct HeapByteBuffer:
    data: mutable heap u8&?
    len: mutable usize
    capacity: mutable usize

struct CxxU32MapEntry[T]:
    key: mutable u32
    value: mutable T

struct CxxU32Map[T]:
    entries: mutable darray[CxxU32MapEntry[T]]

def cxx_min_usize(a: usize, b: usize) -> usize:
    return (a if (a < b) else b)

def cxx_clamp_f32(value: f32, lo: f32, hi: f32) -> f32:
    if (value < lo):
        return lo
    if (value > hi):
        return hi
    return value

def cxx_memset(dest: mutable void&, value: u8, n: usize) -> mutable void&:
    bytes: mutable u8& = arena_mutable_u8_from_void(dest)
    trusted Unsafe.UncheckedIndex:
        for i in 0 ..< n:
            bytes[i] <- value
    return dest

def cxx_zero_memory(dest: mutable void&, n: usize) -> mutable void&:
    return cxx_memset(dest, 0.u8(), n)

def cxx_byte_buffer_empty() -> ByteBuffer:
    out: ByteBuffer = zeroed
    return out

def cxx_byte_buffer_alloc(a: mutable Arena&, size: usize) -> ByteBuffer:
    can Memory.Allocate, Abort.Panic:
        out: mutable ByteBuffer = zeroed
        if (size == 0):
            return out
        raw: mutable heap u8& = arena_heap_u8_from_alloc(arena_alloc(a, size))
        _ = cxx_zero_memory(arena_void_from_mutable_u8(raw), size)
        out.data as & <- raw
        out.len <- size
        out.capacity <- size
        return out

def cxx_byte_buffer_from(a: mutable Arena&, src: void&, size: usize) -> ByteBuffer:
    can Memory.Allocate, Abort.Panic:
        out: ByteBuffer = cxx_byte_buffer_alloc(a, size)
        if (size == 0):
            return out
        assert((out.data != null))
        _ = arena_memcpy(arena_void_from_mutable_u8(out.data), src, size)
        return out

def cxx_byte_buffer_resize_zeroed(a: mutable Arena&, buffer: mutable ByteBuffer&, size: usize):
    can Memory.Allocate, Abort.Panic:
        if (size <= buffer.capacity):
            return
        old_data: mutable heap u8&? = buffer.data
        old_len: usize = buffer.len
        raw: mutable heap u8& = arena_heap_u8_from_alloc(arena_alloc(a, size))
        _ = cxx_zero_memory(arena_void_from_mutable_u8(raw), size)
        if ((old_data != null) and (old_len > 0)):
            _ = arena_memcpy(arena_void_from_mutable_u8(raw), arena_void_from_u8(old_data), old_len)
        buffer.data as & <- raw
        buffer.capacity <- size
        buffer.len <- size

def cxx_byte_buffer_clear(buffer: mutable ByteBuffer&):
    buffer.len <- 0

def cxx_byte_buffer_view(buffer: ByteBuffer&) -> view[u8]:
    return (DynArrayView(null, 0, size_of(u8)) if ((buffer.data == null) or (buffer.len == 0)) else DynArrayView(arena_void_from_u8(buffer.data), buffer.len, size_of(u8)))

def cxx_heap_byte_buffer_alloc(size: usize) -> HeapByteBuffer:
    can Memory.Allocate, Abort.Panic:
        out: mutable HeapByteBuffer = zeroed
        if (size == 0):
            return out
        raw_void: mutable heap void&? = null
        trusted Unsafe.RawExtern:
            raw_void <- malloc(size)
        assert((raw_void != null))
        raw: mutable heap u8& = arena_heap_u8_from_alloc(raw_void)
        _ = cxx_zero_memory(arena_void_from_mutable_u8(raw), size)
        out.data as & <- raw
        out.len <- size
        out.capacity <- size
        return out

def cxx_heap_byte_buffer_from(src: void&, size: usize) -> HeapByteBuffer:
    can Memory.Allocate, Abort.Panic:
        out: HeapByteBuffer = cxx_heap_byte_buffer_alloc(size)
        if (size == 0):
            return out
        assert((out.data != null))
        _ = arena_memcpy(arena_void_from_mutable_u8(out.data), src, size)
        return out

def cxx_heap_byte_buffer_free(buffer: mutable HeapByteBuffer&):
    can Memory.Release:
        if (buffer.data == null):
            return
        trusted Unsafe.RawExtern:
            free(buffer.data.cast[heap void&])
        buffer.data as ! <- null
        buffer.len <- 0
        buffer.capacity <- 0

def cxx_read_value[T](ptr: void&?) -> T:
    can Abort.Panic:
        assert((ptr != null))
        trusted Unsafe.PointerCast:
            value: T& = ptr.cast[T&]
            return value[0]

def cxx_write_value[T](ptr: mutable void&?, value: T):
    can Abort.Panic:
        assert((ptr != null))
        trusted Unsafe.PointerCast:
            out: mutable T& = ptr.cast[mutable T&]
            out[0] <- value

def cxx_copy_value_to[T](ptr: mutable void&?, value: T):
    cxx_write_value[T](ptr, value) can Abort.Panic

def cxx_read_array_at[T](ptr: void&?, index: usize) -> T:
    can Abort.Panic:
        assert((ptr != null))
        trusted Unsafe.PointerCast, Unsafe.PointerArithmetic:
            items: T& = ptr.cast[T&]
            return items[index]

def cxx_array_ref_at[T](ptr: mutable void&?, index: usize) -> mutable T&:
    can Abort.Panic:
        assert((ptr != null))
        trusted Unsafe.PointerCast, Unsafe.PointerArithmetic:
            items: mutable T& = ptr.cast[mutable T&]
            return &items[index]

def cxx_vector_new[T](a: mutable Arena&, initial_capacity: usize) -> darray[T]:
    can Memory.Allocate, Abort.Panic:
        out: mutable darray[T] = zeroed
        in a:
            _ = out.reserve(initial_capacity)
        return out

def cxx_vector_push[T](a: mutable Arena&, vec: mutable darray[T]&, value: T):
    _ = arena_da_append(a, vec, value) can Memory.Allocate, Abort.Panic

def cxx_vector_assign_bytes(a: mutable Arena&, vec: mutable darray[u8]&, src: void&, size: usize):
    can Memory.Allocate, Abort.Panic:
        vec.count <- 0
        if (size == 0):
            return
        bytes: u8& = arena_u8_from_void(src)
        _ = arena_da_append_many(a, vec, bytes, size)

def cxx_deque_new[T](a: mutable Arena&, initial_capacity: usize) -> Deque[T]:
    return arena_deque_with_capacity[T](a, initial_capacity) can Memory.Allocate, Abort.Panic

def cxx_deque_push_back[T](a: mutable Arena&, deque: mutable Deque[T]&, item: T):
    _ = arena_deque_push_back[T](a, deque, item) can Memory.Allocate, Abort.Panic

def cxx_deque_pop_front[T](deque: mutable Deque[T]&, out: mutable T&) -> bool:
    return arena_deque_pop_front[T](deque, out) can Abort.Panic

def cxx_hash_map_new[K, T](a: mutable Arena&, initial_capacity: usize) -> dict[K, T]:
    return arena_dict_new[K, T](a, initial_capacity) can Memory.Allocate, Abort.Panic

def cxx_hash_map_put[K, T](a: mutable Arena&, map: mutable dict[K, T]&, key: K, value: T) -> mutable T&? error[RuntimeError]:
    return (try arena_dict_put[K, T](a, map, key, value)) can Memory.Allocate, Abort.Panic

def cxx_hash_map_get[K, T](map: dict[K, T]&, key: K) -> mutable T&?:
    return arena_dict_get[K, T](map, key)

def cxx_hash_map_contains[K, T](map: dict[K, T]&, key: K) -> bool:
    return arena_dict_contains[K, T](map, key)

def cxx_hash_map_remove[K, T](map: mutable dict[K, T]&, key: K) -> bool:
    return arena_dict_remove[K, T](map, key)

def cxx_hash_map_clear[K, T](map: mutable dict[K, T]&):
    arena_dict_clear[K, T](map)

def cxx_u32_map_new[T](a: mutable Arena&, initial_capacity: usize) -> CxxU32Map[T]:
    can Memory.Allocate, Abort.Panic:
        out: mutable CxxU32Map[T] = zeroed
        in a:
            _ = out.entries.reserve(initial_capacity)
        return out

def cxx_u32_map_count[T](map: CxxU32Map[T]&) -> usize:
    return map.entries.count

def cxx_u32_map_find_index[T](map: CxxU32Map[T]&, key: u32) -> usize:
    i: mutable usize = 0
    while (i < map.entries.count):
        if (map.entries[i].key == key):
            return i
        i <- (i + 1)
    return map.entries.count

def cxx_u32_map_get[T](map: CxxU32Map[T]&, key: u32) -> mutable T&?:
    index: usize = cxx_u32_map_find_index[T](map, key)
    if (index >= map.entries.count):
        return null
    return map.entries[index].value.cast[mutable T&]

def cxx_u32_map_contains[T](map: CxxU32Map[T]&, key: u32) -> bool:
    return (cxx_u32_map_find_index[T](map, key) < map.entries.count)

def cxx_u32_map_put[T](a: mutable Arena&, map: mutable CxxU32Map[T]&, key: u32, value: T) -> bool:
    can Memory.Allocate, Abort.Panic:
        index: usize = cxx_u32_map_find_index[T](map, key)
        if (index < map.entries.count):
            map.entries[index].value <- value
            return true
        entry: CxxU32MapEntry[T] = zeroed
        entry.key <- key
        entry.value <- value
        _ = arena_da_append[CxxU32MapEntry[T]](a, map.entries.cast[darray[CxxU32MapEntry[T]]&], entry)
        return true

def cxx_u32_map_remove[T](map: mutable CxxU32Map[T]&, key: u32) -> bool:
    can Abort.Panic:
        index: usize = cxx_u32_map_find_index[T](map, key)
        if (index >= map.entries.count):
            return false
        _ = darray_remove_at[CxxU32MapEntry[T]](map.entries.cast[darray[CxxU32MapEntry[T]]&], index)
        return true

def cxx_u32_map_clear[T](map: mutable CxxU32Map[T]&):
    map.entries.count <- 0

const IR_TYPE_VOID: u32 = 0

const IR_TYPE_OPAQUE: u32 = 1

const IR_TYPE_SCALARREG: u32 = 2

const IR_TYPE_VECTORREG: u32 = 4

const IR_TYPE_ATTRIBUTE: u32 = 8

const IR_TYPE_PATCH: u32 = 16

const IR_TYPE_U1: u32 = 32

const IR_TYPE_U8: u32 = 64

const IR_TYPE_U16: u32 = 128

const IR_TYPE_U32: u32 = 256

const IR_TYPE_U64: u32 = 512

const IR_TYPE_F16: u32 = 1024

const IR_TYPE_F32: u32 = 2048

const IR_TYPE_F64: u32 = 4096

const IR_TYPE_U32X2: u32 = 8192

const IR_TYPE_U32X3: u32 = 16384

const IR_TYPE_U32X4: u32 = 32768

const IR_TYPE_F16X2: u32 = 65536

const IR_TYPE_F16X3: u32 = 131072

const IR_TYPE_F16X4: u32 = 262144

const IR_TYPE_F32X2: u32 = 524288

const IR_TYPE_F32X3: u32 = 1048576

const IR_TYPE_F32X4: u32 = 2097152

const IR_TYPE_F64X2: u32 = 4194304

const IR_TYPE_F64X3: u32 = 8388608

const IR_TYPE_F64X4: u32 = 16777216

const IR_TYPE_STRINGLITERAL: u32 = 33554432

def ShaderIrType_NameOf(type_bits: u32) -> static u8&:
    if (type_bits == IR_TYPE_VOID):
        return "Void"
    if (type_bits == IR_TYPE_OPAQUE):
        return "Opaque"
    if (type_bits == IR_TYPE_SCALARREG):
        return "ScalarReg"
    if (type_bits == IR_TYPE_VECTORREG):
        return "VectorReg"
    if (type_bits == IR_TYPE_ATTRIBUTE):
        return "Attribute"
    if (type_bits == IR_TYPE_PATCH):
        return "Patch"
    if (type_bits == IR_TYPE_U1):
        return "U1"
    if (type_bits == IR_TYPE_U8):
        return "U8"
    if (type_bits == IR_TYPE_U16):
        return "U16"
    if (type_bits == IR_TYPE_U32):
        return "U32"
    if (type_bits == IR_TYPE_U64):
        return "U64"
    if (type_bits == IR_TYPE_F16):
        return "F16"
    if (type_bits == IR_TYPE_F32):
        return "F32"
    if (type_bits == IR_TYPE_F64):
        return "F64"
    if (type_bits == IR_TYPE_U32X2):
        return "U32x2"
    if (type_bits == IR_TYPE_U32X3):
        return "U32x3"
    if (type_bits == IR_TYPE_U32X4):
        return "U32x4"
    if (type_bits == IR_TYPE_F16X2):
        return "F16x2"
    if (type_bits == IR_TYPE_F16X3):
        return "F16x3"
    if (type_bits == IR_TYPE_F16X4):
        return "F16x4"
    if (type_bits == IR_TYPE_F32X2):
        return "F32x2"
    if (type_bits == IR_TYPE_F32X3):
        return "F32x3"
    if (type_bits == IR_TYPE_F32X4):
        return "F32x4"
    if (type_bits == IR_TYPE_F64X2):
        return "F64x2"
    if (type_bits == IR_TYPE_F64X3):
        return "F64x3"
    if (type_bits == IR_TYPE_F64X4):
        return "F64x4"
    if (type_bits == IR_TYPE_STRINGLITERAL):
        return "StringLiteral"
    return "<type-mask>"

def ShaderIrType_AreTypesCompatible(lhs: u32, rhs: u32) -> bool:
    return (((lhs == rhs) or (lhs == IR_TYPE_OPAQUE)) or (rhs == IR_TYPE_OPAQUE))

