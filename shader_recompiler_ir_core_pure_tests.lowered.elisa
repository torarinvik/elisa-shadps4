def ShaderIrEmitter_ILessThan(program: mutable ShaderIrProgram&, emitter: mutable ShaderIrEmitter&, lhs: ShaderIrValue, rhs: ShaderIrValue, is_signed: ShaderIrValue) -> ShaderIrValue:
    signed_op: bool = ShaderIrEmitter_ValueToBool(is_signed)
    args: mutable ShaderIrValue[6] = zeroed
    args[0] <- lhs
    args[1] <- rhs
    if (lhs.type_bits != rhs.type_bits):
        return ShaderIrValue_Empty()
    if (lhs.type_bits == IR_TYPE_U32):
        if signed_op:
            return ShaderIrEmitter_Emit(program.cast[mutable ShaderIrProgram&], emitter.cast[mutable ShaderIrEmitter&], IR_OPCODE_SLESSTHAN32, 0, args, 2)
        return ShaderIrEmitter_Emit(program.cast[mutable ShaderIrProgram&], emitter.cast[mutable ShaderIrEmitter&], IR_OPCODE_ULESSTHAN32, 0, args, 2)
    if (lhs.type_bits == IR_TYPE_U64):
        if signed_op:
            return ShaderIrEmitter_Emit(program.cast[mutable ShaderIrProgram&], emitter.cast[mutable ShaderIrEmitter&], IR_OPCODE_SLESSTHAN64, 0, args, 2)
        return ShaderIrEmitter_Emit(program.cast[mutable ShaderIrProgram&], emitter.cast[mutable ShaderIrEmitter&], IR_OPCODE_ULESSTHAN64, 0, args, 2)
    return ShaderIrValue_Empty()

