        if (arg_index == 0):
            return IR_TYPE_OPAQUE
        if (arg_index == 1):
            return IR_TYPE_U32
        if (arg_index == 2):
            return IR_TYPE_U1
        return IR_TYPE_VOID
    if (op == IR_OPCODE_IMAGEQUERYLOD):
        if (arg_index == 0):
            return IR_TYPE_OPAQUE
        if (arg_index == 1):
            return IR_TYPE_OPAQUE
        return IR_TYPE_VOID
    if (op == IR_OPCODE_IMAGEGRADIENT):
        if (arg_index == 0):
            return IR_TYPE_OPAQUE
        if (arg_index == 1):
            return IR_TYPE_OPAQUE
        if (arg_index == 2):
            return IR_TYPE_OPAQUE
        if (arg_index == 3):
            return IR_TYPE_OPAQUE
        if (arg_index == 4):
            return IR_TYPE_OPAQUE
        if (arg_index == 5):
            return IR_TYPE_F32
        return IR_TYPE_VOID
    if (op == IR_OPCODE_IMAGEREAD):
        if (arg_index == 0):
            return IR_TYPE_OPAQUE
        if (arg_index == 1):
            return IR_TYPE_OPAQUE
        if (arg_index == 2):
            return IR_TYPE_U32
        if (arg_index == 3):
            return IR_TYPE_U32
        return IR_TYPE_VOID
    if (op == IR_OPCODE_IMAGEWRITE):
        if (arg_index == 0):
            return IR_TYPE_OPAQUE
        if (arg_index == 1):
            return IR_TYPE_OPAQUE
        if (arg_index == 2):
            return IR_TYPE_U32
        if (arg_index == 3):
            return IR_TYPE_U32
        if (arg_index == 4):
            return IR_TYPE_F32X4
        return IR_TYPE_VOID
    if (op == IR_OPCODE_IMAGEATOMICIADD32):
        if (arg_index == 0):
            return IR_TYPE_OPAQUE
        if (arg_index == 1):
            return IR_TYPE_OPAQUE
        if (arg_index == 2):
            return IR_TYPE_U32
        return IR_TYPE_VOID
    if (op == IR_OPCODE_IMAGEATOMICSMIN32):
        if (arg_index == 0):
            return IR_TYPE_OPAQUE
        if (arg_index == 1):
            return IR_TYPE_OPAQUE
        if (arg_index == 2):
            return IR_TYPE_U32
        return IR_TYPE_VOID
    if (op == IR_OPCODE_IMAGEATOMICUMIN32):
        if (arg_index == 0):
            return IR_TYPE_OPAQUE
        if (arg_index == 1):
            return IR_TYPE_OPAQUE
        if (arg_index == 2):
            return IR_TYPE_U32
        return IR_TYPE_VOID
    if (op == IR_OPCODE_IMAGEATOMICSMAX32):
        if (arg_index == 0):
            return IR_TYPE_OPAQUE
        if (arg_index == 1):
            return IR_TYPE_OPAQUE
        if (arg_index == 2):
            return IR_TYPE_U32
        return IR_TYPE_VOID
    if (op == IR_OPCODE_IMAGEATOMICUMAX32):
        if (arg_index == 0):
            return IR_TYPE_OPAQUE
        if (arg_index == 1):
            return IR_TYPE_OPAQUE
        if (arg_index == 2):
            return IR_TYPE_U32
        return IR_TYPE_VOID
    if (op == IR_OPCODE_IMAGEATOMICFMAX32):
        if (arg_index == 0):
            return IR_TYPE_OPAQUE
        if (arg_index == 1):
            return IR_TYPE_OPAQUE
        if (arg_index == 2):
            return IR_TYPE_F32
        return IR_TYPE_VOID
    if (op == IR_OPCODE_IMAGEATOMICFMIN32):
        if (arg_index == 0):
            return IR_TYPE_OPAQUE
        if (arg_index == 1):
            return IR_TYPE_OPAQUE
        if (arg_index == 2):
            return IR_TYPE_F32
        return IR_TYPE_VOID
    if (op == IR_OPCODE_IMAGEATOMICINC32):
        if (arg_index == 0):
            return IR_TYPE_OPAQUE
        if (arg_index == 1):
            return IR_TYPE_OPAQUE
        if (arg_index == 2):
            return IR_TYPE_U32
        return IR_TYPE_VOID
    if (op == IR_OPCODE_IMAGEATOMICDEC32):
        if (arg_index == 0):
            return IR_TYPE_OPAQUE
        if (arg_index == 1):
            return IR_TYPE_OPAQUE
        if (arg_index == 2):
            return IR_TYPE_U32
        return IR_TYPE_VOID
    if (op == IR_OPCODE_IMAGEATOMICAND32):
        if (arg_index == 0):
            return IR_TYPE_OPAQUE
        if (arg_index == 1):
            return IR_TYPE_OPAQUE
        if (arg_index == 2):
            return IR_TYPE_U32
        return IR_TYPE_VOID
    if (op == IR_OPCODE_IMAGEATOMICOR32):
        if (arg_index == 0):
            return IR_TYPE_OPAQUE
        if (arg_index == 1):
            return IR_TYPE_OPAQUE
        if (arg_index == 2):
            return IR_TYPE_U32
        return IR_TYPE_VOID
    if (op == IR_OPCODE_IMAGEATOMICXOR32):
        if (arg_index == 0):
            return IR_TYPE_OPAQUE
        if (arg_index == 1):
            return IR_TYPE_OPAQUE
        if (arg_index == 2):
            return IR_TYPE_U32
        return IR_TYPE_VOID
    if (op == IR_OPCODE_IMAGEATOMICEXCHANGE32):
        if (arg_index == 0):
            return IR_TYPE_OPAQUE
        if (arg_index == 1):
            return IR_TYPE_OPAQUE
        if (arg_index == 2):
            return IR_TYPE_U32
        return IR_TYPE_VOID
    if (op == IR_OPCODE_IMAGEATOMICCMPSWAP32):
        if (arg_index == 0):
            return IR_TYPE_OPAQUE
        if (arg_index == 1):
            return IR_TYPE_OPAQUE
        if (arg_index == 2):
            return IR_TYPE_U32
        if (arg_index == 3):
            return IR_TYPE_U32
        return IR_TYPE_VOID
    if (op == IR_OPCODE_CUBEFACEINDEX):
        if (arg_index == 0):
            return IR_TYPE_F32X3
        return IR_TYPE_VOID
    if (op == IR_OPCODE_LANEID):
        return IR_TYPE_VOID
    if (op == IR_OPCODE_WARPID):
        return IR_TYPE_VOID
    if (op == IR_OPCODE_QUADSHUFFLE):
        if (arg_index == 0):
            return IR_TYPE_U32
        if (arg_index == 1):
            return IR_TYPE_U32
        return IR_TYPE_VOID
    if (op == IR_OPCODE_READFIRSTLANE):
        if (arg_index == 0):
            return IR_TYPE_U32
        return IR_TYPE_VOID
    if (op == IR_OPCODE_READLANE):
        if (arg_index == 0):
            return IR_TYPE_U32
        if (arg_index == 1):
            return IR_TYPE_U32
        return IR_TYPE_VOID
    if (op == IR_OPCODE_WRITELANE):
        if (arg_index == 0):
            return IR_TYPE_U32
        if (arg_index == 1):
            return IR_TYPE_U32
        if (arg_index == 2):
            return IR_TYPE_U32
        return IR_TYPE_VOID
    if (op == IR_OPCODE_BALLOT):
        if (arg_index == 0):
            return IR_TYPE_U1
        return IR_TYPE_VOID
    if (op == IR_OPCODE_BALLOTFINDLSB):
        if (arg_index == 0):
            return IR_TYPE_U32X4
        return IR_TYPE_VOID
    if (op == IR_OPCODE_DATAAPPEND):
        if (arg_index == 0):
            return IR_TYPE_U32
        if (arg_index == 1):
            return IR_TYPE_U32
        return IR_TYPE_VOID
    if (op == IR_OPCODE_DATACONSUME):
        if (arg_index == 0):
            return IR_TYPE_U32
        if (arg_index == 1):
            return IR_TYPE_U32
        return IR_TYPE_VOID
    if (op == IR_OPCODE_GROUPANY):
        if (arg_index == 0):
            return IR_TYPE_U1
        return IR_TYPE_VOID
    return IR_TYPE_VOID

const IR_NUM_SCALAR_REGS: u32 = 104

const IR_NUM_VECTOR_REGS: u32 = 256

const IR_MAX_ARGS: u32 = 6

const IR_MAX_PHI_ARGS: u32 = 64

struct ShaderIrValue:
    type_bits: mutable u32
    inst_block: mutable u32
    inst_index: mutable u32
    scalar_reg: mutable u32
    vector_reg: mutable u32
    attribute: mutable u64
    patch: mutable u64
    imm_u1: mutable bool
    imm_u8: mutable u8
    imm_u16: mutable u16
    imm_u32: mutable u32
    imm_f32: mutable f32
    imm_u64: mutable u64
    imm_f64: mutable f64
    string_literal: mutable static u8&

struct ShaderIrUse:
    user_block: mutable u32
    user_inst: mutable u32
    operand: mutable u32

struct ShaderIrInst:
    opcode: mutable u32
    definition: mutable u32
    flags_u64: mutable u64
    parent_block: mutable u32
    arg_count: mutable u32
    args: mutable ShaderIrValue[6]
    phi_arg_count: mutable u32
    phi_blocks: mutable u32[64]
    phi_values: mutable ShaderIrValue[64]
    use_count: mutable u32
    uses: mutable ShaderIrUse[128]

struct ShaderIrTypedValue:
    value: mutable ShaderIrValue
    accepted_mask: mutable u32

def ShaderIrValue_Empty() -> ShaderIrValue:
    out: mutable ShaderIrValue = zeroed
    out.type_bits <- IR_TYPE_VOID
    out.string_literal <- ""
    return out

def ShaderIrValue_FromInst(inst_block: u32, inst_index: u32) -> ShaderIrValue:
    out: mutable ShaderIrValue = ShaderIrValue_Empty()
    out.type_bits <- IR_TYPE_OPAQUE
    out.inst_block <- inst_block
    out.inst_index <- inst_index
    return out

def ShaderIrValue_FromScalarReg(reg: u32) -> ShaderIrValue:
    out: mutable ShaderIrValue = ShaderIrValue_Empty()
    out.type_bits <- IR_TYPE_SCALARREG
    out.scalar_reg <- reg
    return out

def ShaderIrValue_FromVectorReg(reg: u32) -> ShaderIrValue:
    out: mutable ShaderIrValue = ShaderIrValue_Empty()
    out.type_bits <- IR_TYPE_VECTORREG
    out.vector_reg <- reg
    return out

def ShaderIrValue_FromAttribute(attribute: u64) -> ShaderIrValue:
    out: mutable ShaderIrValue = ShaderIrValue_Empty()
    out.type_bits <- IR_TYPE_ATTRIBUTE
    out.attribute <- attribute
    return out

def ShaderIrValue_FromPatch(patch: u64) -> ShaderIrValue:
    out: mutable ShaderIrValue = ShaderIrValue_Empty()
    out.type_bits <- IR_TYPE_PATCH
    out.patch <- patch
    return out

def ShaderIrValue_FromU1(value: bool) -> ShaderIrValue:
    out: mutable ShaderIrValue = ShaderIrValue_Empty()
    out.type_bits <- IR_TYPE_U1
    out.imm_u1 <- value
    return out

def ShaderIrValue_FromU8(value: u8) -> ShaderIrValue:
    out: mutable ShaderIrValue = ShaderIrValue_Empty()
    out.type_bits <- IR_TYPE_U8
    out.imm_u8 <- value
    return out

def ShaderIrValue_FromU16(value: u16) -> ShaderIrValue:
    out: mutable ShaderIrValue = ShaderIrValue_Empty()
    out.type_bits <- IR_TYPE_U16
    out.imm_u16 <- value
    return out

def ShaderIrValue_FromU32(value: u32) -> ShaderIrValue:
    out: mutable ShaderIrValue = ShaderIrValue_Empty()
    out.type_bits <- IR_TYPE_U32
    out.imm_u32 <- value
    return out

def ShaderIrValue_FromF32(value: f32) -> ShaderIrValue:
    out: mutable ShaderIrValue = ShaderIrValue_Empty()
    out.type_bits <- IR_TYPE_F32
    out.imm_f32 <- value
    return out

def ShaderIrValue_FromU64(value: u64) -> ShaderIrValue:
    out: mutable ShaderIrValue = ShaderIrValue_Empty()
    out.type_bits <- IR_TYPE_U64
    out.imm_u64 <- value
    return out

def ShaderIrValue_FromF64(value: f64) -> ShaderIrValue:
    out: mutable ShaderIrValue = ShaderIrValue_Empty()
    out.type_bits <- IR_TYPE_F64
    out.imm_f64 <- value
    return out

def ShaderIrValue_FromStringLiteral(value: static u8&) -> ShaderIrValue:
    out: mutable ShaderIrValue = ShaderIrValue_Empty()
    out.type_bits <- IR_TYPE_STRINGLITERAL
    out.string_literal <- value
    return out

def ShaderIrTypedValue_New(value: ShaderIrValue, accepted_mask: u32) -> ShaderIrTypedValue:
    out: mutable ShaderIrTypedValue = zeroed
    out.value <- value
    out.accepted_mask <- accepted_mask
    return out

def ShaderIrTypedValue_IsCompatible(tv: ShaderIrTypedValue) -> bool:
    return (((tv.value.type_bits & tv.accepted_mask)) != 0)

def ShaderIrValue_IsEmpty(value: ShaderIrValue) -> bool:
    return (value.type_bits == IR_TYPE_VOID)

def ShaderIrValue_IsImmediate(value: ShaderIrValue) -> bool:
    return (value.type_bits != IR_TYPE_OPAQUE)

def ShaderIrValue_Type(value: ShaderIrValue) -> u32:
    return value.type_bits

def ShaderIrValue_ScalarReg(value: ShaderIrValue) -> u32:
    assert((value.type_bits == IR_TYPE_SCALARREG))
    return value.scalar_reg

def ShaderIrValue_VectorReg(value: ShaderIrValue) -> u32:
    assert((value.type_bits == IR_TYPE_VECTORREG))
    return value.vector_reg

def ShaderIrValue_Attribute(value: ShaderIrValue) -> u64:
    assert((value.type_bits == IR_TYPE_ATTRIBUTE))
    return value.attribute

def ShaderIrValue_Patch(value: ShaderIrValue) -> u64:
    assert((value.type_bits == IR_TYPE_PATCH))
    return value.patch

def ShaderIrValue_U1(value: ShaderIrValue) -> bool:
    assert((value.type_bits == IR_TYPE_U1))
    return value.imm_u1

def ShaderIrValue_U8(value: ShaderIrValue) -> u8:
    assert((value.type_bits == IR_TYPE_U8))
    return value.imm_u8

def ShaderIrValue_U16(value: ShaderIrValue) -> u16:
    assert((value.type_bits == IR_TYPE_U16))
    return value.imm_u16

def ShaderIrValue_U32(value: ShaderIrValue) -> u32:
    assert((value.type_bits == IR_TYPE_U32))
    return value.imm_u32

def ShaderIrValue_F32(value: ShaderIrValue) -> f32:
    assert((value.type_bits == IR_TYPE_F32))
    return value.imm_f32

def ShaderIrValue_U64(value: ShaderIrValue) -> u64:
    assert((value.type_bits == IR_TYPE_U64))
    return value.imm_u64

def ShaderIrValue_F64(value: ShaderIrValue) -> f64:
    assert((value.type_bits == IR_TYPE_F64))
    return value.imm_f64

def ShaderIrValue_StringLiteral(value: ShaderIrValue) -> static u8&:
    assert((value.type_bits == IR_TYPE_STRINGLITERAL))
    return value.string_literal

def ShaderIrValue_Equals(lhs: ShaderIrValue, rhs: ShaderIrValue) -> bool:
    if (lhs.type_bits != rhs.type_bits):
        return false
    if (lhs.type_bits == IR_TYPE_VOID):
        return true
    if (lhs.type_bits == IR_TYPE_OPAQUE):
        return ((lhs.inst_block == rhs.inst_block) and (lhs.inst_index == rhs.inst_index))
    if (lhs.type_bits == IR_TYPE_SCALARREG):
        return (lhs.scalar_reg == rhs.scalar_reg)
    if (lhs.type_bits == IR_TYPE_VECTORREG):
        return (lhs.vector_reg == rhs.vector_reg)
    if (lhs.type_bits == IR_TYPE_ATTRIBUTE):
        return (lhs.attribute == rhs.attribute)
    if (lhs.type_bits == IR_TYPE_PATCH):
        return (lhs.patch == rhs.patch)
    if (lhs.type_bits == IR_TYPE_U1):
        return (lhs.imm_u1 == rhs.imm_u1)
    if (lhs.type_bits == IR_TYPE_U8):
        return (lhs.imm_u8 == rhs.imm_u8)
    if ((lhs.type_bits == IR_TYPE_U16) or (lhs.type_bits == IR_TYPE_F16)):
        return (lhs.imm_u16 == rhs.imm_u16)
    if ((lhs.type_bits == IR_TYPE_U32) or (lhs.type_bits == IR_TYPE_F32)):
        return (lhs.imm_u32 == rhs.imm_u32)
    if ((lhs.type_bits == IR_TYPE_U64) or (lhs.type_bits == IR_TYPE_F64)):
        return (lhs.imm_u64 == rhs.imm_u64)
    if (lhs.type_bits == IR_TYPE_STRINGLITERAL):
        return (lhs.string_literal == rhs.string_literal)
    return false

def ShaderIrInst_New(opcode: u32, flags_u64: u64) -> ShaderIrInst:
    out: mutable ShaderIrInst = zeroed
    out.opcode <- opcode
    out.flags_u64 <- flags_u64
    out.parent_block <- 0xFFFFFFFF
    out.arg_count <- ShaderIrOpcode_NumArgsOf(opcode)
    if (opcode == IR_OPCODE_PHI):
        out.arg_count <- 0
    return out

def ShaderIrInst_NumArgs(inst: ShaderIrInst) -> u32:
    if (inst.opcode == IR_OPCODE_PHI):
        return inst.phi_arg_count
    return inst.arg_count

def ShaderIrInst_Arg(inst: ShaderIrInst, index: u32) -> ShaderIrValue:
    if (inst.opcode == IR_OPCODE_PHI):
        assert((index < inst.phi_arg_count))
        return inst.phi_values[index.usize()]
    assert((index < inst.arg_count))
    return inst.args[index.usize()]

def ShaderIrInst_SetArg(inst: mutable ShaderIrInst&, index: u32, value: ShaderIrValue) -> void:
    if (inst.opcode == IR_OPCODE_PHI):
        assert((index < inst.phi_arg_count))
        inst.phi_values[index.usize()] <- value
        return
    assert((index < IR_MAX_ARGS))
    if ((index + 1) > inst.arg_count):
        inst.arg_count <- (index + 1)
    inst.args[index.usize()] <- value

def ShaderIrInst_PhiBlock(inst: ShaderIrInst, index: u32) -> u32:
    assert((inst.opcode == IR_OPCODE_PHI))
    assert((index < inst.phi_arg_count))
    return inst.phi_blocks[index.usize()]

def ShaderIrInst_AddPhiOperand(inst: mutable ShaderIrInst&, predecessor_block: u32, value: ShaderIrValue) -> void:
    assert((inst.opcode == IR_OPCODE_PHI))
    assert((inst.phi_arg_count < IR_MAX_PHI_ARGS))
    idx: u32 = inst.phi_arg_count
    inst.phi_blocks[idx.usize()] <- predecessor_block
    inst.phi_values[idx.usize()] <- value
    inst.phi_arg_count <- (inst.phi_arg_count + 1)

def ShaderIrInst_ClearArgs(inst: mutable ShaderIrInst&) -> void:
    if (inst.opcode == IR_OPCODE_PHI):
        inst.phi_arg_count <- 0
    else:
        inst.arg_count <- 0
    inst.args <- zeroed
    inst.phi_values <- zeroed
    inst.phi_blocks <- zeroed

def ShaderIrInst_ReplaceOpcode(inst: mutable ShaderIrInst&, opcode: u32) -> void:
    assert((opcode != IR_OPCODE_PHI))
    if (inst.opcode == IR_OPCODE_PHI):
        inst.phi_arg_count <- 0
        inst.phi_values <- zeroed
        inst.phi_blocks <- zeroed
    inst.opcode <- opcode
    inst.arg_count <- ShaderIrOpcode_NumArgsOf(opcode)

def ShaderIrInst_Invalidate(inst: mutable ShaderIrInst&) -> void:
    ShaderIrInst_ClearArgs(inst.cast[mutable ShaderIrInst&])
    ShaderIrInst_ReplaceOpcode(inst.cast[mutable ShaderIrInst&], IR_OPCODE_VOID)

def ShaderIrInst_HasUses(inst: ShaderIrInst) -> bool:
    return (inst.use_count > 0)

def ShaderIrInst_UseCount(inst: ShaderIrInst) -> int:
    return inst.use_count.int()

def ShaderIrInst_AreAllArgsImmediates(inst: ShaderIrInst) -> bool:
    if (inst.opcode == IR_OPCODE_PHI):
        assert(false)
        return false
    i: mutable u32 = 0
    while (i < inst.arg_count):
        if (not ShaderIrValue_IsImmediate(inst.args[i.usize()])):
            return false
        i <- (i + 1)
    return true

def ShaderIrInst_Type(inst: ShaderIrInst) -> u32:
    return ShaderIrOpcode_TypeOf(inst.opcode)

const IR_ASL_NODE_BLOCK: u32 = 0

const IR_ASL_NODE_IF: u32 = 1

const IR_ASL_NODE_ENDIF: u32 = 2

const IR_ASL_NODE_LOOP: u32 = 3

const IR_ASL_NODE_REPEAT: u32 = 4

const IR_ASL_NODE_BREAK: u32 = 5

const IR_ASL_NODE_RETURN: u32 = 6

const IR_ASL_NODE_UNREACHABLE: u32 = 7

struct ShaderIrAbstractSyntaxNode:
    node_type: mutable u32
    block: mutable u32
    cond: mutable ShaderIrValue
    body: mutable u32
    merge: mutable u32
    continue_block: mutable u32
    loop_header: mutable u32
    skip: mutable u32

def ShaderIrAbstractSyntaxNode_Block(block_index: u32) -> ShaderIrAbstractSyntaxNode:
    out: mutable ShaderIrAbstractSyntaxNode = zeroed
    out.node_type <- IR_ASL_NODE_BLOCK
    out.block <- block_index
    return out

def ShaderIrAbstractSyntaxNode_If(cond: ShaderIrValue, body: u32, merge: u32) -> ShaderIrAbstractSyntaxNode:
    out: mutable ShaderIrAbstractSyntaxNode = zeroed
    out.node_type <- IR_ASL_NODE_IF
    out.cond <- cond
    out.body <- body
    out.merge <- merge
    return out

def ShaderIrAbstractSyntaxNode_EndIf(merge: u32) -> ShaderIrAbstractSyntaxNode:
    out: mutable ShaderIrAbstractSyntaxNode = zeroed
    out.node_type <- IR_ASL_NODE_ENDIF
    out.merge <- merge
    return out

def ShaderIrAbstractSyntaxNode_Loop(body: u32, continue_block: u32, merge: u32) -> ShaderIrAbstractSyntaxNode:
    out: mutable ShaderIrAbstractSyntaxNode = zeroed
    out.node_type <- IR_ASL_NODE_LOOP
    out.body <- body
    out.continue_block <- continue_block
    out.merge <- merge
    return out

def ShaderIrAbstractSyntaxNode_Repeat(cond: ShaderIrValue, loop_header: u32, merge: u32) -> ShaderIrAbstractSyntaxNode:
    out: mutable ShaderIrAbstractSyntaxNode = zeroed
    out.node_type <- IR_ASL_NODE_REPEAT
    out.cond <- cond
    out.loop_header <- loop_header
    out.merge <- merge
    return out

def ShaderIrAbstractSyntaxNode_Break(cond: ShaderIrValue, merge: u32, skip: u32) -> ShaderIrAbstractSyntaxNode:
    out: mutable ShaderIrAbstractSyntaxNode = zeroed
    out.node_type <- IR_ASL_NODE_BREAK
    out.cond <- cond
    out.merge <- merge
    out.skip <- skip
    return out

def ShaderIrAbstractSyntaxNode_Return() -> ShaderIrAbstractSyntaxNode:
    out: mutable ShaderIrAbstractSyntaxNode = zeroed
    out.node_type <- IR_ASL_NODE_RETURN
    return out

def ShaderIrAbstractSyntaxNode_Unreachable() -> ShaderIrAbstractSyntaxNode:
    out: mutable ShaderIrAbstractSyntaxNode = zeroed
    out.node_type <- IR_ASL_NODE_UNREACHABLE
    return out

def ShaderIrDumpASLNode(node: ShaderIrAbstractSyntaxNode) -> static u8&:
    if (node.node_type == IR_ASL_NODE_BLOCK):
        return "Block"
    if (node.node_type == IR_ASL_NODE_IF):
        return "If"
    if (node.node_type == IR_ASL_NODE_ENDIF):
        return "EndIf"
    if (node.node_type == IR_ASL_NODE_LOOP):
        return "Loop"
    if (node.node_type == IR_ASL_NODE_REPEAT):
        return "Repeat"
    if (node.node_type == IR_ASL_NODE_BREAK):
        return "Break"
    if (node.node_type == IR_ASL_NODE_RETURN):
        return "Return"
    if (node.node_type == IR_ASL_NODE_UNREACHABLE):
        return "Unreachable"
    return "<invalid asl node>"

const IR_MAX_BLOCK_INSTRUCTIONS: u32 = 1024

const IR_MAX_BLOCK_EDGES: u32 = 64

struct ShaderIrBlock:
    definition: mutable u32
    is_ssa_sealed: mutable bool
    cfg_block_id: mutable u32
    inst_count: mutable u32
    insts: mutable ShaderIrInst[1024]
    imm_predecessor_count: mutable u32
    imm_predecessors: mutable u32[64]
    imm_successor_count: mutable u32
    imm_successors: mutable u32[64]
    ssa_sreg_values: mutable ShaderIrValue[104]
    ssa_sbit_values: mutable ShaderIrValue[104]
    ssa_vreg_values: mutable ShaderIrValue[256]

def ShaderIrBlock_New() -> ShaderIrBlock:
    out: mutable ShaderIrBlock = zeroed
    out.cfg_block_id <- 0xFFFFFFFF
    return out

def ShaderIrBlock_AppendNewInst(block: mutable ShaderIrBlock&, opcode: u32, args: ShaderIrValue[6], arg_count: u32) -> u32:
    assert((block.inst_count < IR_MAX_BLOCK_INSTRUCTIONS))
    idx: u32 = block.inst_count
    block.inst_count <- (block.inst_count + 1)
    block.insts[idx.usize()] <- ShaderIrInst_New(opcode, 0)
    if (opcode != IR_OPCODE_PHI):
        block.insts[idx.usize()].arg_count <- arg_count
        a: mutable u32 = 0
        while ((a < arg_count) and (a < IR_MAX_ARGS)):
            block.insts[idx.usize()].args[a.usize()] <- args[a.usize()]
            a <- (a + 1)
    return idx

def ShaderIrBlock_PrependNewInstCopy(block: mutable ShaderIrBlock&, insertion_index: u32, base_inst: ShaderIrInst) -> u32:
    assert((insertion_index <= block.inst_count))
    assert((block.inst_count < IR_MAX_BLOCK_INSTRUCTIONS))
    i: mutable u32 = block.inst_count
    while (i > insertion_index):
        block.insts[i.usize()] <- block.insts[((i - 1)).usize()]
        i <- (i - 1)
    block.insts[insertion_index.usize()] <- base_inst
    block.inst_count <- (block.inst_count + 1)
    return insertion_index

def ShaderIrBlock_PrependNewInst(block: mutable ShaderIrBlock&, insertion_index: u32, opcode: u32, args: ShaderIrValue[6], arg_count: u32, flags_u64: u64) -> u32:
    assert((insertion_index <= block.inst_count))
    assert((block.inst_count < IR_MAX_BLOCK_INSTRUCTIONS))
    i: mutable u32 = block.inst_count
    while (i > insertion_index):
        block.insts[i.usize()] <- block.insts[((i - 1)).usize()]
        i <- (i - 1)
    block.insts[insertion_index.usize()] <- ShaderIrInst_New(opcode, flags_u64)
    if (opcode != IR_OPCODE_PHI):
        block.insts[insertion_index.usize()].arg_count <- arg_count
        a: mutable u32 = 0
        while ((a < arg_count) and (a < IR_MAX_ARGS)):
            block.insts[insertion_index.usize()].args[a.usize()] <- args[a.usize()]
            a <- (a + 1)
    block.inst_count <- (block.inst_count + 1)
    return insertion_index

def ShaderIrBlock_AddBranch(block: mutable ShaderIrBlock&, succ_block_index: u32, succ_block: mutable ShaderIrBlock&) -> void:
    i: mutable u32 = 0
    while (i < block.imm_successor_count):
        if (block.imm_successors[i.usize()] == succ_block_index):
            assert(false)
        i <- (i + 1)
    j: mutable u32 = 0
    while (j < succ_block.imm_predecessor_count):
        if (succ_block.imm_predecessors[j.usize()] == block.cfg_block_id):
            assert(false)
        j <- (j + 1)
    assert((block.imm_successor_count < IR_MAX_BLOCK_EDGES))
    assert((succ_block.imm_predecessor_count < IR_MAX_BLOCK_EDGES))
    block.imm_successors[block.imm_successor_count.usize()] <- succ_block_index
    block.imm_successor_count <- (block.imm_successor_count + 1)
    succ_block.imm_predecessors[succ_block.imm_predecessor_count.usize()] <- block.cfg_block_id
    succ_block.imm_predecessor_count <- (succ_block.imm_predecessor_count + 1)

def ShaderIrBlock_SsaSeal(block: mutable ShaderIrBlock&) -> void:
    block.is_ssa_sealed <- true

def ShaderIrBlock_IsSsaSealed(block: ShaderIrBlock) -> bool:
    return block.is_ssa_sealed

def ShaderIrBlock_Empty(block: ShaderIrBlock) -> bool:
    return (block.inst_count == 0)

def ShaderIrBlock_Size(block: ShaderIrBlock) -> u32:
    return block.inst_count

def ShaderIrBlock_SetDefinition(block: mutable ShaderIrBlock&, definition: u32) -> void:
    block.definition <- definition

def ShaderIrBlock_begin(block: ShaderIrBlock) -> u32:
    _ = block
    return 0

def ShaderIrBlock_end(block: ShaderIrBlock) -> u32:
    return block.inst_count

def ShaderIrBlock_Dump(block: ShaderIrBlock) -> static u8&:
    _ = block
    return "Block"

const IR_PROGRAM_MAX_BLOCKS: u32 = 256

const IR_PROGRAM_MAX_ASL_NODES: u32 = 1024

const IR_PROGRAM_MAX_INS_LIST: u32 = 4096

struct ShaderIrProgramInfo:
    stage: mutable u32
    pgm_hash: mutable u64

struct ShaderIrProgram:
    syntax_count: mutable u32
    syntax_list: mutable ShaderIrAbstractSyntaxNode[1024]
    block_count: mutable u32
    blocks: mutable ShaderIrBlock[256]
    post_order_count: mutable u32
    post_order_blocks: mutable u32[256]
    ins_count: mutable u32
    ins_list: mutable u32[4096]
    info: mutable ShaderIrProgramInfo

def ShaderIrProgram_New(info: ShaderIrProgramInfo) -> ShaderIrProgram:
    out: mutable ShaderIrProgram = zeroed
    out.info <- info
    return out

def ShaderIrProgram_AddBlock(program: mutable ShaderIrProgram&) -> u32:
    assert((program.block_count < IR_PROGRAM_MAX_BLOCKS))
    idx: u32 = program.block_count
    program.blocks[idx.usize()] <- ShaderIrBlock_New()
    program.blocks[idx.usize()].cfg_block_id <- idx
    program.block_count <- (program.block_count + 1)
    return idx

def ShaderIrProgram_AppendInst(program: mutable ShaderIrProgram&, block_index: u32, opcode: u32, args: ShaderIrValue[6], arg_count: u32, flags_u64: u64) -> u32:
    assert((block_index < program.block_count))
    block: mutable ShaderIrBlock& = program.blocks[block_index.usize()].cast[mutable ShaderIrBlock&]
    assert((block.inst_count < IR_MAX_BLOCK_INSTRUCTIONS))
    inst_index: u32 = block.inst_count
    block.inst_count <- (block.inst_count + 1)
    block.insts[inst_index.usize()] <- ShaderIrInst_New(opcode, flags_u64)
    block.insts[inst_index.usize()].parent_block <- block_index
    if (opcode == IR_OPCODE_PHI):
        block.insts[inst_index.usize()].arg_count <- 0
    else:
        block.insts[inst_index.usize()].arg_count <- arg_count
        i: mutable u32 = 0
        while ((i < arg_count) and (i < IR_MAX_ARGS)):
            block.insts[inst_index.usize()].args[i.usize()] <- args[i.usize()]
            i <- (i + 1)
    return inst_index

def ShaderIrProgram_PrependInst(program: mutable ShaderIrProgram&, block_index: u32, insertion_index: u32, opcode: u32, args: ShaderIrValue[6], arg_count: u32, flags_u64: u64) -> u32:
    assert((block_index < program.block_count))
    block: mutable ShaderIrBlock& = program.blocks[block_index.usize()].cast[mutable ShaderIrBlock&]
    return ShaderIrBlock_PrependNewInst(block.cast[mutable ShaderIrBlock&], insertion_index, opcode, args, arg_count, flags_u64)

def ShaderIrProgram_FindInstByHandle(program: ShaderIrProgram&, inst_block: u32, inst_index: u32) -> ShaderIrInst?:
    if (inst_block >= program.block_count):
        return null
    if (inst_index >= program.blocks[inst_block.usize()].inst_count):
        return null
    return program.blocks[inst_block.usize()].insts[inst_index.usize()]

def ShaderIrProgram_FindInstRef(program: mutable ShaderIrProgram&, inst_block: u32, inst_index: u32) -> mutable ShaderIrInst&?:
    if (inst_block >= program.block_count):
        return null
    if (inst_index >= program.blocks[inst_block.usize()].inst_count):
        return null
    return program.blocks[inst_block.usize()].insts[inst_index.usize()].cast[mutable ShaderIrInst&]

def ShaderIrProgram_AddSyntaxNode(program: mutable ShaderIrProgram&, node: ShaderIrAbstractSyntaxNode) -> void:
    assert((program.syntax_count < IR_PROGRAM_MAX_ASL_NODES))
    program.syntax_list[program.syntax_count.usize()] <- node
    program.syntax_count <- (program.syntax_count + 1)

def ShaderIrProgram_Dump(program: ShaderIrProgram) -> static u8&:
    _ = program
    return "ShaderIrProgram"

def ShaderIrProgram_DumpWithType(program: ShaderIrProgram, dump_type: static u8&) -> static u8&:
    _ = program
    _ = dump_type
    return "ShaderIrProgram"

def ShaderIrProgram_DumpProgram(program: ShaderIrProgram, info: ShaderIrProgramInfo, dump_type: static u8&) -> static u8&:
    _ = info
    return ShaderIrProgram_DumpWithType(program, dump_type)

