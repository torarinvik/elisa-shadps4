def ShaderIrOpcode_NameOf(op: u32) -> static u8&:
    if (op == IR_OPCODE_PHI):
        return "Phi"
    if (op == IR_OPCODE_IDENTITY):
        return "Identity"
    if (op == IR_OPCODE_VOID):
        return "Void"
    if (op == IR_OPCODE_CONDITIONREF):
        return "ConditionRef"
    if (op == IR_OPCODE_REFERENCE):
        return "Reference"
    if (op == IR_OPCODE_PHIMOVE):
        return "PhiMove"
    if (op == IR_OPCODE_PROLOGUE):
        return "Prologue"
    if (op == IR_OPCODE_EPILOGUE):
        return "Epilogue"
    if (op == IR_OPCODE_DISCARD):
        return "Discard"
    if (op == IR_OPCODE_DISCARDCOND):
        return "DiscardCond"
    if (op == IR_OPCODE_DEBUGPRINT):
        return "DebugPrint"
    if (op == IR_OPCODE_READCONST):
        return "ReadConst"
    if (op == IR_OPCODE_READCONSTBUFFER):
        return "ReadConstBuffer"
    if (op == IR_OPCODE_BARRIER):
        return "Barrier"
    if (op == IR_OPCODE_WORKGROUPMEMORYBARRIER):
        return "WorkgroupMemoryBarrier"
    if (op == IR_OPCODE_DEVICEMEMORYBARRIER):
        return "DeviceMemoryBarrier"
    if (op == IR_OPCODE_EMITVERTEX):
        return "EmitVertex"
    if (op == IR_OPCODE_EMITPRIMITIVE):
        return "EmitPrimitive"
    if (op == IR_OPCODE_LOADSHAREDU16):
        return "LoadSharedU16"
    if (op == IR_OPCODE_LOADSHAREDU32):
        return "LoadSharedU32"
    if (op == IR_OPCODE_LOADSHAREDU64):
        return "LoadSharedU64"
    if (op == IR_OPCODE_WRITESHAREDU16):
        return "WriteSharedU16"
    if (op == IR_OPCODE_WRITESHAREDU32):
        return "WriteSharedU32"
    if (op == IR_OPCODE_WRITESHAREDU64):
        return "WriteSharedU64"
    if (op == IR_OPCODE_SHAREDATOMICIADD32):
        return "SharedAtomicIAdd32"
    if (op == IR_OPCODE_SHAREDATOMICIADD64):
        return "SharedAtomicIAdd64"
    if (op == IR_OPCODE_SHAREDATOMICISUB32):
        return "SharedAtomicISub32"
    if (op == IR_OPCODE_SHAREDATOMICISUB64):
        return "SharedAtomicISub64"
    if (op == IR_OPCODE_SHAREDATOMICSMIN32):
        return "SharedAtomicSMin32"
    if (op == IR_OPCODE_SHAREDATOMICSMIN64):
        return "SharedAtomicSMin64"
    if (op == IR_OPCODE_SHAREDATOMICUMIN32):
        return "SharedAtomicUMin32"
    if (op == IR_OPCODE_SHAREDATOMICUMIN64):
        return "SharedAtomicUMin64"
    if (op == IR_OPCODE_SHAREDATOMICSMAX32):
        return "SharedAtomicSMax32"
    if (op == IR_OPCODE_SHAREDATOMICSMAX64):
        return "SharedAtomicSMax64"
    if (op == IR_OPCODE_SHAREDATOMICUMAX32):
        return "SharedAtomicUMax32"
    if (op == IR_OPCODE_SHAREDATOMICUMAX64):
        return "SharedAtomicUMax64"
    if (op == IR_OPCODE_SHAREDATOMICINC32):
        return "SharedAtomicInc32"
    if (op == IR_OPCODE_SHAREDATOMICINC64):
        return "SharedAtomicInc64"
    if (op == IR_OPCODE_SHAREDATOMICDEC32):
        return "SharedAtomicDec32"
    if (op == IR_OPCODE_SHAREDATOMICDEC64):
        return "SharedAtomicDec64"
    if (op == IR_OPCODE_SHAREDATOMICAND32):
        return "SharedAtomicAnd32"
    if (op == IR_OPCODE_SHAREDATOMICAND64):
        return "SharedAtomicAnd64"
    if (op == IR_OPCODE_SHAREDATOMICOR32):
        return "SharedAtomicOr32"
    if (op == IR_OPCODE_SHAREDATOMICOR64):
        return "SharedAtomicOr64"
    if (op == IR_OPCODE_SHAREDATOMICXOR32):
        return "SharedAtomicXor32"
    if (op == IR_OPCODE_SHAREDATOMICXOR64):
        return "SharedAtomicXor64"
    if (op == IR_OPCODE_GETUSERDATA):
        return "GetUserData"
    if (op == IR_OPCODE_GETTHREADBITSCALARREG):
        return "GetThreadBitScalarReg"
    if (op == IR_OPCODE_SETTHREADBITSCALARREG):
        return "SetThreadBitScalarReg"
    if (op == IR_OPCODE_GETSCALARREGISTER):
        return "GetScalarRegister"
    if (op == IR_OPCODE_SETSCALARREGISTER):
        return "SetScalarRegister"
    if (op == IR_OPCODE_GETVECTORREGISTER):
        return "GetVectorRegister"
    if (op == IR_OPCODE_SETVECTORREGISTER):
        return "SetVectorRegister"
