def ShaderIrProgram_RecomputeUses(program: mutable ShaderIrProgram&) -> void:
    b: mutable u32 = 0
    while (b < program.block_count):
        i: mutable u32 = 0
        while (i < program.blocks[b.usize()].inst_count):
            program.blocks[b.usize()].insts[i.usize()].use_count <- 0
            program.blocks[b.usize()].insts[i.usize()].uses <- zeroed
            i <- (i + 1)
        b <- (b + 1)
    b <- 0
    while (b < program.block_count):
        i: mutable u32 = 0
        while (i < program.blocks[b.usize()].inst_count):
            inst: ShaderIrInst = program.blocks[b.usize()].insts[i.usize()]
            argc: u32 = ShaderIrInst_NumArgs(inst)
            a: mutable u32 = 0
            while (a < argc):
                arg: ShaderIrValue = ShaderIrInst_Arg(inst, a)
                if (arg.type_bits == IR_TYPE_OPAQUE):
                    if ((arg.inst_block < program.block_count) and (arg.inst_index < program.blocks[arg.inst_block.usize()].inst_count)):
                        target: mutable ShaderIrInst& = program.blocks[arg.inst_block.usize()].insts[arg.inst_index.usize()].cast[mutable ShaderIrInst&]
                        if (target.use_count < 128):
                            idx: u32 = target.use_count
                            target.uses[idx.usize()].user_block <- b
                            target.uses[idx.usize()].user_inst <- i
                            target.uses[idx.usize()].operand <- a
                            target.use_count <- (target.use_count + 1)
                a <- (a + 1)
            i <- (i + 1)
        b <- (b + 1)

def ShaderIrInst_ReplaceUsesWith(program: mutable ShaderIrProgram&, inst_block: u32, inst_index: u32, replacement: ShaderIrValue, preserve: bool) -> void:
    assert((inst_block < program.block_count))
    assert((inst_index < program.blocks[inst_block.usize()].inst_count))
    b: mutable u32 = 0
    while (b < program.block_count):
        i: mutable u32 = 0
        while (i < program.blocks[b.usize()].inst_count):
            inst: mutable ShaderIrInst& = program.blocks[b.usize()].insts[i.usize()].cast[mutable ShaderIrInst&]
            argc: u32 = ShaderIrInst_NumArgs(inst)
            a: mutable u32 = 0
            while (a < argc):
                arg: ShaderIrValue = ShaderIrInst_Arg(inst, a)
                if (((arg.type_bits == IR_TYPE_OPAQUE) and (arg.inst_block == inst_block)) and (arg.inst_index == inst_index)):
                    ShaderIrInst_SetArg(inst.cast[mutable ShaderIrInst&], a, replacement)
                a <- (a + 1)
            i <- (i + 1)
        b <- (b + 1)
    target: mutable ShaderIrInst& = program.blocks[inst_block.usize()].insts[inst_index.usize()].cast[mutable ShaderIrInst&]
    ShaderIrInst_Invalidate(target.cast[mutable ShaderIrInst&])
    if preserve:
        ShaderIrInst_ReplaceOpcode(target.cast[mutable ShaderIrInst&], IR_OPCODE_IDENTITY)
        target.arg_count <- 1
        target.args[0] <- replacement
    ShaderIrProgram_RecomputeUses(program.cast[mutable ShaderIrProgram&])

def ShaderIrInst_ReplaceUsesWithAndRemove(program: mutable ShaderIrProgram&, inst_block: u32, inst_index: u32, replacement: ShaderIrValue) -> void:
    ShaderIrInst_ReplaceUsesWith(program.cast[mutable ShaderIrProgram&], inst_block, inst_index, replacement, false)

def ShaderIrInst_ReplaceUsesWithIdentity(program: mutable ShaderIrProgram&, inst_block: u32, inst_index: u32, replacement: ShaderIrValue) -> void:
    ShaderIrInst_ReplaceUsesWith(program.cast[mutable ShaderIrProgram&], inst_block, inst_index, replacement, true)

struct ShaderIrEmitter:
    block_index: mutable u32
    insertion_index: mutable u32

def ShaderIrEmitter_New(block_index: u32) -> ShaderIrEmitter:
    return ShaderIrEmitter(block_index, 0)

def ShaderIrEmitter_NewAt(block_index: u32, insertion_index: u32) -> ShaderIrEmitter:
    return ShaderIrEmitter(block_index, insertion_index)

def ShaderIrEmitter_Emit(program: mutable ShaderIrProgram&, emitter: mutable ShaderIrEmitter&, opcode: u32, flags_u64: u64, args: ShaderIrValue[6], arg_count: u32) -> ShaderIrValue:
    block_index: u32 = emitter.block_index
    assert((block_index < program.block_count))
    block: mutable ShaderIrBlock& = program.blocks[block_index.usize()].cast[mutable ShaderIrBlock&]
    insert_at: u32 = emitter.insertion_index
    if (insert_at > block.inst_count):
        insert_at <- block.inst_count
    _ = ShaderIrProgram_PrependInst(program.cast[mutable ShaderIrProgram&], block_index, insert_at, opcode, args, arg_count, flags_u64)
    emitter.insertion_index <- (insert_at + 1)
    if (ShaderIrOpcode_TypeOf(opcode) == IR_TYPE_VOID):
        return ShaderIrValue_Empty()
    return ShaderIrValue_FromInst(block_index, insert_at)

def ShaderIrEmitter_EmitNoFlags(program: mutable ShaderIrProgram&, emitter: mutable ShaderIrEmitter&, opcode: u32, args: ShaderIrValue[6], arg_count: u32) -> ShaderIrValue:
    return ShaderIrEmitter_Emit(program.cast[mutable ShaderIrProgram&], emitter.cast[mutable ShaderIrEmitter&], opcode, 0, args, arg_count)

def ShaderIrEmitter_Imm1(value: bool) -> ShaderIrValue:
    return ShaderIrValue_FromU1(value)

def ShaderIrEmitter_Imm8(value: u8) -> ShaderIrValue:
    return ShaderIrValue_FromU8(value)

def ShaderIrEmitter_Imm16(value: u16) -> ShaderIrValue:
    return ShaderIrValue_FromU16(value)

def ShaderIrEmitter_Imm32FromU32(value: u32) -> ShaderIrValue:
    return ShaderIrValue_FromU32(value)

def ShaderIrEmitter_Imm32FromI32(value: i32) -> ShaderIrValue:
    return ShaderIrValue_FromU32(value.u32())

def ShaderIrEmitter_Imm32FromF32(value: f32) -> ShaderIrValue:
    return ShaderIrValue_FromF32(value)

def ShaderIrEmitter_Imm64FromU64(value: u64) -> ShaderIrValue:
    return ShaderIrValue_FromU64(value)

def ShaderIrEmitter_Imm64FromI64(value: i64) -> ShaderIrValue:
    return ShaderIrValue_FromU64(value.u64())

def ShaderIrEmitter_Imm64FromF64(value: f64) -> ShaderIrValue:
    return ShaderIrValue_FromF64(value)

def ShaderIrEmitter_Imm32(value: ShaderIrValue) -> ShaderIrValue:
    if (value.type_bits == IR_TYPE_U32):
        return value
    if (value.type_bits == IR_TYPE_U1):
        if value.imm_u1:
            return ShaderIrValue_FromU32(1)
        return ShaderIrValue_FromU32(0)
    if (value.type_bits == IR_TYPE_F32):
        return ShaderIrValue_FromF32(value.imm_f32)
    return ShaderIrValue_FromU32(0)

def ShaderIrEmitter_Imm64(value: ShaderIrValue) -> ShaderIrValue:
    if (value.type_bits == IR_TYPE_U64):
        return value
    if (value.type_bits == IR_TYPE_F64):
        return ShaderIrValue_FromF64(value.imm_f64)
    return ShaderIrValue_FromU64(0)

const IR_CONDITION_FALSE: u32 = 0

const IR_CONDITION_TRUE: u32 = 1

const IR_CONDITION_SCC0: u32 = 2

const IR_CONDITION_SCC1: u32 = 3

const IR_CONDITION_VCCZ: u32 = 4

const IR_CONDITION_VCCNZ: u32 = 5

const IR_CONDITION_EXECZ: u32 = 6

const IR_CONDITION_EXECNZ: u32 = 7

const IR_NUMFMT_UNORM: u32 = 1

const IR_NUMFMT_SNORM: u32 = 2

const IR_NUMFMT_UINT: u32 = 4

const IR_NUMFMT_SINT: u32 = 5

const IR_NUMFMT_FLOAT: u32 = 9

def ShaderIrEmitter_ValueToBool(value: ShaderIrValue) -> bool:
    if (value.type_bits == IR_TYPE_U1):
        return value.imm_u1
    if (value.type_bits == IR_TYPE_U8):
        return (value.imm_u8 != 0)
    if (value.type_bits == IR_TYPE_U16):
        return (value.imm_u16 != 0)
    if (value.type_bits == IR_TYPE_U32):
        return (value.imm_u32 != 0)
    if (value.type_bits == IR_TYPE_U64):
        return (value.imm_u64 != 0)
    return false

def ShaderIrEmitter_ValueToU32(value: ShaderIrValue) -> u32:
    if (value.type_bits == IR_TYPE_U1):
        if value.imm_u1:
            return 1
        return 0
    if (value.type_bits == IR_TYPE_U8):
        return value.imm_u8.u32()
    if (value.type_bits == IR_TYPE_U16):
        return value.imm_u16.u32()
    if (value.type_bits == IR_TYPE_U32):
        return value.imm_u32
    if (value.type_bits == IR_TYPE_U64):
        return value.imm_u64.u32()
    return 0

def ShaderIrEmitter_ValueToU64(value: ShaderIrValue) -> u64:
    if (value.type_bits == IR_TYPE_U1):
        if value.imm_u1:
            return 1
        return 0
    if (value.type_bits == IR_TYPE_U8):
        return value.imm_u8.u64()
    if (value.type_bits == IR_TYPE_U16):
        return value.imm_u16.u64()
    if (value.type_bits == IR_TYPE_U32):
        return value.imm_u32.u64()
    if (value.type_bits == IR_TYPE_U64):
        return value.imm_u64
    return 0

