def ShaderIrEmitter_LoadShared(program: mutable ShaderIrProgram&, emitter: mutable ShaderIrEmitter&, bit_size: ShaderIrValue, is_signed: ShaderIrValue, offset: ShaderIrValue, is_gds: ShaderIrValue) -> ShaderIrValue:
    flags_u64: u64 = ShaderIrEmitter_ValueToU64(is_gds)
    bits: u32 = ShaderIrEmitter_ValueToU32(bit_size)
    args: mutable ShaderIrValue[6] = zeroed
    args[0] <- offset
    if (bits == 16):
        return ShaderIrEmitter_Emit(program.cast[mutable ShaderIrProgram&], emitter.cast[mutable ShaderIrEmitter&], IR_OPCODE_LOADSHAREDU16, flags_u64, args, 1)
    if (bits == 32):
        return ShaderIrEmitter_Emit(program.cast[mutable ShaderIrProgram&], emitter.cast[mutable ShaderIrEmitter&], IR_OPCODE_LOADSHAREDU32, flags_u64, args, 1)
    if (bits == 64):
        return ShaderIrEmitter_Emit(program.cast[mutable ShaderIrProgram&], emitter.cast[mutable ShaderIrEmitter&], IR_OPCODE_LOADSHAREDU64, flags_u64, args, 1)
    _ = is_signed
    return ShaderIrValue_Empty()

def ShaderIrEmitter_WriteShared(program: mutable ShaderIrProgram&, emitter: mutable ShaderIrEmitter&, bit_size: ShaderIrValue, value: ShaderIrValue, offset: ShaderIrValue, is_gds: ShaderIrValue) -> ShaderIrValue:
    flags_u64: u64 = ShaderIrEmitter_ValueToU64(is_gds)
    bits: u32 = ShaderIrEmitter_ValueToU32(bit_size)
    args: mutable ShaderIrValue[6] = zeroed
    args[0] <- offset
    args[1] <- value
    if (bits == 16):
        return ShaderIrEmitter_Emit(program.cast[mutable ShaderIrProgram&], emitter.cast[mutable ShaderIrEmitter&], IR_OPCODE_WRITESHAREDU16, flags_u64, args, 2)
    if (bits == 32):
        return ShaderIrEmitter_Emit(program.cast[mutable ShaderIrProgram&], emitter.cast[mutable ShaderIrEmitter&], IR_OPCODE_WRITESHAREDU32, flags_u64, args, 2)
    if (bits == 64):
        return ShaderIrEmitter_Emit(program.cast[mutable ShaderIrProgram&], emitter.cast[mutable ShaderIrEmitter&], IR_OPCODE_WRITESHAREDU64, flags_u64, args, 2)
    return ShaderIrValue_Empty()

def ShaderIrEmitter_SharedAtomicIAdd(program: mutable ShaderIrProgram&, emitter: mutable ShaderIrEmitter&, address: ShaderIrValue, data: ShaderIrValue, is_gds: ShaderIrValue) -> ShaderIrValue:
    flags_u64: u64 = ShaderIrEmitter_ValueToU64(is_gds)
    args: mutable ShaderIrValue[6] = zeroed
    args[0] <- address
    args[1] <- data
    if (data.type_bits == IR_TYPE_U32):
        return ShaderIrEmitter_Emit(program.cast[mutable ShaderIrProgram&], emitter.cast[mutable ShaderIrEmitter&], IR_OPCODE_SHAREDATOMICIADD32, flags_u64, args, 2)
    if (data.type_bits == IR_TYPE_U64):
        return ShaderIrEmitter_Emit(program.cast[mutable ShaderIrProgram&], emitter.cast[mutable ShaderIrEmitter&], IR_OPCODE_SHAREDATOMICIADD64, flags_u64, args, 2)
    return ShaderIrValue_Empty()

def ShaderIrEmitter_SharedAtomicIMin(program: mutable ShaderIrProgram&, emitter: mutable ShaderIrEmitter&, address: ShaderIrValue, data: ShaderIrValue, is_signed: ShaderIrValue, is_gds: ShaderIrValue) -> ShaderIrValue:
    flags_u64: u64 = ShaderIrEmitter_ValueToU64(is_gds)
    signed_op: bool = ShaderIrEmitter_ValueToBool(is_signed)
    args: mutable ShaderIrValue[6] = zeroed
    args[0] <- address
    args[1] <- data
    if (data.type_bits == IR_TYPE_U32):
        if signed_op:
            return ShaderIrEmitter_Emit(program.cast[mutable ShaderIrProgram&], emitter.cast[mutable ShaderIrEmitter&], IR_OPCODE_SHAREDATOMICSMIN32, flags_u64, args, 2)
        return ShaderIrEmitter_Emit(program.cast[mutable ShaderIrProgram&], emitter.cast[mutable ShaderIrEmitter&], IR_OPCODE_SHAREDATOMICUMIN32, flags_u64, args, 2)
