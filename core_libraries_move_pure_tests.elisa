include "../compiler/runtime/elisacore_std/elisacore_runtime.elisa"
include "./core/libraries/move/move.elisa"

@test
def move_library_init_open_close_contracts() -> void:
    can Abort.Panic:
        info: OrbisMoveDeviceInfo = zeroed
        state: OrbisMoveData = zeroed
        count: mutable s32 = 0
        ext_data: mutable void&? = null

        assert sceMoveGetDeviceInfo(0, info.ref[mutable OrbisMoveDeviceInfo&]) == ORBIS_MOVE_ERROR_NOT_INIT
        assert sceMoveReadStateLatest(0, state.ref[mutable OrbisMoveData&]) == ORBIS_MOVE_ERROR_NOT_INIT
        assert sceMoveReadStateRecent(0, 0, state.ref[mutable OrbisMoveData&], count.ref[mutable s32&]) == ORBIS_MOVE_ERROR_NOT_INIT
        assert sceMoveGetExtensionPortInfo(0, ext_data) == ORBIS_MOVE_ERROR_NOT_INIT
        assert sceMoveSetVibration(0, 0u8) == ORBIS_MOVE_ERROR_NOT_INIT
        assert sceMoveSetLightSphere(0, 0u8, 0u8, 0u8) == ORBIS_MOVE_ERROR_NOT_INIT
        assert sceMoveClose(0) == ORBIS_MOVE_ERROR_NOT_INIT

        assert sceMoveInit() == ORBIS_OK
        assert sceMoveInit() == ORBIS_MOVE_ERROR_ALREADY_INIT

        handle: mutable s32 = sceMoveOpen(1, 0, 0)
        assert handle != 0x30b0000
        assert sceMoveOpen(1, 0, 0) > handle

        assert sceMoveGetDeviceInfo(handle, null) == ORBIS_MOVE_ERROR_INVALID_ARG
        assert sceMoveGetDeviceInfo(handle, info.ref[mutable OrbisMoveDeviceInfo&]) == ORBIS_MOVE_ERROR_NO_CONTROLLER_CONNECTED
        assert sceMoveReadStateLatest(handle, null) == ORBIS_MOVE_ERROR_INVALID_ARG
        assert sceMoveReadStateLatest(handle, state.ref[mutable OrbisMoveData&]) == ORBIS_MOVE_ERROR_NO_CONTROLLER_CONNECTED
        assert sceMoveReadStateRecent(handle, -1, state.ref[mutable OrbisMoveData&], count.ref[mutable s32&]) == ORBIS_MOVE_ERROR_INVALID_ARG
        assert sceMoveReadStateRecent(handle, 0, null, count.ref[mutable s32&]) == ORBIS_MOVE_ERROR_INVALID_ARG
        assert sceMoveReadStateRecent(handle, 0, state.ref[mutable OrbisMoveData&], null) == ORBIS_MOVE_ERROR_INVALID_ARG
        assert sceMoveReadStateRecent(handle, 0, state.ref[mutable OrbisMoveData&], count.ref[mutable s32&]) == ORBIS_MOVE_ERROR_NO_CONTROLLER_CONNECTED

        assert sceMoveGetExtensionPortInfo(handle, null) == ORBIS_MOVE_ERROR_INVALID_ARG
        assert sceMoveGetExtensionPortInfo(handle, ext_data) == ORBIS_MOVE_ERROR_NO_CONTROLLER_CONNECTED
        assert sceMoveSetVibration(handle, 0u8) == ORBIS_MOVE_ERROR_NO_CONTROLLER_CONNECTED
        assert sceMoveSetLightSphere(handle, 1u8, 2u8, 3u8) == ORBIS_MOVE_ERROR_NO_CONTROLLER_CONNECTED
        assert sceMoveResetLightSphere(handle) == ORBIS_OK

        assert sceMoveClose(handle) == ORBIS_OK
        assert sceMoveTerm() == ORBIS_OK
        assert sceMoveTerm() == ORBIS_MOVE_ERROR_NOT_INIT
