include "../compiler/runtime/elisacore_std/elisacore_runtime.elisa"
include "./core/libraries/random/random.elisa"

@test
def random_get_random_number_contracts() -> void:
    can Abort.Panic:
        buf: mutable u8[64] = zeroed
        before: mutable u8[64] = zeroed
        i: mutable usize = 0
        while i < 64:
            before[i] <- buf[i]
            i <- i + 1

        assert sceRandomGetRandomNumber(buf[0].ref[mutable u8&], 0) == ORBIS_OK
        assert sceRandomGetRandomNumber(buf[0].ref[mutable u8&], 64) == ORBIS_OK
        assert sceRandomGetRandomNumber(buf[0].ref[mutable u8&], 65) == SCE_RANDOM_ERROR_INVALID

        # C++ parity: null buffer with zero size succeeds (loop is skipped).
        assert sceRandomGetRandomNumber(null, 0) == ORBIS_OK
