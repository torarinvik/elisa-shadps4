include "../compiler/runtime/elisacore_std/elisacore_runtime.elisa"
include "./core/libraries/system/commondialog.elisa"
include "./core/libraries/save_data/dialog/savedatadialog.elisa"

def savedata_dialog_reset_globals() -> void:
    g_isInitialized <- false
    g_isUsed <- false
    g_savedata_dialog_status <- ORBIS_COMMON_DIALOG_STATUS_NONE
    g_savedata_dialog_state <- SaveDialogState_new()
    g_savedata_dialog_result <- SaveDialogResult_new()
    g_savedata_dialog_ui <- SaveDialogUi_new()

@test
def savedata_dialog_state_machine_contracts() -> void:
    can Abort.Panic:
        savedata_dialog_reset_globals()

        assert sceSaveDataDialogInitialize() == ORBIS_COMMON_DIALOG_ERROR_NOT_SYSTEM_INITIALIZED.u32()
        assert sceSaveDataDialogTerminate() == ORBIS_COMMON_DIALOG_ERROR_NOT_INITIALIZED.u32()
        assert sceSaveDataDialogOpen(null) == ORBIS_COMMON_DIALOG_ERROR_INVALID_STATE.u32()

        assert sceCommonDialogInitialize() == ORBIS_OK.u32()
        assert sceSaveDataDialogInitialize() == ORBIS_OK.u32()
        assert sceSaveDataDialogGetStatus() == ORBIS_COMMON_DIALOG_STATUS_INITIALIZED
        assert sceSaveDataDialogOpen(null) == ORBIS_COMMON_DIALOG_ERROR_ARG_NULL.u32()

        assert sceSaveDataDialogProgressBarSetValue(ORBIS_SAVE_DATA_DIALOG_PROGRESS_BAR_TARGET_DEFAULT, 10) == ORBIS_COMMON_DIALOG_ERROR_NOT_RUNNING.u32()

        msg_text: mutable u8[3] = zeroed
        msg_text[0] <- 'o'.u8()
        msg_text[1] <- 'k'.u8()
        user_msg_param: mutable SaveDataDialogUserMessageParam = zeroed
        user_msg_param.buttonType <- ORBIS_SAVE_DATA_DIALOG_BUTTON_TYPE_OK
        user_msg_param.msgType <- ORBIS_SAVE_DATA_DIALOG_USER_MSG_TYPE_NORMAL
        user_msg_param.msg <- msg_text[0].ref[mutable u8&]

        items: mutable SaveDataDialogItems = zeroed
        items.userId <- 1
        items.focusPos <- ORBIS_SAVE_DATA_DIALOG_FOCUS_POS_LIST_HEAD
        items.itemStyle <- ORBIS_SAVE_DATA_DIALOG_ITEM_STYLE_TITLE_DATASIZE_SUBTITLE

        open_param: mutable OrbisSaveDataDialogParam = zeroed
        open_param.baseParam.size <- size_of(BaseParam)
        open_param.size <- size_of(OrbisSaveDataDialogParam).s32()
        open_param.mode <- ORBIS_SAVE_DATA_DIALOG_MODE_USER_MSG
        open_param.dispType <- ORBIS_SAVE_DATA_DIALOG_TYPE_SAVE
        open_param.items <- items.ref[mutable SaveDataDialogItems&]
        open_param.userMsgParam <- user_msg_param.ref[mutable SaveDataDialogUserMessageParam&]

        assert sceSaveDataDialogOpen(open_param.ref[mutable OrbisSaveDataDialogParam&]) == ORBIS_OK.u32()
        assert sceSaveDataDialogGetStatus() == ORBIS_COMMON_DIALOG_STATUS_RUNNING
        assert sceSaveDataDialogUpdateStatus() == ORBIS_COMMON_DIALOG_STATUS_RUNNING
        assert sceSaveDataDialogProgressBarInc(ORBIS_SAVE_DATA_DIALOG_PROGRESS_BAR_TARGET_DEFAULT, 5) == ORBIS_COMMON_DIALOG_ERROR_NOT_SUPPORTED.u32()
        assert sceSaveDataDialogClose() == ORBIS_OK.u32()
        assert sceSaveDataDialogGetStatus() == ORBIS_COMMON_DIALOG_STATUS_FINISHED
        assert sceSaveDataDialogUpdateStatus() == ORBIS_COMMON_DIALOG_STATUS_FINISHED

        assert sceSaveDataDialogGetResult(null) == ORBIS_COMMON_DIALOG_ERROR_ARG_NULL.u32()
        result_out: mutable OrbisSaveDataDialogResult = zeroed
        assert sceSaveDataDialogGetResult(result_out.ref[mutable OrbisSaveDataDialogResult&]) == ORBIS_OK.u32()
        assert result_out.mode == ORBIS_SAVE_DATA_DIALOG_MODE_USER_MSG
        assert result_out.result == ORBIS_COMMON_DIALOG_RESULT_OK
        assert result_out.buttonId == ORBIS_SAVE_DATA_DIALOG_BUTTON_ID_INVALID

        assert sceSaveDataDialogTerminate() == ORBIS_OK.u32()
        assert sceSaveDataDialogGetStatus() == ORBIS_COMMON_DIALOG_STATUS_NONE
        assert g_isUsed == false
        assert sceSaveDataDialogTerminate() == ORBIS_COMMON_DIALOG_ERROR_NOT_INITIALIZED.u32()

@test
def savedata_dialog_state_builders_match_cpp_contracts() -> void:
    can Abort.Panic:
        state: mutable SaveDialogState = SaveDialogState_new()
        state.dialog_type <- ORBIS_SAVE_DATA_DIALOG_TYPE_SAVE
        state.has_enable_back <- true
        state.enable_back <- false

        sys_param: mutable SaveDataDialogSystemMessageParam = zeroed
        param: mutable OrbisSaveDataDialogParam = zeroed
        param.sysMsgParam <- sys_param.ref[mutable SaveDataDialogSystemMessageParam&]

        sys_param.msgType <- ORBIS_SAVE_DATA_DIALOG_SYSTEM_MSG_PROGRESS
        progress_state: SaveDialogSystemState = SaveDialogState_BuildSystemState(state.ref[SaveDialogState&], param.ref[OrbisSaveDataDialogParam&])
        assert progress_state.hide_ok == true
        assert progress_state.show_cancel == false
        assert streq(progress_state.msg, "Saving...") == 1

        sys_param.msgType <- ORBIS_SAVE_DATA_DIALOG_SYSTEM_MSG_NOSPACE
        sys_param.value <- 2
        no_space_state: SaveDialogSystemState = SaveDialogState_BuildSystemState(state.ref[SaveDialogState&], param.ref[OrbisSaveDataDialogParam&])
        assert no_space_state.return_cancel == true
        assert streq(no_space_state.msg, "There is not enough space to save the data. To continue 64.00 KB free space is required.") == 1

        sys_param.msgType <- 99
        unknown_state: SaveDialogSystemState = SaveDialogState_BuildSystemState(state.ref[SaveDialogState&], param.ref[OrbisSaveDataDialogParam&])
        assert streq(unknown_state.msg, "Unknown message type: 99") == 1

        err_param: mutable SaveDataDialogErrorCodeParam = zeroed
        param.errorCodeParam <- err_param.ref[mutable SaveDataDialogErrorCodeParam&]
        err_param.errorCode <- ORBIS_SAVEDATA_ERR_NOT_FOUND
        err_not_found: SaveDialogErrorCodeState = SaveDialogState_BuildErrorCodeState(param.ref[OrbisSaveDataDialogParam&])
        assert streq(err_not_found.error_msg, "There is not saved data.") == 1

@test
def savedata_dialog_result_copy_preserves_maintitle_presence_rule() -> void:
    can Abort.Panic:
        sfo: mutable PsfFile = PsfFile_empty()
        Psf_AddString(sfo.ref[mutable PsfFile&], "MAINTITLE", "", true)
        Psf_AddString(sfo.ref[mutable PsfFile&], "SUBTITLE", "S", true)
        Psf_AddString(sfo.ref[mutable PsfFile&], "DETAIL", "D", true)

        result_src: mutable SaveDialogResult = SaveDialogResult_new()
        result_src.mode <- ORBIS_SAVE_DATA_DIALOG_MODE_LIST
        result_src.result <- ORBIS_COMMON_DIALOG_RESULT_OK
        result_src.button_id <- ORBIS_SAVE_DATA_DIALOG_BUTTON_ID_OK
        result_src.param <- sfo

        param_out: mutable OrbisSaveDataParam = zeroed
        result_out: mutable OrbisSaveDataDialogResult = zeroed
        result_out.param <- param_out.ref[mutable OrbisSaveDataParam&]

        SaveDialogResult_CopyTo(result_src.ref[SaveDialogResult&], result_out.ref[mutable OrbisSaveDataDialogResult&])
        assert param_out.title[0] == 0
        assert param_out.subTitle[0] == 'S'.u8()
        assert param_out.detail[0] == 'D'.u8()
