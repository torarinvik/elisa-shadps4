include "../compiler/runtime/elisacore_std/elisacore_runtime.elisa"
include "./core/libraries/playgo/playgo.elisa"
include "./core/libraries/playgo/playgo_dialog.elisa"

@test
def playgo_init_open_close_contracts() -> void:
    can Abort.Panic:
        handle: mutable OrbisPlayGoHandle = 0u32
        entries: mutable u32 = 0u32
        eta: mutable OrbisPlayGoEta = -1
        speed: mutable OrbisPlayGoInstallSpeed = -1
        lang: mutable OrbisPlayGoLanguageMask = 0u64
        progress: mutable OrbisPlayGoProgress = zeroed
        chunk_id: mutable OrbisPlayGoChunkId = 0u16
        locus: mutable OrbisPlayGoLocus = ORBIS_PLAYGO_LOCUS_NOT_DOWNLOADED
        todo: mutable OrbisPlayGoToDo = zeroed

        assert scePlayGoOpen(handle.ref[mutable OrbisPlayGoHandle&], null) == ORBIS_PLAYGO_ERROR_NOT_INITIALIZED
        assert scePlayGoClose(1u32) == ORBIS_PLAYGO_ERROR_NOT_INITIALIZED
        assert scePlayGoTerminate() == ORBIS_PLAYGO_ERROR_NOT_INITIALIZED

        bad_init: mutable OrbisPlayGoInitParams = zeroed
        assert scePlayGoInitialize(bad_init.ref[mutable OrbisPlayGoInitParams&]) == ORBIS_PLAYGO_ERROR_BAD_POINTER
        bad_init.bufAddr <- 1u64.cast[void&]
        bad_init.bufSize <- 0x1000u32
        assert scePlayGoInitialize(bad_init.ref[mutable OrbisPlayGoInitParams&]) == ORBIS_PLAYGO_ERROR_BAD_SIZE

        init: mutable OrbisPlayGoInitParams = zeroed
        init.bufAddr <- 1u64.cast[void&]
        init.bufSize <- 0x200000u32
        assert scePlayGoInitialize(init.ref[mutable OrbisPlayGoInitParams&]) == 0
        assert scePlayGoInitialize(init.ref[mutable OrbisPlayGoInitParams&]) == ORBIS_PLAYGO_ERROR_ALREADY_INITIALIZED

        assert scePlayGoOpen(null, null) == ORBIS_PLAYGO_ERROR_BAD_POINTER
        assert scePlayGoOpen(handle.ref[mutable OrbisPlayGoHandle&], 1u64.cast[void&]) == ORBIS_PLAYGO_ERROR_INVALID_ARGUMENT
        assert scePlayGoOpen(handle.ref[mutable OrbisPlayGoHandle&], null) == 0
        assert handle == 1u32

        assert scePlayGoGetChunkId(1u32, null, 0u32, entries.ref[mutable u32&]) == 0
        assert entries == 0u32
        assert scePlayGoGetChunkId(1u32, chunk_id.ref[mutable OrbisPlayGoChunkId&], 0u32, entries.ref[mutable u32&]) == ORBIS_PLAYGO_ERROR_BAD_SIZE
        assert scePlayGoGetEta(1u32, chunk_id.ref[OrbisPlayGoChunkId&], 1u32, eta.ref[mutable OrbisPlayGoEta&]) == 0
        assert eta == 0
        assert scePlayGoGetInstallSpeed(1u32, speed.ref[mutable OrbisPlayGoInstallSpeed&]) == 0
        assert speed == ORBIS_PLAYGO_INSTALL_SPEED_TRICKLE
        assert scePlayGoSetInstallSpeed(1u32, ORBIS_PLAYGO_INSTALL_SPEED_FULL) == 0
        assert scePlayGoGetInstallSpeed(1u32, speed.ref[mutable OrbisPlayGoInstallSpeed&]) == 0
        assert speed == ORBIS_PLAYGO_INSTALL_SPEED_FULL
        assert scePlayGoGetLanguageMask(1u32, lang.ref[mutable OrbisPlayGoLanguageMask&]) == 0
        assert scePlayGoSetLanguageMask(1u32, 0xFFu64) == 0
        assert scePlayGoGetLanguageMask(1u32, lang.ref[mutable OrbisPlayGoLanguageMask&]) == 0
        assert lang == 0xFFu64
        assert scePlayGoGetLocus(1u32, chunk_id.ref[OrbisPlayGoChunkId&], 1u32, locus.ref[mutable OrbisPlayGoLocus&]) == ORBIS_PLAYGO_ERROR_BAD_CHUNK_ID
        assert scePlayGoGetProgress(1u32, chunk_id.ref[OrbisPlayGoChunkId&], 1u32, progress.ref[mutable OrbisPlayGoProgress&]) == ORBIS_PLAYGO_ERROR_BAD_CHUNK_ID
        assert scePlayGoGetToDoList(1u32, todo.ref[mutable OrbisPlayGoToDo&], 1u32, entries.ref[mutable u32&]) == 0
        assert entries == 0u32

        assert scePlayGoClose(1u32) == 0
        assert scePlayGoTerminate() == 0

@test
def playgo_dialog_contracts() -> void:
    can Abort.Panic:
        result: mutable OrbisPlayGoDialogResult = zeroed
        assert scePlayGoDialogInitialize() == 0
        assert scePlayGoDialogGetStatus() == 0u32
        assert scePlayGoDialogOpen(null) == 0x80B8000D
        assert scePlayGoDialogGetResult(null) == 0x80B8000D
        assert scePlayGoDialogGetResult(result.ref[mutable OrbisPlayGoDialogResult&]) == 0
        assert result.result == 3u32
        assert scePlayGoDialogClose() == 0
        assert scePlayGoDialogUpdateStatus() == 0u32
        assert scePlayGoDialogTerminate() == 0
