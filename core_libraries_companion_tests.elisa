include "../compiler/runtime/elisacore_std/elisacore_runtime.elisa"
include "./core/libraries/companion/companion_error.elisa"
include "./core/libraries/companion/companion_util.elisa"
include "./core/libraries/companion/companion_httpd.elisa"

def write_i32_le(buf: mutable u8&, off: usize, value: u32):
    buf[off + 0] <- (value & 0xff).u8()
    buf[off + 1] <- ((value >> 8) & 0xff).u8()
    buf[off + 2] <- ((value >> 16) & 0xff).u8()
    buf[off + 3] <- ((value >> 24) & 0xff).u8()

@test
def companion_util_get_event_argument_and_flag_behavior() -> void:
    out_event: mutable sceCompanionUtilEvent = zeroed
    ctx: mutable sceCompanionUtilContext = zeroed

    assert getEvent(ctx.ref[mutable sceCompanionUtilContext&], null, 0) == ORBIS_COMPANION_UTIL_INVALID_ARGUMENT
    assert getEvent(null, out_event.ref[mutable sceCompanionUtilEvent&], 0) == ORBIS_COMPANION_UTIL_INVALID_POINTER
    assert getEvent(ctx.ref[mutable sceCompanionUtilContext&], out_event.ref[mutable sceCompanionUtilEvent&], 0) == ORBIS_COMPANION_UTIL_NO_EVENT

    write_i32_le(ctx.blob[0].ref[mutable u8&], 0x178, 1)
    assert getEvent(ctx.ref[mutable sceCompanionUtilContext&], out_event.ref[mutable sceCompanionUtilEvent&], 0) == ORBIS_COMPANION_UTIL_OK

@test
def companion_util_stub_entrypoints_match_cpp_stub_returns() -> void:
    assert sceCompanionUtilGetEvent(null) == ORBIS_COMPANION_UTIL_NO_EVENT.int()
    assert sceCompanionUtilGetRemoteOskEvent() == 0
    assert sceCompanionUtilInitialize() == 0
    assert sceCompanionUtilOptParamInitialize() == 0
    assert sceCompanionUtilTerminate() == 0

@test
def companion_httpd_get_event_and_stub_returns() -> void:
    event: mutable OrbisCompanionHttpdEvent = zeroed
    assert sceCompanionHttpdGetEvent(event.ref[mutable OrbisCompanionHttpdEvent&]) == ORBIS_COMPANION_HTTPD_ERROR_NO_EVENT
    assert event.event == ORBIS_COMPANION_HTTPD_EVENT_DISCONNECT

    response: mutable OrbisCompanionHttpdResponse = zeroed
    assert sceCompanionHttpdAddHeader(null, null, response.ref[mutable OrbisCompanionHttpdResponse&]) == 0
    assert sceCompanionHttpdSetBody(null, 0, response.ref[mutable OrbisCompanionHttpdResponse&]) == 0
    assert sceCompanionHttpdSetStatus(200, response.ref[mutable OrbisCompanionHttpdResponse&]) == 0
    assert sceCompanionHttpdInitialize() == 0
    assert sceCompanionHttpdInitialize2() == 0
    assert sceCompanionHttpdOptParamInitialize() == 0
    assert sceCompanionHttpdStart() == 0
    assert sceCompanionHttpdStop() == 0
    assert sceCompanionHttpdTerminate() == 0
