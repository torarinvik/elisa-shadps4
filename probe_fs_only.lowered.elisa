    return ("input.toml" if (game_id == "") else game_id)

struct StopState:
    stop_requested: mutable bool

struct stop_token:
    state: mutable heap StopState&?

struct stop_source:
    state: mutable heap StopState&?

struct nostopstate_t:
    unused: mutable u8

struct jthread:
    handle: mutable void&?
    source: mutable stop_source

extern stop_state_alloc() -> mutable heap StopState&

extern jthread_start(entry: void&, arg: void&?) -> void&?

extern jthread_join(handle: void&) -> void

def stop_source_new() -> stop_source:
    out: mutable stop_source = zeroed
    out.state <- stop_state_alloc()
    return out

def stop_source_get_token(self: stop_source&) -> stop_token:
    out: mutable stop_token = zeroed
    out.state <- self.state
    return out

def stop_source_request_stop(self: mutable stop_source&) -> bool:
    if (self.state == null):
        return false
    state: mutable heap StopState& = self.state
    state.stop_requested <- true
    return true

def stop_token_stop_requested(self: stop_token&) -> bool:
    if (self.state == null):
        return false
    state: mutable heap StopState& = self.state
    return state.stop_requested

def jthread_new(entry: void&, arg: void&?) -> jthread:
    source: stop_source = stop_source_new()
    out: mutable jthread = zeroed
    out.handle <- jthread_start(entry, arg)
    out.source <- source
    return out

def jthread_join(self: mutable jthread&) -> void:
    if (self.handle != null):
        jthread_join(self.handle.cast[void&])
        self.handle <- null

def CondvarWait[Condvar, Lock, Pred](cv: mutable Condvar&, lk: mutable Lock&, token: stop_token, pred: Pred) -> void:
    return

def StoppableTimedWait(token: stop_token, rel_time_ns: i64) -> bool:
    return (not stop_token_stop_requested(token))

struct U128Product:
    low: mutable u64
    high: mutable u64

struct Div128Result:
    quotient: mutable u64
    remainder: mutable u64

def MultiplyAndDivide64(a: u64, b: u64, d: u64) -> u64:
    diva: u64 = (a / d)
    moda: u64 = (a % d)
    divb: u64 = (b / d)
    modb: u64 = (b % d)
    return (((diva * b) + (moda * divb)) + ((moda * modb) / d))

def Multiply64Into128(a: u64, b: u64) -> U128Product:
    return U128Product((a * b), MultiplyHigh(a, b))

def GetFixedPoint64Factor(numerator: u64, divisor: u64) -> u64:
    return MultiplyAndDivide64(0xffffffffffffffff, numerator, divisor)

def MultiplyHigh(a: u64, b: u64) -> u64:
    a_lo: u64 = a.u32().u64()
    a_hi: u64 = (a >> 32)
    b_lo: u64 = b.u32().u64()
    b_hi: u64 = (b >> 32)
    a_x_b_hi: u64 = (a_hi * b_hi)
    a_x_b_mid: u64 = (a_hi * b_lo)
    b_x_a_mid: u64 = (b_hi * a_lo)
    a_x_b_lo: u64 = (a_lo * b_lo)
    carry_bit: u64 = ((((a_x_b_mid.u32().u64() + b_x_a_mid.u32().u64()) + ((a_x_b_lo >> 32)))) >> 32)
    return (((a_x_b_hi + ((a_x_b_mid >> 32))) + ((b_x_a_mid >> 32))) + carry_bit)

def Divide128On32(dividend: U128Product, divisor: u32) -> Div128Result:
    divisor64: u64 = divisor.u64()
    remainder: mutable u64 = (dividend.low % divisor64)
    accum: mutable u64 = (dividend.low / divisor64)
    if (dividend.high == 0):
        return Div128Result(accum, remainder)
    first_segment: u64 = (((dividend.high % divisor64)) << 32)
    accum <- (accum + ((((first_segment / divisor64)) << 32)))
    second_segment: u64 = (((first_segment % divisor64)) << 32)
    accum <- (accum + ((second_segment / divisor64)))
    remainder <- (remainder + ((second_segment % divisor64)))
    if (remainder >= divisor64):
        accum <- (accum + 1)
        remainder <- (remainder - divisor64)
    return Div128Result(accum, remainder)

struct AtomicFlag:
    value: mutable bool

extern atomic_flag_test_and_set(flag: mutable AtomicFlag&, order: MemoryOrder) -> bool

extern atomic_flag_clear(flag: mutable AtomicFlag&, order: MemoryOrder) -> void

@intrinsic(llvm.x86.sse2.pause)
extern x86_mm_pause() -> void

extern arm64_msvc_yield() -> void

extern arm64_asm_yield() -> void

struct SpinLock:
    lck: mutable AtomicFlag

def SpinLock_new() -> SpinLock:
    return SpinLock(AtomicFlag(false))

def ThreadPause() -> void:
    static if ARCH_X86_64:
        x86_mm_pause()
    static elif (ARCH_ARM64 and COMPILER_MSVC):
        arm64_msvc_yield()
    static elif ARCH_ARM64:
        arm64_asm_yield()
    static else:
        pass

def SpinLock_lock(self: mutable SpinLock&) -> void:
    while atomic_flag_test_and_set(self.lck.ref[mutable AtomicFlag&], MemoryOrder.Acquire):
        ThreadPause()

def SpinLock_unlock(self: mutable SpinLock&) -> void:
    atomic_flag_clear(self.lck.ref[mutable AtomicFlag&], MemoryOrder.Release)

def SpinLock_try_lock(self: mutable SpinLock&) -> bool:
    if atomic_flag_test_and_set(self.lck.ref[mutable AtomicFlag&], MemoryOrder.Acquire):
        return false
    return true

extern windows_get_xmm_pointer(ctx: void&, index: u8) -> void&?

extern apple_get_xmm_pointer(ctx: void&, index: u8) -> void&?

extern freebsd_get_xmm_pointer(ctx: void&, index: u8) -> void&?

extern posix_get_xmm_pointer(ctx: void&, index: u8) -> void&?

extern windows_get_rip(ctx: void&) -> void&?

extern apple_get_rip(ctx: void&) -> void&?

extern freebsd_get_rip(ctx: void&) -> void&?

extern posix_get_rip(ctx: void&) -> void&?

extern windows_increment_rip(ctx: void&, length: u64) -> void

extern apple_increment_rip(ctx: void&, length: u64) -> void

extern freebsd_increment_rip(ctx: void&, length: u64) -> void

extern posix_increment_rip(ctx: void&, length: u64) -> void

extern windows_is_write_error(ctx: void&) -> bool

extern apple_x86_is_write_error(ctx: void&) -> bool

extern apple_arm64_is_write_error(ctx: void&) -> bool

extern freebsd_x86_is_write_error(ctx: void&) -> bool

extern posix_x86_is_write_error(ctx: void&) -> bool

def GetXmmPointer(ctx: void&, index: u8) -> void&?:
    if (index > 15):
        can Abort.Panic:
            panic("Invalid XMM register index")
    static if PLATFORM_WINDOWS:
        return windows_get_xmm_pointer(ctx, index)
    static elif PLATFORM_APPLE:
        return apple_get_xmm_pointer(ctx, index)
    static elif PLATFORM_FREEBSD:
        return freebsd_get_xmm_pointer(ctx, index)
    static else:
        return posix_get_xmm_pointer(ctx, index)

def GetRip(ctx: void&) -> void&?:
    static if PLATFORM_WINDOWS:
        return windows_get_rip(ctx)
    static elif PLATFORM_APPLE:
        return apple_get_rip(ctx)
    static elif PLATFORM_FREEBSD:
        return freebsd_get_rip(ctx)
    static else:
        return posix_get_rip(ctx)

def IncrementRip(ctx: void&, length: u64) -> void:
    static if PLATFORM_WINDOWS:
        windows_increment_rip(ctx, length)
    static elif PLATFORM_APPLE:
        apple_increment_rip(ctx, length)
    static elif PLATFORM_FREEBSD:
        freebsd_increment_rip(ctx, length)
    static else:
        posix_increment_rip(ctx, length)

def IsWriteError(ctx: void&) -> bool:
    static if PLATFORM_WINDOWS:
        return windows_is_write_error(ctx)
    static elif (PLATFORM_APPLE and ARCH_X86_64):
        return apple_x86_is_write_error(ctx)
    static elif (PLATFORM_APPLE and ARCH_ARM64):
        return apple_arm64_is_write_error(ctx)
    static elif (PLATFORM_FREEBSD and ARCH_X86_64):
        return freebsd_x86_is_write_error(ctx)
    static elif ARCH_X86_64:
        return posix_x86_is_write_error(ctx)
    static else:
        can Abort.Panic:
            panic("Unsupported architecture")

