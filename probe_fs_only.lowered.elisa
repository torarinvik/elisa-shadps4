extern aes_key_from_string(key: static u8&) -> darray[u8]

extern aes_encrypt_block(key: u8&, key_size: usize, input: u8&, output: mutable u8&) -> void

extern aes_decrypt_block(key: u8&, key_size: usize, input: u8&, output: mutable u8&) -> void

extern aes_cbc_encrypt(key: u8&, key_size: usize, iv: u8&, input: u8&, input_size: usize, output: mutable u8&) -> void

extern aes_cbc_decrypt(key: u8&, key_size: usize, iv: u8&, input: u8&, input_size: usize, output: mutable u8&) -> void

extern aes_gcm_encrypt(key: u8&, key_size: usize, iv: u8&, iv_size: usize, plain: u8&, plain_size: usize, out: mutable u8&) -> void

extern aes_gcm_decrypt(key: u8&, key_size: usize, iv: u8&, iv_size: usize, cipher: u8&, cipher_size: usize, out: mutable u8&) -> void

def key_from_string(key: static u8&) -> darray[u8]:
    return aes_key_from_string(key)

def AesEncryptBlock(key: u8&, key_size: usize, input: u8&, output: mutable u8&) -> void:
    aes_encrypt_block(key, key_size, input, output)

def AesDecryptBlock(key: u8&, key_size: usize, input: u8&, output: mutable u8&) -> void:
    aes_decrypt_block(key, key_size, input, output)

def AesCbcEncrypt(key: u8&, key_size: usize, iv: u8&, input: u8&, input_size: usize, output: mutable u8&) -> void:
    aes_cbc_encrypt(key, key_size, iv, input, input_size, output)

def AesCbcDecrypt(key: u8&, key_size: usize, iv: u8&, input: u8&, input_size: usize, output: mutable u8&) -> void:
    aes_cbc_decrypt(key, key_size, iv, input, input_size, output)

def AesGcmEncrypt(key: u8&, key_size: usize, iv: u8&, iv_size: usize, plain: u8&, plain_size: usize, out: mutable u8&) -> void:
    aes_gcm_encrypt(key, key_size, iv, iv_size, plain, plain_size, out)

def AesGcmDecrypt(key: u8&, key_size: usize, iv: u8&, iv_size: usize, cipher: u8&, cipher_size: usize, out: mutable u8&) -> void:
    aes_gcm_decrypt(key, key_size, iv, iv_size, cipher, cipher_size, out)

static interface ContiguousContainer:
    type Item

static interface DerivedFrom:
    type Base

static interface ConvertibleTo:
    type To

struct StringLiteral:
    value: mutable static u8&
    size: mutable usize

def StringLiteral_new(value: static u8&) -> StringLiteral:
    return StringLiteral(value, runtime_strlen(value))

struct CString:
    owner: mutable Arena&?
    data: mutable darray[u8]
    capacity: mutable usize

def CString_new(owner: mutable Arena&, capacity: usize) -> CString:
    out: mutable CString = zeroed
    out.owner as & <- owner
    out.capacity <- capacity
    in owner:
        _ = out.data.reserve(capacity)
        for i in 0 ..< capacity:
            out.data.push(0)
    return out

def CString_assign(self: mutable CString&, value: static u8&) -> void:
    len: usize = runtime_strlen(value)
    limit: usize = ((self.capacity - 1) if (self.capacity != 0) else 0)
    count: usize = (len if (len < limit) else limit)
    for i in 0 ..< count:
        self.data[i] <- value[i]
    if (self.capacity != 0):
        self.data[count] <- 0

def CString_c_str(self: mutable CString&) -> mutable u8&?:
    return (null if (self.capacity == 0) else self.data[0].ref[mutable u8&])

type CWString = CString

type CU16String = CString

extern wide_to_utf8(input: void&) -> static u8&

extern utf8_to_wide(input: static u8&) -> void&

def ascii_tolower(value: u8) -> u8:
    if ((value >= 'A') and (value <= 'Z')):
        return (value + (('a' - 'A')))
    return value

def string_alloc(size: usize) -> mutable heap u8&:
    out: mutable heap u8& = zeroed
    can Memory.Allocate, Abort.Panic:
        owner: mutable Arena& = scratch_arena.ref[mutable Arena&]
        out <- arena_heap_u8_from_alloc(arena_alloc(owner, size))
    return out

def string_substr_in(owner: mutable Arena&, input: static u8&, start: usize, len: usize) -> static u8&:
    out: mutable heap u8& = zeroed
    out <- arena_heap_u8_from_alloc(arena_alloc(owner, (len + 1))) can Memory.Allocate, Abort.Panic
    for i in 0 ..< len:
        out[i] <- input[(start + i)]
    out[len] <- 0
    return out.cast[static u8&]

def string_substr(input: static u8&, start: usize, len: usize) -> static u8&:
    owner: mutable Arena& = scratch_arena.ref[mutable Arena&]
    out: mutable static u8& = ""
    out <- string_substr_in(owner, input, start, len) can Memory.Allocate, Abort.Panic
    return out

def ToLower(input: static u8&) -> static u8&:
    len: usize = runtime_strlen(input)
    out: mutable heap u8& = zeroed
    out <- string_alloc((len + 1)) can Memory.Allocate, Abort.Panic
    for i in 0 ..< len:
        out[i] <- ascii_tolower(input[i])
    out[len] <- 0
    return out.cast[static u8&]

def ToLowerInPlace(str: mutable heap u8&) -> void:
    len: usize = runtime_strlen(str.cast[static u8&])
    for i in 0 ..< len:
        str[i] <- ascii_tolower(str[i])

def SplitString(owner: mutable Arena&, str: static u8&, delimiter: u8) -> darray[static u8&]:
    output: mutable darray[static u8&] = []
    start: mutable usize = 0
    len: usize = runtime_strlen(str)
    for i in 0 ..< len:
        if (str[i] == delimiter):
            part: mutable static u8& = ""
            part <- string_substr_in(owner, str, start, (i - start)) can Memory.Allocate, Abort.Panic
            in owner:
                output.push(part)
            start <- (i + 1)
    part: mutable static u8& = ""
    part <- string_substr_in(owner, str, start, (len - start)) can Memory.Allocate, Abort.Panic
    in owner:
        output.push(part)
    return output

def U8stringToString(u8str: static u8&) -> static u8&:
    return u8str

def UTF16ToUTF8(input: void&) -> static u8&:
    return wide_to_utf8(input)

def UTF8ToUTF16W(input: static u8&) -> void&:
    return utf8_to_wide(input)

