    return string_view_index(view, index)

def ctx_string_view_eq(view: sview, other: cstr[shape_other]) -> int:
    return string_view_eq(view, other)

def ctx_string_views_eq(lhs: sview, rhs: sview) -> int:
    return string_views_eq(lhs, rhs)

def ctx_string_from_view(view: sview) -> cstr[shape_out]:
    return string_view_copy(view).cast[u8&] can Memory.Allocate, Abort.Panic

def rt_reset_scratch():
    reset_scratch()

def rt_puts(value: u8&?) -> int:
    return puts((value if (value != null) else "")) can Console.Write

def ctx_llvm_codegen_fatal(msg: u8&?):
    can Console, Abort.Exit:
        actual_msg: u8& = (msg if (msg != null) else "<null>")
        puts("ctx_llvm_codegen_fatal:")
        puts(actual_msg)
        exit(1)

const ARCH_X86_64 = (target.arch == "x86_64")

const ARCH_ARM64 = (target.arch == "arm64")

const PLATFORM_WINDOWS = (target.os == "windows")

const PLATFORM_APPLE = (target.os == "macos")

const PLATFORM_LINUX = (target.os == "linux")

const PLATFORM_FREEBSD = (target.os == "freebsd")

const COMPILER_MSVC = (target.compiler == "msvc")

const HAS_AVX2 = target.features.avx2

const HAS_U128 = target.features.u128

type s8 = i8

type s16 = i16

type s32 = i32

type s64 = i64

type VAddr = uintptr

type PAddr = uintptr

struct u128:
    lo: mutable u64
    hi: mutable u64

def KB(x: u64) -> u64:
    return (x * 1024)

def MB(x: u64) -> u64:
    return ((x * 1024) * 1024)

def GB(x: u64) -> u64:
    return (((x * 1024) * 1024) * 1024)

def DivCeil(number: usize, divisor: usize) -> usize:
    return (0 if (divisor == 0) else ((((number + divisor) - 1)) / divisor))

def DivCeilLog2(value: usize, alignment_log2: usize) -> usize:
    alignment: usize = (1 << alignment_log2)
    return DivCeil(value, alignment)

def AlignUp(value: usize, size: usize) -> usize:
    return (value if (size == 0) else ((((((value + size) - 1)) / size)) * size))

def AlignDown(value: usize, size: usize) -> usize:
    return (value if (size == 0) else (((value / size)) * size))

def IsAligned(value: usize, alignment: usize) -> bool:
    if (alignment == 0):
        return (value == 0)
    return (((value & ((alignment - 1)))) == 0)

def Is16KBAligned(value: usize) -> bool:
    return IsAligned(value, (16 * 1024))

def Is64KBAligned(value: usize) -> bool:
    return IsAligned(value, (64 * 1024))

def Is2MBAligned(value: usize) -> bool:
    return IsAligned(value, ((2 * 1024) * 1024))

@intrinsic(llvm.bswap.i16)
extern byteswap_u16(value: u16) -> u16

@intrinsic(llvm.bswap.i32)
extern byteswap_u32(value: u32) -> u32

@intrinsic(llvm.bswap.i64)
extern byteswap_u64(value: u64) -> u64

struct SwappedEndian16:
    raw: mutable u16

struct SwappedEndian32:
    raw: mutable u32

struct SwappedEndian64:
    raw: mutable u64

type u16_be = SwappedEndian16

type u32_be = SwappedEndian32

type u64_be = SwappedEndian64

type u16_le = u16

type u32_le = u32

type u64_le = u64

def SwappedEndian16_new(value: u16) -> SwappedEndian16:
    return SwappedEndian16(byteswap_u16(value))

def SwappedEndian32_new(value: u32) -> SwappedEndian32:
    return SwappedEndian32(byteswap_u32(value))

def SwappedEndian64_new(value: u64) -> SwappedEndian64:
    return SwappedEndian64(byteswap_u64(value))

def SwappedEndian16_get(value: SwappedEndian16) -> u16:
    return byteswap_u16(value.raw)

def SwappedEndian32_get(value: SwappedEndian32) -> u32:
    return byteswap_u32(value.raw)

def SwappedEndian64_get(value: SwappedEndian64) -> u64:
    return byteswap_u64(value.raw)

const TRACY_GPU_ENABLED = 0

const EmulatorMarkerColor = 0xff0000

const RendererMarkerColor = 0x00ff00

const HleMarkerColor = 0x0000ff

extern debug_breakpoint() -> void effects[Abort.Panic]

extern profiler_connected() -> bool

extern tracy_alloc(ptr: void&, size: usize, pool: static u8&) -> void

extern tracy_free(ptr: void&, pool: static u8&) -> void

def BREAKPOINT() -> void:
    debug_breakpoint() can Abort.Panic

def IsProfilerConnected() -> bool:
    return profiler_connected()

def TRACK_ALLOC(ptr: void&, size: usize, pool: static u8&) -> void:
    tracy_alloc(ptr, size, pool)

def TRACK_FREE(ptr: void&, pool: static u8&) -> void:
    tracy_free(ptr, pool)

extern x86_debug_break() -> void effects[Abort.Panic]

extern arm64_debug_break() -> void effects[Abort.Panic]

def common_log_flush() -> void:
    pass

def common_log_critical_debug(format: static u8&, message: u8&) -> void:
    can Console.Write:
        _ = puts(format)
        _ = puts(message)

def crash() -> void:
    can Abort.Panic:
        static if ARCH_X86_64:
            x86_debug_break()
        static elif ARCH_ARM64:
            arm64_debug_break()
        static else:
            panic("Missing Crash() implementation for target CPU architecture.")

def assert_fail_impl() -> void:
    can Abort.Panic:
        common_log_flush()
        crash()

def unreachable_impl() -> void:
    can Abort.Panic:
        common_log_flush()
        crash()
        panic("Unreachable code")

def assert_fail_debug_msg(msg: u8&) -> void:
    can Console.Write, Abort.Panic:
        common_log_critical_debug("Assertion Failed!\n{}", msg)
        assert_fail_impl()

def ASSERT(condition: bool) -> void:
    can Abort.Panic:
        if (not condition):
            assert_fail_impl()

def ASSERT_MSG(condition: bool, msg: u8&) -> void:
    can Console.Write, Abort.Panic:
        if (not condition):
            assert_fail_debug_msg(msg)

def UNREACHABLE() -> void:
    unreachable_impl() can Abort.Panic

def UNREACHABLE_MSG(msg: u8&) -> void:
    can Console.Write, Abort.Panic:
        assert_fail_debug_msg(msg)
        unreachable_impl()

def DEBUG_ASSERT(condition: bool) -> void:
    ASSERT(condition) can Abort.Panic

def DEBUG_ASSERT_MSG(condition: bool, msg: u8&) -> void:
    ASSERT_MSG(condition, msg) can Console.Write, Abort.Panic

def UNIMPLEMENTED() -> void:
    ASSERT_MSG(false, "Unimplemented code!") can Console.Write, Abort.Panic

def UNIMPLEMENTED_MSG(msg: u8&) -> void:
    ASSERT_MSG(false, msg) can Console.Write, Abort.Panic

def UNIMPLEMENTED_IF(condition: bool) -> void:
    ASSERT_MSG((not condition), "Unimplemented code!") can Console.Write, Abort.Panic

def ASSERT_OR_EXECUTE(condition: bool, callback: void&) -> void:
    can Abort.Panic:
        if (not condition):
            scope_guard_call(callback)
            assert_fail_impl()

struct AdaptiveMutex:
    handle: mutable void&?

extern adaptive_mutex_lock(mutex: mutable AdaptiveMutex&) -> void

extern adaptive_mutex_unlock(mutex: mutable AdaptiveMutex&) -> void

extern adaptive_mutex_try_lock(mutex: mutable AdaptiveMutex&) -> bool

def AdaptiveMutex_new() -> AdaptiveMutex:
    return AdaptiveMutex(null)

def AdaptiveMutex_lock(self: mutable AdaptiveMutex&) -> void:
    adaptive_mutex_lock(self)

def AdaptiveMutex_unlock(self: mutable AdaptiveMutex&) -> void:
    adaptive_mutex_unlock(self)

def AdaptiveMutex_try_lock(self: mutable AdaptiveMutex&) -> bool:
    return adaptive_mutex_try_lock(self)

