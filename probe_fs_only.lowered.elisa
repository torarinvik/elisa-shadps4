extern posix_fs_directory_size(path: static u8&) -> u64

def io_open(path: static u8&, mode: FileAccessMode, file_type: FileType, share: FileShareFlag) -> void&?:
    static if PLATFORM_WINDOWS:
        return windows_io_open(path, mode, file_type, share)
    static else:
        return posix_io_open(path, mode, file_type, share)

def io_close(file: void&) -> void:
    static if PLATFORM_WINDOWS:
        windows_io_close(file)
    static else:
        posix_io_close(file)

def io_unlink(path: static u8&) -> void:
    static if PLATFORM_WINDOWS:
        windows_io_unlink(path)
    static else:
        posix_io_unlink(path)

def io_flush(file: void&) -> bool:
    static if PLATFORM_WINDOWS:
        return windows_io_flush(file)
    static else:
        return posix_io_flush(file)

def io_commit(file: void&) -> bool:
    static if PLATFORM_WINDOWS:
        return windows_io_commit(file)
    static else:
        return posix_io_commit(file)

def io_set_size(file: void&, size: u64) -> bool:
    static if PLATFORM_WINDOWS:
        return windows_io_set_size(file, size)
    static else:
        return posix_io_set_size(file, size)

def io_get_size(file: void&) -> u64:
    static if PLATFORM_WINDOWS:
        return windows_io_get_size(file)
    static else:
        return posix_io_get_size(file)

def io_seek(file: void&, offset: i64, origin: SeekOrigin) -> bool:
    static if PLATFORM_WINDOWS:
        return windows_io_seek(file, offset, origin)
    static else:
        return posix_io_seek(file, offset, origin)

def io_tell(file: void&) -> i64:
    static if PLATFORM_WINDOWS:
        return windows_io_tell(file)
    static else:
        return posix_io_tell(file)

def io_read(file: void&, data: mutable void&, elem_size: usize, count: usize) -> usize:
    static if PLATFORM_WINDOWS:
        return windows_io_read(file, data, elem_size, count)
    static else:
        return posix_io_read(file, data, elem_size, count)

def io_write(file: void&, data: void&, elem_size: usize, count: usize) -> usize:
    static if PLATFORM_WINDOWS:
        return windows_io_write(file, data, elem_size, count)
    static else:
        return posix_io_write(file, data, elem_size, count)

def io_read_string(file: void&, length: usize) -> static u8&:
    static if PLATFORM_WINDOWS:
        return windows_io_read_string(file, length)
    static else:
        return posix_io_read_string(file, length)

def io_get_mapping(file: void&) -> uintptr:
    static if PLATFORM_WINDOWS:
        return windows_io_get_mapping(file)
    static else:
        return posix_io_get_mapping(file)

def fs_directory_size(path: static u8&) -> u64:
    static if PLATFORM_WINDOWS:
        return windows_fs_directory_size(path)
    static else:
        return posix_fs_directory_size(path)

def IOFile_new() -> IOFile:
    return IOFile(null, "", FileAccessMode.Read, FileType.BinaryFile, 0.uintptr())

def IOFile_opened(path: static u8&, mode: FileAccessMode, file_type: FileType = FileType.BinaryFile, flag: FileShareFlag = FileShareFlag.ShareReadOnly) -> IOFile:
    out: mutable IOFile = IOFile_new()
    _ = IOFile_Open(out.ref[mutable IOFile&], path, mode, file_type, flag)
    return out

def IOFile_IsOpen(self: IOFile&) -> bool:
    return (self.file != null)

def IOFile_IsWriteOnly(self: IOFile&) -> bool:
    return ((self.file_access_mode == FileAccessMode.Append) or (self.file_access_mode == FileAccessMode.Write))

def IOFile_Open(self: mutable IOFile&, path: static u8&, mode: FileAccessMode, file_type: FileType = FileType.BinaryFile, flag: FileShareFlag = FileShareFlag.ShareReadOnly) -> int:
    IOFile_Close(self)
    self.file <- io_open(path, mode, file_type, flag)
    self.file_path <- path
    self.file_access_mode <- mode
    self.file_type <- file_type
    return (0 if (self.file != null) else (-1))

def IOFile_Close(self: mutable IOFile&) -> void:
    if (self.file != null):
        io_close(self.file.cast[void&])
        self.file <- null

def IOFile_Unlink(self: IOFile&) -> void:
    if (self.file_path != ""):
        io_unlink(self.file_path)

def IOFile_Flush(self: IOFile&) -> bool:
    return (false if (self.file == null) else io_flush(self.file.cast[void&]))

def IOFile_Commit(self: IOFile&) -> bool:
    return (false if (self.file == null) else io_commit(self.file.cast[void&]))

def IOFile_SetSize(self: IOFile&, size: u64) -> bool:
    return (false if (self.file == null) else io_set_size(self.file.cast[void&], size))

def IOFile_GetSize(self: IOFile&) -> u64:
    return (0 if (self.file == null) else io_get_size(self.file.cast[void&]))

def IOFile_Seek(self: IOFile&, offset: i64, origin: SeekOrigin = SeekOrigin.SetOrigin) -> bool:
    return (false if (self.file == null) else io_seek(self.file.cast[void&], offset, origin))

def IOFile_Tell(self: IOFile&) -> i64:
    return ((-1) if (self.file == null) else io_tell(self.file.cast[void&]))

def IOFile_ReadRaw(self: IOFile&, data: mutable void&, elem_size: usize, count: usize) -> usize:
    return (0 if (self.file == null) else io_read(self.file.cast[void&], data, elem_size, count))

def IOFile_WriteRaw(self: IOFile&, data: void&, elem_size: usize, count: usize) -> usize:
    return (0 if (self.file == null) else io_write(self.file.cast[void&], data, elem_size, count))

def IOFile_ReadObject[T](self: IOFile&, out: mutable T&) -> bool:
    return (IOFile_ReadRaw(self, out.cast[mutable void&], size_of(T), 1) == 1)

def IOFile_WriteObject[T](self: IOFile&, value: T&) -> bool:
    return (IOFile_WriteRaw(self, value.cast[void&], size_of(T), 1) == 1)

def IOFile_ReadSpan[T](self: IOFile&, data: mutable T&, count: usize) -> usize:
    return IOFile_ReadRaw(self, data.cast[mutable void&], size_of(T), count)

def IOFile_WriteSpan[T](self: IOFile&, data: T&, count: usize) -> usize:
    return IOFile_WriteRaw(self, data.cast[void&], size_of(T), count)

def IOFile_ReadString(self: IOFile&, length: usize) -> static u8&:
    return ("" if (self.file == null) else io_read_string(self.file.cast[void&], length))

def IOFile_GetFileMapping(self: mutable IOFile&) -> uintptr:
    if ((self.file_mapping == 0.uintptr()) and (self.file != null)):
        self.file_mapping <- io_get_mapping(self.file.cast[void&])
    return self.file_mapping

def GetDirectorySize(path: static u8&) -> u64:
    return fs_directory_size(path)

error KeyManagerError:
    InvalidHexStringLength
    InvalidHexCharacter

struct TrophyKeySet:
    ReleaseTrophyKey: mutable darray[u8]

struct AllKeys:
    TrophyKeySet: mutable TrophyKeySet

struct KeyManager:
    keys: mutable AllKeys

global mutable key_manager_instance: heap KeyManager&? = null

def key_manager_keys_path() -> static u8&:
    return fs_join(GetUserPath(PathType.UserDir), "keys.json") can Memory.Allocate, Abort.Panic
    return "keys.json"

def alloc_key_manager() -> mutable heap KeyManager&?:
    out: mutable heap KeyManager& = zeroed
    can Memory.Allocate, Abort.Panic:
        owner: mutable Arena& = scratch_arena.ref[mutable Arena&]
        out <- arena_alloc(owner, size_of(KeyManager)).cast[mutable heap KeyManager&]
    out.keys <- AllKeys(TrophyKeySet([]))
    return out

def KeyManager_new() -> KeyManager:
    out: mutable KeyManager = zeroed
    KeyManager_SetDefaultKeys(out.ref[mutable KeyManager&])
    return out

def KeyManager_GetInstance() -> heap KeyManager&:
    if (key_manager_instance == null):
        ptr_opt: mutable heap KeyManager&? = null
        ptr_opt <- alloc_key_manager() can Memory.Allocate, Abort.Panic
        if (ptr_opt == null):
            can Abort.Panic:
                panic("KeyManager allocation failed")
        if (ptr_opt != null):
            ptr: mutable heap KeyManager& = ptr_opt
            ptr.keys <- AllKeys(TrophyKeySet([]))
            key_manager_instance <- ptr
    assert((key_manager_instance != null))
    return key_manager_instance

def KeyManager_SetInstance(instance: heap KeyManager&?) -> void:
    key_manager_instance <- instance

def KeyManager_LoadFromFile(self: mutable KeyManager&) -> bool:
    KeyManager_SetDefaultKeys(self)
    return key_file_load(key_manager_keys_path(), self)

def KeyManager_SaveToFile(self: KeyManager&) -> bool:
    return key_file_save(key_manager_keys_path(), self)

def KeyManager_KeysToJson(self: KeyManager&, out: mutable KeyManager&) -> void:
    out.keys <- self.keys

def KeyManager_JsonToKeys(self: mutable KeyManager&, source: KeyManager&) -> void:
    self.keys <- source.keys

def KeyManager_SetDefaultKeys(self: mutable KeyManager&) -> void:
    self.keys <- AllKeys(TrophyKeySet([]))

def KeyManager_HasKeys(self: KeyManager&) -> bool:
    return (self.keys.TrophyKeySet.ReleaseTrophyKey.count != 0)

def hex_char_to_int(c: u8) -> u8 error[KeyManagerError]:
    if ((c >= '0') and (c <= '9')):
        return (c - '0')
    if ((c >= 'A') and (c <= 'F')):
        return ((c - 'A') + 10)
    if ((c >= 'a') and (c <= 'f')):
        return ((c - 'a') + 10)
    raise KeyManagerError.InvalidHexCharacter

def KeyManager_HexStringToBytes(hexStr: static u8&) -> darray[u8] error[KeyManagerError]:
    bytes: mutable darray[u8] = []
    len: usize = runtime_strlen(hexStr)
    if (len == 0):
        return bytes
    if ((len % 2) != 0):
        raise KeyManagerError.InvalidHexStringLength
    for i in 0 ..< len:
        high: u8 = try hex_char_to_int(hexStr[i])
        low: u8 = try hex_char_to_int(hexStr[(i + 1)])
        owner: mutable Arena& = scratch_arena.ref[mutable Arena&]
        in owner:
            bytes.push((((high << 4)) | low))
    return bytes

def KeyManager_BytesToHexString(bytes: darray[u8]) -> static u8&:
    hexDigits: static u8& = "0123456789ABCDEF"
    out: mutable heap u8& = zeroed
    out <- string_alloc(((bytes.count * 2) + 1)) can Memory.Allocate, Abort.Panic
    cursor: mutable usize = 0
    for b in bytes:
        out[cursor] <- hexDigits[((((b >> 4)) & 0xF)).usize()]
        out[(cursor + 1)] <- hexDigits[((b & 0xF)).usize()]
        cursor <- (cursor + 2)
    out[cursor] <- 0
    return out.cast[static u8&]

def key_json_is_quote(json: static u8&, len: usize, cursor: usize) -> bool:
    return ((cursor < len) and (((json[cursor] == '"') or ((((json[cursor] == '\\') and ((cursor + 1) < len)) and (json[(cursor + 1)] == '"'))))))

def key_json_advance_quote(json: static u8&, len: usize, cursor: usize) -> usize:
    if ((((cursor < len) and (json[cursor] == '\\')) and ((cursor + 1) < len)) and (json[(cursor + 1)] == '"')):
        return (cursor + 2)
    return (cursor + 1)

def key_json_find_release_trophy_key(json: static u8&) -> static u8&:
    needle: static u8& = "ReleaseTrophyKey"
    json_len: usize = runtime_strlen(json)
    needle_len: usize = runtime_strlen(needle)
    if (json_len < needle_len):
        return ""
    for i in 0 ..< (((json_len - needle_len) + 1)):
        if (string_slice_eq(json, i.i64(), ((i + needle_len)).i64(), needle) == 1):
            cursor: mutable usize = (i + needle_len)
            while ((cursor < json_len) and (json[cursor] != ':')):
                cursor <- (cursor + 1)
            if (cursor >= json_len):
                return ""
            cursor <- (cursor + 1)
            while ((cursor < json_len) and ((((json[cursor] == ' ') or (json[cursor] == '\n')) or (json[cursor] == '\t')))):
                cursor <- (cursor + 1)
            if (cursor >= json_len):
                return ""
            quoted: bool = key_json_is_quote(json, json_len, cursor)
            if quoted:
                cursor <- key_json_advance_quote(json, json_len, cursor)
            start: usize = cursor
            if quoted:
                while ((cursor < json_len) and (not key_json_is_quote(json, json_len, cursor))):
                    cursor <- (cursor + 1)
                if (cursor >= json_len):
                    return ""
            else:
                while ((cursor < json_len) and ((((((json[cursor] >= '0') and (json[cursor] <= '9'))) or (((json[cursor] >= 'A') and (json[cursor] <= 'F')))) or (((json[cursor] >= 'a') and (json[cursor] <= 'f')))))):
                    cursor <- (cursor + 1)
            out: mutable heap u8& = zeroed
            out <- string_alloc(((cursor - start) + 1)) can Memory.Allocate, Abort.Panic
            for j in 0 ..< ((cursor - start)):
                out[j] <- json[(start + j)]
            out[(cursor - start)] <- 0
            return out.cast[static u8&]
    return ""

def key_manager_apply_json(self: mutable KeyManager&, json: static u8&) -> bool:
    key_hex: static u8& = key_json_find_release_trophy_key(json)
    if (runtime_strlen(key_hex) == 0):
        return true
    empty: darray[u8] = []
    bytes: darray[u8] = try KeyManager_HexStringToBytes(key_hex) else empty
    self.keys.TrophyKeySet.ReleaseTrophyKey <- bytes
    return true

def key_manager_to_json(value: KeyManager&) -> static u8&:
    key_hex: mutable static u8& = ""
    can Memory.Allocate, Abort.Panic:
        key_hex <- KeyManager_BytesToHexString(value.keys.TrophyKeySet.ReleaseTrophyKey)
        builder: mutable heap StringBuilder& = string_builder_new("{\n    \"TrophyKeySet\": {\n        \"ReleaseTrophyKey\": \"")
        builder <- string_builder_append(builder, key_hex)
        builder <- string_builder_append(builder, "\"\n    }\n}\n")
        return string_builder_finish(builder).cast[static u8&]
    return "{}"

def key_file_load(path: static u8&, out: mutable KeyManager&) -> bool:
    if (not fs_exists(path)):
        KeyManager_SetDefaultKeys(out)
        return key_file_save(path, out)
    file: mutable IOFile = IOFile_opened(path, FileAccessMode.Read)
    if (not IOFile_IsOpen(file)):
        return false
    size: usize = IOFile_GetSize(file).usize()
    json: static u8& = IOFile_ReadString(file, size)
    IOFile_Close(file)
    return key_manager_apply_json(out, json)

def key_file_save(path: static u8&, value: KeyManager&) -> bool:
    file: mutable IOFile = IOFile_opened(path, FileAccessMode.Create)
    if (not IOFile_IsOpen(file)):
        return false
    json: static u8& = key_manager_to_json(value)
    len: usize = runtime_strlen(json)
    written: usize = IOFile_WriteSpan(file, json[0].ref[u8&], len)
    _ = IOFile_Flush(file)
    IOFile_Close(file)
    return (written == len)

struct BitArray:
    owner: mutable Arena&?
    words: mutable darray[u64]
    bit_count: mutable usize

def BitArray_new(owner: mutable Arena&, bit_count: usize) -> BitArray:
    out: mutable BitArray = zeroed
    out.owner as & <- owner
    out.bit_count <- bit_count
    needed: usize = DivCeil(bit_count, 64)
    in owner:
        _ = out.words.reserve(needed)
        for i in 0 ..< needed:
            out.words.push(0)
    return out

def BitArray_get(self: BitArray&, index: usize) -> bool:
    if (index >= self.bit_count):
        return false
    return (((((self.words[(index / 64)] >> ((index % 64)))) & 1)) != 0)

def BitArray_count_true(self: BitArray&) -> usize:
    count: mutable usize = 0
    for word in self.words:
        count <- (count + popcount_u64(word))
    return count

@intrinsic(llvm.ctpop.i64)
extern popcount_u64(value: u64) -> u64

def BitArray_set(self: mutable BitArray&, index: usize) -> void:
    if (index < self.bit_count):
        self.words[(index / 64)] <- (self.words[(index / 64)] | ((1.u64() << ((index % 64)))))

def BitArray_clear(self: mutable BitArray&, index: usize) -> void:
    if (index < self.bit_count):
        self.words[(index / 64)] <- (self.words[(index / 64)] & (~((1.u64() << ((index % 64))))))

def BitArray_clear_all(self: mutable BitArray&) -> void:
    for i in 0 ..< self.words.count:
        self.words[i] <- 0

struct BitField:
    storage: mutable u64
    position: mutable usize
    bits: mutable usize

def BitField_mask(bits: usize) -> u64:
    return (0xffffffffffffffff if (bits >= 64) else (((1.u64() << bits)) - 1))

def BitField_field_mask(self: BitField&) -> u64:
    return (BitField_mask(self.bits) << self.position)

def BitField_format_unsigned(position: usize, bits: usize, value: u64) -> u64:
    return (((value & BitField_mask(bits))) << position)

def BitField_format_signed(position: usize, bits: usize, value: i64) -> u64:
    return BitField_format_unsigned(position, bits, value.u64())

def BitField_get(self: BitField&) -> u64:
    return (((self.storage >> self.position)) & BitField_mask(self.bits))

def BitField_get_signed(self: BitField&) -> i64:
    if (self.bits == 0):
        return 0
    if (self.bits >= 64):
        return self.storage.i64()
    value: u64 = BitField_get(self)
    sign_bit: u64 = (1.u64() << ((self.bits - 1)))
    if (((value & sign_bit)) != 0):
        return (value.i64() - ((1.i64() << self.bits)))
    return value.i64()

def BitField_set(self: mutable BitField&, value: u64) -> void:
    mask: u64 = BitField_field_mask(self)
    self.storage <- (((self.storage & (~mask))) | ((((value << self.position)) & mask)))

def BitField_set_signed(self: mutable BitField&, value: i64) -> void:
    BitField_set(self, value.u64())

const DefaultCapacity: usize = 0x1000

struct SPSCQueue[T]:
    owner: mutable Arena&?
    items: mutable darray[T]
    capacity: mutable usize

struct MPSCQueue[T]:
    owner: mutable Arena&?
    items: mutable darray[T]
    capacity: mutable usize

struct MPMCQueue[T]:
    owner: mutable Arena&?
    items: mutable darray[T]
    capacity: mutable usize

def SPSCQueue_new[T](owner: mutable Arena&, capacity: usize = DefaultCapacity) -> SPSCQueue[T]:
    out: mutable SPSCQueue[T] = zeroed
    out.owner as & <- owner
    out.capacity <- capacity
    return out

def MPSCQueue_new[T](owner: mutable Arena&, capacity: usize = DefaultCapacity) -> MPSCQueue[T]:
    out: mutable MPSCQueue[T] = zeroed
    out.owner as & <- owner
    out.capacity <- capacity
    return out

def MPMCQueue_new[T](owner: mutable Arena&, capacity: usize = DefaultCapacity) -> MPMCQueue[T]:
    out: mutable MPMCQueue[T] = zeroed
    out.owner as & <- owner
    out.capacity <- capacity
    return out

def SPSCQueue_push[T](self: mutable SPSCQueue[T]&, value: T) -> bool:
    can Memory.Allocate, Abort.Panic:
        if (self.items.count >= self.capacity):
            return false
        assert((self.owner != null))
        owner: mutable Arena& = self.owner
        in owner:
            self.items.push(value)
        return true

def SPSCQueue_pop[T](self: mutable SPSCQueue[T]&, out: mutable T&) -> bool:
    can Abort.Panic:
        if (self.items.count == 0):
            return false
        out <- self.items[0]
        self.items.remove_at(0)
        return true

def MPSCQueue_push[T](self: mutable MPSCQueue[T]&, value: T) -> bool:
    can Memory.Allocate, Abort.Panic:
        if (self.items.count >= self.capacity):
            return false
        assert((self.owner != null))
        owner: mutable Arena& = self.owner
        in owner:
            self.items.push(value)
        return true

def MPSCQueue_pop[T](self: mutable MPSCQueue[T]&, out: mutable T&) -> bool:
    can Abort.Panic:
        if (self.items.count == 0):
            return false
        out <- self.items[0]
        self.items.remove_at(0)
        return true

def MPMCQueue_push[T](self: mutable MPMCQueue[T]&, value: T) -> bool:
    can Memory.Allocate, Abort.Panic:
        if (self.items.count >= self.capacity):
            return false
        assert((self.owner != null))
        owner: mutable Arena& = self.owner
        in owner:
            self.items.push(value)
        return true

def MPMCQueue_pop[T](self: mutable MPMCQueue[T]&, out: mutable T&) -> bool:
    can Abort.Panic:
        if (self.items.count == 0):
            return false
        out <- self.items[0]
        self.items.remove_at(0)
        return true

struct LruCacheEntry[ObjectType, TickType]:
    object: mutable ObjectType
    tick: mutable TickType

struct LeastRecentlyUsedCache[ObjectType, TickType]:
    entries: mutable darray[LruCacheEntry[ObjectType, TickType]]
    tick: mutable TickType
    capacity: mutable usize

def LeastRecentlyUsedCache_new[ObjectType, TickType](capacity: usize, initial_tick: TickType) -> LeastRecentlyUsedCache[ObjectType, TickType]:
    return LeastRecentlyUsedCache[ObjectType, TickType]([], initial_tick, capacity)

def LeastRecentlyUsedCache_Touch[ObjectType, TickType](self: mutable LeastRecentlyUsedCache[ObjectType, TickType]&, index: usize, tick: TickType) -> void:
    if (index < self.entries.count):
        self.entries[index].tick <- tick
        self.tick <- tick

def LeastRecentlyUsedCache_Size[ObjectType, TickType](self: LeastRecentlyUsedCache[ObjectType, TickType]&) -> usize:
    return self.entries.count

struct ObjectPool[T]:
    owner: mutable Arena&?
    objects: mutable darray[heap T&]
    free_indices: mutable darray[usize]

def ObjectPool_new[T](owner: mutable Arena&) -> ObjectPool[T]:
    out: mutable ObjectPool[T] = zeroed
    out.owner as & <- owner
    return out

def ObjectPool_Create[T](self: mutable ObjectPool[T]&) -> mutable heap T&:
    can Memory.Allocate, Abort.Panic:
        if (self.free_indices.count != 0):
            index: usize = self.free_indices[(self.free_indices.count - 1)]
            _ = self.free_indices.pop()
            return self.objects[index]
        assert((self.owner != null))
        owner: mutable Arena& = self.owner
        item: mutable heap T& = arena_alloc(owner, size_of(T)).cast[mutable heap T&]
        in owner:
            self.objects.push(item)
        return item

def ObjectPool_Destroy[T](self: mutable ObjectPool[T]&, item: heap T&) -> void:
    can Memory.Allocate, Abort.Panic:
        for i, candidate in self.objects.enumerate():
            if (candidate == item):
                assert((self.owner != null))
                owner: mutable Arena& = self.owner
                in owner:
                    self.free_indices.push(i)
                return
        assert(false)

struct RangeLockGuard[T]:
    items: mutable darray[mutable T&]
    owns: mutable bool

extern range_item_lock[T](item: mutable T&) -> void

extern range_item_unlock[T](item: mutable T&) -> void

def RangeLockGuard_new[T](items: darray[mutable T&]) -> RangeLockGuard[T]:
    guard: mutable RangeLockGuard[T] = RangeLockGuard[T](items, true)
    for item in guard.items:
        range_item_lock[T](item)
    return guard

def RangeLockGuard_unlock[T](self: mutable RangeLockGuard[T]&) -> void:
    if (not self.owns):
        return
    for item in self.items:
        range_item_unlock[T](item)
    self.owns <- false

def LockRange[T](items: darray[mutable T&]) -> RangeLockGuard[T]:
    guard: mutable RangeLockGuard[T] = RangeLockGuard[T](items, true)
    for item in guard.items:
        range_item_lock[T](item)
    return guard

enum RecursiveLockType:
    None
    Shared
    Exclusive

struct RecursiveLockState:
    type: mutable RecursiveLockType
    count: mutable int

global mutable recursive_lock_mutexes: darray[void&]

global mutable recursive_lock_states: darray[RecursiveLockState]

def find_recursive_lock(mutex: void&) -> int:
    for i, item in recursive_lock_mutexes.enumerate():
        if (item == mutex):
            return i.int()
    return (-1)

def IncrementRecursiveLock(mutex: void&, lock_type: RecursiveLockType) -> bool:
    index: int = find_recursive_lock(mutex)
    if (index < 0):
        owner: mutable Arena& = scratch_arena.ref[mutable Arena&]
        in owner:
            recursive_lock_mutexes.push(mutex)
            recursive_lock_states.push(RecursiveLockState(lock_type, 1))
        return true
    state: mutable RecursiveLockState& = recursive_lock_states[index.usize()].ref[mutable RecursiveLockState&]
    assert((state.type == lock_type))
    state.count <- (state.count + 1)
    return false

def DecrementRecursiveLock(mutex: void&, lock_type: RecursiveLockType) -> bool:
    can Abort.Panic:
        index: int = find_recursive_lock(mutex)
        assert((index >= 0))
        state: mutable RecursiveLockState& = recursive_lock_states[index.usize()].ref[mutable RecursiveLockState&]
        assert(((state.type == lock_type) and (state.count > 0)))
        state.count <- (state.count - 1)
        if (state.count == 0):
            recursive_lock_mutexes.remove_at(index.usize())
            recursive_lock_states.remove_at(index.usize())
            return true
        return false

struct RecursiveScopedLock:
    mutex: mutable void&?
    locked: mutable bool

struct RecursiveSharedLock:
    mutex: mutable void&?
    locked: mutable bool

extern recursive_mutex_lock(mutex: void&) -> void

extern recursive_mutex_unlock(mutex: void&) -> void

extern recursive_mutex_lock_shared(mutex: void&) -> void

extern recursive_mutex_unlock_shared(mutex: void&) -> void

def RecursiveScopedLock_new(mutex: void&) -> RecursiveScopedLock:
    locked: bool = IncrementRecursiveLock(mutex, RecursiveLockType.Exclusive)
    if locked:
        recursive_mutex_lock(mutex)
    return RecursiveScopedLock(mutex, locked)

def RecursiveScopedLock_destroy(self: mutable RecursiveScopedLock&) -> void:
    if (self.mutex == null):
        return
    should_unlock: mutable bool = false
    should_unlock <- DecrementRecursiveLock(self.mutex.cast[void&], RecursiveLockType.Exclusive) can Abort.Panic
    if (should_unlock and self.locked):
        recursive_mutex_unlock(self.mutex.cast[void&])
    self.mutex <- null

def RecursiveSharedLock_new(mutex: void&) -> RecursiveSharedLock:
    locked: bool = IncrementRecursiveLock(mutex, RecursiveLockType.Shared)
    if locked:
        recursive_mutex_lock_shared(mutex)
    return RecursiveSharedLock(mutex, locked)

def RecursiveSharedLock_destroy(self: mutable RecursiveSharedLock&) -> void:
    if (self.mutex == null):
        return
    should_unlock: mutable bool = false
    should_unlock <- DecrementRecursiveLock(self.mutex.cast[void&], RecursiveLockType.Shared) can Abort.Panic
    if (should_unlock and self.locked):
        recursive_mutex_unlock_shared(self.mutex.cast[void&])
    self.mutex <- null

