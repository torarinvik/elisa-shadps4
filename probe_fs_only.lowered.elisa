extern g_is_release: bool

extern g_scm_rev: static u8&

extern g_scm_branch: static u8&

extern g_scm_desc: static u8&

extern g_scm_remote_name: static u8&

extern g_scm_remote_url: static u8&

extern g_scm_date: static u8&

def GetRemoteNameFromLink() -> static u8&:
    return g_scm_remote_name

struct ScopeGuard:
    active: mutable bool
    callback: mutable void&?

extern scope_guard_call(callback: void&) -> void

def ScopeGuard_new(callback: void&) -> ScopeGuard:
    return ScopeGuard(true, callback)

def ScopeGuard_cancel(self: mutable ScopeGuard&) -> void:
    self.active <- false

def ScopeGuard_run(self: mutable ScopeGuard&) -> void:
    if (self.active and (self.callback != null)):
        scope_guard_call(self.callback.cast[void&])
        self.active <- false

struct Archive:
    data: mutable darray[u8]
    offset: mutable usize

struct Writer:
    archive: mutable Archive

struct Reader:
    archive: mutable Archive

def Writer_new() -> Writer:
    return Writer(Archive([], 0))

def Reader_new(data: darray[u8]) -> Reader:
    return Reader(Archive(data, 0))

def Archive_Grow(self: mutable Archive&, size: usize) -> void:
    can Memory.Allocate, Abort.Panic:
        owner: mutable Arena& = scratch_arena.ref[mutable Arena&]
        for i in 0 ..< size:
            in owner:
                self.data.push(0)

def Archive_Advance(self: mutable Archive&, size: usize) -> void:
    assert(((self.offset + size) <= self.data.count)) can Abort.Panic
    self.offset <- (self.offset + size)

def serdes_write_bytes(archive: mutable Archive&, data: void&, size: usize) -> void:
    if ((archive.offset + size) >= archive.data.count):
        Archive_Grow(archive, size) can Memory.Allocate, Abort.Panic
    source: u8& = data.cast[u8&]
    for i in 0 ..< size:
        archive.data[(archive.offset + i)] <- source[i]
    Archive_Advance(archive, size) can Abort.Panic

def serdes_read_bytes(archive: mutable Archive&, data: mutable void&, size: usize) -> void:
    assert(((archive.offset + size) <= archive.data.count)) can Abort.Panic
    dest: mutable u8& = data.cast[mutable u8&]
    for i in 0 ..< size:
        dest[i] <- archive.data[(archive.offset + i)]
    Archive_Advance(archive, size) can Abort.Panic

def Writer_write[T](self: mutable Writer&, value: T&) -> void:
    serdes_write_bytes(self.archive.ref[mutable Archive&], value.cast[void&], size_of(T)) can Memory.Allocate, Abort.Panic

def Reader_read[T](self: mutable Reader&, out: mutable T&) -> void:
    serdes_read_bytes(self.archive.ref[mutable Archive&], out.cast[mutable void&], size_of(T)) can Abort.Panic

struct SHA1Digest:
    bytes: mutable u8[20]

struct SHA1Context:
    state: mutable u32[5]
    count: mutable u64
    buffer: mutable u8[64]

def sha1_left_rotate(value: u32, count: usize) -> u32:
    return (((value << count)) ^ ((value >> ((32 - count)))))

def sha1_process_block(ctx: mutable SHA1Context&) -> void:
    w: mutable u32[80]
    for i in 0 ..< 16:
        base: usize = (i * 4)
        word: u32 = (((((ctx.buffer[base].u32() << 24)) | ((ctx.buffer[(base + 1)].u32() << 16))) | ((ctx.buffer[(base + 2)].u32() << 8))) | ctx.buffer[(base + 3)].u32())
        w[i] <- word
    for i in 16 ..< 80:
        w[i] <- sha1_left_rotate((((w[(i - 3)] ^ w[(i - 8)]) ^ w[(i - 14)]) ^ w[(i - 16)]), 1)
    a: mutable u32 = ctx.state[0]
    b: mutable u32 = ctx.state[1]
    c: mutable u32 = ctx.state[2]
    d: mutable u32 = ctx.state[3]
    e: mutable u32 = ctx.state[4]
    for i in 0 ..< 80:
        f: mutable u32 = 0
        k: mutable u32 = 0
        if (i < 20):
            f <- (((b & c)) | (((~b) & d)))
            k <- 0x5A827999
        else:
            if (i < 40):
                f <- ((b ^ c) ^ d)
                k <- 0x6ED9EBA1
            else:
                if (i < 60):
                    f <- ((((b & c)) | ((b & d))) | ((c & d)))
                    k <- 0x8F1BBCDC
                else:
                    f <- ((b ^ c) ^ d)
                    k <- 0xCA62C1D6
        temp: u32 = ((((sha1_left_rotate(a, 5) + f) + e) + k) + w[i])
        e <- d
        d <- c
        c <- sha1_left_rotate(b, 30)
        b <- a
        a <- temp
    ctx.state[0] <- (ctx.state[0] + a)
    ctx.state[1] <- (ctx.state[1] + b)
    ctx.state[2] <- (ctx.state[2] + c)
    ctx.state[3] <- (ctx.state[3] + d)
    ctx.state[4] <- (ctx.state[4] + e)

def sha1_process_byte(ctx: mutable SHA1Context&, octet: u8) -> void:
    block_index: usize = ((ctx.count % 64)).usize()
    ctx.buffer[block_index] <- octet
    ctx.count <- (ctx.count + 1)
    if (block_index == 63):
        sha1_process_block(ctx)

def sha1_init(ctx: mutable SHA1Context&) -> void:
    ctx.state[0] <- 0x67452301
    ctx.state[1] <- 0xEFCDAB89
    ctx.state[2] <- 0x98BADCFE
    ctx.state[3] <- 0x10325476
    ctx.state[4] <- 0xC3D2E1F0
    ctx.count <- 0
    for i in 0 ..< 64:
        ctx.buffer[i] <- 0

def sha1_update(ctx: mutable SHA1Context&, data: u8&, size: usize) -> void:
    for i in 0 ..< size:
        sha1_process_byte(ctx, data[i])

def sha1_final(ctx: mutable SHA1Context&, digest: mutable SHA1Digest&) -> void:
    bit_count: u64 = (ctx.count * 8)
    sha1_process_byte(ctx, 0x80)
    while (((ctx.count % 64)) != 56):
        sha1_process_byte(ctx, 0)
    sha1_process_byte(ctx, 0)
    sha1_process_byte(ctx, 0)
    sha1_process_byte(ctx, 0)
    sha1_process_byte(ctx, 0)
    sha1_process_byte(ctx, ((((bit_count >> 24)) & 0xff)).u32().u8())
    sha1_process_byte(ctx, ((((bit_count >> 16)) & 0xff)).u32().u8())
    sha1_process_byte(ctx, ((((bit_count >> 8)) & 0xff)).u32().u8())
    sha1_process_byte(ctx, ((bit_count & 0xff)).u32().u8())
    di: mutable usize = 0
    for i in 0 ..< 5:
        word: u32 = ctx.state[i]
        digest.bytes[di] <- ((((word >> 24)) & 0xff)).u8()
        digest.bytes[(di + 1)] <- ((((word >> 16)) & 0xff)).u8()
        digest.bytes[(di + 2)] <- ((((word >> 8)) & 0xff)).u8()
        digest.bytes[(di + 3)] <- ((word & 0xff)).u8()
        di <- (di + 4)

def SHA1Context_new() -> SHA1Context:
    ctx: mutable SHA1Context = zeroed
    sha1_init(ctx.ref[mutable SHA1Context&])
    return ctx

def SHA1_Update(ctx: mutable SHA1Context&, data: u8&, size: usize) -> void:
    sha1_update(ctx, data, size)

def SHA1_Final(ctx: mutable SHA1Context&) -> SHA1Digest:
    digest: mutable SHA1Digest = zeroed
    sha1_final(ctx, digest.ref[mutable SHA1Digest&])
    return digest

struct SharedFirstMutex:
    handle: mutable void&?

extern shared_first_mutex_lock(mutex: mutable SharedFirstMutex&) -> void

extern shared_first_mutex_unlock(mutex: mutable SharedFirstMutex&) -> void

extern shared_first_mutex_lock_shared(mutex: mutable SharedFirstMutex&) -> void

extern shared_first_mutex_unlock_shared(mutex: mutable SharedFirstMutex&) -> void

def SharedFirstMutex_new() -> SharedFirstMutex:
    return SharedFirstMutex(null)

def SharedFirstMutex_lock(self: mutable SharedFirstMutex&) -> void:
    shared_first_mutex_lock(self)

def SharedFirstMutex_unlock(self: mutable SharedFirstMutex&) -> void:
    shared_first_mutex_unlock(self)

def SharedFirstMutex_lock_shared(self: mutable SharedFirstMutex&) -> void:
    shared_first_mutex_lock_shared(self)

def SharedFirstMutex_unlock_shared(self: mutable SharedFirstMutex&) -> void:
    shared_first_mutex_unlock_shared(self)

struct Singleton[T]:
    instance: mutable heap T&?

def Singleton_new[T]() -> Singleton[T]:
    return Singleton[T](null)

def Singleton_Instance[T](self: mutable Singleton[T]&, fallback: heap T&) -> heap T&:
    if (self.instance == null):
        self.instance <- fallback
    assert((self.instance != null))
    return self.instance

struct SlabHeapImpl:
    object_size: mutable usize
    capacity: mutable usize
    free_count: mutable usize
    storage: mutable heap u8&?

struct SlabHeapBase:
    impl: mutable SlabHeapImpl

struct SlabHeap[T]:
    base: mutable SlabHeapBase

extern slab_heap_init(size: usize, capacity: usize) -> SlabHeapImpl

extern slab_heap_alloc(impl: mutable SlabHeapImpl&) -> mutable heap void&?

extern slab_heap_free(impl: mutable SlabHeapImpl&, ptr: heap void&) -> void

def SlabHeap_new[T](capacity: usize) -> SlabHeap[T]:
    return SlabHeap[T](SlabHeapBase(slab_heap_init(size_of(T), capacity)))

def SlabHeap_Allocate[T](self: mutable SlabHeap[T]&) -> mutable heap T&?:
    raw: mutable heap void&? = slab_heap_alloc(self.base.impl.ref[mutable SlabHeapImpl&])
    return (null if (raw == null) else raw.cast[mutable heap T&])

def SlabHeap_Free[T](self: mutable SlabHeap[T]&, ptr: heap T&) -> void:
    slab_heap_free(self.base.impl.ref[mutable SlabHeapImpl&], ptr.cast[heap void&])

struct SlotArray[IndexType, ResourceType]:
    owner: mutable Arena&?
    resources: mutable darray[ResourceType]
    used: mutable darray[bool]

def SlotArray_new[IndexType, ResourceType](owner: mutable Arena&) -> SlotArray[IndexType, ResourceType]:
    out: mutable SlotArray[IndexType, ResourceType] = zeroed
    out.owner as & <- owner
    return out

def SlotArray_Allocate[IndexType, ResourceType](self: mutable SlotArray[IndexType, ResourceType]&, resource: ResourceType) -> usize:
    can Memory.Allocate, Abort.Panic:
        for i, flag in self.used.enumerate():
            if (not flag):
                self.resources[i] <- resource
                self.used[i] <- true
                return i
        assert((self.owner != null))
        owner: mutable Arena& = self.owner
        in owner:
            self.resources.push(resource)
            self.used.push(true)
        return (self.resources.count - 1)

def SlotArray_Free[IndexType, ResourceType](self: mutable SlotArray[IndexType, ResourceType]&, index: usize) -> void:
    if (index < self.used.count):
        self.used[index] <- false

def SlotArray_Get[IndexType, ResourceType](self: mutable SlotArray[IndexType, ResourceType]&, index: usize) -> mutable ResourceType&?:
    if ((index >= self.used.count) or (not self.used[index])):
        return null
    return self.resources[index].ref[mutable ResourceType&]

struct SlotId:
    index: mutable u32
    generation: mutable u32

struct SlotVectorEntry[T]:
    value: mutable T
    generation: mutable u32
    occupied: mutable bool

struct SlotVector[T]:
    owner: mutable Arena&?
    entries: mutable darray[SlotVectorEntry[T]]
    free_list: mutable darray[u32]

def SlotVector_new[T](owner: mutable Arena&) -> SlotVector[T]:
    out: mutable SlotVector[T] = zeroed
    out.owner as & <- owner
    return out

def SlotVector_insert[T](self: mutable SlotVector[T]&, value: T) -> SlotId:
    can Memory.Allocate, Abort.Panic:
        if (self.free_list.count != 0):
            index: u32 = self.free_list[(self.free_list.count - 1)]
            _ = self.free_list.pop()
            entry: mutable SlotVectorEntry[T]& = self.entries[index.usize()].ref[mutable SlotVectorEntry[T]&]
            entry.value <- value
            entry.occupied <- true
            return SlotId(index, entry.generation)
        index: u32 = self.entries.count.u32()
        assert((self.owner != null))
        owner: mutable Arena& = self.owner
        in owner:
            self.entries.push(SlotVectorEntry[T](value, 0, true))
        return SlotId(index, 0)

def SlotVector_get[T](self: mutable SlotVector[T]&, id: SlotId) -> mutable T&?:
    if (id.index.usize() >= self.entries.count):
        return null
    entry: mutable SlotVectorEntry[T]& = self.entries[id.index.usize()].ref[mutable SlotVectorEntry[T]&]
    if ((not entry.occupied) or (entry.generation != id.generation)):
        return null
    return entry.value.ref[mutable T&]

def SlotVector_erase[T](self: mutable SlotVector[T]&, id: SlotId) -> bool:
    can Memory.Allocate, Abort.Panic:
        if (id.index.usize() >= self.entries.count):
            return false
        entry: mutable SlotVectorEntry[T]& = self.entries[id.index.usize()].ref[mutable SlotVectorEntry[T]&]
        if ((not entry.occupied) or (entry.generation != id.generation)):
            return false
        entry.occupied <- false
        entry.generation <- (entry.generation + 1)
        assert((self.owner != null))
        owner: mutable Arena& = self.owner
        in owner:
            self.free_list.push(id.index)
        return true

