def addGameInstallDir(dir: static u8&, enabled: bool = true) -> bool:
    owner: mutable Arena& = scratch_arena.ref[mutable Arena&]
    in owner:
        settings_install_dirs.push(GameInstallDir(dir, enabled))
        install_dirs_enabled.push(enabled)
    return true

def removeGameInstallDir(dir: static u8&) -> void:
    filtered: mutable darray[GameInstallDir] = []
    for entry in settings_install_dirs:
        if (entry.path != dir):
            owner: mutable Arena& = scratch_arena.ref[mutable Arena&]
            in owner:
                filtered.push(entry)
    settings_install_dirs <- filtered

def setGameInstallDirEnabled(dir: static u8&, enabled: bool) -> void:
    for entry in settings_install_dirs:
        if (entry.path == dir):
            entry.enabled <- enabled
            return

def setAddonInstallDir(dir: static u8&) -> void:
    settings_addon_install_dir <- dir

def setGameInstallDirs(dirs_config: darray[static u8&]) -> void:
    settings_install_dirs <- []
    install_dirs_enabled <- []
    for dir in dirs_config:
        _ = addGameInstallDir(dir, true)

def setAllGameInstallDirs(dirs_config: darray[GameInstallDir]) -> void:
    settings_install_dirs <- dirs_config
    install_dirs_enabled <- []
    for entry in dirs_config:
        owner: mutable Arena& = scratch_arena.ref[mutable Arena&]
        in owner:
            install_dirs_enabled.push(entry.enabled)

def getGameInstallDirs() -> darray[static u8&]:
    out: mutable darray[static u8&] = []
    for entry in settings_install_dirs:
        owner: mutable Arena& = scratch_arena.ref[mutable Arena&]
        in owner:
            out.push(entry.path)
    return out

def getGameInstallDirsEnabled() -> darray[bool]:
    return install_dirs_enabled

def getAddonInstallDir() -> static u8&:
    return settings_addon_install_dir

