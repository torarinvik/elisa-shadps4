global mutable NtQueueApcThreadEx: ProcAddress = null

def Common_NtApi_Initialize() -> void:
    static if (not PLATFORM_WINDOWS):
        return
    nt_handle: HModule = GetModuleHandleA("ntdll.dll")
    NtClose <- GetProcAddress(nt_handle, "NtClose")
    NtSetInformationFile <- GetProcAddress(nt_handle, "NtSetInformationFile")
    NtCreateThread <- GetProcAddress(nt_handle, "NtCreateThread")
    NtTerminateThread <- GetProcAddress(nt_handle, "NtTerminateThread")
    NtQueueApcThreadEx <- GetProcAddress(nt_handle, "NtQueueApcThreadEx")

extern windows_format_message(error_code: int, buffer: mutable stack u8&, buffer_size: usize) -> bool

extern windows_get_last_error() -> int

extern gnu_strerror_r(error_code: int, buffer: mutable stack u8&, buffer_size: usize) -> static u8&

extern xsi_strerror_r(error_code: int, buffer: mutable stack u8&, buffer_size: usize) -> int

extern posix_errno() -> int

const USE_GNU_STRERROR_R = target.libc.gnu_strerror_r

def NativeErrorToString(e: int) -> static u8&:
    err_str: mutable u8[255]
    static if PLATFORM_WINDOWS:
        if (not windows_format_message(e, err_str[0].ref[mutable stack u8&], 255)):
            return "(FormatMessageA failed to format error)"
        return err_str[0].ref[static u8&]
    static elif USE_GNU_STRERROR_R:
        return gnu_strerror_r(e, err_str[0].ref[mutable stack u8&], 255)
    static else:
        second_err: int = xsi_strerror_r(e, err_str[0].ref[mutable stack u8&], 255)
        if (second_err != 0):
            return "(strerror_r failed to format error)"
        return err_str[0].ref[static u8&]

def GetLastErrorMsg() -> static u8&:
    static if PLATFORM_WINDOWS:
        return NativeErrorToString(windows_get_last_error())
    static else:
        return NativeErrorToString(posix_errno())

const SecondToNanoseconds: u64 = 1000000000

extern FencedRDTSC() -> u64

extern common_sleep_for_ms(milliseconds: u64) -> void

extern windows_precise_time_ns() -> u64

extern apple_clock_gettime_nsec_np() -> u64

extern posix_clock_gettime_ns() -> u64

def RoundToNearest_100000(value: u64) -> u64:
    nearest: u64 = 100000
    mod: u64 = (value % nearest)
    if (mod >= (nearest / 2)):
        return ((value - mod) + nearest)
    return (value - mod)

def GetTimeNs() -> u64:
    static if PLATFORM_WINDOWS:
        return windows_precise_time_ns()
    static elif PLATFORM_APPLE:
        return apple_clock_gettime_nsec_np()
    static else:
        return posix_clock_gettime_ns()

def EstimateRDTSCFrequency() -> u64:
    _ = FencedRDTSC()
    common_sleep_for_ms(1)
    _ = FencedRDTSC()
    start_time: u64 = GetTimeNs()
    tsc_start: u64 = FencedRDTSC()
    common_sleep_for_ms(100)
    end_time: u64 = GetTimeNs()
    tsc_end: u64 = FencedRDTSC()
    tsc_diff: u64 = (tsc_end - tsc_start)
    tsc_freq: u64 = MultiplyAndDivide64(tsc_diff, 1000000000, (end_time - start_time))
    return RoundToNearest_100000(tsc_freq)

const NANO_DEN: u64 = 1000000000

const MICRO_DEN: u64 = 1000000

const MILLI_DEN: u64 = 1000

struct NativeClock:
    rdtsc_frequency: u64
    ns_rdtsc_factor: u64
    us_rdtsc_factor: u64
    ms_rdtsc_factor: u64

def NativeClock_new() -> NativeClock:
    frequency: u64 = EstimateRDTSCFrequency()
    return NativeClock(frequency, GetFixedPoint64Factor(NANO_DEN, frequency), GetFixedPoint64Factor(MICRO_DEN, frequency), GetFixedPoint64Factor(MILLI_DEN, frequency))

def NativeClock_GetTscFrequency(clock: NativeClock&) -> u64:
    return clock.rdtsc_frequency

def NativeClock_GetTimeNS(clock: NativeClock&, base_ptc: u64 = 0) -> u64:
    return MultiplyHigh((NativeClock_GetUptime(clock) - base_ptc), clock.ns_rdtsc_factor)

def NativeClock_GetTimeUS(clock: NativeClock&, base_ptc: u64 = 0) -> u64:
    return MultiplyHigh((NativeClock_GetUptime(clock) - base_ptc), clock.us_rdtsc_factor)

def NativeClock_GetTimeMS(clock: NativeClock&, base_ptc: u64 = 0) -> u64:
    return MultiplyHigh((NativeClock_GetUptime(clock) - base_ptc), clock.ms_rdtsc_factor)

def NativeClock_GetUptime(clock: NativeClock&) -> u64:
    return FencedRDTSC()

const UF11_EXPONENT_SHIFT: u32 = 6

const UF10_EXPONENT_SHIFT: u32 = 5

const F32_INFINITY: u32 = 0x7f800000

def f32_positive_infinity() -> f32:
    return (1.0 / 0.0)

def Uf11ToF32(val: u16) -> f32:
    exponent: mutable int = ((((val & 0x07c0)).u32() >> UF11_EXPONENT_SHIFT)).int()
    mantissa: int = ((val & 0x003f)).int()
    if (exponent == 0):
        if (mantissa != 0):
            return (((1.0 / ((1 << 20)).f32())) * mantissa.f32())
        return 0.0
    if (exponent == 31):
        return f32_positive_infinity()
    exponent <- (exponent - 15)
    scale: f32 = (((1.0 / ((1 << (-exponent))).f32())) if (exponent < 0) else ((1 << exponent)).f32())
    decimal: f32 = (1.0 + (mantissa.f32() / 64.0))
    return (scale * decimal)

def Uf10ToF32(val: u16) -> f32:
    exponent: mutable int = ((((val & 0x03e0)).u32() >> UF10_EXPONENT_SHIFT)).int()
    mantissa: int = ((val & 0x001f)).int()
    if (exponent == 0):
        if (mantissa != 0):
            return (((1.0 / ((1 << 19)).f32())) * mantissa.f32())
        return 0.0
    if (exponent == 31):
        return f32_positive_infinity()
    exponent <- (exponent - 15)
    scale: f32 = (((1.0 / ((1 << (-exponent))).f32())) if (exponent < 0) else ((1 << exponent)).f32())
    decimal: f32 = (1.0 + (mantissa.f32() / 32.0))
    return (scale * decimal)

def Uf16ToF32(val: u16) -> f32:
    sign: bool = (((val & 0x8000)) != 0)
    exponent: int = ((((val & 0x7c00)).u32() >> 10)).int()
    mantissa: int = ((val & 0x03ff)).int()
    out: mutable f32 = 0.0
    if (exponent == 0):
        out <- (mantissa.f32() / 16777216.0)
    else:
        if (exponent == 31):
            out <- f32_positive_infinity()
        else:
            unbiased: int = (exponent - 15)
            scale: f32 = (((1.0 / ((1 << (-unbiased))).f32())) if (unbiased < 0) else ((1 << unbiased)).f32())
            out <- (scale * ((1.0 + (mantissa.f32() / 1024.0))))
    if sign:
        return (0.0 - out)
    return out

def U2ToUnorm(val: u8) -> f32:
    return (val.f32() * ((1.0 / 3.0)))

def S2ToSnorm(val: i8) -> f32:
    return val.f32()

def U4ToUnorm(val: u8) -> f32:
    return (val.f32() * ((1.0 / 15.0)))

def S4ToSnorm(val: i8) -> f32:
    return (val.f32() * ((1.0 / 7.0)))

def U5ToUnorm(val: u8) -> f32:
    return (val.f32() * ((1.0 / 31.0)))

def S5ToSnorm(val: i8) -> f32:
    return (val.f32() * ((1.0 / 15.0)))

def U6ToUnorm(val: u8) -> f32:
    return (val.f32() * ((1.0 / 63.0)))

def S6ToSnorm(val: i8) -> f32:
    return (val.f32() * ((1.0 / 31.0)))

def U8ToUnorm(val: u8) -> f32:
    return (val.f32() * ((1.0 / 255.0)))

def S8ToSnorm(val: i8) -> f32:
    return (val.f32() * ((1.0 / 127.0)))

def U10ToUnorm(val: u16) -> f32:
    return (val.f32() * ((1.0 / 1023.0)))

def S10ToSnorm(val: i16) -> f32:
    return (val.f32() * ((1.0 / 511.0)))

def U16ToUnorm(val: u16) -> f32:
    return (val.f32() * ((1.0 / 65535.0)))

def S16ToSnorm(val: i16) -> f32:
    return (val.f32() * ((1.0 / 32767.0)))

static if PLATFORM_WINDOWS:
    const MAX_PATH = 260
static else:
    const MAX_PATH = 1024

const PORTABLE_DIR = "user"

const LOG_DIR = "log"

const SCREENSHOTS_DIR = "screenshots"

const SHADER_DIR = "shader"

const GAMEDATA_DIR = "data"

const TEMPDATA_DIR = "temp"

const SYSMODULES_DIR = "sys_modules"

const DOWNLOAD_DIR = "download"

const CAPTURES_DIR = "captures"

const CHEATS_DIR = "cheats"

const PATCHES_DIR = "patches"

const METADATA_DIR = "game_data"

const CUSTOM_TROPHY = "custom_trophy"

const CUSTOM_CONFIGS = "custom_configs"

const CACHE_DIR = "cache"

const FONTS_DIR = "fonts"

const HOME_DIR = "home"

const CUSTOM_MODULES_DIR = "custom_modules"

const LOG_FILE = "shad_log.txt"

