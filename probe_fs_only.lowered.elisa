def toHex(value: u64, byteSize: usize) -> static u8&:
    digits: usize = (byteSize * 2)
    hexDigits: static u8& = "0123456789abcdef"
    out: mutable heap u8& = zeroed
    out <- string_alloc((digits + 1)) can Memory.Allocate, Abort.Panic
    for i in 0 ..< digits:
        shift: usize = ((((digits - 1) - i)) * 4)
        out[i] <- hexDigits[((((value >> shift)) & 0xF)).usize()]
    out[digits] <- 0
    return out.cast[static u8&]

def patcher_parse_u64(value: static u8&, base: int) -> u64:
    out: mutable u64 = 0
    len: usize = runtime_strlen(value)
    for i in 0 ..< len:
        c: u8 = value[i]
        digit: mutable u8 = 0
        if ((c >= '0') and (c <= '9')):
            digit <- (c - '0')
        else:
            if ((c >= 'A') and (c <= 'F')):
                digit <- ((c - 'A') + 10)
            else:
                if ((c >= 'a') and (c <= 'f')):
                    digit <- ((c - 'a') + 10)
                else:
                    return out
        if (digit.int() >= base):
            return out
        out <- ((out * base.u64()) + digit.u64())
    return out

def patcher_parse_f64(value: static u8&) -> f64:
    len: usize = runtime_strlen(value)
    i: mutable usize = 0
    sign: mutable f64 = 1.0
    if ((i < len) and (value[i] == '-')):
        sign <- (-1.0)
        i <- (i + 1)
    else:
        if ((i < len) and (value[i] == '+')):
            i <- (i + 1)
    out: mutable f64 = 0.0
    while (((i < len) and (value[i] >= '0')) and (value[i] <= '9')):
        out <- ((out * 10.0) + ((value[i] - '0')).f64())
        i <- (i + 1)
    if ((i < len) and (value[i] == '.')):
        i <- (i + 1)
        scale: mutable f64 = 0.1
        while (((i < len) and (value[i] >= '0')) and (value[i] <= '9')):
            out <- (out + (((value[i] - '0')).f64() * scale))
            scale <- (scale * 0.1)
            i <- (i + 1)
    if ((i < len) and (((value[i] == 'e') or (value[i] == 'E')))):
        i <- (i + 1)
        exp_sign: mutable int = 1
        if ((i < len) and (value[i] == '-')):
            exp_sign <- (-1)
            i <- (i + 1)
        else:
            if ((i < len) and (value[i] == '+')):
                i <- (i + 1)
        exp: mutable int = 0
        while (((i < len) and (value[i] >= '0')) and (value[i] <= '9')):
            exp <- ((exp * 10) + ((value[i] - '0')).int())
            i <- (i + 1)
        for _ in 0 ..< exp:
            if (exp_sign < 0):
                out <- (out / 10.0)
            else:
                out <- (out * 10.0)
    return (out * sign)

def patcher_parse_f32_bits(value: static u8&) -> u32:
    parsed: f32 = patcher_parse_f64(value).f32()
    bits: u32 = parsed.ref[f32&].cast[u32&][0]
    return byteswap_u32(bits)

def patcher_parse_f64_bits(value: static u8&) -> u64:
    parsed: f64 = patcher_parse_f64(value)
    bits: u64 = parsed.ref[f64&].cast[u64&][0]
    return byteswap_u64(bits)

def patcher_write_u32_le(address: uintptr, value: u32) -> void:
    out: mutable u8& = address.cast[mutable u8&]
    out[0] <- ((value & 0xff)).u8()
    out[1] <- ((((value >> 8)) & 0xff)).u8()
    out[2] <- ((((value >> 16)) & 0xff)).u8()
    out[3] <- ((((value >> 24)) & 0xff)).u8()

def patcher_write_hex_bytes(address: uintptr, valueStr: static u8&, littleEndian: bool) -> void:
    out: mutable u8& = address.cast[mutable u8&]
    len: usize = runtime_strlen(valueStr)
    byteCount: usize = (len / 2)
    for i in 0 ..< byteCount:
        source: usize = (((byteCount - 1) - i) if littleEndian else i)
        high: u8 = try hex_char_to_int(valueStr[(source * 2)]) else 0
        low: u8 = try hex_char_to_int(valueStr[((source * 2) + 1)]) else 0
        out[i] <- (((high << 4)) | low)

def patcher_utf8_to_hex(value: static u8&) -> static u8&:
    len: usize = runtime_strlen(value)
    out: mutable heap u8& = zeroed
    out <- string_alloc(((((len + 1)) * 2) + 1)) can Memory.Allocate, Abort.Panic
    cursor: mutable usize = 0
    for i in 0 ..< len:
        byte_hex: mutable static u8& = ""
        byte_hex <- toHex(value[i].u64(), 1) can Memory.Allocate, Abort.Panic
        out[cursor] <- byte_hex[0]
        out[(cursor + 1)] <- byte_hex[1]
        cursor <- (cursor + 2)
    out[cursor] <- '0'
    out[(cursor + 1)] <- '0'
    out[(cursor + 2)] <- 0
    return out.cast[static u8&]

def patcher_utf16_to_hex(value: static u8&) -> static u8&:
    len: usize = runtime_strlen(value)
    out: mutable heap u8& = zeroed
    out <- string_alloc(((((len + 1)) * 4) + 1)) can Memory.Allocate, Abort.Panic
    cursor: mutable usize = 0
    for i in 0 ..< len:
        byte_hex: mutable static u8& = ""
        byte_hex <- toHex(value[i].u64(), 1) can Memory.Allocate, Abort.Panic
        out[cursor] <- byte_hex[0]
        out[(cursor + 1)] <- byte_hex[1]
        out[(cursor + 2)] <- '0'
        out[(cursor + 3)] <- '0'
        cursor <- (cursor + 4)
    out[cursor] <- '0'
    out[(cursor + 1)] <- '0'
    out[(cursor + 2)] <- '0'
    out[(cursor + 3)] <- '0'
    out[(cursor + 4)] <- 0
    return out.cast[static u8&]

def convertValueToHex(value_type: static u8&, valueStr: static u8&) -> static u8&:
    if (value_type == "byte"):
        return toHex(patcher_parse_u64(valueStr, 16), 1) can Memory.Allocate, Abort.Panic
    if (value_type == "bytes16"):
        return toHex(patcher_parse_u64(valueStr, 16), 2) can Memory.Allocate, Abort.Panic
    if (value_type == "bytes32"):
        return toHex(patcher_parse_u64(valueStr, 16), 4) can Memory.Allocate, Abort.Panic
    if (value_type == "bytes64"):
        return toHex(patcher_parse_u64(valueStr, 16), 8) can Memory.Allocate, Abort.Panic
    if (value_type == "float32"):
        return toHex(patcher_parse_f32_bits(valueStr).u64(), 4) can Memory.Allocate, Abort.Panic
    if (value_type == "float64"):
        return toHex(patcher_parse_f64_bits(valueStr), 8) can Memory.Allocate, Abort.Panic
    if (value_type == "utf8"):
        return patcher_utf8_to_hex(valueStr) can Memory.Allocate, Abort.Panic
    if (value_type == "utf16"):
        return patcher_utf16_to_hex(valueStr) can Memory.Allocate, Abort.Panic
    return valueStr

def OnGameLoaded() -> void:
    patches_applied <- false
    ApplyPendingPatches()

def AddPatchToQueue(patchToAdd: PatchInfo) -> void:
    owner: mutable Arena& = scratch_arena.ref[mutable Arena&]
    in owner:
        pending_patches.push(patchToAdd)

def ApplyPendingPatches() -> void:
    for patch in pending_patches:
        patcher_apply_patch(patch)
    patches_applied <- true

def PatchMemory(modNameStr: static u8&, offsetStr: static u8&, valueStr: static u8&, targetStr: static u8&, sizeStr: static u8&, isOffset: bool, littleEndian: bool, patchMask: PatchMask = PatchMask.None, maskOffset: int = 0) -> void:
    info: PatchInfo = PatchInfo(g_game_serial, modNameStr, offsetStr, valueStr, targetStr, sizeStr, isOffset, littleEndian, patchMask, maskOffset)
    if patches_applied:
        patcher_apply_patch(info)
    else:
        AddPatchToQueue(info)

def patcher_apply_patch(info: PatchInfo) -> void:
    cheatAddress: mutable uintptr = 0.uintptr()
    if (info.patchMask == PatchMask.None):
        offset: uintptr = patcher_parse_u64(info.offsetStr, 16).uintptr()
        if info.isOffset:
            cheatAddress <- (g_eboot_address + offset)
        else:
            cheatAddress <- (g_eboot_address + ((offset - 0x400000.uintptr())))
    if (info.patchMask == PatchMask.Mask):
        cheatAddress <- (PatternScan(info.offsetStr) + info.maskOffset.uintptr())
    if (info.patchMask == PatchMask.Mask_Jump32):
        jumpSize: int = patcher_parse_u64(info.sizeStr, 10).int()
        if ((jumpSize < 5) or (jumpSize > 256)):
            return
        baseAddress: uintptr = PatternScan(info.offsetStr)
        if (baseAddress == 0.uintptr()):
            return
        patchAddress: uintptr = (baseAddress + info.maskOffset.uintptr())
        patchBytes: mutable u8& = patchAddress.cast[mutable u8&]
        for i in 0 ..< jumpSize.usize():
            patchBytes[i] <- 0x90
        jumpTarget: uintptr = PatternScan(info.targetStr)
        if (jumpTarget == 0.uintptr()):
            return
        patcher_write_hex_bytes(jumpTarget, info.valueStr, false)
        payloadSize: uintptr = ((runtime_strlen(info.valueStr) / 2)).uintptr()
        codeCaveEnd: uintptr = (jumpTarget + payloadSize)
        patchBytes[0] <- 0xe9
        relJump: i64 = ((jumpTarget.i64() - patchAddress.i64()) - 5)
        patcher_write_u32_le((patchAddress + 1.uintptr()), relJump.u32())
        caveEndBytes: mutable u8& = codeCaveEnd.cast[mutable u8&]
        caveEndBytes[0] <- 0xe9
        targetReturn: i64 = ((((patchAddress + jumpSize.uintptr())).i64() - codeCaveEnd.i64()) - 5)
        patcher_write_u32_le((codeCaveEnd + 1.uintptr()), targetReturn.u32())
        return
    if (cheatAddress == 0.uintptr()):
        return
    patcher_write_hex_bytes(cheatAddress, info.valueStr, info.littleEndian)

def PatternToByte(pattern: static u8&) -> darray[i32]:
    out: mutable darray[i32] = []
    i: mutable usize = 0
    len: usize = runtime_strlen(pattern)
    trusted Unsafe.AssumeProgress:
        while (i < len):
            if (pattern[i] == ' '):
                i <- (i + 1)
            else:
                if (pattern[i] == '?'):
                    owner: mutable Arena& = scratch_arena.ref[mutable Arena&]
                    in owner:
                        out.push((-1))
                    i <- (i + 1)
                    if ((i < len) and (pattern[i] == '?')):
                        i <- (i + 1)
                else:
                    high: u8 = try hex_char_to_int(pattern[i]) else 0
                    low: mutable u8 = 0
                    if ((i + 1) < len):
                        low <- try hex_char_to_int(pattern[(i + 1)]) else 0
                    owner: mutable Arena& = scratch_arena.ref[mutable Arena&]
                    in owner:
                        out.push(((((high << 4)) | low)).i32())
                    i <- (i + 2)
    return out

def PatternScan(signature: static u8&) -> uintptr:
    patternBytes: darray[i32] = PatternToByte(signature)
    sigSize: usize = patternBytes.count
    if (((g_eboot_address == 0.uintptr()) or (sigSize == 0)) or (g_eboot_image_size < sigSize.u64())):
        return 0.uintptr()
    scanBytes: u8& = g_eboot_address.cast[u8&]
    limit: usize = ((g_eboot_image_size - sigSize.u64())).usize()
    for i in 0 ..< limit:
        found: mutable bool = true
        for j in 0 ..< sigSize:
            sigByte: i32 = patternBytes[j]
            if ((sigByte != (-1)) and (scanBytes[(i + j)] != sigByte.u8())):
                found <- false
        if found:
            return ((scanBytes + i)).uintptr()
    return 0.uintptr()

extern av_err2string(err: int) -> static u8&

def av_err2str(err: int) -> static u8&:
    return av_err2string(err)

enum FsFileType:
    Regular
    Directory
    Device
    Socket
    Epoll
    Resolver
    Equeue

enum HostPathType:
    Default
    Base
    Patch
    Mod

struct MntPair:
    host_path: mutable static u8&
    mount: mutable static u8&
    read_only: mutable bool

struct MntPoints:
    pairs: mutable darray[MntPair]

global mutable MntPoints_IgnoreGamePatches: bool = false

def MntPoints_new() -> MntPoints:
    return MntPoints([])

def RemoveTrailingSlashes(path: static u8&) -> static u8&:
    len: mutable usize = runtime_strlen(path)
    while ((len > 0) and (path[(len - 1)] == '/'.u8())):
        len <- (len - 1)
    return string_substr(path, 0, len) can Memory.Allocate, Abort.Panic
    return path

def NormalizePath(path: static u8&) -> static u8&:
    if (path == ""):
        return "/"
    can Memory.Allocate, Abort.Panic:
        owner: mutable Arena& = scratch_arena.ref[mutable Arena&]
        in owner:
            out: mutable darray[u8] = []
            prev_slash: mutable bool = false
            for i in 0 ..< runtime_strlen(path):
                c: mutable u8 = 0
                c <- path[i].u8()
                if (c == '\\'.u8()):
                    c <- '/'.u8()
                if (c == '/'.u8()):
                    if prev_slash:
                        pass
                    else:
                        out.push('/'.u8())
                        prev_slash <- true
                else:
                    out.push(c)
                    prev_slash <- false
            if (out.count == 0):
                out.push('/'.u8())
            out.push(0)
            return out[0].ref[static u8&]
    return path

def IsGuestOverlayMount(path: static u8&) -> bool:
    return ((string_slice_eq(path, 0, runtime_strlen("/app0"), "/app0") == 1) or (string_slice_eq(path, 0, runtime_strlen("/hostapp"), "/hostapp") == 1))

def AsciiLower(path: static u8&) -> static u8&:
    can Memory.Allocate, Abort.Panic:
        owner: mutable Arena& = scratch_arena.ref[mutable Arena&]
        in owner:
            len: usize = runtime_strlen(path)
            out: mutable darray[u8] = []
            for i in 0 ..< len:
                ch: mutable u8 = 0
                ch <- path[i].u8()
                if ((ch >= 'A'.u8()) and (ch <= 'Z'.u8())):
                    ch <- ((ch + 32)).u8()
                out.push(ch)
            out.push(0)
            return out[0].ref[static u8&]
    return path

def ResolveCaseInsensitiveHostPath(path: static u8&) -> static u8&:
    return path

def MntPoints_Mount(self: mutable MntPoints&, host_folder: static u8&, guest_folder: static u8&, read_only: bool = false) -> void:
    guest_folder_sanitized: static u8& = RemoveTrailingSlashes(NormalizePath(guest_folder))
    can Memory.Allocate, Abort.Panic:
        owner: mutable Arena& = scratch_arena.ref[mutable Arena&]
        in owner:
            self.pairs.push(MntPair(host_folder, guest_folder_sanitized, read_only))

def MntPoints_Unmount(self: mutable MntPoints&, host_folder: static u8&, guest_folder: static u8&) -> void:
    _ = host_folder
    guest_folder_sanitized: static u8& = RemoveTrailingSlashes(NormalizePath(guest_folder))
    write_i: mutable usize = 0
    for i in 0 ..< self.pairs.count:
        if (streq(self.pairs[i].mount, guest_folder_sanitized) != 1):
            if (write_i != i):
                self.pairs[write_i] <- self.pairs[i]
            write_i <- (write_i + 1)
    self.pairs.count <- write_i

def MntPoints_UnmountAll(self: mutable MntPoints&) -> void:
    self.pairs.count <- 0

def MntPoints_GetHostPath(self: MntPoints&, guest_path: static u8&, is_read_only: mutable bool&? = null, path_type: HostPathType = HostPathType.Default) -> static u8&:
    normalized_guest: static u8& = NormalizePath(guest_path)
    guest_len: usize = runtime_strlen(normalized_guest)
    best_index: mutable s64 = (-1)
    best_len: mutable usize = 0
    for i in 0 ..< self.pairs.count:
        pair: MntPair = self.pairs[i]
        mount_len: usize = runtime_strlen(pair.mount)
        mount_prefix: static u8& = concat2(pair.mount, "/")
        mount_prefix_len: usize = runtime_strlen(mount_prefix)
        exact_match: bool = ((guest_len == mount_len) and (string_slice_eq(normalized_guest, 0, mount_len, pair.mount) == 1))
        child_match: bool = ((guest_len > mount_len) and (string_slice_eq(normalized_guest, 0, mount_prefix_len, mount_prefix) == 1))
        if ((mount_len >= best_len) and ((exact_match or child_match))):
            best_index <- i.i64()
            best_len <- mount_len
    if (best_index >= 0):
        match_pair: MntPair = self.pairs[best_index.usize()]
        if (is_read_only != null):
            is_read_only <- match_pair.read_only
        suffix: mutable static u8& = ""
        if (guest_len > best_len):
            suffix <- string_substr(normalized_guest, best_len, (guest_len - best_len)) can Memory.Allocate, Abort.Panic
        rel_path: static u8& = suffix
        if ((runtime_strlen(rel_path) > 0) and (string_slice_eq(rel_path, 0, 1, "/") == 1)):
            rel_path <- string_substr(rel_path, 1, (runtime_strlen(rel_path) - 1)) can Memory.Allocate, Abort.Panic
        base_path: static u8& = fs_join(match_pair.host_path, rel_path)
        patch_root: mutable static u8& = concat2(match_pair.host_path, "-UPDATE")
        if (not fs_exists(patch_root)):
            patch_root <- concat2(match_pair.host_path, "-patch")
        patch_path: static u8& = fs_join(patch_root, rel_path)
        mod_path: static u8& = fs_join(concat2(match_pair.host_path, "-mods"), rel_path)
        if (path_type == HostPathType.Mod):
            return ResolveCaseInsensitiveHostPath(mod_path)
        if (path_type == HostPathType.Patch):
            return ResolveCaseInsensitiveHostPath(patch_path)
        if (IsGuestOverlayMount(normalized_guest) and (path_type != HostPathType.Base)):
            if fs_exists(mod_path):
                return ResolveCaseInsensitiveHostPath(mod_path)
            if ((not MntPoints_IgnoreGamePatches) and fs_exists(patch_path)):
                return ResolveCaseInsensitiveHostPath(patch_path)
        return ResolveCaseInsensitiveHostPath(base_path)
    return elisa_filesys_get_host_path_default(normalized_guest)

struct FsFile:
    is_opened: mutable bool
    kind: mutable FsFileType
    host_name: mutable static u8&
    guest_name: mutable static u8&
    directory: mutable void&?
    device: mutable void&?

def FsFile_new() -> FsFile:
    return FsFile(false, FsFileType.Regular, "", "", null, null)

struct HandleTable:
    files: mutable darray[FsFile]

def HandleTable_new() -> HandleTable:
    return HandleTable([])

def HandleTable_CreateHandle(self: mutable HandleTable) -> s32:
    for i in 0 ..< self.files.count:
        if (not self.files[i].is_opened):
            self.files[i] <- FsFile_new()
            return i.i32()
    can Memory.Allocate, Abort.Panic:
        owner: mutable Arena& = scratch_arena.ref[mutable Arena&]
        in owner:
            self.files.push(FsFile_new())
    return ((self.files.count - 1)).i32()

def HandleTable_DeleteHandle(self: mutable HandleTable&, d: s32) -> void:
    if ((d < 0) or (d >= self.files.count.i32())):
        return
    self.files[d.usize()].is_opened <- false

def HandleTable_GetFile(self: mutable HandleTable&, d: s32) -> mutable FsFile&?:
    if ((d < 0) or (d >= self.files.count.i32())):
        return null
    return self.files[d.usize()].ref[mutable FsFile&]

def HandleTable_CreateStdHandles(self: mutable HandleTable) -> void:
    for i in 0 ..< 3:
        fd: s32 = HandleTable_CreateHandle(self)
        file: mutable FsFile&? = HandleTable_GetFile(self, fd)
        if (file != null):
            f: mutable FsFile& = file
            f.is_opened <- true
            f.kind <- FsFileType.Device
            if (i == 0):
                f.guest_name <- "/dev/stdin"
            else:
                if (i == 1):
                    f.guest_name <- "/dev/stdout"
                else:
                    f.guest_name <- "/dev/stderr"
