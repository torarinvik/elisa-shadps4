def HashCombine64(seed: u64, hash: u64) -> u64:
    return (seed ^ ((((hash + 0x9e3779b9) + ((seed << 12))) + ((seed >> 4)))))

def HashCombine32(seed: u32, hash: u32) -> u32:
    return (seed ^ ((((hash + 0x9e3779b9.u32()) + ((seed << 6))) + ((seed >> 2)))))

enum FileAccessMode:
    Read
    Write
    ReadWrite
    Append
    ReadAppend
    Create

enum FileType:
    BinaryFile
    TextFile

enum FileShareFlag:
    ShareNone
    ShareReadOnly
    ShareWriteOnly
    ShareReadWrite

enum SeekOrigin:
    SetOrigin
    CurrentPosition
    End

def AccessModeToStr(mode: FileAccessMode, file_type: FileType) -> static u8&:
    static if PLATFORM_WINDOWS:
        return AccessModeToWStr(mode, file_type)
    static else:
        match file_type:
            FileType.BinaryFile:
                match mode:
                    FileAccessMode.Read:
                        return "rb"
                    FileAccessMode.Append:
                        return "ab"
                    FileAccessMode.Write:
                        return "r+b"
                    FileAccessMode.ReadWrite:
                        return "r+b"
                    FileAccessMode.ReadAppend:
                        return "a+b"
                    FileAccessMode.Create:
                        return "wb"
            FileType.TextFile:
                match mode:
                    FileAccessMode.Read:
                        return "r"
                    FileAccessMode.Append:
                        return "a"
                    FileAccessMode.Write:
                        return "r+"
                    FileAccessMode.ReadWrite:
                        return "r+"
                    FileAccessMode.ReadAppend:
                        return "a+"
                    FileAccessMode.Create:
                        return "w"

def AccessModeToWStr(mode: FileAccessMode, file_type: FileType) -> static u8&:
    match file_type:
        FileType.BinaryFile:
            match mode:
                FileAccessMode.Read:
                    return "rb"
                FileAccessMode.Append:
                    return "ab"
                FileAccessMode.Write:
                    return "r+b"
                FileAccessMode.ReadWrite:
                    return "r+b"
                FileAccessMode.ReadAppend:
                    return "a+b"
                FileAccessMode.Create:
                    return "wb"
        FileType.TextFile:
            match mode:
                FileAccessMode.Read:
                    return "r"
                FileAccessMode.Append:
                    return "a"
                FileAccessMode.Write:
                    return "r+"
                FileAccessMode.ReadWrite:
                    return "r+"
                FileAccessMode.ReadAppend:
                    return "a+"
                FileAccessMode.Create:
                    return "w"

def ToWindowsFileShareFlag(flag: FileShareFlag) -> int:
    match flag:
        FileShareFlag.ShareNone:
            return 0
        FileShareFlag.ShareReadOnly:
            return 1
        FileShareFlag.ShareWriteOnly:
            return 2
        FileShareFlag.ShareReadWrite:
            return 3

def ToSeekOrigin(origin: SeekOrigin) -> int:
    match origin:
        SeekOrigin.SetOrigin:
            return 0
        SeekOrigin.CurrentPosition:
            return 1
        SeekOrigin.End:
            return 2

struct IOFile:
    file: mutable void&?
    file_path: mutable static u8&
    file_access_mode: mutable FileAccessMode
    file_type: mutable FileType
    file_mapping: mutable uintptr

extern windows_io_open(path: static u8&, mode: FileAccessMode, file_type: FileType, share: FileShareFlag) -> void&?

extern posix_io_open(path: static u8&, mode: FileAccessMode, file_type: FileType, share: FileShareFlag) -> void&?

extern windows_io_close(file: void&) -> void

extern posix_io_close(file: void&) -> void

extern windows_io_unlink(path: static u8&) -> void

extern posix_io_unlink(path: static u8&) -> void

extern windows_io_flush(file: void&) -> bool

extern posix_io_flush(file: void&) -> bool

extern windows_io_commit(file: void&) -> bool

extern posix_io_commit(file: void&) -> bool

extern windows_io_set_size(file: void&, size: u64) -> bool

extern posix_io_set_size(file: void&, size: u64) -> bool

extern windows_io_get_size(file: void&) -> u64

extern posix_io_get_size(file: void&) -> u64

extern windows_io_seek(file: void&, offset: i64, origin: SeekOrigin) -> bool

extern posix_io_seek(file: void&, offset: i64, origin: SeekOrigin) -> bool

extern windows_io_tell(file: void&) -> i64

extern posix_io_tell(file: void&) -> i64

extern windows_io_read(file: void&, data: mutable void&, elem_size: usize, count: usize) -> usize

extern posix_io_read(file: void&, data: mutable void&, elem_size: usize, count: usize) -> usize

extern windows_io_write(file: void&, data: void&, elem_size: usize, count: usize) -> usize

extern posix_io_write(file: void&, data: void&, elem_size: usize, count: usize) -> usize

extern windows_io_read_string(file: void&, length: usize) -> static u8&

extern posix_io_read_string(file: void&, length: usize) -> static u8&

