# Pure-Elisa port of native/guest_exec_runtime.c. The guest execution runtime
# captures crash/boundary state when handing control to a loaded PS4 module.
# Guest code only runs on x86_64 hosts; the signal-handler / ucontext / fork /
# trampoline machinery is therefore gated behind `static if ARCH_X86_64` and is
# inert (and unreachable) on other hosts, exactly like the original C file's
# `#if defined(__x86_64__)` guards.
#
# This file provides the `c_GuestExec_*` functions that core/guest_exec.elisa
# and core/linker.elisa previously declared `extern` against the C symbols
# `ElisaGuestExec_*`. Being whole-program Elisa, the calls bind to these defs
# directly; no C ABI boundary remains for the Elisa->runtime calls.

include "../common/types.elisa"
include "../common/arch.elisa"

# --- Native phase codes (diagnostic breadcrumbs through the run path) ---
const GE_PHASE_NONE: s32 = 0
const GE_PHASE_FUNCTION_ENTRY: s32 = 100
const GE_PHASE_RETURN_BAD_PARAMS: s32 = 101
const GE_PHASE_AFTER_RESET: s32 = 110
const GE_PHASE_SYNTHETIC_ENTRY: s32 = 120
const GE_PHASE_SYNTHETIC_BEFORE_SIGSETJMP: s32 = 121
const GE_PHASE_SYNTHETIC_BEFORE_MAIN_ENTRY: s32 = 122
const GE_PHASE_BEFORE_FORK_REPORT_SETUP: s32 = 200
const GE_PHASE_RETURN_FORK_REPORT_SETUP_FAILED: s32 = 201
const GE_PHASE_AFTER_FORK_REPORT_SETUP: s32 = 202
const GE_PHASE_BEFORE_FORK: s32 = 210
const GE_PHASE_RETURN_FORK_FAILED: s32 = 211
const GE_PHASE_CHILD_BRANCH_ENTERED: s32 = 220
const GE_PHASE_CHILD_GUARDS_INSTALLED: s32 = 221
const GE_PHASE_CHILD_BEFORE_SIGSETJMP: s32 = 222
const GE_PHASE_CHILD_SIGLONGJMP: s32 = 223
const GE_PHASE_CHILD_BEFORE_MAIN_ENTRY: s32 = 224
const GE_PHASE_CHILD_AFTER_MAIN_ENTRY: s32 = 225
const GE_PHASE_CHILD_ENTRY_SNAPSHOT: s32 = 226
const GE_PHASE_SIGNAL_HANDLER_ENTERED: s32 = 300
const GE_PHASE_ALARM_HANDLER_ENTERED: s32 = 310
const GE_PHASE_PARENT_BRANCH_ENTERED: s32 = 400
const GE_PHASE_PARENT_WAITPID_CHILD: s32 = 401
const GE_PHASE_PARENT_WIFSIGNALED: s32 = 402
const GE_PHASE_PARENT_WIFEXITED: s32 = 403
const GE_PHASE_PARENT_WAIT_STATUS_OTHER: s32 = 404
const GE_PHASE_PARENT_WAITPID_ERROR: s32 = 410
const GE_PHASE_PARENT_WAITPID_EINTR: s32 = 411
const GE_PHASE_PARENT_TIMEOUT: s32 = 420
const GE_PHASE_NATIVE_BOUNDARY_REPORTED: s32 = 500
const GE_PHASE_UNSUPPORTED_RETURN: s32 = 900

# --- PC source codes ---
const GE_PC_SOURCE_NONE: s32 = 0
const GE_PC_SOURCE_SIGNAL_UCONTEXT: s32 = 1
const GE_PC_SOURCE_FALLBACK_CHILD_SIGLONGJMP: s32 = 2
const GE_PC_SOURCE_FALLBACK_PARENT_SILENT_CHILD: s32 = 3
const GE_PC_SOURCE_FALLBACK_PARENT_STATUS: s32 = 4

