# --- Cross-process fork report (mmap MAP_SHARED). Layout shared between the
# forked child (which runs the guest) and the parent (which reads it back). ---
@fixed_layout
struct ElisaGuestExecForkReport:
    boundary_reached: mutable s32
    boundary_reason: mutable s32
    execution_stage: mutable s32
    status: mutable s32
    signal: mutable s32
    fault_address: mutable uintptr
    guest_pc: mutable uintptr
    guest_sp: mutable uintptr
    guest_bp: mutable uintptr
    guest_rdi: mutable uintptr
    guest_rsi: mutable uintptr
    guest_rdx: mutable uintptr
    guest_rcx: mutable uintptr
    guest_r8: mutable uintptr
    guest_r9: mutable uintptr
    guest_rax: mutable uintptr
    guest_rbx: mutable uintptr
    expected_entry_params: mutable uintptr
    expected_stack_word0: mutable uintptr
    expected_stack_word1: mutable uintptr
    entry_stack_word0: mutable uintptr
    entry_stack_word1: mutable uintptr
    entry_native_word0: mutable uintptr
    entry_native_word1: mutable uintptr
    fault_word0: mutable uintptr
    fault_word1: mutable uintptr
    signal_stack_word0: mutable uintptr
    signal_stack_word1: mutable uintptr
    signal_stack_symbol0: mutable static u8&?
    signal_stack_image0: mutable static u8&?
    signal_pc_symbol: mutable static u8&?
    signal_pc_image: mutable static u8&?
    prejump_rdi: mutable uintptr
    prejump_rsi: mutable uintptr
    prejump_rsp: mutable uintptr
    signal_guest_pc: mutable uintptr
    fallback_guest_pc: mutable uintptr
    signal_pc_valid: mutable s32
    pc_source: mutable s32
    entry_native_prot: mutable u32
    pc_native_prot: mutable u32
    entry_addr: mutable uintptr
    native_phase: mutable s32
    pc_was_fallback: mutable s32
    aerolib_fallback_caller_pc: mutable uintptr
    aerolib_fallback_slot_va: mutable uintptr
    aerolib_fallback_callsite_bytes: mutable u64
    aerolib_fallback_invocations: mutable u64
    aerolib_fallback_plt_va: mutable uintptr
    aerolib_fallback_plt_bytes: mutable u64
    runtime_hle_module: mutable static u8&?
    runtime_hle_symbol: mutable static u8&?
    runtime_hle_arg0: mutable uintptr
    runtime_hle_arg1: mutable uintptr
    runtime_hle_arg2: mutable uintptr
    runtime_hle_ret: mutable uintptr

global mutable ge_fork_report: ElisaGuestExecForkReport&? = null

def ge_set_native_phase(phase: s32) -> void:
    ge_last_native_phase <- phase
    fr: ElisaGuestExecForkReport&? = ge_fork_report
    if fr != null:
        fr.native_phase <- phase

def ge_pc_source_is_fallback(source: s32) -> bool:
    return source == GE_PC_SOURCE_FALLBACK_CHILD_SIGLONGJMP or source == GE_PC_SOURCE_FALLBACK_PARENT_SILENT_CHILD or source == GE_PC_SOURCE_FALLBACK_PARENT_STATUS

# ============================================================
# Trivial state getters (parent-side reads of captured state)
# ============================================================

def c_GuestExec_ReportedBoundaryReached() -> s32:
    fr: ElisaGuestExecForkReport&? = ge_fork_report
    return fr.boundary_reached if fr != null else 0

def c_GuestExec_ReportedBoundaryReason() -> s32:
    fr: ElisaGuestExecForkReport&? = ge_fork_report
    return fr.boundary_reason if fr != null else 0

