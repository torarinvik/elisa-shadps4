struct NidEntry:
    nid: static u8&
    name: static u8&

def AeroLib_StrCmp(lhs: static u8&, rhs: static u8&) -> int:
    i: mutable usize = 0
    while lhs[i] != 0 and lhs[i] == rhs[i]:
        i <- i + 1

    left_byte: u8 = lhs[i]
    right_byte: u8 = rhs[i]
    if left_byte == right_byte:
        return 0
    if left_byte < right_byte:
        return -1
    return 1
