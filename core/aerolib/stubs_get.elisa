def GetStub(nid: static u8&) -> u64:
    if UsedStubEntries >= MAX_STUBS:
        return AeroLib_UnknownStub.uintptr().u64()

    index: u32 = UsedStubEntries
    entry: NidEntry? = FindByNid(nid)
    if entry == null:
        stub_nids_unknown[index.usize()] <- nid
    else:
        stub_nids[index.usize()] <- entry

    UsedStubEntries <- UsedStubEntries + 1
    return AeroLib_StubHandlerAddress(index)
