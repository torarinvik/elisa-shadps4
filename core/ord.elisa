protocol Ord:
    def le(self: Self, o: Self) -> bool
    law total(a: Self, b: Self) = a.le(b) or b.le(a)
    law antisym(a: Self, b: Self) = (a.le(b) and b.le(a)) implies (a == b)
    law transitive(a: Self, b: Self, c: Self) = (a.le(b) and b.le(c)) implies a.le(c)

def Ord_IsSortedAdjacent[T: Ord](items: darray[T]) -> bool:
    if items.count < 2:
        return true
    i: mutable usize = 1
    while i < items.count:
        if not items[i - 1].le(items[i]):
            return false
        i <- i + 1
    return true

