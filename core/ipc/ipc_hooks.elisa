struct IpcMemoryPatchInfo:
    gameSerial: mutable static u8&
    modNameStr: mutable static u8&
    offsetStr: mutable static u8&
    valueStr: mutable static u8&
    targetStr: mutable static u8&
    sizeStr: mutable static u8&
    isOffset: mutable bool
    littleEndian: mutable bool
    patchMask: mutable int
    maskOffset: mutable int

def IpcMemoryPatchInfo_new() -> IpcMemoryPatchInfo:
    out: IpcMemoryPatchInfo = zeroed
    out.gameSerial <- ""
    out.modNameStr <- ""
    out.offsetStr <- ""
    out.valueStr <- ""
    out.targetStr <- ""
    out.sizeStr <- ""
    out.isOffset <- false
    out.littleEndian <- false
    out.patchMask <- 0
    out.maskOffset <- 0
    return out

def IPC_HookAddMemoryPatch(info: IpcMemoryPatchInfo) -> void:
    _ = info

def IPC_HookPauseGuestThreads() -> void:
    pass

def IPC_HookResumeGuestThreads() -> void:
    pass

def IPC_HookQuit() -> void:
    pass

def IPC_HookToggleFullscreen() -> void:
    pass

def IPC_HookSetVolumeSlider(value: int, is_game_specific: bool) -> void:
    _ = value
    _ = is_game_specific

def IPC_HookAdjustVolume() -> void:
    pass

def IPC_HookSetFsrEnabled(enabled: bool) -> void:
    _ = enabled

def IPC_HookSetRcasEnabled(enabled: bool) -> void:
    _ = enabled

def IPC_HookSetRcasAttenuation(value: int) -> void:
    _ = value

def IPC_HookLoadFigure(path: static u8&, portal: u8, slot: u8) -> void:
    _ = path
    _ = portal
    _ = slot

def IPC_HookRemoveFigure(portal: u8, slot: u8, temporary: bool) -> void:
    _ = portal
    _ = slot
    _ = temporary

def IPC_HookMoveFigure(from_portal: u8, from_slot: u8, to_portal: u8, to_slot: u8) -> void:
    _ = from_portal
    _ = from_slot
    _ = to_portal
    _ = to_slot

def IPC_HookTempRemoveFigure(slot: u8) -> void:
    _ = slot

def IPC_HookCancelRemoveFigure(slot: u8) -> void:
    _ = slot

def IPC_HookReloadInputs(path: static u8&) -> void:
    _ = path
