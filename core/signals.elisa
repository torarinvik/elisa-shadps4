include "../common/types.elisa"

type AccessViolationHandlerPtr = uintptr
type IllegalInstructionHandlerPtr = uintptr

struct SignalHandlerEntry:
    handler: mutable uintptr
    priority: mutable u32

struct SignalDispatch:
    access_handlers: mutable darray[SignalHandlerEntry]
    illegal_handlers: mutable darray[SignalHandlerEntry]

global mutable signal_dispatch_singleton: SignalDispatch = SignalDispatch([], [])

def SignalDispatch_New() -> SignalDispatch:
    return SignalDispatch([], [])

def Signals_GetInstance() -> mutable SignalDispatch&:
    return signal_dispatch_singleton.ref[mutable SignalDispatch&]

def Signals_Reset() -> void:
    signal_dispatch_singleton.access_handlers.clear()
    signal_dispatch_singleton.illegal_handlers.clear()

def SignalDispatch_RegisterAccessViolationHandler(self: mutable SignalDispatch&, handler: AccessViolationHandlerPtr, priority: u32) -> void:
    if handler == 0.uintptr():
        return
    self.access_handlers.push(SignalHandlerEntry(handler, priority))
    SignalDispatch_SortByPriority(self.access_handlers)

def SignalDispatch_RegisterIllegalInstructionHandler(self: mutable SignalDispatch&, handler: IllegalInstructionHandlerPtr, priority: u32) -> void:
    if handler == 0.uintptr():
        return
    self.illegal_handlers.push(SignalHandlerEntry(handler, priority))
    SignalDispatch_SortByPriority(self.illegal_handlers)

def SignalDispatch_SortByPriority(entries: mutable darray[SignalHandlerEntry]&) -> void:
    if entries.count < 2:
        return
    i: mutable usize = 0
    while i < entries.count:
        j: mutable usize = i + 1
        while j < entries.count:
            if entries[j].priority < entries[i].priority:
                tmp: SignalHandlerEntry = entries[i]
                entries[i] <- entries[j]
                entries[j] <- tmp
            j <- j + 1
        i <- i + 1

def SignalDispatch_DispatchAccessViolation(self: SignalDispatch&, ctx: void&?, fault_address: void&?) -> bool:
    _ = ctx
    _ = fault_address
    return self.access_handlers.count > 0

def SignalDispatch_DispatchIllegalInstruction(self: SignalDispatch&, ctx: void&?) -> bool:
    _ = ctx
    return self.illegal_handlers.count > 0

def SignalDispatch_AccessHandlerCount(self: SignalDispatch&) -> usize:
    return self.access_handlers.count

def SignalDispatch_IllegalHandlerCount(self: SignalDispatch&) -> usize:
    return self.illegal_handlers.count
