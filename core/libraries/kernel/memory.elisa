include "./lib_function_stub.elisa"

const KERNEL_MEMORY_PAGE_SIZE: u64 = 16 * 1024
const KERNEL_MEMORY_MMAP_FAILED: uintptr = 0.uintptr() - 1.uintptr()

def KernelMemory_Is16KBAligned(value: u64) -> bool:
    return (value % KERNEL_MEMORY_PAGE_SIZE) == 0

def KernelMemory_AlignUp(value: u64, alignment: u64) -> u64:
    if alignment == 0:
        return value
    remainder: u64 = value % alignment
    if remainder == 0:
        return value
    return value + (alignment - remainder)

def KernelMemory_AlignDown(value: u64, alignment: u64) -> u64:
    if alignment == 0:
        return value
    return value - (value % alignment)

def KernelMemory_WriteOutPtr(out_ptr: mutable void&?&, value: void&?) -> void:
    out_ptr <- value

def KernelMemory_MapDirect(addr: mutable void&?&, len: u64, prot: int, flags: int, phys_addr: i64, alignment: u64, name: static u8&) -> int:
    if len == 0 or not KernelMemory_Is16KBAligned(len):
        return ORBIS_KERNEL_ERROR_EINVAL
    if phys_addr < 0 or not KernelMemory_Is16KBAligned(phys_addr.u64()):
        return ORBIS_KERNEL_ERROR_EINVAL
    if alignment != 0 and not KernelMemory_Is16KBAligned(alignment):
        return ORBIS_KERNEL_ERROR_EINVAL
    if (prot.u32() & MemoryProt_CpuExec) != 0u32:
        return ORBIS_KERNEL_ERROR_EACCES
    mapped: mutable VAddr = 0.uintptr()
    result: s32 = MemoryManager_MapMemory(
        Memory_Instance(),
        mapped.ref[mutable VAddr&],
        addr.cast[VAddr],
        len,
        prot.u32(),
        flags.u32(),
        VMAType_Direct,
        name,
        false,
        phys_addr.uintptr(),
        alignment
    )
    if result == 0:
        KernelMemory_WriteOutPtr(addr, mapped.cast[void&?])
        return ORBIS_OK
    return result

def KernelMemory_MapFlexible(addr_in_out: mutable void&?&, len: u64, prot: int, flags: int, name: static u8&) -> int:
    if len == 0 or not KernelMemory_Is16KBAligned(len):
        return ORBIS_KERNEL_ERROR_EINVAL
    mapped: mutable VAddr = 0.uintptr()
    result: s32 = MemoryManager_MapMemory(
        Memory_Instance(),
        mapped.ref[mutable VAddr&],
        addr_in_out.cast[VAddr],
        len,
        prot.u32(),
        flags.u32(),
        VMAType_Flexible,
        name,
        false,
        0.uintptr(),
        0
    )
    if result == 0:
        KernelMemory_WriteOutPtr(addr_in_out, mapped.cast[void&?])
        return ORBIS_OK
    return result

def KernelMemory_PosixMmapImpl(addr: void&?, len: u64, prot: int, flags: int, fd: int, phys_addr: i64) -> void&?:
    if len == 0:
        return KERNEL_MEMORY_MMAP_FAILED.cast[void&?]
    vaddr: u64 = addr.cast[u64]
    aligned_addr: VAddr = KernelMemory_AlignUp(vaddr, KERNEL_MEMORY_PAGE_SIZE).uintptr()
    aligned_size: u64 = KernelMemory_AlignUp(len, KERNEL_MEMORY_PAGE_SIZE)
    map_flags: MemoryMapFlags = flags.u32()
    if (map_flags & MemoryMapFlags_Fixed) != 0u32 and vaddr != aligned_addr.u64():
        return KERNEL_MEMORY_MMAP_FAILED.cast[void&?]
    mapped: mutable VAddr = 0.uintptr()
    result: mutable s32 = 0
    if (map_flags & MemoryMapFlags_Anon) != 0u32:
        result <- MemoryManager_MapMemory(Memory_Instance(), mapped.ref[mutable VAddr&], aligned_addr, aligned_size, prot.u32(), map_flags, VMAType_Flexible, "anon", false, 0.uintptr(), 0)
    elif (map_flags & MemoryMapFlags_Stack) != 0u32:
        result <- MemoryManager_MapMemory(Memory_Instance(), mapped.ref[mutable VAddr&], aligned_addr, aligned_size, prot.u32(), map_flags, VMAType_Stack, "anon", false, 0.uintptr(), 0)
    elif (map_flags & MemoryMapFlags_Void) != 0u32:
        result <- MemoryManager_MapMemory(Memory_Instance(), mapped.ref[mutable VAddr&], aligned_addr, aligned_size, MemoryProt_NoAccess, map_flags, VMAType_Reserved, "anon", false, 0.uintptr(), 0)
    else:
        result <- MemoryManager_MapFile(Memory_Instance(), mapped.ref[mutable VAddr&], aligned_addr, aligned_size, prot.u32(), map_flags, fd.s32(), phys_addr)
    if result != 0:
        return KERNEL_MEMORY_MMAP_FAILED.cast[void&?]
    return mapped.cast[void&?]

