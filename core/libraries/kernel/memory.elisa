# @port core/libraries/kernel/memory.cpp::sceKernelMapNamedDirectMemory sha256=8e2d640ff32f5849 oracle@a3773841
def sceKernelMapNamedDirectMemory(addr: mutable void&?&, len: u64, prot: int, flags: int, phys_addr: i64, alignment: u64, name: u8&?) -> int:
    if name == null:
        return ORBIS_KERNEL_ERROR_EFAULT
    # The guest name pointer is directly addressable as host memory (same as
    # other guest string params, e.g. KernelFile_Open); pass it through to the
    # VMA instead of hardcoding "anon". The strlen >= 32 -> ENAMETOOLONG check
    # lives in KernelMemory_MapDirect to preserve the oracle's validation order.
    return KernelMemory_MapDirect(addr, len, prot, flags, phys_addr, alignment, name.cast[static u8&])

# @port core/libraries/kernel/memory.cpp::sceKernelMapDirectMemory sha256=68881a2372bf212d oracle@a3773841
def sceKernelMapDirectMemory(addr: mutable void&?&, len: u64, prot: int, flags: int, phys_addr: i64, alignment: u64) -> int can[Unsafe.SegmentMutation, Segment.Host]:
    can Unsafe.SegmentMutation, Segment.Host:
        ge_emergency_mark(GE_EV_HLE_KNOWN_TARGET, 0x444d4d42u64.uintptr(), addr.cast[void&].uintptr(), KernelMemory_ReadInOutPtr(addr), len.uintptr())
    # Oracle: `return sceKernelMapNamedDirectMemory(addr, len, prot, flags, phys_addr, alignment, "anon");`
    result: int = sceKernelMapNamedDirectMemory(addr, len, prot, flags, phys_addr, alignment, "anon")
    kernel_debug_last_direct_map_result <- result
    kernel_debug_last_direct_map_addr <- KernelMemory_ReadInOutPtr(addr)
    kernel_debug_last_direct_map_phys <- phys_addr
    kernel_debug_last_direct_map_len <- len
    can Unsafe.SegmentMutation, Segment.Host:
        ge_emergency_mark(GE_EV_HLE_KNOWN_TARGET, 0x444d4d45u64.uintptr(), result.u64().uintptr(), addr.cast[void&].uintptr(), KernelMemory_ReadInOutPtr(addr))
    return result

