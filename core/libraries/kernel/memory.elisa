    return ORBIS_OK

def sceKernelGetDirectMemoryType(addr: u64, directMemoryTypeOut: void&?, directMemoryStartOut: void&?, directMemoryEndOut: void&?) -> int:
    out_type: mutable int&? = directMemoryTypeOut as mutable int&?
    out_start: mutable i64&? = directMemoryStartOut as mutable i64&?
    out_end: mutable i64&? = directMemoryEndOut as mutable i64&?
    if out_type == null or out_start == null or out_end == null:
        return ORBIS_KERNEL_ERROR_EFAULT
    direct_base: u64 = KERNEL_DIRECT_MEMORY_BASE
    direct_end: u64 = KERNEL_DIRECT_MEMORY_BASE + MemoryManager_GetTotalDirectSize(Memory_Instance())
    if addr < direct_base or addr >= direct_end:
        return ORBIS_KERNEL_ERROR_EINVAL
    out_type[0] <- KERNEL_DIRECT_MEMORY_TYPE_DEFAULT
    out_start[0] <- direct_base.i64()
    out_end[0] <- direct_end.i64()
    return ORBIS_OK

def sceKernelGetDirectMemorySize() -> u64:
    return MemoryManager_GetTotalDirectSize(Memory_Instance())

