    return ORBIS_OK

def sceKernelMmap(addr: void&?, len: u64, prot: int, flags: int, fd: int, phys_addr: i64, res: mutable void&?&) -> int:
    mapped: void&? = KernelMemory_PosixMmapImpl(addr, len, prot, flags, fd, phys_addr)
    if mapped == KERNEL_MEMORY_MMAP_FAILED.cast[void&?]:
        return ORBIS_KERNEL_ERROR_EINVAL
    KernelMemory_WriteOutPtr(res, mapped)
    return ORBIS_OK

def sceKernelMunmap(addr: void&?, len: u64) -> int:
    if len == 0:
        return ORBIS_KERNEL_ERROR_EINVAL
    if addr == null or not KernelMemory_Is16KBAligned(addr.cast[u64]) or not KernelMemory_Is16KBAligned(len):
        return ORBIS_KERNEL_ERROR_EINVAL
    return MemoryManager_UnmapMemory(Memory_Instance(), addr.cast[VAddr], len)

def sceKernelMapNamedFlexibleMemory(addr_in_out: mutable void&?&, len: u64, prot: int, flags: int, name: u8&?) -> int:
    if name == null:
        return ORBIS_KERNEL_ERROR_EFAULT
    return KernelMemory_MapFlexible(addr_in_out, len, prot, flags, "anon")

