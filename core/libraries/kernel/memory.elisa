    return result

def sceKernelQueryMemoryProtection(addr: void&?, start: mutable void&?&, end: mutable void&?&, prot: mutable u32&) -> int:
    start_addr: mutable VAddr = 0.uintptr()
    end_addr: mutable VAddr = 0.uintptr()
    out_prot: mutable u32 = 0u32
    result: s32 = MemoryManager_QueryProtection(Memory_Instance(), addr.cast[VAddr], start_addr.ref[mutable VAddr&], end_addr.ref[mutable VAddr&], out_prot.ref[mutable u32&])
    if result != 0:
        return result
    start <- start_addr.cast[void&?]
    end <- end_addr.cast[void&?]
    prot <- out_prot
    return ORBIS_OK

def sceKernelDirectMemoryQuery(offset: u64, flags: int, query_info: void&?, infoSize: u64) -> int:
    out: mutable OrbisQueryInfo&? = query_info as mutable OrbisQueryInfo&?
    if out == null or infoSize < size_of(OrbisQueryInfo).u64():
        can Unsafe.SegmentMutation, Segment.Host:
            ge_emergency_mark(GE_EV_HLE_KNOWN_TARGET, GuestExec_RuntimeHleGuestReturnAddr(), offset.uintptr(), ORBIS_KERNEL_ERROR_EFAULT.u64().uintptr(), query_info.uintptr())
        return ORBIS_KERNEL_ERROR_EFAULT
    if offset >= MemoryManager_GetTotalDirectSize(Memory_Instance()):
        can Unsafe.SegmentMutation, Segment.Host:
            ge_emergency_mark(GE_EV_HLE_KNOWN_TARGET, GuestExec_RuntimeHleGuestReturnAddr(), offset.uintptr(), ORBIS_KERNEL_ERROR_EACCES.u64().uintptr(), query_info.uintptr())
        return ORBIS_KERNEL_ERROR_EACCES
    find_next: bool = flags == 1
    best_index: mutable s32 = -1
    best_base: mutable u64 = 0xffffffffffffffffu64
    memory: mutable MemoryManager& = Memory_Instance()
    for i in 0..<memory.dmem_areas.count:
        area: PhysicalMemoryArea = memory.dmem_areas[i]
        area_start: u64 = area.base.u64()
        area_end: u64 = area_start + area.size
        if offset >= area_start and offset < area_end:
            if area.dma_type != PhysicalMemoryType_Free:
                best_index <- i.s32()
                best_base <- area_start
            elif find_next:
                j: mutable usize = i + 1usize
                while j < memory.dmem_areas.count and best_index < 0:
                    next_area: PhysicalMemoryArea = memory.dmem_areas[j]
                    if next_area.dma_type != PhysicalMemoryType_Free:
                        best_index <- j.s32()
                        best_base <- next_area.base.u64()
                    j <- j + 1usize
        elif find_next and area.dma_type != PhysicalMemoryType_Free and area_start > offset and area_start < best_base:
            best_index <- i.s32()
            best_base <- area_start
    if best_index < 0:
        can Unsafe.SegmentMutation, Segment.Host:
            ge_emergency_mark(GE_EV_HLE_KNOWN_TARGET, GuestExec_RuntimeHleGuestReturnAddr(), offset.uintptr(), ORBIS_KERNEL_ERROR_EACCES.u64().uintptr(), query_info.uintptr())
        return ORBIS_KERNEL_ERROR_EACCES
    selected: mutable PhysicalMemoryArea = memory.dmem_areas[best_index.usize()]
    out.start <- selected.base
    out.memoryType <- selected.memory_type
    out.end <- selected.base + selected.size.uintptr()
    j: mutable usize = best_index.usize() + 1
    while j < memory.dmem_areas.count:
        next_area: PhysicalMemoryArea = memory.dmem_areas[j]
        if next_area.memory_type != out.memoryType:
            break
        if next_area.dma_type != PhysicalMemoryType_Allocated and next_area.dma_type != PhysicalMemoryType_Mapped:
            break
        out.end <- next_area.base + next_area.size.uintptr()
        j <- j + 1
    can Unsafe.SegmentMutation, Segment.Host:
        ge_emergency_mark(GE_EV_HLE_KNOWN_TARGET, GuestExec_RuntimeHleGuestReturnAddr(), offset.uintptr(), ORBIS_OK.u64().uintptr(), query_info.uintptr())
        ge_emergency_mark(GE_EV_HLE_KNOWN_TARGET, 0x444d5159.uintptr(), offset.uintptr(), out.start, out.end)
        ge_emergency_mark(GE_EV_HLE_KNOWN_TARGET, 0x444d5154.uintptr(), offset.uintptr(), out.memoryType.u64().uintptr(), flags.u64().uintptr())
    return ORBIS_OK

def HLE_sceKernelDirectMemoryQuery(offset: u64, flags: int, query_info: void&?, infoSize: u64) -> int:
    result: mutable int = 0
    can Unsafe.SegmentMutation, Segment.Host:
        result <- sceKernelDirectMemoryQuery(offset, flags, query_info, infoSize)
    return result

def sceKernelReleaseDirectMemory(start: u64, len: u64) -> int:
