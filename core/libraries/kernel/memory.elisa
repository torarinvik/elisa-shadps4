const KERNEL_MEMORY_PAGE_SIZE: u64 = 16 * 1024
const KERNEL_MEMORY_MMAP_FAILED: uintptr = 0.uintptr() - 1.uintptr()
const KERNEL_DIRECT_MEMORY_TYPE_DEFAULT: int = 0
const KERNEL_DIRECT_MEMORY_BASE: u64 = 0u64
const ORBIS_KERNEL_MAP_FIXED_FLAG: int = 0x10
const ORBIS_KERNEL_MAP_OP_MAP_DIRECT: s32 = 0
const ORBIS_KERNEL_MAP_OP_UNMAP: s32 = 1
const ORBIS_KERNEL_MAP_OP_PROTECT: s32 = 2
const ORBIS_KERNEL_MAP_OP_MAP_FLEXIBLE: s32 = 3
const ORBIS_KERNEL_MAP_OP_TYPE_PROTECT: s32 = 4

@fixed_layout
struct OrbisKernelBatchMapEntry:
    start: mutable void&?
    offset: u64
    length: u64
    protection: u8
    type: u8
    reserved: s16
    operation: s32

@fixed_layout
@abi_layout(size, 24, align, 8, field, start, 0, field, end, 8, field, memoryType, 16)
struct OrbisQueryInfo:
    start: mutable uintptr
    end: mutable uintptr
    memoryType: mutable s32

def KernelMemory_Is16KBAligned(value: u64) -> bool:
    return (value % KERNEL_MEMORY_PAGE_SIZE) == 0

def KernelMemory_AlignUp(value: u64, alignment: u64) -> u64:
    if alignment == 0:
        return value
    remainder: u64 = value % alignment
    if remainder == 0:
        return value
    return value + (alignment - remainder)

def KernelMemory_AlignDown(value: u64, alignment: u64) -> u64:
    if alignment == 0:
        return value
    return value - (value % alignment)

def KernelMemory_WriteOutPtr(out_ptr: mutable void&?&, value: void&?) -> void:
    out_ptr[0] <- value

def KernelMemory_WriteOutI64(out_ptr: void&?, value: i64) -> bool:
    if out_ptr == null:
        return false
    # Guest out-pointers must update both the native execution mapping and the
    # AddressSpace backing. Internal loader calls pass host-stack pointers, so
    # fall back to a plain store when the address is not guest-backed.
    if MemoryManager_WriteU64(Memory_Instance(), out_ptr.uintptr(), value.u64()):
        return true
    raw: mutable i64&? = out_ptr as mutable i64&?
    if raw == null:
        return false
    raw[0] <- value
    return true

def KernelMemory_ReadInOutPtr(in_out_ptr: mutable void&?&) -> VAddr:
    if in_out_ptr[0] == null:
        return 0.uintptr()
    return in_out_ptr[0].uintptr()

global mutable g_kernel_direct_alloc_cursor: u64 = KERNEL_DIRECT_MEMORY_BASE
global mutable kernel_debug_last_direct_alloc_result: int = 0
global mutable kernel_debug_last_direct_alloc_phys: i64 = 0
global mutable kernel_debug_last_direct_alloc_len: u64 = 0
global mutable kernel_debug_last_direct_map_result: int = 0
global mutable kernel_debug_last_direct_map_addr: uintptr = 0.uintptr()
global mutable kernel_debug_last_direct_map_phys: i64 = 0
global mutable kernel_debug_last_direct_map_len: u64 = 0

def KernelMemory_MapDirect(addr: mutable void&?&, len: u64, prot: int, flags: int, phys_addr: i64, alignment: u64, name: static u8&) -> int:
    if len == 0 or not KernelMemory_Is16KBAligned(len):
        return ORBIS_KERNEL_ERROR_EINVAL
    if phys_addr < 0 or not KernelMemory_Is16KBAligned(phys_addr.u64()):
        return ORBIS_KERNEL_ERROR_EINVAL
    if alignment != 0 and not KernelMemory_Is16KBAligned(alignment):
        return ORBIS_KERNEL_ERROR_EINVAL
    if (prot.u32() & MemoryProt_CpuExec) != 0u32:
        return ORBIS_KERNEL_ERROR_EACCES
    mapped: mutable VAddr = 0.uintptr()
    result: s32 = MemoryManager_MapMemory(
        Memory_Instance(),
        mapped.ref[mutable VAddr&],
        KernelMemory_ReadInOutPtr(addr),
        len,
        prot.u32(),
        flags.u32(),
        VMAType_Direct,
        name,
        false,
        phys_addr.uintptr(),
        alignment
    )
    if result == 0:
        if not MemoryManager_MarkDirectMapped(Memory_Instance(), phys_addr.uintptr(), len, 0):
            _ = MemoryManager_UnmapMemory(Memory_Instance(), mapped, len)
            return ORBIS_KERNEL_ERROR_EACCES
        KernelMemory_WriteOutPtr(addr, mapped.cast[void&?])
        return ORBIS_OK
    return result

def KernelMemory_MapFlexible(addr_in_out: mutable void&?&, len: u64, prot: int, flags: int, name: static u8&) -> int:
    if len == 0 or not KernelMemory_Is16KBAligned(len):
        return ORBIS_KERNEL_ERROR_EINVAL
    mapped: mutable VAddr = 0.uintptr()
    result: s32 = MemoryManager_MapMemory(
        Memory_Instance(),
        mapped.ref[mutable VAddr&],
        KernelMemory_ReadInOutPtr(addr_in_out),
        len,
        prot.u32(),
        flags.u32(),
        VMAType_Flexible,
        name,
        false,
        0.uintptr(),
        0
    )
    if result == 0:
        KernelMemory_WriteOutPtr(addr_in_out, mapped.cast[void&?])
        return ORBIS_OK
    return result

def KernelMemory_PosixMmapImpl(addr: void&?, len: u64, prot: int, flags: int, fd: int, phys_addr: i64) -> void&?:
    if len == 0:
        return KERNEL_MEMORY_MMAP_FAILED.cast[void&?]
    vaddr: u64 = addr.cast[u64]
    aligned_addr: VAddr = KernelMemory_AlignUp(vaddr, KERNEL_MEMORY_PAGE_SIZE).uintptr()
    aligned_size: u64 = KernelMemory_AlignUp(len, KERNEL_MEMORY_PAGE_SIZE)
    map_flags: MemoryMapFlags = flags.u32()
    if (map_flags & MemoryMapFlags_Fixed) != 0u32 and vaddr != aligned_addr.u64():
        return KERNEL_MEMORY_MMAP_FAILED.cast[void&?]
    mapped: mutable VAddr = 0.uintptr()
    result: mutable s32 = 0
    if (map_flags & MemoryMapFlags_Anon) != 0u32:
        result <- MemoryManager_MapMemory(Memory_Instance(), mapped.ref[mutable VAddr&], aligned_addr, aligned_size, prot.u32(), map_flags, VMAType_Flexible, "anon", false, 0.uintptr(), 0)
    elif (map_flags & MemoryMapFlags_Stack) != 0u32:
        result <- MemoryManager_MapMemory(Memory_Instance(), mapped.ref[mutable VAddr&], aligned_addr, aligned_size, prot.u32(), map_flags, VMAType_Stack, "anon", false, 0.uintptr(), 0)
    elif (map_flags & MemoryMapFlags_Void) != 0u32:
        result <- MemoryManager_MapMemory(Memory_Instance(), mapped.ref[mutable VAddr&], aligned_addr, aligned_size, MemoryProt_NoAccess, map_flags, VMAType_Reserved, "anon", false, 0.uintptr(), 0)
    else:
        result <- MemoryManager_MapFile(Memory_Instance(), mapped.ref[mutable VAddr&], aligned_addr, aligned_size, prot.u32(), map_flags, fd.s32(), phys_addr)
    if result != 0:
        return KERNEL_MEMORY_MMAP_FAILED.cast[void&?]
    return mapped.cast[void&?]

def sceKernelEnableDmemAliasing() -> int:
    return ORBIS_OK

def sceKernelAllocateDirectMemory(searchStart: i64, searchEnd: i64, len: u64, alignment: u64, memoryType: int, physAddrOut: void&?) -> int:
    can Unsafe.SegmentMutation, Segment.Host:
        ge_emergency_mark(GE_EV_HLE_KNOWN_TARGET, 0x444d4142u64.uintptr(), searchStart.u64().uintptr(), searchEnd.u64().uintptr(), len.uintptr())
    if physAddrOut == null:
        can Unsafe.SegmentMutation, Segment.Host:
            ge_emergency_mark(GE_EV_HLE_KNOWN_TARGET, 0x444d4145u64.uintptr(), ORBIS_KERNEL_ERROR_EFAULT.u64().uintptr(), physAddrOut.uintptr(), 0.uintptr())
        return ORBIS_KERNEL_ERROR_EFAULT
    if len == 0 or not KernelMemory_Is16KBAligned(len):
        can Unsafe.SegmentMutation, Segment.Host:
            ge_emergency_mark(GE_EV_HLE_KNOWN_TARGET, 0x444d4145u64.uintptr(), ORBIS_KERNEL_ERROR_EINVAL.u64().uintptr(), len.uintptr(), alignment.uintptr())
        return ORBIS_KERNEL_ERROR_EINVAL
    if alignment != 0 and not KernelMemory_Is16KBAligned(alignment):
        can Unsafe.SegmentMutation, Segment.Host:
            ge_emergency_mark(GE_EV_HLE_KNOWN_TARGET, 0x444d4145u64.uintptr(), ORBIS_KERNEL_ERROR_EINVAL.u64().uintptr(), len.uintptr(), alignment.uintptr())
        return ORBIS_KERNEL_ERROR_EINVAL
    if searchEnd <= searchStart:
        can Unsafe.SegmentMutation, Segment.Host:
            ge_emergency_mark(GE_EV_HLE_KNOWN_TARGET, 0x444d4145u64.uintptr(), ORBIS_KERNEL_ERROR_EINVAL.u64().uintptr(), searchStart.u64().uintptr(), searchEnd.u64().uintptr())
        return ORBIS_KERNEL_ERROR_EINVAL
    _ = memoryType
    align: mutable u64 = alignment
    if align == 0:
        align <- KERNEL_MEMORY_PAGE_SIZE
    min_addr: mutable u64 = KERNEL_DIRECT_MEMORY_BASE
    if searchStart > 0:
        min_addr <- searchStart.u64()
    alloc_start: mutable u64 = KernelMemory_AlignUp(g_kernel_direct_alloc_cursor, align)
    if alloc_start < min_addr:
        alloc_start <- KernelMemory_AlignUp(min_addr, align)
    alloc_end: u64 = alloc_start + len
    if alloc_end <= alloc_start:
        kernel_debug_last_direct_alloc_result <- ORBIS_KERNEL_ERROR_ENOMEM
        kernel_debug_last_direct_alloc_phys <- 0
        kernel_debug_last_direct_alloc_len <- len
        can Unsafe.SegmentMutation, Segment.Host:
            ge_emergency_mark(GE_EV_HLE_KNOWN_TARGET, 0x444d4145u64.uintptr(), ORBIS_KERNEL_ERROR_ENOMEM.u64().uintptr(), alloc_start.uintptr(), len.uintptr())
        return ORBIS_KERNEL_ERROR_ENOMEM
    if alloc_end > searchEnd.u64():
        kernel_debug_last_direct_alloc_result <- ORBIS_KERNEL_ERROR_ENOMEM
        kernel_debug_last_direct_alloc_phys <- 0
        kernel_debug_last_direct_alloc_len <- len
        can Unsafe.SegmentMutation, Segment.Host:
            ge_emergency_mark(GE_EV_HLE_KNOWN_TARGET, 0x444d4145u64.uintptr(), ORBIS_KERNEL_ERROR_ENOMEM.u64().uintptr(), alloc_end.uintptr(), searchEnd.u64().uintptr())
        return ORBIS_KERNEL_ERROR_ENOMEM
    allocated: PAddr = MemoryManager_Allocate(Memory_Instance(), alloc_start.uintptr(), searchEnd.u64().uintptr(), len, align, memoryType)
    if allocated == searchEnd.u64().uintptr():
        kernel_debug_last_direct_alloc_result <- ORBIS_KERNEL_ERROR_ENOMEM
        kernel_debug_last_direct_alloc_phys <- 0
        kernel_debug_last_direct_alloc_len <- len
        can Unsafe.SegmentMutation, Segment.Host:
            ge_emergency_mark(GE_EV_HLE_KNOWN_TARGET, 0x444d4145u64.uintptr(), ORBIS_KERNEL_ERROR_ENOMEM.u64().uintptr(), alloc_start.uintptr(), searchEnd.u64().uintptr())
        return ORBIS_KERNEL_ERROR_ENOMEM
    if not KernelMemory_WriteOutI64(physAddrOut, allocated.u64().i64()):
        kernel_debug_last_direct_alloc_result <- ORBIS_KERNEL_ERROR_EFAULT
        kernel_debug_last_direct_alloc_phys <- allocated.u64().i64()
        kernel_debug_last_direct_alloc_len <- len
        can Unsafe.SegmentMutation, Segment.Host:
            ge_emergency_mark(GE_EV_HLE_KNOWN_TARGET, 0x444d4145u64.uintptr(), ORBIS_KERNEL_ERROR_EFAULT.u64().uintptr(), physAddrOut.uintptr(), allocated)
        return ORBIS_KERNEL_ERROR_EFAULT
    g_kernel_direct_alloc_cursor <- alloc_end
    kernel_debug_last_direct_alloc_result <- ORBIS_OK
    kernel_debug_last_direct_alloc_phys <- allocated.u64().i64()
    kernel_debug_last_direct_alloc_len <- len
    can Unsafe.SegmentMutation, Segment.Host:
        ge_emergency_mark(GE_EV_HLE_KNOWN_TARGET, 0x444d414fu64.uintptr(), allocated, g_kernel_direct_alloc_cursor.uintptr(), len.uintptr())
    return ORBIS_OK

def HLE_sceKernelAllocateDirectMemory(searchStart: i64, searchEnd: i64, len: u64, alignment: u64, memoryType: int, physAddrOut: void&?) -> int:
    result: mutable int = 0
    can Unsafe.SegmentMutation, Segment.Host:
        result <- sceKernelAllocateDirectMemory(searchStart, searchEnd, len, alignment, memoryType, physAddrOut)
    return result

def sceKernelAllocateMainDirectMemory(len: u64, alignment: u64, memoryType: int, physAddrOut: void&?) -> int can[Unsafe.SegmentMutation, Segment.Host]:
    result: mutable int = 0
    can Unsafe.SegmentMutation, Segment.Host:
        result <- sceKernelAllocateDirectMemory(KERNEL_DIRECT_MEMORY_BASE.i64(), (KERNEL_DIRECT_MEMORY_BASE + MemoryManager_GetTotalDirectSize(Memory_Instance())).i64(), len, alignment, memoryType, physAddrOut)
    return result

def sceKernelAvailableDirectMemorySize(searchStart: u64, searchEnd: u64, alignment: u64, physAddrOut: void&?, sizeOut: void&?) -> int:
    out_phys: mutable i64&? = physAddrOut as mutable i64&?
    out_size: mutable u64&? = sizeOut as mutable u64&?
    if out_phys == null or out_size == null:
        return ORBIS_KERNEL_ERROR_EFAULT
    if searchEnd <= searchStart:
        return ORBIS_KERNEL_ERROR_EINVAL
    if alignment != 0 and not KernelMemory_Is16KBAligned(alignment):
        return ORBIS_KERNEL_ERROR_EINVAL
    align: mutable u64 = alignment
    if align == 0:
        align <- KERNEL_MEMORY_PAGE_SIZE
    start: mutable u64 = KernelMemory_AlignUp(searchStart, align)
    if start < g_kernel_direct_alloc_cursor:
        start <- KernelMemory_AlignUp(g_kernel_direct_alloc_cursor, align)
    if start >= searchEnd:
        out_phys[0] <- 0
        out_size[0] <- 0u64
        return ORBIS_OK
    out_phys[0] <- start.i64()
    out_size[0] <- KernelMemory_AlignDown(searchEnd - start, KERNEL_MEMORY_PAGE_SIZE)
    return ORBIS_OK

def sceKernelCheckedReleaseDirectMemory(start: u64, len: u64) -> int:
    _ = start
    _ = len
    return ORBIS_OK

def sceKernelVirtualQuery(addr: void&?, flags: int, info: void&?, infoSize: u64) -> int:
