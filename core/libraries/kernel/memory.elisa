def sceKernelMapDirectMemory2(addr: mutable void&?&, len: u64, type: int, prot: int, flags: int, phys_addr: i64, alignment: u64) -> int:
    _ = type
    result: int = KernelMemory_MapDirect(addr, len, prot, flags, phys_addr, alignment, "anon")
    if result == ORBIS_KERNEL_ERROR_EACCES:
