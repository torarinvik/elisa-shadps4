global mutable kernel_debug_heap_api_func: uintptr = 0.uintptr()
global mutable kernel_debug_heap_api_return_addr: uintptr = 0.uintptr()
global mutable kernel_application_heap_bootstrap_done: bool = false

def KernelMemory_BootstrapApplicationHeapDirectArena() -> void can[Unsafe.SegmentMutation, Segment.Host]:
    if kernel_application_heap_bootstrap_done:
        return
    kernel_application_heap_bootstrap_done <- true
    g_kernel_direct_alloc_cursor <- KERNEL_DIRECT_MEMORY_BASE
    direct_size: mutable u64 = 0u64
    can Unsafe.SegmentMutation, Segment.Host:
        direct_size <- sceKernelGetDirectMemorySize()
    heap_direct_size: u64 = 0xc0000000u64
    if direct_size < heap_direct_size:
        return
    phys_addr: mutable i64 = 0i64
    alloc: mutable int = 0
    can Unsafe.SegmentMutation, Segment.Host:
        alloc <- sceKernelAllocateDirectMemory(0i64, direct_size.i64(), heap_direct_size, 0x200000u64, 0, phys_addr.ref[mutable i64&].cast[void&?])
    if alloc != ORBIS_OK:
        can Unsafe.SegmentMutation, Segment.Host:
            ge_emergency_mark(GE_EV_HLE_KNOWN_TARGET, GuestExec_RuntimeHleGuestReturnAddr(), 0x48454150.uintptr(), alloc.u64().uintptr(), direct_size.uintptr())
        return
    mapped_addr: mutable void&? = null
    map_result: mutable int = 0
    can Unsafe.SegmentMutation, Segment.Host:
        map_result <- sceKernelMapDirectMemory(mapped_addr.ref[mutable void&?&], heap_direct_size, 0x33, 0, phys_addr, 0x200000u64)
    can Unsafe.SegmentMutation, Segment.Host:
        ge_emergency_mark(GE_EV_HLE_KNOWN_TARGET, GuestExec_RuntimeHleGuestReturnAddr(), 0x48454150.uintptr(), phys_addr.u64().uintptr(), mapped_addr.uintptr())
        ge_emergency_mark(GE_EV_HLE_KNOWN_TARGET, GuestExec_RuntimeHleGuestReturnAddr(), 0x48454151.uintptr(), map_result.u64().uintptr(), direct_size.uintptr())

def _sceKernelRtldSetApplicationHeapAPI(func: void&?) -> void can[Unsafe.SegmentMutation, Segment.Host]:
    kernel_debug_heap_api_func <- func.uintptr()
    kernel_debug_heap_api_return_addr <- GuestExec_RuntimeHleGuestReturnAddr()
    Linker_SetHeapAPI(func)
    GuestExec_RecordFirstBoundary(GUEST_EXEC_BOUNDARY_REASON_NATIVE_HLE)
    can Unsafe.SegmentMutation, Segment.Host:
        GuestExec_RecordRuntimeHle("libkernel", "_sceKernelRtldSetApplicationHeapAPI", func.uintptr(), 0.uintptr(), 0.uintptr(), 0.uintptr())
    return

def Kernel_DebugHeapApiFunc() -> uintptr:
    return kernel_debug_heap_api_func

def Kernel_DebugHeapApiReturnAddr() -> uintptr:
    return kernel_debug_heap_api_return_addr

def sceKernelBatchMap(entries: void&?, numEntries: int, numEntriesOut: void&?) -> int can[Unsafe.SegmentMutation, Segment.Host]:
    can Unsafe.SegmentMutation, Segment.Host:
        return sceKernelBatchMap2(entries, numEntries, numEntriesOut, ORBIS_KERNEL_MAP_FIXED_FLAG)

def sceKernelBatchMap2(entries: void&?, numEntries: int, numEntriesOut: void&?, flags: int) -> int can[Unsafe.SegmentMutation, Segment.Host]:
    processed: mutable s32 = 0
    result: mutable int = ORBIS_OK
    out: mutable s32&? = numEntriesOut as mutable s32&?
    batch: mutable OrbisKernelBatchMapEntry&? = entries as mutable OrbisKernelBatchMapEntry&?
    if numEntries < 0:
        if out != null:
            out[0] <- 0
        return ORBIS_KERNEL_ERROR_EINVAL
    i: mutable int = 0
    while i < numEntries:
        if batch == null:
            result <- ORBIS_KERNEL_ERROR_EINVAL
            break
        entry: mutable OrbisKernelBatchMapEntry& = batch[i].ref[mutable OrbisKernelBatchMapEntry&]
        if entry.length == 0 or entry.operation > ORBIS_KERNEL_MAP_OP_TYPE_PROTECT:
            result <- ORBIS_KERNEL_ERROR_EINVAL
            break
        processed <- processed + 1
        if entry.operation == ORBIS_KERNEL_MAP_OP_MAP_DIRECT:
            result <- sceKernelMapNamedDirectMemory(entry.start.ref[mutable void&?&], entry.length, entry.protection.int(), flags, entry.offset.i64(), 0u64, "anon")
        elif entry.operation == ORBIS_KERNEL_MAP_OP_UNMAP:
            result <- sceKernelMunmap(entry.start, entry.length)
        elif entry.operation == ORBIS_KERNEL_MAP_OP_PROTECT:
            result <- sceKernelMprotect(entry.start, entry.length, entry.protection.int())
        elif entry.operation == ORBIS_KERNEL_MAP_OP_MAP_FLEXIBLE:
            can Unsafe.SegmentMutation, Segment.Host:
                result <- sceKernelMapNamedFlexibleMemory(entry.start.ref[mutable void&?&], entry.length, entry.protection.int(), flags, "anon")
        elif entry.operation == ORBIS_KERNEL_MAP_OP_TYPE_PROTECT:
            result <- sceKernelMtypeprotect(entry.start, entry.length, entry.type.int(), entry.protection.int())
        else:
            result <- ORBIS_KERNEL_ERROR_EINVAL
        if result != ORBIS_OK:
            break
        i <- i + 1
    if out != null:
        out[0] <- processed
    return result

