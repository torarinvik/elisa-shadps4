    _ = addr
    _ = start
    _ = end
    return ORBIS_OK

def sceKernelIsAddressSanitizerEnabled() -> u32:
    return 0u32

def sceKernelMapNamedDirectMemory(addr: mutable void&?&, len: u64, prot: int, flags: int, phys_addr: i64, alignment: u64, name: u8&?) -> int:
    if name == null:
        return ORBIS_KERNEL_ERROR_EFAULT
    return KernelMemory_MapDirect(addr, len, prot, flags, phys_addr, alignment, "anon")

def sceKernelMapDirectMemory(addr: mutable void&?&, len: u64, prot: int, flags: int, phys_addr: i64, alignment: u64) -> int:
    return KernelMemory_MapDirect(addr, len, prot, flags, phys_addr, alignment, "anon")

def sceKernelMapDirectMemory2(addr: mutable void&?&, len: u64, type: int, prot: int, flags: int, phys_addr: i64, alignment: u64) -> int:
    _ = type
    result: int = KernelMemory_MapDirect(addr, len, prot, flags, phys_addr, alignment, "anon")
    if result == ORBIS_KERNEL_ERROR_EACCES:
        return ORBIS_KERNEL_ERROR_EINVAL
    return result

def sceKernelQueryMemoryProtection(addr: void&?, start: mutable void&?&, end: mutable void&?&, prot: mutable u32&) -> int:
    start_addr: mutable VAddr = 0.uintptr()
    end_addr: mutable VAddr = 0.uintptr()
    out_prot: mutable u32 = 0u32
    result: s32 = MemoryManager_QueryProtection(Memory_Instance(), addr.cast[VAddr], start_addr.ref[mutable VAddr&], end_addr.ref[mutable VAddr&], out_prot.ref[mutable u32&])
    if result != 0:
        return result
    start <- start_addr.cast[void&?]
    end <- end_addr.cast[void&?]
    prot <- out_prot
    return ORBIS_OK

def sceKernelDirectMemoryQuery(offset: u64, flags: int, query_info: void&?, infoSize: u64) -> int:
    _ = offset
    _ = flags
    _ = query_info
    _ = infoSize
    return ORBIS_OK

def sceKernelReleaseDirectMemory(start: u64, len: u64) -> int:
