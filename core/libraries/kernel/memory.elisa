# @port core/libraries/kernel/memory.cpp::sceKernelMprotect sha256=1698af0d16929ced oracle@a3773841
def sceKernelMprotect(addr: void&?, size: u64, prot: int) -> int:
    in_addr: u64 = addr.cast[u64]
    aligned_addr: VAddr = KernelMemory_AlignDown(in_addr, KERNEL_MEMORY_PAGE_SIZE).uintptr()
    aligned_size: u64 = KernelMemory_AlignUp(size + in_addr - aligned_addr.u64(), KERNEL_MEMORY_PAGE_SIZE)
    if aligned_size == 0:
        return ORBIS_OK
    result: s32 = MemoryManager_Protect(Memory_Instance(), aligned_addr, aligned_size, prot.u32())
    if result == ORBIS_OK:
        MemoryManager_InvalidateMemory(Memory_Instance(), aligned_addr, aligned_size)
    return result

