def KernelMemory_BootstrapApplicationHeapDirectArena() -> void can[Unsafe.SegmentMutation, Segment.Host]:
    if kernel_application_heap_bootstrap_done:
        return
    kernel_application_heap_bootstrap_done <- true
    direct_size: mutable u64 = 0u64
    can Unsafe.SegmentMutation, Segment.Host:
        direct_size <- sceKernelGetDirectMemorySize()
    heap_direct_size: u64 = 0xc0000000u64
    if direct_size < heap_direct_size:
        return
    phys_addr: mutable i64 = 0i64
    alloc: mutable int = 0
    can Unsafe.SegmentMutation, Segment.Host:
        alloc <- sceKernelAllocateDirectMemory(0i64, direct_size.i64(), heap_direct_size, 0x200000u64, 0, phys_addr.ref[mutable i64&].cast[void&?])
    if alloc != ORBIS_OK:
        can Unsafe.SegmentMutation, Segment.Host:
            ge_emergency_mark(GE_EV_HLE_KNOWN_TARGET, GuestExec_RuntimeHleGuestReturnAddr(), 0x48454150.uintptr(), alloc.u64().uintptr(), direct_size.uintptr())
        return
    mapped_addr: mutable void&? = null
    map_result: mutable int = 0
    can Unsafe.SegmentMutation, Segment.Host:
        map_result <- sceKernelMapDirectMemory(mapped_addr, heap_direct_size, 0x33, 0, phys_addr, 0x200000u64)
    can Unsafe.SegmentMutation, Segment.Host:
        ge_emergency_mark(GE_EV_HLE_KNOWN_TARGET, GuestExec_RuntimeHleGuestReturnAddr(), 0x48454150.uintptr(), phys_addr.u64().uintptr(), mapped_addr.uintptr())
        ge_emergency_mark(GE_EV_HLE_KNOWN_TARGET, GuestExec_RuntimeHleGuestReturnAddr(), 0x48454151.uintptr(), map_result.u64().uintptr(), direct_size.uintptr())

