def sceKernelAioSubmitWriteCommandsMultiple(req: void&?, size: int, prio: int, id: void&?) -> int:
    _ = prio
    requests: mutable OrbisKernelAioRWRequest&? = req as mutable OrbisKernelAioRWRequest&?
    out_ids: mutable int&? = id as mutable int&?
    if requests == null:
        return ORBIS_KERNEL_ERROR_EFAULT
    if out_ids == null:
        return ORBIS_KERNEL_ERROR_EFAULT
    if size < 0:
        return ORBIS_KERNEL_ERROR_EINVAL
    out: mutable int& = out_ids

    i: mutable int = 0
    while i < size:
        item: OrbisKernelAioRWRequest = requests[i.usize()]
        if item.result == null:
            return ORBIS_KERNEL_ERROR_EFAULT
        submit_id: int = aio_next_submit_id()
        aio_id_state[submit_id.usize()] <- ORBIS_KERNEL_AIO_STATE_PROCESSING

        retv: i64 = sceKernelPwrite(item.fd, item.buf, item.nbyte.u64(), item.offset)
        out_result: mutable OrbisKernelAioResult&? = item.result as mutable OrbisKernelAioResult&?
        if out_result != null:
            r: mutable OrbisKernelAioResult& = out_result
            if retv < 0:
                r.state <- ORBIS_KERNEL_AIO_STATE_ABORTED.u32()
                r.returnValue <- retv
                aio_id_state[submit_id.usize()] <- ORBIS_KERNEL_AIO_STATE_ABORTED
            else:
                r.state <- ORBIS_KERNEL_AIO_STATE_COMPLETED.u32()
                r.returnValue <- retv
                aio_id_state[submit_id.usize()] <- ORBIS_KERNEL_AIO_STATE_COMPLETED
        out[i.usize()] <- submit_id
        i <- i + 1
    return 0

def sceKernelAioSetParam() -> int:
    return ORBIS_OK

def sceKernelAioInitializeParam() -> int:
    return ORBIS_OK

def RegisterAio(sym: void&?) -> void:
    _ = sym
    aio_id_index <- 1
    i: mutable int = 0
    while i < AIO_MAX_QUEUE:
        aio_id_state[i.usize()] <- 0
        i <- i + 1

    LIB_FUNCTION("fR521KIGgb8", "libkernel", 1, "libkernel", sceKernelAioCancelRequest)
    LIB_FUNCTION("3Lca1XBrQdY", "libkernel", 1, "libkernel", sceKernelAioCancelRequests)
    LIB_FUNCTION("5TgME6AYty4", "libkernel", 1, "libkernel", sceKernelAioDeleteRequest)
    LIB_FUNCTION("Ft3EtsZzAoY", "libkernel", 1, "libkernel", sceKernelAioDeleteRequests)
    LIB_FUNCTION("vYU8P9Td2Zo", "libkernel", 1, "libkernel", sceKernelAioInitializeImpl)
    LIB_FUNCTION("nu4a0-arQis", "libkernel", 1, "libkernel", sceKernelAioInitializeParam)
    LIB_FUNCTION("2pOuoWoCxdk", "libkernel", 1, "libkernel", sceKernelAioPollRequest)
    LIB_FUNCTION("o7O4z3jwKzo", "libkernel", 1, "libkernel", sceKernelAioPollRequests)
    LIB_FUNCTION("9WK-vhNXimw", "libkernel", 1, "libkernel", sceKernelAioSetParam)
    LIB_FUNCTION("HgX7+AORI58", "libkernel", 1, "libkernel", sceKernelAioSubmitReadCommands)
    LIB_FUNCTION("lXT0m3P-vs4", "libkernel", 1, "libkernel", sceKernelAioSubmitReadCommandsMultiple)
    LIB_FUNCTION("XQ8C8y+de+E", "libkernel", 1, "libkernel", sceKernelAioSubmitWriteCommands)
    LIB_FUNCTION("xT3Cpz0yh6Y", "libkernel", 1, "libkernel", sceKernelAioSubmitWriteCommandsMultiple)
    LIB_FUNCTION("KOF-oJbQVvc", "libkernel", 1, "libkernel", sceKernelAioWaitRequest)
    LIB_FUNCTION("lgK+oIWkJyA", "libkernel", 1, "libkernel", sceKernelAioWaitRequests)
