# --- linux_boot_bridge time wrappers (native Elisa) ---
# Replace former core/linux_boot_bridge_time.c. Reuse kt_clock_gettime
# (@link_name(clock_gettime)) + KtTimespec already declared in this file.
const LBB_CLOCK_MONOTONIC: int = 1

def posix_clock_gettime_ns() -> u64:
    ts: mutable KtTimespec = zeroed
    _ = kt_clock_gettime(LBB_CLOCK_MONOTONIC, (&ts).cast[void&])
    return ts.tv_sec.u64() * 1000000000u64 + ts.tv_nsec.u64()

def high_resolution_now_ns() -> i64:
    ts: mutable KtTimespec = zeroed
    _ = kt_clock_gettime(LBB_CLOCK_MONOTONIC, (&ts).cast[void&])
    return ts.tv_sec * 1000000000i64 + ts.tv_nsec

def FencedRDTSC() -> u64:
    ts: mutable KtTimespec = zeroed
    _ = kt_clock_gettime(LBB_CLOCK_MONOTONIC, (&ts).cast[void&])
    return ts.tv_sec.u64() * 1000000000u64 + ts.tv_nsec.u64()
