    can Memory.Release:
        return kt_mutex_destroy(handle)
@c_abi(c)
def elisa_kernel_mutex_lock(handle: void&?) -> int:
    can Sync.Lock:
        return kt_mutex_lock(handle)
@c_abi(c)
