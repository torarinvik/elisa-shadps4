extern elisa_kernel_thread_detach(handle: void&?) -> int
extern elisa_kernel_thread_cancel(handle: void&?) -> int

const ORBIS_KERNEL_PRIO_FIFO_DEFAULT: int = 700
const ORBIS_KERNEL_PRIO_FIFO_LOWEST: int = 256
const ORBIS_KERNEL_PRIO_FIFO_HIGHEST: int = 767
const ORBIS_KERNEL_PRIO_OTHER_DEFAULT: int = 900
const ORBIS_KERNEL_PRIO_OTHER_LOWEST: int = 768
const ORBIS_KERNEL_PRIO_OTHER_HIGHEST: int = 959
const ORBIS_KERNEL_PRIO_RR_DEFAULT: int = 700
const ORBIS_KERNEL_PRIO_RR_LOWEST: int = 256
const ORBIS_KERNEL_PRIO_RR_HIGHEST: int = 767

const PTHREAD_INHERIT_SCHED: int = 4
const PTHREAD_STACK_MIN: u64 = 0x4000u64
const PTHREAD_SCOPE_PROCESS: int = 0
const PTHREAD_SCOPE_SYSTEM: int = 2
const PTHREAD_DETACHED: int = 1
const POSIX_PTHREAD_CANCELED_VALUE: int = 1

type ThreadDtorsFunc = func() -> void

@fixed_layout
struct SchedParam:
    sched_priority: mutable int

@fixed_layout
struct PthreadAttr:
    sched_policy: mutable int
    sched_inherit: mutable int
    prio: mutable int
    suspend: mutable int
    flags: mutable int
    stackaddr_attr: mutable void&?
    stacksize_attr: mutable u64
    guardsize_attr: mutable u64
    cpusetsize: mutable u64
    cpuset: mutable void&?

global mutable g_default_attr: PthreadAttr = PthreadAttr(2, PTHREAD_INHERIT_SCHED, ORBIS_KERNEL_PRIO_FIFO_DEFAULT, 0, PTHREAD_SCOPE_SYSTEM, null, 0x100000u64, 0u64, 0u64, null)

def posix_sched_get_priority_max(policy: int) -> int:
    if policy == 1 or policy == 3:
        return ORBIS_KERNEL_PRIO_FIFO_HIGHEST
    if policy == 2:
        return ORBIS_KERNEL_PRIO_OTHER_HIGHEST
    return -1

def posix_sched_get_priority_min(policy: int) -> int:
    if policy == 1 or policy == 3:
        return ORBIS_KERNEL_PRIO_FIFO_LOWEST
    if policy == 2:
        return ORBIS_KERNEL_PRIO_OTHER_LOWEST
    return -1

def threads_sched_priority_valid(policy: int, prio: int) -> bool:
    if policy == 1 or policy == 3:
        return prio >= ORBIS_KERNEL_PRIO_FIFO_LOWEST and prio <= ORBIS_KERNEL_PRIO_FIFO_HIGHEST
    return true

def posix_getpid() -> int:
    return getpid()

def threads_orbis_from_posix(ret: int) -> int:
    if ret == 0:
        return 0
    return threads_posix_to_orbis_errno(ret)

def posix_pthread_attr_init(attr: mutable PthreadAttr&?&) -> int:
    if attr == null:
        return POSIX_EINVAL
    local: mutable PthreadAttr = g_default_attr
    attr[0] <- local
    return 0

def posix_pthread_attr_destroy(attr: mutable PthreadAttr&?&) -> int:
    if attr == null or attr[0] == null:
        return POSIX_EINVAL
    attr[0] <- null
    return 0

def posix_pthread_attr_getdetachstate(attr: PthreadAttr&?, detachstate: mutable int&) -> int:
    if attr == null:
        return POSIX_EINVAL
    if (attr.flags & PTHREAD_DETACHED) != 0:
        detachstate <- 1
    else:
        detachstate <- 0
    return 0

def posix_pthread_attr_setdetachstate(attr: mutable PthreadAttr&?, detachstate: int) -> int:
    if attr == null or (detachstate != 0 and detachstate != 1):
        return POSIX_EINVAL
    if detachstate == 1:
        attr.flags <- attr.flags | PTHREAD_DETACHED
    else:
        attr.flags <- attr.flags & ~PTHREAD_DETACHED
    return 0

def posix_pthread_attr_getguardsize(attr: PthreadAttr&?, guardsize: mutable u64&) -> int:
    if attr == null:
        return POSIX_EINVAL
    guardsize <- attr.guardsize_attr
    return 0

def posix_pthread_attr_setguardsize(attr: mutable PthreadAttr&?, guardsize: u64) -> int:
    if attr == null:
        return POSIX_EINVAL
    attr.guardsize_attr <- guardsize
    return 0

def posix_pthread_attr_getinheritsched(attr: PthreadAttr&?, sched_inherit: mutable int&) -> int:
    if attr == null:
        return POSIX_EINVAL
    sched_inherit <- attr.sched_inherit
    return 0

def posix_pthread_attr_setinheritsched(attr: mutable PthreadAttr&?, sched_inherit: int) -> int:
    if attr == null:
        return POSIX_EINVAL
    if sched_inherit != PTHREAD_INHERIT_SCHED and sched_inherit != 0:
        return POSIX_ENOTSUP
    attr.sched_inherit <- sched_inherit
    return 0

def posix_pthread_attr_getschedparam(attr: PthreadAttr&?, param: mutable SchedParam&?) -> int:
    if attr == null or param == null:
        return POSIX_EINVAL
    param.sched_priority <- attr.prio
    return 0

def posix_pthread_attr_setschedparam(attr: mutable PthreadAttr&?, param: SchedParam&?) -> int:
    if attr == null:
        return POSIX_EINVAL
    if param == null:
        return POSIX_ENOTSUP
    if not threads_sched_priority_valid(attr.sched_policy, param.sched_priority):
        return POSIX_ENOTSUP
    attr.prio <- param.sched_priority
    return 0

def posix_pthread_attr_getschedpolicy(attr: PthreadAttr&?, policy: mutable int&) -> int:
    if attr == null:
        return POSIX_EINVAL
    policy <- attr.sched_policy
    return 0

def posix_pthread_attr_setschedpolicy(attr: mutable PthreadAttr&?, policy: int) -> int:
    if attr == null:
        return POSIX_EINVAL
    if policy < 1 or policy > 3:
        return POSIX_ENOTSUP
    attr.sched_policy <- policy
    if policy == 2:
        attr.prio <- ORBIS_KERNEL_PRIO_OTHER_DEFAULT
    else:
        attr.prio <- ORBIS_KERNEL_PRIO_FIFO_DEFAULT
    return 0

def posix_pthread_attr_getscope(attr: PthreadAttr&?, contentionscope: mutable int&) -> int:
    if attr == null:
        return POSIX_EINVAL
    if (attr.flags & PTHREAD_SCOPE_SYSTEM) != 0:
        contentionscope <- PTHREAD_SCOPE_SYSTEM
    else:
        contentionscope <- PTHREAD_SCOPE_PROCESS
    return 0

def posix_pthread_attr_setscope(attr: mutable PthreadAttr&?, contentionscope: int) -> int:
    if attr == null:
        return POSIX_EINVAL
    # Match C++ parity: original condition uses `||` and always returns EINVAL.
    if contentionscope != PTHREAD_SCOPE_PROCESS or contentionscope != PTHREAD_SCOPE_SYSTEM:
        return POSIX_EINVAL
    if contentionscope == PTHREAD_SCOPE_SYSTEM:
        attr.flags <- attr.flags | PTHREAD_SCOPE_SYSTEM
    else:
        attr.flags <- attr.flags & ~PTHREAD_SCOPE_SYSTEM
    return 0

def posix_pthread_attr_getstack(attr: PthreadAttr&?, stackaddr: mutable void&?&, stacksize: mutable u64&) -> int:
    if attr == null:
        return POSIX_EINVAL
    stackaddr[0] <- attr.stackaddr_attr
    stacksize <- attr.stacksize_attr
    return 0

def posix_pthread_attr_setstack(attr: mutable PthreadAttr&?, stackaddr: void&?, stacksize: u64) -> int:
    if attr == null or stackaddr == null or stacksize < PTHREAD_STACK_MIN:
        return POSIX_EINVAL
    attr.stackaddr_attr <- stackaddr
    attr.stacksize_attr <- stacksize
    return 0

def posix_pthread_attr_getstackaddr(attr: PthreadAttr&?, stackaddr: mutable void&?&) -> int:
    if attr == null:
        return POSIX_EINVAL
    stackaddr[0] <- attr.stackaddr_attr
    return 0

def posix_pthread_attr_setstackaddr(attr: mutable PthreadAttr&?, stackaddr: void&?) -> int:
    if attr == null or stackaddr == null:
        return POSIX_EINVAL
    attr.stackaddr_attr <- stackaddr
    return 0

def posix_pthread_attr_getstacksize(attr: PthreadAttr&?, stacksize: mutable u64&) -> int:
    if attr == null:
        return POSIX_EINVAL
    stacksize <- attr.stacksize_attr
    return 0

def posix_pthread_attr_setstacksize(attr: mutable PthreadAttr&?, stacksize: u64) -> int:
    if attr == null or stacksize < PTHREAD_STACK_MIN:
        return POSIX_EINVAL
    attr.stacksize_attr <- stacksize
    return 0

def posix_pthread_attr_get_np(pthread: void&?, dstattr: mutable PthreadAttr&?) -> int:
    threads_bootstrap_runtime()
    if pthread == null or dstattr == null:
        return POSIX_EINVAL
    id: mutable int = threads_handle_to_id(pthread)
    if threads_is_current_self_handle(pthread):
        id <- g_fake_thread_id
    if not threads_is_valid_live_thread_id(id):
        return POSIX_ESRCH
    dstattr <- g_default_attr
    if g_fake_threads_detached[id]:
        dstattr.flags <- dstattr.flags | PTHREAD_DETACHED
    return 0

def posix_pthread_attr_setcreatesuspend_np(attr: mutable PthreadAttr&?) -> int:
    if attr == null:
        return POSIX_EINVAL
    attr.suspend <- 1
    return 0

def posix_pthread_attr_getaffinity_np(pattr: PthreadAttr&?, cpusetsize: u64, cpusetp: mutable void&?) -> int:
    _ = cpusetsize
    if pattr == null:
        return POSIX_EINVAL
    if cpusetp != null:
        mask: mutable u64&? = cpusetp as mutable u64&?
        if mask != null:
            if pattr.cpuset == null:
                mask[0] <- 0xffffffffffffffffu64
            else:
                source: u64&? = pattr.cpuset as u64&?
                if source != null:
                    mask[0] <- source[0]
    return 0

def posix_pthread_attr_setaffinity_np(pattr: mutable PthreadAttr&?, cpusetsize: u64, cpusetp: void&?) -> int:
    if pattr == null:
        return POSIX_EINVAL
    if cpusetsize == 0u64 or cpusetp == null:
        pattr.cpusetsize <- 0u64
        pattr.cpuset <- null
        return 0
    pattr.cpusetsize <- cpusetsize
    pattr.cpuset <- cpusetp
    return 0

def scePthreadAttrGetaffinity(attr: PthreadAttr&?, mask: mutable u64&) -> int:
    local_mask: mutable u64 = 0u64
    ret: int = posix_pthread_attr_getaffinity_np(attr, 8u64, local_mask as mutable void&?)
    if ret == 0:
        mask <- local_mask
    return threads_orbis_from_posix(ret)

def scePthreadAttrSetaffinity(attr: mutable PthreadAttr&?, mask: u64) -> int:
    local_mask: mutable u64 = mask
    return threads_orbis_from_posix(posix_pthread_attr_setaffinity_np(attr, 8u64, local_mask as void&?))

def scePthreadAttrInit(attr: mutable PthreadAttr&?&) -> int:
    return threads_orbis_from_posix(posix_pthread_attr_init(attr))

def scePthreadAttrDestroy(attr: mutable PthreadAttr&?&) -> int:
    return threads_orbis_from_posix(posix_pthread_attr_destroy(attr))

def scePthreadAttrGetNp(thread: void&?, attr: mutable PthreadAttr&?) -> int:
    return threads_orbis_from_posix(posix_pthread_attr_get_np(thread, attr))

def scePthreadAttrGetdetachstate(attr: PthreadAttr&?, detachstate: mutable int&) -> int:
    return threads_orbis_from_posix(posix_pthread_attr_getdetachstate(attr, detachstate))

def scePthreadAttrGetguardsize(attr: PthreadAttr&?, guardsize: mutable u64&) -> int:
    return threads_orbis_from_posix(posix_pthread_attr_getguardsize(attr, guardsize))

def scePthreadAttrGetinheritsched(attr: PthreadAttr&?, sched_inherit: mutable int&) -> int:
    return threads_orbis_from_posix(posix_pthread_attr_getinheritsched(attr, sched_inherit))

def scePthreadAttrGetschedparam(attr: PthreadAttr&?, param: mutable SchedParam&?) -> int:
    return threads_orbis_from_posix(posix_pthread_attr_getschedparam(attr, param))

def scePthreadAttrGetschedpolicy(attr: PthreadAttr&?, policy: mutable int&) -> int:
    return threads_orbis_from_posix(posix_pthread_attr_getschedpolicy(attr, policy))

def scePthreadAttrGetscope(attr: PthreadAttr&?, contentionscope: mutable int&) -> int:
    return threads_orbis_from_posix(posix_pthread_attr_getscope(attr, contentionscope))

def scePthreadAttrGetstack(attr: PthreadAttr&?, stackaddr: mutable void&?&, stacksize: mutable u64&) -> int:
    return threads_orbis_from_posix(posix_pthread_attr_getstack(attr, stackaddr, stacksize))

def scePthreadAttrGetstackaddr(attr: PthreadAttr&?, stackaddr: mutable void&?&) -> int:
    return threads_orbis_from_posix(posix_pthread_attr_getstackaddr(attr, stackaddr))

def scePthreadAttrGetstacksize(attr: PthreadAttr&?, stacksize: mutable u64&) -> int:
    return threads_orbis_from_posix(posix_pthread_attr_getstacksize(attr, stacksize))

def scePthreadAttrSetcreatesuspend(attr: mutable PthreadAttr&?) -> int:
    return threads_orbis_from_posix(posix_pthread_attr_setcreatesuspend_np(attr))

def scePthreadAttrSetdetachstate(attr: mutable PthreadAttr&?, detachstate: int) -> int:
    return threads_orbis_from_posix(posix_pthread_attr_setdetachstate(attr, detachstate))

def scePthreadAttrSetguardsize(attr: mutable PthreadAttr&?, guardsize: u64) -> int:
    return threads_orbis_from_posix(posix_pthread_attr_setguardsize(attr, guardsize))

def scePthreadAttrSetinheritsched(attr: mutable PthreadAttr&?, sched_inherit: int) -> int:
    return threads_orbis_from_posix(posix_pthread_attr_setinheritsched(attr, sched_inherit))

def scePthreadAttrSetschedparam(attr: mutable PthreadAttr&?, param: SchedParam&?) -> int:
    return threads_orbis_from_posix(posix_pthread_attr_setschedparam(attr, param))

def scePthreadAttrSetschedpolicy(attr: mutable PthreadAttr&?, policy: int) -> int:
    return threads_orbis_from_posix(posix_pthread_attr_setschedpolicy(attr, policy))

def scePthreadAttrSetscope(attr: mutable PthreadAttr&?, contentionscope: int) -> int:
    return threads_orbis_from_posix(posix_pthread_attr_setscope(attr, contentionscope))

def scePthreadAttrSetstack(attr: mutable PthreadAttr&?, stackaddr: void&?, stacksize: u64) -> int:
    return threads_orbis_from_posix(posix_pthread_attr_setstack(attr, stackaddr, stacksize))

def scePthreadAttrSetstackaddr(attr: mutable PthreadAttr&?, stackaddr: void&?) -> int:
    return threads_orbis_from_posix(posix_pthread_attr_setstackaddr(attr, stackaddr))

def scePthreadAttrSetstacksize(attr: mutable PthreadAttr&?, stacksize: u64) -> int:
    return threads_orbis_from_posix(posix_pthread_attr_setstacksize(attr, stacksize))

@fixed_layout
struct PthreadOnce:
    state: mutable int

global mutable g_fake_thread_id: int = 1
global mutable g_fake_sched_policy: int = 2
global mutable g_fake_sched_prio: int = ORBIS_KERNEL_PRIO_FIFO_DEFAULT
global mutable g_fake_cancel_enable: bool = true
global mutable g_fake_cancel_pending: bool = false
global mutable g_fake_cancelling: bool = false
global mutable g_fake_affinity_mask: u64 = 0xffffffffffffffffu64
const FAKE_THREADS_MAX: int = 256
global mutable g_fake_threads_bootstrapped: bool = false
global mutable g_fake_threads_alive: bool[FAKE_THREADS_MAX]
global mutable g_fake_threads_detached: bool[FAKE_THREADS_MAX]
global mutable g_fake_threads_has_joiner: bool[FAKE_THREADS_MAX]
global mutable g_fake_threads_retval: void&?[FAKE_THREADS_MAX]
global mutable g_fake_threads_host_handle: void&?[FAKE_THREADS_MAX]
global mutable g_fake_threads_host_backed: bool[FAKE_THREADS_MAX]
global mutable g_fake_next_thread_id: int = 2
global mutable g_fake_thread_dtors: void&? = null
global mutable g_fake_threads_exited: bool[FAKE_THREADS_MAX]
global mutable g_fake_threads_autocomplete: bool = true
global mutable g_fake_threads_running: bool[FAKE_THREADS_MAX]

def threads_bootstrap_runtime() -> void:
    if g_fake_threads_bootstrapped:
        return
    g_fake_threads_bootstrapped <- true
    g_fake_threads_alive[1] <- true

def threads_handle_to_id(thread: void&?) -> int:
    i: mutable int = 1
    trusted Unsafe.AssumeProgress:
        while i < FAKE_THREADS_MAX:
            if g_fake_threads_alive[i] and g_fake_threads_host_handle[i] == thread:
                return i
            i <- i + 1
    return thread as int

def threads_handle_for_id(id: int) -> void&?:
    if id > 0 and id < FAKE_THREADS_MAX and g_fake_threads_host_handle[id] != null:
        return g_fake_threads_host_handle[id]
    return id as void&?

def threads_native_handle_for_call(id: int, thread: void&?) -> void&?:
    if id > 0 and id < FAKE_THREADS_MAX and g_fake_threads_host_backed[id]:
        return elisa_kernel_thread_native(g_fake_threads_host_handle[id])
    return thread

def threads_is_valid_live_thread_id(id: int) -> bool:
    if id <= 0 or id >= FAKE_THREADS_MAX:
        return false
    return g_fake_threads_alive[id]

def threads_is_current_self_handle(thread: void&?) -> bool:
    self_thread: void&? = posix_pthread_self()
    return thread != null and self_thread != null and posix_pthread_equal(thread, self_thread) == 1

def posix_pthread_once(once_control: mutable PthreadOnce&?, init_routine: void&?) -> int:
    threads_bootstrap_runtime()
    if once_control == null or init_routine == null:
        return POSIX_EINVAL
    if once_control.state != 1:
        once_control.state <- 1
    return 0

def posix_pthread_equal(thread1: void&?, thread2: void&?) -> int:
    threads_bootstrap_runtime()
    if thread1 != null and thread2 != null:
        host_eq: int = pthread_equal(thread1, thread2)
        if host_eq != 0:
            return 1
    if thread1 == thread2:
        return 1
    return 0

def posix_pthread_self() -> void&?:
    threads_bootstrap_runtime()
    host_tid: void&? = pthread_self()
    if host_tid != null:
        return host_tid
    return g_fake_thread_id as void&?

def posix_pthread_yield() -> int:
    return sched_yield()

def posix_pthread_detach(pthread: void&?) -> int:
    threads_bootstrap_runtime()
    if pthread == null:
        return POSIX_EINVAL
    id: mutable int = threads_handle_to_id(pthread)
    if threads_is_current_self_handle(pthread):
        id <- g_fake_thread_id
    if not threads_is_valid_live_thread_id(id):
        return POSIX_ESRCH
    if g_fake_threads_detached[id] or g_fake_threads_has_joiner[id]:
        return POSIX_EINVAL
    if g_fake_threads_exited[id]:
        g_fake_threads_alive[id] <- false
        g_fake_threads_running[id] <- false
    host_handle: void&? = threads_handle_for_id(id)
    if g_fake_threads_host_backed[id]:
        host_res: int = elisa_kernel_thread_detach(host_handle)
        if host_res != 0:
            return host_res
    else:
        _ = pthread_detach(host_handle)
    g_fake_threads_detached[id] <- true
    return 0

def posix_pthread_exit(status: void&?) -> void:
    threads_bootstrap_runtime()
    if g_fake_cancelling:
        return
    g_fake_cancelling <- true
    g_fake_cancel_enable <- false
    g_fake_cancel_pending <- false
    g_fake_threads_retval[g_fake_thread_id] <- status
    g_fake_threads_exited[g_fake_thread_id] <- true
    threads_run_cleanup_handlers()
    if g_fake_thread_dtors != null:
        dtors_fn: ThreadDtorsFunc = g_fake_thread_dtors.cast[ThreadDtorsFunc]
        dtors_fn()
    threads_cleanup_specific()
    g_fake_threads_alive[g_fake_thread_id] <- false
    g_fake_cancelling <- false
    return

def posix_pthread_join(pthread: void&?, thread_return: mutable void&?&) -> int:
    threads_bootstrap_runtime()
    _ = thread_return
    if pthread == null:
        return POSIX_EINVAL
    id: mutable int = threads_handle_to_id(pthread)
    if threads_is_current_self_handle(pthread):
        id <- g_fake_thread_id
    if id == g_fake_thread_id:
        return POSIX_EDEADLK
    if not threads_is_valid_live_thread_id(id):
        return POSIX_ESRCH
    if g_fake_threads_detached[id]:
        return POSIX_EINVAL
    if g_fake_threads_has_joiner[id]:
        return POSIX_ENOTSUP
    if g_fake_threads_running[id] and not g_fake_threads_exited[id] and not g_fake_threads_host_backed[id]:
        return POSIX_ETIMEDOUT
    host_ret: mutable void&? = null
    if g_fake_threads_host_backed[id]:
        host_res: int = elisa_kernel_thread_join(threads_handle_for_id(id), host_ret)
        if host_res != 0:
            return host_res
        g_fake_threads_retval[id] <- host_ret
    g_fake_threads_has_joiner[id] <- true
    if thread_return != null:
        thread_return[0] <- g_fake_threads_retval[id]
    g_fake_threads_alive[id] <- false
    g_fake_threads_running[id] <- false
    g_fake_threads_detached[id] <- true
    g_fake_threads_has_joiner[id] <- false
    g_fake_threads_exited[id] <- false
    g_fake_threads_retval[id] <- null
    g_fake_threads_host_handle[id] <- null
    g_fake_threads_host_backed[id] <- false
    return 0

def posix_pthread_timedjoin_np(pthread: void&?, thread_return: mutable void&?&, abstime: void&?) -> int:
    if pthread == null:
        return POSIX_EINVAL
    if threads_is_current_self_handle(pthread) or threads_handle_to_id(pthread) == g_fake_thread_id:
        return POSIX_EDEADLK
    if abstime == null:
        return POSIX_EINVAL
    ts: OrbisKernelTimespec&? = abstime as OrbisKernelTimespec&?
    if ts == null or ts.tv_sec < 0 or ts.tv_nsec < 0 or ts.tv_nsec >= 1000000000:
        return POSIX_EINVAL
    id: mutable int = threads_handle_to_id(pthread)
    if threads_is_current_self_handle(pthread):
        id <- g_fake_thread_id
    if not threads_is_valid_live_thread_id(id):
        return POSIX_ESRCH
    if g_fake_threads_detached[id]:
        return POSIX_EINVAL
    if g_fake_threads_has_joiner[id]:
        return POSIX_ENOTSUP
    if g_fake_threads_host_backed[id]:
        host_ret: mutable void&? = null
        # Match current C++ behavior: timed join shares join path and does not enforce timeout.
        host_res: int = elisa_kernel_thread_join(threads_handle_for_id(id), host_ret)
        if host_res != 0:
            return host_res
        g_fake_threads_retval[id] <- host_ret
        if thread_return != null:
            thread_return[0] <- g_fake_threads_retval[id]
        g_fake_threads_alive[id] <- false
        g_fake_threads_running[id] <- false
        g_fake_threads_detached[id] <- true
        g_fake_threads_has_joiner[id] <- false
        g_fake_threads_exited[id] <- false
        g_fake_threads_retval[id] <- null
        g_fake_threads_host_handle[id] <- null
        g_fake_threads_host_backed[id] <- false
        return 0
    if not g_fake_threads_exited[id]:
        return POSIX_ETIMEDOUT
    return posix_pthread_join(pthread, thread_return)

def posix_pthread_create(thread: mutable void&?&, attr: void&?, start_routine: void&?, arg: void&?) -> int:
    threads_bootstrap_runtime()
    if thread == null:
        return POSIX_EINVAL
    if g_fake_next_thread_id >= FAKE_THREADS_MAX:
        return POSIX_EAGAIN
    id: int = g_fake_next_thread_id
    g_fake_next_thread_id <- g_fake_next_thread_id + 1
    g_fake_threads_alive[id] <- true
    g_fake_threads_running[id] <- true
    g_fake_threads_detached[id] <- false
    g_fake_threads_has_joiner[id] <- false
    g_fake_threads_retval[id] <- null
    g_fake_threads_host_handle[id] <- null
    g_fake_threads_host_backed[id] <- false
    g_fake_threads_exited[id] <- false
    if attr != null:
        a: PthreadAttr& = attr.cast[PthreadAttr&]
        if (a.flags & PTHREAD_DETACHED) != 0:
            g_fake_threads_detached[id] <- true
    if start_routine != null:
        create_res: mutable int = 0
        host_thread: void&? = elisa_kernel_thread_create(start_routine, arg, create_res)
        if create_res != 0:
            g_fake_threads_alive[id] <- false
            g_fake_threads_running[id] <- false
            g_fake_threads_detached[id] <- false
            g_fake_threads_exited[id] <- false
            return create_res
        g_fake_threads_host_handle[id] <- host_thread
        g_fake_threads_host_backed[id] <- true
        thread[0] <- host_thread
        if g_fake_threads_detached[id]:
            _ = elisa_kernel_thread_detach(host_thread)
        return 0
    if g_fake_threads_autocomplete:
        g_fake_threads_retval[id] <- arg
        g_fake_threads_running[id] <- false
        g_fake_threads_exited[id] <- true
    thread[0] <- id as void&?
    return 0

def posix_pthread_create_name_np(thread: mutable void&?&, attr: void&?, start_routine: void&?, arg: void&?, name: static u8&?) -> int:
    r: int = posix_pthread_create(thread, attr, start_routine, arg)
    if r != 0:
        return r
    if name != null and thread != null and thread[0] != null:
        _ = posix_pthread_rename_np(thread[0], name)
    return 0

def posix_pthread_setcancelstate(state: int, oldstate: mutable int&?) -> int:
    threads_bootstrap_runtime()
    if state != 0 and state != 1:
        return POSIX_EINVAL
    host_old: mutable int = 0
    _ = pthread_setcancelstate(state, host_old)
    if oldstate != null:
        if g_fake_cancel_enable:
            oldstate <- 0
        else:
            oldstate <- 1
    g_fake_cancel_enable <- state == 0
    if g_fake_cancel_enable and g_fake_cancel_pending:
        posix_pthread_exit(POSIX_PTHREAD_CANCELED_VALUE as void&?)
    return 0

def posix_pthread_cancel(thread: void&?) -> int:
    threads_bootstrap_runtime()
    if thread == null:
        return POSIX_EINVAL
    id: mutable int = threads_handle_to_id(thread)
    if threads_is_current_self_handle(thread):
        id <- g_fake_thread_id
    if not threads_is_valid_live_thread_id(id):
        return POSIX_ESRCH
    if id == g_fake_thread_id:
        g_fake_cancel_pending <- true
        if g_fake_cancel_enable:
            posix_pthread_exit(POSIX_PTHREAD_CANCELED_VALUE as void&?)
        return 0
    if g_fake_threads_host_backed[id]:
        host_res: int = elisa_kernel_thread_cancel(threads_handle_for_id(id))
        if host_res != 0:
            return host_res
    g_fake_threads_retval[id] <- POSIX_PTHREAD_CANCELED_VALUE as void&?
    g_fake_threads_exited[id] <- true
    g_fake_threads_running[id] <- false
    return 0

def posix_pthread_testcancel() -> void:
    threads_bootstrap_runtime()
    if g_fake_cancel_enable and g_fake_cancel_pending:
        posix_pthread_exit(POSIX_PTHREAD_CANCELED_VALUE as void&?)
    return

def posix_pthread_setprio(thread: void&?, prio: int) -> int:
    threads_bootstrap_runtime()
    if thread == null:
        return POSIX_EINVAL
    id: mutable int = threads_handle_to_id(thread)
    if threads_is_current_self_handle(thread):
        id <- g_fake_thread_id
    if not threads_is_valid_live_thread_id(id):
        return POSIX_ESRCH
    g_fake_sched_prio <- prio
    return 0

def posix_pthread_rename_np(thread: void&?, name: static u8&?) -> int:
    threads_bootstrap_runtime()
    if thread == null:
        return POSIX_EINVAL
    id: mutable int = threads_handle_to_id(thread)
    if threads_is_current_self_handle(thread):
        id <- g_fake_thread_id
    if not threads_is_valid_live_thread_id(id):
        return POSIX_ESRCH
    self_thread: void&? = posix_pthread_self()
    if name != null and posix_pthread_equal(thread, self_thread) == 1:
        host_r: int = pthread_setname_np(name)
        if host_r != 0:
            return POSIX_EINVAL
    return 0

def posix_pthread_getschedparam(thread: void&?, policy: mutable int&, param: mutable SchedParam&) -> int:
    threads_bootstrap_runtime()
    if thread == null:
        return POSIX_EINVAL
    id: mutable int = threads_handle_to_id(thread)
    if threads_is_current_self_handle(thread):
        id <- g_fake_thread_id
    if not threads_is_valid_live_thread_id(id):
        return POSIX_ESRCH
    host_r: int = pthread_getschedparam(threads_native_handle_for_call(id, thread), policy, param)
    if host_r != 0 and posix_pthread_equal(thread, posix_pthread_self()) == 1:
        return POSIX_EINVAL
    policy <- g_fake_sched_policy
    param.sched_priority <- g_fake_sched_prio
    return 0

def posix_pthread_setschedparam(thread: void&?, policy: int, param: SchedParam&?) -> int:
    threads_bootstrap_runtime()
    if thread == null or param == null:
        return POSIX_EINVAL
    id: mutable int = threads_handle_to_id(thread)
    if threads_is_current_self_handle(thread):
        id <- g_fake_thread_id
    if not threads_is_valid_live_thread_id(id):
        return POSIX_ESRCH
    host_r: int = pthread_setschedparam(threads_native_handle_for_call(id, thread), policy, param as SchedParam&)
    if host_r != 0 and posix_pthread_equal(thread, posix_pthread_self()) == 1:
        return POSIX_EINVAL
    g_fake_sched_policy <- policy
    g_fake_sched_prio <- param.sched_priority
    return 0

def posix_pthread_getaffinity_np(thread: void&?, cpusetsize: u64, cpusetp: mutable void&?) -> int:
    threads_bootstrap_runtime()
    _ = cpusetsize
    _ = cpusetp
    if thread == null:
        return POSIX_EINVAL
    id: mutable int = threads_handle_to_id(thread)
    if threads_is_current_self_handle(thread):
        id <- g_fake_thread_id
    if not threads_is_valid_live_thread_id(id):
        return POSIX_ESRCH
    host_r: int = pthread_getaffinity_np(threads_native_handle_for_call(id, thread), cpusetsize, cpusetp)
    if host_r != 0 and posix_pthread_equal(thread, posix_pthread_self()) == 1:
        return POSIX_EINVAL
    return 0

def posix_pthread_setaffinity_np(thread: void&?, cpusetsize: u64, cpusetp: void&?) -> int:
    threads_bootstrap_runtime()
    _ = cpusetsize
    _ = cpusetp
    if thread == null:
        return POSIX_EINVAL
    id: mutable int = threads_handle_to_id(thread)
    if threads_is_current_self_handle(thread):
        id <- g_fake_thread_id
    if not threads_is_valid_live_thread_id(id):
        return POSIX_ESRCH
    host_r: int = pthread_setaffinity_np(threads_native_handle_for_call(id, thread), cpusetsize, cpusetp)
    if host_r != 0 and posix_pthread_equal(thread, posix_pthread_self()) == 1:
        return POSIX_EINVAL
    return 0

def posix_pthread_getthreadid_np() -> int:
    threads_bootstrap_runtime()
    host_tid: void&? = pthread_self()
    if host_tid != null:
        return host_tid as int
    return g_fake_thread_id

def posix_pthread_getname_np(thread: void&?, name: mutable u8&?) -> int:
    threads_bootstrap_runtime()
    if name == null:
        return POSIX_EINVAL
    if thread == null:
        return POSIX_EINVAL
    id: mutable int = threads_handle_to_id(thread)
    if threads_is_current_self_handle(thread):
        id <- g_fake_thread_id
    if not threads_is_valid_live_thread_id(id):
        return POSIX_ESRCH
    self_thread: void&? = posix_pthread_self()
    if posix_pthread_equal(thread, self_thread) == 1:
        host_r: int = pthread_getname_np(self_thread, name, 32u64)
        if host_r != 0:
            return POSIX_EINVAL
    return 0

def posix_pthread_set_name_np(thread: void&?, name: static u8&?) -> int:
    return posix_pthread_rename_np(thread, name)

def scePthreadGetprio(thread: void&?, priority: mutable int&?) -> int:
    if priority == null:
        return ORBIS_KERNEL_ERROR_EINVAL
    if thread == null:
        return ORBIS_KERNEL_ERROR_ESRCH
    priority <- g_fake_sched_prio
    return 0

def scePthreadGetaffinity(thread: void&?, mask: mutable u64&?) -> int:
    if mask == null:
        return POSIX_EINVAL
    if thread == null:
        return POSIX_EINVAL
    self_thread: void&? = posix_pthread_self()
    if posix_pthread_equal(thread, self_thread) == 1:
        scratch: mutable u64 = g_fake_affinity_mask
        host_r: int = pthread_getaffinity_np(self_thread, 8u64, scratch as mutable void&?)
        if host_r != 0:
            return POSIX_EINVAL
    mask <- g_fake_affinity_mask
    return 0

def scePthreadSetaffinity(thread: void&?, mask: u64) -> int:
    if thread == null:
        return POSIX_EINVAL
    g_fake_affinity_mask <- mask
    self_thread: void&? = posix_pthread_self()
    if posix_pthread_equal(thread, self_thread) == 1:
        scratch: mutable u64 = mask
        host_r: int = pthread_setaffinity_np(self_thread, 8u64, scratch as void&?)
        if host_r != 0:
            return POSIX_EINVAL
    return 0

def scePthreadOnce(once_control: mutable PthreadOnce&?, init_routine: void&?) -> int:
    return threads_orbis_from_posix(posix_pthread_once(once_control, init_routine))

def scePthreadRenameNp(thread: void&?, name: static u8&?) -> int:
    return threads_orbis_from_posix(posix_pthread_rename_np(thread, name))

def scePthreadCreateNameNp(thread: mutable void&?&, attr: void&?, start_routine: void&?, arg: void&?, name: static u8&?) -> int:
    return threads_orbis_from_posix(posix_pthread_create_name_np(thread, attr, start_routine, arg, name))

def scePthreadDetach(thread: void&?) -> int:
    return threads_orbis_from_posix(posix_pthread_detach(thread))

def scePthreadJoin(thread: void&?, thread_return: mutable void&?&) -> int:
    return threads_orbis_from_posix(posix_pthread_join(thread, thread_return))

def scePthreadGetschedparam(thread: void&?, policy: mutable int&, param: mutable SchedParam&) -> int:
    return threads_orbis_from_posix(posix_pthread_getschedparam(thread, policy, param))

def scePthreadSetschedparam(thread: void&?, policy: int, param: SchedParam&) -> int:
    return threads_orbis_from_posix(posix_pthread_setschedparam(thread, policy, param))

def scePthreadGetnameNp(thread: void&?, name: mutable u8&?) -> int:
    return threads_orbis_from_posix(posix_pthread_getname_np(thread, name))

def scePthreadSetprio(thread: void&?, priority: int) -> int:
    return threads_orbis_from_posix(posix_pthread_setprio(thread, priority))

def scePthreadGetaffinityOrbis(thread: void&?, mask: mutable u64&?) -> int:
    return threads_orbis_from_posix(scePthreadGetaffinity(thread, mask))

def scePthreadSetaffinityOrbis(thread: void&?, mask: u64) -> int:
    return threads_orbis_from_posix(scePthreadSetaffinity(thread, mask))

def posix_sched_yield_shim() -> int:
    return sched_yield()

def _sceKernelSetThreadDtors(dtor: void&?) -> void:
    g_fake_thread_dtors <- dtor
    return

def __tls_get_addr(index: void&?) -> void&?:
    _ = index
    return null


