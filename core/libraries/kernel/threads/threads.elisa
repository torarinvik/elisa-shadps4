extern pthread_self() -> void&?
extern pthread_equal(t1: void&?, t2: void&?) -> int
extern pthread_setname_np(name: static u8&) -> int
extern pthread_getname_np(thread: void&?, name: mutable u8&, len: u64) -> int
extern pthread_setcancelstate(state: int, oldstate: mutable int&) -> int
extern pthread_getschedparam(thread: void&?, policy: mutable int&, param: mutable SchedParam&) -> int
extern pthread_setschedparam(thread: void&?, policy: int, param: SchedParam&) -> int
extern pthread_create(thread: mutable void&?&, attr: void&?, start_routine: void&?, arg: void&?) -> int
