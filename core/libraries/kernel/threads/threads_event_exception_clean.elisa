# @port core/libraries/kernel/threads/exception.cpp::sceKernelInstallExceptionHandler sha256=a372be06c6cbfe07 oracle@a3773841
def sceKernelInstallExceptionHandler(signum: int, handler: void&?) -> int:
    if signum < 0 or signum >= 130:
        return ORBIS_KERNEL_ERROR_EINVAL
    if threads_exception_signal_allowed(signum) == false:
        return ORBIS_KERNEL_ERROR_EINVAL
    if g_exception_handlers[signum] != null:
        return ORBIS_KERNEL_ERROR_EAGAIN
    # Guest exception handler function pointer held in the global table for the process lifetime.
    trusted Unsafe.StaleRef:
        g_exception_handlers[signum] <- handler
    return ORBIS_OK

# @port core/libraries/kernel/threads/exception.cpp::sceKernelRemoveExceptionHandler sha256=27ad01157b6c8627 oracle@a3773841
def sceKernelRemoveExceptionHandler(signum: int) -> int:
    if signum < 0 or signum >= 130:
        return ORBIS_KERNEL_ERROR_EINVAL
    if threads_exception_signal_allowed(signum) == false:
        return ORBIS_KERNEL_ERROR_EINVAL
    g_exception_handlers[signum] <- null
    return ORBIS_OK

# @port core/libraries/kernel/threads/exception.cpp::sceKernelRaiseException sha256=74e64e658ba24a84 oracle@a3773841
def sceKernelRaiseException(thread: void&?, signum: int) -> int:
    _ = thread
    if signum != POSIX_SIGUSR1:
        return ORBIS_KERNEL_ERROR_EINVAL
    return ORBIS_OK

# @port core/libraries/kernel/threads/exception.cpp::sceKernelDebugRaiseException sha256=d167bbf6de7c8e6f oracle@a3773841
def sceKernelDebugRaiseException(err_code: int, unk: i64) -> int can[Unsafe.SegmentMutation, Segment.Host]:
    if unk != 0:
        return ORBIS_KERNEL_ERROR_EINVAL
    can Unsafe.SegmentMutation, Segment.Host, Memory.Allocate:
        GuestExec_RecordDebugRaise(err_code, unk)
        GuestExec_RecordRuntimeHle("libkernel", "sceKernelDebugRaiseException", err_code.u64().uintptr(), unk.u64().uintptr(), 0.uintptr(), ORBIS_OK.uintptr())
        GuestExec_AbortGuestFatalHle(err_code.u64().uintptr())
    return ORBIS_OK

# @port core/libraries/kernel/threads/exception.cpp::sceKernelDebugRaiseExceptionOnReleaseMode sha256=c1c38ece4eb6d039 oracle@a3773841
def sceKernelDebugRaiseExceptionOnReleaseMode(err_code: int, unk: i64) -> int can[Unsafe.SegmentMutation, Segment.Host]:
    if unk != 0:
        return ORBIS_KERNEL_ERROR_EINVAL
    can Unsafe.SegmentMutation, Segment.Host, Memory.Allocate:
        GuestExec_RecordDebugRaise(err_code, unk)
        GuestExec_RecordRuntimeHle("libkernel", "sceKernelDebugRaiseExceptionOnReleaseMode", err_code.u64().uintptr(), unk.u64().uintptr(), 0.uintptr(), ORBIS_OK.uintptr())
        GuestExec_AbortGuestFatalHle(err_code.u64().uintptr())
    return ORBIS_OK

