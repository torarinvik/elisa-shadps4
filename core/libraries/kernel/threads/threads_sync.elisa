include "../../error_codes.elisa"
include "../posix_error.elisa"

@fixed_layout
struct PthreadMutexAttr:
    m_type: mutable int
    m_protocol: mutable int
    m_ceiling: mutable int

@fixed_layout
struct PthreadMutex:
    initialized: mutable bool
    locked: mutable bool
    spinloops: mutable int
    yieldloops: mutable int
    m_type: mutable int
    m_protocol: mutable int

@fixed_layout
struct PthreadCondAttr:
    c_pshared: mutable int
    c_clockid: mutable int

@fixed_layout
struct PthreadCond:
    initialized: mutable bool

@fixed_layout
struct PthreadRwlockAttr:
    pshared: mutable int
    type_: mutable int

@fixed_layout
struct PthreadRwlock:
    initialized: mutable bool
    read_count: mutable int
    write_locked: mutable bool

global mutable g_default_mutex_attr: PthreadMutexAttr = PthreadMutexAttr(1, 0, 0)
global mutable g_default_cond_attr: PthreadCondAttr = PthreadCondAttr(0, 0)
global mutable g_default_rwlock_attr: PthreadRwlockAttr = PthreadRwlockAttr(0, 0)

def posix_pthread_mutex_init(mutex: mutable PthreadMutex&?&, mutex_attr: PthreadMutexAttr&?) -> int:
    if mutex == null:
        return POSIX_EINVAL
    attr: mutable PthreadMutexAttr = g_default_mutex_attr
    if mutex_attr != null:
        attr <- mutex_attr
    mutex <- PthreadMutex(true, false, 0, 0, attr.m_type, attr.m_protocol)
    return 0

def scePthreadMutexInit(mutex: mutable PthreadMutex&?&, mutex_attr: PthreadMutexAttr&?, name: static u8&?) -> int:
    _ = name
    return posix_pthread_mutex_init(mutex, mutex_attr)

def posix_pthread_mutex_destroy(mutex: mutable PthreadMutex&?&) -> int:
    if mutex == null or mutex == null:
        return POSIX_EINVAL
    if mutex.locked:
        return POSIX_EBUSY
    mutex <- null
    return 0

def posix_pthread_mutex_trylock(mutex: mutable PthreadMutex&?&) -> int:
    if mutex == null or mutex == null:
        return POSIX_EINVAL
    if mutex.locked:
        return POSIX_EBUSY
    mutex.locked <- true
    return 0

def posix_pthread_mutex_lock(mutex: mutable PthreadMutex&?&) -> int:
    return posix_pthread_mutex_trylock(mutex)

def posix_pthread_mutex_timedlock(mutex: mutable PthreadMutex&?&, abstime: void&?) -> int:
    _ = abstime
    return posix_pthread_mutex_trylock(mutex)

def posix_pthread_mutex_reltimedlock_np(mutex: mutable PthreadMutex&?&, usec: u64) -> int:
    _ = usec
    return posix_pthread_mutex_trylock(mutex)

def posix_pthread_mutex_unlock(mutex: mutable PthreadMutex&?&) -> int:
    if mutex == null or mutex == null:
        return POSIX_EINVAL
    if not mutex.locked:
        return POSIX_EPERM
    mutex.locked <- false
    return 0

def posix_pthread_mutex_getspinloops_np(mutex: PthreadMutex&?, count: mutable int&) -> int:
    if mutex == null:
        return POSIX_EINVAL
    count <- mutex.spinloops
    return 0

def posix_pthread_mutex_setspinloops_np(mutex: mutable PthreadMutex&?, count: int) -> int:
    if mutex == null:
        return POSIX_EINVAL
    mutex.spinloops <- count
    return 0

def posix_pthread_mutex_getyieldloops_np(mutex: PthreadMutex&?, count: mutable int&) -> int:
    if mutex == null:
        return POSIX_EINVAL
    count <- mutex.yieldloops
    return 0

def posix_pthread_mutex_setyieldloops_np(mutex: mutable PthreadMutex&?, count: int) -> int:
    if mutex == null:
        return POSIX_EINVAL
    mutex.yieldloops <- count
    return 0

def posix_pthread_mutex_isowned_np(mutex: PthreadMutex&?) -> int:
    if mutex == null:
        return POSIX_EINVAL
    if mutex.locked:
        return 1
    return 0

def posix_pthread_mutexattr_init(attr: mutable PthreadMutexAttr&?&) -> int:
    if attr == null:
        return POSIX_EINVAL
    attr <- g_default_mutex_attr
    return 0

def posix_pthread_mutexattr_setkind_np(attr: mutable PthreadMutexAttr&?, kind: int) -> int:
    if attr == null:
        return POSIX_EINVAL
    attr.m_type <- kind
    return 0

def posix_pthread_mutexattr_getkind_np(attr: PthreadMutexAttr&?) -> int:
    if attr == null:
        return POSIX_EINVAL
    return attr.m_type

def posix_pthread_mutexattr_setprioceiling(attr: mutable PthreadMutexAttr&?, prioceiling: int) -> int:
    if attr == null:
        return POSIX_EINVAL
    attr.m_ceiling <- prioceiling
    return 0

def posix_pthread_mutexattr_getprioceiling(attr: PthreadMutexAttr&?, prioceiling: mutable int&) -> int:
    if attr == null:
        return POSIX_EINVAL
    prioceiling <- attr.m_ceiling
    return 0

def posix_pthread_mutexattr_setprotocol(attr: mutable PthreadMutexAttr&?, protocol: int) -> int:
    if attr == null:
        return POSIX_EINVAL
    attr.m_protocol <- protocol
    return 0

def posix_pthread_mutexattr_getprotocol(attr: PthreadMutexAttr&?, protocol: mutable int&) -> int:
    if attr == null:
        return POSIX_EINVAL
    protocol <- attr.m_protocol
    return 0

def posix_pthread_mutexattr_setpshared(attr: PthreadMutexAttr&?, pshared: int) -> int:
    if attr == null or pshared != 0:
        return POSIX_EINVAL
    return 0

def posix_pthread_mutexattr_getpshared(attr: PthreadMutexAttr&?, pshared: mutable int&) -> int:
    if attr == null:
        return POSIX_EINVAL
    pshared <- 0
    return 0

def posix_pthread_mutexattr_settype(attr: mutable PthreadMutexAttr&?, type_: int) -> int:
    if attr == null:
        return POSIX_EINVAL
    attr.m_type <- type_
    return 0

def posix_pthread_mutexattr_gettype(attr: PthreadMutexAttr&?, type_: mutable int&) -> int:
    if attr == null:
        return POSIX_EINVAL
    type_ <- attr.m_type
    return 0

def posix_pthread_mutexattr_destroy(attr: mutable PthreadMutexAttr&?&) -> int:
    if attr == null or attr == null:
        return POSIX_EINVAL
    attr <- null
    return 0

def posix_pthread_cond_init(cond: mutable PthreadCond&?&, cond_attr: PthreadCondAttr&?) -> int:
    _ = cond_attr
    if cond == null:
        return POSIX_EINVAL
    cond <- PthreadCond(true)
    return 0

def scePthreadCondInit(cond: mutable PthreadCond&?&, cond_attr: PthreadCondAttr&?, name: static u8&?) -> int:
    _ = name
    return posix_pthread_cond_init(cond, cond_attr)

def posix_pthread_cond_destroy(cond: mutable PthreadCond&?&) -> int:
    if cond == null or cond == null:
        return POSIX_EINVAL
    cond <- null
    return 0

def posix_pthread_cond_wait(cond: PthreadCond&?, mutex: mutable PthreadMutex&?&) -> int:
    if cond == null or mutex == null or mutex == null:
        return POSIX_EINVAL
    return 0

def posix_pthread_cond_timedwait(cond: PthreadCond&?, mutex: mutable PthreadMutex&?&, abstime: void&?) -> int:
    _ = abstime
    return posix_pthread_cond_wait(cond, mutex)

def posix_pthread_cond_reltimedwait_np(cond: PthreadCond&?, mutex: mutable PthreadMutex&?&, usec: u64) -> int:
    _ = usec
    return posix_pthread_cond_wait(cond, mutex)

def posix_pthread_cond_signal(cond: PthreadCond&?) -> int:
    if cond == null:
        return POSIX_EINVAL
    return 0

def posix_pthread_cond_signalto_np(cond: PthreadCond&?, thread: void&?) -> int:
    _ = thread
    return posix_pthread_cond_signal(cond)

def posix_pthread_cond_broadcast(cond: PthreadCond&?) -> int:
    return posix_pthread_cond_signal(cond)

def posix_pthread_condattr_init(attr: mutable PthreadCondAttr&?&) -> int:
    if attr == null:
        return POSIX_EINVAL
    attr <- g_default_cond_attr
    return 0

def posix_pthread_condattr_destroy(attr: mutable PthreadCondAttr&?&) -> int:
    if attr == null or attr == null:
        return POSIX_EINVAL
    attr <- null
    return 0

def posix_pthread_condattr_getclock(attr: PthreadCondAttr&?, clock_id: mutable int&) -> int:
    if attr == null:
        return POSIX_EINVAL
    clock_id <- attr.c_clockid
    return 0

def posix_pthread_condattr_setclock(attr: mutable PthreadCondAttr&?, clock_id: int) -> int:
    if attr == null:
        return POSIX_EINVAL
    attr.c_clockid <- clock_id
    return 0

def posix_pthread_condattr_getpshared(attr: PthreadCondAttr&?, pshared: mutable int&) -> int:
    if attr == null:
        return POSIX_EINVAL
    pshared <- 0
    return 0

def posix_pthread_condattr_setpshared(attr: PthreadCondAttr&?, pshared: int) -> int:
    if attr == null or pshared != 0:
        return POSIX_EINVAL
    return 0

def posix_pthread_rwlock_destroy(rwlock: mutable PthreadRwlock&?&) -> int:
    if rwlock == null or rwlock == null:
        return POSIX_EINVAL
    rwlock <- null
    return 0

def posix_pthread_rwlock_init(rwlock: mutable PthreadRwlock&?&, attr: PthreadRwlockAttr&?) -> int:
    _ = attr
    if rwlock == null:
        return POSIX_EINVAL
    rwlock <- PthreadRwlock(true, 0, false)
    return 0

def posix_pthread_rwlock_rdlock(rwlock: mutable PthreadRwlock&?&) -> int:
    if rwlock == null or rwlock == null:
        return POSIX_EINVAL
    if rwlock.write_locked:
        return POSIX_EBUSY
    rwlock.read_count <- rwlock.read_count + 1
    return 0

def posix_pthread_rwlock_timedrdlock(rwlock: mutable PthreadRwlock&?&, abstime: void&?) -> int:
    _ = abstime
    return posix_pthread_rwlock_rdlock(rwlock)

def posix_pthread_rwlock_tryrdlock(rwlock: mutable PthreadRwlock&?&) -> int:
    return posix_pthread_rwlock_rdlock(rwlock)

def posix_pthread_rwlock_trywrlock(rwlock: mutable PthreadRwlock&?&) -> int:
    if rwlock == null or rwlock == null:
        return POSIX_EINVAL
    if rwlock.write_locked or rwlock.read_count > 0:
        return POSIX_EBUSY
    rwlock.write_locked <- true
    return 0

def posix_pthread_rwlock_wrlock(rwlock: mutable PthreadRwlock&?&) -> int:
    return posix_pthread_rwlock_trywrlock(rwlock)

def posix_pthread_rwlock_timedwrlock(rwlock: mutable PthreadRwlock&?&, abstime: void&?) -> int:
    _ = abstime
    return posix_pthread_rwlock_trywrlock(rwlock)

def posix_pthread_rwlock_unlock(rwlock: mutable PthreadRwlock&?&) -> int:
    if rwlock == null or rwlock == null:
        return POSIX_EINVAL
    if rwlock.write_locked:
        rwlock.write_locked <- false
        return 0
    if rwlock.read_count > 0:
        rwlock.read_count <- rwlock.read_count - 1
        return 0
    return POSIX_EPERM

def posix_pthread_rwlockattr_destroy(rwlockattr: mutable PthreadRwlockAttr&?&) -> int:
    if rwlockattr == null or rwlockattr == null:
        return POSIX_EINVAL
    rwlockattr <- null
    return 0

def posix_pthread_rwlockattr_getpshared(rwlockattr: PthreadRwlockAttr&?, pshared: mutable int&) -> int:
    if rwlockattr == null:
        return POSIX_EINVAL
    pshared <- rwlockattr.pshared
    return 0

def posix_pthread_rwlockattr_gettype_np(rwlockattr: PthreadRwlockAttr&?, type_: mutable int&) -> int:
    if rwlockattr == null:
        return POSIX_EINVAL
    type_ <- rwlockattr.type_
    return 0

def posix_pthread_rwlockattr_init(rwlockattr: mutable PthreadRwlockAttr&?&) -> int:
    if rwlockattr == null:
        return POSIX_EINVAL
    rwlockattr <- g_default_rwlock_attr
    return 0

def posix_pthread_rwlockattr_settype_np(rwlockattr: mutable PthreadRwlockAttr&?, type_: int) -> int:
    if rwlockattr == null:
        return POSIX_EINVAL
    rwlockattr.type_ <- type_
    return 0

def posix_pthread_rwlockattr_setpshared(rwlockattr: mutable PthreadRwlockAttr&?, pshared: int) -> int:
    if rwlockattr == null or pshared != 0:
        return POSIX_EINVAL
    rwlockattr.pshared <- pshared
    return 0

def RegisterMutex(sym: void&?) -> void:
    _ = sym
    LIB_FUNCTION("ttHNfU+qDBU", "libScePosix", 1, "libkernel", posix_pthread_mutex_init)
    LIB_FUNCTION("gKqzW-zWhvY", "libScePosix", 1, "libkernel", posix_pthread_mutex_isowned_np)
    LIB_FUNCTION("7H0iTOciTLo", "libScePosix", 1, "libkernel", posix_pthread_mutex_lock)
    LIB_FUNCTION("Io9+nTKXZtA", "libScePosix", 1, "libkernel", posix_pthread_mutex_timedlock)
    LIB_FUNCTION("K-jXhbt2gn4", "libScePosix", 1, "libkernel", posix_pthread_mutex_trylock)
    LIB_FUNCTION("2Z+PpY6CaJg", "libScePosix", 1, "libkernel", posix_pthread_mutex_unlock)
    LIB_FUNCTION("x4vQj3JKKmc", "libScePosix", 1, "libkernel", posix_pthread_mutex_getspinloops_np)
    LIB_FUNCTION("OxEIUqkByy4", "libScePosix", 1, "libkernel", posix_pthread_mutex_getyieldloops_np)
    LIB_FUNCTION("5-ncLMtL5+g", "libScePosix", 1, "libkernel", posix_pthread_mutex_setspinloops_np)
    LIB_FUNCTION("frFuGprJmPc", "libScePosix", 1, "libkernel", posix_pthread_mutex_setyieldloops_np)
    LIB_FUNCTION("ltCfaGr2JGE", "libScePosix", 1, "libkernel", posix_pthread_mutex_destroy)
    LIB_FUNCTION("dQHWEsJtoE4", "libScePosix", 1, "libkernel", posix_pthread_mutexattr_init)
    LIB_FUNCTION("U6SNV+RnyLQ", "libScePosix", 1, "libkernel", posix_pthread_mutexattr_getkind_np)
    LIB_FUNCTION("+m8+quqOwhM", "libScePosix", 1, "libkernel", posix_pthread_mutexattr_getprioceiling)
    LIB_FUNCTION("yDaWxUE50s0", "libScePosix", 1, "libkernel", posix_pthread_mutexattr_getprotocol)
    LIB_FUNCTION("PmL-TwKUzXI", "libScePosix", 1, "libkernel", posix_pthread_mutexattr_getpshared)
    LIB_FUNCTION("GZFlI7RhuQo", "libScePosix", 1, "libkernel", posix_pthread_mutexattr_gettype)
    LIB_FUNCTION("J9rlRuQ8H5s", "libScePosix", 1, "libkernel", posix_pthread_mutexattr_setkind_np)
    LIB_FUNCTION("ZLvf6lVAc4M", "libScePosix", 1, "libkernel", posix_pthread_mutexattr_setprioceiling)
    LIB_FUNCTION("5txKfcMUAok", "libScePosix", 1, "libkernel", posix_pthread_mutexattr_setprotocol)
    LIB_FUNCTION("EXv3ztGqtDM", "libScePosix", 1, "libkernel", posix_pthread_mutexattr_setpshared)
    LIB_FUNCTION("mDmgMOGVUqg", "libScePosix", 1, "libkernel", posix_pthread_mutexattr_settype)
    LIB_FUNCTION("HF7lK46xzjY", "libScePosix", 1, "libkernel", posix_pthread_mutexattr_destroy)
    LIB_FUNCTION("cmo1RIYva9o", "libkernel", 1, "libkernel", scePthreadMutexInit)
    LIB_FUNCTION("W6OrTBO95UY", "libkernel", 1, "libkernel", posix_pthread_mutex_isowned_np)

