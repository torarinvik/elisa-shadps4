def posix_pthread_condattr_init(attr: mutable PthreadCondAttr&?) -> int:
    if attr == null:
        return POSIX_EINVAL
    attr <- g_default_cond_attr
    return 0

def posix_pthread_condattr_destroy(attr: mutable PthreadCondAttr&?) -> int:
    if attr == null:
        return POSIX_EINVAL
    attr <- g_default_cond_attr
    return 0

def posix_pthread_condattr_getclock(attr: PthreadCondAttr&?, clock_id: mutable int&) -> int:
    if attr == null:
        return POSIX_EINVAL
    clock_id <- attr.c_clockid
    return 0

def posix_pthread_condattr_setclock(attr: mutable PthreadCondAttr&?, clock_id: int) -> int:
    if attr == null:
        return POSIX_EINVAL
    if clock_id != 0 and clock_id != 1 and clock_id != 2 and clock_id != 4:
        return POSIX_EINVAL
    attr.c_clockid <- clock_id
    return 0

def posix_pthread_condattr_getpshared(attr: PthreadCondAttr&?, pshared: mutable int&) -> int:
    if attr == null:
        return POSIX_EINVAL
    pshared <- 0
    return 0

def posix_pthread_condattr_setpshared(attr: PthreadCondAttr&?, pshared: int) -> int:
    if attr == null or pshared != 0:
        return POSIX_EINVAL
    return 0

def posix_pthread_rwlock_destroy(rwlock: mutable PthreadRwlock&?) -> int:
    if rwlock == null:
        return POSIX_EINVAL
    # Match C++ static-initializer destroy behavior: null rwlock value is a no-op success.
    if rwlock.initialized == false:
        return 0
    if rwlock.native_handle != null:
        r: int = elisa_kernel_rwlock_destroy(rwlock.native_handle)
        if r != 0:
            return r
    rwlock <- PthreadRwlock(false, 0, false, null)
    return 0

def posix_pthread_rwlock_init(rwlock: mutable PthreadRwlock&?, attr: PthreadRwlockAttr&?) -> int:
    if rwlock == null:
        return POSIX_EINVAL
    if attr != null and attr.type_ > 2:
        return POSIX_EINVAL
    create_res: mutable int = 0
    native: void&? = elisa_kernel_rwlock_create(create_res)
    if native == null:
        return create_res
    rwlock <- PthreadRwlock(true, 0, false, native)
    return 0

def posix_pthread_rwlock_rdlock(rwlock: mutable PthreadRwlock&?) -> int:
    if rwlock == null:
        return POSIX_EINVAL
    r: int = elisa_kernel_rwlock_rdlock(rwlock.native_handle)
    if r != 0:
        return r
    rwlock.read_count <- rwlock.read_count + 1
    return 0

def posix_pthread_rwlock_timedrdlock(rwlock: mutable PthreadRwlock&?, abstime: void&?) -> int:
    if rwlock != null and rwlock.write_locked == true and abstime != null:
        ts: ThreadsSyncTimespec&? = abstime as ThreadsSyncTimespec&?
        if ts == null or ts.tv_nsec < 0 or ts.tv_nsec >= 1000000000:
            return POSIX_EINVAL
    return posix_pthread_rwlock_rdlock(rwlock)

def posix_pthread_rwlock_tryrdlock(rwlock: mutable PthreadRwlock&?) -> int:
    if rwlock == null:
        return POSIX_EINVAL
    r: int = elisa_kernel_rwlock_tryrdlock(rwlock.native_handle)
    if r != 0:
        return r
    rwlock.read_count <- rwlock.read_count + 1
    return 0

def posix_pthread_rwlock_trywrlock(rwlock: mutable PthreadRwlock&?) -> int:
    if rwlock == null:
        return POSIX_EINVAL
    r: int = elisa_kernel_rwlock_trywrlock(rwlock.native_handle)
    if r != 0:
        return r
    rwlock.write_locked <- true
    return 0

def posix_pthread_rwlock_wrlock(rwlock: mutable PthreadRwlock&?) -> int:
    if rwlock == null:
        return POSIX_EINVAL
    r: int = elisa_kernel_rwlock_wrlock(rwlock.native_handle)
    if r != 0:
        return r
    rwlock.write_locked <- true
    return 0

def posix_pthread_rwlock_timedwrlock(rwlock: mutable PthreadRwlock&?, abstime: void&?) -> int:
    if rwlock != null and (rwlock.write_locked == true or rwlock.read_count > 0) and abstime != null:
        ts: ThreadsSyncTimespec&? = abstime as ThreadsSyncTimespec&?
        if ts == null or ts.tv_nsec < 0 or ts.tv_nsec >= 1000000000:
            return POSIX_EINVAL
    return posix_pthread_rwlock_trywrlock(rwlock)

def posix_pthread_rwlock_unlock(rwlock: mutable PthreadRwlock&?) -> int:
    if rwlock == null:
        return POSIX_EINVAL
    if rwlock.write_locked == true:
        r: int = elisa_kernel_rwlock_unlock(rwlock.native_handle)
        if r != 0:
            return r
        rwlock.write_locked <- false
        return 0
    if rwlock.read_count > 0:
        r: int = elisa_kernel_rwlock_unlock(rwlock.native_handle)
        if r != 0:
            return r
        rwlock.read_count <- rwlock.read_count - 1
        return 0
    return POSIX_EPERM

def posix_pthread_rwlockattr_destroy(rwlockattr: mutable PthreadRwlockAttr&?) -> int:
    if rwlockattr == null:
        return POSIX_EINVAL
    rwlockattr <- g_default_rwlock_attr
    return 0

def posix_pthread_rwlockattr_getpshared(rwlockattr: PthreadRwlockAttr&?, pshared: mutable int&) -> int:
    if rwlockattr == null:
        return POSIX_EINVAL
    pshared <- rwlockattr.pshared
    return 0

def posix_pthread_rwlockattr_gettype_np(rwlockattr: PthreadRwlockAttr&?, type_: mutable int&) -> int:
    if rwlockattr == null:
        return POSIX_EINVAL
    type_ <- rwlockattr.type_
    return 0

def posix_pthread_rwlockattr_init(rwlockattr: mutable PthreadRwlockAttr&?) -> int:
    if rwlockattr == null:
        return POSIX_EINVAL
    rwlockattr <- g_default_rwlock_attr
    return 0

def posix_pthread_rwlockattr_settype_np(rwlockattr: mutable PthreadRwlockAttr&?, type_: int) -> int:
    if rwlockattr == null:
        return POSIX_EINVAL
    # Match C++ parity: validates current attr value, not incoming `type_`.
    if rwlockattr.type_ > 2:
        return POSIX_EINVAL
    rwlockattr.type_ <- type_
    return 0

def posix_pthread_rwlockattr_setpshared(rwlockattr: mutable PthreadRwlockAttr&?, pshared: int) -> int:
    if rwlockattr == null or pshared != 0:
        return POSIX_EINVAL
    rwlockattr.pshared <- pshared
    return 0

