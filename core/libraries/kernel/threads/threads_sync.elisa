def threads_sync_record_mutex(op: static u8&, mutex: mutable void&?&?, ret: int) -> int can[Segment.Host, Unsafe.SegmentMutation]:
    can Unsafe.SegmentMutation, Segment.Host:
        threads_sync_last_mutex_op <- op
        threads_sync_last_mutex_slot <- 0u64
        threads_sync_last_mutex_value <- 0u64
        reason: u64 = threads_sync_mutex_slot_reject_reason(mutex)
        threads_sync_last_mutex_reject_reason <- reason
        if mutex != null:
            threads_sync_last_mutex_slot <- mutex.cast[void&].uintptr().u64()
            if not threads_sync_mutex_slot_low(mutex):
                threads_sync_last_mutex_value <- threads_sync_mutex_slot_value(mutex).u64()
        threads_sync_last_mutex_ret <- ret
        if reason != 0u64:
            if threads_sync_mutex_reject_count == 0u64:
                threads_sync_first_mutex_reject_op <- op
                threads_sync_first_mutex_reject_slot <- threads_sync_last_mutex_slot
                threads_sync_first_mutex_reject_value <- threads_sync_last_mutex_value
                threads_sync_first_mutex_reject_reason <- reason
                threads_sync_first_mutex_reject_ret <- ret
                threads_sync_first_mutex_reject_return_addr <- GuestExec_RuntimeHleGuestReturnAddr().u64()
                threads_sync_first_mutex_reject_rdi <- GuestExec_RuntimeHleGuestRdi().u64()
                threads_sync_first_mutex_reject_rsi <- GuestExec_RuntimeHleGuestRsi().u64()
                threads_sync_first_mutex_reject_rdx <- GuestExec_RuntimeHleGuestRdx().u64()
            threads_sync_mutex_reject_count <- threads_sync_mutex_reject_count + 1u64
            if threads_sync_last_mutex_slot != 0u64:
                _ = threads_sync_debug_guard_unmapped_slot(op, threads_sync_last_mutex_slot.uintptr().cast[GuestVAddr[void]], 8u64)
        GuestExec_RecordRuntimeHle("libkernel", op, threads_sync_last_mutex_slot.uintptr(), threads_sync_last_mutex_value.uintptr(), reason.uintptr(), ret.u64().uintptr())
        return ret

def threads_sync_mutex_attr_alloc_default() -> mutable PthreadMutexAttr&?:
    i: mutable usize = 0usize
    while i < 128usize:
        if not threads_sync_mutex_attr_pool_used[i]:
            threads_sync_mutex_attr_pool_used[i] <- true
            threads_sync_mutex_attr_pool[i] <- g_default_mutex_attr
            return threads_sync_mutex_attr_pool[i].ref[mutable PthreadMutexAttr&]
        i <- i + 1usize
    return null

def threads_sync_mutex_attr_pool_release(attr: PthreadMutexAttr&?) -> void:
    if attr == null:
        return
    i: mutable usize = 0usize
    while i < 128usize:
        if threads_sync_mutex_attr_pool[i].ref[PthreadMutexAttr&].uintptr() == attr.uintptr():
            threads_sync_mutex_attr_pool_used[i] <- false
            threads_sync_mutex_attr_pool[i] <- g_default_mutex_attr
            return
        i <- i + 1usize

def threads_sync_mutex_attr_read_slot(slot: GuestVAddr[void]) -> mutable PthreadMutexAttr&? can[Segment.Host, Unsafe.SegmentMutation]:
    can Unsafe.SegmentMutation, Segment.Host:
        if slot.cast[uintptr] == 0.uintptr():
            return null
        raw: mutable u64 = MemoryManager_ReadU64(Memory_Instance(), slot.cast[uintptr])
        if raw == 0u64 and GuestExec_AddressNativeProt(slot.cast[uintptr]) != 0xffffffffu32:
            raw <- GuestExec_ReadContextU64(slot.cast[uintptr]).u64()
        return raw.uintptr().cast[mutable PthreadMutexAttr&?]

def threads_sync_mutex_attr_write_slot(slot: GuestVAddr[void], attr: PthreadMutexAttr&?) -> bool can[Segment.Host, Unsafe.SegmentMutation]:
    can Unsafe.SegmentMutation, Segment.Host:
        raw: mutable u64 = 0u64
        if attr != null:
            raw <- attr.uintptr().u64()
        addr: uintptr = slot.cast[uintptr]
        if MemoryManager_WriteU64(Memory_Instance(), addr, raw):
            if GuestExec_AddressNativeProt(addr) != 0xffffffffu32:
                return GuestExec_WriteU64(addr, raw)
            return true
        if GuestExec_AddressNativeProt(addr) != 0xffffffffu32:
            return GuestExec_WriteU64(addr, raw)
        return false

def threads_sync_mutex_init_slot(mutex: mutable void&?&?, mutex_attr: PthreadMutexAttr&?) -> int can[Segment.Host, Unsafe.SegmentMutation]:
    can Unsafe.SegmentMutation, Segment.Host:
        if mutex == null:
            return POSIX_EINVAL
        if threads_sync_mutex_slot_low(mutex):
            return POSIX_EINVAL
        attr: mutable PthreadMutexAttr = g_default_mutex_attr
        if mutex_attr != null:
            if mutex_attr.m_type < 1 or mutex_attr.m_type >= 5:
                return POSIX_EINVAL
            if mutex_attr.m_protocol > 2:
                return POSIX_EINVAL
            attr <- mutex_attr[0]
        create_res: mutable int = 0
        native: void&? = elisa_kernel_mutex_create(attr.m_type, create_res)
        if native == null:
            return create_res
        if not threads_sync_mutex_slot_write(mutex, native):
            _ = elisa_kernel_mutex_destroy(native)
            return POSIX_EINVAL
        return 0

def threads_sync_mutex_ensure_initialized(mutex: mutable void&?&?) -> int can[Segment.Host, Unsafe.SegmentMutation]:
    can Unsafe.SegmentMutation, Segment.Host:
        if mutex == null:
            return POSIX_EINVAL
        if threads_sync_mutex_slot_low(mutex):
            return POSIX_EINVAL
        value: uintptr = threads_sync_mutex_slot_value(mutex)
        if value == 2.uintptr():
            return POSIX_EINVAL
        if value == 0.uintptr():
            return threads_sync_mutex_init_slot(mutex, null)
        if value == 1.uintptr():
            adaptive: mutable PthreadMutexAttr = PthreadMutexAttr(4, 0, 0)
            return threads_sync_mutex_init_slot(mutex, adaptive)
        return 0

