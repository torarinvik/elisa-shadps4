@fixed_layout
struct ThreadsSyncTimespec:
    tv_sec: mutable i64
    tv_nsec: mutable i64

@fixed_layout
struct PthreadMutexAttr:
    m_type: mutable int
    m_protocol: mutable int
    m_ceiling: mutable int

@fixed_layout
struct PthreadMutex:
    initialized: mutable bool
    locked: mutable bool
    spinloops: mutable int
    yieldloops: mutable int
    m_type: mutable int
    m_protocol: mutable int
    native_handle: mutable void&?

@fixed_layout
struct PthreadCondAttr:
    c_pshared: mutable int
    c_clockid: mutable int

@fixed_layout
struct PthreadCond:
    initialized: mutable bool
    native_handle: mutable void&?

@fixed_layout
struct PthreadRwlockAttr:
    pshared: mutable int
    type_: mutable int

@fixed_layout
struct PthreadRwlock:
    initialized: mutable bool
    read_count: mutable int
    write_locked: mutable bool
    native_handle: mutable void&?

global mutable g_default_mutex_attr: PthreadMutexAttr = PthreadMutexAttr(1, 0, 0)
global mutable g_default_cond_attr: PthreadCondAttr = PthreadCondAttr(0, 0)
global mutable g_default_rwlock_attr: PthreadRwlockAttr = PthreadRwlockAttr(0, 0)

def threads_sync_low_guest_pointer(ptr: void&?) -> bool:
    # C++ resolves guest pointer slots before dereferencing. Real guest code can
    # hand us low/sentinel values; treat those as invalid instead of crashing.
    if ptr == null:
        return true
    return ptr.uintptr() < 4096.uintptr()

def threads_sync_boundary_guest_ptr_mapped(site: cstr, ptr: GuestVAddr[void], size: u64, optional: bool) -> bool:
    raw: VAddr = ptr.cast[uintptr]
    if optional and raw == 0.uintptr():
        return true
    if MemoryManager_AddressIsMapped(Memory_Instance(), raw, size):
        return true
    nearest_base: mutable VAddr = 0.uintptr()
    nearest_end: mutable VAddr = 0.uintptr()
    nearest_prot: mutable u32 = 0u32
    _ = MemoryManager_FindNearestVmaRange(Memory_Instance(), raw, nearest_base, nearest_end, nearest_prot)
    return GuestExec_DebugGuardMappedGuestPointer(site, ptr, size, nearest_base, nearest_end, nearest_prot, 0u64)

def threads_sync_debug_guard_unmapped_slot(site: cstr, ptr: GuestVAddr[void], size: u64) -> bool:
    raw: VAddr = ptr.cast[uintptr]
    nearest_base: mutable VAddr = 0.uintptr()
    nearest_end: mutable VAddr = 0.uintptr()
    nearest_prot: mutable u32 = 0u32
    _ = MemoryManager_FindNearestVmaRange(Memory_Instance(), raw, nearest_base, nearest_end, nearest_prot)
    return GuestExec_DebugGuardMappedGuestPointer(site, ptr, size, nearest_base, nearest_end, nearest_prot, 0u64)

def threads_sync_orbis_from_posix(ret: int) -> int:
    if ret == 0:
        return 0
    return ORBIS_KERNEL_ERROR_UNKNOWN + ret

def threads_sync_mutex_slot_low(mutex: mutable void&?&) -> bool:
    addr: VAddr = mutex.cast[void&].uintptr()
    if addr == 0.uintptr():
        return true
    if MemoryManager_FindBackingIndex(Memory_Instance(), addr, 8) >= 0:
        return false
    return addr < 4096.uintptr()

def threads_sync_mutex_slot_reject_reason(mutex: mutable void&?&?) -> u64:
    if mutex == null:
        return 1u64
    addr: VAddr = mutex.cast[void&].uintptr()
    if addr == 0.uintptr():
        return 1u64
    if MemoryManager_FindBackingIndex(Memory_Instance(), addr, 8) >= 0:
        return 0u64
    if addr < 4096.uintptr():
        return 3u64
    return 4u64

def threads_sync_mutex_slot_addr(mutex: mutable void&?&) -> VAddr:
    return mutex.cast[void&].uintptr()

def threads_sync_mutex_slot_is_guest_mapped(mutex: mutable void&?&) -> bool:
    addr: VAddr = threads_sync_mutex_slot_addr(mutex)
    return MemoryManager_FindBackingIndex(Memory_Instance(), addr, 8) >= 0

def threads_sync_mutex_slot_value(mutex: mutable void&?&) -> uintptr:
    if threads_sync_mutex_slot_is_guest_mapped(mutex):
        return MemoryManager_ReadU64(Memory_Instance(), threads_sync_mutex_slot_addr(mutex)).uintptr()
    if mutex[0] == null:
        return 0.uintptr()
    return mutex[0].uintptr()

def threads_sync_mutex_slot_write(mutex: mutable void&?&, value: void&?) -> bool:
    if threads_sync_mutex_slot_is_guest_mapped(mutex):
        raw: mutable u64 = 0u64
        if value != null:
            raw <- value.uintptr().u64()
        return MemoryManager_WriteU64(Memory_Instance(), threads_sync_mutex_slot_addr(mutex), raw)
    mutex[0] <- value
    return true


global mutable threads_sync_last_mutex_op: static u8&? = null
global mutable threads_sync_last_mutex_slot: u64 = 0u64
global mutable threads_sync_last_mutex_value: u64 = 0u64
global mutable threads_sync_last_mutex_ret: int = 0
global mutable threads_sync_last_mutex_reject_reason: u64 = 0u64
global mutable threads_sync_mutex_reject_count: u64 = 0u64
global mutable threads_sync_first_mutex_reject_op: static u8&? = null
global mutable threads_sync_first_mutex_reject_slot: u64 = 0u64
global mutable threads_sync_first_mutex_reject_value: u64 = 0u64
global mutable threads_sync_first_mutex_reject_reason: u64 = 0u64
global mutable threads_sync_first_mutex_reject_ret: int = 0
global mutable threads_sync_first_mutex_reject_return_addr: u64 = 0u64
global mutable threads_sync_first_mutex_reject_rdi: u64 = 0u64
global mutable threads_sync_first_mutex_reject_rsi: u64 = 0u64
global mutable threads_sync_first_mutex_reject_rdx: u64 = 0u64

def threads_sync_record_mutex(op: static u8&, mutex: mutable void&?&?, ret: int) -> int:
    threads_sync_last_mutex_op <- op
    threads_sync_last_mutex_slot <- 0u64
    threads_sync_last_mutex_value <- 0u64
    reason: u64 = threads_sync_mutex_slot_reject_reason(mutex)
    threads_sync_last_mutex_reject_reason <- reason
    if mutex != null:
        threads_sync_last_mutex_slot <- mutex.cast[void&].uintptr().u64()
        if not threads_sync_mutex_slot_low(mutex):
            threads_sync_last_mutex_value <- threads_sync_mutex_slot_value(mutex).u64()
    threads_sync_last_mutex_ret <- ret
    if reason != 0u64:
        if threads_sync_mutex_reject_count == 0u64:
            threads_sync_first_mutex_reject_op <- op
            threads_sync_first_mutex_reject_slot <- threads_sync_last_mutex_slot
            threads_sync_first_mutex_reject_value <- threads_sync_last_mutex_value
            threads_sync_first_mutex_reject_reason <- reason
            threads_sync_first_mutex_reject_ret <- ret
            threads_sync_first_mutex_reject_return_addr <- GuestExec_RuntimeHleGuestReturnAddr().u64()
            threads_sync_first_mutex_reject_rdi <- GuestExec_RuntimeHleGuestRdi().u64()
            threads_sync_first_mutex_reject_rsi <- GuestExec_RuntimeHleGuestRsi().u64()
            threads_sync_first_mutex_reject_rdx <- GuestExec_RuntimeHleGuestRdx().u64()
        threads_sync_mutex_reject_count <- threads_sync_mutex_reject_count + 1u64
        if threads_sync_last_mutex_slot != 0u64:
            _ = threads_sync_debug_guard_unmapped_slot(op, threads_sync_last_mutex_slot.uintptr().cast[GuestVAddr[void]], 8u64)
    GuestExec_RecordRuntimeHle("libkernel", op, threads_sync_last_mutex_slot.uintptr(), threads_sync_last_mutex_value.uintptr(), reason.uintptr(), ret.u64().uintptr())
    return ret

def threads_sync_mutex_init_slot(mutex: mutable void&?&?, mutex_attr: PthreadMutexAttr&?) -> int:
    if mutex == null:
        return POSIX_EINVAL
    if threads_sync_mutex_slot_low(mutex):
        return POSIX_EINVAL
    attr: mutable PthreadMutexAttr = g_default_mutex_attr
    if mutex_attr != null:
        if mutex_attr.m_type < 1 or mutex_attr.m_type >= 5:
            return POSIX_EINVAL
        if mutex_attr.m_protocol > 2:
            return POSIX_EINVAL
        attr <- mutex_attr[0]
    create_res: mutable int = 0
    native: void&? = elisa_kernel_mutex_create(attr.m_type, create_res)
    if native == null:
        return create_res
    if not threads_sync_mutex_slot_write(mutex, native):
        _ = elisa_kernel_mutex_destroy(native)
        return POSIX_EINVAL
    return 0

def threads_sync_mutex_ensure_initialized(mutex: mutable void&?&?) -> int:
    if mutex == null:
        return POSIX_EINVAL
    if threads_sync_mutex_slot_low(mutex):
        return POSIX_EINVAL
    value: uintptr = threads_sync_mutex_slot_value(mutex)
    if value == 2.uintptr():
        return POSIX_EINVAL
    if value == 0.uintptr():
        return threads_sync_mutex_init_slot(mutex, null)
    if value == 1.uintptr():
        adaptive: mutable PthreadMutexAttr = PthreadMutexAttr(4, 0, 0)
        return threads_sync_mutex_init_slot(mutex, adaptive.ref[PthreadMutexAttr&])
    return 0

def posix_pthread_mutex_init(mutex: mutable void&?&?, mutex_attr: PthreadMutexAttr&?) -> int:
    r: int = threads_sync_mutex_init_slot(mutex, mutex_attr)
    return threads_sync_record_mutex("posix_pthread_mutex_init", mutex, r)

@boundary_pointer_args(mutex, mutex_attr)
def posix_pthread_mutex_init_hle(mutex: GuestVAddr[void], mutex_attr: GuestVAddr[void]) -> int:
    if not threads_sync_boundary_guest_ptr_mapped("posix_pthread_mutex_init.mutex", mutex, 8u64, false):
        return POSIX_EINVAL
    if not threads_sync_boundary_guest_ptr_mapped("posix_pthread_mutex_init.mutex_attr", mutex_attr, 12u64, true):
        return POSIX_EINVAL
    trusted Unsafe.GuestHostPointerCast:
        return posix_pthread_mutex_init(mutex.cast[mutable void&?&?], mutex_attr.cast[PthreadMutexAttr&?])
    return POSIX_EINVAL

def scePthreadMutexInit(mutex: mutable void&?&?, mutex_attr: PthreadMutexAttr&?, name: static u8&?) -> int:
    _ = name
    return threads_sync_orbis_from_posix(posix_pthread_mutex_init(mutex, mutex_attr))

def scePthreadMutexInitPosix(mutex: mutable void&?&?, mutex_attr: PthreadMutexAttr&?, name: static u8&?) -> int:
    _ = name
    return posix_pthread_mutex_init(mutex, mutex_attr)

def posix_pthread_mutex_destroy(mutex: mutable void&?&?) -> int:
    if mutex == null:
        return POSIX_EINVAL
    if threads_sync_mutex_slot_low(mutex):
        return POSIX_EINVAL
    value: uintptr = threads_sync_mutex_slot_value(mutex)
    if value < 2.uintptr():
        return 0
    if value == 2.uintptr():
        return POSIX_EINVAL
    r: int = elisa_kernel_mutex_destroy(value.cast[void&?])
    if r != 0:
        return r
    _ = threads_sync_mutex_slot_write(mutex, 2u64.cast[void&?])
    return 0

@boundary_pointer_args(mutex)
def posix_pthread_mutex_destroy_hle(mutex: GuestVAddr[void]) -> int:
    if not threads_sync_boundary_guest_ptr_mapped("posix_pthread_mutex_destroy.mutex", mutex, 8u64, false):
        return POSIX_EINVAL
    trusted Unsafe.GuestHostPointerCast:
        return posix_pthread_mutex_destroy(mutex.cast[mutable void&?&?])
    return POSIX_EINVAL

def posix_pthread_mutex_trylock(mutex: mutable void&?&?) -> int:
    if mutex == null:
        return threads_sync_record_mutex("posix_pthread_mutex_trylock", mutex, POSIX_EINVAL)
    if threads_sync_mutex_slot_low(mutex):
        return threads_sync_record_mutex("posix_pthread_mutex_trylock", mutex, POSIX_EINVAL)
    init_res: int = threads_sync_mutex_ensure_initialized(mutex)
    if init_res != 0:
        return threads_sync_record_mutex("posix_pthread_mutex_trylock", mutex, init_res)
    r: int = elisa_kernel_mutex_trylock(threads_sync_mutex_slot_value(mutex).cast[void&?])
    return threads_sync_record_mutex("posix_pthread_mutex_trylock", mutex, r)

@boundary_pointer_args(mutex)
def posix_pthread_mutex_trylock_hle(mutex: GuestVAddr[void]) -> int:
    if not threads_sync_boundary_guest_ptr_mapped("posix_pthread_mutex_trylock.mutex", mutex, 8u64, false):
        return POSIX_EINVAL
    trusted Unsafe.GuestHostPointerCast:
        return posix_pthread_mutex_trylock(mutex.cast[mutable void&?&?])
    return POSIX_EINVAL

def posix_pthread_mutex_lock(mutex: mutable void&?&?) -> int can[Segment.Host]:
    if mutex == null:
        return threads_sync_record_mutex("posix_pthread_mutex_lock", mutex, POSIX_EINVAL)
    if threads_sync_mutex_slot_low(mutex):
        return threads_sync_record_mutex("posix_pthread_mutex_lock", mutex, POSIX_EINVAL)
    init_res: int = threads_sync_mutex_ensure_initialized(mutex)
    if init_res != 0:
        return threads_sync_record_mutex("posix_pthread_mutex_lock", mutex, init_res)
    r: int = elisa_kernel_mutex_lock(threads_sync_mutex_slot_value(mutex).cast[void&?])
    return threads_sync_record_mutex("posix_pthread_mutex_lock", mutex, r)

@boundary_pointer_args(mutex)
def posix_pthread_mutex_lock_hle(mutex: GuestVAddr[void]) -> int:
    if not threads_sync_boundary_guest_ptr_mapped("posix_pthread_mutex_lock.mutex", mutex, 8u64, false):
        return POSIX_EINVAL
    trusted Unsafe.GuestHostPointerCast:
        can Segment.Host:
            return posix_pthread_mutex_lock(mutex.cast[mutable void&?&?])
    return POSIX_EINVAL

def posix_pthread_mutex_timedlock(mutex: mutable void&?&?, abstime: void&?) -> int:
    if abstime != null:
        ts: ThreadsSyncTimespec&? = abstime as ThreadsSyncTimespec&?
        if ts == null or ts.tv_nsec < 0 or ts.tv_nsec >= 1000000000:
            return POSIX_EINVAL
    return posix_pthread_mutex_trylock(mutex)

@boundary_pointer_args(mutex, abstime)
def posix_pthread_mutex_timedlock_hle(mutex: GuestVAddr[void], abstime: GuestVAddr[void]) -> int:
    if not threads_sync_boundary_guest_ptr_mapped("posix_pthread_mutex_timedlock.mutex", mutex, 8u64, false):
        return POSIX_EINVAL
    if not threads_sync_boundary_guest_ptr_mapped("posix_pthread_mutex_timedlock.abstime", abstime, 16u64, true):
        return POSIX_EINVAL
    trusted Unsafe.GuestHostPointerCast:
        return posix_pthread_mutex_timedlock(mutex.cast[mutable void&?&?], abstime.cast[void&?])
    return POSIX_EINVAL

def posix_pthread_mutex_reltimedlock_np(mutex: mutable void&?&?, usec: u64) -> int:
    _ = usec
    return posix_pthread_mutex_trylock(mutex)

@boundary_pointer_args(mutex)
def posix_pthread_mutex_reltimedlock_np_hle(mutex: GuestVAddr[void], usec: u64) -> int:
    if not threads_sync_boundary_guest_ptr_mapped("posix_pthread_mutex_reltimedlock_np.mutex", mutex, 8u64, false):
        return POSIX_EINVAL
    trusted Unsafe.GuestHostPointerCast:
        return posix_pthread_mutex_reltimedlock_np(mutex.cast[mutable void&?&?], usec)
    return POSIX_EINVAL

def posix_pthread_mutex_unlock(mutex: mutable void&?&?) -> int:
    if mutex == null:
        return threads_sync_record_mutex("posix_pthread_mutex_unlock", mutex, POSIX_EINVAL)
    if threads_sync_mutex_slot_low(mutex):
        return threads_sync_record_mutex("posix_pthread_mutex_unlock", mutex, POSIX_EINVAL)
    value: uintptr = threads_sync_mutex_slot_value(mutex)
    if value <= 2.uintptr():
        return threads_sync_record_mutex("posix_pthread_mutex_unlock", mutex, POSIX_EINVAL)
    r: int = elisa_kernel_mutex_unlock(value.cast[void&?])
    return threads_sync_record_mutex("posix_pthread_mutex_unlock", mutex, r)

@boundary_pointer_args(mutex)
def posix_pthread_mutex_unlock_hle(mutex: GuestVAddr[void]) -> int:
    if not threads_sync_boundary_guest_ptr_mapped("posix_pthread_mutex_unlock.mutex", mutex, 8u64, false):
        return POSIX_EINVAL
    trusted Unsafe.GuestHostPointerCast:
        return posix_pthread_mutex_unlock(mutex.cast[mutable void&?&?])
    return POSIX_EINVAL

def posix_pthread_mutex_getspinloops_np(mutex: mutable void&?&?, count: mutable int&) -> int:
    if mutex == null:
        return POSIX_EINVAL
    if threads_sync_mutex_slot_low(mutex):
        return POSIX_EINVAL
    count <- 0
    return 0

def posix_pthread_mutex_setspinloops_np(mutex: mutable void&?&?, count: int) -> int:
    if mutex == null:
        return POSIX_EINVAL
    if threads_sync_mutex_slot_low(mutex):
        return POSIX_EINVAL
    _ = count
    return 0

def posix_pthread_mutex_getyieldloops_np(mutex: mutable void&?&?, count: mutable int&) -> int:
    if mutex == null:
        return POSIX_EINVAL
    if threads_sync_mutex_slot_low(mutex):
        return POSIX_EINVAL
    count <- 0
    return 0

def posix_pthread_mutex_setyieldloops_np(mutex: mutable void&?&?, count: int) -> int:
    if mutex == null:
        return POSIX_EINVAL
    if threads_sync_mutex_slot_low(mutex):
        return POSIX_EINVAL
    _ = count
    return 0

def posix_pthread_mutex_isowned_np(mutex: mutable void&?&?) -> int:
    if mutex == null:
        return POSIX_EINVAL
    if threads_sync_mutex_slot_low(mutex):
        return POSIX_EINVAL
    value: uintptr = threads_sync_mutex_slot_value(mutex)
    if value <= 2.uintptr():
        return 0
    if elisa_kernel_mutex_isowned(value.cast[void&?]) == 1:
        return 1
    return 0

def posix_pthread_mutexattr_init(attr: mutable PthreadMutexAttr&?) -> int:
    if attr == null:
        return POSIX_EINVAL
    attr <- g_default_mutex_attr
    return 0

def posix_pthread_mutexattr_setkind_np(attr: mutable PthreadMutexAttr&?, kind: int) -> int:
    if attr == null:
        return POSIX_EINVAL
    attr.m_type <- kind
    return 0

def posix_pthread_mutexattr_getkind_np(attr: PthreadMutexAttr&?) -> int:
    if attr == null:
        return POSIX_EINVAL
    return attr.m_type

def posix_pthread_mutexattr_setprioceiling(attr: mutable PthreadMutexAttr&?, prioceiling: int) -> int:
    if attr == null:
        return POSIX_EINVAL
    if attr.m_protocol != 2 or prioceiling > ORBIS_KERNEL_PRIO_FIFO_HIGHEST or prioceiling < ORBIS_KERNEL_PRIO_FIFO_LOWEST:
        return POSIX_EINVAL
    attr.m_ceiling <- prioceiling
    return 0

def posix_pthread_mutexattr_getprioceiling(attr: PthreadMutexAttr&?, prioceiling: mutable int&) -> int:
    if attr == null:
        return POSIX_EINVAL
    if attr.m_protocol != 2:
        return POSIX_EINVAL
    prioceiling <- attr.m_ceiling
    return 0

def posix_pthread_mutexattr_setprotocol(attr: mutable PthreadMutexAttr&?, protocol: int) -> int:
    if attr == null:
        return POSIX_EINVAL
    if protocol < 0 or protocol > 2:
        return POSIX_EINVAL
    attr.m_protocol <- protocol
    attr.m_ceiling <- ORBIS_KERNEL_PRIO_RR_HIGHEST
    return 0

def posix_pthread_mutexattr_getprotocol(attr: PthreadMutexAttr&?, protocol: mutable int&) -> int:
    if attr == null:
        return POSIX_EINVAL
    protocol <- attr.m_protocol
    return 0

def posix_pthread_mutexattr_setpshared(attr: PthreadMutexAttr&?, pshared: int) -> int:
    if attr == null or pshared != 0:
        return POSIX_EINVAL
    return 0

def posix_pthread_mutexattr_getpshared(attr: PthreadMutexAttr&?, pshared: mutable int&) -> int:
    if attr == null:
        return POSIX_EINVAL
    pshared <- 0
    return 0

def posix_pthread_mutexattr_settype(attr: mutable PthreadMutexAttr&?, type_: int) -> int:
    if attr == null:
        return POSIX_EINVAL
    if type_ < 1 or type_ >= 5:
        return POSIX_EINVAL
    attr.m_type <- type_
    return 0

def posix_pthread_mutexattr_gettype(attr: PthreadMutexAttr&?, type_: mutable int&) -> int:
    if attr == null:
        return POSIX_EINVAL
    if attr.m_type >= 5:
        return POSIX_EINVAL
    type_ <- attr.m_type
    return 0

def posix_pthread_mutexattr_destroy(attr: mutable PthreadMutexAttr&?) -> int:
    if attr == null:
        return POSIX_EINVAL
    attr <- g_default_mutex_attr
    return 0

def posix_pthread_cond_init(cond: mutable PthreadCond&?, cond_attr: PthreadCondAttr&?) -> int:
    _ = cond_attr
    if cond == null:
        return POSIX_EINVAL
    create_res: mutable int = 0
    native: void&? = elisa_kernel_cond_create(create_res)
    if native == null:
        return create_res
    cond <- PthreadCond(true, native)
    return 0

def scePthreadCondInit(cond: mutable PthreadCond&?, cond_attr: PthreadCondAttr&?, name: static u8&?) -> int:
    _ = name
    return threads_sync_orbis_from_posix(posix_pthread_cond_init(cond, cond_attr))

def posix_pthread_cond_destroy(cond: mutable PthreadCond&?) -> int:
    if cond == null:
        return POSIX_EINVAL
    if cond.initialized == false:
        return 0
    if cond.native_handle != null:
        r: int = elisa_kernel_cond_destroy(cond.native_handle)
        if r != 0:
            return r
    cond <- PthreadCond(false, null)
    return 0

def posix_pthread_cond_wait(cond: PthreadCond&?, mutex: mutable PthreadMutex&?) -> int:
    if cond == null or mutex == null:
        return POSIX_EINVAL
    cond_v: PthreadCond& = cond.cast[PthreadCond&]
    mutex_v: mutable PthreadMutex& = mutex.cast[mutable PthreadMutex&]
    if mutex_v.locked == false:
        return POSIX_EPERM
    return elisa_kernel_cond_wait(cond_v.native_handle, mutex_v.native_handle)

def posix_pthread_cond_timedwait(cond: PthreadCond&?, mutex: mutable PthreadMutex&?, abstime: void&?) -> int:
    if cond == null or mutex == null:
        return POSIX_EINVAL
    if abstime == null:
        return POSIX_EINVAL
    ts: ThreadsSyncTimespec&? = abstime as ThreadsSyncTimespec&?
    if ts == null or ts.tv_sec < 0 or ts.tv_nsec < 0 or ts.tv_nsec >= 1000000000:
        return POSIX_EINVAL
    cond_v: PthreadCond& = cond.cast[PthreadCond&]
    mutex_v: mutable PthreadMutex& = mutex.cast[mutable PthreadMutex&]
    return elisa_kernel_cond_timedwait(cond_v.native_handle, mutex_v.native_handle, ts.tv_sec, ts.tv_nsec)

def posix_pthread_cond_reltimedwait_np(cond: PthreadCond&?, mutex: mutable PthreadMutex&?, usec: u64) -> int:
    if cond == null or mutex == null:
        return POSIX_EINVAL
    cond_v: PthreadCond& = cond.cast[PthreadCond&]
    mutex_v: mutable PthreadMutex& = mutex.cast[mutable PthreadMutex&]
    if mutex_v.locked == false:
        return POSIX_EPERM
    return elisa_kernel_cond_reltimedwait(cond_v.native_handle, mutex_v.native_handle, usec)

def posix_pthread_cond_signal(cond: PthreadCond&?) -> int:
    if cond == null:
        return POSIX_EINVAL
    return elisa_kernel_cond_signal(cond.native_handle)

def posix_pthread_cond_signalto_np(cond: PthreadCond&?, thread: void&?) -> int:
    _ = thread
    return posix_pthread_cond_signal(cond)

def posix_pthread_cond_broadcast(cond: PthreadCond&?) -> int:
    if cond == null:
        return POSIX_EINVAL
    return elisa_kernel_cond_broadcast(cond.native_handle)

# Boundary wrappers: the guest hands these condvar HLEs raw guest addresses, so
# the registered entrypoints take GuestVAddr carriers and convert at the unsafe
# edge (mirrors the pthread-mutex pilot). Behaviour-preserving thin wrappers; the
# @boundary_pointer_args + GuestVAddr typing make the address-space boundary
# explicit and machine-checked.
@boundary_pointer_args(cond, cond_attr)
def posix_pthread_cond_init_hle(cond: GuestVAddr[void], cond_attr: GuestVAddr[void]) -> int:
    if not threads_sync_boundary_guest_ptr_mapped("posix_pthread_cond_init.cond", cond, 8u64, false):
        return POSIX_EINVAL
    if not threads_sync_boundary_guest_ptr_mapped("posix_pthread_cond_init.cond_attr", cond_attr, 8u64, true):
        return POSIX_EINVAL
    trusted Unsafe.GuestHostPointerCast:
        return posix_pthread_cond_init(cond.cast[mutable PthreadCond&?], cond_attr.cast[PthreadCondAttr&?])
    return POSIX_EINVAL

@boundary_pointer_args(cond)
def posix_pthread_cond_destroy_hle(cond: GuestVAddr[void]) -> int:
    if not threads_sync_boundary_guest_ptr_mapped("posix_pthread_cond_destroy.cond", cond, 8u64, false):
        return POSIX_EINVAL
    trusted Unsafe.GuestHostPointerCast:
        return posix_pthread_cond_destroy(cond.cast[mutable PthreadCond&?])
    return POSIX_EINVAL

@boundary_pointer_args(cond, mutex)
def posix_pthread_cond_wait_hle(cond: GuestVAddr[void], mutex: GuestVAddr[void]) -> int:
    if not threads_sync_boundary_guest_ptr_mapped("posix_pthread_cond_wait.cond", cond, 8u64, false):
        return POSIX_EINVAL
    if not threads_sync_boundary_guest_ptr_mapped("posix_pthread_cond_wait.mutex", mutex, 8u64, false):
        return POSIX_EINVAL
    trusted Unsafe.GuestHostPointerCast:
        return posix_pthread_cond_wait(cond.cast[PthreadCond&?], mutex.cast[mutable PthreadMutex&?])
    return POSIX_EINVAL

@boundary_pointer_args(cond, mutex, abstime)
def posix_pthread_cond_timedwait_hle(cond: GuestVAddr[void], mutex: GuestVAddr[void], abstime: GuestVAddr[void]) -> int:
    if not threads_sync_boundary_guest_ptr_mapped("posix_pthread_cond_timedwait.cond", cond, 8u64, false):
        return POSIX_EINVAL
    if not threads_sync_boundary_guest_ptr_mapped("posix_pthread_cond_timedwait.mutex", mutex, 8u64, false):
        return POSIX_EINVAL
    if not threads_sync_boundary_guest_ptr_mapped("posix_pthread_cond_timedwait.abstime", abstime, 16u64, true):
        return POSIX_EINVAL
    trusted Unsafe.GuestHostPointerCast:
        return posix_pthread_cond_timedwait(cond.cast[PthreadCond&?], mutex.cast[mutable PthreadMutex&?], abstime.cast[void&?])
    return POSIX_EINVAL

@boundary_pointer_args(cond, mutex)
def posix_pthread_cond_reltimedwait_np_hle(cond: GuestVAddr[void], mutex: GuestVAddr[void], usec: u64) -> int:
    if not threads_sync_boundary_guest_ptr_mapped("posix_pthread_cond_reltimedwait_np.cond", cond, 8u64, false):
        return POSIX_EINVAL
    if not threads_sync_boundary_guest_ptr_mapped("posix_pthread_cond_reltimedwait_np.mutex", mutex, 8u64, false):
