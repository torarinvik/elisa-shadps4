    return POSIX_EINVAL

@boundary_pointer_args(cond)
def posix_pthread_cond_signal_hle(cond: GuestVAddr[void]) -> int:
    if not threads_sync_boundary_guest_ptr_mapped("posix_pthread_cond_signal.cond", cond, 8u64, false):
