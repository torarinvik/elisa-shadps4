        ge_emergency_mark(GE_EV_HLE_NATIVE_CALL_END, GE_EV_MUTEX_INIT.u64().uintptr(), r.u64().uintptr(), mutex.uintptr(), mutex_attr.uintptr())
        return threads_sync_record_mutex("posix_pthread_mutex_init", mutex, r)

