def threads_sync_low_guest_pointer(ptr: void&?) -> bool:
    # C++ resolves guest pointer slots before dereferencing. Real guest code can
    # hand us low/sentinel values; treat those as invalid instead of crashing.
    if ptr == null:
        return true
    return ptr.uintptr() < 4096.uintptr()

def threads_sync_boundary_guest_ptr_mapped(site: cstr, ptr: GuestVAddr[void], size: u64, optional: bool) -> bool can[Segment.Host, Unsafe.SegmentMutation]:
    can Unsafe.SegmentMutation, Segment.Host:
        raw: VAddr = ptr.cast[uintptr]
        if optional and raw == 0.uintptr():
            return true
        if MemoryManager_AddressIsMapped(Memory_Instance(), raw, size):
            return true
        native_prot: u32 = GuestExec_AddressNativeProt(raw)
        if native_prot != 0xffffffffu32:
            return true
        nearest_base: mutable VAddr = 0.uintptr()
        nearest_end: mutable VAddr = 0.uintptr()
        nearest_prot: mutable u32 = 0u32
        _ = MemoryManager_FindNearestVmaRange(Memory_Instance(), raw, nearest_base, nearest_end, nearest_prot)
        return GuestExec_DebugGuardMappedGuestPointer(site, ptr, size, nearest_base, nearest_end, nearest_prot, 0u64)

def threads_sync_debug_guard_unmapped_slot(site: cstr, ptr: GuestVAddr[void], size: u64) -> bool can[Segment.Host, Unsafe.SegmentMutation]:
    can Unsafe.SegmentMutation, Segment.Host:
        raw: VAddr = ptr.cast[uintptr]
        nearest_base: mutable VAddr = 0.uintptr()
        nearest_end: mutable VAddr = 0.uintptr()
        nearest_prot: mutable u32 = 0u32
        _ = MemoryManager_FindNearestVmaRange(Memory_Instance(), raw, nearest_base, nearest_end, nearest_prot)
        return GuestExec_DebugGuardMappedGuestPointer(site, ptr, size, nearest_base, nearest_end, nearest_prot, 0u64)

def threads_sync_orbis_from_posix(ret: int) -> int:
    if ret == 0:
        return 0
    return ORBIS_KERNEL_ERROR_UNKNOWN + ret

def threads_sync_mutex_slot_low(mutex: mutable void&?&) -> bool can[Segment.Host, Unsafe.SegmentMutation]:
    can Unsafe.SegmentMutation, Segment.Host:
        addr: VAddr = mutex.cast[void&].uintptr()
        if addr == 0.uintptr():
            return true
        if MemoryManager_FindBackingIndex(Memory_Instance(), addr, 8) >= 0:
            return false
        return addr < 4096.uintptr()

def threads_sync_mutex_slot_reject_reason(mutex: mutable void&?&?) -> u64 can[Segment.Host, Unsafe.SegmentMutation]:
    can Unsafe.SegmentMutation, Segment.Host:
        if mutex == null:
            return 1u64
        addr: VAddr = mutex.cast[void&].uintptr()
        if addr == 0.uintptr():
            return 1u64
        if MemoryManager_FindBackingIndex(Memory_Instance(), addr, 8) >= 0:
            return 0u64
        if GuestExec_AddressNativeProt(addr) != 0xffffffffu32:
            return 0u64
        if addr < 4096.uintptr():
            return 3u64
        return 4u64

def threads_sync_mutex_slot_addr(mutex: mutable void&?&) -> VAddr:
    return mutex.cast[void&].uintptr()

def threads_sync_mutex_slot_is_guest_mapped(mutex: mutable void&?&) -> bool can[Segment.Host, Unsafe.SegmentMutation]:
    can Unsafe.SegmentMutation, Segment.Host:
        addr: VAddr = threads_sync_mutex_slot_addr(mutex)
        if MemoryManager_FindBackingIndex(Memory_Instance(), addr, 8) >= 0:
            return true
        return GuestExec_AddressNativeProt(addr) != 0xffffffffu32

def threads_sync_mutex_slot_value(mutex: mutable void&?&) -> uintptr can[Segment.Host, Unsafe.SegmentMutation]:
    can Unsafe.SegmentMutation, Segment.Host:
        addr: VAddr = threads_sync_mutex_slot_addr(mutex)
        if MemoryManager_FindBackingIndex(Memory_Instance(), addr, 8) >= 0:
            raw: mutable u64 = MemoryManager_ReadU64(Memory_Instance(), addr)
            if raw == 0u64 and GuestExec_AddressNativeProt(addr) != 0xffffffffu32:
                raw <- GuestExec_ReadContextU64(addr).u64()
            return raw.uintptr()
        if GuestExec_AddressNativeProt(addr) != 0xffffffffu32:
            return GuestExec_ReadContextU64(addr).u64().uintptr()
        if mutex[0] == null:
            return 0.uintptr()
        return mutex[0].uintptr()

def threads_sync_mutex_slot_write(mutex: mutable void&?&, value: void&?) -> bool can[Segment.Host, Unsafe.SegmentMutation]:
    can Unsafe.SegmentMutation, Segment.Host:
        addr: VAddr = threads_sync_mutex_slot_addr(mutex)
        raw: mutable u64 = 0u64
        if value != null:
            raw <- value.uintptr().u64()
        if MemoryManager_FindBackingIndex(Memory_Instance(), addr, 8) >= 0:
            if MemoryManager_WriteU64(Memory_Instance(), addr, raw):
                if GuestExec_AddressNativeProt(addr) != 0xffffffffu32:
                    return GuestExec_WriteU64(addr, raw)
                return true
            return false
        if GuestExec_AddressNativeProt(addr) != 0xffffffffu32:
            return GuestExec_WriteU64(addr, raw)
        mutex[0] <- value
        return true


