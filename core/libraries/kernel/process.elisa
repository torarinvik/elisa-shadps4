include "../error_codes.elisa"
include "./orbis_error.elisa"
include "./posix_error.elisa"
include "./lib_function_stub.elisa"

const GLOBAL_PID: int = 1

@fixed_layout
struct KernelModuleInfoHeader:
    st_size: mutable u64

def sceKernelIsInSandbox() -> int:
    return 1

def sceKernelGetCompiledSdkVersion(ver: void&?) -> int:
    p: mutable int&? = ver as mutable int&?
    if p == null:
        return ORBIS_KERNEL_ERROR_EINVAL
    p <- 0
    return ORBIS_OK

def sceKernelIsNeoMode() -> int:
    return 0

def sceKernelHasNeoMode() -> int:
    return 0

def sceKernelGetMainSocId() -> int:
    return 0x710f10

def sceKernelGetCpumode() -> int:
    return 0

def sceKernelGetCurrentCpu() -> int:
    return 0

def sceKernelGetProcParam() -> void&?:
    return null

def sceKernelLoadStartModule(moduleFileName: u8&?, args: u64, argp: void&?, flags: u32, pOpt: void&?, pRes: void&?) -> int:
    _ = moduleFileName
    _ = args
    _ = argp
    _ = flags
    _ = pOpt
    result: mutable int&? = pRes as mutable int&?
    if result != null:
        result <- -1
    return ORBIS_KERNEL_ERROR_ENOENT

def sceKernelDlsym(handle: int, symbol: u8&?, addrp: void&?) -> int:
    _ = handle
    _ = symbol
    addr: mutable void&?&? = addrp as mutable void&?&?
    if addr == null:
        return ORBIS_KERNEL_ERROR_EFAULT
    addr <- null
    return ORBIS_KERNEL_ERROR_ESRCH

def sceKernelGetModuleInfoForUnwind(addr: u64, flags: int, info: void&?) -> int:
    _ = addr
    if flags >= 3:
        return ORBIS_KERNEL_ERROR_EINVAL
    if info == null:
        return ORBIS_KERNEL_ERROR_EFAULT
    return ORBIS_KERNEL_ERROR_ESRCH

def sceKernelGetModuleInfoFromAddr(addr: u64, flags: int, info: void&?) -> int:
    _ = addr
    if flags >= 3:
        return ORBIS_KERNEL_ERROR_EINVAL
    if info == null:
        return ORBIS_KERNEL_ERROR_EFAULT
    return ORBIS_KERNEL_ERROR_ESRCH

def sceKernelGetModuleInfo(handle: int, info: void&?) -> int:
    _ = handle
    if info == null:
        return ORBIS_KERNEL_ERROR_EFAULT
    hdr: KernelModuleInfoHeader&? = info as KernelModuleInfoHeader&?
    if hdr == null or hdr.st_size == 0u64:
        return ORBIS_KERNEL_ERROR_EINVAL
    return ORBIS_KERNEL_ERROR_ESRCH

def sceKernelGetModuleInfo2(handle: int, info: void&?) -> int:
    return sceKernelGetModuleInfo(handle, info)

def sceKernelGetModuleInfoInternal(handle: int, info: void&?) -> int:
    return sceKernelGetModuleInfo(handle, info)

def sceKernelGetModuleList(handles: void&?, num_array: u64, out_count: void&?) -> int:
    _ = handles
    _ = num_array
    count: mutable u64&? = out_count as mutable u64&?
    if handles == null or count == null:
        return ORBIS_KERNEL_ERROR_EFAULT
    count <- 0u64
    return ORBIS_OK

def sceKernelGetModuleList2(handles: void&?, num_array: u64, out_count: void&?) -> int:
    return sceKernelGetModuleList(handles, num_array, out_count)

def posix_getuid() -> u32:
    return 1u32

def exit(status: int) -> int:
    _ = status
    return 0

def RegisterProcess(sym: void&?) -> void:
    _ = sym
    LIB_FUNCTION("xeu-pV8wkKs", "libkernel", 1, "libkernel", sceKernelIsInSandbox)
    LIB_FUNCTION("WB66evu8bsU", "libkernel", 1, "libkernel", sceKernelGetCompiledSdkVersion)
    LIB_FUNCTION("WslcK1FQcGI", "libkernel", 1, "libkernel", sceKernelIsNeoMode)
    LIB_FUNCTION("rNRtm1uioyY", "libkernel", 1, "libkernel", sceKernelHasNeoMode)
    LIB_FUNCTION("0vTn5IDMU9A", "libkernel", 1, "libkernel", sceKernelGetMainSocId)
    LIB_FUNCTION("VOx8NGmHXTs", "libkernel", 1, "libkernel", sceKernelGetCpumode)
    LIB_FUNCTION("g0VTBxfJyu0", "libkernel", 1, "libkernel", sceKernelGetCurrentCpu)
    LIB_FUNCTION("959qrazPIrg", "libkernel", 1, "libkernel", sceKernelGetProcParam)
    LIB_FUNCTION("wzvqT4UqKX8", "libkernel", 1, "libkernel", sceKernelLoadStartModule)
    LIB_FUNCTION("LwG8g3niqwA", "libkernel", 1, "libkernel", sceKernelDlsym)
    LIB_FUNCTION("RpQJJVKTiFM", "libkernel", 1, "libkernel", sceKernelGetModuleInfoForUnwind)
    LIB_FUNCTION("f7KBOafysXo", "libkernel", 1, "libkernel", sceKernelGetModuleInfoFromAddr)
    LIB_FUNCTION("kUpgrXIrz7Q", "libkernel", 1, "libkernel", sceKernelGetModuleInfo)
    LIB_FUNCTION("QgsKEUfkqMA", "libkernel", 1, "libkernel", sceKernelGetModuleInfo2)
    LIB_FUNCTION("QgsKEUfkqMA", "libkernel_module_info", 1, "libkernel", sceKernelGetModuleInfo2)
    LIB_FUNCTION("HZO7xOos4xc", "libkernel", 1, "libkernel", sceKernelGetModuleInfoInternal)
    LIB_FUNCTION("IuxnUuXk6Bg", "libkernel", 1, "libkernel", sceKernelGetModuleList)
    LIB_FUNCTION("ZzzC3ZGVAkc", "libkernel", 1, "libkernel", sceKernelGetModuleList2)
    LIB_FUNCTION("kg4x8Prhfxw", "libkernel", 1, "libkernel", posix_getuid)
    LIB_FUNCTION("6Z83sYWFlA8", "libkernel", 1, "libkernel", exit)
