# @port core/libraries/kernel/process.cpp::sceKernelGetProcParam sha256=ba14bbe80eee1ab8 oracle@a3773841
def sceKernelGetProcParam() -> void&? can[Unsafe.SegmentMutation, Segment.Host]:
    linker: mutable Linker& = Linker_GetInstance()
    result_addr: VAddr = Linker_GetProcParam(linker)
    GuestExec_RecordFirstBoundary(GUEST_EXEC_BOUNDARY_REASON_NATIVE_HLE)
    can Unsafe.SegmentMutation, Segment.Host:
        GuestExec_RecordRuntimeHle("libkernel", "sceKernelGetProcParam", 0.uintptr(), 0.uintptr(), 0.uintptr(), result_addr)
    return Linker_GetProcParam(linker).cast[void&?]

# @port core/libraries/kernel/process.cpp::sceKernelLoadStartModule sha256=7bc93f72430c8919 oracle@a3773841
def sceKernelLoadStartModule(moduleFileName: u8&?, args: u64, argp: void&?, flags: u32, pOpt: void&?, pRes: void&?) -> int:
    _ = flags
    _ = pOpt
    result: mutable int&? = pRes as mutable int&?
    if moduleFileName == null:
        return ORBIS_KERNEL_ERROR_EFAULT
    path: static u8& = moduleFileName.ref[static u8&]
    if static_strlen(path) == 0:
        return ORBIS_KERNEL_ERROR_EINVAL
    linker: mutable Linker& = Linker_GetInstance()
    handle: mutable s32 = 0
    can Unsafe.SegmentMutation, Unsafe.GuestSegmentInstall, Segment.Guest, Segment.Host:
        handle <- Linker_LoadAndStartGuestModule(linker, path, args, argp, result)
    if handle < 0:
        return ORBIS_KERNEL_ERROR_ENOENT
    return handle

# @port core/libraries/kernel/process.cpp::sceKernelStopUnloadModule sha256=a2b2f4b0839ffa56 oracle@a3773841
def sceKernelStopUnloadModule(handle: int, args: u64, argp: void&?, flags: u32, pOpt: void&?, pRes: void&?) -> int:
    _ = handle
    _ = args
    _ = argp
    _ = flags
    _ = pOpt
    result: mutable int&? = pRes as mutable int&?
    if result != null:
        result[0] <- ORBIS_OK
    return ORBIS_OK

# @port core/libraries/kernel/process.cpp::sceKernelDlsym sha256=bfe180e683c949e3 oracle@a3773841
def sceKernelDlsym(handle: int, symbol: u8&?, addrp: void&?) -> int:
    addr: mutable void&?&? = addrp as mutable void&?&?
    if addr == null:
        return ORBIS_KERNEL_ERROR_EFAULT
    linker: mutable Linker& = Linker_GetInstance()
    module: mutable Module&? = Linker_GetModule(linker, handle.s32())
    if module == null:
        return ORBIS_KERNEL_ERROR_ESRCH
    if symbol == null:
        addr[0] <- null
        return ORBIS_KERNEL_ERROR_ESRCH
    resolved_addr: mutable u64 = 0u64
    if not Module_FindDefinedSymbolAddress(module, symbol.ref[static u8&], resolved_addr.ref[mutable u64&]):
        addr[0] <- null
        return ORBIS_KERNEL_ERROR_ESRCH
    addr[0] <- resolved_addr.cast[void&?]
    return ORBIS_OK

# @port core/libraries/kernel/process.cpp::sceKernelGetModuleInfoForUnwind sha256=e3961986ad0ba9b3 oracle@a3773841
def sceKernelGetModuleInfoForUnwind(addr: u64, flags: int, info: void&?) -> int:
    kernel_debug_unwind_addr <- addr
    kernel_debug_unwind_flags <- flags
    kernel_debug_unwind_info <- info.uintptr().u64()
    kernel_debug_unwind_ret <- 0
    kernel_debug_unwind_module_base <- 0u64
    kernel_debug_unwind_module_size <- 0u64
    GuestExec_RecordFirstBoundary(GUEST_EXEC_BOUNDARY_REASON_NATIVE_HLE)
    can Unsafe.SegmentMutation, Segment.Host:
        GuestExec_RecordRuntimeHle("libkernel", "sceKernelGetModuleInfoForUnwind", addr.uintptr(), flags.uintptr(), info.uintptr(), 0.uintptr())
    if flags >= 3:
        unwind_info: mutable OrbisModuleInfoForUnwind&? = info as mutable OrbisModuleInfoForUnwind&?
        if unwind_info != null:
            Kernel_ClearModuleInfoForUnwind(unwind_info)
        ret_invalid_flags: int = ORBIS_KERNEL_ERROR_EINVAL
        kernel_debug_unwind_ret <- ret_invalid_flags
        can Unsafe.SegmentMutation, Segment.Host:
            GuestExec_RecordRuntimeHle("libkernel", "sceKernelGetModuleInfoForUnwind", addr.uintptr(), flags.uintptr(), info.uintptr(), ret_invalid_flags.u64().uintptr())
        return ret_invalid_flags
    if info == null:
        ret_null_info: int = ORBIS_KERNEL_ERROR_EFAULT
        kernel_debug_unwind_ret <- ret_null_info
        can Unsafe.SegmentMutation, Segment.Host:
            GuestExec_RecordRuntimeHle("libkernel", "sceKernelGetModuleInfoForUnwind", addr.uintptr(), flags.uintptr(), info.uintptr(), ret_null_info.u64().uintptr())
        return ret_null_info
    unwind_info: mutable OrbisModuleInfoForUnwind&? = info as mutable OrbisModuleInfoForUnwind&?
    if unwind_info == null or unwind_info.st_size < size_of(OrbisModuleInfoForUnwind).u64():
        ret_bad_info: int = ORBIS_KERNEL_ERROR_EINVAL
        kernel_debug_unwind_ret <- ret_bad_info
        can Unsafe.SegmentMutation, Segment.Host:
            GuestExec_RecordRuntimeHle("libkernel", "sceKernelGetModuleInfoForUnwind", addr.uintptr(), flags.uintptr(), info.uintptr(), ret_bad_info.u64().uintptr())
        return ret_bad_info
    linker: mutable Linker& = Linker_GetInstance()
    module: mutable Module&? = Linker_FindByAddress(linker, addr.uintptr())
    if module == null:
        ret_missing_module: int = ORBIS_KERNEL_ERROR_ESRCH
        kernel_debug_unwind_ret <- ret_missing_module
        can Unsafe.SegmentMutation, Segment.Host:
            GuestExec_RecordRuntimeHle("libkernel", "sceKernelGetModuleInfoForUnwind", addr.uintptr(), flags.uintptr(), info.uintptr(), ret_missing_module.u64().uintptr())
        return ret_missing_module
    mod_info: OrbisKernelModuleInfoEx = Module_GetModuleInfoEx(module)
    Kernel_ClearModuleInfoForUnwind(unwind_info)
    Kernel_CopyModuleInfoUnwindName(unwind_info, mod_info.name)
    unwind_info.eh_frame_hdr_addr <- mod_info.eh_frame_hdr_addr
    unwind_info.eh_frame_addr <- mod_info.eh_frame_addr
    unwind_info.eh_frame_size <- mod_info.eh_frame_size.u64()
    unwind_info.seg0_addr <- module.base_virtual_addr
    unwind_info.seg0_size <- module.base_size
    kernel_debug_unwind_ret <- ORBIS_OK
    kernel_debug_unwind_module_base <- module.base_virtual_addr.u64()
    kernel_debug_unwind_module_size <- module.base_size
    can Unsafe.SegmentMutation, Segment.Host:
        GuestExec_RecordRuntimeHle("libkernel", "sceKernelGetModuleInfoForUnwind", addr.uintptr(), flags.uintptr(), info.uintptr(), ORBIS_OK.uintptr())
    return ORBIS_OK

# @port core/libraries/kernel/process.cpp::sceKernelGetModuleInfoFromAddr sha256=ccceef4f4e30c6b1 oracle@a3773841
def sceKernelGetModuleInfoFromAddr(addr: u64, flags: int, info: void&?) -> int:
    if flags >= 3:
        ex_info: mutable OrbisKernelModuleInfoEx&? = info as mutable OrbisKernelModuleInfoEx&?
        if ex_info != null:
            Kernel_ClearModuleInfoEx(ex_info)
        return ORBIS_KERNEL_ERROR_EINVAL
    if info == null:
        return ORBIS_KERNEL_ERROR_EFAULT
    ex_info: mutable OrbisKernelModuleInfoEx&? = info as mutable OrbisKernelModuleInfoEx&?
    if ex_info == null:
        return ORBIS_KERNEL_ERROR_EINVAL
    linker: mutable Linker& = Linker_GetInstance()
    module: mutable Module&? = Linker_FindByAddress(linker, addr.uintptr())
    if module == null:
        return ORBIS_KERNEL_ERROR_ESRCH
    ex_info[0] <- Module_GetModuleInfoEx(module)
    return ORBIS_OK

# @port core/libraries/kernel/process.cpp::sceKernelGetModuleInfo sha256=59c2b5a80cbe65b9 oracle@a3773841
def sceKernelGetModuleInfo(handle: int, info: void&?) -> int:
    if info == null:
        return ORBIS_KERNEL_ERROR_EFAULT
    module_info: mutable OrbisKernelModuleInfo&? = info as mutable OrbisKernelModuleInfo&?
    if module_info == null or module_info.st_size != 0x160.u64():
        return ORBIS_KERNEL_ERROR_EINVAL
    linker: mutable Linker& = Linker_GetInstance()
    module: mutable Module&? = Linker_GetModule(linker, handle.s32())
    if module == null:
        return ORBIS_KERNEL_ERROR_ESRCH
    module_info[0] <- Module_GetModuleInfo(module)
    return ORBIS_OK

# @port core/libraries/kernel/process.cpp::sceKernelGetModuleInfo2 sha256=49b770cad90cc7ca oracle@a3773841
def sceKernelGetModuleInfo2(handle: int, info: void&?) -> int:
    if info == null:
        return ORBIS_KERNEL_ERROR_EFAULT
    module_info: mutable OrbisKernelModuleInfo&? = info as mutable OrbisKernelModuleInfo&?
    if module_info == null or module_info.st_size != 0x160.u64():
        return ORBIS_KERNEL_ERROR_EINVAL
    linker: mutable Linker& = Linker_GetInstance()
    module: mutable Module&? = Linker_GetModule(linker, handle.s32())
    if module == null:
        return ORBIS_KERNEL_ERROR_ESRCH
    if Module_IsSharedLib(module):
        return ORBIS_KERNEL_ERROR_EPERM
    module_info[0] <- Module_GetModuleInfo(module)
    return ORBIS_OK

# @port core/libraries/kernel/process.cpp::sceKernelGetModuleInfoInternal sha256=c943678d59b25e5c oracle@a3773841
def sceKernelGetModuleInfoInternal(handle: int, info: void&?) -> int:
    if info == null:
        return ORBIS_KERNEL_ERROR_EFAULT
    ex_info: mutable OrbisKernelModuleInfoEx&? = info as mutable OrbisKernelModuleInfoEx&?
    if ex_info == null or ex_info.st_size != 0x1A8.u64():
        return ORBIS_KERNEL_ERROR_EINVAL
    linker: mutable Linker& = Linker_GetInstance()
    module: mutable Module&? = Linker_GetModule(linker, handle.s32())
    if module == null:
        return ORBIS_KERNEL_ERROR_ESRCH
    ex_info[0] <- Module_GetModuleInfoEx(module)
    return ORBIS_OK

# @port core/libraries/kernel/process.cpp::sceKernelGetModuleList sha256=bf684bf99d3b4651 oracle@a3773841
def sceKernelGetModuleList(handles: void&?, num_array: u64, out_count: void&?) -> int:
    handle_array: mutable s32&? = handles as mutable s32&?
    count: mutable u64&? = out_count as mutable u64&?
    if handle_array == null or count == null:
        return ORBIS_KERNEL_ERROR_EFAULT
    linker: mutable Linker& = Linker_GetInstance()
    written: mutable u64 = 0u64
    while written < num_array and written < linker.modules.count.u64():
        handle_array[written.usize()] <- written.s32()
        written <- written + 1u64
    if written == num_array and written < linker.modules.count.u64():
        return ORBIS_KERNEL_ERROR_ENOMEM
    count[0] <- written
    return ORBIS_OK

# @port core/libraries/kernel/process.cpp::sceKernelGetModuleList2 sha256=9f494afe776c462d oracle@a3773841
def sceKernelGetModuleList2(handles: void&?, num_array: u64, out_count: void&?) -> int:
    handle_array: mutable s32&? = handles as mutable s32&?
    count: mutable u64&? = out_count as mutable u64&?
    if handle_array == null or count == null:
        return ORBIS_KERNEL_ERROR_EFAULT
    linker: mutable Linker& = Linker_GetInstance()
    id: mutable u64 = 0u64
    written: mutable u64 = 0u64
    while id < linker.modules.count.u64():
        module: Module = linker.modules[id.usize()]
        if not Module_IsSharedLib(module):
            if written >= num_array:
                return ORBIS_KERNEL_ERROR_ENOMEM
            handle_array[written.usize()] <- id.s32()
            written <- written + 1u64
        id <- id + 1u64
    count[0] <- written
    return ORBIS_OK

# @port core/libraries/kernel/process.cpp::posix_getuid sha256=66c8f772e6d19996 oracle@a3773841
def posix_getuid() -> u32:
    return 1u32

# @port core/libraries/kernel/process.cpp::posix_getrusage sha256=f2e78ac64bee8df3 oracle@a3773841
def posix_getrusage(who: int, usage: void&?) -> int:
    _ = who
    if usage == null:
        return -1
    out: mutable u8&? = usage as mutable u8&?
    if out == null:
        return -1
    i: mutable int = 0
    while i < 0x90:
        out[i.usize()] <- 0u8
        i <- i + 1
    return 0

