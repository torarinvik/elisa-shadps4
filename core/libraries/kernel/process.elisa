@fixed_layout
struct KernelModuleInfoHeader:
    st_size: mutable u64

@fixed_layout
struct OrbisModuleInfoForUnwind:
    st_size: mutable u64
    name: mutable u8[256]
    eh_frame_hdr_addr: mutable VAddr
    eh_frame_addr: mutable VAddr
    eh_frame_size: mutable u64
    seg0_addr: mutable VAddr
    seg0_size: mutable u64

global mutable kernel_debug_unwind_addr: u64 = 0u64
global mutable kernel_debug_unwind_flags: int = 0
global mutable kernel_debug_unwind_info: u64 = 0u64
global mutable kernel_debug_unwind_ret: int = 0
global mutable kernel_debug_unwind_module_base: u64 = 0u64
global mutable kernel_debug_unwind_module_size: u64 = 0u64

def Kernel_DebugUnwindAddr() -> u64:
    return kernel_debug_unwind_addr

def Kernel_DebugUnwindFlags() -> int:
    return kernel_debug_unwind_flags

def Kernel_DebugUnwindInfo() -> u64:
    return kernel_debug_unwind_info

def Kernel_DebugUnwindRet() -> int:
    return kernel_debug_unwind_ret

def Kernel_DebugUnwindModuleBase() -> u64:
    return kernel_debug_unwind_module_base

def Kernel_DebugUnwindModuleSize() -> u64:
    return kernel_debug_unwind_module_size

def Kernel_ClearModuleInfoEx(info: mutable OrbisKernelModuleInfoEx&) -> void:
    info.st_size <- 0u64
    info.name <- ""
    info.id <- 0
    info.tls_index <- 0u32
    info.tls_init_addr <- 0.uintptr()
    info.tls_init_size <- 0u32
    info.tls_size <- 0u32
    info.tls_offset <- 0u32
    info.tls_align <- 0u32
    info.init_proc_addr <- 0.uintptr()
    info.fini_proc_addr <- 0.uintptr()
    info.eh_frame_hdr_addr <- 0.uintptr()
    info.eh_frame_addr <- 0.uintptr()
    info.eh_frame_hdr_size <- 0u32
    info.eh_frame_size <- 0u32
    info.segment_count <- 0u32

def Kernel_ClearModuleInfoForUnwind(info: mutable OrbisModuleInfoForUnwind&) -> void:
    info.st_size <- 0u64
    i: mutable usize = 0
    while i < 256:
        info.name[i] <- 0u8
        i <- i + 1
    info.eh_frame_hdr_addr <- 0.uintptr()
    info.eh_frame_addr <- 0.uintptr()
    info.eh_frame_size <- 0u64
    info.seg0_addr <- 0.uintptr()
    info.seg0_size <- 0u64

def Kernel_CopyModuleInfoUnwindName(info: mutable OrbisModuleInfoForUnwind&, name: static u8&) -> void:
    len: usize = static_strlen(name)
    limit: mutable usize = len
    if limit > 255:
        limit <- 255
    i: mutable usize = 0
    while i < limit:
        info.name[i] <- name[i]
        i <- i + 1
    info.name[i] <- 0u8

# @port core/libraries/kernel/process.cpp::sceKernelIsInSandbox sha256=9d22bc8333984541 oracle@a3773841
def sceKernelIsInSandbox() -> int:
    return 1

# @port core/libraries/kernel/process.cpp::sceKernelGetCompiledSdkVersion sha256=92b20e66de8390d2 oracle@a3773841
def sceKernelGetCompiledSdkVersion(ver: void&?) -> int:
    p: mutable int&? = ver as mutable int&?
    if p == null:
        return ORBIS_KERNEL_ERROR_EINVAL
    linker: mutable Linker& = Linker_GetInstance()
    p[0] <- Linker_GetCompiledSdkVersion(linker).int()
    return ORBIS_OK

