    _ = sym
    ge_known_kernel_file_write_target <- KernelFile_Write.uintptr().u64()
    ge_known_posix_write_target <- posix_write.uintptr().u64()
    ge_known_sce_kernel_write_target <- sceKernelWrite.uintptr().u64()
    LIB_FUNCTION("6c3rCVE-fTU", "libkernel", 1, "libkernel", KernelFile_Open)
