    _ = iov
    _ = iovcnt
    return ORBIS_OK

def posix_lseek(fd: int, offset: i64, whence: int) -> i64:
    h: mutable KernelFileHandle&? = KernelFile_GetHandle(fd)
    if h == null:
        return KernelFile_PosixFail64(POSIX_EBADF)
    return KernelFile_LseekHandle(h, offset, whence)

def sceKernelLseek(fd: int, offset: i64, whence: int) -> i64:
    result: i64 = posix_lseek(fd, offset, whence)
    if result < 0:
        return KernelFile_SceErrorFromErrno().i64()
    return result

def KernelFile_Read(fd: int, buf: void&?, nbytes: u64) -> i64:
    h: mutable KernelFileHandle&? = KernelFile_GetHandle(fd)
    if h == null:
        return KernelFile_PosixFail64(POSIX_EBADF)
    return KernelFile_ReadHandle(h, buf, nbytes)

def posix_read(fd: int, buf: void&?, nbytes: u64) -> i64:
    return KernelFile_Read(fd, buf, nbytes)

def sceKernelRead(fd: int, buf: void&?, nbytes: u64) -> i64:
    result: i64 = KernelFile_Read(fd, buf, nbytes)
    if result < 0:
        return KernelFile_SceErrorFromErrno().i64()
    return result

def posix_mkdir(path: u8&?, mode: int) -> int:
    _ = path
    _ = mode
    return -1

def sceKernelMkdir(path: u8&?, mode: int) -> int:
    _ = path
    _ = mode
    return ORBIS_OK

def posix_rmdir(path: u8&?) -> int:
    _ = path
    return -1

def sceKernelRmdir(path: u8&?) -> int:
    _ = path
    return ORBIS_OK

def posix_stat(path: u8&?, sb: void&?) -> int:
    if path == null:
        return KernelFile_PosixFail(POSIX_EFAULT)
    guest_path: static u8& = path.cast[static u8&]
    if runtime_strlen(guest_path) > 255:
        return KernelFile_PosixFail(POSIX_ENAMETOOLONG)
    host_path: static u8& = KernelFile_ResolveHostPath(guest_path, null)
    return KernelFile_FillStatForHostPath(host_path, sb)

def sceKernelStat(path: u8&?, sb: void&?) -> int:
    result: int = posix_stat(path, sb)
    if result < 0:
        return KernelFile_SceErrorFromErrno()
    return result

def sceKernelCheckReachability(path: u8&?) -> int:
    _ = path
    return ORBIS_OK

def posix_fstat(fd: int, sb: void&?) -> int:
    h: mutable KernelFileHandle&? = KernelFile_GetHandle(fd)
    if h == null:
        return KernelFile_PosixFail(POSIX_EBADF)
    handle: mutable KernelFileHandle& = h
    return KernelFile_FillStatForHostPath(handle.path, sb)

def sceKernelFstat(fd: int, sb: void&?) -> int:
    result: int = posix_fstat(fd, sb)
    if result < 0:
        return KernelFile_SceErrorFromErrno()
    return result

