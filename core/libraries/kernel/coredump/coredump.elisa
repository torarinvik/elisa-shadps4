include "../../error_codes.elisa"
include "./coredump_error.elisa"
include "./coredump_nids.elisa"

type OrbisCoredumpHandler = func(void&?) -> s32

def LIB_FUNCTION[T](nid: static u8&, lib_name: static u8&, version: int, export_lib: static u8&, func: T) -> void:
    return

@fixed_layout
struct OrbisCoredumpStopInfoCpu:
    thread: mutable void&?
    reason_code: mutable s32

@fixed_layout
struct OrbisCoredumpStopInfoGpu:
    timestamp: mutable u64

@fixed_layout
struct OrbisCoredumpThreadContextInfo:
    rdi: mutable u64
    rsi: mutable u64
    rdx: mutable u64
    rcx: mutable u64
    r8: mutable u64
    r9: mutable u64
    rax: mutable u64
    rbx: mutable u64
    rbp: mutable u64
    r10: mutable u64
    r11: mutable u64
    r12: mutable u64
    r13: mutable u64
    r14: mutable u64
    r15: mutable u64
    rip: mutable u64
    rflags: mutable u64
    rsp: mutable u64

global mutable g_coredump_handler: OrbisCoredumpHandler? = null
global mutable g_coredump_common: void&? = null
global mutable g_sdk_ver: s32 = 0

def sceCoredumpRegisterCoredumpHandler(handler: OrbisCoredumpHandler?, stack_size: u64, common: void&?) -> s32:
    if g_coredump_handler != null:
        return ORBIS_COREDUMP_ERROR_ALREADY_REGISTERED
    if handler == null or stack_size >= 0x20000000u64:
        return ORBIS_COREDUMP_ERROR_PARAM
    g_coredump_handler <- handler
    g_coredump_common <- common
    return ORBIS_OK

def sceCoredumpUnregisterCoredumpHandler() -> s32:
    if g_coredump_handler == null:
        return ORBIS_COREDUMP_ERROR_NOT_REGISTERED
    g_coredump_handler <- null
    return ORBIS_OK

def RegisterCoredump(sym: void&?) -> void:
    _ = sym
    g_sdk_ver <- 0
    LIB_FUNCTION("8zLSfEfW5AU", "libSceCoredump", 1, "libkernel", sceCoredumpRegisterCoredumpHandler)
    LIB_FUNCTION("fFkhOgztiCA", "libSceCoredump", 1, "libkernel", sceCoredumpUnregisterCoredumpHandler)
