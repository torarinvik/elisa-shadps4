# Elisa parity helper for kernel/sync/mutex.{h,cpp} TimedMutex.
# This is a cooperative runtime model used for semantic/runtime parity tests.

struct TimedMutex:
    is_locked: mutable bool

def TimedMutex_new() -> TimedMutex:
    out: mutable TimedMutex = zeroed
    out.is_locked <- false
    return out

def TimedMutex_lock(mtx: mutable TimedMutex&) -> void:
    # In single-threaded parity runtime, lock is a best-effort acquire.
    if not mtx.is_locked:
        mtx.is_locked <- true

def TimedMutex_try_lock(mtx: mutable TimedMutex&) -> bool:
    if mtx.is_locked:
        return false
    mtx.is_locked <- true
    return true

def TimedMutex_unlock(mtx: mutable TimedMutex&) -> void:
    mtx.is_locked <- false

def TimedMutex_try_lock_for(mtx: mutable TimedMutex&, rel_time_ns: i64) -> bool:
    _ = rel_time_ns
    return TimedMutex_try_lock(mtx)

def TimedMutex_try_lock_until(mtx: mutable TimedMutex&, abs_time_ns: i64) -> bool:
    _ = abs_time_ns
    return TimedMutex_try_lock(mtx)
