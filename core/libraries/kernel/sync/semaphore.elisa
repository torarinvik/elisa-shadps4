# Elisa parity helper for kernel/sync/semaphore.h template Semaphore<max>.
# This models semaphore state for cooperative runtime checks.

const ORBIS_KERNEL_SEM_VALUE_MAX: int = 0x7fffffff

struct Semaphore:
    count: mutable int
    max_count: mutable int

type BinarySemaphore = Semaphore
type CountingSemaphore = Semaphore

def Semaphore_new(initialCount: int, maxCount: int) -> Semaphore:
    out: mutable Semaphore = zeroed
    out.max_count <- (1 if maxCount < 1 else maxCount)
    if initialCount < 0:
        out.count <- 0
    elif initialCount > out.max_count:
        out.count <- out.max_count
    else:
        out.count <- initialCount
    return out

def Semaphore_release(sem: mutable Semaphore&) -> void:
    if sem.count < sem.max_count:
        sem.count <- sem.count + 1

def Semaphore_acquire(sem: mutable Semaphore&) -> void:
    # Cooperative mode: consume one token if available, otherwise no-op.
    if sem.count > 0:
        sem.count <- sem.count - 1

def Semaphore_try_acquire(sem: mutable Semaphore&) -> bool:
    if sem.count > 0:
        sem.count <- sem.count - 1
        return true
    return false

def Semaphore_try_acquire_for(sem: mutable Semaphore&, rel_time_ns: i64) -> bool:
    _ = rel_time_ns
    return Semaphore_try_acquire(sem)

def Semaphore_try_acquire_until(sem: mutable Semaphore&, abs_time_ns: i64) -> bool:
    _ = abs_time_ns
    return Semaphore_try_acquire(sem)

def BinarySemaphore_new(initialCount: int = 0) -> BinarySemaphore:
    return Semaphore_new(initialCount, 1)

def CountingSemaphore_new(initialCount: int = 0) -> CountingSemaphore:
    return Semaphore_new(initialCount, ORBIS_KERNEL_SEM_VALUE_MAX)
