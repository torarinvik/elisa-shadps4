    _ = sym
    time_initial_ptc_ns <- time_now_ns()
    time_tsc_frequency <- 1000000000u64

    LIB_FUNCTION("NhpspxdjEKU", "libkernel", 1, "libkernel", posix_nanosleep)
    LIB_FUNCTION("NhpspxdjEKU", "libScePosix", 1, "libkernel", posix_nanosleep)
