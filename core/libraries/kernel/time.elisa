include "../error_codes.elisa"
include "./orbis_error.elisa"
include "./posix_error.elisa"
include "./lib_function_stub.elisa"

def posix_nanosleep(rqtp: void&?, rmtp: void&?) -> int:
    _ = rqtp
    _ = rmtp
    return -1

def posix_usleep(microseconds: u32) -> int:
    _ = microseconds
    return -1

def posix_sleep(seconds: u32) -> u32:
    _ = seconds
    return 0u32

def posix_clock_gettime(clock_id: u32, ts: void&?) -> int:
    _ = clock_id
    _ = ts
    return -1

def posix_clock_getres(clock_id: u32, res: void&?) -> int:
    _ = clock_id
    _ = res
    return -1

def posix_gettimeofday(tp: void&?, tz: void&?) -> int:
    _ = tp
    _ = tz
    return -1

def sceKernelSettimeofday(_tv: void&?, _tz: void&?) -> int:
    _ = _tv
    _ = _tz
    return ORBIS_OK

def posix_settimeofday(_tv: void&?, _tz: void&?) -> int:
    _ = _tv
    _ = _tz
    return -1

def posix_clock_settime(clock_id: int, tp: void&?) -> int:
    _ = clock_id
    _ = tp
    return -1

def sceKernelGetProcessTime() -> u64:
    return 0u64

def sceKernelGetProcessTimeCounter() -> u64:
    return 0u64

def sceKernelGetProcessTimeCounterFrequency() -> u64:
    return 0u64

def sceKernelReadTsc() -> u64:
    return 0u64

def sceKernelGetTscFrequency() -> u64:
    return 0u64

def sceKernelNanosleep(rqtp: void&?, rmtp: void&?) -> int:
    _ = rqtp
    _ = rmtp
    return ORBIS_OK

def sceKernelUsleep(microseconds: u32) -> int:
    _ = microseconds
    return ORBIS_OK

def sceKernelSleep(seconds: u32) -> int:
    _ = seconds
    return ORBIS_OK

def sceKernelClockGettime(clock_id: u32, ts: void&?) -> int:
    _ = clock_id
    _ = ts
    return ORBIS_OK

def sceKernelClockGetres(clock_id: u32, res: void&?) -> int:
    _ = clock_id
    _ = res
    return ORBIS_OK

def sceKernelGettimeofday(tp: void&?) -> int:
    _ = tp
    return ORBIS_OK

def sceKernelGettimezone(tz: void&?) -> int:
    _ = tz
    return ORBIS_OK

def sceKernelConvertLocaltimeToUtc(param_1: i64, param_2: i64, seconds: void&?, timezone: void&?, dst_seconds: void&?) -> int:
    _ = param_1
    _ = param_2
    _ = seconds
    _ = timezone
    _ = dst_seconds
    return ORBIS_OK

def sceKernelConvertUtcToLocaltime(time: i64, local_time: void&?, st: void&?, dst_sec: void&?) -> int:
    _ = time
    _ = local_time
    _ = st
    _ = dst_sec
    return ORBIS_OK

