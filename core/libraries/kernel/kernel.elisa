include "../error_codes.elisa"
include "./orbis_error.elisa"
include "./posix_error.elisa"
include "./lib_function_stub.elisa"
include "../../guest_exec.elisa"

const CURRENT_FIRMWARE_VERSION: int = 0x13500011
const GLOBAL_PID: int = 1
const POSIX_SC_PAGESIZE: int = 47

global mutable g_stack_chk_guard: u64 = 0x54321ABC.u64()

@fixed_layout
struct SwVersionStruct:
    struct_size: mutable u64
    text_representation: mutable i8[0x1c]
    hex_representation: mutable u32

@fixed_layout
struct AuthInfoData:
    paid: mutable u64
    caps: mutable u64[4]
    attrs: mutable u64[4]
    ucred: mutable u64[8]

@fixed_layout
struct OrbisKernelTitleWorkaround:
    version: mutable int
    align: mutable int
    ids: mutable u64[2]

@fixed_layout
struct OrbisKernelAppInfo:
    app_id: mutable int
    mmap_flags: mutable int
    attribute_exe: mutable int
    attribute2: mutable int
    cusa_name: mutable i8[10]
    debug_level: mutable u8
    slv_flags: mutable u8
    mini_app_dmem_flags: mutable u8
    render_mode: mutable u8
    mdbg_out: mutable u8
    required_hdcp_type: mutable u8
    preload_prx_flags: mutable u64
    attribute1: mutable int
    has_param_sfo: mutable int
    title_workaround: mutable OrbisKernelTitleWorkaround

@fixed_layout
struct HeapInfoInfo:
    size: mutable u64
    flag: mutable u32
    getSegmentInfo: mutable u32
    mspace_atomic_id_mask: mutable void&?
    mstate_table: mutable void&?

@fixed_layout
struct OrbisKernelUuid:
    timeLow: mutable u32
    timeMid: mutable u16
    timeHiAndVersion: mutable u16
    clockSeqHiAndReserved: mutable u8
    clockSeqLow: mutable u8
    node: mutable u8[6]

global mutable g_posix_errno: int = 0
global mutable g_mspace_atomic_id_mask: u64 = 0u64
global mutable g_mstate_table: u64[64] = zeroed
global mutable g_libc_ztext_start: u64 = 0u64
global mutable g_libc_ztext_stop: u64 = 0u64

def __Error() -> void&?:
    # POSIX errno is a process-wide singleton (matches the C runtime). Vouched
    # locally so this presents a clean signature matching its extern forward-decl.
    trusted Unsafe.MutableGlobal, Unsafe.PointerCast:
        return g_posix_errno.ref[mutable int&].cast[void&]

def ErrSceToPosix(err: int) -> void:
    g_posix_errno <- err - ORBIS_KERNEL_ERROR_UNKNOWN


def ErrnoToSceKernelError(err: int) -> int:
    return err + ORBIS_KERNEL_ERROR_UNKNOWN


def SetPosixErrno(e: int) -> void:
    # Process-wide POSIX errno singleton; vouched locally to keep a clean
    # signature matching the extern forward-decls used by other modules.
    trusted Unsafe.MutableGlobal:
        if e == POSIX_EPERM:
            g_posix_errno <- POSIX_EPERM
        elif e == POSIX_ENOENT:
            g_posix_errno <- POSIX_ENOENT
        elif e == POSIX_EDEADLK:
            g_posix_errno <- POSIX_EDEADLK
        elif e == POSIX_ENOMEM:
            g_posix_errno <- POSIX_ENOMEM
        elif e == POSIX_EACCES:
            g_posix_errno <- POSIX_EACCES
        elif e == POSIX_EFAULT:
            g_posix_errno <- POSIX_EFAULT
        elif e == POSIX_EINVAL:
            g_posix_errno <- POSIX_EINVAL
        elif e == POSIX_ENOSPC:
            g_posix_errno <- POSIX_ENOSPC
        elif e == POSIX_ERANGE:
            g_posix_errno <- POSIX_ERANGE
        elif e == POSIX_EAGAIN:
            g_posix_errno <- POSIX_EAGAIN
        elif e == POSIX_ETIMEDOUT:
            g_posix_errno <- POSIX_ETIMEDOUT
        else:
            g_posix_errno <- e


def sceKernelError(posix_error: int) -> int:
    if posix_error == 0:
        return 0
    return posix_error + ORBIS_KERNEL_ERROR_UNKNOWN


def sceKernelGetAllowedSdkVersionOnSystem(ver: void&?) -> int:
    out: mutable int&? = ver as mutable int&?
    if out == null:
        return ORBIS_KERNEL_ERROR_EINVAL
    out[0] <- CURRENT_FIRMWARE_VERSION | 0xfff
    return ORBIS_OK


def sceKernelGetSystemSwVersion(ret: void&?) -> int:
    out: mutable SwVersionStruct&? = ret as mutable SwVersionStruct&?
    if out == null:
        return ORBIS_OK
    out.hex_representation <- CURRENT_FIRMWARE_VERSION.u32()
    i: mutable int = 0
    while i < 0x1c:
        out.text_representation[i.usize()] <- 0
        i <- i + 1
    # Minimal stable value; formatting parity can be expanded later.
    out.text_representation[0] <- '1'.i8()
    out.text_representation[1] <- '.'.i8()
    out.text_representation[2] <- '3'.i8()
    out.text_representation[3] <- '5'.i8()
    return ORBIS_OK


def get_authinfo(pid: int, p2: void&?) -> int:
    if p2 == null:
        SetPosixErrno(POSIX_EPERM)
        return -1
    if pid != 0 and pid != GLOBAL_PID:
        SetPosixErrno(POSIX_ESRCH)
        return -1
    info: mutable AuthInfoData&? = p2 as mutable AuthInfoData&?
    if info != null:
        info.paid <- 0u64
        idx: mutable int = 0
        while idx < 4:
            info.caps[idx.usize()] <- 0u64
            info.attrs[idx.usize()] <- 0u64
            idx <- idx + 1
        idx <- 0
        while idx < 8:
            info.ucred[idx.usize()] <- 0u64
            idx <- idx + 1
        info.caps[0] <- 0x2000000000000000u64
    return ORBIS_OK


def sceKernelGetAppInfo(pid: int, app_info: void&?) -> int:
    if pid != GLOBAL_PID:
        return ORBIS_KERNEL_ERROR_EPERM
    info: mutable OrbisKernelAppInfo&? = app_info as mutable OrbisKernelAppInfo&?
    if info == null:
        return ORBIS_OK
    info.has_param_sfo <- 1
    return ORBIS_OK


def sceKernelTitleWorkaroundIsEnabled(tw: void&?, bit: int, result: void&?) -> int:
    if tw == null or result == null:
        return ORBIS_KERNEL_ERROR_EFAULT
    if bit >= 0x3a:
        return ORBIS_KERNEL_ERROR_EINVAL
    work: OrbisKernelTitleWorkaround&? = tw as OrbisKernelTitleWorkaround&?
    out: mutable int&? = result as mutable int&?
    if work == null or out == null:
        return ORBIS_KERNEL_ERROR_EFAULT
    idx: usize = (bit >> 6).usize()
    shift: u64 = (bit & 0x3f).u64()
    out[0] <- ((work.ids[idx] >> shift) & 1u64).int()
    return ORBIS_OK


def sceKernelGetProcessType(pid: int) -> int:
    if pid != GLOBAL_PID:
        return ORBIS_KERNEL_ERROR_ENOSYS
    return 0


def kernel_ioctl(fd: int, cmd: u64, VA_ARGS: int) -> int:
    _ = fd
    _ = cmd
    _ = VA_ARGS
    return ORBIS_OK


def sceKernelGetFsSandboxRandomWord() -> u8&?:
    return "sys"


def _sigprocmask() -> int:
    return ORBIS_OK


def sceKernelUuidCreate(orbisUuid: void&?) -> int:
    uuid: mutable OrbisKernelUuid&? = orbisUuid as mutable OrbisKernelUuid&?
    if uuid == null:
        return ORBIS_KERNEL_ERROR_EINVAL
    uuid.timeLow <- 0u32
    uuid.timeMid <- 0u16
    uuid.timeHiAndVersion <- 0u16
    uuid.clockSeqHiAndReserved <- 0u8
    uuid.clockSeqLow <- 0u8
    i: mutable int = 0
    while i < 6:
        uuid.node[i.usize()] <- 0u8
        i <- i + 1
    return ORBIS_OK


def stack_chk_fail() -> int can[Unsafe.SegmentMutation, Segment.Host]:
    can Unsafe.SegmentMutation, Segment.Host:
        GuestExec_AbortGuestFatalHle(0x5354434bu64.uintptr())
    return ORBIS_KERNEL_ERROR_EFAULT


def posix_getpagesize() -> int:
    return 16 * 1024


def posix_sysconf(name: int) -> u64:
    if name == POSIX_SC_PAGESIZE:
        return posix_getpagesize().u64()
    return 0u64


def sceLibcHeapGetTraceInfo(info: void&?) -> void:
    out: mutable HeapInfoInfo&? = info as mutable HeapInfoInfo&?
    if out != null:
        out.mspace_atomic_id_mask <- g_mspace_atomic_id_mask.ref[mutable u64&].cast[void&]
        out.mstate_table <- g_mstate_table[0].ref[mutable u64&].cast[void&]
        out.getSegmentInfo <- 0u32
    return

def sceKernelInternalMemoryGetModuleSegmentInfo(address_or_handle: u64, segment_index_or_info: u64, info: void&?) -> int:
    _ = address_or_handle
    _ = segment_index_or_info
    if info == null:
        return ORBIS_KERNEL_ERROR_EFAULT
    return ORBIS_KERNEL_ERROR_ESRCH

def Need_sceLibcInternal() -> int:
    return ORBIS_OK

