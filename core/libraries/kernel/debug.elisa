include "../error_codes.elisa"
include "./orbis_error.elisa"
include "./posix_error.elisa"
include "./lib_function_stub.elisa"

def sceKernelDebugOutText(unk: void&?, text: u8&?) -> void:
    _ = unk
    _ = text
    return

def RegisterDebug(sym: void&?) -> void:
    _ = sym
    LIB_FUNCTION("9JYNqN6jAKI", "libkernel", 1, "libkernel", sceKernelDebugOutText)
