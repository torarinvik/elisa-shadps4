const ORBIS_COMPANION_HTTPD_EVENT_CONNECT: int = 0x10000001
const ORBIS_COMPANION_HTTPD_EVENT_DISCONNECT: int = 0x10000002
const COMPANION_HTTPD_ERROR_NO_EVENT: int = 0x80E40008

@fixed_layout
struct OrbisCompanionHttpdHeader:
    key: mutable u8&?
    value: mutable u8&?
    header: mutable OrbisCompanionHttpdHeader&?

@fixed_layout
struct OrbisCompanionHttpdRequest:
    method: mutable int
    url: mutable u8&?
    header: mutable OrbisCompanionHttpdHeader&?
    body: mutable u8&?
    bodySize: mutable u64

@fixed_layout
struct OrbisCompanionHttpdResponse:
    status: mutable int
    header: mutable OrbisCompanionHttpdHeader&?
    body: mutable u8&?
    bodySize: mutable u64

@fixed_layout
struct OrbisCompanionUtilDeviceInfo:
    userId: mutable int
    addr: mutable array[u8, 16]
    reserved: mutable array[u8, 236]

@fixed_layout
struct OrbisCompanionHttpdEvent:
    event: mutable int
    data: mutable array[u8, 256]

# @port core/libraries/companion/companion_httpd.cpp::sceCompanionHttpdAddHeader sha256=c82001d16feb0cb4 oracle@a3773841
def sceCompanionHttpdAddHeader(key: u8&?, value: u8&?, response: mutable OrbisCompanionHttpdResponse&?) -> int:
    _ = key
    _ = value
    _ = response
    return 0

