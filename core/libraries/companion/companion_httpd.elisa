const ORBIS_COMPANION_HTTPD_EVENT_CONNECT: int = 0x10000001
const ORBIS_COMPANION_HTTPD_EVENT_DISCONNECT: int = 0x10000002
const COMPANION_HTTPD_ERROR_NO_EVENT: int = 0x80E40008

@fixed_layout
struct OrbisCompanionHttpdHeader:
    key: mutable u8&?
    value: mutable u8&?
    header: mutable OrbisCompanionHttpdHeader&?

@fixed_layout
struct OrbisCompanionHttpdRequest:
    method: mutable int
    url: mutable u8&?
    header: mutable OrbisCompanionHttpdHeader&?
    body: mutable u8&?
    bodySize: mutable u64

@fixed_layout
struct OrbisCompanionHttpdResponse:
    status: mutable int
    header: mutable OrbisCompanionHttpdHeader&?
    body: mutable u8&?
    bodySize: mutable u64

@fixed_layout
struct OrbisCompanionUtilDeviceInfo:
    userId: mutable int
    addr: mutable array[u8, 16]
    reserved: mutable array[u8, 236]

@fixed_layout
struct OrbisCompanionHttpdEvent:
    event: mutable int
    data: mutable array[u8, 256]

def sceCompanionHttpdAddHeader(key: u8&?, value: u8&?, response: mutable OrbisCompanionHttpdResponse&?) -> int:
    _ = key
    _ = value
    _ = response
    return 0

def sceCompanionHttpdGet2ndScreenStatus(userId: int) -> int:
    _ = userId
    return 0

def sceCompanionHttpdGetEvent(pEvent: mutable OrbisCompanionHttpdEvent&) -> int:
    pEvent.event <- ORBIS_COMPANION_HTTPD_EVENT_DISCONNECT
    return COMPANION_HTTPD_ERROR_NO_EVENT

def sceCompanionHttpdGetUserId(addr: u32, userId: mutable int&?) -> int:
    _ = addr
    _ = userId
    return 0

def sceCompanionHttpdInitialize() -> int:
    return 0

def sceCompanionHttpdInitialize2() -> int:
    return 0

def sceCompanionHttpdOptParamInitialize() -> int:
    return 0

def sceCompanionHttpdRegisterRequestBodyReceptionCallback(function: void&?, param: void&?) -> int:
    _ = function
    _ = param
    return 0

def sceCompanionHttpdRegisterRequestCallback(function: void&?, param: void&?) -> int:
    _ = function
    _ = param
    return 0

def sceCompanionHttpdRegisterRequestCallback2(function: void&?, param: void&?) -> int:
    _ = function
    _ = param
    return 0

def sceCompanionHttpdSetBody(body: u8&?, bodySize: u64, response: mutable OrbisCompanionHttpdResponse&?) -> int:
    _ = body
    _ = bodySize
    _ = response
    return 0

def sceCompanionHttpdSetStatus(status: int, response: mutable OrbisCompanionHttpdResponse&?) -> int:
    _ = status
    _ = response
    return 0

def sceCompanionHttpdStart() -> int:
    return 0

def sceCompanionHttpdStop() -> int:
    return 0

def sceCompanionHttpdTerminate() -> int:
    return 0

def sceCompanionHttpdUnregisterRequestBodyReceptionCallback() -> int:
    return 0

def sceCompanionHttpdUnregisterRequestCallback() -> int:
    return 0

def CompanionHttpd_RegisterLib(sym: void&?) -> void:
    _ = sym
