include "../error_codes.elisa"
include "./video_recording_error.elisa"
include "../../../common/logging/log.elisa"

const ORBIS_VIDEO_RECORDING_INFO_SUBTITLE: int = 0x2
const ORBIS_VIDEO_RECORDING_INFO_DESCRIPTION: int = 0x6
const ORBIS_VIDEO_RECORDING_INFO_COMMENTS: int = 0x7
const ORBIS_VIDEO_RECORDING_INFO_KEYWORDS: int = 0x8
const ORBIS_VIDEO_RECORDING_INFO_CHAPTER: int = 0xd
const ORBIS_VIDEO_RECORDING_INFO_COPYRIGHT: int = 0xa01
const ORBIS_VIDEO_RECORDING_INFO_PERMISSION_LEVEL: int = 0xa007
const ORBIS_VIDEO_RECORDING_INFO_GUARD_AREA: int = 0xa008
const ORBIS_VIDEO_RECORDING_INFO_USER_META: int = 0xa009

def sceVideoRecordingSetInfo(set_info: int, info: void&?, info_len: u64) -> int:
    LOG_ERROR("Lib_VideoRecording", "(STUBBED) called")

    invalid_set_info: bool = false
    if set_info < ORBIS_VIDEO_RECORDING_INFO_SUBTITLE:
        invalid_set_info <- true
    elif set_info > ORBIS_VIDEO_RECORDING_INFO_SUBTITLE and set_info < ORBIS_VIDEO_RECORDING_INFO_DESCRIPTION:
        invalid_set_info <- true
    elif set_info > ORBIS_VIDEO_RECORDING_INFO_KEYWORDS and set_info < ORBIS_VIDEO_RECORDING_INFO_CHAPTER:
        invalid_set_info <- true
    elif set_info > ORBIS_VIDEO_RECORDING_INFO_CHAPTER and set_info < ORBIS_VIDEO_RECORDING_INFO_COPYRIGHT:
        invalid_set_info <- true
    elif set_info > ORBIS_VIDEO_RECORDING_INFO_CHAPTER and set_info < ORBIS_VIDEO_RECORDING_INFO_PERMISSION_LEVEL:
        invalid_set_info <- true
    elif set_info > ORBIS_VIDEO_RECORDING_INFO_USER_META:
        invalid_set_info <- true

    if invalid_set_info:
        _ = info_len
        return ORBIS_VIDEO_RECORDING_ERROR_INVALID_VALUE

    if info == null:
        _ = info_len
        return ORBIS_VIDEO_RECORDING_ERROR_INVALID_VALUE

    _ = info_len
    return ORBIS_OK

def RegisterLib(sym: void&?) -> void:
    _ = sym
    LIB_FUNCTION("Fc8qxlKINYQ", "libSceVideoRecording", 1, "libSceVideoRecording", sceVideoRecordingSetInfo)
