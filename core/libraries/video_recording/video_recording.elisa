include "../error_codes.elisa"
include "./video_recording_error.elisa"

const ORBIS_VIDEO_RECORDING_INFO_SUBTITLE: int = 0x2
const ORBIS_VIDEO_RECORDING_INFO_DESCRIPTION: int = 0x6
const ORBIS_VIDEO_RECORDING_INFO_COMMENTS: int = 0x7
const ORBIS_VIDEO_RECORDING_INFO_KEYWORDS: int = 0x8
const ORBIS_VIDEO_RECORDING_INFO_CHAPTER: int = 0xd
const ORBIS_VIDEO_RECORDING_INFO_COPYRIGHT: int = 0xa01
const ORBIS_VIDEO_RECORDING_INFO_PERMISSION_LEVEL: int = 0xa007
const ORBIS_VIDEO_RECORDING_INFO_GUARD_AREA: int = 0xa008
const ORBIS_VIDEO_RECORDING_INFO_USER_META: int = 0xa009

global mutable g_video_recording_open: bool = false
global mutable g_video_recording_recording: bool = false
global mutable g_video_recording_memory_size: u64 = 0

def sceVideoRecordingSetInfo(set_info: int, info: void&?, info_len: u64) -> int:
    invalid_set_info: mutable bool = false
    if set_info < ORBIS_VIDEO_RECORDING_INFO_SUBTITLE:
        invalid_set_info <- true
    elif set_info > ORBIS_VIDEO_RECORDING_INFO_SUBTITLE and set_info < ORBIS_VIDEO_RECORDING_INFO_DESCRIPTION:
        invalid_set_info <- true
    elif set_info > ORBIS_VIDEO_RECORDING_INFO_KEYWORDS and set_info < ORBIS_VIDEO_RECORDING_INFO_CHAPTER:
        invalid_set_info <- true
    elif set_info > ORBIS_VIDEO_RECORDING_INFO_CHAPTER and set_info < ORBIS_VIDEO_RECORDING_INFO_COPYRIGHT:
        invalid_set_info <- true
    elif set_info > ORBIS_VIDEO_RECORDING_INFO_CHAPTER and set_info < ORBIS_VIDEO_RECORDING_INFO_PERMISSION_LEVEL:
        invalid_set_info <- true
    elif set_info > ORBIS_VIDEO_RECORDING_INFO_USER_META:
        invalid_set_info <- true

    if invalid_set_info:
        _ = info_len
        return ORBIS_VIDEO_RECORDING_ERROR_INVALID_VALUE

    if info == null:
        _ = info_len
        return ORBIS_VIDEO_RECORDING_ERROR_INVALID_VALUE

    _ = info_len
    return ORBIS_OK

def sceVideoRecordingQueryMemSize2(param: void&?, mem_size: mutable u64&?) -> int:
    _ = param
    if mem_size != null:
        mem_size[0] <- g_video_recording_memory_size
    return ORBIS_OK

def sceVideoRecordingOpen2(param: void&?, work: void&?) -> int:
    _ = param
    _ = work
    g_video_recording_open <- true
    g_video_recording_recording <- false
    return ORBIS_OK

def sceVideoRecordingClose() -> int:
    g_video_recording_open <- false
    g_video_recording_recording <- false
    return ORBIS_OK

def sceVideoRecordingStart() -> int:
    g_video_recording_recording <- true
    return ORBIS_OK

def sceVideoRecordingStop() -> int:
    g_video_recording_recording <- false
    return ORBIS_OK

def sceVideoRecordingGetStatus(status: mutable int&?) -> int:
    if status != null:
        status[0] <- 1 if g_video_recording_recording else 0
    return ORBIS_OK

def VideoRecording_RegisterLib(sym: void&?) -> void:
    _ = sym
    LIB_FUNCTION("KHvkPQJDMLk", "libSceVideoRecording", 1, "libSceVideoRecording", sceVideoRecordingClose)
    LIB_FUNCTION("fZJQzFK4Gv4", "libSceVideoRecording", 1, "libSceVideoRecording", sceVideoRecordingGetStatus)
    LIB_FUNCTION("s28dalBwp2g", "libSceVideoRecording", 1, "libSceVideoRecording", sceVideoRecordingOpen2)
    LIB_FUNCTION("bGYkY6q3bIw", "libSceVideoRecording", 1, "libSceVideoRecording", sceVideoRecordingQueryMemSize2)
    LIB_FUNCTION("Fc8qxlKINYQ", "libSceVideoRecording", 1, "libSceVideoRecording", sceVideoRecordingSetInfo)
    LIB_FUNCTION("tWoe9IlGAhs", "libSceVideoRecording", 1, "libSceVideoRecording", sceVideoRecordingStart)
    LIB_FUNCTION("OOFxrMY+mfI", "libSceVideoRecording", 1, "libSceVideoRecording", sceVideoRecordingStop)
