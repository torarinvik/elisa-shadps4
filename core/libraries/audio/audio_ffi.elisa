include "./audioout_error.elisa"
include "../../../common/arch.elisa"

# Minimal FFI bridge for SDL3/OpenAL availability and basic lifecycle.
static if PLATFORM_APPLE:
    @c_abi(c)
    extern SDL_Init(flags: u32) -> s32

    @c_abi(c)
    extern SDL_Quit() -> void

    @c_abi(c)
    extern SDL_GetError() -> u8&?

    @c_abi(c)
    extern SDL_OpenAudioDevice(devid: u32, spec: void&?) -> u32

    @c_abi(c)
    extern SDL_CloseAudioDevice(devid: u32) -> void

    @c_abi(c)
    extern SDL_ResumeAudioDevice(devid: u32) -> s32

    @c_abi(c)
    extern SDL_PauseAudioDevice(devid: u32) -> s32

    @c_abi(c)
    extern SDL_QueueAudio(devid: u32, data: void&, len: u32) -> s32

    @c_abi(c)
    extern SDL_DequeueAudio(devid: u32, data: mutable void&, len: u32) -> u32

    @c_abi(c)
    extern alcOpenDevice(devicename: u8&?) -> void&?

    @c_abi(c)
    extern alcCloseDevice(device: void&) -> u8

    @c_abi(c)
    extern alGenSources(n: s32, sources: mutable u32&) -> void
    @c_abi(c)
    extern alDeleteSources(n: s32, sources: u32&) -> void
    @c_abi(c)
    extern alGenBuffers(n: s32, buffers: mutable u32&) -> void
    @c_abi(c)
    extern alDeleteBuffers(n: s32, buffers: u32&) -> void
    @c_abi(c)
    extern alBufferData(buffer: u32, format: s32, data: void&, size: s32, freq: s32) -> void
    @c_abi(c)
    extern alSourceQueueBuffers(source: u32, nb: s32, buffers: u32&) -> void
    @c_abi(c)
    extern alSourceUnqueueBuffers(source: u32, nb: s32, buffers: mutable u32&) -> void
    @c_abi(c)
    extern alSourcePlay(source: u32) -> void
    @c_abi(c)
    extern alSourceStop(source: u32) -> void
    @c_abi(c)
    extern alGetSourcei(source: u32, param: s32, value: mutable s32&) -> void
    @c_abi(c)
    extern alSourcef(source: u32, param: s32, value: f32) -> void
    @c_abi(c)
    extern alSourcei(source: u32, param: s32, value: s32) -> void
    @c_abi(c)
    extern alGetError() -> s32
    @c_abi(c)
    extern alGetEnumValue(ename: u8&) -> s32

    @c_abi(c)
    extern AudioElisa_RegisterAudioOutLib(sym: void&?) -> void

    @c_abi(c)
    extern AudioElisa_RegisterAudioInLib(sym: void&?) -> void
static else:
    def SDL_Init(flags: u32) -> s32:
        _ = flags
        return ORBIS_AUDIO_OUT_ERROR_NOT_OPENED

    def SDL_Quit() -> void:
        return

    def SDL_GetError() -> u8&?:
        return null

    def SDL_OpenAudioDevice(devid: u32, spec: void&?) -> u32:
        _ = devid
        _ = spec
        return 0

    def SDL_CloseAudioDevice(devid: u32) -> void:
        _ = devid
        return

    def SDL_ResumeAudioDevice(devid: u32) -> s32:
        _ = devid
        return ORBIS_AUDIO_OUT_ERROR_NOT_OPENED

    def SDL_PauseAudioDevice(devid: u32) -> s32:
        _ = devid
        return ORBIS_AUDIO_OUT_ERROR_NOT_OPENED

    def SDL_QueueAudio(devid: u32, data: void&, len: u32) -> s32:
        _ = devid
        _ = data
        _ = len
        return ORBIS_AUDIO_OUT_ERROR_NOT_OPENED

    def SDL_DequeueAudio(devid: u32, data: mutable void&, len: u32) -> u32:
        _ = devid
        _ = data
        _ = len
        return 0

    def alcOpenDevice(devicename: u8&?) -> void&?:
        _ = devicename
        return null

    def alcCloseDevice(device: void&) -> u8:
        _ = device
        return 0

    def alGenSources(n: s32, sources: mutable u32&) -> void:
        _ = n
        _ = sources
        return

    def alDeleteSources(n: s32, sources: u32&) -> void:
        _ = n
        _ = sources
        return

    def alGenBuffers(n: s32, buffers: mutable u32&) -> void:
        _ = n
        _ = buffers
        return

    def alDeleteBuffers(n: s32, buffers: u32&) -> void:
        _ = n
        _ = buffers
        return

    def alBufferData(buffer: u32, format: s32, data: void&, size: s32, freq: s32) -> void:
        _ = buffer
        _ = format
        _ = data
        _ = size
        _ = freq
        return

    def alSourceQueueBuffers(source: u32, nb: s32, buffers: u32&) -> void:
        _ = source
        _ = nb
        _ = buffers
        return

    def alSourceUnqueueBuffers(source: u32, nb: s32, buffers: mutable u32&) -> void:
        _ = source
        _ = nb
        _ = buffers
        return

    def alSourcePlay(source: u32) -> void:
        _ = source
        return

    def alSourceStop(source: u32) -> void:
        _ = source
        return

    def alGetSourcei(source: u32, param: s32, value: mutable s32&) -> void:
        _ = source
        _ = param
        _ = value
        return

    def alSourcef(source: u32, param: s32, value: f32) -> void:
        _ = source
        _ = param
        _ = value
        return

    def alSourcei(source: u32, param: s32, value: s32) -> void:
        _ = source
        _ = param
        _ = value
        return

    def alGetError() -> s32:
        return 0

    def alGetEnumValue(ename: u8&) -> s32:
        _ = ename
        return 0

    def AudioElisa_RegisterAudioOutLib(sym: void&?) -> void:
        _ = sym
        return

    def AudioElisa_RegisterAudioInLib(sym: void&?) -> void:
        _ = sym
        return

const SDL_INIT_AUDIO: u32 = 0x00000010

global mutable audio_sdl_ready: bool = false
global mutable audio_openal_probe: void&? = null
global mutable audioout_sdl_device_ids: u32[25] = zeroed
global mutable audioin_sdl_device_ids: u32[7] = zeroed
global mutable audioout_openal_source_ids: u32[25] = zeroed
global mutable audioout_openal_buf_ids: u32[150] = zeroed
global mutable audioout_openal_next_buf: s32[25] = zeroed

const AL_FORMAT_MONO16: s32 = 0x1101
const AL_FORMAT_STEREO16: s32 = 0x1103
const AL_FORMAT_MONO_FLOAT32: s32 = 0x10010
const AL_FORMAT_STEREO_FLOAT32: s32 = 0x10011
const AL_BUFFERS_PROCESSED: s32 = 0x1016
const AL_BUFFERS_QUEUED: s32 = 0x1015
const AL_SOURCE_STATE: s32 = 0x1010
const AL_PLAYING: s32 = 0x1012
const AL_STOPPED: s32 = 0x1014
const AL_GAIN: s32 = 0x100A

static if PLATFORM_APPLE:
    def AudioFFI_InitSDL() -> s32:
        if audio_sdl_ready:
            return ORBIS_OK
        rc: s32 = SDL_Init(SDL_INIT_AUDIO)
        if rc != 0:
            return ORBIS_AUDIO_OUT_ERROR_NOT_OPENED
        audio_sdl_ready <- true
        return ORBIS_OK

    def AudioFFI_QuitSDL() -> void:
        if audio_sdl_ready:
            SDL_Quit()
            audio_sdl_ready <- false

    def AudioFFI_IsSDLReady() -> bool:
        return audio_sdl_ready

    def AudioFFI_ProbeOpenAL() -> bool:
        if audio_openal_probe != null:
            return true
        dev: void&? = alcOpenDevice(null)
        if dev == null:
            return false
        # OpenAL-owned device handle cached in a process-lifetime global (OpenAL owns it until alcCloseDevice).
        can Unsafe.StaleRef:
            audio_openal_probe <- dev
        return true

    def AudioFFI_CloseOpenALProbe() -> void:
        if audio_openal_probe != null:
            _ = alcCloseDevice(audio_openal_probe.cast[void&])
            audio_openal_probe <- null

    def AudioFFI_AudioOutSDLOpen(port_id: s32) -> bool:
        if port_id < 0 or port_id >= ORBIS_AUDIO_OUT_NUM_PORTS:
            return false
        if AudioFFI_InitSDL() != ORBIS_OK:
            return false
        dev: u32 = SDL_OpenAudioDevice(0, null)
        if dev == 0:
            return false
        if SDL_ResumeAudioDevice(dev) != 0:
            SDL_CloseAudioDevice(dev)
            return false
        audioout_sdl_device_ids[port_id] <- dev
        return true

    def AudioFFI_AudioOutSDLClose(port_id: s32) -> void:
        if port_id < 0 or port_id >= ORBIS_AUDIO_OUT_NUM_PORTS:
            return
        dev: u32 = audioout_sdl_device_ids[port_id]
        if dev != 0:
            _ = SDL_PauseAudioDevice(dev)
            SDL_CloseAudioDevice(dev)
            audioout_sdl_device_ids[port_id] <- 0

    def AudioFFI_AudioOutSDLQueue(port_id: s32, data: void&, len: u32) -> s32:
        if port_id < 0 or port_id >= ORBIS_AUDIO_OUT_NUM_PORTS:
            return -1
        dev: u32 = audioout_sdl_device_ids[port_id]
        if dev == 0:
            return -1
        return SDL_QueueAudio(dev, data, len)

    def AudioFFI_AudioInSDLOpen(port_id: s32) -> bool:
        if port_id < 0 or port_id >= ORBIS_AUDIO_IN_NUM_PORTS:
            return false
        if AudioFFI_InitSDL() != ORBIS_OK:
            return false
        dev: u32 = SDL_OpenAudioDevice(0xFFFFFFFF, null)
        if dev == 0:
            return false
        if SDL_ResumeAudioDevice(dev) != 0:
            SDL_CloseAudioDevice(dev)
            return false
        audioin_sdl_device_ids[port_id] <- dev
        return true

    def AudioFFI_AudioInSDLClose(port_id: s32) -> void:
        if port_id < 0 or port_id >= ORBIS_AUDIO_IN_NUM_PORTS:
            return
        dev: u32 = audioin_sdl_device_ids[port_id]
        if dev != 0:
            _ = SDL_PauseAudioDevice(dev)
            SDL_CloseAudioDevice(dev)
            audioin_sdl_device_ids[port_id] <- 0

    def AudioFFI_AudioInSDLRead(port_id: s32, out_data: mutable void&, len: u32) -> u32:
        if port_id < 0 or port_id >= ORBIS_AUDIO_IN_NUM_PORTS:
            return 0
        dev: u32 = audioin_sdl_device_ids[port_id]
        if dev == 0:
            return 0
        return SDL_DequeueAudio(dev, out_data, len)
static else:
    def AudioFFI_InitSDL() -> s32:
        return ORBIS_AUDIO_OUT_ERROR_NOT_OPENED

    def AudioFFI_QuitSDL() -> void:
        return

    def AudioFFI_IsSDLReady() -> bool:
        return false

    def AudioFFI_ProbeOpenAL() -> bool:
        return false

    def AudioFFI_CloseOpenALProbe() -> void:
        return

    def AudioFFI_AudioOutSDLOpen(port_id: s32) -> bool:
        _ = port_id
        return false

    def AudioFFI_AudioOutSDLClose(port_id: s32) -> void:
        _ = port_id
        return

    def AudioFFI_AudioOutSDLQueue(port_id: s32, data: void&, len: u32) -> s32:
        _ = port_id
        _ = data
        _ = len
        return -1

    def AudioFFI_AudioInSDLOpen(port_id: s32) -> bool:
        _ = port_id
        return false

    def AudioFFI_AudioInSDLClose(port_id: s32) -> void:
        _ = port_id
        return

    def AudioFFI_AudioInSDLRead(port_id: s32, out_data: mutable void&, len: u32) -> u32:
        _ = port_id
        _ = out_data
        _ = len
        return 0
