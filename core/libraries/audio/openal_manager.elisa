# Port of openal_manager.h high-level manager hooks.
def OpenALManager_Init() -> s32:
    if not AudioFFI_ProbeOpenAL():
        return ORBIS_AUDIO_OUT_ERROR_NOT_OPENED
    return ORBIS_OK

def OpenALManager_Shutdown() -> void:
    AudioFFI_CloseOpenALProbe()
