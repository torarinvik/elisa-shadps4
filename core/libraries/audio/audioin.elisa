include "./audio_port.elisa"
include "./audioin_error.elisa"
include "./audio_ffi.elisa"
include "./audioin_nids.elisa"
include "./sdl_audio_in.elisa"
include "../../guest_exec.elisa"

@link_name(ElisaGuestExec_EmitCusaArtifactKV)
extern c_GuestExec_EmitCusaArtifactKV(key: static u8&?, value: u64) -> void

const AUDIOIN_HANDLE_TAG: s32 = 0x30000000

global mutable audioin_open_mask: bool[ORBIS_AUDIO_IN_NUM_PORTS] = [false, false, false, false, false, false, false]
global mutable audioin_silent_mask: bool[ORBIS_AUDIO_IN_NUM_PORTS] = [true, true, true, true, true, true, true]
global mutable audioin_backend_open: bool[ORBIS_AUDIO_IN_NUM_PORTS] = [false, false, false, false, false, false, false]
global mutable audioin_samples: u32[ORBIS_AUDIO_IN_NUM_PORTS] = [0u32, 0u32, 0u32, 0u32, 0u32, 0u32, 0u32]
global mutable audioin_frame_bytes: u32[ORBIS_AUDIO_IN_NUM_PORTS] = [0u32, 0u32, 0u32, 0u32, 0u32, 0u32, 0u32]

def audioin_emit_u64(key: static u8&, value: u64) -> void:
    if GuestExec_IsEnabled():
        c_GuestExec_EmitCusaArtifactKV(key, value)


def audioin_get_port_id(handle: s32) -> s32:
    pid: s32 = handle & 0xff
    if pid < 0 or pid >= ORBIS_AUDIO_IN_NUM_PORTS:
        return ORBIS_AUDIO_IN_ERROR_PORT_FULL
    if (handle & 0x7f000000) != AUDIOIN_HANDLE_TAG:
        return ORBIS_AUDIO_IN_ERROR_INVALID_HANDLE
    return pid

def audioin_alloc_port() -> s32:
    i: mutable s32 = 0
    while i < ORBIS_AUDIO_IN_NUM_PORTS:
        if not audioin_open_mask[i]:
            return i
        i <- i + 1
    return -1

def audioin_open_count() -> s32:
    count: mutable s32 = 0
    i: mutable s32 = 0
    while i < ORBIS_AUDIO_IN_NUM_PORTS:
        if audioin_open_mask[i]:
            count <- count + 1
        i <- i + 1
    return count

# @port core/libraries/audio/audioin.cpp::sceAudioInInit sha256=4881568214192e0b oracle@a3773841
def sceAudioInInit() -> s32:
    return ORBIS_OK
# @port core/libraries/audio/audioin.cpp::sceAudioInCountPorts sha256=302ec2c31af8a9c5 oracle@a3773841
def sceAudioInCountPorts() -> s32:
    return ORBIS_OK

# @port core/libraries/audio/audioin.cpp::sceAudioInOpen sha256=5da9c69d822e53b6 oracle@a3773841
def sceAudioInOpen(userId: s32, type: u32, index: u32, len: u32, freq: u32, param: u32) -> s32:
    _ = userId
    _ = type
    _ = index
    audioin_emit_u64("audio_input_attempted", 1u64)
    if len == 0u32 or len > 2048u32:
        return ORBIS_AUDIO_IN_ERROR_INVALID_SIZE
    if param != 0u32 and param != 1u32:
        return ORBIS_AUDIO_IN_ERROR_INVALID_PARAM
    if freq != 16000u32 and freq != 48000u32:
        return ORBIS_AUDIO_IN_ERROR_INVALID_FREQ
    frame_bytes: mutable u32 = 0u32
    if param == 0u32:
        frame_bytes <- 2u32
    if param == 1u32:
        frame_bytes <- 4u32
    pid: s32 = audioin_alloc_port()
    if pid < 0:
        return ORBIS_AUDIO_IN_ERROR_PORT_FULL
    if SDLAudioIn_Open(1.cast[void&?]) == null:
        return ORBIS_AUDIO_IN_ERROR_NOT_OPENED
    if not AudioFFI_AudioInSDLOpen(pid):
        return ORBIS_AUDIO_IN_ERROR_NOT_OPENED
    audioin_open_mask[pid] <- true
    audioin_backend_open[pid] <- true
    audioin_samples[pid] <- len
    audioin_frame_bytes[pid] <- frame_bytes
    audioin_silent_mask[pid] <- false
    audioin_emit_u64("audio_input_opened", 1u64)
    return AUDIOIN_HANDLE_TAG | (((type.cast[i32]) & 0xff) << 16) | pid

# @port core/libraries/audio/audioin.cpp::sceAudioInHqOpen sha256=58014db30cf5074e oracle@a3773841
def sceAudioInHqOpen(userId: s32, type: u32, index: u32, len: u32, freq: u32, param: u32) -> s32:
    return sceAudioInOpen(userId, type, index, len, freq, param)

# @port core/libraries/audio/audioin.cpp::sceAudioInClose sha256=c7d1c0234c1f900e oracle@a3773841
def sceAudioInClose(handle: s32) -> s32:
    pid: s32 = audioin_get_port_id(handle)
    if pid < 0:
        return ORBIS_AUDIO_IN_ERROR_INVALID_HANDLE
    if not audioin_open_mask[pid]:
        return ORBIS_AUDIO_IN_ERROR_NOT_OPENED
    audioin_open_mask[pid] <- false
    audioin_backend_open[pid] <- false
    AudioFFI_AudioInSDLClose(pid)
    audioin_silent_mask[pid] <- true
    audioin_emit_u64("audio_input_closed", 1u64)
    return ORBIS_OK

# @port core/libraries/audio/audioin.cpp::sceAudioInInput sha256=4e9cc4d78fa719b4 oracle@a3773841
def sceAudioInInput(handle: s32, dest: mutable u8&?) -> s32:
    audioin_emit_u64("audio_input_read_attempted", 1u64)
    pid: s32 = audioin_get_port_id(handle)
    if pid < 0:
        return ORBIS_AUDIO_IN_ERROR_INVALID_HANDLE
    if dest == null:
        return ORBIS_AUDIO_IN_ERROR_INVALID_POINTER
    if not audioin_open_mask[pid]:
        return ORBIS_AUDIO_IN_ERROR_NOT_OPENED
    if not audioin_backend_open[pid]:
        return ORBIS_AUDIO_IN_ERROR_NOT_OPENED
    want_bytes: u32 = audioin_samples[pid] * audioin_frame_bytes[pid]
    got_bytes: u32 = AudioFFI_AudioInSDLRead(pid, dest.cast[mutable void&], want_bytes)
    if got_bytes == 0u32:
        audioin_emit_u64("audio_input_read_rc", 0u64)
        return 0
    audioin_emit_u64("audio_input_read_rc", got_bytes.u64())
    return (got_bytes / audioin_frame_bytes[pid]).cast[i32]

# @port core/libraries/audio/audioin.cpp::sceAudioInGetSilentState sha256=8cb2636a7969ad37 oracle@a3773841
def sceAudioInGetSilentState(handle: s32) -> s32:
    pid: s32 = audioin_get_port_id(handle)
    if pid < 0:
        return ORBIS_AUDIO_IN_ERROR_INVALID_HANDLE
    if not audioin_open_mask[pid]:
        return ORBIS_AUDIO_IN_ERROR_NOT_OPENED
    if not audioin_backend_open[pid]:
        audioin_emit_u64("audio_input_silent_state", 0u64)
        return ORBIS_AUDIO_IN_SILENT_STATE_DEVICE_NONE
    audioin_emit_u64("audio_input_silent_state", 1u64)
    return 0

