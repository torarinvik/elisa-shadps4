def AudioIn_RegisterLib(sym: void&?) -> void: _ = sym

def AudioIn_ShutdownBackends() -> void:
    i: s32 = 0
    while i < ORBIS_AUDIO_IN_NUM_PORTS:
        if audioin_open_mask[i]:
            AudioFFI_AudioInSDLClose(i)
        audioin_open_mask[i] <- false
        audioin_backend_open[i] <- false
        audioin_silent_mask[i] <- true
        audioin_samples[i] <- 0u32
        audioin_frame_bytes[i] <- 0u32
        i <- i + 1

