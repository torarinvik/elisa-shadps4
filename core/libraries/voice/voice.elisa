# @port core/libraries/voice/voice.cpp::sceVoiceGetPortInfo sha256=3290ea00c77e904f oracle@a3773841
def sceVoiceGetPortInfo(port_id: u32, info: mutable OrbisVoicePortInfo&?) -> int:
    _ = port_id
    if info != null:
        info.port_type <- 0
        info.state <- 0
        info.byte_count <- 0
        info.frame_size <- 1
        info.edge_count <- 0
        info.reserved <- 0
    return ORBIS_OK

