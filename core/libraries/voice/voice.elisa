# @port core/libraries/voice/voice.cpp::sceVoiceGetBitRate sha256=469d1eed3584f0a4 oracle@a3773841
def sceVoiceGetBitRate(port_id: u32, bitrate: mutable u32&?) -> int:
    _ = port_id
    if bitrate != null:
        bitrate <- 48000
    return ORBIS_OK

# @port core/libraries/voice/voice.cpp::sceVoiceGetMuteFlag sha256=89097908c6206d20 oracle@a3773841
def sceVoiceGetMuteFlag() -> int:
