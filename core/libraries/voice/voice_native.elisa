include "./voice_ffi.elisa"

type OrbisVoicePortInfo = VoiceElisaPortInfo

def voice_native_result(rc: s32) -> int:
    return (rc as u32) as int

def sceVoiceConnectIPortToOPort() -> int:
    return voice_native_result(c_voice_connect_iport_to_oport())

def sceVoiceCreatePort() -> int:
    return voice_native_result(c_voice_create_port())

def sceVoiceDeletePort() -> int:
    return voice_native_result(c_voice_delete_port())

def sceVoiceDisconnectIPortFromOPort() -> int:
    return voice_native_result(c_voice_disconnect_iport_from_oport())

def sceVoiceEnd() -> int:
    return voice_native_result(c_voice_end())

def sceVoiceGetBitRate(port_id: u32, bitrate: mutable u32&?) -> int:
    return voice_native_result(c_voice_get_bitrate(port_id, bitrate))

def sceVoiceGetMuteFlag() -> int:
    return voice_native_result(c_voice_get_muteflag())

def sceVoiceGetPortAttr() -> int:
    return voice_native_result(c_voice_get_port_attr())

def sceVoiceGetPortInfo(port_id: u32, info: mutable OrbisVoicePortInfo&?) -> int:
    return voice_native_result(c_voice_get_port_info(port_id, info))

def sceVoiceGetResourceInfo() -> int:
    return voice_native_result(c_voice_get_resource_info())

def sceVoiceGetVolume() -> int:
    return voice_native_result(c_voice_get_volume())

def sceVoiceInit() -> int:
    return voice_native_result(c_voice_init())

def sceVoiceInitHQ() -> int:
    return voice_native_result(c_voice_init_hq())

def sceVoicePausePort() -> int:
    return voice_native_result(c_voice_pause_port())

def sceVoicePausePortAll() -> int:
    return voice_native_result(c_voice_pause_port_all())

def sceVoiceReadFromOPort() -> int:
    return voice_native_result(c_voice_read_from_oport())

def sceVoiceResetPort() -> int:
    return voice_native_result(c_voice_reset_port())

def sceVoiceResumePort() -> int:
    return voice_native_result(c_voice_resume_port())

def sceVoiceResumePortAll() -> int:
    return voice_native_result(c_voice_resume_port_all())

def sceVoiceSetBitRate() -> int:
    return voice_native_result(c_voice_set_bitrate())

def sceVoiceSetMuteFlag() -> int:
    return voice_native_result(c_voice_set_muteflag())

def sceVoiceSetMuteFlagAll() -> int:
    return voice_native_result(c_voice_set_muteflag_all())

def sceVoiceSetThreadsParams() -> int:
    return voice_native_result(c_voice_set_threads_params())

def sceVoiceSetVolume() -> int:
    return voice_native_result(c_voice_set_volume())

def sceVoiceStart() -> int:
    return voice_native_result(c_voice_start())

def sceVoiceStop() -> int:
    return voice_native_result(c_voice_stop())

def sceVoiceUpdatePort() -> int:
    return voice_native_result(c_voice_update_port())

def sceVoiceVADAdjustment() -> int:
    return voice_native_result(c_voice_vad_adjustment())

def sceVoiceVADSetVersion() -> int:
    return voice_native_result(c_voice_vad_set_version())

def sceVoiceWriteToIPort() -> int:
    return voice_native_result(c_voice_write_to_iport())

def RegisterLib(sym: void&?) -> void:
    c_voice_register_lib(sym)
