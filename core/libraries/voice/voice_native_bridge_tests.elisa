include "../../../../compiler/runtime/elisacore_std/elisacore_runtime.elisa"
include "./voice_native.elisa"

@test
def voice_native_bridge_forwards_outputs() -> void:
    can Abort.Panic:
        bitrate: mutable u32 = 0u32
        info: mutable OrbisVoicePortInfo = zeroed

        assert sceVoiceGetBitRate(1u32, (&bitrate).cast[mutable u32&]) == 0
        assert bitrate == 48000u32

        assert sceVoiceGetPortInfo(2u32, (&info).cast[mutable OrbisVoicePortInfo&]) == 0
        assert info.port_type == 0
        assert info.state == 0
        assert info.byte_count == 0u32
        assert info.frame_size == 1u32
        assert info.edge_count == 0u16
        assert info.reserved == 0u16

        assert sceVoiceInit() == 0
        assert sceVoiceEnd() == 0
        assert sceVoiceSetVolume() == 0
        assert sceVoiceWriteToIPort() == 0
