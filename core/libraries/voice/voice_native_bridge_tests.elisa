include "../../../../compiler/runtime/elisacore_std/elisacore_runtime.elisa"
include "./voice_native.elisa"

@test
def voice_native_bridge_forwards_outputs() -> void:
    can Abort.Panic:
        bitrate: mutable u32 = 0
        info: mutable OrbisVoicePortInfo = zeroed

        assert sceVoiceGetBitRate(1, (&bitrate).cast[mutable u32&]) == 0
        assert bitrate == 48000

        assert sceVoiceGetPortInfo(2, (&info).cast[mutable OrbisVoicePortInfo&]) == 0
        assert info.port_type == 0
        assert info.state == 0
        assert info.byte_count == 0
        assert info.frame_size == 1
        assert info.edge_count == 0
        assert info.reserved == 0

        assert sceVoiceInit() == 0
        assert sceVoiceEnd() == 0
        assert sceVoiceSetVolume() == 0
        assert sceVoiceWriteToIPort() == 0
