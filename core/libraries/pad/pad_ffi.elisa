# Native pad bridge declarations.
#
# Medium-term shape:
#   - Keep pad.elisa as the pure deterministic fallback for isolated tests.
#   - Link pad_elisa_bridge.cpp when the full C++ runtime is available.
#   - Route backend-dependent behavior through these C ABI functions.
#
# Struct pointers use explicit C bridge DTOs. The C++ bridge translates between
# these stable structs and the namespaced shadPS4 C++ pad structs.

type s32 = i32

@c_bind("core/libraries/pad/pad_elisa_bridge.hh", "struct PadElisaControllerInformation")
struct PadElisaControllerInformation layout c:
    touch_pad_dummy: mutable u8[16]
    stick_dummy: mutable u8[2]
    connectionType: mutable u8
    connectedCount: mutable u8
    connected: mutable bool
    deviceClass: mutable s32
    reserve: mutable u8[8]

@c_bind("core/libraries/pad/pad_elisa_bridge.hh", "struct PadElisaExtendedControllerInformation")
struct PadElisaExtendedControllerInformation layout c:
    base: mutable PadElisaControllerInformation
    padType1: mutable u16
    padType2: mutable u16
    capability: mutable u8
    data: mutable u8[8]

@c_bind("core/libraries/pad/pad_elisa_bridge.hh", "struct PadElisaLightBarParam")
struct PadElisaLightBarParam layout c:
    r: mutable u8
    g: mutable u8
    b: mutable u8
    reserve: mutable u8

@c_bind("core/libraries/pad/pad_elisa_bridge.hh", "struct PadElisaVibrationParam")
struct PadElisaVibrationParam layout c:
    largeMotor: mutable u8
    smallMotor: mutable u8

@c_bind("core/libraries/pad/pad_elisa_bridge.hh", "struct PadElisaData")
struct PadElisaData layout c:
    buttons: mutable u32
    left_x: mutable u8
    left_y: mutable u8
    right_x: mutable u8
    right_y: mutable u8
    l2: mutable u8
    r2: mutable u8
    pad0: mutable u8[2]
    pad1: mutable u8[80]
    connected: mutable bool
    timestamp: mutable u64
    pad2: mutable u8[32]

@c_bind("core/libraries/pad/pad_elisa_bridge.hh", "struct PadElisaInfo")
struct PadElisaInfo layout c:
    unk1: mutable u32
    unk2: mutable u32
    pad_handle: mutable u32
    unk3: mutable u32
    colour: mutable u32

@c_bind("core/libraries/pad/pad_elisa_bridge.hh", "struct PadElisaDeviceClassExtendedInformation")
struct PadElisaDeviceClassExtendedInformation layout c:
    deviceClass: mutable s32
    reserved: mutable u8[16]

@link_name(PadElisa_scePadInit)
@c_abi(c)
extern c_pad_init() -> s32

@link_name(PadElisa_scePadOpen)
@c_abi(c)
extern c_pad_open(user_id: s32, pad_type: s32, index: s32, param: void&?) -> s32

@link_name(PadElisa_scePadOpenExt)
@c_abi(c)
extern c_pad_open_ext(user_id: s32, pad_type: s32, index: s32, param: void&?) -> s32

@link_name(PadElisa_scePadGetHandle)
@c_abi(c)
extern c_pad_get_handle(user_id: s32, pad_type: s32, index: s32) -> s32

@link_name(PadElisa_scePadClose)
@c_abi(c)
extern c_pad_close(handle: s32) -> s32

@link_name(PadElisa_scePadGetControllerInformation)
@c_abi(c)
extern c_pad_get_controller_information(handle: s32, info: mutable PadElisaControllerInformation&?) -> s32

@link_name(PadElisa_scePadGetExtControllerInformation)
@c_abi(c)
extern c_pad_get_ext_controller_information(handle: s32, info: mutable PadElisaExtendedControllerInformation&?) -> s32

@link_name(PadElisa_scePadDeviceClassGetExtendedInformation)
@c_abi(c)
extern c_pad_device_class_get_extended_information(handle: s32, info: mutable PadElisaDeviceClassExtendedInformation&?) -> s32

@link_name(PadElisa_scePadGetInfo)
@c_abi(c)
extern c_pad_get_info(info: mutable PadElisaInfo&?) -> s32

@link_name(PadElisa_scePadRead)
@c_abi(c)
extern c_pad_read(handle: s32, data: mutable PadElisaData&?, num: s32) -> s32

@link_name(PadElisa_scePadReadState)
@c_abi(c)
extern c_pad_read_state(handle: s32, data: mutable PadElisaData&?) -> s32

@link_name(PadElisa_scePadResetLightBar)
@c_abi(c)
extern c_pad_reset_light_bar(handle: s32) -> s32

@link_name(PadElisa_scePadResetOrientation)
@c_abi(c)
extern c_pad_reset_orientation(handle: s32) -> s32

@link_name(PadElisa_scePadSetLightBar)
@c_abi(c)
extern c_pad_set_light_bar(handle: s32, param: PadElisaLightBarParam&?) -> s32

@link_name(PadElisa_scePadSetLightBarForTracker)
@c_abi(c)
extern c_pad_set_light_bar_for_tracker(handle: s32, param: PadElisaLightBarParam&?) -> s32

@link_name(PadElisa_scePadSetVibration)
@c_abi(c)
extern c_pad_set_vibration(handle: s32, param: PadElisaVibrationParam&?) -> s32

@link_name(PadElisa_RegisterLib)
@c_abi(c)
extern c_pad_register_lib(sym: void&?) -> void
