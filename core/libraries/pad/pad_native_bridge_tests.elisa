include "../../../../compiler/runtime/elisacore_std/elisacore_runtime.elisa"
include "./pad_native.elisa"

@test
def pad_native_bridge_forwards_lifecycle() -> void:
    can Abort.Panic:
        assert scePadInit() == 0
        h: int = scePadOpen(11, ORBIS_PAD_PORT_TYPE_STANDARD, 0, null)
        assert h == 7001
        assert scePadGetHandle(11, ORBIS_PAD_PORT_TYPE_STANDARD, 0) == h
        assert scePadClose(h) == 0
        assert scePadClose(h) == ORBIS_PAD_ERROR_INVALID_HANDLE

@test
def pad_native_bridge_forwards_struct_outputs() -> void:
    can Abort.Panic:
        _ = scePadInit()
        h: int = scePadOpen(12, ORBIS_PAD_PORT_TYPE_STANDARD, 0, null)

        data: mutable OrbisPadData = zeroed
        assert scePadRead(h, (&data).cast[mutable OrbisPadData&], 1) == 1
        assert data.connected
        assert data.buttons == 0x1234

        info: mutable OrbisPadInfo = zeroed
        assert scePadGetInfo((&info).cast[mutable OrbisPadInfo&]) == 0
        assert info.pad_handle == 7001
        assert info.colour == 0x102030

        light: mutable OrbisPadLightBarParam = zeroed
        light.r <- 10
        light.g <- 20
        light.b <- 30
        assert scePadSetLightBar(h, (&light).cast[OrbisPadLightBarParam&]) == 0
