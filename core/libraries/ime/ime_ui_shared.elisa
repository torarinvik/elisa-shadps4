#
# Native Elisa port of the self-contained portion of core/libraries/ime/
# ime_ui_shared.h: the OSK timing constants and the OskPadInputFrame layout
# (all primitive fields). The nested anonymous struct virtual_lstick_dirs is
# lifted out as OskPadInputFrameLstickDirs. Everything else is deferred:
# VirtualPadSnapshot / SelectorFadeState (ImVec2/ImVec4), OskPadInputState /
# OskVirtualPadInputView / OskShortcutRepeatState (reference fields and Pad
# types), OskShortcutActionResult (ImeKbKeyAction from ime_kb_layout.h), and
# all function/template declarations (ImGui/render and ime_common types).

# OSK input timing constants (from ime_ui_shared.h constexpr globals).
const IME_UI_PANEL_EDGE_WRAP_HOLD_DELAY_SEC: f64 = 0.5f64
const IME_UI_REPEAT_INTENT_WINDOW_SEC: f64 = 0.45f64
const IME_UI_SELECTOR_FADE_OUT_DURATION_SEC: f32 = 0.2f32
const IME_UI_SELECTOR_PRESS_PULSE_DURATION_SEC: f32 = 0.2f32
const IME_UI_SELECTOR_PRESS_PULSE_EXPAND_BORDER_FACTOR: f32 = 1.0f32

# Lifted from the anonymous struct OskPadInputFrame::virtual_lstick_dirs.
struct OskPadInputFrameLstickDirs:
    left: mutable bool
    right: mutable bool
    up: mutable bool
    down: mutable bool

struct OskPadInputFrame:
    virtual_buttons: mutable u32
    prev_virtual_buttons: mutable u32
    virtual_lstick_dirs: mutable OskPadInputFrameLstickDirs
    cross_down: mutable bool
    l2_analog: mutable f32
    panel_activate_pressed_raw: mutable bool
    panel_activate_repeat_raw: mutable bool
    virtual_nav_left: mutable bool
    virtual_nav_right: mutable bool
    virtual_nav_up: mutable bool
    virtual_nav_down: mutable bool
    virtual_nav_left_repeat: mutable bool
    virtual_nav_right_repeat: mutable bool
    virtual_nav_up_repeat: mutable bool
    virtual_nav_down_repeat: mutable bool
    stick_nav_left: mutable bool
    stick_nav_right: mutable bool
    stick_nav_up: mutable bool
    stick_nav_down: mutable bool
    stick_nav_left_repeat: mutable bool
    stick_nav_right_repeat: mutable bool
    stick_nav_up_repeat: mutable bool
    stick_nav_down_repeat: mutable bool
    nav_left: mutable bool
    nav_right: mutable bool
    nav_up: mutable bool
    nav_down: mutable bool
    nav_left_repeat: mutable bool
    nav_right_repeat: mutable bool
    nav_up_repeat: mutable bool
    nav_down_repeat: mutable bool
    raw_osk_control_input: mutable bool
    virtual_control_input: mutable bool
    osk_control_input: mutable bool
