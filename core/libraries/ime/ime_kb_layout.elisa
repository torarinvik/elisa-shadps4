#
# Native Elisa port of the self-contained data in
# core/libraries/ime/ime_kb_layout.h: keyboard-layout enums and the plain
# primitive-only structs/constants.
#
# DEFERRED (depend on ime_common.h / imgui types and are not ported here):
#   ImeViewportMetrics, ImeKbGridLayout, ImePanelMetricsConfig, ImePanelMetrics
#     (use ImVec2 / float UI metrics),
#   ImeKbKeySpec, ImeKbLayoutModel, ImeTopPanelLayoutConfig
#     (use const char* / pointer-to-table fields),
#   ImeStyleConfig (uses OrbisImeColor),
#   ImeKbDrawParams, ImeKbDrawState (use ImU32 / ImVec2 / OrbisIme* types).
# The full per-key layout tables are also deferred (generated key arrays).

# enum class ImeKbLayoutFamily : u8
const IME_KB_LAYOUT_FAMILY_LATIN: u32 = 0
const IME_KB_LAYOUT_FAMILY_SYMBOLS: u32 = 1
const IME_KB_LAYOUT_FAMILY_SPECIALS: u32 = 2

# enum class ImeKbCaseState : u8
const IME_KB_CASE_STATE_LOWER: u32 = 0
const IME_KB_CASE_STATE_UPPER: u32 = 1
const IME_KB_CASE_STATE_CAPS_LOCK: u32 = 2

# enum class ImeKbLayoutId : u8
const IME_KB_LAYOUT_ID_LATIN_LOWER: u32 = 0
const IME_KB_LAYOUT_ID_LATIN_UPPER: u32 = 1
const IME_KB_LAYOUT_ID_LATIN_CAPS_LOCK: u32 = 2
const IME_KB_LAYOUT_ID_SYMBOLS_PAGE1: u32 = 3
const IME_KB_LAYOUT_ID_SYMBOLS_PAGE2: u32 = 4
const IME_KB_LAYOUT_ID_SPECIALS_PAGE1: u32 = 5
const IME_KB_LAYOUT_ID_SPECIALS_PAGE2: u32 = 6

