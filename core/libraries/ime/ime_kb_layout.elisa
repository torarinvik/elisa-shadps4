# enum class ImeTopPanelElementId : u8
const IME_TOP_PANEL_ELEMENT_ID_PREDICTION: u32 = 0
const IME_TOP_PANEL_ELEMENT_ID_CLOSE: u32 = 1

# struct ImeSelectionGridIndex (static constexpr index constants only;
# the constexpr helper functions are deferred).
const IME_SELECTION_DEFAULT_KEYBOARD_ROWS: u32 = 6
const IME_SELECTION_DEFAULT_KEYBOARD_COLS: u32 = 10
const IME_SELECTION_DEFAULT_TOP_PANEL_ROW: u32 = 0
const IME_SELECTION_DEFAULT_TOP_PANEL_ROWS: u32 = 1
const IME_SELECTION_DEFAULT_FUNCTION_ROWS: u32 = 2
const IME_SELECTION_PANEL_MIN_ROW: u32 = 0
const IME_SELECTION_PANEL_MAX_ROW: u32 = 6
const IME_SELECTION_PANEL_TOP_ROW: u32 = 0
const IME_SELECTION_PANEL_KEYBOARD_MIN_ROW: u32 = 1
const IME_SELECTION_PANEL_KEYBOARD_MAX_ROW: u32 = 6
const IME_SELECTION_KEYBOARD_MIN_ROW: u32 = 0
const IME_SELECTION_KEYBOARD_MAX_ROW: u32 = 5
const IME_SELECTION_KEYBOARD_MIN_COL: u32 = 0
const IME_SELECTION_KEYBOARD_MAX_COL: u32 = 9
const IME_SELECTION_TOP_ROW_MIN_COL: u32 = 0
const IME_SELECTION_TOP_ROW_PREDICTION_MAX_COL: u32 = 8
const IME_SELECTION_TOP_ROW_CLOSE_COL: u32 = 9

# struct ImeKbLayoutSelection (all primitive: enums modeled as u8 + u8)
struct ImeKbLayoutSelection:
    family: mutable u8
    case_state: mutable u8
    page: mutable u8

# struct ImeTopPanelElementSpec (enum id modeled as u8 + u8 + u8)
struct ImeTopPanelElementSpec:
    id: mutable u8
    col: mutable u8
    col_span: mutable u8

# struct ImeEdgeWrapNavState (all primitive: int -> i32, double -> f64, bool)
struct ImeEdgeWrapNavState:
    last_step_row: mutable i32
    last_step_col: mutable i32
    last_step_time: mutable f64
    hold_step_row: mutable i32
    hold_step_col: mutable i32
    hold_release_time: mutable f64
    hold_active: mutable bool
