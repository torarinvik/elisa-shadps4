# enum class ImeKbKeyGlyph : u8
const IME_KB_KEY_GLYPH_NONE: u32 = 0
const IME_KB_KEY_GLYPH_BACKSPACE: u32 = 1
const IME_KB_KEY_GLYPH_ARROW_LEFT: u32 = 2
