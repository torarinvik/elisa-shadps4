const ORBIS_OK: int = 0x00000000

const ORBIS_FAIL: int = 0xFFFFFFFF

const ORBIS_ERROR_DIALOG_ERROR_NOT_INITIALIZED: int = 0x80ED0001

const ORBIS_ERROR_DIALOG_ERROR_ALREADY_INITIALIZED: int = 0x80ED0002

const ORBIS_ERROR_DIALOG_ERROR_PARAM_INVALID: int = 0x80ED0003

const ORBIS_ERROR_DIALOG_ERROR_UNEXPECTED_FATAL: int = 0x80ED0004

const ORBIS_ERROR_DIALOG_ERROR_INVALID_STATE: int = 0x80ED0005

const ORBIS_ERROR_DIALOG_ERROR_SERVICE_BUSY: int = 0x80ED0006

const ORBIS_ERROR_DIALOG_ERROR_INVALID_USER_ID: int = 0x80ED0007

const ORBIS_IME_ERROR_BUSY: int = 0x80BC0001

const ORBIS_IME_ERROR_NOT_OPENED: int = 0x80BC0002

const ORBIS_IME_ERROR_NO_MEMORY: int = 0x80BC0003

const ORBIS_IME_ERROR_CONNECTION_FAILED: int = 0x80BC0004

const ORBIS_IME_ERROR_TOO_MANY_REQUESTS: int = 0x80BC0005

const ORBIS_IME_ERROR_INVALID_TEXT: int = 0x80BC0006

const ORBIS_IME_ERROR_EVENT_OVERFLOW: int = 0x80BC0007

const ORBIS_IME_ERROR_NOT_ACTIVE: int = 0x80BC0008

const ORBIS_IME_ERROR_IME_SUSPENDING: int = 0x80BC0009

const ORBIS_IME_ERROR_DEVICE_IN_USE: int = 0x80BC000A

const ORBIS_IME_ERROR_INVALID_USER_ID: int = 0x80BC0010

const ORBIS_IME_ERROR_INVALID_TYPE: int = 0x80BC0011

const ORBIS_IME_ERROR_INVALID_SUPPORTED_LANGUAGES: int = 0x80BC0012

const ORBIS_IME_ERROR_INVALID_ENTER_LABEL: int = 0x80BC0013

const ORBIS_IME_ERROR_INVALID_INPUT_METHOD: int = 0x80BC0014

const ORBIS_IME_ERROR_INVALID_OPTION: int = 0x80BC0015

const ORBIS_IME_ERROR_INVALID_MAX_TEXT_LENGTH: int = 0x80BC0016

const ORBIS_IME_ERROR_INVALID_INPUT_TEXT_BUFFER: int = 0x80BC0017

const ORBIS_IME_ERROR_INVALID_POSX: int = 0x80BC0018

const ORBIS_IME_ERROR_INVALID_POSY: int = 0x80BC0019

const ORBIS_IME_ERROR_INVALID_HORIZONTAL_ALIGNMENT: int = 0x80BC001A

const ORBIS_IME_ERROR_INVALID_VERTICAL_ALIGNMENT: int = 0x80BC001B

const ORBIS_IME_ERROR_INVALID_EXTENDED: int = 0x80BC001C

const ORBIS_IME_ERROR_INVALID_KEYBOARD_TYPE: int = 0x80BC001D

const ORBIS_IME_ERROR_INVALID_WORK: int = 0x80BC0020

const ORBIS_IME_ERROR_INVALID_ARG: int = 0x80BC0021

const ORBIS_IME_ERROR_INVALID_HANDLER: int = 0x80BC0022

const ORBIS_IME_ERROR_NO_RESOURCE_ID: int = 0x80BC0023

const ORBIS_IME_ERROR_INVALID_MODE: int = 0x80BC0024

const ORBIS_IME_ERROR_INVALID_PARAM: int = 0x80BC0030

const ORBIS_IME_ERROR_INVALID_ADDRESS: int = 0x80BC0031

const ORBIS_IME_ERROR_INVALID_RESERVED: int = 0x80BC0032

const ORBIS_IME_ERROR_INVALID_TIMING: int = 0x80BC0033

const ORBIS_IME_ERROR_INTERNAL: int = 0x80BC00FF

const ORBIS_IME_DIALOG_MAX_TEXT_LENGTH: u32 = 2048

const ORBIS_IME_USER_SERVICE_USER_ID_INVALID: int = (-1)

const ORBIS_IME_USER_SERVICE_USER_ID_SYSTEM: int = 255

const ORBIS_IME_OPTION_MULTILINE: u32 = 1

const ORBIS_IME_OPTION_PASSWORD: u32 = 4

const ORBIS_IME_OPTION_EXPANDED_PREEDIT_BUFFER: u32 = 4096

const ORBIS_IME_OPTION_USE_OVER_2K_COORDINATES: u32 = 16384

const ORBIS_IME_TYPE_DEFAULT: u32 = 0

const ORBIS_IME_TYPE_BASIC_LATIN: u32 = 1

const ORBIS_IME_TYPE_NUMBER: u32 = 4

const ORBIS_IME_ENTER_LABEL_GO: u32 = 3

const ORBIS_IME_INPUT_METHOD_DEFAULT: u32 = 0

const ORBIS_IME_PANEL_PRIORITY_ACCENT: u32 = 3

const ORBIS_IME_TEXT_AREA_MODE_PREEDIT: u32 = 2

const ORBIS_IME_TEXT_AREA_MODE_SELECT: u32 = 3

const ORBIS_IME_KEYBOARD_OPTION_MASK: u32 = 63

const ORBIS_IME_EXT_OPTION_ALLOW_SDK_GE_156: u32 = 0x4fdf

const ORBIS_IME_PANEL_TYPE_HIDE: u32 = 0

type OrbisImeEventHandler = func(void&?, OrbisImeEvent&?) -> void

type OrbisImeTextFilter = func(mutable u16&?, mutable u32&?, u16&?, u32) -> int

type OrbisImeExtKeyboardFilter = func(OrbisImeKeycode&?, mutable u16&?, mutable u32&?, void&?) -> int

@fixed_layout
struct OrbisImeRect:
    x: mutable f32
    y: mutable f32
    width: mutable u32
    height: mutable u32

@fixed_layout
struct OrbisImeColor:
    r: mutable u8
    g: mutable u8
    b: mutable u8
    a: mutable u8

@fixed_layout
struct OrbisImeTextAreaProperty:
    mode: mutable u32
    index: mutable u32
    length: mutable int

@fixed_layout
struct OrbisImeEditText:
    str: mutable u16&?
    caret_index: mutable u32
    area_num: mutable u32
    text_area: mutable OrbisImeTextAreaProperty[4]

@fixed_layout
struct OrbisImeKeyboardResourceIdArray:
    user_id: mutable int
    resource_id: mutable u32[5]

@fixed_layout
struct OrbisImeKeycode:
    keycode: mutable u16
    character: mutable u16
    status: mutable u32
    type_: mutable u32
    user_id: mutable int
    resource_id: mutable u32
    timestamp: mutable u64

@fixed_layout
struct OrbisImeKeyboardInfo:
    user_id: mutable int
    device: mutable u32
    type_: mutable u32
    repeat_delay: mutable u32
    repeat_rate: mutable u32
    status: mutable u32
    reserved: mutable i8[12]

@fixed_layout
struct OrbisImePositionAndForm:
    type_: mutable u32
    posx: mutable f32
    posy: mutable f32
    horizontal_alignment: mutable u32
    vertical_alignment: mutable u32
    width: mutable u32
    height: mutable u32

@fixed_layout
struct OrbisImeTextGeometry:
    x: mutable f32
    y: mutable f32
    width: mutable u32
    height: mutable u32

@fixed_layout
struct OrbisImeEventParam:
    reserved: mutable i8[64]

@fixed_layout
struct OrbisImeEvent:
    id: mutable u32
    param: mutable OrbisImeEventParam

@fixed_layout
struct OrbisImeKeyboardParam:
    option: mutable u32
    reserved1: mutable i8[4]
    arg: mutable void&?
    handler: mutable OrbisImeEventHandler?
    reserved2: mutable i8[8]

@fixed_layout
struct OrbisImeParam:
    user_id: mutable int
    type_: mutable u32
    supported_languages: mutable u64
    enter_label: mutable u32
    input_method: mutable u32
    filter: mutable OrbisImeTextFilter?
    option: mutable u32
    maxTextLength: mutable u32
    inputTextBuffer: mutable u16&?
    posx: mutable f32
    posy: mutable f32
    horizontal_alignment: mutable u32
    vertical_alignment: mutable u32
    work: mutable void&?
    arg: mutable void&?
    handler: mutable OrbisImeEventHandler?
    reserved: mutable i8[8]

@fixed_layout
struct OrbisImeCaret:
    x: mutable f32
    y: mutable f32
    height: mutable u32
    index: mutable u32

@fixed_layout
struct OrbisImeParamExtended:
    option: mutable u32
    color_base: mutable OrbisImeColor
    color_line: mutable OrbisImeColor
    color_text_field: mutable OrbisImeColor
    color_preedit: mutable OrbisImeColor
    color_button_default: mutable OrbisImeColor
    color_button_function: mutable OrbisImeColor
    color_button_symbol: mutable OrbisImeColor
    color_text: mutable OrbisImeColor
    color_special: mutable OrbisImeColor
    priority: mutable u32
    additional_dictionary_path: mutable i8&?
    ext_keyboard_filter: mutable OrbisImeExtKeyboardFilter?
    disable_device: mutable u32
    ext_keyboard_mode: mutable u32
    reserved: mutable i8[60]

global mutable g_ime_open: bool = false

global mutable g_keyboard_open: bool = false

global mutable g_ime_handler: OrbisImeEventHandler? = null

global mutable g_keyboard_handler: OrbisImeEventHandler? = null

global mutable g_ime_option_bits: u32 = 0

global mutable g_ime_max_text_length: u32 = 0

global mutable g_ime_current_text_length: u32 = 0

def ime_stub_ok() -> int:
    return ORBIS_OK

def ime_get_compiled_sdk_version() -> u32:
    return 0x06000000u32

def ime_get_option_mask() -> u32:
    sdk: u32 = ime_get_compiled_sdk_version()
    mask: mutable u32 = (((1u32 << 8)) if (sdk > 0x014fffffu32) else 0u32)
    tmp: mutable u32 = (mask | 0x70ffu32)
    if (sdk > 0x0174ffffu32):
        tmp <- (mask | 0x78ffu32)
    mask <- (tmp & 0x69ffu32)
    if (sdk > 0x02ffffffu32):
        mask <- tmp
    tmp <- (mask & 0x59ffu32)
    if (sdk > 0x034fffffu32):
        tmp <- mask
    mask <- (tmp & 0x39ffu32)
    if (sdk > 0x03ffffffu32):
        mask <- tmp
    return mask

def ime_has_invalid_option(option: u32) -> bool:
    mask: u32 = ime_get_option_mask()
    return ((((((mask ^ 0xfffffdffu32)) & option)) != 0u32))

def ime_get_language_mask() -> u64:
    sdk: u32 = ime_get_compiled_sdk_version()
    mask: mutable u64 = (((0x01000000u64 if (sdk > 0x01ffffffu32) else 0u64)) + 0x3fe1fffffu64)
    tmp: mutable u64 = (mask & 0x3fd1fffffu64)
    if (sdk > 0x024fffffu32):
        tmp <- mask
    mask <- (tmp & 0x2031fffffu64)
    if (sdk > 0x04ffffffu32):
        mask <- tmp
    tmp <- (mask & 0x1ff1fffffu64)
    if (sdk > 0x0fffffffu32):
        tmp <- mask
    return tmp

def ime_valid_ext_option(option: u32) -> bool:
    sdk: u32 = ime_get_compiled_sdk_version()
    allow: mutable u32 = (0x41dfu32 if (sdk < 0x01560000u32) else ORBIS_IME_EXT_OPTION_ALLOW_SDK_GE_156)
    if (((option & 0x4080u32)) == 0x4000u32):
        return false
    if (sdk <= 0x05ffffffu32):
        allow <- (allow & 0x0fdfu32)
    return (((((~allow) & option)) == 0u32))

def ime_valid_user_id(user_id: int) -> bool:
    sdk: u32 = ime_get_compiled_sdk_version()
    uid_u: u32 = user_id as u32
    if (sdk < 0x01500000u32):
        if (((((uid_u + 1u32)) < 2u32)) or ((((uid_u - 0xfeu32)) < 2u32))):
            return true
        return (user_id >= 0)
    if ((user_id == ORBIS_IME_USER_SERVICE_USER_ID_INVALID) or (user_id == ORBIS_IME_USER_SERVICE_USER_ID_SYSTEM)):
        return false
    if (user_id == 0xfe):
        return true
    return (user_id >= 0)

def ime_count_utf16(text: u16&?, max_len: u32) -> u32:
    if (text == null):
        return 0u32
    i: mutable u32 = 0u32
    while ((i < max_len) and (text[i] != 0u16)):
        i <- (i + 1u32)
    return i

def ime_valid_text(text: u16&?, length: u32, multiline: bool, sdk: u32) -> bool:
    if (text == null):
        return false
    allow_new_line: bool = (((sdk >= 0x01560000u32)) and multiline)
    i: mutable u32 = 0u32
    while (i < length):
        ch: u16 = text[i]
        if (((not allow_new_line)) and (((ch == 10u16) or (ch == 13u16)))):
            return false
        if ((((ch & 0xf800u16)) == 0xd800u16)):
            return false
        if (ch == 0u16):
            return true
        i <- (i + 1u32)
    return true

def ime_all_zero_i8_4(data: i8[4]) -> bool:
    i: mutable int = 0
    while (i < 4):
        if (data[i] != 0):
            return false
        i <- (i + 1)
    return true

def ime_all_zero_i8_8(data: i8[8]) -> bool:
    i: mutable int = 0
    while (i < 8):
        if (data[i] != 0):
            return false
        i <- (i + 1)
    return true

def ime_all_zero_i8_60(data: i8[60]) -> bool:
    i: mutable int = 0
    while (i < 60):
        if (data[i] != 0):
            return false
        i <- (i + 1)
    return true

def ime_zero_u32_5(values: mutable u32[5]) -> void:
    i: mutable int = 0
    while (i < 5):
        values[i] <- 0u32
        i <- (i + 1)

