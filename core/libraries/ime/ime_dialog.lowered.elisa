def sceImeGetPanelPositionAndForm(posForm: mutable OrbisImePositionAndForm&?) -> int:
    if (posForm != null):
        posForm.type_ <- ORBIS_IME_PANEL_TYPE_HIDE
        posForm.posx <- 0.0
        posForm.posy <- 0.0
        posForm.horizontal_alignment <- 0u32
        posForm.vertical_alignment <- 0u32
        posForm.width <- 0u32
        posForm.height <- 0u32
    return ORBIS_OK

def sceImeGetPanelSize(param: OrbisImeParam&?, width: mutable u32&?, height: mutable u32&?) -> int:
    if (((param == null) or (width == null)) or (height == null)):
        return ORBIS_IME_ERROR_INVALID_ADDRESS
    if (param.type_ > ORBIS_IME_TYPE_NUMBER):
        return ORBIS_IME_ERROR_INVALID_TYPE
    option: u32 = param.option
    if ime_has_invalid_option(option):
        return ORBIS_IME_ERROR_INVALID_OPTION
    sdk: u32 = ime_get_compiled_sdk_version()
    if (param.type_ == ORBIS_IME_TYPE_NUMBER):
        width[0] <- 0x172u32
        height[0] <- ((0x192u32 if (sdk > 0x016fffffu32) else 0x170u32))
    else:
        if ((param.type_ == ORBIS_IME_TYPE_BASIC_LATIN) or (((option & 0xc0000004u32)) == 4u32)):
            width[0] <- 0x319u32
            height[0] <- ((0x198u32 if (sdk > 0x016fffffu32) else 0x170u32))
        else:
            width[0] <- 0x319u32
            height[0] <- 0x198u32
    if (((option & ORBIS_IME_OPTION_USE_OVER_2K_COORDINATES)) != 0u32):
        width[0] <- (width[0] << 1u32)
        height[0] <- (height[0] << 1u32)
    return ORBIS_OK

def sceImeKeyboardClose(userId: int) -> int:
    if (not g_keyboard_open):
        return ORBIS_IME_ERROR_NOT_OPENED
    if (userId == ORBIS_IME_USER_SERVICE_USER_ID_INVALID):
        return ORBIS_IME_ERROR_INVALID_USER_ID
    g_keyboard_open <- false
    g_keyboard_handler <- null
    return ORBIS_OK

def sceImeKeyboardGetInfo(resourceId: u32, info: mutable OrbisImeKeyboardInfo&?) -> int:
    _ = resourceId
    if (info != null):
        info.user_id <- 0
        info.device <- 0u32
        info.type_ <- 0u32
        info.repeat_delay <- 0u32
        info.repeat_rate <- 0u32
        info.status <- 0u32
        i: mutable int = 0
        while (i < 12):
            info.reserved[i] <- 0
            i <- (i + 1)
    return ORBIS_OK

def sceImeKeyboardGetResourceId(userId: int, resourceIdArray: mutable OrbisImeKeyboardResourceIdArray&?) -> int:
    if (resourceIdArray == null):
        return ORBIS_IME_ERROR_INVALID_ADDRESS
    if (userId == ORBIS_IME_USER_SERVICE_USER_ID_INVALID):
        return ORBIS_IME_ERROR_INVALID_USER_ID
    resourceIdArray.user_id <- userId
    ime_zero_u32_5(resourceIdArray.resource_id)
    if (not g_keyboard_open):
        return ORBIS_IME_ERROR_NOT_OPENED
    return ORBIS_IME_ERROR_CONNECTION_FAILED

def sceImeKeyboardOpen(userId: int, param: OrbisImeKeyboardParam&?) -> int:
    if (param == null):
        return ORBIS_IME_ERROR_INVALID_ADDRESS
    if (param.handler == null):
        return ORBIS_IME_ERROR_INVALID_HANDLER
    if (((param.option & (~ORBIS_IME_KEYBOARD_OPTION_MASK))) != 0u32):
        return ORBIS_IME_ERROR_INVALID_OPTION
    if (userId == ORBIS_IME_USER_SERVICE_USER_ID_INVALID):
        return ORBIS_IME_ERROR_INVALID_USER_ID
    if (not ime_all_zero_i8_4(param.reserved1)):
        return ORBIS_IME_ERROR_INVALID_RESERVED
    if (not ime_all_zero_i8_8(param.reserved2)):
        return ORBIS_IME_ERROR_INVALID_RESERVED
    if g_keyboard_open:
        return ORBIS_IME_ERROR_BUSY
    g_keyboard_open <- true
    g_keyboard_handler <- param.handler
    return ORBIS_OK

def sceImeKeyboardOpenInternal() -> int:
    return ime_stub_ok()

def sceImeKeyboardSetMode(userId: int, mode: u32) -> int:
    _ = userId
    _ = mode
    return ime_stub_ok()

def sceImeKeyboardUpdate() -> int:
    return ime_stub_ok()

def sceImeOpen(param: OrbisImeParam&?, extended: OrbisImeParamExtended&?) -> int:
    if g_ime_open:
        return ORBIS_IME_ERROR_BUSY
    if (param == null):
        return ORBIS_IME_ERROR_INVALID_ADDRESS
    if (not ime_valid_user_id(param.user_id)):
        return ORBIS_IME_ERROR_INVALID_USER_ID
    if (param.type_ > ORBIS_IME_TYPE_NUMBER):
        return ORBIS_IME_ERROR_INVALID_TYPE
    lang_mask: u64 = ime_get_language_mask()
    if (((((~lang_mask) & param.supported_languages)) != 0u64)):
        return ORBIS_IME_ERROR_INVALID_SUPPORTED_LANGUAGES
    if (param.enter_label > ORBIS_IME_ENTER_LABEL_GO):
        return ORBIS_IME_ERROR_INVALID_ENTER_LABEL
    if (param.input_method != ORBIS_IME_INPUT_METHOD_DEFAULT):
        return ORBIS_IME_ERROR_INVALID_INPUT_METHOD
    option: u32 = param.option
    if ime_has_invalid_option(option):
        return ORBIS_IME_ERROR_INVALID_OPTION
    multiline: bool = (((option & ORBIS_IME_OPTION_MULTILINE)) != 0u32)
    password: bool = (((option & ORBIS_IME_OPTION_PASSWORD)) != 0u32)
    if (multiline and password):
        return ORBIS_IME_ERROR_INVALID_PARAM
    if ((multiline and (param.type_ != ORBIS_IME_TYPE_DEFAULT)) and (param.type_ != ORBIS_IME_TYPE_BASIC_LATIN)):
        return ORBIS_IME_ERROR_INVALID_PARAM
    if ((password and (param.type_ != ORBIS_IME_TYPE_BASIC_LATIN)) and (param.type_ != ORBIS_IME_TYPE_NUMBER)):
        return ORBIS_IME_ERROR_INVALID_PARAM
    if ((param.maxTextLength == 0u32) or (param.maxTextLength > ORBIS_IME_DIALOG_MAX_TEXT_LENGTH)):
        return ORBIS_IME_ERROR_INVALID_MAX_TEXT_LENGTH
    if (param.inputTextBuffer == null):
        return ORBIS_IME_ERROR_INVALID_INPUT_TEXT_BUFFER
    sdk: u32 = ime_get_compiled_sdk_version()
    maxWidth: mutable f32 = 1920.0
    maxHeight: mutable f32 = 1080.0
    if (sdk >= 0x01500000u32):
        use_high_res: bool = (((option & ORBIS_IME_OPTION_USE_OVER_2K_COORDINATES)) != 0u32)
        maxWidth <- ((3840.0 if use_high_res else 1920.0))
        maxHeight <- ((2160.0 if use_high_res else 1080.0))
    if ((param.posx < 0.0) or (param.posx >= maxWidth)):
        return ORBIS_IME_ERROR_INVALID_POSX
    if ((param.posy < 0.0) or (param.posy >= maxHeight)):
        return ORBIS_IME_ERROR_INVALID_POSY
    if (param.horizontal_alignment > 2u32):
        return ORBIS_IME_ERROR_INVALID_HORIZONTAL_ALIGNMENT
    if (param.vertical_alignment > 2u32):
        return ORBIS_IME_ERROR_INVALID_VERTICAL_ALIGNMENT
    if (extended != null):
        if (extended.priority > ORBIS_IME_PANEL_PRIORITY_ACCENT):
            return ORBIS_IME_ERROR_INVALID_EXTENDED
        if (not ime_valid_ext_option(extended.option)):
            return ORBIS_IME_ERROR_INVALID_EXTENDED
        if (((extended.ext_keyboard_mode & 0xe3fffffcu32)) != 0u32):
            return ORBIS_IME_ERROR_INVALID_EXTENDED
        if (not ime_all_zero_i8_60(extended.reserved)):
            return ORBIS_IME_ERROR_INVALID_EXTENDED
        if (extended.disable_device > 7u32):
            return ORBIS_IME_ERROR_INVALID_EXTENDED
    if (param.work == null):
        return ORBIS_IME_ERROR_INVALID_WORK
    if (((param.work.usize() & 0x3usize)) != 0usize):
        return ORBIS_IME_ERROR_INVALID_WORK
    if (param.handler == null):
        return ORBIS_IME_ERROR_INVALID_HANDLER
    if (not ime_all_zero_i8_8(param.reserved)):
        return ORBIS_IME_ERROR_INVALID_RESERVED
    if (not ime_valid_text(param.inputTextBuffer, param.maxTextLength, multiline, sdk)):
        return ORBIS_IME_ERROR_INVALID_TEXT
    g_ime_open <- true
    g_ime_handler <- param.handler
    g_ime_option_bits <- option
    g_ime_max_text_length <- param.maxTextLength
    g_ime_current_text_length <- ime_count_utf16(param.inputTextBuffer, param.maxTextLength)
    return ORBIS_OK

def sceImeOpenInternal() -> int:
    return ime_stub_ok()

def sceImeParamInit(param: mutable OrbisImeParam&?) -> void:
    if (param == null):
        return
    param[0] <- zeroed
    param.user_id <- ORBIS_IME_USER_SERVICE_USER_ID_INVALID

def sceImeSetCandidateIndex(index: int) -> int:
    _ = index
    return ime_stub_ok()

def sceImeSetCaret(caret: OrbisImeCaret&?) -> int:
    if (not g_ime_open):
        return ORBIS_IME_ERROR_NOT_OPENED
    sdk: u32 = ime_get_compiled_sdk_version()
    if (caret == null):
        return (ORBIS_IME_ERROR_INVALID_PARAM if (sdk < 0x01500000u32) else ORBIS_IME_ERROR_INVALID_ADDRESS)
    if (caret.index > g_ime_current_text_length):
        return ORBIS_IME_ERROR_INVALID_PARAM
    return ORBIS_OK

def sceImeSetText(text: u16&?, length: u32) -> int:
    if (not g_ime_open):
        return ORBIS_IME_ERROR_NOT_OPENED
    if (text == null):
        return ORBIS_IME_ERROR_INVALID_ADDRESS
    sdk: u32 = ime_get_compiled_sdk_version()
    if ((sdk < 0x01560000u32) and (length == 0u32)):
        return ORBIS_IME_ERROR_INVALID_PARAM
    if (length != 0u32):
        multiline: bool = (((g_ime_option_bits & ORBIS_IME_OPTION_MULTILINE)) != 0u32)
        if (not ime_valid_text(text, length, multiline, sdk)):
            return ORBIS_IME_ERROR_INVALID_TEXT
    g_ime_current_text_length <- length
    return ORBIS_OK

def sceImeSetTextGeometry(mode: u32, geometry: OrbisImeTextGeometry&?) -> int:
    if (not g_ime_open):
        return ORBIS_IME_ERROR_NOT_OPENED
    if (geometry == null):
        return ORBIS_IME_ERROR_INVALID_ADDRESS
    x: f32 = geometry.x
    y: f32 = geometry.y
    if ((((x < 0.0) or (x >= 1920.0)) or (y < 0.0)) or (y >= 1080.0)):
        return ORBIS_IME_ERROR_INVALID_PARAM
    if ((mode != ORBIS_IME_TEXT_AREA_MODE_SELECT) and (mode != ORBIS_IME_TEXT_AREA_MODE_PREEDIT)):
        return ORBIS_IME_ERROR_INVALID_PARAM
    return ORBIS_OK

