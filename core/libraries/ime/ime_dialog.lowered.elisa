def sceImeClose() -> int:
    if (not g_ime_open):
        return ORBIS_IME_ERROR_NOT_OPENED
    g_ime_open <- false
    g_ime_handler <- null
    g_ime_option_bits <- 0u32
    g_ime_max_text_length <- 0u32
    g_ime_current_text_length <- 0u32
    return ORBIS_OK

