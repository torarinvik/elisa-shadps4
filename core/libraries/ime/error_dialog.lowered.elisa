def sceCommonDialogInitialize() -> u32:
    if g_isInitialized:
        return ORBIS_COMMON_DIALOG_ERROR_ALREADY_SYSTEM_INITIALIZED.u32()
    g_isInitialized <- true
    return ORBIS_OK.u32()

def sceCommonDialogIsUsed() -> bool:
    return g_isUsed

