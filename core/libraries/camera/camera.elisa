# @port core/libraries/camera/camera.cpp::sceCameraStopByHandle sha256=59c4b4f34826df37 oracle@a3773841
def sceCameraStopByHandle(handle: int) -> int:
    return sceCameraStop(handle)

def Camera_RegisterLib(sym: void&?) -> void:
    _ = sym
