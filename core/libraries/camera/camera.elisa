def sceCameraGetDeviceInfo(reserved: int, device_info: mutable OrbisCameraDeviceInfo&?) -> int:
    if reserved != 0 or device_info == null:
        return ORBIS_CAMERA_ERROR_PARAM
    info: mutable OrbisCameraDeviceInfo& = device_info
    if info.sizeThis != size_of(OrbisCameraDeviceInfo).u32() or info.infoRevision != 1:
        return ORBIS_CAMERA_ERROR_PARAM
    if not g_camera_library_opened:
        return ORBIS_CAMERA_ERROR_NOT_INIT
    return ORBIS_CAMERA_ERROR_NOT_CONNECTED

def sceCameraGetExposureGain(handle: int, channel: int, exposure_gain: mutable OrbisCameraExposureGain&?, option: void&?) -> int:
    if handle < 1 or not camera_channel_valid_get(channel) or exposure_gain == null or option != null:
        return ORBIS_CAMERA_ERROR_PARAM
    if not g_camera_library_opened:
        return ORBIS_CAMERA_ERROR_NOT_OPEN
    eg: mutable OrbisCameraExposureGain& = exposure_gain
    eg.exposureControl <- 0
    eg.exposure <- 83
    eg.gain <- 100
    eg.mode <- 0
    return ORBIS_OK

def sceCameraGetFrameData(handle: int, frame_data: mutable OrbisCameraFrameData&?) -> int:
    if handle < 1 or frame_data == null or frame_data.ref[mutable OrbisCameraFrameData&].sizeThis > 584:
        return ORBIS_CAMERA_ERROR_PARAM
    if not g_camera_library_opened:
        return ORBIS_CAMERA_ERROR_NOT_OPEN
    if not g_camera_backend_connected:
        if g_camera_sdl_camera == null:
            return ORBIS_CAMERA_ERROR_NOT_OPEN
        fd_real: mutable OrbisCameraFrameData& = frame_data
        return camera_backend_acquire_frame(fd_real)
    if not g_camera_started:
        return ORBIS_CAMERA_ERROR_BUSY
    if not g_camera_frame_ready:
        return ORBIS_CAMERA_ERROR_BUSY
    fd: mutable OrbisCameraFrameData& = frame_data
    fd.status[0] <- 0
    fd.status[1] <- 0
    fd.meta.metaMode <- 0
    fd.meta.format[0] <- g_camera_output_config0.format.formatLevel0
    fd.meta.format[1] <- g_camera_output_config1.format.formatLevel0
    fd.meta.timestamp[0] <- 0
    fd.meta.timestamp[1] <- 0
    fd.pFramePointerList[0] <- null
    fd.pFramePointerList[1] <- null
    g_camera_frame_ready <- false
    return ORBIS_OK

def sceCameraGetGamma(handle: int, channel: int, gamma: mutable OrbisCameraGamma&?, option: void&?) -> int:
    if handle < 1 or not camera_channel_valid_get(channel) or gamma == null or option != null:
        return ORBIS_CAMERA_ERROR_PARAM
    if not g_camera_library_opened:
        return ORBIS_CAMERA_ERROR_NOT_OPEN
    g: mutable OrbisCameraGamma& = gamma
    g <- zeroed
    g.value <- 4
    return ORBIS_OK

