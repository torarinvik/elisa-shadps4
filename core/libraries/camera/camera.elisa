# @port core/libraries/camera/camera.cpp::sceCameraClose sha256=41e274ab581238cb oracle@a3773841
def sceCameraClose(handle: int) -> int:
    if handle < 1:
        return ORBIS_CAMERA_ERROR_PARAM
    if not g_camera_library_opened:
        return ORBIS_CAMERA_ERROR_NOT_OPEN
    g_camera_handles <- g_camera_handles - 1
    if g_camera_handles <= 0:
        g_camera_handles <- 0
        g_camera_library_opened <- false
        camera_backend_close()
    return ORBIS_OK

# @port core/libraries/camera/camera.cpp::sceCameraCloseByHandle sha256=a0db69981e6873ed oracle@a3773841
def sceCameraCloseByHandle(handle: int) -> int:
    return sceCameraClose(handle)

