def sceCameraDeviceOpen() -> int:
    return ORBIS_OK

# @port core/libraries/camera/camera.cpp::sceCameraGetAttribute sha256=cbc373d26272d5fb oracle@a3773841
def sceCameraGetAttribute(handle: int, attribute: mutable OrbisCameraAttribute&?) -> int:
    if handle < 1 or attribute == null:
        return ORBIS_CAMERA_ERROR_PARAM
    attr: mutable OrbisCameraAttribute& = attribute
    if attr.sizeThis != size_of(OrbisCameraAttribute).u32() or not camera_channel_valid_get(attr.channel):
        return ORBIS_CAMERA_ERROR_PARAM
    if not g_camera_library_opened:
        return ORBIS_CAMERA_ERROR_NOT_OPEN
    channel: int = attr.channel
    attr.framePosition <- zeroed
    attr.exposureGain <- zeroed
    attr.whiteBalance <- zeroed
    attr.gamma <- zeroed
    attr.sizeThis <- size_of(OrbisCameraAttribute).u32()
    attr.channel <- channel
    attr.exposureGain.exposure <- 83
    attr.exposureGain.gain <- 100
    attr.whiteBalance.gainRed <- 768
    attr.whiteBalance.gainBlue <- 768
    attr.whiteBalance.gainGreen <- 512
    attr.gamma.value <- 4
    attr.saturation <- 64
    attr.contrast <- 32
    attr.sharpness <- 1
    attr.hue <- 1
    return ORBIS_OK

# @port core/libraries/camera/camera.cpp::sceCameraGetAutoExposureGain sha256=4ea5be68969d0381 oracle@a3773841
def sceCameraGetAutoExposureGain(handle: int, channel: int, enable: mutable u32&, option: mutable OrbisCameraAutoExposureGainTarget&?) -> int:
    if handle < 1 or not camera_channel_valid_get(channel):
        return ORBIS_CAMERA_ERROR_PARAM
    if option != null and (g_camera_firmware_version < ORBIS_CAMERA_SDK_FW_30 or option.ref[mutable OrbisCameraAutoExposureGainTarget&].sizeThis != size_of(OrbisCameraAutoExposureGainTarget).u32()):
        return ORBIS_CAMERA_ERROR_PARAM
    if not g_camera_library_opened:
        return ORBIS_CAMERA_ERROR_NOT_OPEN
    enable <- 0.u32()
    if option != null:
        opt: mutable OrbisCameraAutoExposureGainTarget& = option
        opt.sizeThis <- 0
        opt.target <- ORBIS_CAMERA_ATTRIBUTE_AECAGC_TARGET_DEF
    return ORBIS_OK

# @port core/libraries/camera/camera.cpp::sceCameraGetAutoWhiteBalance sha256=79f7b22d58547aa7 oracle@a3773841
def sceCameraGetAutoWhiteBalance(handle: int, channel: int, enable: mutable u32&, option: void&?) -> int:
    if handle < 1 or not camera_channel_valid_get(channel) or option != null:
        return ORBIS_CAMERA_ERROR_PARAM
    if not g_camera_library_opened:
        return ORBIS_CAMERA_ERROR_NOT_OPEN
    enable <- 0.u32()
    return ORBIS_OK

