def sceCameraSetVideoSync(handle: int, video_sync: OrbisCameraVideoSyncParameter&?) -> int:
    if handle < 1 or video_sync == null:
        return ORBIS_CAMERA_ERROR_PARAM
    vs: OrbisCameraVideoSyncParameter& = video_sync
    if vs.sizeThis != size_of(OrbisCameraVideoSyncParameter).u32() or vs.videoSyncMode > 1 or vs.pModeOption != null:
        return ORBIS_CAMERA_ERROR_PARAM
    if not g_camera_library_opened:
        return ORBIS_CAMERA_ERROR_NOT_OPEN
    return ORBIS_OK

def sceCameraSetVideoSyncInternal(handle: int, video_sync: OrbisCameraVideoSyncParameter&?) -> int:
