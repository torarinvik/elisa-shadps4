# @port core/libraries/camera/camera.cpp::sceCameraSetAutoExposureGain sha256=78da66df74d0dfad oracle@a3773841
def sceCameraSetAutoExposureGain(handle: int, channel: int, enable: u32, option: OrbisCameraAutoExposureGainTarget&?) -> int:
    _ = enable
    if handle < 1 or not camera_channel_valid_set(channel):
        return ORBIS_CAMERA_ERROR_PARAM
    if option != null:
        opt: OrbisCameraAutoExposureGainTarget& = option
        if g_camera_firmware_version < ORBIS_CAMERA_SDK_FW_30 or opt.sizeThis != size_of(OrbisCameraAutoExposureGainTarget).u32():
            return ORBIS_CAMERA_ERROR_PARAM
        if (opt.target & 1) == 1 or opt.target > ORBIS_CAMERA_ATTRIBUTE_AECAGC_TARGET_2_0:
            return ORBIS_CAMERA_ERROR_PARAM
    if not g_camera_library_opened:
        return ORBIS_CAMERA_ERROR_NOT_OPEN
    return ORBIS_CAMERA_ERROR_NOT_CONNECTED

