const ORBIS_CAMERA_MAX_DEVICE_NUM: int = 2
const ORBIS_CAMERA_MAX_FORMAT_LEVEL_NUM: int = 4

const ORBIS_CAMERA_CHANNEL_0: int = 1
const ORBIS_CAMERA_CHANNEL_1: int = 2
const ORBIS_CAMERA_CHANNEL_BOTH: int = 3

const ORBIS_CAMERA_CONFIG_TYPE1: u32 = 0x01
const ORBIS_CAMERA_CONFIG_TYPE2: u32 = 0x02
const ORBIS_CAMERA_CONFIG_TYPE3: u32 = 0x03
const ORBIS_CAMERA_CONFIG_TYPE4: u32 = 0x04
const ORBIS_CAMERA_CONFIG_TYPE5: u32 = 0x05
const ORBIS_CAMERA_CONFIG_EXTENTION: u32 = 0x10

const ORBIS_CAMERA_FORMAT_YUV422: u32 = 0x0
const ORBIS_CAMERA_FORMAT_RAW16: u32 = 0x1
const ORBIS_CAMERA_FORMAT_RAW8: u32 = 0x2

const ORBIS_CAMERA_SCALE_FORMAT_YUV422: u32 = 0x0
const ORBIS_CAMERA_SCALE_FORMAT_Y8: u32 = 0x4

const ORBIS_CAMERA_FRAMERATE_60: u32 = 60
const ORBIS_CAMERA_RESOLUTION_1280X800: u32 = 0

const ORBIS_CAMERA_ATTRIBUTE_AECAGC_TARGET_DEF: u32 = 0x00
const ORBIS_CAMERA_ATTRIBUTE_AECAGC_TARGET_2_0: u32 = 0x20

const ORBIS_CAMERA_USER_SERVICE_USER_ID_SYSTEM: int = -1
const ORBIS_CAMERA_SDK_FW_30: int = 0x03000000
const ORBIS_CAMERA_SDK_FW_35: int = 0x03500000
const ORBIS_CAMERA_SDK_FW_45: int = 0x04500000

struct OrbisCameraOpenParameter:
    sizeThis: mutable u32
    reserved1: mutable u32
    reserved2: mutable u32
    reserved3: mutable u32

struct OrbisCameraFormat:
    formatLevel0: mutable u32
    formatLevel1: mutable u32
    formatLevel2: mutable u32
    formatLevel3: mutable u32

struct OrbisCameraConfigExtention:
    format: mutable OrbisCameraFormat
    resolution: mutable u32
    framerate: mutable u32
    width: mutable u32
    height: mutable u32
    reserved1: mutable u32
    pBaseOption: mutable void&?

struct OrbisCameraConfig:
    sizeThis: mutable u32
    configType: mutable u32
    configExtention: mutable OrbisCameraConfigExtention[2]

struct OrbisCameraDeviceInfo:
    sizeThis: mutable u32
    infoRevision: mutable u32
    deviceRevision: mutable u32
    padding: mutable u32

struct OrbisCameraStartParameter:
    sizeThis: mutable u32
    formatLevel: mutable u32[2]
    pStartOption: mutable void&?

struct OrbisCameraVideoSyncParameter:
    sizeThis: mutable u32
    videoSyncMode: mutable u32
    pModeOption: mutable void&?

struct OrbisCameraFramePosition:
    x: mutable u32
    y: mutable u32
    xSize: mutable u32
    ySize: mutable u32

struct OrbisCameraAutoExposureGainTarget:
    sizeThis: mutable u32
    target: mutable u32

struct OrbisCameraExposureGain:
    exposureControl: mutable u32
    exposure: mutable u32
    gain: mutable u32
    mode: mutable u32

struct OrbisCameraWhiteBalance:
    whiteBalanceControl: mutable u32
    gainRed: mutable u32
    gainBlue: mutable u32
    gainGreen: mutable u32

struct OrbisCameraGamma:
    gammaControl: mutable u32
    value: mutable u32
    reserved: mutable u8[16]

struct OrbisCameraMeta:
    frame: mutable u64[2]
    timestamp: mutable u64[2]
    vcounter: mutable u64
    reserved: mutable u32[14]
    gamma: mutable OrbisCameraGamma[2]
    format: mutable u32[8]
    exposureGain: mutable OrbisCameraExposureGain[2]
    whiteBalance: mutable OrbisCameraWhiteBalance[2]
    deviceTimestamp: mutable u32[2]
    luminance: mutable u32[2]
    metaMode: mutable u32
    acceleration_x: mutable f32
    acceleration_y: mutable f32
    acceleration_z: mutable f32

struct OrbisCameraFrameData:
    sizeThis: mutable u32
    readMode: mutable u32
    framePosition: mutable OrbisCameraFramePosition[8]
    pFramePointerList: mutable void&?[8]
    frameSize: mutable u32[8]
    status: mutable u32[2]
    meta: mutable OrbisCameraMeta
    pFramePointerListGarlic: mutable void&?[8]

struct OrbisCameraAttribute:
    channel: mutable int
    hue: mutable int
    gamma: mutable OrbisCameraGamma
    framePosition: mutable OrbisCameraFramePosition
    exposureGain: mutable OrbisCameraExposureGain
    whiteBalance: mutable OrbisCameraWhiteBalance
    sizeThis: mutable u32
    saturation: mutable u32
    contrast: mutable u32
    sharpness: mutable u32
    reserved1: mutable u32
    reserved2: mutable u32
    reserved3: mutable u32
    reserved4: mutable u32

struct OrbisCameraGetCalibrationDataParameter:
    size: mutable u32
    format_type: mutable u32
    function_type: mutable u32

struct OrbisCameraCalibrationData:
    format_type: mutable u32
    function_type: mutable u32

global mutable g_camera_library_opened: bool = false
global mutable g_camera_firmware_version: int = 0
global mutable g_camera_handles: int = 0
global mutable g_camera_output_config0: OrbisCameraConfigExtention = zeroed
global mutable g_camera_output_config1: OrbisCameraConfigExtention = zeroed
global mutable g_camera_backend_connected: bool = false
global mutable g_camera_real_backend_enabled: bool = false
global mutable g_camera_started: bool = false
global mutable g_camera_frame_ready: bool = false

include "./camera_sdl_backend.elisa"

def camera_channel_valid_get(channel: int) -> bool:
    return channel >= ORBIS_CAMERA_CHANNEL_0 and channel < ORBIS_CAMERA_CHANNEL_BOTH

def camera_channel_valid_set(channel: int) -> bool:
    return channel >= ORBIS_CAMERA_CHANNEL_0 and channel <= ORBIS_CAMERA_CHANNEL_BOTH

def camera_reset_defaults() -> void:
    g_camera_output_config0.format.formatLevel0 <- ORBIS_CAMERA_FORMAT_YUV422
    g_camera_output_config0.format.formatLevel1 <- ORBIS_CAMERA_SCALE_FORMAT_Y8
    g_camera_output_config0.format.formatLevel2 <- ORBIS_CAMERA_SCALE_FORMAT_Y8
    g_camera_output_config0.format.formatLevel3 <- ORBIS_CAMERA_SCALE_FORMAT_Y8
    g_camera_output_config0.resolution <- ORBIS_CAMERA_RESOLUTION_1280X800
    g_camera_output_config0.framerate <- ORBIS_CAMERA_FRAMERATE_60
    g_camera_output_config0.width <- 0
    g_camera_output_config0.height <- 0
    g_camera_output_config0.reserved1 <- 0
    g_camera_output_config0.pBaseOption <- null

    g_camera_output_config1 <- g_camera_output_config0
    g_camera_output_config1.format.formatLevel0 <- ORBIS_CAMERA_FORMAT_RAW16

def camera_make_default_extension() -> OrbisCameraConfigExtention:
    out: mutable OrbisCameraConfigExtention = zeroed
    out.format.formatLevel0 <- ORBIS_CAMERA_FORMAT_YUV422
    out.format.formatLevel1 <- ORBIS_CAMERA_SCALE_FORMAT_Y8
    out.format.formatLevel2 <- ORBIS_CAMERA_SCALE_FORMAT_Y8
    out.format.formatLevel3 <- ORBIS_CAMERA_SCALE_FORMAT_Y8
    out.resolution <- ORBIS_CAMERA_RESOLUTION_1280X800
    out.framerate <- ORBIS_CAMERA_FRAMERATE_60
    return out

def camera_make_config_type(config_type: u32, device_index: usize) -> OrbisCameraConfigExtention:
    out: mutable OrbisCameraConfigExtention = zeroed
    if config_type == ORBIS_CAMERA_CONFIG_TYPE1:
        if device_index == 0:
            out.format.formatLevel0 <- ORBIS_CAMERA_FORMAT_YUV422
        else:
            out.format.formatLevel0 <- ORBIS_CAMERA_FORMAT_RAW16
        out.format.formatLevel1 <- ORBIS_CAMERA_SCALE_FORMAT_Y8
        out.format.formatLevel2 <- ORBIS_CAMERA_SCALE_FORMAT_Y8
        out.format.formatLevel3 <- ORBIS_CAMERA_SCALE_FORMAT_Y8
        out.framerate <- ORBIS_CAMERA_FRAMERATE_60
        return out
    if config_type == ORBIS_CAMERA_CONFIG_TYPE2:
        out.format.formatLevel0 <- ORBIS_CAMERA_FORMAT_YUV422
        out.format.formatLevel1 <- ORBIS_CAMERA_SCALE_FORMAT_YUV422
        out.format.formatLevel2 <- ORBIS_CAMERA_SCALE_FORMAT_YUV422
        out.format.formatLevel3 <- ORBIS_CAMERA_SCALE_FORMAT_YUV422
        out.framerate <- ORBIS_CAMERA_FRAMERATE_60
        return out
    if config_type == ORBIS_CAMERA_CONFIG_TYPE3:
        out.format.formatLevel0 <- ORBIS_CAMERA_FORMAT_YUV422
        out.format.formatLevel1 <- ORBIS_CAMERA_SCALE_FORMAT_Y8
        out.format.formatLevel2 <- ORBIS_CAMERA_SCALE_FORMAT_Y8
        out.format.formatLevel3 <- ORBIS_CAMERA_SCALE_FORMAT_Y8
        out.framerate <- ORBIS_CAMERA_FRAMERATE_60
        return out
    if config_type == ORBIS_CAMERA_CONFIG_TYPE4:
        out.format.formatLevel0 <- ORBIS_CAMERA_FORMAT_RAW16
        out.format.formatLevel1 <- ORBIS_CAMERA_SCALE_FORMAT_YUV422
        out.format.formatLevel2 <- ORBIS_CAMERA_SCALE_FORMAT_YUV422
        out.format.formatLevel3 <- ORBIS_CAMERA_SCALE_FORMAT_YUV422
        out.framerate <- ORBIS_CAMERA_FRAMERATE_60
        return out
    if config_type == ORBIS_CAMERA_CONFIG_TYPE5:
        if device_index == 0:
            out.format.formatLevel0 <- ORBIS_CAMERA_FORMAT_YUV422
        else:
            out.format.formatLevel0 <- ORBIS_CAMERA_FORMAT_RAW16
        out.format.formatLevel1 <- ORBIS_CAMERA_SCALE_FORMAT_YUV422
        out.format.formatLevel2 <- ORBIS_CAMERA_SCALE_FORMAT_YUV422
        out.format.formatLevel3 <- ORBIS_CAMERA_SCALE_FORMAT_YUV422
        out.framerate <- ORBIS_CAMERA_FRAMERATE_60
        return out
    return out

def Camera_DebugResetState() -> void:
    camera_backend_close()
    g_camera_library_opened <- false
    g_camera_firmware_version <- 0
    g_camera_handles <- 0
    g_camera_backend_connected <- false
    g_camera_real_backend_enabled <- false
    g_camera_started <- false
    g_camera_frame_ready <- false
    g_camera_selected_device_index <- 0
    camera_reset_defaults()

def Camera_DebugSetBackendConnected(connected: bool) -> void:
    g_camera_backend_connected <- connected

def Camera_DebugSetFrameReady(ready: bool) -> void:
    g_camera_frame_ready <- ready

def Camera_DebugSetRealBackendEnabled(enabled: bool) -> void:
    g_camera_real_backend_enabled <- enabled

