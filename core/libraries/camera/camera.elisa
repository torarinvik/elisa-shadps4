def sceCameraGetWhiteBalance(handle: int, channel: int, white_balance: mutable OrbisCameraWhiteBalance&?, option: void&?) -> int:
    if handle < 1 or not camera_channel_valid_get(channel) or white_balance == null or option != null:
        return ORBIS_CAMERA_ERROR_PARAM
    if not g_camera_library_opened:
        return ORBIS_CAMERA_ERROR_NOT_OPEN
    wb: mutable OrbisCameraWhiteBalance& = white_balance
    wb.whiteBalanceControl <- 0
    wb.gainRed <- 768
    wb.gainBlue <- 768
    wb.gainGreen <- 512
    return ORBIS_OK

def sceCameraInitializeRegistryCalibData() -> int:
    if not g_camera_library_opened:
        return ORBIS_CAMERA_ERROR_NOT_INIT
    return ORBIS_OK

def sceCameraIsAttached(index: int) -> int:
    if index != 0:
        return ORBIS_CAMERA_ERROR_PARAM
    return 1 if camera_backend_is_attached() else 0

def sceCameraIsConfigChangeDone() -> int:
    return ORBIS_OK

def sceCameraIsValidFrameData(handle: int, frame_data: OrbisCameraFrameData&?) -> int:
    if handle < 1 or frame_data == null or frame_data.ref[OrbisCameraFrameData&].sizeThis > 584:
        return ORBIS_CAMERA_ERROR_PARAM
    if not g_camera_library_opened:
        return ORBIS_CAMERA_ERROR_NOT_OPEN
    return 1

def sceCameraOpen(user_id: int, type_: int, index: int, param: OrbisCameraOpenParameter&?) -> int:
    _ = param
    if user_id != ORBIS_USER_SERVICE_USER_ID_SYSTEM or type_ != 0 or index != 0:
        return ORBIS_CAMERA_ERROR_PARAM
    g_camera_library_opened <- true
    g_camera_handles <- g_camera_handles + 1
    return g_camera_handles

def sceCameraOpenByModuleId() -> int:
    return ORBIS_OK

def sceCameraRemoveAppModuleFocus() -> int:
    return ORBIS_OK

def sceCameraSetAppModuleFocus() -> int:
    return ORBIS_OK

def sceCameraSetAttribute(handle: int, attribute: OrbisCameraAttribute&?) -> int:
    if handle < 1 or attribute == null:
        return ORBIS_CAMERA_ERROR_PARAM
    attr: OrbisCameraAttribute& = attribute
    if attr.sizeThis != size_of(OrbisCameraAttribute).u32() or not camera_channel_valid_set(attr.channel):
        return ORBIS_CAMERA_ERROR_PARAM
    if not g_camera_library_opened:
        return ORBIS_CAMERA_ERROR_NOT_OPEN
    return ORBIS_CAMERA_ERROR_NOT_CONNECTED

def sceCameraSetAttributeInternal() -> int:
    return ORBIS_OK

def sceCameraSetAutoExposureGain(handle: int, channel: int, enable: u32, option: OrbisCameraAutoExposureGainTarget&?) -> int:
    _ = enable
    if handle < 1 or not camera_channel_valid_set(channel):
        return ORBIS_CAMERA_ERROR_PARAM
    if option != null:
        opt: OrbisCameraAutoExposureGainTarget& = option
        if g_camera_firmware_version < ORBIS_CAMERA_SDK_FW_30 or opt.sizeThis != size_of(OrbisCameraAutoExposureGainTarget).u32():
            return ORBIS_CAMERA_ERROR_PARAM
        if (opt.target & 1) == 1 or opt.target > ORBIS_CAMERA_ATTRIBUTE_AECAGC_TARGET_2_0:
            return ORBIS_CAMERA_ERROR_PARAM
    if not g_camera_library_opened:
        return ORBIS_CAMERA_ERROR_NOT_OPEN
    return ORBIS_CAMERA_ERROR_NOT_CONNECTED

def sceCameraSetAutoWhiteBalance(handle: int, channel: int, enable: u32, option: void&?) -> int:
    _ = enable
    if handle < 1 or not camera_channel_valid_set(channel) or option != null:
        return ORBIS_CAMERA_ERROR_PARAM
    if not g_camera_library_opened:
        return ORBIS_CAMERA_ERROR_NOT_OPEN
    return ORBIS_CAMERA_ERROR_NOT_CONNECTED

def sceCameraSetCalibData() -> int:
    return ORBIS_OK

def sceCameraSetConfig(handle: int, config: mutable OrbisCameraConfig&?) -> int:
    if handle < 1 or config == null:
        return ORBIS_CAMERA_ERROR_PARAM
    cfg: mutable OrbisCameraConfig& = config
    if cfg.sizeThis != size_of(OrbisCameraConfig).u32():
        return ORBIS_CAMERA_ERROR_PARAM
    if not g_camera_library_opened:
        return ORBIS_CAMERA_ERROR_NOT_OPEN
    if cfg.configType >= ORBIS_CAMERA_CONFIG_TYPE1 and cfg.configType <= ORBIS_CAMERA_CONFIG_TYPE4:
        g_camera_output_config0 <- camera_make_config_type(cfg.configType, 0)
        g_camera_output_config1 <- camera_make_config_type(cfg.configType, 1)
        return ORBIS_OK
    if cfg.configType == ORBIS_CAMERA_CONFIG_TYPE5:
        if g_camera_firmware_version < ORBIS_CAMERA_SDK_FW_45:
            return ORBIS_CAMERA_ERROR_UNKNOWN_CONFIG
        g_camera_output_config0 <- camera_make_config_type(cfg.configType, 0)
        g_camera_output_config1 <- camera_make_config_type(cfg.configType, 1)
        return ORBIS_OK
    if cfg.configType == ORBIS_CAMERA_CONFIG_EXTENTION:
        g_camera_output_config0 <- cfg.configExtention[0]
        g_camera_output_config1 <- cfg.configExtention[1]
        return ORBIS_OK
    return ORBIS_CAMERA_ERROR_PARAM

def sceCameraSetConfigInternal(handle: int, config: OrbisCameraConfig&?) -> int:
    if handle < 1 or config == null or config.ref[OrbisCameraConfig&].sizeThis != size_of(OrbisCameraConfig).u32():
        return ORBIS_CAMERA_ERROR_PARAM
    if not g_camera_library_opened:
        return ORBIS_CAMERA_ERROR_NOT_OPEN
    return ORBIS_CAMERA_ERROR_NOT_CONNECTED

