def sceCameraGetDeviceConfig(handle: int, config: mutable OrbisCameraConfig&) -> int:
    if handle < 1 or config.sizeThis != size_of(OrbisCameraConfig).u32():
        return ORBIS_CAMERA_ERROR_PARAM
