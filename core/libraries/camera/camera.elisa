# @port core/libraries/camera/camera.cpp::sceCameraStart sha256=df31dcb900209ed5 oracle@a3773841
def sceCameraStart(handle: int, param: OrbisCameraStartParameter&?) -> int:
    if handle < 1 or param == null:
        return ORBIS_CAMERA_ERROR_PARAM
    p: OrbisCameraStartParameter& = param
    if p.sizeThis != size_of(OrbisCameraStartParameter).u32():
        return ORBIS_CAMERA_ERROR_PARAM
    if not g_camera_library_opened:
        return ORBIS_CAMERA_ERROR_NOT_OPEN
    if g_camera_firmware_version >= 0x02500000 and (p.formatLevel[0] >= 0xf or p.formatLevel[1] >= 0xf or (p.formatLevel[0] | p.formatLevel[1]) == 0):
        return ORBIS_CAMERA_ERROR_FORMAT_UNKNOWN
    if g_camera_backend_connected:
        g_camera_started <- true
        g_camera_frame_ready <- false
        return ORBIS_OK
    if not g_camera_real_backend_enabled:
        return ORBIS_CAMERA_ERROR_NOT_CONNECTED
    return camera_backend_open_real()

# @port core/libraries/camera/camera.cpp::sceCameraStartByHandle sha256=a58e50d5e97e14a0 oracle@a3773841
def sceCameraStartByHandle(handle: int, param: OrbisCameraStartParameter&?) -> int:
    if handle < 1 or param == null or param.ref[OrbisCameraStartParameter&].sizeThis != size_of(OrbisCameraStartParameter).u32():
        return ORBIS_CAMERA_ERROR_PARAM
    if not g_camera_library_opened:
        return ORBIS_CAMERA_ERROR_NOT_OPEN
    return ORBIS_OK

