# @port core/libraries/camera/camera.cpp::sceCameraGetCalibrationData sha256=992760779873a0c4 oracle@a3773841
def sceCameraGetCalibrationData(param: OrbisCameraGetCalibrationDataParameter&?, calibration_data: mutable OrbisCameraCalibrationData&?) -> int:
    _ = calibration_data
    if param == null:
        return ORBIS_CAMERA_ERROR_PARAM
    p: OrbisCameraGetCalibrationDataParameter& = param
    if p.size != size_of(OrbisCameraGetCalibrationDataParameter).u32() or p.format_type != 0 or p.function_type > 1:
        return ORBIS_CAMERA_ERROR_PARAM
    return ORBIS_CAMERA_ERROR_NOT_CONNECTED

# @port core/libraries/camera/camera.cpp::sceCameraGetConfig sha256=b914e70d98717735 oracle@a3773841
def sceCameraGetConfig(handle: int, config: mutable OrbisCameraConfig&?) -> int:
    if handle < 1 or config == null:
        return ORBIS_CAMERA_ERROR_PARAM
    cfg: mutable OrbisCameraConfig& = config
    if cfg.sizeThis != size_of(OrbisCameraConfig).u32():
        return ORBIS_CAMERA_ERROR_PARAM
    if not g_camera_library_opened:
        return ORBIS_CAMERA_ERROR_NOT_OPEN
    cfg.configType <- ORBIS_CAMERA_CONFIG_TYPE1
    cfg.sizeThis <- 0
    cfg.configExtention[0] <- camera_make_default_extension()
    cfg.configExtention[1] <- camera_make_default_extension()
    return ORBIS_OK

# @port core/libraries/camera/camera.cpp::sceCameraGetContrast sha256=b87c56f31e683a65 oracle@a3773841
def sceCameraGetContrast(handle: int, channel: int, contrast: mutable u32&, option: void&?) -> int:
    if handle < 1 or not camera_channel_valid_get(channel) or option != null:
        return ORBIS_CAMERA_ERROR_PARAM
    if not g_camera_library_opened:
        return ORBIS_CAMERA_ERROR_NOT_OPEN
    contrast <- 32.u32()
    return ORBIS_OK

