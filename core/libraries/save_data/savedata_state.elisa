#
# SaveData library lifecycle state. Deliberately dependency-free (no sys_fs / PSF):
# this is the `g_initialized` guard that every sceSaveData* entry point consults,
# and it is included by both the entry-point layer (savedata.elisa) and the
# host-backed mount core (save_mount.elisa). Keeping it separate means the full
# emulator boot can pull in the entry points without dragging the POSIX syscall
# externs of common/sys_fs.elisa into the link (which would clash with the kernel
# file_system.elisa declarations).

global mutable g_savedata_initialized: bool = false

def savedata_core_initialize() -> u32:
    g_savedata_initialized <- true
    return 0

def savedata_core_is_initialized() -> bool:
    return g_savedata_initialized

# savedata_core_set_terminated clears only the init guard. The host-backed mount
# core (save_mount.elisa) layers mount-table teardown on top via savedata_core_terminate().
def savedata_core_set_terminated() -> void:
    g_savedata_initialized <- false
