include "../../../../compiler/runtime/elisacore_std/elisacore_runtime.elisa"
include "./sysmodule_native.elisa"

@test
def sysmodule_native_bridge_forwards_state_and_errors() -> void:
    can Abort.Panic:
        handle: mutable s32 = 0
        result: mutable s32 = -1

        assert sceSysmoduleIsLoaded(0) == ORBIS_SYSMODULE_INVALID_ID
        assert sceSysmoduleIsLoaded(7) == ORBIS_SYSMODULE_NOT_LOADED
        assert sceSysmoduleGetModuleHandleInternal(7, (&handle).cast[mutable s32&]) == ORBIS_SYSMODULE_NOT_LOADED

        assert sceSysmoduleLoadModule(7) == 0
        assert sceSysmoduleIsLoaded(7) == 0
        assert sceSysmoduleGetModuleHandleInternal(7, (&handle).cast[mutable s32&]) == 0
        assert handle == 0x2200

        assert sceSysmoduleLoadModuleInternalWithArg(8, 0, null, 1, (&result).cast[mutable s32&]) == ORBIS_SYSMODULE_INVALID_ID
        assert sceSysmoduleLoadModuleInternalWithArg(8, 0, null, 0, (&result).cast[mutable s32&]) == 0
        assert result == 0
        assert sceSysmoduleIsLoadedInternal(8) == 0

        assert sceSysmoduleUnloadModule(7) == ORBIS_SYSMODULE_NOT_LOADED
        assert sceSysmoduleLoadModule(7) == 0
        assert sceSysmoduleUnloadModule(7) == 0
        assert sceSysmoduleUnloadModule(7) == ORBIS_SYSMODULE_NOT_LOADED

        assert sceSysmoduleGetModuleInfoForUnwind(0, 0, null) == 0
        assert sceSysmoduleIsCalledFromSysModule() == 0
        assert sceSysmoduleIsCameraPreloaded() == 0
        assert sceSysmoduleLoadModuleByNameInternal() == 0
        assert sceSysmoduleMapLibcForLibkernel() == 0
        assert sceSysmodulePreloadModuleForLibkernel() == 0
        assert sceSysmoduleUnloadModuleByNameInternal() == 0
        assert sceSysmoduleUnloadModuleInternal() == 0
        assert sceSysmoduleUnloadModuleInternalWithArg() == 0
