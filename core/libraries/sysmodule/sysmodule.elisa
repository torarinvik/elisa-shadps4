include "../error_codes.elisa"
include "./sysmodule_error.elisa"

type OrbisSysModule = u16
type OrbisSysModuleInternal = u32

global mutable g_sysmodule_slot_ids: u32[256] = zeroed
global mutable g_sysmodule_slot_loads: int[256] = zeroed
global mutable g_sysmodule_slot_handles: int[256] = zeroed
global mutable g_sysmodule_next_handle: int = 0x1000

def sysmodule_invalid_id_internal(id: OrbisSysModuleInternal) -> bool:
    return id == 0 or id == 0x80000000

def sysmodule_find_slot(id: u32) -> int:
    i: mutable int = 0
    while i < 256:
        if g_sysmodule_slot_ids[i] == id:
            return i
        i <- i + 1
    return -1

def sysmodule_find_or_create_slot(id: u32) -> int:
    existing: int = sysmodule_find_slot(id)
    if existing >= 0:
        return existing
    i: mutable int = 0
    while i < 256:
        if g_sysmodule_slot_ids[i] == 0:
            g_sysmodule_slot_ids[i] <- id
            g_sysmodule_slot_loads[i] <- 0
            g_sysmodule_slot_handles[i] <- 0
            return i
        i <- i + 1
    return -1

# @port core/libraries/sysmodule/sysmodule.cpp::sceSysmoduleGetModuleHandleInternal sha256=68daba924ad4a905 oracle@a3773841
def sceSysmoduleGetModuleHandleInternal(id: OrbisSysModuleInternal, handle: mutable int&?) -> int:
    _ = handle
    if sysmodule_invalid_id_internal(id):
        return ORBIS_SYSMODULE_INVALID_ID
    slot: int = sysmodule_find_slot(id)
    if slot < 0 or g_sysmodule_slot_loads[slot] <= 0:
        return ORBIS_SYSMODULE_NOT_LOADED
    return ORBIS_OK

# @port core/libraries/sysmodule/sysmodule.cpp::sceSysmoduleGetModuleInfoForUnwind sha256=d969b7d4fa994b42 oracle@a3773841
def sceSysmoduleGetModuleInfoForUnwind(addr: u64, flags: int, info: mutable void&?) -> int:
    _ = addr
    _ = flags
    _ = info
    return ORBIS_OK

# @port core/libraries/sysmodule/sysmodule.cpp::sceSysmoduleIsCalledFromSysModule sha256=43e5ee45dc082063 oracle@a3773841
def sceSysmoduleIsCalledFromSysModule() -> int:
    return ORBIS_OK

# @port core/libraries/sysmodule/sysmodule.cpp::sceSysmoduleIsCameraPreloaded sha256=42fa39f2a8be18c7 oracle@a3773841
def sceSysmoduleIsCameraPreloaded() -> int:
    return ORBIS_OK

# @port core/libraries/sysmodule/sysmodule.cpp::sceSysmoduleIsLoaded sha256=3de25e00216a51cc oracle@a3773841
def sceSysmoduleIsLoaded(id: OrbisSysModule) -> int:
    if id == 0:
        return ORBIS_SYSMODULE_INVALID_ID
    slot: int = sysmodule_find_slot(id.u32())
    if slot < 0 or g_sysmodule_slot_loads[slot] <= 0:
        return ORBIS_SYSMODULE_NOT_LOADED
    return ORBIS_OK

# @port core/libraries/sysmodule/sysmodule.cpp::sceSysmoduleIsLoadedInternal sha256=abb70ac759dccbed oracle@a3773841
def sceSysmoduleIsLoadedInternal(id: OrbisSysModuleInternal) -> int:
    if sysmodule_invalid_id_internal(id):
        return ORBIS_SYSMODULE_INVALID_ID
    slot: int = sysmodule_find_slot(id)
    if slot < 0 or g_sysmodule_slot_loads[slot] <= 0:
        return ORBIS_SYSMODULE_NOT_LOADED
    return ORBIS_OK

# @port core/libraries/sysmodule/sysmodule.cpp::sceSysmoduleLoadModule sha256=2f03eab16008f140 oracle@a3773841
def sceSysmoduleLoadModule(id: OrbisSysModule) -> int:
    if id == 0:
        return ORBIS_SYSMODULE_INVALID_ID
    slot: int = sysmodule_find_or_create_slot(id.u32())
    if slot < 0:
        return ORBIS_SYSMODULE_LOCK_FAILED
    if g_sysmodule_slot_loads[slot] == 0:
        g_sysmodule_slot_handles[slot] <- g_sysmodule_next_handle
        g_sysmodule_next_handle <- g_sysmodule_next_handle + 1
    g_sysmodule_slot_loads[slot] <- g_sysmodule_slot_loads[slot] + 1
    return ORBIS_OK

# @port core/libraries/sysmodule/sysmodule.cpp::sceSysmoduleLoadModuleByNameInternal sha256=dfb72cae635ac4ef oracle@a3773841
def sceSysmoduleLoadModuleByNameInternal() -> int:
    return ORBIS_OK

# @port core/libraries/sysmodule/sysmodule.cpp::sceSysmoduleLoadModuleInternal sha256=170461244dbf10cd oracle@a3773841
def sceSysmoduleLoadModuleInternal(id: OrbisSysModuleInternal) -> int:
    if sysmodule_invalid_id_internal(id):
        return ORBIS_SYSMODULE_INVALID_ID
    slot: int = sysmodule_find_or_create_slot(id)
    if slot < 0:
        return ORBIS_SYSMODULE_LOCK_FAILED
    if g_sysmodule_slot_loads[slot] == 0:
        g_sysmodule_slot_handles[slot] <- g_sysmodule_next_handle
        g_sysmodule_next_handle <- g_sysmodule_next_handle + 1
    g_sysmodule_slot_loads[slot] <- g_sysmodule_slot_loads[slot] + 1
    return ORBIS_OK

# @port core/libraries/sysmodule/sysmodule.cpp::sceSysmoduleLoadModuleInternalWithArg sha256=cff52531ea575105 oracle@a3773841
def sceSysmoduleLoadModuleInternalWithArg(id: OrbisSysModuleInternal, argc: int, argv: void&?, unk: u64, res_out: mutable int&?) -> int:
    _ = argc
    _ = argv
    _ = res_out
    if sysmodule_invalid_id_internal(id):
        return ORBIS_SYSMODULE_INVALID_ID
    if unk != 0:
        return ORBIS_SYSMODULE_INVALID_ID
    result: int = sceSysmoduleLoadModuleInternal(id)
    if result != ORBIS_OK:
        return result
    _ = res_out
    return ORBIS_OK

