include "../../error_codes.elisa"
include "../../../file_format/binary.elisa"

const SKY_BLOCK_COUNT: usize = 0x40
const SKY_BLOCK_SIZE: usize = 0x10
const SKY_FIGURE_SIZE: usize = SKY_BLOCK_COUNT * SKY_BLOCK_SIZE
const MAX_SKYLANDERS: usize = 16

struct Skylander:
    present: mutable bool
    status: mutable u8
    queued_a: mutable u8
    queued_b: mutable u8
    has_queued_a: mutable bool
    has_queued_b: mutable bool
    file_path: mutable static u8&
    data: mutable u8[SKY_FIGURE_SIZE]
    last_id: mutable u32

struct SkylanderPortalState:
    activated: mutable bool
    interrupt_counter: mutable u8
    right_r: mutable u8
    right_g: mutable u8
    right_b: mutable u8
    left_r: mutable u8
    left_g: mutable u8
    left_b: mutable u8
    trap_r: mutable u8
    trap_g: mutable u8
    trap_b: mutable u8
    skylanders: mutable Skylander[MAX_SKYLANDERS]

struct SkylanderQueryQueue:
    responses: mutable u8[64 * 32]
    read_index: mutable usize
    write_index: mutable usize

global mutable g_sky_state: SkylanderPortalState = zeroed
global mutable g_sky_queue: SkylanderQueryQueue = zeroed
global mutable g_sky_init: bool = false

def Skylander_InitIfNeeded() -> void:
    if g_sky_init:
        return
    g_sky_state.activated <- true
    i: mutable usize = 0
    while i < MAX_SKYLANDERS:
        g_sky_state.skylanders[i].present <- false
        g_sky_state.skylanders[i].status <- 0u8
        g_sky_state.skylanders[i].has_queued_a <- false
        g_sky_state.skylanders[i].has_queued_b <- false
        g_sky_state.skylanders[i].last_id <- 0u32
        i <- i + 1
    g_sky_queue.read_index <- 0
    g_sky_queue.write_index <- 0
    g_sky_init <- true

def Skylander_QueuePush(packet: u8&) -> void:
    slot: usize = g_sky_queue.write_index % 64
    base: usize = slot * 32
    i: mutable usize = 0
    while i < 32:
        g_sky_queue.responses[base + i] <- packet[i]
        i <- i + 1
    g_sky_queue.write_index <- g_sky_queue.write_index + 1
    if g_sky_queue.write_index - g_sky_queue.read_index > 64:
        g_sky_queue.read_index <- g_sky_queue.write_index - 64

def Skylander_QueuePop(out: mutable u8&) -> bool:
    if g_sky_queue.read_index >= g_sky_queue.write_index:
        return false
    slot: usize = g_sky_queue.read_index % 64
    base: usize = slot * 32
    i: mutable usize = 0
    while i < 32:
        out[i] <- g_sky_queue.responses[base + i]
        i <- i + 1
    g_sky_queue.read_index <- g_sky_queue.read_index + 1
    return true

def Skylander_SetLEDs(side: u8, r: u8, g: u8, b: u8) -> void:
    if side == 0u8:
        g_sky_state.right_r <- r
        g_sky_state.right_g <- g
        g_sky_state.right_b <- b
    elif side == 1u8:
        g_sky_state.right_r <- r
        g_sky_state.right_g <- g
        g_sky_state.right_b <- b
        g_sky_state.left_r <- r
        g_sky_state.left_g <- g
        g_sky_state.left_b <- b
    elif side == 2u8:
        g_sky_state.left_r <- r
        g_sky_state.left_g <- g
        g_sky_state.left_b <- b
    elif side == 3u8:
        g_sky_state.trap_r <- r
        g_sky_state.trap_g <- g
        g_sky_state.trap_b <- b

def Skylander_Activate() -> void:
    if g_sky_state.activated:
        return
    i: mutable usize = 0
    while i < MAX_SKYLANDERS:
        if g_sky_state.skylanders[i].status & 1u8 != 0u8:
            g_sky_state.skylanders[i].queued_a <- 3u8
            g_sky_state.skylanders[i].queued_b <- 1u8
            g_sky_state.skylanders[i].has_queued_a <- true
            g_sky_state.skylanders[i].has_queued_b <- true
        i <- i + 1
    g_sky_state.activated <- true

def Skylander_Deactivate() -> void:
    if not g_sky_state.activated:
        return
    i: mutable usize = 0
    while i < MAX_SKYLANDERS:
        if g_sky_state.skylanders[i].has_queued_a:
            g_sky_state.skylanders[i].status <- g_sky_state.skylanders[i].queued_a
            g_sky_state.skylanders[i].has_queued_a <- false
            g_sky_state.skylanders[i].has_queued_b <- false
        g_sky_state.skylanders[i].status <- g_sky_state.skylanders[i].status & 1u8
        i <- i + 1
    g_sky_state.activated <- false

def Skylander_GetStatusPacket(out: mutable u8&) -> void:
    status: mutable u32 = 0u32
    active: mutable u8 = 0u8
    if g_sky_state.activated:
        active <- 1u8
    i: mutable int = 15
    while i >= 0:
        s: mutable Skylander& = g_sky_state.skylanders[i.usize()].ref[mutable Skylander&]
        if s.has_queued_a:
            s.status <- s.queued_a
            s.has_queued_a <- s.has_queued_b
            s.queued_a <- s.queued_b
            s.has_queued_b <- false
        status <- (status << 2u32) | s.status.u32()
        i <- i - 1
    j: mutable usize = 0
    while j < 32:
        out[j] <- 0u8
        j <- j + 1
    out[0] <- 0x53u8
    out[1] <- (status & 0xffu32).u8()
    out[2] <- ((status >> 8u32) & 0xffu32).u8()
    out[3] <- ((status >> 16u32) & 0xffu32).u8()
    out[4] <- ((status >> 24u32) & 0xffu32).u8()
    out[5] <- g_sky_state.interrupt_counter
    out[6] <- active
    g_sky_state.interrupt_counter <- (g_sky_state.interrupt_counter + 1u8).u8()

def Skylander_QueryBlock(sky_num: u8, block: u8, out: mutable u8&) -> void:
    out[0] <- 'Q'.u8()
    out[1] <- 1u8
    out[2] <- block
    if sky_num >= MAX_SKYLANDERS.u8() or block >= 64u8:
        return
    s: mutable Skylander& = g_sky_state.skylanders[sky_num.usize()].ref[mutable Skylander&]
    if s.status & 1u8 == 0u8:
        return
    out[1] <- (0x10u8 | sky_num)
    base: usize = block.usize() * 16
    i: mutable usize = 0
    while i < 16:
        out[3 + i] <- s.data[base + i]
        i <- i + 1

def Skylander_WriteBlock(sky_num: u8, block: u8, in_data: u8&, out: mutable u8&) -> void:
    out[0] <- 'W'.u8()
    out[1] <- 1u8
    out[2] <- block
    if sky_num >= MAX_SKYLANDERS.u8() or block >= 64u8:
        return
    s: mutable Skylander& = g_sky_state.skylanders[sky_num.usize()].ref[mutable Skylander&]
    if s.status & 1u8 == 0u8:
        return
    out[1] <- (0x10u8 | sky_num)
    base: usize = block.usize() * 16
    i: mutable usize = 0
    while i < 16:
        s.data[base + i] <- in_data[i]
        i <- i + 1
    saved: mutable darray[u8] = []
    j: mutable usize = 0
    while j < SKY_FIGURE_SIZE:
        can Memory.Allocate, Abort.Panic:
            owner: mutable Arena& = scratch_arena.ref[mutable Arena&]
            in owner:
                saved.push(s.data[j])
        j <- j + 1
    if runtime_strlen(s.file_path) != 0:
        _ = ff_file_write_all(s.file_path, saved)

def UsbdSkylanderEmu_ControlTransfer(request: u8&, wLength: u16) -> int:
    Skylander_InitIfNeeded()
    if wLength == 0u16:
        return 0
    cmd: u8 = request[0]
    control_response: mutable u8[32] = zeroed
    interrupt_response: mutable u8[32] = zeroed
    expected: mutable int = 0
    if cmd == 'A'.u8():
        if wLength == 2u16:
            control_response[0] <- request[0]
            control_response[1] <- request[1]
            interrupt_response[0] <- 0x41u8
            interrupt_response[1] <- request[1]
            interrupt_response[2] <- 0xffu8
            interrupt_response[3] <- 0x77u8
            Skylander_QueuePush(interrupt_response[0])
            if request[1] == 0u8:
                Skylander_Deactivate()
            else:
                Skylander_Activate()
            expected <- 10
    elif cmd == 'C'.u8():
        if wLength == 4u16:
            Skylander_SetLEDs(1u8, request[1], request[2], request[3])
            expected <- 12
    elif cmd == 'J'.u8():
        if wLength == 7u16:
            side: mutable u8 = request[1]
            Skylander_SetLEDs(side, request[2], request[3], request[4])
            interrupt_response[0] <- request[0]
            Skylander_QueuePush(interrupt_response[0])
            expected <- 15
    elif cmd == 'L'.u8():
        if wLength == 5u16:
            side: mutable u8 = request[1]
            if side == 2u8:
                side <- 4u8
            Skylander_SetLEDs(side, request[2], request[3], request[4])
            expected <- 13
    elif cmd == 'M'.u8():
        if wLength == 2u16:
            interrupt_response[0] <- request[0]
            interrupt_response[1] <- request[1]
            interrupt_response[2] <- 0u8
            interrupt_response[3] <- 0x19u8
            Skylander_QueuePush(interrupt_response[0])
            expected <- 10
    elif cmd == 'Q'.u8():
        if wLength == 3u16:
            sky_num: u8 = request[1] & 0x0fu8
            block: u8 = request[2]
            Skylander_QueryBlock(sky_num, block, interrupt_response[0])
            Skylander_QueuePush(interrupt_response[0])
            expected <- 11
    elif cmd == 'R'.u8():
        if wLength == 2u16:
            interrupt_response[0] <- 0x52u8
            interrupt_response[1] <- 0x02u8
            interrupt_response[2] <- 0x1bu8
            Skylander_QueuePush(interrupt_response[0])
            expected <- 10
    elif cmd == 'S'.u8():
        if wLength == 1u16:
            expected <- 9
    elif cmd == 'V'.u8():
        if wLength == 4u16:
            expected <- 12
    elif cmd == 'W'.u8():
        if wLength == 19u16:
            sky_num: u8 = request[1] & 0x0fu8
            block: u8 = request[2]
            Skylander_WriteBlock(sky_num, block, request[3], interrupt_response[0])
            Skylander_QueuePush(interrupt_response[0])
            expected <- 27
    _ = control_response
    return expected

def UsbdSkylanderEmu_InterruptIn(out: mutable u8&) -> int:
    Skylander_InitIfNeeded()
    if Skylander_QueuePop(out):
        return 32
    Skylander_GetStatusPacket(out)
    return 32

def UsbdSkylanderEmu_Init() -> int:
    Skylander_InitIfNeeded()
    return ORBIS_OK

def UsbdSkylanderEmu_LoadFigure(path: static u8&, slot: u8) -> void:
    Skylander_InitIfNeeded()
    if slot >= MAX_SKYLANDERS.u8():
        return
    s: mutable Skylander& = g_sky_state.skylanders[slot.usize()].ref[mutable Skylander&]
    s.file_path <- path
    file_data: darray[u8] = ff_file_read_all(path)
    if file_data.count >= SKY_FIGURE_SIZE:
        i: mutable usize = 0
        while i < SKY_FIGURE_SIZE:
            s.data[i] <- file_data[i]
            i <- i + 1
    else:
        i: mutable usize = 0
        while i < SKY_FIGURE_SIZE:
            s.data[i] <- 0u8
            i <- i + 1
    s.present <- true
    s.status <- 3u8
    s.queued_a <- 3u8
    s.queued_b <- 1u8
    s.has_queued_a <- true
    s.has_queued_b <- true

def UsbdSkylanderEmu_RemoveFigure(slot: u8) -> void:
    Skylander_InitIfNeeded()
    if slot >= MAX_SKYLANDERS.u8():
        return
    s: mutable Skylander& = g_sky_state.skylanders[slot.usize()].ref[mutable Skylander&]
    if s.status & 1u8 == 0u8:
        return
    saved: mutable darray[u8] = []
    j: mutable usize = 0
    while j < SKY_FIGURE_SIZE:
        can Memory.Allocate, Abort.Panic:
            owner: mutable Arena& = scratch_arena.ref[mutable Arena&]
            in owner:
                saved.push(s.data[j])
        j <- j + 1
    if runtime_strlen(s.file_path) != 0:
        _ = ff_file_write_all(s.file_path, saved)
    s.status <- 2u8
    s.queued_a <- 2u8
    s.queued_b <- 0u8
    s.has_queued_a <- true
    s.has_queued_b <- true
