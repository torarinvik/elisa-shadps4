def sceUsbdControlTransferGetSetup(transfer: void&?) -> void&?: return transfer
def sceUsbdFillControlSetup(buf: mutable u8&?, bmRequestType: u8, bRequest: u8, wValue: u16, wIndex: u16, wLength: u16) -> void: _ = buf; _ = bmRequestType; _ = bRequest; _ = wValue; _ = wIndex; _ = wLength; return
