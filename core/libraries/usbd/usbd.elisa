def sceUsbdGetConfigDescriptorByValue(device: void&?, bConfigurationValue: u8, config: mutable void&?&) -> s32: return usbd_libusb_to_orbis_error(libusb_get_config_descriptor_by_value(device, bConfigurationValue, config))
