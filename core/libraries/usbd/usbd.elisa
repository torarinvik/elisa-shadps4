def sceUsbdReleaseInterface(dev_handle: void&?, interface_number: s32) -> s32: _ = dev_handle; _ = interface_number; return ORBIS_OK
def sceUsbdOpenDeviceWithVidPid(vendor_id: u16, product_id: u16) -> void&?: _ = vendor_id; _ = product_id; return null
