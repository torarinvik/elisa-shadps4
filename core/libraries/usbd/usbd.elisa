global mutable g_libusb_context: mutable void&? = null
global mutable g_has_removed_driver: bool = false
const USBD_BACKEND_REAL: int = 0
const USBD_BACKEND_SKYLANDER: int = 1
const USBD_BACKEND_INFINITY: int = 2
const USBD_BACKEND_DIMENSIONS: int = 3
global mutable g_usbd_backend_mode: int = USBD_BACKEND_REAL

def usbd_libusb_to_orbis_error(retVal: int) -> s32:
    if retVal == -99:
        return 0x802400ff
    if retVal < 0:
        return 0x80240000 - retVal
    return retVal.s32()

# @port core/libraries/usbd/usbd.cpp::sceUsbdInit sha256=b40a8f263ecefa07 oracle@a3773841
def sceUsbdInit() -> s32:
    _ = UsbdSkylanderEmu_Init()
    _ = UsbdInfinityEmu_Init()
    _ = UsbdDimensionsEmu_Init()
    return usbd_libusb_to_orbis_error(libusb_init(g_libusb_context.ref[mutable void&?&]))

# @port core/libraries/usbd/usbd.cpp::sceUsbdExit sha256=1ca7967bcdbd41ae oracle@a3773841
def sceUsbdExit() -> void:
    libusb_exit(g_libusb_context)

# @port core/libraries/usbd/usbd.cpp::sceUsbdGetDeviceList sha256=d7fc24081fcc62bb oracle@a3773841
def sceUsbdGetDeviceList(list: mutable void&?&) -> s64:
    count: s64 = libusb_get_device_list(g_libusb_context, list)
    if count < 0:
        return usbd_libusb_to_orbis_error(count.int()).s64()
    return count

# @port core/libraries/usbd/usbd.cpp::sceUsbdFreeDeviceList sha256=e77cf64f7cb81e34 oracle@a3773841
def sceUsbdFreeDeviceList(list: void&?, unref_devices: s32) -> void: libusb_free_device_list(list, unref_devices.int())
