def sceUsbdCancelTransfer(transfer: void&?) -> s32: _ = transfer; return ORBIS_OK
def sceUsbdFreeTransfer(transfer: void&?) -> void: _ = transfer; return
def sceUsbdFillControlTransfer(transfer: void&?, dev_handle: void&?, buffer: mutable u8&?, callback: void&?, user_data: void&?, timeout: u32) -> void: _ = transfer; _ = dev_handle; _ = buffer; _ = callback; _ = user_data; _ = timeout; return
def sceUsbdFillBulkTransfer(transfer: void&?, dev_handle: void&?, endpoint: u8, buffer: mutable u8&?, length: s32, callback: void&?, user_data: void&?, timeout: u32) -> void: _ = transfer; _ = dev_handle; _ = endpoint; _ = buffer; _ = length; _ = callback; _ = user_data; _ = timeout; return
def sceUsbdFillInterruptTransfer(transfer: void&?, dev_handle: void&?, endpoint: u8, buffer: mutable u8&?, length: s32, callback: void&?, user_data: void&?, timeout: u32) -> void: _ = transfer; _ = dev_handle; _ = endpoint; _ = buffer; _ = length; _ = callback; _ = user_data; _ = timeout; return
