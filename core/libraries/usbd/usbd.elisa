def Usbd_HookLoadFigure(path: static u8&, portal: u8, slot: u8) -> void:
    if g_usbd_backend_mode == USBD_BACKEND_SKYLANDER:
        UsbdSkylanderEmu_LoadFigure(path, slot)
    elif g_usbd_backend_mode == USBD_BACKEND_INFINITY:
        UsbdInfinityEmu_LoadFigure(path, slot)
    elif g_usbd_backend_mode == USBD_BACKEND_DIMENSIONS:
        UsbdDimensionsEmu_LoadFigure(path, portal, slot)

def Usbd_HookRemoveFigure(portal: u8, slot: u8, temporary: bool) -> void:
    _ = portal
    _ = temporary
    if g_usbd_backend_mode == USBD_BACKEND_SKYLANDER:
        UsbdSkylanderEmu_RemoveFigure(slot)
    elif g_usbd_backend_mode == USBD_BACKEND_INFINITY:
        UsbdInfinityEmu_RemoveFigure(slot)
    elif g_usbd_backend_mode == USBD_BACKEND_DIMENSIONS:
        UsbdDimensionsEmu_RemoveFigure(slot)

def Usbd_HookMoveFigure(from_portal: u8, from_slot: u8, to_portal: u8, to_slot: u8) -> void:
    if g_usbd_backend_mode == USBD_BACKEND_DIMENSIONS:
        UsbdDimensionsEmu_MoveFigure(from_portal, from_slot, to_portal, to_slot)

def Usbd_HookTempRemoveFigure(slot: u8) -> void:
    if g_usbd_backend_mode == USBD_BACKEND_DIMENSIONS:
        UsbdDimensionsEmu_TempRemoveFigure(slot)

def Usbd_HookCancelRemoveFigure(slot: u8) -> void:
    if g_usbd_backend_mode == USBD_BACKEND_DIMENSIONS:
        UsbdDimensionsEmu_CancelRemoveFigure(slot)

def Usbd_RegisterLib(sym: void&?) -> void:
    _ = sym
