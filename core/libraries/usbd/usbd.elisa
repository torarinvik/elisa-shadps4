def sceUsbdFillBulkTransfer(transfer: void&?, dev_handle: void&?, endpoint: u8, buffer: mutable u8&?, length: s32, callback: void&?, user_data: void&?, timeout: u32) -> void: libusb_fill_bulk_transfer(transfer, dev_handle, endpoint, buffer, length, callback, user_data, timeout)
