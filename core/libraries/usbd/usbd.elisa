def sceUsbdBulkTransfer(dev_handle: void&?, endpoint: u8, data: mutable u8&?, length: s32, actual_length: mutable s32&?, timeout: u32) -> s32: _ = dev_handle; _ = endpoint; _ = data; _ = length; if actual_length != null: actual_length <- length; _ = timeout; return ORBIS_OK
def sceUsbdInterruptTransfer(dev_handle: void&?, endpoint: u8, data: mutable u8&?, length: s32, actual_length: mutable s32&?, timeout: u32) -> s32: _ = dev_handle; _ = endpoint; _ = data; _ = length; if actual_length != null: actual_length <- length; _ = timeout; return ORBIS_OK
