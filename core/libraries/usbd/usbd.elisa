def sceUsbdGetMaxIsoPacketSize(device: void&?, endpoint: u8) -> s32: _ = device; _ = endpoint; return ORBIS_OK
def sceUsbdOpen(device: void&?, dev_handle: void&?) -> s32: _ = device; _ = dev_handle; return ORBIS_OK
def sceUsbdClose(dev_handle: void&?) -> void: _ = dev_handle; return
def sceUsbdGetDevice(dev_handle: void&?) -> void&?: return dev_handle
def sceUsbdSetConfiguration(dev_handle: void&?, config: s32) -> s32: _ = dev_handle; _ = config; return ORBIS_OK
