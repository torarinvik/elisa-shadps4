def sceUsbdGetIsoPacketBuffer(transfer: void&?, packet: u32) -> void&?: return libusb_get_iso_packet_buffer(transfer, packet)
# @port core/libraries/usbd/usbd.cpp::sceUsbdControlTransfer sha256=5e2123f621444298 oracle@a3773841
def sceUsbdControlTransfer(dev_handle: void&?, request_type: u8, bRequest: u8, wValue: u16, wIndex: u16, data: mutable u8&?, wLength: s32, timeout: u32) -> s32:
    if g_usbd_backend_mode == USBD_BACKEND_SKYLANDER and data != null:
        if request_type == 0x21u8 and bRequest == 0x09u8:
            return UsbdSkylanderEmu_ControlTransfer(data.cast[u8&], wLength.u16()).s32()
    _ = timeout
    return usbd_libusb_to_orbis_error(libusb_control_transfer(dev_handle, request_type, bRequest, wValue, wIndex, data, wLength.u16(), timeout))
# @port core/libraries/usbd/usbd.cpp::sceUsbdBulkTransfer sha256=546e103b66d0ad0d oracle@a3773841
def sceUsbdBulkTransfer(dev_handle: void&?, endpoint: u8, data: mutable u8&?, length: s32, actual_length: mutable s32&?, timeout: u32) -> s32: return usbd_libusb_to_orbis_error(libusb_bulk_transfer(dev_handle, endpoint, data, length, actual_length, timeout))
# @port core/libraries/usbd/usbd.cpp::sceUsbdInterruptTransfer sha256=76ffa8a8daae4f53 oracle@a3773841
def sceUsbdInterruptTransfer(dev_handle: void&?, endpoint: u8, data: mutable u8&?, length: s32, actual_length: mutable s32&?, timeout: u32) -> s32:
    if data != null:
        if g_usbd_backend_mode == USBD_BACKEND_INFINITY:
            if endpoint == 0x01u8:
                _ = UsbdInfinityEmu_CommandOut(data.cast[u8&])
                if actual_length != null:
                    actual_length[0] <- length
                return ORBIS_OK
            if endpoint == 0x81u8:
                produced: int = UsbdInfinityEmu_InterruptIn(data.cast[mutable u8&])
                if actual_length != null:
                    actual_length[0] <- produced
                return ORBIS_OK
        elif g_usbd_backend_mode == USBD_BACKEND_SKYLANDER:
            if endpoint == 0x81u8:
                produced: int = UsbdSkylanderEmu_InterruptIn(data.cast[mutable u8&])
                if actual_length != null:
                    actual_length[0] <- produced
                return ORBIS_OK
        elif g_usbd_backend_mode == USBD_BACKEND_DIMENSIONS:
            if endpoint == 0x01u8:
                _ = UsbdDimensionsEmu_CommandOut(data.cast[u8&])
                if actual_length != null:
                    actual_length[0] <- length
                return ORBIS_OK
            if endpoint == 0x81u8:
                produced: int = UsbdDimensionsEmu_InterruptIn(data.cast[mutable u8&])
                if actual_length != null:
                    actual_length[0] <- produced
                return ORBIS_OK
    _ = dev_handle
    _ = timeout
    return usbd_libusb_to_orbis_error(libusb_interrupt_transfer(dev_handle, endpoint, data, length, actual_length, timeout))
