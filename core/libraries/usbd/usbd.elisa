def sceUsbdSetConfiguration(dev_handle: void&?, config: s32) -> s32: return usbd_libusb_to_orbis_error(libusb_set_configuration(dev_handle, config.int()))
# @port core/libraries/usbd/usbd.cpp::sceUsbdClaimInterface sha256=5c4bf38643f33a3d oracle@a3773841
def sceUsbdClaimInterface(dev_handle: void&?, interface_number: s32) -> s32:
    if sceUsbdKernelDriverActive(dev_handle, interface_number.int()) > 0:
        _ = sceUsbdDetachKernelDriver(dev_handle, interface_number.int())
    return usbd_libusb_to_orbis_error(libusb_claim_interface(dev_handle, interface_number.int()))
# @port core/libraries/usbd/usbd.cpp::sceUsbdReleaseInterface sha256=d070f384fe41b6d4 oracle@a3773841
def sceUsbdReleaseInterface(dev_handle: void&?, interface_number: s32) -> s32: return usbd_libusb_to_orbis_error(libusb_release_interface(dev_handle, interface_number.int()))
# @port core/libraries/usbd/usbd.cpp::sceUsbdOpenDeviceWithVidPid sha256=e28609ab36ef9300 oracle@a3773841
def sceUsbdOpenDeviceWithVidPid(vendor_id: u16, product_id: u16) -> void&?:
    if vendor_id == 0x1430u16 and product_id == 0x0150u16:
        g_usbd_backend_mode <- USBD_BACKEND_SKYLANDER
    elif vendor_id == 0x0e6fu16 and product_id == 0x0129u16:
        g_usbd_backend_mode <- USBD_BACKEND_INFINITY
    elif vendor_id == 0x0e6fu16 and product_id == 0x0241u16:
        g_usbd_backend_mode <- USBD_BACKEND_DIMENSIONS
    else:
        g_usbd_backend_mode <- USBD_BACKEND_REAL
    return libusb_open_device_with_vid_pid(g_libusb_context, vendor_id, product_id)
# @port core/libraries/usbd/usbd.cpp::sceUsbdSetInterfaceAltSetting sha256=ab3b8426b9a81135 oracle@a3773841
def sceUsbdSetInterfaceAltSetting(dev_handle: void&?, interface_number: int, alternate_setting: int) -> s32: return usbd_libusb_to_orbis_error(libusb_set_interface_alt_setting(dev_handle, interface_number, alternate_setting))
# @port core/libraries/usbd/usbd.cpp::sceUsbdClearHalt sha256=79aa67d49257ced2 oracle@a3773841
def sceUsbdClearHalt(dev_handle: void&?, endpoint: u8) -> s32: return usbd_libusb_to_orbis_error(libusb_clear_halt(dev_handle, endpoint))
# @port core/libraries/usbd/usbd.cpp::sceUsbdResetDevice sha256=78e59b4c74260d5a oracle@a3773841
def sceUsbdResetDevice(dev_handle: void&?) -> s32: return usbd_libusb_to_orbis_error(libusb_reset_device(dev_handle))
def sceUsbdKernelDriverActive(dev_handle: void&?, interface_number: int) -> s32:
    static if PLATFORM_WINDOWS or PLATFORM_DARWIN:
        _ = dev_handle
        _ = interface_number
        if g_has_removed_driver:
            return 0
        return 1
    return usbd_libusb_to_orbis_error(libusb_kernel_driver_active(dev_handle, interface_number))
# @port core/libraries/usbd/usbd.cpp::sceUsbdDetachKernelDriver sha256=e8bf277b2007fa99 oracle@a3773841
def sceUsbdDetachKernelDriver(dev_handle: void&?, interface_number: int) -> s32:
    static if PLATFORM_WINDOWS or PLATFORM_DARWIN:
        _ = dev_handle
        _ = interface_number
        g_has_removed_driver <- true
        return ORBIS_OK
    return usbd_libusb_to_orbis_error(libusb_detach_kernel_driver(dev_handle, interface_number))
# @port core/libraries/usbd/usbd.cpp::sceUsbdAttachKernelDriver sha256=c55bcd2adb8257fd oracle@a3773841
def sceUsbdAttachKernelDriver(dev_handle: void&?, interface_number: int) -> s32:
    static if PLATFORM_WINDOWS or PLATFORM_DARWIN:
        _ = dev_handle
        _ = interface_number
        g_has_removed_driver <- false
        return ORBIS_OK
    return usbd_libusb_to_orbis_error(libusb_attach_kernel_driver(dev_handle, interface_number))
# @port core/libraries/usbd/usbd.cpp::sceUsbdControlTransferGetData sha256=6a671322e59d9a73 oracle@a3773841
