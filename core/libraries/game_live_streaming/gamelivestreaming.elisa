type s32 = i32

def LIB_FUNCTION[T](nid: static u8&, lib_name: static u8&, version: int, export_lib: static u8&, func: T) -> void:
    return

struct OrbisGameLiveStreamingStatus:
    isOnAir: mutable bool
    align: mutable u8[3]
    spectatorCounts: mutable u32
    userId: mutable s32
    reserved: mutable u8[60]

struct OrbisGameLiveStreamingStatus2:
    userId: mutable s32
    isOnAir: mutable bool
    align: mutable u8[3]
    spectatorCounts: mutable u32
    textMessageCounts: mutable u32
    commandMessageCounts: mutable u32
    broadcastVideoResolution: mutable u32
    reserved: mutable u8[48]

