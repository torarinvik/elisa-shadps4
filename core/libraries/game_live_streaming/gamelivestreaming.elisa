def sceGameLiveStreamingEnableLiveStreaming() -> int:
    return ORBIS_OK

def sceGameLiveStreamingEnableSocialFeedback() -> int:
    return ORBIS_OK

def sceGameLiveStreamingGetCurrentBroadcastScreenLayout() -> int:
    return ORBIS_OK

def sceGameLiveStreamingGetCurrentStatus(status: mutable OrbisGameLiveStreamingStatus&?) -> int:
    if status == null:
        return ORBIS_OK
    status.isOnAir <- false
    status.align[0] <- 0u8
    status.align[1] <- 0u8
    status.align[2] <- 0u8
    status.spectatorCounts <- 0u32
    status.userId <- 0
    i: mutable int = 0
    while i < 60:
        status.reserved[i] <- 0u8
        i <- i + 1
    return ORBIS_OK

