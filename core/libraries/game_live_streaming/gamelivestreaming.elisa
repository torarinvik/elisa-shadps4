include "../error_codes.elisa"
include "./gamelivestreaming_nids.elisa"

struct OrbisGameLiveStreamingStatus:
    isOnAir: mutable bool
    align: mutable u8[3]
    spectatorCounts: mutable u32
    userId: mutable s32
    reserved: mutable u8[60]

struct OrbisGameLiveStreamingStatus2:
    userId: mutable s32
    isOnAir: mutable bool
    align: mutable u8[3]
    spectatorCounts: mutable u32
    textMessageCounts: mutable u32
    commandMessageCounts: mutable u32
    broadcastVideoResolution: mutable u32
    reserved: mutable u8[48]

def sceGameLiveStreamingStartDebugBroadcast() -> int:
    return ORBIS_OK

def sceGameLiveStreamingStopDebugBroadcast() -> int:
    return ORBIS_OK

def sceGameLiveStreamingApplySocialFeedbackMessageFilter() -> int:
    return ORBIS_OK

