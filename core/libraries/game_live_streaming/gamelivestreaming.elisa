# @port core/libraries/game_live_streaming/gamelivestreaming.cpp::sceGameLiveStreamingGetCurrentStatus sha256=188b908fa58a7307 oracle@a3773841
def sceGameLiveStreamingGetCurrentStatus(status: mutable OrbisGameLiveStreamingStatus&?) -> int:
    if status == null:
        assert false
    else:
        status.isOnAir <- false
        status.align[0] <- 0u8
        status.align[1] <- 0u8
        status.align[2] <- 0u8
        status.spectatorCounts <- 0u32
        status.userId <- 0
        i: mutable int = 0
        while i < 60:
            status.reserved[i] <- 0u8
            i <- i + 1
    return ORBIS_OK

