include "./pngenc_error.elisa"

const ORBIS_PNG_ENC_ATTRIBUTE_NONE: u32 = 0
const ORBIS_PNG_ENC_COLOR_SPACE_RGB: u16 = 3
const ORBIS_PNG_ENC_COLOR_SPACE_RGBA: u16 = 19
const ORBIS_PNG_ENC_PIXEL_FORMAT_R8G8B8A8: u16 = 0
const ORBIS_PNG_ENC_PIXEL_FORMAT_B8G8R8A8: u16 = 1
const ORBIS_PNG_ENC_FILTER_TYPE_NONE: u16 = 0
const ORBIS_PNG_ENC_FILTER_TYPE_SUB: u16 = 1
const ORBIS_PNG_ENC_FILTER_TYPE_UP: u16 = 2
const ORBIS_PNG_ENC_FILTER_TYPE_AVERAGE: u16 = 4
const ORBIS_PNG_ENC_FILTER_TYPE_PAETH: u16 = 8
const ORBIS_PNG_ENC_FILTER_TYPE_ALL: u16 = 15

const PNG_IMAGE_VERSION: u32 = 1
const PNG_FORMAT_RGB: u32 = 0x02
const PNG_FORMAT_BGR: u32 = 0x12
const PNG_FORMAT_RGBA: u32 = 0x03
const PNG_FORMAT_BGRA: u32 = 0x13

struct PngImage layout c:
    opaque: void&?
    version: u32
    width: u32
    height: u32
    format: u32
    flags: u32
    colormap_entries: u32
    warning_or_error: u32
    message: u8[64]

@link_name(png_image_write_to_memory)
extern c_png_image_write_to_memory(image: mutable PngImage&, memory: mutable void&?, memory_bytes: mutable usize&, convert_to_8_bit: int, buffer: void&, row_stride: i32, colormap: void&?) -> int

@fixed_layout
struct OrbisPngEncCreateParam:
    this_size: u32
    attribute: u32
    max_image_width: u32
    max_filter_number: u32

@fixed_layout
struct OrbisPngEncEncodeParam:
    image_mem_addr: u8&?
    png_mem_addr: mutable u8&?
    image_mem_size: u32
    png_mem_size: u32
    image_width: u32
    image_height: u32
    image_pitch: u32
    pixel_format: u16
    color_space: u16
    bit_depth: u16
    clut_number: u16
    filter_type: u16
    compression_level: u16

@fixed_layout
struct OrbisPngEncOutputInfo:
    data_size: u32
    processed_height: u32

@fixed_layout
struct OrbisPngEncHandleInternal:
    self_ptr: OrbisPngEncHandleInternal&?
    max_image_width: u32
    max_filter_number: u32

type OrbisPngEncHandle = OrbisPngEncHandleInternal&?

def PngEnc_ValidateHandle(handle: OrbisPngEncHandle) -> int:
    if handle == null:
        return ORBIS_PNG_ENC_ERROR_INVALID_HANDLE
    h_opt: OrbisPngEncHandleInternal&? = handle
    if h_opt == null:
        return ORBIS_PNG_ENC_ERROR_INVALID_HANDLE
    h: OrbisPngEncHandleInternal& = h_opt
    if h.self_ptr != h_opt:
        return ORBIS_PNG_ENC_ERROR_INVALID_HANDLE
    return ORBIS_OK

def PngEnc_WriteBe32(dst: mutable u8&, off: u32, v: u32) -> void:
    dst[off.usize()] <- ((v >> 24) & 0xff).u8()
    dst[(off + 1).usize()] <- ((v >> 16) & 0xff).u8()
    dst[(off + 2).usize()] <- ((v >> 8) & 0xff).u8()
    dst[(off + 3).usize()] <- (v & 0xff).u8()

def PngEnc_Adler32(data: mutable u8&, off: u32, len: u32) -> u32:
    a: u32 = 1
    b: u32 = 0
    i: u32 = 0
    while i < len:
        a <- (a + data[(off + i).usize()].u32()) % 65521
        b <- (b + a) % 65521
        i <- i + 1
    return (b << 16) | a

def PngEnc_Crc32(data: mutable u8&, off: u32, len: u32) -> u32:
    crc: u32 = 0xffffffff
    i: u32 = 0
    while i < len:
        crc <- crc ^ data[(off + i).usize()].u32()
        j: u32 = 0
        while j < 8:
            if (crc & 1) != 0:
                crc <- (crc >> 1) ^ 0xedb88320
            else:
                crc <- crc >> 1
            j <- j + 1
        i <- i + 1
    return crc ^ 0xffffffff

def PngEnc_RowBytes(width: u32, color_space: u16) -> u32:
    channels: u32 = 4
    if color_space == ORBIS_PNG_ENC_COLOR_SPACE_RGB:
        channels <- 3
    return width * channels

def PngEnc_CalcPngSize(width: u32, height: u32, color_space: u16) -> u32:
    row_bytes: u32 = PngEnc_RowBytes(width, color_space)
    raw_size: u32 = (row_bytes + 1) * height
    block_count: u32 = (raw_size + 65534) / 65535
    zlib_size: u32 = 2 + raw_size + (block_count * 5) + 4
    # Signature 8 + IHDR 25 + IDAT (12 + payload) + IEND 12
    return 8 + 25 + 12 + zlib_size + 12

def PngEnc_WriteChunk(out: mutable u8&, write_off: mutable u32&, t0: u8, t1: u8, t2: u8, t3: u8, payload: mutable u8&, payload_off: u32, payload_len: u32) -> void:
    PngEnc_WriteBe32(out, write_off, payload_len)
    write_off <- write_off + 4
    out[write_off.usize()] <- t0
    out[(write_off + 1).usize()] <- t1
    out[(write_off + 2).usize()] <- t2
    out[(write_off + 3).usize()] <- t3
    write_off <- write_off + 4
    i: u32 = 0
    while i < payload_len:
        out[(write_off + i).usize()] <- payload[(payload_off + i).usize()]
        i <- i + 1
    crc_start: u32 = write_off - 4
    write_off <- write_off + payload_len
    crc: u32 = PngEnc_Crc32(out, crc_start, payload_len + 4)
    PngEnc_WriteBe32(out, write_off, crc)
    write_off <- write_off + 4

def PngEnc_PaethPredictor(a: u8, b: u8, c: u8) -> u8:
    ai: int = a.i32()
    bi: int = b.i32()
    ci: int = c.i32()
    p: int = ai + bi - ci
    pa: int = (p - ai).abs()
    pb: int = (p - bi).abs()
    pc: int = (p - ci).abs()
    if pa <= pb and pa <= pc:
        return a
    if pb <= pc:
        return b
    return c

def PngEnc_SelectFilterType(filter_type: u16) -> u8:
    if filter_type == ORBIS_PNG_ENC_FILTER_TYPE_NONE:
        return 0.u8()
    if (filter_type & ORBIS_PNG_ENC_FILTER_TYPE_SUB) != 0:
        return 1.u8()
    if (filter_type & ORBIS_PNG_ENC_FILTER_TYPE_UP) != 0:
        return 2.u8()
    if (filter_type & ORBIS_PNG_ENC_FILTER_TYPE_AVERAGE) != 0:
        return 3.u8()
    if (filter_type & ORBIS_PNG_ENC_FILTER_TYPE_PAETH) != 0:
        return 4.u8()
    return 0.u8()

def PngEnc_SignedByte(v: u8) -> int:
    i: int = v.i32()
    if i < 128:
        return i
    return i - 256

def PngEnc_FilterScore(filtered: mutable u8&, row_len: u32) -> i64:
    score: i64 = 0
    i: u32 = 0
    while i < row_len:
        score <- score + PngEnc_SignedByte(filtered[i.usize()]).abs().i64()
        i <- i + 1
    return score

def PngEnc_ChooseBestFilter(filter_mask: u16, row: mutable u8&, prev: mutable u8&, scratch: mutable u8&, best: mutable u8&, row_len: u32, bpp: u32) -> u8:
    best_filter: u8 = 0.u8()
    best_score: i64 = 0x7fffffffffffffff
    candidate: u8 = 0
    while candidate <= 4:
        allow: bool = false
        if filter_mask == ORBIS_PNG_ENC_FILTER_TYPE_ALL:
            allow <- true
        elif candidate == 0 and filter_mask == ORBIS_PNG_ENC_FILTER_TYPE_NONE:
            allow <- true
        elif candidate == 1 and (filter_mask & ORBIS_PNG_ENC_FILTER_TYPE_SUB) != 0:
            allow <- true
        elif candidate == 2 and (filter_mask & ORBIS_PNG_ENC_FILTER_TYPE_UP) != 0:
            allow <- true
        elif candidate == 3 and (filter_mask & ORBIS_PNG_ENC_FILTER_TYPE_AVERAGE) != 0:
            allow <- true
        elif candidate == 4 and (filter_mask & ORBIS_PNG_ENC_FILTER_TYPE_PAETH) != 0:
            allow <- true
        if allow:
            filter_ret: int = PngEnc_FilterRow(candidate, row, prev, scratch, row_len, bpp)
            if filter_ret == ORBIS_OK:
                score: i64 = PngEnc_FilterScore(scratch, row_len)
                if score < best_score:
                    best_score <- score
                    best_filter <- candidate
                    i: u32 = 0
                    while i < row_len:
                        best[i.usize()] <- scratch[i.usize()]
                        i <- i + 1
        candidate <- candidate + 1
    return best_filter

def PngEnc_FilterRow(filter: u8, row: mutable u8&, prev: mutable u8&, out: mutable u8&, row_len: u32, bpp: u32) -> int:
    i: u32 = 0
    if filter == 0.u8():
        while i < row_len:
            out[i.usize()] <- row[i.usize()]
            i <- i + 1
        return ORBIS_OK
    if filter == 1.u8():
        while i < row_len:
            left: u8 = 0.u8()
            if i >= bpp:
                left <- row[(i - bpp).usize()]
            out[i.usize()] <- (row[i.usize()].u32() - left.u32()).u8()
            i <- i + 1
        return ORBIS_OK
    if filter == 2.u8():
        while i < row_len:
            out[i.usize()] <- (row[i.usize()].u32() - prev[i.usize()].u32()).u8()
            i <- i + 1
        return ORBIS_OK
    if filter == 3.u8():
        while i < row_len:
            left: u8 = 0.u8()
            if i >= bpp:
                left <- row[(i - bpp).usize()]
            up: u8 = prev[i.usize()]
            avg: u8 = ((left.u32() + up.u32()) / 2).u8()
            out[i.usize()] <- (row[i.usize()].u32() - avg.u32()).u8()
            i <- i + 1
        return ORBIS_OK
    if filter == 4.u8():
        while i < row_len:
            left: u8 = 0.u8()
            up: u8 = prev[i.usize()]
            up_left: u8 = 0.u8()
            if i >= bpp:
                left <- row[(i - bpp).usize()]
                up_left <- prev[(i - bpp).usize()]
            p: u8 = PngEnc_PaethPredictor(left, up, up_left)
            out[i.usize()] <- (row[i.usize()].u32() - p.u32()).u8()
            i <- i + 1
        return ORBIS_OK
    return ORBIS_PNG_ENC_ERROR_INVALID_PARAM

def PngEnc_BuildRawRows(param: OrbisPngEncEncodeParam&, raw: mutable u8&, raw_size: u32) -> int:
    src_opt: u8&? = param.image_mem_addr
    if src_opt == null:
        return ORBIS_PNG_ENC_ERROR_INVALID_ADDR
    src: u8& = src_opt
    row_bytes: u32 = PngEnc_RowBytes(param.image_width, param.color_space)
    if raw_size < (row_bytes + 1) * param.image_height:
        return ORBIS_PNG_ENC_ERROR_INVALID_SIZE
    if row_bytes > 262144:
        return ORBIS_PNG_ENC_ERROR_INVALID_SIZE
    filter_method: u8 = PngEnc_SelectFilterType(param.filter_type)
    row_buf: mutable u8[262144] = zeroed
    prev_row: mutable u8[262144] = zeroed
    filtered_row: mutable u8[262144] = zeroed
    scratch_row: mutable u8[262144] = zeroed
    bpp: u32 = 3
    if param.color_space == ORBIS_PNG_ENC_COLOR_SPACE_RGBA:
        bpp <- 4
    y: u32 = 0
    while y < param.image_height:
        dst_row: u32 = y * (row_bytes + 1)
        selected_filter: u8 = filter_method
        src_row: u32 = y * param.image_pitch
        x: u32 = 0
        dst_channels: u32 = 3
        if param.color_space == ORBIS_PNG_ENC_COLOR_SPACE_RGBA:
            dst_channels <- 4
        while x < param.image_width:
            s: u32 = src_row + x * 4
            d: u32 = dst_row + 1 + x * dst_channels
            r: u8 = src[s.usize()]
            g: u8 = src[(s + 1).usize()]
            b: u8 = src[(s + 2).usize()]
            a: u8 = src[(s + 3).usize()]
            if param.pixel_format == ORBIS_PNG_ENC_PIXEL_FORMAT_B8G8R8A8:
                r <- src[(s + 2).usize()]
                g <- src[(s + 1).usize()]
                b <- src[s.usize()]
            row_buf[(x * dst_channels).usize()] <- r
            row_buf[(x * dst_channels + 1).usize()] <- g
            row_buf[(x * dst_channels + 2).usize()] <- b
            if param.color_space == ORBIS_PNG_ENC_COLOR_SPACE_RGBA:
                row_buf[(x * dst_channels + 3).usize()] <- a
            x <- x + 1
        if param.filter_type == ORBIS_PNG_ENC_FILTER_TYPE_ALL:
            selected_filter <- PngEnc_ChooseBestFilter(param.filter_type, row_buf.ref[mutable u8&], prev_row.ref[mutable u8&], scratch_row.ref[mutable u8&], filtered_row.ref[mutable u8&], row_bytes, bpp)
        else:
            selected_filter <- filter_method
        raw[dst_row.usize()] <- selected_filter
        filter_ret: int = PngEnc_FilterRow(selected_filter, row_buf.ref[mutable u8&], prev_row.ref[mutable u8&], filtered_row.ref[mutable u8&], row_bytes, bpp)
        if filter_ret != ORBIS_OK:
            return filter_ret
        dst_data_off: u32 = dst_row + 1
        i: u32 = 0
        while i < row_bytes:
            raw[(dst_data_off + i).usize()] <- filtered_row[i.usize()]
            prev_row[i.usize()] <- row_buf[i.usize()]
            i <- i + 1
        y <- y + 1
    return ORBIS_OK

def PngEnc_BuildZlibStored(raw: mutable u8&, raw_size: u32, zlib: mutable u8&, zlib_size: u32) -> int:
    if zlib_size < raw_size + 6:
        return ORBIS_PNG_ENC_ERROR_DATA_OVERFLOW
    write_off: u32 = 0
    zlib[write_off.usize()] <- 0x78.u8()
    zlib[(write_off + 1).usize()] <- 0x01.u8()
    write_off <- write_off + 2

    remain: u32 = raw_size
    raw_off: u32 = 0
    while remain > 0:
        block: u32 = remain
        if block > 65535:
            block <- 65535
        final_block: u8 = 0.u8()
        if block == remain:
            final_block <- 1.u8()
        zlib[write_off.usize()] <- final_block
        write_off <- write_off + 1
        zlib[write_off.usize()] <- (block & 0xff).u8()
        zlib[(write_off + 1).usize()] <- ((block >> 8) & 0xff).u8()
        nlen: u32 = (~block) & 0xffff
        zlib[(write_off + 2).usize()] <- (nlen & 0xff).u8()
        zlib[(write_off + 3).usize()] <- ((nlen >> 8) & 0xff).u8()
        write_off <- write_off + 4
        i: u32 = 0
        while i < block:
            zlib[(write_off + i).usize()] <- raw[(raw_off + i).usize()]
            i <- i + 1
        write_off <- write_off + block
        raw_off <- raw_off + block
        remain <- remain - block

    adler: u32 = PngEnc_Adler32(raw, 0, raw_size)
    PngEnc_WriteBe32(zlib, write_off, adler)
    write_off <- write_off + 4
    return write_off.i32()

def scePngEncCreate(param: OrbisPngEncCreateParam&?, memory_address: mutable void&?, memory_size: u32, handle: mutable OrbisPngEncHandle&) -> int:
    _ = memory_size
    if param == null or param.attribute != ORBIS_PNG_ENC_ATTRIBUTE_NONE:
        return ORBIS_PNG_ENC_ERROR_INVALID_ADDR
    if memory_address == null:
        return ORBIS_PNG_ENC_ERROR_INVALID_ADDR
    if param.max_image_width == 0 or (param.max_image_width - 1) > 1000000:
        return ORBIS_PNG_ENC_ERROR_INVALID_SIZE
    mem: mutable void& = memory_address
    h: mutable OrbisPngEncHandleInternal& = mem.cast[mutable OrbisPngEncHandleInternal&]
    h.self_ptr <- h
    h.max_image_width <- param.max_image_width
    h.max_filter_number <- param.max_filter_number
    handle <- h
    return ORBIS_OK

def scePngEncDelete(handle: OrbisPngEncHandle) -> int:
    handle_ret: int = PngEnc_ValidateHandle(handle)
    if handle_ret != ORBIS_OK:
        return handle_ret
    if handle == null:
        return ORBIS_PNG_ENC_ERROR_INVALID_HANDLE
    h: OrbisPngEncHandleInternal& = handle
    h.self_ptr <- null
    return ORBIS_OK

def scePngEncEncode(handle: OrbisPngEncHandle, param: OrbisPngEncEncodeParam&?, output_info: mutable OrbisPngEncOutputInfo&?) -> int:
    handle_ret: int = PngEnc_ValidateHandle(handle)
    if handle_ret != ORBIS_OK:
        return handle_ret
    if param == null:
        return ORBIS_PNG_ENC_ERROR_INVALID_PARAM
    if param.image_mem_addr == null or param.png_mem_addr == null:
        return ORBIS_PNG_ENC_ERROR_INVALID_ADDR
    if param.png_mem_size == 0 or param.image_mem_size == 0 or param.image_width == 0 or param.image_height == 0:
        return ORBIS_PNG_ENC_ERROR_INVALID_SIZE
    if param.color_space != ORBIS_PNG_ENC_COLOR_SPACE_RGB and param.color_space != ORBIS_PNG_ENC_COLOR_SPACE_RGBA:
        return ORBIS_PNG_ENC_ERROR_INVALID_PARAM
    if param.pixel_format != ORBIS_PNG_ENC_PIXEL_FORMAT_R8G8B8A8 and param.pixel_format != ORBIS_PNG_ENC_PIXEL_FORMAT_B8G8R8A8:
        return ORBIS_PNG_ENC_ERROR_INVALID_PARAM
    if param.bit_depth != 8:
        return ORBIS_PNG_ENC_ERROR_INVALID_PARAM
    if param.compression_level > 9:
        return ORBIS_PNG_ENC_ERROR_INVALID_PARAM
    if param.filter_type > ORBIS_PNG_ENC_FILTER_TYPE_ALL:
        return ORBIS_PNG_ENC_ERROR_INVALID_PARAM
    native_image: mutable PngImage = zeroed
    native_image.version <- PNG_IMAGE_VERSION
    native_image.width <- param.image_width
    native_image.height <- param.image_height

    src_opt: u8&? = param.image_mem_addr
    if src_opt == null:
        return ORBIS_PNG_ENC_ERROR_INVALID_ADDR
    src: u8& = src_opt

    output_opt: mutable u8&? = param.png_mem_addr
    if output_opt == null:
        return ORBIS_PNG_ENC_ERROR_INVALID_ADDR
    output_buf: mutable u8& = output_opt

    probe_bytes: usize = param.png_mem_size.usize()
    image_arg: void& = src as void&
    row_stride: i32 = param.image_pitch.i32()
    scratch_rgb: mutable u8[1048576] = zeroed

    if param.color_space == ORBIS_PNG_ENC_COLOR_SPACE_RGBA:
        if param.pixel_format == ORBIS_PNG_ENC_PIXEL_FORMAT_B8G8R8A8:
            native_image.format <- PNG_FORMAT_BGRA
        else:
            native_image.format <- PNG_FORMAT_RGBA
    else:
        row_bytes: u32 = PngEnc_RowBytes(param.image_width, param.color_space)
        packed_size: u32 = row_bytes * param.image_height
        if packed_size > 1048576:
            if output_info != null:
                output_info.data_size <- 0
                output_info.processed_height <- 0
            return ORBIS_PNG_ENC_ERROR_INVALID_SIZE
        if param.pixel_format == ORBIS_PNG_ENC_PIXEL_FORMAT_B8G8R8A8:
            native_image.format <- PNG_FORMAT_BGR
        else:
            native_image.format <- PNG_FORMAT_RGB
        y: u32 = 0
        while y < param.image_height:
            src_row_off: u32 = y * param.image_pitch
            dst_row_off: u32 = y * row_bytes
            x: u32 = 0
            while x < param.image_width:
                s: u32 = src_row_off + x * 4
                d: u32 = dst_row_off + x * 3
                scratch_rgb[d.usize()] <- src[s.usize()]
                scratch_rgb[(d + 1).usize()] <- src[(s + 1).usize()]
                scratch_rgb[(d + 2).usize()] <- src[(s + 2).usize()]
                x <- x + 1
            y <- y + 1
        image_arg <- scratch_rgb.ref[mutable u8&] as void&
        row_stride <- row_bytes.i32()

    probe_ok: int = c_png_image_write_to_memory(native_image.ref[mutable PngImage&], null, probe_bytes.ref[mutable usize&], 0, image_arg, row_stride, null)
    if probe_ok == 0:
        if output_info != null:
            output_info.data_size <- 0
            output_info.processed_height <- 0
        return ORBIS_PNG_ENC_ERROR_FATAL
    if probe_bytes > param.png_mem_size.usize():
        if output_info != null:
            output_info.data_size <- 0
            output_info.processed_height <- 0
        return ORBIS_PNG_ENC_ERROR_DATA_OVERFLOW

    written_bytes: usize = param.png_mem_size.usize()
    write_ok: int = c_png_image_write_to_memory(native_image.ref[mutable PngImage&], output_buf as mutable void&?, written_bytes.ref[mutable usize&], 0, image_arg, row_stride, null)
    if write_ok == 0:
        if output_info != null:
            output_info.data_size <- 0
            output_info.processed_height <- 0
        return ORBIS_PNG_ENC_ERROR_FATAL

    if output_info != null:
        output_info.data_size <- written_bytes.u32()
        output_info.processed_height <- param.image_height
    return written_bytes.i32()

def scePngEncQueryMemorySize(param: OrbisPngEncCreateParam&?) -> int:
    if param == null:
        return ORBIS_PNG_ENC_ERROR_INVALID_ADDR
    if param.attribute != ORBIS_PNG_ENC_ATTRIBUTE_NONE or param.max_filter_number > 5:
        return ORBIS_PNG_ENC_ERROR_INVALID_PARAM
    if param.max_image_width == 0 or (param.max_image_width - 1) > 1000000:
        return ORBIS_PNG_ENC_ERROR_INVALID_SIZE
    return size_of(OrbisPngEncHandleInternal).i32()

def PngEnc_RegisterLib(sym: void&?) -> void:
    _ = sym
