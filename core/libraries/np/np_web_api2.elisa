include "../../user_settings.elisa"

const ORBIS_NP_WEBAPI2_USER_SERVICE_USER_ID_INVALID: s32 = -1

def NpWebApi2_IsShadNetEnabled() -> bool:
    settings: mutable UserSettingsImpl& = UserSettings_GetInstance()
    _ = UserSettings_Load(settings)
    user_mgr: mutable UserManager& = UserSettings_GetUserManager(settings)
    default_user: User = UserManager_GetDefaultUser(user_mgr)
    return default_user.shadnet_enabled

# @port core/libraries/np/np_web_api2.cpp::sceNpWebApi2Initialize sha256=12190ca3e13dde78 oracle@a3773841
def sceNpWebApi2Initialize(lib_http_ctx_id: s32, pool_size: u64) -> s32:
    _ = lib_http_ctx_id
    _ = pool_size
    return ORBIS_OK

# @port core/libraries/np/np_web_api2.cpp::sceNpWebApi2InitializeForPresence sha256=7972519968f98b0e oracle@a3773841
