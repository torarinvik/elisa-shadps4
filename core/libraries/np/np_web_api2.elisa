# @port core/libraries/np/np_web_api2.cpp::sceNpWebApi2IntInitialize sha256=9968c982cde72889 oracle@a3773841
def sceNpWebApi2IntInitialize(args: void&?) -> s32:
    if args == null:
        return ORBIS_NP_WEBAPI2_ERROR_INVALID_ARGUMENT
    return ORBIS_OK

# @port core/libraries/np/np_web_api2.cpp::sceNpWebApi2IntInitialize2 sha256=b6432d28a7380fd8 oracle@a3773841
