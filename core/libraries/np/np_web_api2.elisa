    if data == null or size == 0:
        return ORBIS_NP_WEBAPI2_ERROR_INVALID_ARGUMENT
    return ORBIS_OK

def sceNpWebApi2SetRequestTimeout(request_id: s64, timeout: u32) -> s32:
