const ORBIS_USER_SERVICE_USER_ID_INVALID: s32 = -1

def sceNpWebApi2Initialize(lib_http_ctx_id: s32, pool_size: u64) -> s32:
    _ = lib_http_ctx_id
    _ = pool_size
    return ORBIS_OK

def sceNpWebApi2InitializeForPresence(lib_http_ctx_id: s32, pool_size: u64) -> s32:
    _ = lib_http_ctx_id
    _ = pool_size
    return ORBIS_OK

def sceNpWebApi2IntInitialize(args: void&?) -> s32:
    if args == null:
        return ORBIS_NP_WEBAPI2_ERROR_INVALID_ARGUMENT
    return ORBIS_OK

def sceNpWebApi2IntInitialize2(args: void&?) -> s32:
