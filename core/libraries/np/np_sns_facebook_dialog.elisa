def sceNpSnsFacebookDialogUpdateStatus() -> u32:
    return ORBIS_COMMON_DIALOG_STATUS_NONE


def sceNpSnsFacebookDialogInitialize() -> u32:
    return ORBIS_OK.u32()

def sceNpSnsFacebookDialogOpen() -> u32:
    return ORBIS_OK.u32()

def sceNpSnsFacebookDialogTerminate() -> u32:
    return ORBIS_OK.u32()

def sceNpSnsFacebookDialogGetResult(result: mutable void&?) -> u32:
    _ = result
    return ORBIS_OK.u32()
