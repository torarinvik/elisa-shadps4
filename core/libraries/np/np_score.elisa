type OrbisNpScoreBoardId = u32
type OrbisNpScorePcId = s32
type OrbisNpScoreRankNumber = u32
type OrbisNpScoreValue = s64

const ORBIS_NP_SCORE_COMMENT_MAXLEN: usize = 63
const ORBIS_NP_SCORE_GAMEINFO_MAXSIZE: usize = 189

global mutable g_np_score_next_title_ctx: s32 = 1
global mutable g_np_score_next_request: s32 = 1

def sceNpScoreCreateNpTitleCtx(serviceLabel: OrbisNpServiceLabel, npId: mutable OrbisNpId&?) -> int:
    _ = serviceLabel
    _ = npId
    id: s32 = g_np_score_next_title_ctx
    g_np_score_next_title_ctx <- g_np_score_next_title_ctx + 1
    return id

def sceNpScoreCreateNpTitleCtxA(npServiceLabel: OrbisNpServiceLabel, accountId: OrbisNpAccountId) -> int:
    _ = accountId
    return sceNpScoreCreateNpTitleCtx(npServiceLabel, null)

def sceNpScoreCreateTitleCtx() -> int:
    return sceNpScoreCreateNpTitleCtx(0, null)

def sceNpScoreDeleteNpTitleCtx(titleCtxId: s32) -> int:
    _ = titleCtxId
    return ORBIS_OK

def sceNpScoreCreateRequest(titleCtxId: s32) -> int:
    _ = titleCtxId
    id: s32 = g_np_score_next_request
    g_np_score_next_request <- g_np_score_next_request + 1
    return id

def sceNpScoreDeleteRequest(reqId: s32) -> int:
    _ = reqId
    return ORBIS_OK

def sceNpScoreAbortRequest(reqId: s32) -> int:
    _ = reqId
    return ORBIS_OK

def sceNpScoreWaitAsync(reqId: s32, result: mutable s32&?) -> int:
    _ = reqId
    if result != null:
        result <- ORBIS_OK
    return ORBIS_OK

def sceNpScorePollAsync(reqId: s32, result: mutable s32&?) -> int:
    return sceNpScoreWaitAsync(reqId, result)

def sceNpScoreSanitizeComment(reqId: s32, comment: u8&?, sanitizedComment: mutable u8&?, option: void&?) -> int:
    _ = reqId
    _ = option
    if comment == null or sanitizedComment == null:
        return ORBIS_NP_COMMUNITY_ERROR_INVALID_ARGUMENT
    i: mutable usize = 0
    while i < ORBIS_NP_SCORE_COMMENT_MAXLEN and comment[i] != 0:
        sanitizedComment[i] <- comment[i]
        i <- i + 1
    sanitizedComment[i] <- 0
    return ORBIS_OK

def sceNpScoreSanitizeCommentAsync(reqId: s32, comment: u8&?, sanitizedComment: mutable u8&?, option: void&?) -> int:
    return sceNpScoreSanitizeComment(reqId, comment, sanitizedComment, option)

def sceNpScoreCensorComment(reqId: s32, comment: u8&?, option: void&?) -> int:
    _ = reqId
    _ = comment
    _ = option
    return ORBIS_OK

def sceNpScoreCensorCommentAsync(reqId: s32, comment: u8&?, option: void&?) -> int:
    return sceNpScoreCensorComment(reqId, comment, option)

def sceNpScoreSetPlayerCharacterId(ctxId: s32, pcId: OrbisNpScorePcId) -> int:
    _ = ctxId
    _ = pcId
    return ORBIS_OK

def sceNpScoreSetThreadParam(threadPriority: s32, cpuAffinityMask: u64) -> int:
    _ = threadPriority
    _ = cpuAffinityMask
    return ORBIS_OK

def sceNpScoreSetTimeout(id: s32, resolveRetry: s32, resolveTimeout: s32, connTimeout: s32, sendTimeout: s32, recvTimeout: s32) -> int:
    _ = id
    _ = resolveRetry
    _ = resolveTimeout
    _ = connTimeout
    _ = sendTimeout
    _ = recvTimeout
    return ORBIS_OK

def sceNpScoreStubOk() -> int:
    return ORBIS_OK

