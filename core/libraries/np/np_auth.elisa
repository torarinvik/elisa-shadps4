const ORBIS_NP_AUTH_REQUEST_LIMIT: s32 = 0x10
const ORBIS_NP_AUTH_REQUEST_ID_OFFSET: s32 = 0x10000000
const NP_AUTH_REQUEST_NONE: u8 = 0
const NP_AUTH_REQUEST_READY: u8 = 1
const NP_AUTH_REQUEST_ABORTED: u8 = 2
const NP_AUTH_REQUEST_COMPLETE: u8 = 3

@fixed_layout
struct OrbisNpAuthCreateAsyncRequestParameter:
    size: mutable u64
    cpu_affinity_mask: mutable u64
    thread_priority: mutable s32
    padding: mutable u8[4]

@fixed_layout
struct OrbisNpAuthGetAuthorizationCodeParameter:
    size: mutable u64
    online_id: mutable OrbisNpOnlineId&?
    client_id: mutable OrbisNpClientId&?
    scope: mutable u8&?

@fixed_layout
struct OrbisNpAuthGetAuthorizationCodeParameterA:
    size: mutable u64
    user_id: mutable s32
    padding: mutable u8[4]
    client_id: mutable OrbisNpClientId&?
    scope: mutable u8&?

@fixed_layout
struct OrbisNpAuthGetIdTokenParameter:
    size: mutable u64
    online_id: mutable OrbisNpOnlineId&?
    client_id: mutable OrbisNpClientId&?
    client_secret: mutable OrbisNpClientSecret&?
    scope: mutable u8&?

@fixed_layout
struct OrbisNpAuthGetIdTokenParameterA:
    size: mutable u64
    user_id: mutable s32
    padding: mutable u8[4]
    client_id: mutable OrbisNpClientId&?
    client_secret: mutable OrbisNpClientSecret&?
    scope: mutable u8&?

@fixed_layout
struct NpAuthRequest:
    state: mutable u8
    async_: mutable bool
    result: mutable s32

global mutable g_np_auth_active_requests: s32 = 0
global mutable g_np_auth_requests: NpAuthRequest[16] = zeroed

def NpAuthReqIndex(req_id: s32) -> s32:
    return req_id - ORBIS_NP_AUTH_REQUEST_ID_OFFSET - 1

def NpAuthValidIndex(index: s32) -> bool:
    return index >= 0 and index < ORBIS_NP_AUTH_REQUEST_LIMIT

def NpAuthCreateRequest(async_: bool) -> s32:
    if g_np_auth_active_requests == ORBIS_NP_AUTH_REQUEST_LIMIT:
        return ORBIS_NP_AUTH_ERROR_REQUEST_MAX
    for i in 0..<ORBIS_NP_AUTH_REQUEST_LIMIT:
        if g_np_auth_requests[i].state == NP_AUTH_REQUEST_NONE:
            g_np_auth_requests[i].state <- NP_AUTH_REQUEST_READY
            g_np_auth_requests[i].async_ <- async_
            g_np_auth_requests[i].result <- 0
            g_np_auth_active_requests <- g_np_auth_active_requests + 1
            return ORBIS_NP_AUTH_REQUEST_ID_OFFSET + i + 1
    return ORBIS_NP_AUTH_ERROR_REQUEST_MAX

# @port core/libraries/np/np_auth.cpp::sceNpAuthCreateRequest sha256=56ac7c741669f477 oracle@a3773841
def sceNpAuthCreateRequest() -> s32:
    return NpAuthCreateRequest(false)

# @port core/libraries/np/np_auth.cpp::sceNpAuthCreateAsyncRequest sha256=899e9b859f6332da oracle@a3773841
def sceNpAuthCreateAsyncRequest(param: OrbisNpAuthCreateAsyncRequestParameter&?) -> s32:
    if param == null:
        return ORBIS_NP_AUTH_ERROR_INVALID_ARGUMENT
    if param.size != size_of(OrbisNpAuthCreateAsyncRequestParameter).u64():
        return ORBIS_NP_AUTH_ERROR_INVALID_SIZE
    return NpAuthCreateRequest(true)

def NpAuthProcessSignedOut(req_id: s32) -> s32:
    index: s32 = NpAuthReqIndex(req_id)
    if not NpAuthValidIndex(index) or g_np_auth_requests[index].state == NP_AUTH_REQUEST_NONE:
        return ORBIS_NP_AUTH_ERROR_REQUEST_NOT_FOUND
    if g_np_auth_requests[index].state == NP_AUTH_REQUEST_COMPLETE:
        g_np_auth_requests[index].result <- ORBIS_NP_AUTH_ERROR_INVALID_ARGUMENT
        return ORBIS_NP_AUTH_ERROR_INVALID_ARGUMENT
    if g_np_auth_requests[index].state == NP_AUTH_REQUEST_ABORTED:
        g_np_auth_requests[index].result <- ORBIS_NP_AUTH_ERROR_ABORTED
        return ORBIS_NP_AUTH_ERROR_ABORTED
    g_np_auth_requests[index].state <- NP_AUTH_REQUEST_COMPLETE
    g_np_auth_requests[index].result <- ORBIS_NP_ERROR_SIGNED_OUT
    if g_np_auth_requests[index].async_:
        return ORBIS_OK
    return ORBIS_NP_ERROR_SIGNED_OUT

# @port core/libraries/np/np_auth.cpp::sceNpAuthGetAuthorizationCode sha256=7216dc0fb49c39a0 oracle@a3773841
def sceNpAuthGetAuthorizationCode(req_id: s32, param: OrbisNpAuthGetAuthorizationCodeParameter&?, auth_code: mutable OrbisNpAuthorizationCode&?, issuer_id: mutable s32&?) -> s32:
    _ = req_id
    _ = issuer_id
    if param == null or auth_code == null:
        return ORBIS_NP_AUTH_ERROR_INVALID_ARGUMENT
    if param.size != size_of(OrbisNpAuthGetAuthorizationCodeParameter).u64():
        return ORBIS_NP_AUTH_ERROR_INVALID_SIZE
    if param.online_id == null or param.client_id == null or param.scope == null:
        return ORBIS_NP_AUTH_ERROR_INVALID_ARGUMENT
    return ORBIS_NP_ERROR_USER_NOT_FOUND

# @port core/libraries/np/np_auth.cpp::sceNpAuthGetAuthorizationCodeA sha256=bc13fb2204be2d16 oracle@a3773841
def sceNpAuthGetAuthorizationCodeA(req_id: s32, param: OrbisNpAuthGetAuthorizationCodeParameterA&?, auth_code: mutable OrbisNpAuthorizationCode&?, issuer_id: mutable s32&?) -> s32:
    _ = auth_code
    _ = issuer_id
    if param == null or auth_code == null:
        return ORBIS_NP_AUTH_ERROR_INVALID_ARGUMENT
    if param.size != size_of(OrbisNpAuthGetAuthorizationCodeParameterA).u64():
        return ORBIS_NP_AUTH_ERROR_INVALID_SIZE
    if param.user_id == -1 or param.client_id == null or param.scope == null:
        return ORBIS_NP_AUTH_ERROR_INVALID_ARGUMENT
    return NpAuthProcessSignedOut(req_id)

# @port core/libraries/np/np_auth.cpp::sceNpAuthGetAuthorizationCodeV3 sha256=9c41988bd23c5bb3 oracle@a3773841
def sceNpAuthGetAuthorizationCodeV3(req_id: s32, param: OrbisNpAuthGetAuthorizationCodeParameterA&?, auth_code: mutable OrbisNpAuthorizationCode&?, issuer_id: mutable s32&?) -> s32:
    return sceNpAuthGetAuthorizationCodeA(req_id, param, auth_code, issuer_id)

# @port core/libraries/np/np_auth.cpp::sceNpAuthGetIdToken sha256=08365ab8718811e7 oracle@a3773841
def sceNpAuthGetIdToken(req_id: s32, param: OrbisNpAuthGetIdTokenParameter&?, token: mutable OrbisNpIdToken&?) -> s32:
    _ = req_id
    if param == null or token == null:
        return ORBIS_NP_AUTH_ERROR_INVALID_ARGUMENT
    if param.size != size_of(OrbisNpAuthGetIdTokenParameter).u64():
        return ORBIS_NP_AUTH_ERROR_INVALID_SIZE
    if param.online_id == null or param.client_id == null or param.client_secret == null or param.scope == null:
        return ORBIS_NP_AUTH_ERROR_INVALID_ARGUMENT
    return ORBIS_NP_ERROR_USER_NOT_FOUND

# @port core/libraries/np/np_auth.cpp::sceNpAuthGetIdTokenA sha256=49202a71e1b5d302 oracle@a3773841
def sceNpAuthGetIdTokenA(req_id: s32, param: OrbisNpAuthGetIdTokenParameterA&?, token: mutable OrbisNpIdToken&?) -> s32:
    if param == null or token == null:
        return ORBIS_NP_AUTH_ERROR_INVALID_ARGUMENT
    if param.size != size_of(OrbisNpAuthGetIdTokenParameterA).u64():
        return ORBIS_NP_AUTH_ERROR_INVALID_SIZE
    if param.user_id == -1 or param.client_id == null or param.client_secret == null or param.scope == null:
        return ORBIS_NP_AUTH_ERROR_INVALID_ARGUMENT
    return NpAuthProcessSignedOut(req_id)

# @port core/libraries/np/np_auth.cpp::sceNpAuthGetIdTokenV3 sha256=e12a1f01b1389171 oracle@a3773841
def sceNpAuthGetIdTokenV3(req_id: s32, param: OrbisNpAuthGetIdTokenParameterA&?, token: mutable OrbisNpIdToken&?) -> s32:
    return sceNpAuthGetIdTokenA(req_id, param, token)

# @port core/libraries/np/np_auth.cpp::sceNpAuthSetTimeout sha256=f53f5502a742c2a5 oracle@a3773841
def sceNpAuthSetTimeout(req_id: s32, resolve_retry: s32, resolve_timeout: u32, conn_timeout: u32, send_timeout: u32, recv_timeout: u32) -> s32:
    _ = req_id
    _ = resolve_retry
    _ = resolve_timeout
    _ = conn_timeout
    _ = send_timeout
    _ = recv_timeout
    return ORBIS_OK

# @port core/libraries/np/np_auth.cpp::sceNpAuthAbortRequest sha256=fdada105d85fafbb oracle@a3773841
def sceNpAuthAbortRequest(req_id: s32) -> s32:
    index: s32 = NpAuthReqIndex(req_id)
    if not NpAuthValidIndex(index) or g_np_auth_requests[index].state == NP_AUTH_REQUEST_NONE:
        return ORBIS_NP_AUTH_ERROR_REQUEST_NOT_FOUND
    if g_np_auth_requests[index].state != NP_AUTH_REQUEST_COMPLETE:
        g_np_auth_requests[index].state <- NP_AUTH_REQUEST_ABORTED
    return ORBIS_OK

# @port core/libraries/np/np_auth.cpp::sceNpAuthWaitAsync sha256=24c71e402fc4bee4 oracle@a3773841
def sceNpAuthWaitAsync(req_id: s32, result: mutable s32&?) -> s32:
    if result == null:
        return ORBIS_NP_AUTH_ERROR_INVALID_ARGUMENT
    index: s32 = NpAuthReqIndex(req_id)
    if not NpAuthValidIndex(index) or g_np_auth_requests[index].state == NP_AUTH_REQUEST_NONE:
        return ORBIS_NP_AUTH_ERROR_REQUEST_NOT_FOUND
    if not g_np_auth_requests[index].async_ or g_np_auth_requests[index].state == NP_AUTH_REQUEST_READY:
        return ORBIS_NP_AUTH_ERROR_INVALID_ID
    result <- g_np_auth_requests[index].result
    return ORBIS_OK

# @port core/libraries/np/np_auth.cpp::sceNpAuthPollAsync sha256=a15752730e1eb9b6 oracle@a3773841
def sceNpAuthPollAsync(req_id: s32, result: mutable s32&?) -> s32:
    return sceNpAuthWaitAsync(req_id, result)

# @port core/libraries/np/np_auth.cpp::sceNpAuthDeleteRequest sha256=54ed7d8f500af478 oracle@a3773841
def sceNpAuthDeleteRequest(req_id: s32) -> s32:
    index: s32 = NpAuthReqIndex(req_id)
    if not NpAuthValidIndex(index) or g_np_auth_requests[index].state == NP_AUTH_REQUEST_NONE:
        return ORBIS_NP_AUTH_ERROR_REQUEST_NOT_FOUND
    g_np_auth_requests[index].state <- NP_AUTH_REQUEST_NONE
    g_np_auth_active_requests <- g_np_auth_active_requests - 1
    return ORBIS_OK

