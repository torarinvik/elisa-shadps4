type OrbisNpMatching2ContextId = u16
type OrbisNpMatching2RequestId = u16
type OrbisNpMatching2ServerId = u16
type OrbisNpMatching2WorldId = u32
type OrbisNpMatching2RoomId = u64

const ORBIS_NP_MATCHING2_ERROR_NOT_INITIALIZED: i32 = -2141910015  # 0x80550c01
const ORBIS_NP_MATCHING2_ERROR_ALREADY_INITIALIZED: i32 = -2141910014  # 0x80550c02
const ORBIS_NP_MATCHING2_ERROR_INVALID_ARGUMENT: i32 = -2141909995  # 0x80550c15

global mutable g_np_matching2_initialized: bool = false
global mutable g_np_matching2_next_context: u16 = 1
global mutable g_np_matching2_next_request: u16 = 1

# @port core/libraries/np/np_matching2.cpp::sceNpMatching2Initialize sha256=818a702332cd611f oracle@a3773841
def sceNpMatching2Initialize(param: mutable void&?) -> int:
    _ = param
    if g_np_matching2_initialized:
        return ORBIS_NP_MATCHING2_ERROR_ALREADY_INITIALIZED
    g_np_matching2_initialized <- true
    return ORBIS_OK

# @port core/libraries/np/np_matching2.cpp::sceNpMatching2Terminate sha256=a73da8ced227948e oracle@a3773841
def sceNpMatching2Terminate() -> int:
    if not g_np_matching2_initialized:
        return ORBIS_NP_MATCHING2_ERROR_NOT_INITIALIZED
    g_np_matching2_initialized <- false
    return ORBIS_OK

# @port core/libraries/np/np_matching2.cpp::sceNpMatching2CreateContext sha256=945bc39a7e2c5b10 oracle@a3773841
def sceNpMatching2CreateContext(param: void&?, ctx_id: mutable OrbisNpMatching2ContextId&?) -> int:
    if not g_np_matching2_initialized:
        return ORBIS_NP_MATCHING2_ERROR_NOT_INITIALIZED
    if param == null or ctx_id == null:
        return ORBIS_NP_MATCHING2_ERROR_INVALID_ARGUMENT
    ctx_id <- g_np_matching2_next_context
    g_np_matching2_next_context <- g_np_matching2_next_context + 1
    return ORBIS_OK

# @port core/libraries/np/np_matching2.cpp::sceNpMatching2CreateContextA sha256=2bf93107b15d58d6 oracle@a3773841
def sceNpMatching2CreateContextA(param: void&?, ctx_id: mutable OrbisNpMatching2ContextId&?) -> int:
    return sceNpMatching2CreateContext(param, ctx_id)

# @port core/libraries/np/np_matching2.cpp::sceNpMatching2ContextStart sha256=cabdf5dc210fa72b oracle@a3773841
def sceNpMatching2ContextStart(ctxId: OrbisNpMatching2ContextId, timeout: u64) -> int:
    _ = ctxId
    _ = timeout
    if not g_np_matching2_initialized:
        return ORBIS_NP_MATCHING2_ERROR_NOT_INITIALIZED
    return ORBIS_OK

# @port core/libraries/np/np_matching2.cpp::sceNpMatching2GetServerId sha256=a36c4f3e5542af7c oracle@a3773841
def sceNpMatching2GetServerId(ctxId: OrbisNpMatching2ContextId, serverId: mutable OrbisNpMatching2ServerId&?) -> int:
    _ = ctxId
    if serverId == null:
        return ORBIS_NP_MATCHING2_ERROR_INVALID_ARGUMENT
    serverId <- 1
    return ORBIS_OK

# @port core/libraries/np/np_matching2.cpp::sceNpMatching2SetDefaultRequestOptParam sha256=9ca4798e950e53f4 oracle@a3773841
def sceNpMatching2SetDefaultRequestOptParam(ctxId: OrbisNpMatching2ContextId, opt: void&?) -> int:
    _ = ctxId
    _ = opt
    return ORBIS_OK

# @port core/libraries/np/np_matching2.cpp::sceNpMatching2CreateJoinRoomA sha256=ef591b3372c42be9 oracle@a3773841
def sceNpMatching2CreateJoinRoomA(ctxId: OrbisNpMatching2ContextId, request: void&?, requestId: mutable OrbisNpMatching2RequestId&?) -> int:
    _ = ctxId
    _ = request
    if requestId != null:
        requestId <- g_np_matching2_next_request
        g_np_matching2_next_request <- g_np_matching2_next_request + 1
    return ORBIS_OK

# @port core/libraries/np/np_matching2.cpp::sceNpMatching2GetWorldInfoList sha256=fe7056d15bc8d90b oracle@a3773841
def sceNpMatching2GetWorldInfoList(ctxId: OrbisNpMatching2ContextId, request: void&?, requestId: mutable OrbisNpMatching2RequestId&?) -> int:
    return sceNpMatching2CreateJoinRoomA(ctxId, request, requestId)

# @port core/libraries/np/np_matching2.cpp::sceNpMatching2LeaveRoom sha256=e0b585b00286876f oracle@a3773841
def sceNpMatching2LeaveRoom(ctxId: OrbisNpMatching2ContextId, request: void&?, requestId: mutable OrbisNpMatching2RequestId&?) -> int:
    return sceNpMatching2CreateJoinRoomA(ctxId, request, requestId)

# @port core/libraries/np/np_matching2.cpp::sceNpMatching2SearchRoom sha256=32d502c3b40fedf9 oracle@a3773841
def sceNpMatching2SearchRoom(ctxId: OrbisNpMatching2ContextId, request: void&?, requestId: mutable OrbisNpMatching2RequestId&?) -> int:
