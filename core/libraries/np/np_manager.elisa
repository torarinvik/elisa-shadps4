include "../../user_settings.elisa"

const ORBIS_NP_MANAGER_REQUEST_LIMIT: s32 = 0x20
const ORBIS_NP_MANAGER_REQUEST_ID_OFFSET: s32 = 0x20000000
const ORBIS_NP_STATE_UNKNOWN: u32 = 0
const ORBIS_NP_STATE_SIGNED_OUT: u32 = 1
const ORBIS_NP_STATE_SIGNED_IN: u32 = 2
const ORBIS_NP_REACHABILITY_STATE_UNAVAILABLE: u32 = 0
const ORBIS_NP_REACHABILITY_STATE_AVAILABLE: u32 = 1
const ORBIS_NP_REACHABILITY_STATE_REACHABLE: u32 = 2
const ORBIS_NP_GAME_PRESENCE_STATUS_OFFLINE: u32 = 0
const ORBIS_NP_GAME_PRESENCE_STATUS_ONLINE: u32 = 1

const NP_MANAGER_REQUEST_NONE: u8 = 0
const NP_MANAGER_REQUEST_READY: u8 = 1
const NP_MANAGER_REQUEST_ABORTED: u8 = 2
const NP_MANAGER_REQUEST_COMPLETE: u8 = 3

@fixed_layout
struct OrbisNpCountryCode:
    country_code: mutable u8[2]
    end: mutable u8
    pad: mutable u8

@fixed_layout
struct OrbisNpAgeRestriction:
    country_code: mutable OrbisNpCountryCode
    age: mutable s8
    padding: mutable u8[3]

@fixed_layout
struct OrbisNpContentRestriction:
    size: mutable u64
    default_age_restriction: mutable s8
    padding: mutable u8[3]
    age_restriction_count: mutable s32
    age_restriction: mutable OrbisNpAgeRestriction&?

@fixed_layout
struct OrbisNpDate:
    year: mutable u16
    month: mutable u8
    day: mutable u8

@fixed_layout
struct OrbisNpLanguageCode:
    code: mutable u8[6]
    padding: mutable u8[10]

@fixed_layout
struct OrbisNpParentalControlInfo:
    content_restriction: mutable bool
    chat_restriction: mutable bool
    user_generated_content_restriction: mutable bool

@fixed_layout
struct OrbisNpCheckPlusParameter:
    size: mutable u64
    user_id: mutable s32
    padding: mutable u8[4]
    features: mutable u64
    reserved: mutable u8[32]

@fixed_layout
struct OrbisNpCheckPlusResult:
    authorized: mutable bool
    reserved: mutable u8[32]

@fixed_layout
struct OrbisNpCreateAsyncRequestParameter:
    size: mutable u64
    cpu_affinity_mask: mutable u64
    thread_priority: mutable s32
    padding: mutable u8[4]

@fixed_layout
struct NpManagerRequest:
    state: mutable u8
    async_: mutable bool
    result: mutable s32

global mutable g_np_manager_active_requests: s32 = 0
global mutable g_np_manager_requests: NpManagerRequest[32] = zeroed

def NpManagerReqIndex(req_id: s32) -> s32:
    return req_id - ORBIS_NP_MANAGER_REQUEST_ID_OFFSET - 1

def NpManagerValidIndex(index: s32) -> bool:
    return index >= 0 and index < ORBIS_NP_MANAGER_REQUEST_LIMIT

def NpManagerIsShadNetEnabled() -> bool:
    settings: mutable UserSettingsImpl& = UserSettings_GetInstance()
    _ = UserSettings_Load(settings)
    user_mgr: mutable UserManager& = UserSettings_GetUserManager(settings)
    default_user: User = UserManager_GetDefaultUser(user_mgr)
    return default_user.shadnet_enabled

def NpManagerGetActiveRequestIndex(req_id: s32) -> s32:
    index: s32 = NpManagerReqIndex(req_id)
    if not NpManagerValidIndex(index):
        return -1
    if g_np_manager_requests[index].state == NP_MANAGER_REQUEST_NONE:
        return -1
    return index

def NpManagerProcessRequest(index: s32) -> int:
    if g_np_manager_requests[index].state == NP_MANAGER_REQUEST_COMPLETE:
        g_np_manager_requests[index].result <- ORBIS_NP_ERROR_INVALID_ARGUMENT
        return ORBIS_NP_ERROR_INVALID_ARGUMENT
    if g_np_manager_requests[index].state == NP_MANAGER_REQUEST_ABORTED:
        g_np_manager_requests[index].result <- ORBIS_NP_ERROR_ABORTED
        return ORBIS_NP_ERROR_ABORTED
    g_np_manager_requests[index].state <- NP_MANAGER_REQUEST_COMPLETE
    return ORBIS_OK

def NpManagerCompleteSignedOut(index: s32) -> int:
    g_np_manager_requests[index].result <- ORBIS_NP_ERROR_SIGNED_OUT
    if g_np_manager_requests[index].async_:
        return ORBIS_OK
    return ORBIS_NP_ERROR_SIGNED_OUT

def NpManagerCreateRequest(async_: bool) -> s32:
    if g_np_manager_active_requests == ORBIS_NP_MANAGER_REQUEST_LIMIT:
        return ORBIS_NP_ERROR_REQUEST_MAX
    for i in 0..<ORBIS_NP_MANAGER_REQUEST_LIMIT:
        if g_np_manager_requests[i].state == NP_MANAGER_REQUEST_NONE:
            g_np_manager_requests[i].state <- NP_MANAGER_REQUEST_READY
            g_np_manager_requests[i].async_ <- async_
            g_np_manager_requests[i].result <- 0
            g_np_manager_active_requests <- g_np_manager_active_requests + 1
            return ORBIS_NP_MANAGER_REQUEST_ID_OFFSET + i + 1
    return ORBIS_NP_ERROR_REQUEST_MAX

# @port core/libraries/np/np_manager.cpp::sceNpCreateRequest sha256=3feb25e4b174a106 oracle@a3773841
def sceNpCreateRequest() -> s32:
    return NpManagerCreateRequest(false)

# @port core/libraries/np/np_manager.cpp::sceNpCreateAsyncRequest sha256=a6c1fd106d2b8ae3 oracle@a3773841
def sceNpCreateAsyncRequest(param: OrbisNpCreateAsyncRequestParameter&?) -> s32:
    if param == null:
        return ORBIS_NP_ERROR_INVALID_ARGUMENT
    if param.size != size_of(OrbisNpCreateAsyncRequestParameter).u64():
        return ORBIS_NP_ERROR_INVALID_SIZE
    return NpManagerCreateRequest(true)

# @port core/libraries/np/np_manager.cpp::sceNpCheckNpAvailability sha256=3b842cc388362f9b oracle@a3773841
def sceNpCheckNpAvailability(req_id: s32, online_id: mutable OrbisNpOnlineId&?) -> int:
    if online_id == null:
        return ORBIS_NP_ERROR_INVALID_ARGUMENT
    index: s32 = NpManagerGetActiveRequestIndex(req_id)
    if index < 0:
        return ORBIS_NP_ERROR_REQUEST_NOT_FOUND
    request_status: int = NpManagerProcessRequest(index)
    if request_status != ORBIS_OK:
        return request_status
    if not NpManagerIsShadNetEnabled():
        return NpManagerCompleteSignedOut(index)
    g_np_manager_requests[index].result <- ORBIS_OK
    return ORBIS_OK

# @port core/libraries/np/np_manager.cpp::sceNpCheckNpAvailabilityA sha256=d7d5a1adb9caa445 oracle@a3773841
def sceNpCheckNpAvailabilityA(req_id: s32, user_id: s32) -> int:
    _ = user_id
    index: s32 = NpManagerGetActiveRequestIndex(req_id)
    if index < 0:
        return ORBIS_NP_ERROR_REQUEST_NOT_FOUND
    request_status: int = NpManagerProcessRequest(index)
    if request_status != ORBIS_OK:
        return request_status
    if not NpManagerIsShadNetEnabled():
        return NpManagerCompleteSignedOut(index)
    g_np_manager_requests[index].result <- ORBIS_OK
    return ORBIS_OK

# @port core/libraries/np/np_manager.cpp::sceNpCheckNpReachability sha256=2d553ff0cb91dd7b oracle@a3773841
def sceNpCheckNpReachability(req_id: s32, user_id: s32, state: mutable u32&?) -> int:
    _ = user_id
    index: s32 = NpManagerGetActiveRequestIndex(req_id)
    if index < 0:
        return ORBIS_NP_ERROR_REQUEST_NOT_FOUND
    request_status: int = NpManagerProcessRequest(index)
    if request_status != ORBIS_OK:
        return request_status
    if not NpManagerIsShadNetEnabled():
        if state != null:
            state <- ORBIS_NP_REACHABILITY_STATE_UNAVAILABLE
        return NpManagerCompleteSignedOut(index)
    if state != null:
        state <- ORBIS_NP_REACHABILITY_STATE_REACHABLE
    g_np_manager_requests[index].result <- ORBIS_OK
    return ORBIS_OK

# @port core/libraries/np/np_manager.cpp::sceNpCheckPlus sha256=6e3c05ad78e8790b oracle@a3773841
def sceNpCheckPlus(req_id: s32, param: OrbisNpCheckPlusParameter&?, result: mutable OrbisNpCheckPlusResult&?) -> int:
    if req_id == 0 or param == null or result == null:
        return ORBIS_NP_ERROR_INVALID_ARGUMENT
    if param.size != size_of(OrbisNpCheckPlusParameter).u64():
        return ORBIS_NP_ERROR_INVALID_SIZE
    if param.features < 1u64 or param.features > 3u64:
        return ORBIS_NP_ERROR_INVALID_ARGUMENT
    index: s32 = NpManagerGetActiveRequestIndex(req_id)
    if index < 0:
        return ORBIS_NP_ERROR_REQUEST_NOT_FOUND
    request_status: int = NpManagerProcessRequest(index)
    if request_status != ORBIS_OK:
        return request_status
    if not NpManagerIsShadNetEnabled():
        result.authorized <- false
        return NpManagerCompleteSignedOut(index)
    result.authorized <- true
    g_np_manager_requests[index].result <- ORBIS_OK
    return ORBIS_OK

# @port core/libraries/np/np_manager.cpp::sceNpGetAccountLanguage sha256=221a4ab71e5c1da1 oracle@a3773841
def sceNpGetAccountLanguage(req_id: s32, online_id: mutable OrbisNpOnlineId&?, lang_code: mutable OrbisNpLanguageCode&?) -> int:
    if online_id == null or lang_code == null:
        return ORBIS_NP_ERROR_INVALID_ARGUMENT
    index: s32 = NpManagerGetActiveRequestIndex(req_id)
    if index < 0:
        return ORBIS_NP_ERROR_REQUEST_NOT_FOUND
    request_status: int = NpManagerProcessRequest(index)
    if request_status != ORBIS_OK:
        return request_status
    if not NpManagerIsShadNetEnabled():
        return NpManagerCompleteSignedOut(index)
    lang_code.code[0] <- 0
    lang_code.code[1] <- 0
    lang_code.code[2] <- 0
    g_np_manager_requests[index].result <- ORBIS_OK
    return ORBIS_OK

