        return ORBIS_NP_ERROR_INVALID_ARGUMENT
    result <- NpManagerIsShadNetEnabled()
    return ORBIS_OK

# @port core/libraries/np/np_manager.cpp::sceNpSetContentRestriction sha256=d5d2d74ee2698c4c oracle@a3773841
def sceNpSetContentRestriction(restriction: OrbisNpContentRestriction&?) -> int:
    if restriction == null:
        return ORBIS_NP_ERROR_INVALID_ARGUMENT
    if restriction.size != size_of(OrbisNpContentRestriction).u64():
        return ORBIS_NP_ERROR_INVALID_SIZE
    if restriction.default_age_restriction < 0 or restriction.age_restriction_count > 0x100:
        return ORBIS_NP_ERROR_INVALID_ARGUMENT
    if restriction.age_restriction_count > 0 and restriction.age_restriction == null:
        return ORBIS_NP_ERROR_INVALID_ARGUMENT
    return ORBIS_OK

# @port core/libraries/np/np_manager.cpp::sceNpSetNpTitleId sha256=4c64a4240717b627 oracle@a3773841
