# @port core/libraries/np/np_manager.cpp::sceNpGetParentalControlInfo sha256=8c0c2bb82bfe8f71 oracle@a3773841
def sceNpGetParentalControlInfo(req_id: s32, online_id: mutable OrbisNpOnlineId&?, age: mutable s8&?, info: mutable OrbisNpParentalControlInfo&?) -> int:
    if online_id == null or age == null or info == null:
        return ORBIS_NP_ERROR_INVALID_ARGUMENT
    index: s32 = NpManagerGetActiveRequestIndex(req_id)
    if index < 0:
        return ORBIS_NP_ERROR_REQUEST_NOT_FOUND
    request_status: int = NpManagerProcessRequest(index)
    if request_status != ORBIS_OK:
        return request_status
    if not NpManagerIsShadNetEnabled():
        age <- 13
        info.content_restriction <- false
        info.chat_restriction <- false
        info.user_generated_content_restriction <- false
        return NpManagerCompleteSignedOut(index)
    age <- 13
    info.content_restriction <- false
    info.chat_restriction <- false
    info.user_generated_content_restriction <- false
    g_np_manager_requests[index].result <- ORBIS_OK
    return ORBIS_OK

# @port core/libraries/np/np_manager.cpp::sceNpGetParentalControlInfoA sha256=648b488bba284197 oracle@a3773841
def sceNpGetParentalControlInfoA(req_id: s32, user_id: s32, age: mutable s8&?, info: mutable OrbisNpParentalControlInfo&?) -> int:
    _ = user_id
    if age == null or info == null:
        return ORBIS_NP_ERROR_INVALID_ARGUMENT
    index: s32 = NpManagerGetActiveRequestIndex(req_id)
    if index < 0:
        return ORBIS_NP_ERROR_REQUEST_NOT_FOUND
    request_status: int = NpManagerProcessRequest(index)
    if request_status != ORBIS_OK:
        return request_status
    if not NpManagerIsShadNetEnabled():
        age <- 13
        info.content_restriction <- false
        info.chat_restriction <- false
        info.user_generated_content_restriction <- false
        return NpManagerCompleteSignedOut(index)
    age <- 13
    info.content_restriction <- false
    info.chat_restriction <- false
    info.user_generated_content_restriction <- false
    g_np_manager_requests[index].result <- ORBIS_OK
    return ORBIS_OK

# @port core/libraries/np/np_manager.cpp::sceNpGetGamePresenceStatus sha256=05e4dbcfec2e8d76 oracle@a3773841
def sceNpGetGamePresenceStatus(online_id: mutable OrbisNpOnlineId&?, status: mutable u32&?) -> int:
    if online_id == null or status == null:
        return ORBIS_NP_ERROR_INVALID_ARGUMENT
    status <- ORBIS_NP_GAME_PRESENCE_STATUS_ONLINE if NpManagerIsShadNetEnabled() else ORBIS_NP_GAME_PRESENCE_STATUS_OFFLINE
    return ORBIS_OK

# @port core/libraries/np/np_manager.cpp::sceNpGetGamePresenceStatusA sha256=f98a5c5469455989 oracle@a3773841
def sceNpGetGamePresenceStatusA(user_id: s32, status: mutable u32&?) -> int:
    _ = user_id
    if status == null:
        return ORBIS_NP_ERROR_INVALID_ARGUMENT
    status <- ORBIS_NP_GAME_PRESENCE_STATUS_ONLINE if NpManagerIsShadNetEnabled() else ORBIS_NP_GAME_PRESENCE_STATUS_OFFLINE
    return ORBIS_OK

# @port core/libraries/np/np_manager.cpp::sceNpAbortRequest sha256=3b305470efd1002c oracle@a3773841
def sceNpAbortRequest(req_id: s32) -> int:
    index: s32 = NpManagerGetActiveRequestIndex(req_id)
    if index < 0:
        return ORBIS_NP_ERROR_REQUEST_NOT_FOUND
    if g_np_manager_requests[index].state != NP_MANAGER_REQUEST_COMPLETE:
        g_np_manager_requests[index].state <- NP_MANAGER_REQUEST_ABORTED
    return ORBIS_OK

# @port core/libraries/np/np_manager.cpp::sceNpWaitAsync sha256=882bcc2d3c2e3c2b oracle@a3773841
def sceNpWaitAsync(req_id: s32, result: mutable s32&?) -> int:
    if result == null:
        return ORBIS_NP_ERROR_INVALID_ARGUMENT
    index: s32 = NpManagerGetActiveRequestIndex(req_id)
    if index < 0:
        return ORBIS_NP_ERROR_REQUEST_NOT_FOUND
    if not g_np_manager_requests[index].async_ or g_np_manager_requests[index].state == NP_MANAGER_REQUEST_READY:
        return ORBIS_NP_ERROR_INVALID_ID
    result <- g_np_manager_requests[index].result
    return ORBIS_OK

# @port core/libraries/np/np_manager.cpp::sceNpPollAsync sha256=e20693fbc79a0b6a oracle@a3773841
def sceNpPollAsync(req_id: s32, result: mutable s32&?) -> int:
    return sceNpWaitAsync(req_id, result)

# @port core/libraries/np/np_manager.cpp::sceNpDeleteRequest sha256=be8b335c25c2f459 oracle@a3773841
def sceNpDeleteRequest(req_id: s32) -> int:
    index: s32 = NpManagerGetActiveRequestIndex(req_id)
    if index < 0:
        return ORBIS_NP_ERROR_REQUEST_NOT_FOUND
    g_np_manager_requests[index].state <- NP_MANAGER_REQUEST_NONE
    g_np_manager_requests[index].async_ <- false
    g_np_manager_requests[index].result <- 0
    g_np_manager_active_requests <- g_np_manager_active_requests - 1
    return ORBIS_OK

# @port core/libraries/np/np_manager.cpp::sceNpGetAccountCountry sha256=6d33eec8aa22a3a7 oracle@a3773841
def sceNpGetAccountCountry(online_id: mutable OrbisNpOnlineId&?, country_code: mutable OrbisNpCountryCode&?) -> int:
    if online_id == null or country_code == null:
        return ORBIS_NP_ERROR_INVALID_ARGUMENT
    if not NpManagerIsShadNetEnabled():
        return ORBIS_NP_ERROR_SIGNED_OUT
    country_code.country_code[0] <- 'u'.u8()
    country_code.country_code[1] <- 's'.u8()
    country_code.end <- 0
    return ORBIS_OK

# @port core/libraries/np/np_manager.cpp::sceNpGetAccountCountryA sha256=4c05bc9680fd97a0 oracle@a3773841
def sceNpGetAccountCountryA(user_id: s32, country_code: mutable OrbisNpCountryCode&?) -> int:
