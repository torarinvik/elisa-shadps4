@fixed_layout
struct OrbisNpWebApiRequest:
    request_id: mutable s64
    http_request_id: mutable s32
    status_code: mutable s32
    aborted: mutable bool
    state: mutable u8

def getHttpRequestIdFromRequest(request: mutable OrbisNpWebApiRequest&?) -> s32:
    if request == null:
        return -1
    return request.http_request_id

def getHttpStatusCodeInternal(requestId: s64, out_status_code: mutable s32&?) -> s32:
    if requestId <= 0:
        return ORBIS_NP_WEBAPI_ERROR_REQUEST_NOT_FOUND
    if out_status_code == null:
        return ORBIS_NP_WEBAPI_ERROR_INVALID_ARGUMENT
    out_status_code <- 200
    return ORBIS_OK

def setRequestEndTime(request: mutable OrbisNpWebApiRequest&?) -> void:
    _ = request

def clearRequestEndTime(req: mutable OrbisNpWebApiRequest&?) -> void:
    _ = req

def hasRequestTimedOut(request: mutable OrbisNpWebApiRequest&?) -> bool:
    _ = request
    return false

def isRequestAborted(request: mutable OrbisNpWebApiRequest&?) -> bool:
    if request == null:
        return false
    return request.aborted

def setRequestState(request: mutable OrbisNpWebApiRequest&?, state: u8) -> void:
    if request != null:
        request.state <- state

def copyRequestData(request: mutable OrbisNpWebApiRequest&?, data: mutable void&?, size: u64) -> u64:
    _ = request
    _ = data
    return size

def readDataInternal(requestId: s64, pData: mutable void&?, size: u64) -> s32:
    return sceNpWebApiReadData(requestId, pData, size)

