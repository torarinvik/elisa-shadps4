global mutable g_np_commerce_dialog_status: u32 = ORBIS_COMMON_DIALOG_STATUS_NONE
global mutable g_np_commerce_dialog_result: u32 = ORBIS_COMMON_DIALOG_RESULT_OK

# @port core/libraries/np/np_commerce.cpp::sceNpCommerceDialogClose sha256=0f791775ac99b1df oracle@a3773841
def sceNpCommerceDialogClose() -> int:
    if g_np_commerce_dialog_status == ORBIS_COMMON_DIALOG_STATUS_NONE:
        return ORBIS_COMMON_DIALOG_ERROR_NOT_INITIALIZED
    if g_np_commerce_dialog_status != ORBIS_COMMON_DIALOG_STATUS_FINISHED:
        return ORBIS_COMMON_DIALOG_ERROR_NOT_FINISHED
    g_np_commerce_dialog_status <- ORBIS_COMMON_DIALOG_STATUS_INITIALIZED
    return ORBIS_OK

# @port core/libraries/np/np_commerce.cpp::sceNpCommerceDialogGetResult sha256=268300dca1269d40 oracle@a3773841
def sceNpCommerceDialogGetResult(result: mutable s32&?) -> int:
    if result == null:
        return ORBIS_COMMON_DIALOG_ERROR_ARG_NULL
    if g_np_commerce_dialog_status != ORBIS_COMMON_DIALOG_STATUS_FINISHED:
        return ORBIS_COMMON_DIALOG_ERROR_NOT_FINISHED
    result <- g_np_commerce_dialog_result.cast[s32]
    return ORBIS_OK

# @port core/libraries/np/np_commerce.cpp::sceNpCommerceDialogGetStatus sha256=67c41195acc648e0 oracle@a3773841
def sceNpCommerceDialogGetStatus() -> s8:
    return g_np_commerce_dialog_status.cast[s8]

# @port core/libraries/np/np_commerce.cpp::sceNpCommerceDialogInitialize sha256=3f14b7b60d5182df oracle@a3773841
def sceNpCommerceDialogInitialize() -> int:
    if g_np_commerce_dialog_status != ORBIS_COMMON_DIALOG_STATUS_NONE:
        return ORBIS_COMMON_DIALOG_ERROR_ALREADY_INITIALIZED
    g_np_commerce_dialog_status <- ORBIS_COMMON_DIALOG_STATUS_INITIALIZED
    return ORBIS_OK

# @port core/libraries/np/np_commerce.cpp::sceNpCommerceDialogInitializeInternal sha256=0456aee721571e89 oracle@a3773841
def sceNpCommerceDialogInitializeInternal() -> int:
    return sceNpCommerceDialogInitialize()

# @port core/libraries/np/np_commerce.cpp::sceNpCommerceDialogOpen sha256=e1991b5ee0045258 oracle@a3773841
def sceNpCommerceDialogOpen(check: s64) -> s16:
    _ = check
    if g_np_commerce_dialog_status != ORBIS_COMMON_DIALOG_STATUS_INITIALIZED:
        return ORBIS_OK.cast[s16]
    g_np_commerce_dialog_status <- ORBIS_COMMON_DIALOG_STATUS_FINISHED
    g_np_commerce_dialog_result <- ORBIS_COMMON_DIALOG_RESULT_USER_CANCELED
    return ORBIS_OK.cast[s16]

# @port core/libraries/np/np_commerce.cpp::sceNpCommerceDialogTerminate sha256=e43f1fe2a3ff4d15 oracle@a3773841
def sceNpCommerceDialogTerminate() -> int:
    if g_np_commerce_dialog_status == ORBIS_COMMON_DIALOG_STATUS_NONE:
        return ORBIS_COMMON_DIALOG_ERROR_NOT_INITIALIZED
    if g_np_commerce_dialog_status == ORBIS_COMMON_DIALOG_STATUS_RUNNING:
        return ORBIS_COMMON_DIALOG_ERROR_NOT_FINISHED
    g_np_commerce_dialog_status <- ORBIS_COMMON_DIALOG_STATUS_NONE
    return ORBIS_OK

# @port core/libraries/np/np_commerce.cpp::sceNpCommerceDialogUpdateStatus sha256=5973522ec18245f7 oracle@a3773841
def sceNpCommerceDialogUpdateStatus() -> int:
    return g_np_commerce_dialog_status.cast[int]

# @port core/libraries/np/np_commerce.cpp::sceNpCommerceHidePsStoreIcon sha256=5173479134b66138 oracle@a3773841
def sceNpCommerceHidePsStoreIcon() -> int:
    return ORBIS_OK

# @port core/libraries/np/np_commerce.cpp::sceNpCommerceSetPsStoreIconLayout sha256=b5932a174877d0bb oracle@a3773841
def sceNpCommerceSetPsStoreIconLayout(layout: s32) -> int:
    _ = layout
    return ORBIS_OK

# @port core/libraries/np/np_commerce.cpp::sceNpCommerceShowPsStoreIcon sha256=59b037bf59eb777c oracle@a3773841
def sceNpCommerceShowPsStoreIcon(icon: s16) -> int:
    _ = icon
    return ORBIS_OK
