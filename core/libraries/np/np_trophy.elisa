include "../error_codes.elisa"
include "./np_types.elisa"
include "./np_trophy_error.elisa"

type OrbisNpTrophyContext = s32
type OrbisNpTrophyHandle = s32
type OrbisNpTrophyId = s32
type OrbisNpTrophyGroupId = s32

const ORBIS_NP_TROPHY_CONTEXT_LIMIT: s32 = 4
const ORBIS_NP_TROPHY_HANDLE_LIMIT: s32 = 4

global mutable g_np_trophy_context_used: bool[4] = zeroed
global mutable g_np_trophy_handle_used: bool[4] = zeroed

def NpTrophyAllocContext() -> s32:
    for i in 0..<ORBIS_NP_TROPHY_CONTEXT_LIMIT:
        if not g_np_trophy_context_used[i]:
            g_np_trophy_context_used[i] <- true
            return i + 1
    return 0

def NpTrophyAllocHandle() -> s32:
    for i in 0..<ORBIS_NP_TROPHY_HANDLE_LIMIT:
        if not g_np_trophy_handle_used[i]:
            g_np_trophy_handle_used[i] <- true
            return i + 1
    return 0

def NpTrophyValidContext(trophy_context: OrbisNpTrophyContext) -> bool:
    idx: s32 = trophy_context - 1
    return idx >= 0 and idx < ORBIS_NP_TROPHY_CONTEXT_LIMIT and g_np_trophy_context_used[idx]

def NpTrophyValidHandle(handle: OrbisNpTrophyHandle) -> bool:
    idx: s32 = handle - 1
    return idx >= 0 and idx < ORBIS_NP_TROPHY_HANDLE_LIMIT and g_np_trophy_handle_used[idx]

# @port core/libraries/np/np_trophy.cpp::sceNpTrophyCreateContext sha256=54b310ce8b5abb3d oracle@a3773841
def sceNpTrophyCreateContext(trophy_context: mutable OrbisNpTrophyContext&?, user_id: s32, service_label: OrbisNpServiceLabel, options: u64) -> s32:
    _ = user_id
    _ = service_label
    _ = options
    if trophy_context == null:
        return ORBIS_NP_TROPHY_ERROR_INVALID_ARGUMENT
    id: s32 = NpTrophyAllocContext()
    if id == 0:
        return ORBIS_NP_TROPHY_ERROR_CONTEXT_EXCEEDS_MAX
    trophy_context <- id
    return ORBIS_OK

# @port core/libraries/np/np_trophy.cpp::sceNpTrophyCreateHandle sha256=07a5c19cf0200b58 oracle@a3773841
def sceNpTrophyCreateHandle(handle: mutable OrbisNpTrophyHandle&?) -> s32:
    if handle == null:
        return ORBIS_NP_TROPHY_ERROR_INVALID_ARGUMENT
    id: s32 = NpTrophyAllocHandle()
    if id == 0:
        return ORBIS_NP_TROPHY_ERROR_HANDLE_EXCEEDS_MAX
    handle <- id
    return ORBIS_OK

# @port core/libraries/np/np_trophy.cpp::sceNpTrophyDestroyContext sha256=53ece992717d280e oracle@a3773841
def sceNpTrophyDestroyContext(trophy_context: OrbisNpTrophyContext) -> int:
    if not NpTrophyValidContext(trophy_context):
        return ORBIS_NP_TROPHY_ERROR_INVALID_CONTEXT
    g_np_trophy_context_used[trophy_context - 1] <- false
    return ORBIS_OK

# @port core/libraries/np/np_trophy.cpp::sceNpTrophyDestroyHandle sha256=e6ac4100aea90454 oracle@a3773841
def sceNpTrophyDestroyHandle(handle: OrbisNpTrophyHandle) -> s32:
    if not NpTrophyValidHandle(handle):
        return ORBIS_NP_TROPHY_ERROR_INVALID_HANDLE
    g_np_trophy_handle_used[handle - 1] <- false
    return ORBIS_OK

# @port core/libraries/np/np_trophy.cpp::sceNpTrophyRegisterContext sha256=1ad8d4b2e9d65b5c oracle@a3773841
def sceNpTrophyRegisterContext(trophy_context: OrbisNpTrophyContext, handle: OrbisNpTrophyHandle, statusCb: void&?, arg: void&?, options: u64) -> int:
    _ = statusCb
    _ = arg
    _ = options
    if not NpTrophyValidContext(trophy_context):
        return ORBIS_NP_TROPHY_ERROR_INVALID_CONTEXT
    if not NpTrophyValidHandle(handle):
        return ORBIS_NP_TROPHY_ERROR_INVALID_HANDLE
    return ORBIS_OK

# @port core/libraries/np/np_trophy.cpp::sceNpTrophyUnlockTrophy sha256=fe40f4fd66fd4ef0 oracle@a3773841
def sceNpTrophyUnlockTrophy(trophy_context: OrbisNpTrophyContext, handle: OrbisNpTrophyHandle, trophyId: OrbisNpTrophyId, platinumId: mutable OrbisNpTrophyId&?) -> int:
    _ = platinumId
    if trophyId < 0:
        return ORBIS_NP_TROPHY_ERROR_INVALID_TROPHY_ID
    if not NpTrophyValidContext(trophy_context):
        return ORBIS_NP_TROPHY_ERROR_INVALID_CONTEXT
    if not NpTrophyValidHandle(handle):
        return ORBIS_NP_TROPHY_ERROR_INVALID_HANDLE
    return ORBIS_OK

# @port core/libraries/np/np_trophy.cpp::sceNpTrophyGetGameIcon sha256=a9b2a11ef6291649 oracle@a3773841
def sceNpTrophyGetGameIcon(trophy_context: OrbisNpTrophyContext, handle: OrbisNpTrophyHandle, buffer: mutable void&?, size: mutable u64&?) -> int:
    _ = buffer
    _ = size
    if not NpTrophyValidContext(trophy_context):
        return ORBIS_NP_TROPHY_ERROR_INVALID_CONTEXT
    if not NpTrophyValidHandle(handle):
        return ORBIS_NP_TROPHY_ERROR_INVALID_HANDLE
    return ORBIS_NP_TROPHY_ERROR_ICON_FILE_NOT_FOUND

# @port core/libraries/np/np_trophy.cpp::sceNpTrophyGetGameInfo sha256=ec07342334dc0368 oracle@a3773841
def sceNpTrophyGetGameInfo(trophy_context: OrbisNpTrophyContext, handle: OrbisNpTrophyHandle, gameInfo: mutable void&?, data: mutable void&?) -> int:
    _ = gameInfo
    _ = data
    if not NpTrophyValidContext(trophy_context):
        return ORBIS_NP_TROPHY_ERROR_INVALID_CONTEXT
    if not NpTrophyValidHandle(handle):
        return ORBIS_NP_TROPHY_ERROR_INVALID_HANDLE
    return ORBIS_NP_TROPHY_ERROR_NOT_REGISTERED

# @port core/libraries/np/np_trophy.cpp::sceNpTrophyGetGroupIcon sha256=c8d0d379b388f5e5 oracle@a3773841
def sceNpTrophyGetGroupIcon(trophy_context: OrbisNpTrophyContext, handle: OrbisNpTrophyHandle, groupId: OrbisNpTrophyGroupId, buffer: mutable void&?, size: mutable u64&?) -> int:
    _ = trophy_context
    _ = handle
    _ = groupId
    _ = buffer
    _ = size
    return ORBIS_OK

# @port core/libraries/np/np_trophy.cpp::sceNpTrophyGetTrophyUnlockState sha256=e0f3f6e7b6965e68 oracle@a3773841
def sceNpTrophyGetTrophyUnlockState(trophy_context: OrbisNpTrophyContext, handle: OrbisNpTrophyHandle, flags: mutable void&?, count: mutable u32&?) -> s32:
    _ = flags
    if count != null:
        count <- 0
    if not NpTrophyValidContext(trophy_context):
        return ORBIS_NP_TROPHY_ERROR_INVALID_CONTEXT
    if not NpTrophyValidHandle(handle):
        return ORBIS_NP_TROPHY_ERROR_INVALID_HANDLE
    return ORBIS_OK

# @port core/libraries/np/np_trophy.cpp::sceNpTrophyAbortHandle sha256=d01ac41f9037a4e2 oracle@a3773841
def sceNpTrophyAbortHandle(handle: OrbisNpTrophyHandle) -> int:
    if not NpTrophyValidHandle(handle):
        return ORBIS_NP_TROPHY_ERROR_INVALID_HANDLE
    return ORBIS_OK

# @port core/libraries/np/np_trophy.cpp::sceNpTrophyCaptureScreenshot sha256=e2fa3405dc12896c oracle@a3773841
