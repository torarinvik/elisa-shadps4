    return ORBIS_OK

def sceSharePlaySetProhibition() -> int:
    return ORBIS_OK

def sceSharePlaySetProhibitionModeWithAppId() -> int:
    return ORBIS_OK

def sceSharePlayStartStandby() -> int:
    return ORBIS_OK

def sceSharePlayStartStreaming() -> int:
    return ORBIS_OK

def sceSharePlayStopStandby() -> int:
    return ORBIS_OK

def sceSharePlayStopStreaming() -> int:
    return ORBIS_OK

def sceSharePlayTerminate() -> int:
    return ORBIS_OK

