include "../error_codes.elisa"

const ORBIS_SHARE_PLAY_CONNECTION_STATUS_DORMANT: int = 0x00
const ORBIS_SHARE_PLAY_CONNECTION_STATUS_READY: int = 0x01
const ORBIS_SHARE_PLAY_CONNECTION_STATUS_CONNECTED: int = 0x02

type OrbisUserServiceUserId = int

@fixed_layout
struct OrbisNpOnlineId:
    data: mutable u8[16]
    term: mutable i8
    dummy: mutable i8[3]

@fixed_layout
struct OrbisSharePlayConnectionInfo:
    status: mutable int
    mode: mutable int
    host_online_id: mutable OrbisNpOnlineId
    visitor_online_id: mutable OrbisNpOnlineId
    host_user_id: mutable OrbisUserServiceUserId
    visitor_user_id: mutable OrbisUserServiceUserId

def sceSharePlayCrashDaemon() -> int:
    return ORBIS_OK

def sceSharePlayGetCurrentConnectionInfo(pInfo: mutable OrbisSharePlayConnectionInfo&?) -> int:
    if pInfo == null:
        return ORBIS_OK
    pInfo.status <- ORBIS_SHARE_PLAY_CONNECTION_STATUS_DORMANT
    pInfo.mode <- 0
    pInfo.host_online_id <- zeroed
    pInfo.visitor_online_id <- zeroed
    pInfo.host_user_id <- 0
    pInfo.visitor_user_id <- 0
    return ORBIS_OK

def sceSharePlayGetCurrentConnectionInfoA() -> int:
    return ORBIS_OK

def sceSharePlayGetCurrentInfo() -> int:
    return ORBIS_OK

