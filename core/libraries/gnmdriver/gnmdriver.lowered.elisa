struct Devtools_Widget_PM4Header:
    reserved: mutable u32
    count: mutable u32
    type: mutable u32
    u32All: mutable u32

struct Devtools_Widget_PushMarker:
    name: mutable static u8&

struct Devtools_Widget_BatchBegin:
    id: mutable u32

struct Devtools_Widget_BatchInfo:
    id: mutable u32
    marker: mutable static u8&
    start_addr: mutable usize
    end_addr: mutable usize
    command_addr: mutable usize
    type: mutable u32
    bypass: mutable bool

enum Devtools_Widget_GPUEventKind:
    PushMarker
    PopMarker
    BatchBegin
    BatchInfo

struct Devtools_Widget_GPUEvent:
    kind: mutable Devtools_Widget_GPUEventKind
    push_marker: mutable Devtools_Widget_PushMarker
    batch_begin: mutable Devtools_Widget_BatchBegin
    batch_info: mutable Devtools_Widget_BatchInfo

def Devtools_Widget_PM4HeaderFromU32(value: u32) -> Devtools_Widget_PM4Header:
    return Devtools_Widget_PM4Header((value & 0xffff), (((value >> 16)) & 0x3fff), (((value >> 30)) & 0x3), value)

def Devtools_Widget_PM4HeaderToU32(header: Devtools_Widget_PM4Header) -> u32:
    return ((((header.reserved & 0xffff)) | ((((header.count & 0x3fff)) << 16))) | ((((header.type & 0x3)) << 30)))

def Devtools_Widget_IsDrawCall(opcode: u32) -> bool:
    if (opcode == PM4ItOpcode_DrawIndex2):
        return true
    if (opcode == PM4ItOpcode_DrawIndexOffset2):
        return true
    if (opcode == PM4ItOpcode_DrawIndexAuto):
        return true
    if (opcode == PM4ItOpcode_DrawIndirect):
        return true
    if (opcode == PM4ItOpcode_DrawIndexIndirect):
        return true
    if (opcode == PM4ItOpcode_DispatchDirect):
        return true
    if (opcode == PM4ItOpcode_DispatchIndirect):
        return true
    return false

type s32 = i32

type s64 = i64

type OrbisKernelEqueue = s64

type VAddr = u64

@fixed_layout
struct OrbisKernelEvent:
    ident: mutable u64
    filter: mutable i16
    flags: mutable u16
    fflags: mutable u32
    data: mutable u64
    udata: mutable void&?

const GNM_MAX_COMPUTE_QUEUES: int = 64

const GNM_NUM_COMPUTE_PIPES: int = 4

const GNM_QUEUES_PER_PIPE: int = 16

const GNM_INVALID_QUEUE_ADDR: u64 = 0xffffffffffffffff

const ORBIS_GNM_TESSELLATION_FALLBACK_ADDR: u64 = 0x100000000000

const GNM_TESSELLATION_OFFCHIP_SIZE: int = 0x800000

const GNM_INDIRECT_SGPR_OFFSETS: u32[7] = [0, 0, 0x4c, 0, 0xcc, 0, 0x14c]

const PM4CmdNop_DebugMarkerPush: u32 = 0x68750001

const PM4CmdNop_DebugMarkerPop: u32 = 0x68750002

const PM4CmdNop_DebugSetMarker: u32 = 0x68750003

const PM4CmdNop_DebugColorMarkerPush: u32 = 0x6875000e

const PM4_TYPE3_PACKET: u32 = 3

@fixed_layout
struct GnmComputeQueue:
    used: mutable bool
    pipe_id: mutable u32
    queue_id: mutable u32
    ring_base_addr: mutable VAddr
    ring_size_dw: mutable u32
    read_ptr_addr: mutable u32&?
    next_offs_dw: mutable u32

global mutable g_submissions_lock: u32 = 0

global mutable g_frames_submitted: u64 = 0

global mutable g_send_init_packet: bool = true

global mutable g_sdk_version: s32 = 0

global mutable g_tessellation_factors_ring_addr: u64 = GNM_INVALID_QUEUE_ADDR

global mutable g_compute_queues: array[GnmComputeQueue, GNM_MAX_COMPUTE_QUEUES] = zeroed

def gnm_c_string_length(value: u8&) -> u32:
    len: mutable u32 = 0
    while (value[len] != 0):
        len <- (len + 1)
    return len

def gnm_create_pm4_header(opcode: u32, payload_dwords: u32) -> u32:
    return ((((PM4_TYPE3_PACKET << 30)) | (((((payload_dwords - 1)) << 16)))) | ((opcode << 8)))

def gnm_is_power_of_two(value: u32) -> bool:
    if (value == 0):
        return false
    return (((value & ((value - 1)))) == 0)

def gnm_write_set_sh_reg_2(cmdbuf: u32&?, index: u32, reg: u32, a: u32) -> u32:
    cmdbuf[index] <- gnm_create_pm4_header(PM4ItOpcode_SetShReg, 3)
    cmdbuf[(index + 1)] <- reg
    cmdbuf[(index + 2)] <- a
    return (index + 3)

def gnm_write_set_sh_reg_3(cmdbuf: u32&?, index: u32, reg: u32, a: u32, b: u32) -> u32:
    cmdbuf[index] <- gnm_create_pm4_header(PM4ItOpcode_SetShReg, 4)
    cmdbuf[(index + 1)] <- reg
    cmdbuf[(index + 2)] <- a
    cmdbuf[(index + 3)] <- b
    return (index + 4)

def gnm_write_set_ctx_reg_2(cmdbuf: u32&?, index: u32, reg: u32, a: u32) -> u32:
    cmdbuf[index] <- gnm_create_pm4_header(PM4ItOpcode_SetContextReg, 3)
    cmdbuf[(index + 1)] <- reg
    cmdbuf[(index + 2)] <- a
    return (index + 3)

def gnm_write_set_ctx_reg_3(cmdbuf: u32&?, index: u32, reg: u32, a: u32, b: u32) -> u32:
    cmdbuf[index] <- gnm_create_pm4_header(PM4ItOpcode_SetContextReg, 4)
    cmdbuf[(index + 1)] <- reg
    cmdbuf[(index + 2)] <- a
    cmdbuf[(index + 3)] <- b
    return (index + 4)

def gnm_write_trailing_nop(cmdbuf: u32&?, index: u32, payload_dwords: u32) -> void:
    cmdbuf[index] <- gnm_create_pm4_header(PM4ItOpcode_Nop, payload_dwords)
    i: mutable u32 = 0
    while (i < payload_dwords):
        cmdbuf[((index + 1) + i)] <- 0
        i <- (i + 1)

def gnm_next_compute_queue_slot() -> int:
    i: mutable int = 0
