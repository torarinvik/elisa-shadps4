struct Devtools_Widget_PM4Header:
    reserved: mutable u32
    count: mutable u32
    type: mutable u32
    u32All: mutable u32

struct Devtools_Widget_PushMarker:
    name: mutable static u8&

struct Devtools_Widget_BatchBegin:
    id: mutable u32

struct Devtools_Widget_BatchInfo:
    id: mutable u32
    marker: mutable static u8&
    start_addr: mutable usize
    end_addr: mutable usize
    command_addr: mutable usize
    type: mutable u32
    bypass: mutable bool

enum Devtools_Widget_GPUEventKind:
    PushMarker
    PopMarker
    BatchBegin
    BatchInfo

struct Devtools_Widget_GPUEvent:
    kind: mutable Devtools_Widget_GPUEventKind
    push_marker: mutable Devtools_Widget_PushMarker
    batch_begin: mutable Devtools_Widget_BatchBegin
    batch_info: mutable Devtools_Widget_BatchInfo

def Devtools_Widget_PM4HeaderFromU32(value: u32) -> Devtools_Widget_PM4Header:
    return Devtools_Widget_PM4Header((value & 0xffff), (((value >> 16)) & 0x3fff), (((value >> 30)) & 0x3), value)

def Devtools_Widget_PM4HeaderToU32(header: Devtools_Widget_PM4Header) -> u32:
    return ((((header.reserved & 0xffff)) | ((((header.count & 0x3fff)) << 16))) | ((((header.type & 0x3)) << 30)))

def Devtools_Widget_IsDrawCall(opcode: u32) -> bool:
    if (opcode == PM4ItOpcode_DrawIndex2):
        return true
    if (opcode == PM4ItOpcode_DrawIndexOffset2):
        return true
    if (opcode == PM4ItOpcode_DrawIndexAuto):
        return true
    if (opcode == PM4ItOpcode_DrawIndirect):
        return true
    if (opcode == PM4ItOpcode_DrawIndexIndirect):
        return true
    if (opcode == PM4ItOpcode_DispatchDirect):
        return true
    if (opcode == PM4ItOpcode_DispatchIndirect):
        return true
    return false

type s32 = i32

type s64 = i64

type OrbisKernelEqueue = s64

type VAddr = u64

@fixed_layout
struct OrbisKernelEvent:
    ident: mutable u64
    filter: mutable i16
    flags: mutable u16
    fflags: mutable u32
    data: mutable u64
    udata: mutable void&?

