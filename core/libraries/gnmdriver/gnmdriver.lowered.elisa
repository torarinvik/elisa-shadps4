def sceGnmMapComputeQueue(pipe_id: u32, queue_id: u32, ring_base_addr: u64, ring_size_dw: u32, read_ptr_addr: mutable u32&?) -> int:
    if (pipe_id >= GNM_NUM_COMPUTE_PIPES):
        return ORBIS_GNM_ERROR_COMPUTEQUEUE_INVALID_PIPE_ID
    if (queue_id >= GNM_QUEUES_PER_PIPE):
        return ORBIS_GNM_ERROR_COMPUTEQUEUE_INVALID_QUEUE_ID
    if (((ring_base_addr % 0x100u)) != 0u64):
        return ORBIS_GNM_ERROR_COMPUTEQUEUE_INVALID_RING_BASE_ADDR
    if (not gnm_is_power_of_two(ring_size_dw)):
        return ORBIS_GNM_ERROR_COMPUTEQUEUE_INVALID_RING_SIZE
    if ((read_ptr_addr != null) and (((read_ptr_addr.cast[uintptr] & 3u64)) != 0u64)):
        return ORBIS_GNM_ERROR_COMPUTEQUEUE_INVALID_READ_PTR_ADDR
    if (read_ptr_addr != null):
        _ = read_ptr_addr
    slot: mutable int = gnm_next_compute_queue_slot()
    if (slot == (-1)):
        return ORBIS_GNM_ERROR_COMPUTEQUEUE_INTERNAL
    g_compute_queues[slot].used <- true
    g_compute_queues[slot].pipe_id <- pipe_id
    g_compute_queues[slot].queue_id <- queue_id
    g_compute_queues[slot].ring_base_addr <- ring_base_addr
    g_compute_queues[slot].ring_size_dw <- ring_size_dw
    g_compute_queues[slot].read_ptr_addr <- read_ptr_addr
    g_compute_queues[slot].next_offs_dw <- 0u32
    if (read_ptr_addr != null):
        read_ptr_addr[0] <- 0u32
    return (slot + 1)

def sceGnmMapComputeQueueWithPriority(pipe_id: u32, queue_id: u32, ring_base_addr: u64, ring_size_dw: u32, read_ptr_addr: mutable u32&?, pipePriority: u32) -> int:
    _ = pipePriority
    return sceGnmMapComputeQueue(pipe_id, queue_id, ring_base_addr, ring_size_dw, read_ptr_addr)

