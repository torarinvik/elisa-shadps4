# @port core/libraries/gnmdriver/gnmdriver.cpp::sceGnmInsertPushColorMarker sha256=d1a03202ac749692 oracle@a3773841
def sceGnmInsertPushColorMarker(cmdbuf: u32&?, size: u32, marker: void&?, color: u32) -> s32:
    if ((cmdbuf == null) or (marker == null)):
        return (-1)
    marker_buffer: u8& = marker.cast[u8&]
    marker_len: u32 = (gnm_c_string_length(marker_buffer) + 1)
    packet_size: u32 = (((((marker_len + 0xc)) >> 2)) + (((((marker_len + 0x10)) >> 3)) * 2))
    if ((packet_size + 2) != size):
        return (-1)
    cmdbuf[0] <- gnm_create_pm4_header(PM4ItOpcode_Nop, packet_size)
    cmdbuf[1] <- PM4CmdNop_DebugColorMarkerPush
    bytes: mutable u8& = cmdbuf[1].cast[mutable u8&]
    for i in 0 ..< marker_len:
        bytes[(4 + i)] <- marker_buffer[i]
    bytes[((4 + marker_len) + 8)] <- color.u8()
    bytes[((4 + marker_len) + 9)] <- ((color >> 8)).u8()
    bytes[((4 + marker_len) + 10)] <- ((color >> 16)).u8()
    bytes[((4 + marker_len) + 11)] <- ((color >> 24)).u8()
    clear_len: u32 = ((((packet_size * 4) - marker_len) - 8) - 4)
    for i in 0 ..< clear_len:
        bytes[(((4 + marker_len) + 12) + i)] <- 0
    return ORBIS_OK

