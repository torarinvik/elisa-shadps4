# @port core/libraries/gnmdriver/gnmdriver.cpp::sceGnmSetCsShader sha256=a93c7bcf945ee728 oracle@a3773841
def sceGnmSetCsShader(cmdbuf: u32&?, size: u32, cs_regs: u32&?) -> s32:
    if ((((cmdbuf == null) or (size <= 0x18)) or (cs_regs == null)) or (cs_regs[1] != 0)):
        return (-1)
    index: mutable u32 = 0
    index <- gnm_write_set_sh_reg_3(cmdbuf, index, 0x20c, cs_regs[0], 0)
    index <- gnm_write_set_sh_reg_3(cmdbuf, index, 0x212, cs_regs[2], cs_regs[3])
    index <- gnm_write_set_sh_reg_3(cmdbuf, index, 0x207, cs_regs[4], cs_regs[5], cs_regs[6])
    gnm_write_trailing_nop(cmdbuf, index, 11)
    return ORBIS_OK

# @port core/libraries/gnmdriver/gnmdriver.cpp::sceGnmSetCsShaderWithModifier sha256=09a4b6efb1205154 oracle@a3773841
def sceGnmSetCsShaderWithModifier(cmdbuf: u32&?, size: u32, cs_regs: u32&?, modifier: u32) -> s32:
    if ((modifier & 0xfffffc3f) != 0):
        return (-1)
    if ((((cmdbuf == null) or (size <= 0x18)) or (cs_regs == null)) or (cs_regs[1] != 0)):
        return (-1)
    index: mutable u32 = 0
    rsrc1: u32 = (cs_regs[2] if (modifier == 0) else ((((cs_regs[2] & 0xfffffc3f)) | modifier)))
    index <- gnm_write_set_sh_reg_3(cmdbuf, index, 0x20c, cs_regs[0], 0)
    index <- gnm_write_set_sh_reg_3(cmdbuf, index, 0x212, rsrc1, cs_regs[3])
    index <- gnm_write_set_sh_reg_3(cmdbuf, index, 0x207, cs_regs[4], cs_regs[5], cs_regs[6])
    gnm_write_trailing_nop(cmdbuf, index, 11)
    return ORBIS_OK

# @port core/libraries/gnmdriver/gnmdriver.cpp::sceGnmSetEmbeddedPsShader sha256=8766a89cb2b11e22 oracle@a3773841
def sceGnmSetEmbeddedPsShader(cmdbuf: u32&?, size: u32, shader_id: u32, shader_modifier: u32) -> s32:
    if (shader_id > 1):
        return ORBIS_GNM_ERROR_FAILURE
    _ = shader_modifier
    ps0_regs: u32[12] = [0x0fe000f0, 0, 0x000c0000, 4, 0, 4, 2, 2, 0, 0, 0x10, 0xf]
    ps1_regs: u32[12] = [0x0fe000f2, 0, 0x2000, 0, 0, 2, 2, 2, 0, 0, 0x10, 3]
    ps_regs: u32[12] = (ps0_regs if (shader_id == 0) else ps1_regs)
    index: mutable u32 = 0
    index <- gnm_write_set_sh_reg_3(cmdbuf, index, 8, ps_regs[0], ps_regs[1])
    index <- gnm_write_set_sh_reg_3(cmdbuf, index, 10, ps_regs[2], ps_regs[3])
    index <- gnm_write_set_ctx_reg_3(cmdbuf, index, 0x1c4, ps_regs[4], ps_regs[5])
    index <- gnm_write_set_ctx_reg_3(cmdbuf, index, 0x1b3, ps_regs[6], ps_regs[7])
    index <- gnm_write_set_ctx_reg_2(cmdbuf, index, 0x1b6, ps_regs[8])
    index <- gnm_write_set_ctx_reg_2(cmdbuf, index, 0x1b8, ps_regs[9])
    index <- gnm_write_set_ctx_reg_2(cmdbuf, index, 0x203, ps_regs[10])
    index <- gnm_write_set_ctx_reg_2(cmdbuf, index, 0x8f, ps_regs[11])
    gnm_write_trailing_nop(cmdbuf, index, 11)
    return ORBIS_OK

# @port core/libraries/gnmdriver/gnmdriver.cpp::sceGnmSetEmbeddedVsShader sha256=02884d49438acedf oracle@a3773841
def sceGnmSetEmbeddedVsShader(cmdbuf: u32&?, size: u32, shader_id: u32, modifier: u32) -> s32:
    if (shader_id > 1):
