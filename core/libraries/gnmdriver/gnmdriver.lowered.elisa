global mutable g_frames_submitted: u64 = 0u64

global mutable g_send_init_packet: bool = true

global mutable g_sdk_version: s32 = 0

global mutable g_tessellation_factors_ring_addr: u64 = GNM_INVALID_QUEUE_ADDR

global mutable g_compute_queues: array[GnmComputeQueue, GNM_MAX_COMPUTE_QUEUES] = zeroed

def gnm_c_string_length(value: u8&) -> u32:
    len: mutable u32 = 0u32
    while (value[len] != 0u8):
        len <- (len + 1u32)
    return len

def gnm_create_pm4_header(opcode: u32, payload_dwords: u32) -> u32:
    return ((((PM4_TYPE3_PACKET << 30u32)) | (((((payload_dwords - 1u32)) << 16u32)))) | ((opcode << 8u32)))

def gnm_is_power_of_two(value: u32) -> bool:
    if (value == 0u32):
        return false
    return (((value & ((value - 1u32)))) == 0u32)

def gnm_write_set_sh_reg_2(cmdbuf: u32&?, index: u32, reg: u32, a: u32) -> u32:
    cmdbuf[index] <- gnm_create_pm4_header(PM4ItOpcode_SetShReg, 3u32)
    cmdbuf[(index + 1u32)] <- reg
    cmdbuf[(index + 2u32)] <- a
    return (index + 3u32)

def gnm_write_set_sh_reg_3(cmdbuf: u32&?, index: u32, reg: u32, a: u32, b: u32) -> u32:
    cmdbuf[index] <- gnm_create_pm4_header(PM4ItOpcode_SetShReg, 4u32)
    cmdbuf[(index + 1u32)] <- reg
    cmdbuf[(index + 2u32)] <- a
    cmdbuf[(index + 3u32)] <- b
    return (index + 4u32)

def gnm_write_set_ctx_reg_2(cmdbuf: u32&?, index: u32, reg: u32, a: u32) -> u32:
    cmdbuf[index] <- gnm_create_pm4_header(PM4ItOpcode_SetContextReg, 3u32)
    cmdbuf[(index + 1u32)] <- reg
    cmdbuf[(index + 2u32)] <- a
    return (index + 3u32)

def gnm_write_set_ctx_reg_3(cmdbuf: u32&?, index: u32, reg: u32, a: u32, b: u32) -> u32:
    cmdbuf[index] <- gnm_create_pm4_header(PM4ItOpcode_SetContextReg, 4u32)
    cmdbuf[(index + 1u32)] <- reg
    cmdbuf[(index + 2u32)] <- a
    cmdbuf[(index + 3u32)] <- b
    return (index + 4u32)

def gnm_write_trailing_nop(cmdbuf: u32&?, index: u32, payload_dwords: u32) -> void:
    cmdbuf[index] <- gnm_create_pm4_header(PM4ItOpcode_Nop, payload_dwords)
    i: mutable u32 = 0u32
