def sceGnmSetHsShader(cmdbuf: u32&?, size: u32, hs_regs: u32&?, param4: u32) -> s32:
    if ((((cmdbuf == null) or (size < 0x1eu32)) or (hs_regs == null)) or (hs_regs[1] != 0u32)):
