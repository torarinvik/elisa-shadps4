def sceGnmDeleteEqEvent(eq: OrbisKernelEqueue, id: u64) -> s32:
    if (eq == 0):
        return ORBIS_KERNEL_ERROR_EBADF
    _ = id
    return 0

def sceGnmDestroyWorkloadStream() -> int:
    return 0

def sceGnmDingDong(gnm_vqid: u32, next_offs_dw: u32) -> void:
    if (gnm_vqid == 0):
        return
    i: mutable int = ((gnm_vqid - 1u32)).i32()
    if (((i < 0) or (i >= GNM_MAX_COMPUTE_QUEUES)) or (not g_compute_queues[i].used)):
        return
    g_compute_queues[i].next_offs_dw <- next_offs_dw
    if (g_compute_queues[i].read_ptr_addr != null):
        g_compute_queues[i].read_ptr_addr[0] <- 0u32
    return

def sceGnmDingDongForWorkload(gnm_vqid: u32, next_offs_dw: u32, workload_id: u64) -> void:
    _ = workload_id
    sceGnmDingDong(gnm_vqid, next_offs_dw)
    return

