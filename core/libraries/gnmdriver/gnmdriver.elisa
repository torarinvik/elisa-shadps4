def sceGnmInsertDingDongMarker(cmdbuf: u32&?, size: u32) -> s32:
    if cmdbuf == null or size != 4u32:
        return -1
    cmdbuf[0] <- (PM4ItOpcode_Nop << 24)
    cmdbuf[1] <- 0u32
    cmdbuf[2] <- 0u32
    cmdbuf[3] <- 0u32
    return ORBIS_OK

def sceGnmInsertPopMarker(cmdbuf: u32&?, size: u32) -> s32:
    if cmdbuf == null or size != 6u32:
        return -1
    cmdbuf[0] <- (PM4ItOpcode_Nop << 24)
    cmdbuf[1] <- 0x7b000000u32
    cmdbuf[2] <- 0u32
    cmdbuf[3] <- 0u32
    cmdbuf[4] <- 0u32
    cmdbuf[5] <- 0u32
    return ORBIS_OK

def sceGnmInsertPushColorMarker(cmdbuf: u32&?, size: u32, marker: void&?, color: u32) -> s32:
    _ = color
    if cmdbuf == null or marker == null or size < 2u32:
        return -1
    cmdbuf[0] <- (PM4ItOpcode_Nop << 24)
    cmdbuf[1] <- 0x7a000000u32
    return ORBIS_OK

def sceGnmInsertPushMarker(cmdbuf: u32&?, size: u32, marker: void&?) -> s32:
    if cmdbuf == null or marker == null or size < 2u32:
        return -1
    cmdbuf[0] <- (PM4ItOpcode_Nop << 24)
    cmdbuf[1] <- 0x79000000u32
    return ORBIS_OK

