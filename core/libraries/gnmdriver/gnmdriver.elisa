    index <- gnm_write_set_sh_reg_3(cmdbuf, index, 0x212u, rsrc1, cs_regs[3], 0u32)
    index <- gnm_write_set_sh_reg_3(cmdbuf, index, 0x207u, cs_regs[4], cs_regs[5], cs_regs[6])
    gnm_write_trailing_nop(cmdbuf, index, 11u32)
