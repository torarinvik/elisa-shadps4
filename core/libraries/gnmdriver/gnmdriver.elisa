def sceGnmSetCsShader(cmdbuf: mutable u32&?, size: u32, cs_regs: u32&?) -> s32:
    if cmdbuf == null or size <= 0x18u32 or cs_regs == null or cs_regs[1] != 0u32:
        return -1
    index: mutable u32 = 0u32
    index <- gnm_write_set_sh_reg_2(cmdbuf, index, 0x20cu, cs_regs[0])
    index <- gnm_write_set_sh_reg_3(cmdbuf, index, 0x212u, cs_regs[2], cs_regs[3], 0u32)
    index <- gnm_write_set_sh_reg_3(cmdbuf, index, 0x207u, cs_regs[4], cs_regs[5], cs_regs[6])
    gnm_write_trailing_nop(cmdbuf, index, 11u32)
    return ORBIS_OK

def sceGnmSetCsShaderWithModifier(cmdbuf: mutable u32&?, size: u32, cs_regs: u32&?, modifier: u32) -> s32:
    if modifier & 0xfffffc3fu32 != 0u32:
        return -1
    if cmdbuf == null or size <= 0x18u32 or cs_regs == null or cs_regs[1] != 0u32:
        return -1
    index: mutable u32 = 0u32
    rsrc1: u32 = cs_regs[2] if modifier == 0u32 else ((cs_regs[2] & 0xfffffc3fu32) | modifier)
    index <- gnm_write_set_sh_reg_2(cmdbuf, index, 0x20cu, cs_regs[0])
    index <- gnm_write_set_sh_reg_3(cmdbuf, index, 0x212u, rsrc1, cs_regs[3], 0u32)
    index <- gnm_write_set_sh_reg_3(cmdbuf, index, 0x207u, cs_regs[4], cs_regs[5], cs_regs[6])
    gnm_write_trailing_nop(cmdbuf, index, 11u32)
    return ORBIS_OK

def sceGnmSetEmbeddedPsShader(cmdbuf: mutable u32&?, size: u32, shader_id: u32, shader_modifier: u32) -> s32:
    if shader_id > 1u32:
        return ORBIS_GNM_ERROR_FAILURE
    _ = shader_modifier
    ps0_regs: u32[12] = [
        0x0fe000f0u32,
        0u32,
        0x000c0000u32,
        4u32,
        0u32,
        4u32,
        2u32,
        2u32,
        0u32,
        0u32,
        0x10u32,
        0xfu32,
    ]
    ps1_regs: u32[12] = [
        0x0fe000f2u32,
        0u32,
        0x2000u32,
        0u32,
        0u32,
        2u32,
        2u32,
        2u32,
        0u32,
        0u32,
        0x10u32,
        3u32,
    ]
    ps_regs: u32[12] = ps0_regs if shader_id == 0u32 else ps1_regs
    index: mutable u32 = 0u32
    index <- gnm_write_set_sh_reg_2(cmdbuf, index, 8u, ps_regs[0])
    index <- gnm_write_set_sh_reg_3(cmdbuf, index, 10u, ps_regs[2], ps_regs[3], ps_regs[1])
    index <- gnm_write_set_ctx_reg_3(cmdbuf, index, 0x1c4u, ps_regs[4], ps_regs[5])
    index <- gnm_write_set_ctx_reg_3(cmdbuf, index, 0x1b3u, ps_regs[6], ps_regs[7])
    index <- gnm_write_set_ctx_reg_2(cmdbuf, index, 0x1b6u, ps_regs[8])
    index <- gnm_write_set_ctx_reg_2(cmdbuf, index, 0x1b8u, ps_regs[9])
    index <- gnm_write_set_ctx_reg_2(cmdbuf, index, 0x203u, ps_regs[10])
    index <- gnm_write_set_ctx_reg_2(cmdbuf, index, 0x8fu, ps_regs[11])
    gnm_write_trailing_nop(cmdbuf, index, 11u32)
    return ORBIS_OK

def sceGnmSetEmbeddedVsShader(cmdbuf: mutable u32&?, size: u32, shader_id: u32, modifier: u32) -> s32:
    if shader_id > 1u32:
        return ORBIS_GNM_ERROR_FAILURE
    if shader_id != 0u32:
        return ORBIS_GNM_ERROR_FAILURE
    _ = modifier
    vs_regs: u32[8] = [
        0x0fe000f1u32,
        0u32,
        0x000c0000u32,
        4u32,
        0u32,
        4u32,
        0u32,
        7u32,
    ]
    index: mutable u32 = 0u32
    index <- gnm_write_set_sh_reg_2(cmdbuf, index, 0x48u, vs_regs[0])
    index <- gnm_write_set_sh_reg_3(cmdbuf, index, 0x4au, vs_regs[2], vs_regs[3], vs_regs[1])
    index <- gnm_write_set_ctx_reg_2(cmdbuf, index, 0x207u, vs_regs[6])
    index <- gnm_write_set_ctx_reg_2(cmdbuf, index, 0x1b1u, vs_regs[4])
    index <- gnm_write_set_ctx_reg_2(cmdbuf, index, 0x1c3u, vs_regs[5])
    gnm_write_trailing_nop(cmdbuf, index, 11u32)
    return ORBIS_OK

def sceGnmSetEsShader(cmdbuf: mutable u32&?, size: u32, es_regs: u32&?, shader_modifier: u32) -> s32:
    if shader_modifier & 0xfcfffc3fu32 != 0u32:
        return -1
    if cmdbuf == null or size < 0x14u32 or es_regs == null or es_regs[1] != 0u32:
        return -1
    index: mutable u32 = 0u32
    rsrc1: u32 = es_regs[2] if shader_modifier == 0u32 else ((es_regs[2] & 0xfcfffc3fu32) | shader_modifier)
    index <- gnm_write_set_sh_reg_2(cmdbuf, index, 0xc8u, es_regs[0])
    index <- gnm_write_set_sh_reg_3(cmdbuf, index, 0xcau, rsrc1, es_regs[3], 0u32)
    gnm_write_trailing_nop(cmdbuf, index, 11u32)
    return ORBIS_OK

