def sceGnmSubmitAndFlipCommandBuffers(count: u32, dcb_gpu_addrs: u32&?, dcb_sizes_in_bytes: u32&?, ccb_gpu_addrs: u32&?, ccb_sizes_in_bytes: u32&?, vo_handle: u32, buf_idx: u32, flip_mode: u32, flip_arg: i64) -> s32:
    return sceGnmSubmitAndFlipCommandBuffersForWorkload(
        count,
        count,
        dcb_gpu_addrs,
        dcb_sizes_in_bytes,
        ccb_gpu_addrs,
        ccb_sizes_in_bytes,
        vo_handle,
        buf_idx,
        flip_mode,
        flip_arg
    )

def sceGnmSubmitAndFlipCommandBuffersForWorkload(workload: u32, count: u32, dcb_gpu_addrs: u32&?, dcb_sizes_in_bytes: u32&?, ccb_gpu_addrs: u32&?, ccb_sizes_in_bytes: u32&?, vo_handle: u32, buf_idx: u32, flip_mode: u32, flip_arg: i64) -> int:
    if count == 0 or dcb_gpu_addrs == null or dcb_sizes_in_bytes == null:
        return ORBIS_GNM_ERROR_SUBMISSION_FAILED_INVALID_ARGUMENT
    final_buffer: u32 = dcb_gpu_addrs[count - 1u32]
    final_size_in_bytes: u32 = dcb_sizes_in_bytes[count - 1u32]
    if final_buffer == 0u32 or final_size_in_bytes == 0u32:
        return ORBIS_GNM_ERROR_SUBMISSION_FAILED_INVALID_ARGUMENT
    c_GuestExec_EmitCusaArtifactKV("VIDEO_STAGE_flip_submitted", 1u64)
    runtime_rc: int = gnm_try_runtime_submit_flip_bridge(workload, count, dcb_gpu_addrs, dcb_sizes_in_bytes,
                                                         ccb_gpu_addrs, ccb_sizes_in_bytes,
                                                         vo_handle, buf_idx, flip_mode, flip_arg)
    if runtime_rc != GNM_RUNTIME_BRIDGE_UNBOUND:
        if not g_gnm_artifact_submit_path_bridge_emitted:
            c_GuestExec_EmitCusaArtifactKV("gnm_submit_path_bridge", 1u64)
            g_gnm_artifact_submit_path_bridge_emitted <- true
        if runtime_rc != ORBIS_OK:
            return runtime_rc
        gnm_record_submit_batch(count, dcb_gpu_addrs, dcb_sizes_in_bytes, ccb_gpu_addrs, ccb_sizes_in_bytes)
        gnm_drive_runtime_present(vo_handle, buf_idx, flip_mode, flip_arg, final_buffer.u64())
        return ORBIS_OK
    submit_result: int = sceGnmSubmitCommandBuffersForWorkload(workload, count, dcb_gpu_addrs, dcb_sizes_in_bytes,
                                                               ccb_gpu_addrs, ccb_sizes_in_bytes)
    if submit_result != ORBIS_OK:
        return submit_result
    gnm_drive_runtime_present(vo_handle, buf_idx, flip_mode, flip_arg, final_buffer.u64())
    return ORBIS_OK

def sceGnmSubmitCommandBuffers(count: u32, dcb_gpu_addrs: u32&?, dcb_sizes_in_bytes: u32&?, ccb_gpu_addrs: u32&?, ccb_sizes_in_bytes: u32&?) -> s32:
    return sceGnmSubmitCommandBuffersForWorkload(count, count, dcb_gpu_addrs, dcb_sizes_in_bytes,
                                                ccb_gpu_addrs, ccb_sizes_in_bytes)

def sceGnmSubmitCommandBuffersForWorkload(workload: u32, count: u32, dcb_gpu_addrs: u32&?, dcb_sizes_in_bytes: u32&?, ccb_gpu_addrs: u32&?, ccb_sizes_in_bytes: u32&?) -> int:
    if dcb_gpu_addrs == null or dcb_sizes_in_bytes == null:
        return ORBIS_GNM_ERROR_SUBMISSION_FAILED_INVALID_ARGUMENT
    i: mutable u32 = 0u
    while i < count:
        dcb_size: u32 = dcb_sizes_in_bytes[i]
        if dcb_size == 0u32:
            return ORBIS_GNM_ERROR_SUBMISSION_FAILED_INVALID_ARGUMENT
        if dcb_size > 0x3ffffcu32:
            return ORBIS_GNM_ERROR_SUBMISSION_FAILED_INVALID_ARGUMENT
        if ccb_sizes_in_bytes != null:
            ccb_size: u32 = ccb_sizes_in_bytes[i]
            if ccb_size > 0x3ffffcu32:
                return ORBIS_GNM_ERROR_SUBMISSION_FAILED_INVALID_ARGUMENT
        if dcb_gpu_addrs[i] == 0u32:
            return ORBIS_GNM_ERROR_SUBMISSION_FAILED_INVALID_ARGUMENT
        i <- i + 1u
    runtime_rc: int = gnm_try_runtime_submit_bridge(workload, count, dcb_gpu_addrs, dcb_sizes_in_bytes,
                                                    ccb_gpu_addrs, ccb_sizes_in_bytes)
    if runtime_rc == GNM_RUNTIME_BRIDGE_UNBOUND and not g_gnm_artifact_submit_path_native_emitted:
        c_GuestExec_EmitCusaArtifactKV("gnm_submit_path_native", 1u64)
        g_gnm_artifact_submit_path_native_emitted <- true
    if runtime_rc != GNM_RUNTIME_BRIDGE_UNBOUND and not g_gnm_artifact_submit_path_bridge_emitted:
        c_GuestExec_EmitCusaArtifactKV("gnm_submit_path_bridge", 1u64)
        g_gnm_artifact_submit_path_bridge_emitted <- true
    if runtime_rc != GNM_RUNTIME_BRIDGE_UNBOUND and runtime_rc != ORBIS_OK:
        return runtime_rc
    gnm_record_submit_batch(count, dcb_gpu_addrs, dcb_sizes_in_bytes, ccb_gpu_addrs, ccb_sizes_in_bytes)
    return ORBIS_OK

def sceGnmSubmitDone() -> int:
    runtime_rc: int = gnm_try_runtime_submit_done_bridge()
    if runtime_rc != GNM_RUNTIME_BRIDGE_UNBOUND and runtime_rc != ORBIS_OK:
        return runtime_rc
    g_liverpool_submit_done_count <- g_liverpool_submit_done_count + 1u64
    g_send_init_packet <- true
    g_submissions_lock <- 0u
    g_frames_submitted <- g_frames_submitted + 1u64
    return ORBIS_OK

def sceGnmUnmapComputeQueue(vqid: u32) -> int:
    if vqid == 0u32:
        return ORBIS_OK
    queue_index: int = (vqid - 1u32).int()
    if queue_index < 0 or queue_index >= GNM_MAX_COMPUTE_QUEUES:
        return ORBIS_OK
    g_compute_queues[queue_index].used <- false
    g_compute_queues[queue_index].pipe_id <- 0u32
    g_compute_queues[queue_index].queue_id <- 0u32
    g_compute_queues[queue_index].ring_base_addr <- GNM_INVALID_QUEUE_ADDR
    g_compute_queues[queue_index].ring_size_dw <- 0u32
    g_compute_queues[queue_index].read_ptr_addr <- null
    g_compute_queues[queue_index].next_offs_dw <- 0u32
    return 0

