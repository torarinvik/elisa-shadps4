# @port core/libraries/gnmdriver/gnmdriver.cpp::sceGnmDispatchDirect sha256=8032b14555abd11a oracle@a3773841
def sceGnmDispatchDirect(cmdbuf: mutable u32&?, size: u32, threads_x: u32, threads_y: u32, threads_z: u32, flags: u32) -> s32:
    if cmdbuf == null or size != 9 or ((threads_x | threads_y | threads_z) > 0x7fffffff):
        return -1
    cmdbuf[0] <- 0xc0000001
    cmdbuf[1] <- threads_x
    cmdbuf[2] <- threads_y
    cmdbuf[3] <- threads_z
    cmdbuf[4] <- flags
    cmdbuf[5] <- 0
    cmdbuf[6] <- 0
    cmdbuf[7] <- 0
    cmdbuf[8] <- 0
    return ORBIS_OK

# @port core/libraries/gnmdriver/gnmdriver.cpp::sceGnmDispatchIndirect sha256=3baa68e3f06c9650 oracle@a3773841
def sceGnmDispatchIndirect(cmdbuf: mutable u32&?, size: u32, data_offset: u32, flags: u32) -> s32:
    if cmdbuf == null or size != 7:
        return -1
    cmdbuf[0] <- 0xc0000002
    cmdbuf[1] <- data_offset
    cmdbuf[2] <- flags
    cmdbuf[3] <- 0
    cmdbuf[4] <- 0
    cmdbuf[5] <- 0
    cmdbuf[6] <- 0
    return ORBIS_OK

# @port core/libraries/gnmdriver/gnmdriver.cpp::sceGnmDispatchIndirectOnMec sha256=a40a193cf800994d oracle@a3773841
def sceGnmDispatchIndirectOnMec(cmdbuf: mutable u32&?, size: u32, args: u64, modifier: u32) -> s32:
    if cmdbuf == null or size != 8 or args == 0 or (args & 0x3) != 0:
        return -1
    _ = modifier
    cmdbuf[0] <- 0xc0021602 | (modifier & 1)
    cmdbuf[1] <- args.cast[u32]
    cmdbuf[2] <- (args >> 32).u32()
    cmdbuf[3] <- (modifier & 0x18) | 1
    cmdbuf[4] <- 0xc0021000
    cmdbuf[5] <- 0
    cmdbuf[6] <- 0
    cmdbuf[7] <- 0
    return ORBIS_OK

# @port core/libraries/gnmdriver/gnmdriver.cpp::sceGnmDispatchInitDefaultHardwareState sha256=d3b260afa5826474 oracle@a3773841
def sceGnmDispatchInitDefaultHardwareState(cmdbuf: mutable u32&?, size: u32) -> u32:
    if cmdbuf == null or size < 0x100:
        return 0
    cmdbuf[0] <- 0x00000000
    return 0x100

# @port core/libraries/gnmdriver/gnmdriver.cpp::sceGnmDrawIndex sha256=8d5c07f289fc8048 oracle@a3773841
def sceGnmDrawIndex(cmdbuf: mutable u32&?, size: u32, index_count: u32, index_addr: u64, flags: u32, type: u32) -> s32:
    if cmdbuf == null or size != 10 or index_addr == 0 or (index_addr & 1) != 0 or (flags & 0x1ffffffe) != 0:
        return -1
    cmdbuf[0] <- 0xc0030000
    cmdbuf[1] <- index_addr.cast[u32]
    cmdbuf[2] <- (index_addr >> 32).u32()
    cmdbuf[3] <- index_count
    cmdbuf[4] <- index_count
    cmdbuf[5] <- flags
    cmdbuf[6] <- 0
    cmdbuf[7] <- 0
    cmdbuf[8] <- 0
    cmdbuf[9] <- 0
    _ = type
    return ORBIS_OK

# @port core/libraries/gnmdriver/gnmdriver.cpp::sceGnmDrawIndexAuto sha256=7584693b21f138f9 oracle@a3773841
def sceGnmDrawIndexAuto(cmdbuf: mutable u32&?, size: u32, index_count: u32, flags: u32) -> s32:
    if cmdbuf == null or size != 7 or (flags & 0x1ffffffe) != 0:
        return -1
    cmdbuf[0] <- 0xc0040000
    cmdbuf[1] <- index_count
    cmdbuf[2] <- flags
    cmdbuf[3] <- 0
    cmdbuf[4] <- 0
    cmdbuf[5] <- 0
    cmdbuf[6] <- 0
    return ORBIS_OK

# @port core/libraries/gnmdriver/gnmdriver.cpp::sceGnmDrawIndexIndirect sha256=852351edeb55f23a oracle@a3773841
def sceGnmDrawIndexIndirect(cmdbuf: mutable u32&?, size: u32, data_offset: u32, shader_stage: u32, vertex_sgpr_offset: u32, instance_sgpr_offset: u32, flags: u32) -> s32:
    if cmdbuf == null or size != 9 or shader_stage >= 7 or vertex_sgpr_offset >= 0x10 or instance_sgpr_offset >= 0x10:
        return -1
    sgpr_offset: u32 = GNM_INDIRECT_SGPR_OFFSETS[shader_stage]
    vertex_offset: mutable u32 = 0
    instance_offset: mutable u32 = 0
    if vertex_sgpr_offset != 0:
        vertex_offset <- vertex_sgpr_offset + sgpr_offset
    if instance_sgpr_offset != 0:
        instance_offset <- instance_sgpr_offset + sgpr_offset
    cmdbuf[0] <- data_offset
    cmdbuf[1] <- vertex_offset
    cmdbuf[2] <- instance_offset
    cmdbuf[3] <- flags
    cmdbuf[4] <- 0
    cmdbuf[5] <- 0
    cmdbuf[6] <- 0
    cmdbuf[7] <- 0
    cmdbuf[8] <- 0
    return ORBIS_OK

# @port core/libraries/gnmdriver/gnmdriver.cpp::sceGnmDrawIndexIndirectCountMulti sha256=63f2228240d6847e oracle@a3773841
def sceGnmDrawIndexIndirectCountMulti(cmdbuf: mutable u32&?, size: u32, data_offset: u32, max_count: u32, count_addr: u64, shader_stage: u32, vertex_sgpr_offset: u32, instance_sgpr_offset: u32, flags: u32) -> s32:
    if cmdbuf == null or size != 16 or vertex_sgpr_offset >= 0x10 or instance_sgpr_offset >= 0x10 or (shader_stage != 2 and shader_stage != 4 and shader_stage != 6):
        return -1
    sgpr_offset: u32 = GNM_INDIRECT_SGPR_OFFSETS[shader_stage]
    vertex_offset: mutable u32 = 0
    instance_offset: mutable u32 = 0
    if vertex_sgpr_offset != 0:
        vertex_offset <- vertex_sgpr_offset + sgpr_offset
    if instance_sgpr_offset != 0:
        instance_offset <- instance_sgpr_offset + sgpr_offset
    cmdbuf[0] <- data_offset
    cmdbuf[1] <- vertex_offset
    cmdbuf[2] <- instance_offset
    cmdbuf[3] <- 0
    if count_addr != 0:
        cmdbuf[3] <- 1 << 0x1e
    cmdbuf[4] <- max_count
    cmdbuf[5] <- count_addr.cast[u32]
    cmdbuf[6] <- (count_addr >> 32).u32()
    cmdbuf[7] <- 0x10
    cmdbuf[8] <- flags
    cmdbuf[9] <- 0
    cmdbuf[10] <- 0
    cmdbuf[11] <- 0
    cmdbuf[12] <- 0
    cmdbuf[13] <- 0
    cmdbuf[14] <- 0
    cmdbuf[15] <- 0
    return ORBIS_OK

