include "../error_codes.elisa"
include "./gnm_error.elisa"
include "../kernel/orbis_error.elisa"
include "../../devtools/widget/common.elisa"

type s32 = i32
type s64 = i64
type OrbisKernelEqueue = s64
type VAddr = u64
@fixed_layout
struct OrbisKernelEvent:
    ident: mutable u64
    filter: mutable i16
    flags: mutable u16
    fflags: mutable u32
    data: mutable u64
    udata: mutable void&?

const GNM_MAX_COMPUTE_QUEUES: int = 64
const GNM_NUM_COMPUTE_PIPES: int = 4
const GNM_QUEUES_PER_PIPE: int = 16
const GNM_INVALID_QUEUE_ADDR: u64 = 0xffffffffffffffff
const ORBIS_GNM_TESSELLATION_FALLBACK_ADDR: u64 = 0x100000000000
const GNM_TESSELLATION_OFFCHIP_SIZE: int = 0x800000
const GNM_INDIRECT_SGPR_OFFSETS: u32[7] = [0u32, 0u32, 0x4cu32, 0u32, 0xccu32, 0u32, 0x14cu32]

const PM4CmdNop_DebugMarkerPush: u32 = 0x68750001u
const PM4CmdNop_DebugMarkerPop: u32 = 0x68750002u
const PM4CmdNop_DebugSetMarker: u32 = 0x68750003u
const PM4CmdNop_DebugColorMarkerPush: u32 = 0x6875000eu
const PM4_TYPE3_PACKET: u32 = 3u32

@fixed_layout
struct GnmComputeQueue:
    used: mutable bool
    pipe_id: mutable u32
    queue_id: mutable u32
    ring_base_addr: mutable VAddr
    ring_size_dw: mutable u32
    read_ptr_addr: mutable u32&?
    next_offs_dw: mutable u32

global mutable g_submissions_lock: u32 = 0
global mutable g_frames_submitted: u64 = 0u64
global mutable g_send_init_packet: bool = true
global mutable g_sdk_version: s32 = 0
global mutable g_tessellation_factors_ring_addr: u64 = GNM_INVALID_QUEUE_ADDR
global mutable g_compute_queues: array[GnmComputeQueue, GNM_MAX_COMPUTE_QUEUES] = zeroed

def gnm_c_string_length(value: u8&) -> u32:
    len: mutable u32 = 0u32
    while value[len] != 0u8:
        len <- len + 1u32
    return len

def gnm_create_pm4_header(opcode: u32, payload_dwords: u32) -> u32:
    return (PM4_TYPE3_PACKET << 30u32) | (((payload_dwords - 1u32) << 16u32)) | (opcode << 8u32)

def gnm_is_power_of_two(value: u32) -> bool:
    if value == 0u32:
        return false
    return (value & (value - 1u32)) == 0u32

def gnm_write_set_sh_reg_2(cmdbuf: mutable u32&?, index: u32, reg: u32, a: u32) -> u32:
    cmdbuf[index] <- gnm_create_pm4_header(PM4ItOpcode_SetShReg, 3u32)
    cmdbuf[index + 1u32] <- reg
    cmdbuf[index + 2u32] <- a
    return index + 3u32

def gnm_write_set_sh_reg_3(cmdbuf: mutable u32&?, index: u32, reg: u32, a: u32, b: u32, c: u32) -> u32:
    cmdbuf[index] <- gnm_create_pm4_header(PM4ItOpcode_SetShReg, 4u32)
    cmdbuf[index + 1u32] <- reg
    cmdbuf[index + 2u32] <- a
    cmdbuf[index + 3u32] <- b
    cmdbuf[index + 4u32] <- c
    return index + 5u32

def gnm_write_set_ctx_reg_2(cmdbuf: mutable u32&?, index: u32, reg: u32, a: u32) -> u32:
    cmdbuf[index] <- gnm_create_pm4_header(PM4ItOpcode_SetContextReg, 3u32)
    cmdbuf[index + 1u32] <- reg
    cmdbuf[index + 2u32] <- a
    return index + 3u32

def gnm_write_set_ctx_reg_3(cmdbuf: mutable u32&?, index: u32, reg: u32, a: u32, b: u32) -> u32:
    cmdbuf[index] <- gnm_create_pm4_header(PM4ItOpcode_SetContextReg, 4u32)
    cmdbuf[index + 1u32] <- reg
    cmdbuf[index + 2u32] <- a
    cmdbuf[index + 3u32] <- b
    return index + 4u32

def gnm_write_trailing_nop(cmdbuf: mutable u32&?, index: u32, payload_dwords: u32) -> void:
    cmdbuf[index] <- gnm_create_pm4_header(PM4ItOpcode_Nop, payload_dwords)
    i: mutable u32 = 0u32
    while i < payload_dwords:
        cmdbuf[index + 1u32 + i] <- 0u32
        i <- i + 1u32

def gnm_next_compute_queue_slot() -> int:
    i: mutable int = 0
    while i < GNM_MAX_COMPUTE_QUEUES:
        if not g_compute_queues[i].used:
            return i
        i <- i + 1
    return -1

def sceGnmAddEqEvent(eq: OrbisKernelEqueue, id: u64, udata: void&?) -> s32:
    if eq == 0:
        return ORBIS_KERNEL_ERROR_EBADF
    _ = id
    _ = udata
    return 0

def sceGnmAreSubmitsAllowed() -> int:
    return 1 if g_submissions_lock == 0 else 0

def sceGnmBeginWorkload(workload_stream: u32, workload: mutable u64&?) -> int:
    if workload == null:
        return 3
    workload[0] <- 0u64 if workload_stream >= 0x10u32 else 1u64
    return 1 if workload_stream > 0x0fu32 else 0

def sceGnmComputeWaitOnAddress(cmdbuf: mutable u32&?, size: u32, addr: u64, mask: u32, cmp_func: u32, ref: u32) -> s32:
    if cmdbuf == null or size != 0xeu32:
        return -1
    cmdbuf[0] <- 0xc0000000u32
    cmdbuf[1] <- size
    cmdbuf[2] <- addr as u32
    cmdbuf[3] <- (addr >> 32).u32()
    cmdbuf[4] <- mask
    cmdbuf[5] <- ref
    cmdbuf[6] <- cmp_func
    cmdbuf[7] <- (0x1u32 if addr > 0xffffu32 else 0u32) | 0x30u32
    cmdbuf[8] <- 0u32
    cmdbuf[9] <- 0u32
    cmdbuf[10] <- 0u32
    cmdbuf[11] <- 0u32
    cmdbuf[12] <- 0u32
    cmdbuf[13] <- 0u32
    return ORBIS_OK

def sceGnmComputeWaitSemaphore() -> int:
    return 0

def sceGnmCreateWorkloadStream(param1: u64, workload_stream: mutable u32&?) -> int:
    if param1 == 0 or workload_stream == null:
        return 3
    workload_stream[0] <- 1u32
    return 0

