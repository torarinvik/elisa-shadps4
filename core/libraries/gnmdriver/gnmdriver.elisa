# @port core/libraries/gnmdriver/gnmdriver.cpp::sceGnmDingDong sha256=956a70c390e2ec0d oracle@a3773841
def sceGnmDingDong(gnm_vqid: u32, next_offs_dw: u32) -> void:
    if gnm_vqid == 0:
        return
    i: mutable int = (gnm_vqid - 1).i32()
    if i < 0 or i >= GNM_MAX_COMPUTE_QUEUES or not g_compute_queues[i].used:
        return
    g_compute_queues[i].next_offs_dw <- next_offs_dw
    if let read_ptr_ref = g_compute_queues[i].read_ptr_addr:
        read_ptr_ref[0] <- 0
    return

# @port core/libraries/gnmdriver/gnmdriver.cpp::sceGnmDingDongForWorkload sha256=47593a7a52756d99 oracle@a3773841
def sceGnmDingDongForWorkload(gnm_vqid: u32, next_offs_dw: u32, workload_id: u64) -> void:
    _ = workload_id
    sceGnmDingDong(gnm_vqid, next_offs_dw)
    return

# @port core/libraries/gnmdriver/gnmdriver.cpp::sceGnmDisableMipStatsReport sha256=388b69db3555e61e oracle@a3773841
