def sceGnmDeleteEqEvent(eq: OrbisKernelEqueue, id: u64) -> s32:
    if eq == 0:
        return ORBIS_KERNEL_ERROR_EBADF
    _ = id
    return 0

def sceGnmDestroyWorkloadStream() -> int:
    return 0

def sceGnmDingDong(gnm_vqid: u32, next_offs_dw: u32) -> void:
    if gnm_vqid == 0:
        return
    i: mutable int = (gnm_vqid - 1u32).i32()
    if i < 0 or i >= GNM_MAX_COMPUTE_QUEUES or not g_compute_queues[i].used:
        return
    g_compute_queues[i].next_offs_dw <- next_offs_dw
    if g_compute_queues[i].read_ptr_addr != null:
        g_compute_queues[i].read_ptr_addr[0] <- 0u32
    return

def sceGnmDingDongForWorkload(gnm_vqid: u32, next_offs_dw: u32, workload_id: u64) -> void:
    _ = workload_id
    sceGnmDingDong(gnm_vqid, next_offs_dw)
    return

def sceGnmDisableMipStatsReport() -> int:
    return 0

def sceGnmDispatchDirect(cmdbuf: u32&?, size: u32, threads_x: u32, threads_y: u32, threads_z: u32, flags: u32) -> s32:
    if cmdbuf == null or size != 9u32 or ((threads_x | threads_y | threads_z) > 0x7fffffffu32):
        return -1
    cmdbuf[0] <- 0xc0000001u32
    cmdbuf[1] <- threads_x
    cmdbuf[2] <- threads_y
    cmdbuf[3] <- threads_z
    cmdbuf[4] <- flags
    cmdbuf[5] <- 0u32
    cmdbuf[6] <- 0u32
    cmdbuf[7] <- 0u32
    cmdbuf[8] <- 0u32
    return ORBIS_OK

def sceGnmDispatchIndirect(cmdbuf: u32&?, size: u32, data_offset: u32, flags: u32) -> s32:
    if cmdbuf == null or size != 7u32:
        return -1
    cmdbuf[0] <- 0xc0000002u32
    cmdbuf[1] <- data_offset
    cmdbuf[2] <- flags
    cmdbuf[3] <- 0u32
    cmdbuf[4] <- 0u32
    cmdbuf[5] <- 0u32
    cmdbuf[6] <- 0u32
    return ORBIS_OK

def sceGnmDispatchIndirectOnMec(cmdbuf: u32&?, size: u32, args: u64, modifier: u32) -> s32:
    if cmdbuf == null or size != 8u32 or args == 0u64 or (args & 0x3u64) != 0u64:
        return -1
    _ = modifier
    cmdbuf[0] <- 0xc0021602u32 | (modifier & 1u32)
    cmdbuf[1] <- args as u32
    cmdbuf[2] <- (args >> 32u64).u32()
    cmdbuf[3] <- (modifier & 0x18u32) | 1u32
    cmdbuf[4] <- 0xc0021000u32
    cmdbuf[5] <- 0u32
    cmdbuf[6] <- 0u32
    cmdbuf[7] <- 0u32
    return ORBIS_OK

def sceGnmDispatchInitDefaultHardwareState(cmdbuf: u32&?, size: u32) -> u32:
    if cmdbuf == null or size < 0x100u32:
        return 0u32
    cmdbuf[0] <- 0x00000000u32
    return 0x100u32

def sceGnmDrawIndex(cmdbuf: u32&?, size: u32, index_count: u32, index_addr: u64, flags: u32, type: u32) -> s32:
    if cmdbuf == null or size != 10u32 or index_addr == 0u64 or (index_addr & 1u64) != 0u64 or (flags & 0x1ffffffeu32) != 0u32:
        return -1
    cmdbuf[0] <- 0xc0030000u32
    cmdbuf[1] <- index_addr as u32
    cmdbuf[2] <- (index_addr >> 32u64).u32()
    cmdbuf[3] <- index_count
    cmdbuf[4] <- index_count
    cmdbuf[5] <- flags
    cmdbuf[6] <- 0u32
    cmdbuf[7] <- 0u32
    cmdbuf[8] <- 0u32
    cmdbuf[9] <- 0u32
    _ = type
    return ORBIS_OK

def sceGnmDrawIndexAuto(cmdbuf: u32&?, size: u32, index_count: u32, flags: u32) -> s32:
    if cmdbuf == null or size != 7u32 or (flags & 0x1ffffffeu32) != 0u32:
        return -1
    cmdbuf[0] <- 0xc0040000u32
    cmdbuf[1] <- index_count
    cmdbuf[2] <- flags
    cmdbuf[3] <- 0u32
    cmdbuf[4] <- 0u32
    cmdbuf[5] <- 0u32
    cmdbuf[6] <- 0u32
    return ORBIS_OK

def sceGnmDrawIndexIndirect(cmdbuf: u32&?, size: u32, data_offset: u32, shader_stage: u32, vertex_sgpr_offset: u32, instance_sgpr_offset: u32, flags: u32) -> s32:
    if cmdbuf == null or size != 9u32 or shader_stage >= 7u32 or vertex_sgpr_offset >= 0x10u32 or instance_sgpr_offset >= 0x10u32:
        return -1
    sgpr_offset: u32 = GNM_INDIRECT_SGPR_OFFSETS[shader_stage]
    vertex_offset: mutable u32 = 0u32
    instance_offset: mutable u32 = 0u32
    if vertex_sgpr_offset != 0u32:
        vertex_offset <- vertex_sgpr_offset + sgpr_offset
    if instance_sgpr_offset != 0u32:
        instance_offset <- instance_sgpr_offset + sgpr_offset
    cmdbuf[0] <- data_offset
    cmdbuf[1] <- vertex_offset
    cmdbuf[2] <- instance_offset
    cmdbuf[3] <- flags
    cmdbuf[4] <- 0u32
    cmdbuf[5] <- 0u32
    cmdbuf[6] <- 0u32
    cmdbuf[7] <- 0u32
    cmdbuf[8] <- 0u32
    return ORBIS_OK

def sceGnmDrawIndexIndirectCountMulti(cmdbuf: u32&?, size: u32, data_offset: u32, max_count: u32, count_addr: u64, shader_stage: u32, vertex_sgpr_offset: u32, instance_sgpr_offset: u32, flags: u32) -> s32:
    if cmdbuf == null or size != 16u32 or vertex_sgpr_offset >= 0x10u32 or instance_sgpr_offset >= 0x10u32 or (shader_stage != 2u32 and shader_stage != 4u32 and shader_stage != 6u32):
        return -1
    sgpr_offset: u32 = GNM_INDIRECT_SGPR_OFFSETS[shader_stage]
    vertex_offset: mutable u32 = 0u32
    instance_offset: mutable u32 = 0u32
    if vertex_sgpr_offset != 0u32:
        vertex_offset <- vertex_sgpr_offset + sgpr_offset
    if instance_sgpr_offset != 0u32:
        instance_offset <- instance_sgpr_offset + sgpr_offset
    cmdbuf[0] <- data_offset
    cmdbuf[1] <- vertex_offset
    cmdbuf[2] <- instance_offset
    cmdbuf[3] <- 0u32
    if count_addr != 0u64:
        cmdbuf[3] <- 1u32 << 0x1eu32
    cmdbuf[4] <- max_count
    cmdbuf[5] <- count_addr as u32
    cmdbuf[6] <- (count_addr >> 32u64).u32()
    cmdbuf[7] <- 0x10u32
    cmdbuf[8] <- flags
    cmdbuf[9] <- 0u32
    cmdbuf[10] <- 0u32
    cmdbuf[11] <- 0u32
    cmdbuf[12] <- 0u32
    cmdbuf[13] <- 0u32
    cmdbuf[14] <- 0u32
    cmdbuf[15] <- 0u32
    return ORBIS_OK

def sceGnmDrawIndexIndirectMulti(cmdbuf: u32&?, size: u32, data_offset: u32, max_count: u32, shader_stage: u32, vertex_sgpr_offset: u32, instance_sgpr_offset: u32, flags: u32) -> int:
    if cmdbuf == null or size != 11u32 or vertex_sgpr_offset >= 0x10u32 or instance_sgpr_offset >= 0x10u32 or (shader_stage != 2u32 and shader_stage != 4u32 and shader_stage != 6u32):
        return -1
    sgpr_offset: u32 = GNM_INDIRECT_SGPR_OFFSETS[shader_stage]
    vertex_offset: mutable u32 = 0u32
    instance_offset: mutable u32 = 0u32
    if vertex_sgpr_offset != 0u32:
        vertex_offset <- vertex_sgpr_offset + sgpr_offset
    if instance_sgpr_offset != 0u32:
        instance_offset <- instance_sgpr_offset + sgpr_offset
    cmdbuf[0] <- data_offset
    cmdbuf[1] <- vertex_offset
    cmdbuf[2] <- instance_offset
    cmdbuf[3] <- max_count
    cmdbuf[4] <- 0x10u32
    cmdbuf[5] <- flags
    cmdbuf[6] <- 0u32
    cmdbuf[7] <- 0u32
    cmdbuf[8] <- 0u32
    cmdbuf[9] <- 0u32
    cmdbuf[10] <- 0u32
    return ORBIS_OK

