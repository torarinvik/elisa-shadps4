type s32 = i32
type s64 = i64
type OrbisKernelEqueue = s64

const GNM_MAX_COMPUTE_QUEUES: int = 64
const GNM_NUM_COMPUTE_PIPES: int = 4
const GNM_QUEUES_PER_PIPE: int = 16
global GNM_INVALID_QUEUE_ADDR: u64 = 0
const ORBIS_GNM_TESSELLATION_FALLBACK_ADDR: u64 = 0x100000000000
const GNM_TESSELLATION_OFFCHIP_SIZE: int = 0x800000
global GNM_INDIRECT_SGPR_OFFSETS: u32[7] = [0, 0, 0x4c, 0, 0xcc, 0, 0x14c]

const PM4CmdNop_DebugMarkerPush: u32 = 0x68750001
const PM4CmdNop_DebugMarkerPop: u32 = 0x68750002
const PM4CmdNop_DebugSetMarker: u32 = 0x68750003
const PM4CmdNop_DebugColorMarkerPush: u32 = 0x6875000e
const PM4_TYPE3_PACKET: u32 = 3

@fixed_layout
struct GnmComputeQueue:
    used: mutable bool
    pipe_id: mutable u32
    queue_id: mutable u32
    ring_base_addr: mutable VAddr
    ring_size_dw: mutable u32
    read_ptr_addr: mutable u32&?
    next_offs_dw: mutable u32

type GnmRuntimeSubmitCallback = func(u32, u32, u32&?, u32&?, u32&?, u32&?) -> int
type GnmRuntimeSubmitAndFlipCallback = func(u32, u32, u32&?, u32&?, u32&?, u32&?, u32, u32, u32, i64) -> int
type GnmRuntimeSubmitDoneCallback = func() -> int

const GNM_RUNTIME_BRIDGE_UNBOUND: int = 0x7fff0001

global mutable g_submissions_lock: u32 = 0
global mutable g_frames_submitted: u64 = 0
global mutable g_send_init_packet: bool = true
global mutable g_sdk_version: s32 = 0
global mutable g_tessellation_factors_ring_addr: u64 = GNM_INVALID_QUEUE_ADDR
global mutable g_compute_queues: array[GnmComputeQueue, GNM_MAX_COMPUTE_QUEUES] = zeroed
global mutable g_graphics_submit_count: u64 = 0u64
global mutable g_graphics_init_packet_submit_count: u64 = 0u64
global mutable g_graphics_last_submit_dcb_addr: u64 = 0u64
global mutable g_graphics_last_submit_dcb_size: u32 = 0u32
global mutable g_graphics_last_submit_ccb_addr: u64 = 0u64
global mutable g_graphics_last_submit_ccb_size: u32 = 0u32
global mutable g_liverpool_submit_gfx_count: u64 = 0u64
global mutable g_liverpool_submit_done_count: u64 = 0u64
global mutable g_rasterizer_flush_count: u64 = 0u64
global mutable g_rasterizer_on_submit_count: u64 = 0u64
global mutable g_runtime_scheduler_submit_count: u64 = 0u64
global mutable g_runtime_scheduler_last_tick: u64 = 0u64
global mutable g_runtime_present_prepare_count: u64 = 0u64
global mutable g_runtime_present_count: u64 = 0u64
global mutable g_runtime_present_success_count: u64 = 0u64
global mutable g_runtime_last_present_ok: bool = false
global mutable g_runtime_last_flip_vo_handle: u32 = 0u32
global mutable g_runtime_last_flip_buf_idx: u32 = 0u32
global mutable g_runtime_last_flip_mode: u32 = 0u32
global mutable g_runtime_last_flip_arg: i64 = 0
global mutable g_runtime_submit_bridge_count: u64 = 0u64
global mutable g_runtime_submit_flip_bridge_count: u64 = 0u64
global mutable g_runtime_submit_done_bridge_count: u64 = 0u64
global mutable g_runtime_bridge_last_result: int = ORBIS_OK
global mutable g_runtime_submit_bridge_cb: GnmRuntimeSubmitCallback? = null
global mutable g_runtime_submit_flip_bridge_cb: GnmRuntimeSubmitAndFlipCallback? = null
global mutable g_runtime_submit_done_bridge_cb: GnmRuntimeSubmitDoneCallback? = null
global mutable g_gnm_artifact_renderer_initialized_emitted: bool = false
global mutable g_gnm_artifact_submit_seen_emitted: bool = false
global mutable g_gnm_artifact_submit_path_bridge_emitted: bool = false
global mutable g_gnm_artifact_submit_path_native_emitted: bool = false

def gnm_c_string_length(value: u8&) -> u32:
    len: mutable u32 = 0
    while value[len] != 0:
        len <- len + 1
    return len

def gnm_create_pm4_header(opcode: u32, payload_dwords: u32) -> u32:
    return (PM4_TYPE3_PACKET << 30) | (((payload_dwords - 1) << 16)) | (opcode << 8)

def gnm_is_power_of_two(value: u32) -> bool:
    if value == 0:
        return false
    return (value & (value - 1)) == 0

def gnm_write_set_sh_reg_2(cmdbuf: mutable u32&?, index: u32, reg: u32, a: u32) -> u32:
    if cmdbuf == null:
        return index
    cmdbuf[index] <- gnm_create_pm4_header(PM4ItOpcode_SetShReg, 3)
    cmdbuf[index + 1] <- reg
    cmdbuf[index + 2] <- a
    return index + 3

def gnm_write_set_sh_reg_3(cmdbuf: mutable u32&?, index: u32, reg: u32, a: u32, b: u32, c: u32) -> u32:
    if cmdbuf == null:
        return index
    cmdbuf[index] <- gnm_create_pm4_header(PM4ItOpcode_SetShReg, 4)
    cmdbuf[index + 1] <- reg
    cmdbuf[index + 2] <- a
    cmdbuf[index + 3] <- b
    cmdbuf[index + 4] <- c
    return index + 5

def gnm_write_set_ctx_reg_2(cmdbuf: mutable u32&?, index: u32, reg: u32, a: u32) -> u32:
    if cmdbuf == null:
        return index
    cmdbuf[index] <- gnm_create_pm4_header(PM4ItOpcode_SetContextReg, 3)
    cmdbuf[index + 1] <- reg
    cmdbuf[index + 2] <- a
    return index + 3

def gnm_write_set_ctx_reg_3(cmdbuf: mutable u32&?, index: u32, reg: u32, a: u32, b: u32) -> u32:
    if cmdbuf == null:
        return index
    cmdbuf[index] <- gnm_create_pm4_header(PM4ItOpcode_SetContextReg, 4)
    cmdbuf[index + 1] <- reg
    cmdbuf[index + 2] <- a
    cmdbuf[index + 3] <- b
    return index + 4

def gnm_write_trailing_nop(cmdbuf: mutable u32&?, index: u32, payload_dwords: u32) -> void:
    if cmdbuf == null:
        return
    cmdbuf[index] <- gnm_create_pm4_header(PM4ItOpcode_Nop, payload_dwords)
    i: mutable u32 = 0
    while i < payload_dwords:
        cmdbuf[index + 1 + i] <- 0
        i <- i + 1

def gnm_next_compute_queue_slot() -> int:
    i: mutable int = 0
    while i < GNM_MAX_COMPUTE_QUEUES:
        if not g_compute_queues[i].used:
            return i
        i <- i + 1
    return -1

def gnm_reset_graphics_bootstrap_state() -> void:
    g_submissions_lock <- 0u32
    g_frames_submitted <- 0u64
    g_send_init_packet <- true
    g_graphics_submit_count <- 0u64
    g_graphics_init_packet_submit_count <- 0u64
    g_graphics_last_submit_dcb_addr <- 0u64
    g_graphics_last_submit_dcb_size <- 0u32
    g_graphics_last_submit_ccb_addr <- 0u64
    g_graphics_last_submit_ccb_size <- 0u32
    g_liverpool_submit_gfx_count <- 0u64
    g_liverpool_submit_done_count <- 0u64
    g_rasterizer_flush_count <- 0u64
    g_rasterizer_on_submit_count <- 0u64
    g_runtime_scheduler_submit_count <- 0u64
    g_runtime_scheduler_last_tick <- 0u64
    g_runtime_present_prepare_count <- 0u64
    g_runtime_present_count <- 0u64
    g_runtime_present_success_count <- 0u64
    g_runtime_last_present_ok <- false
    g_runtime_last_flip_vo_handle <- 0u32
    g_runtime_last_flip_buf_idx <- 0u32
    g_runtime_last_flip_mode <- 0u32
    g_runtime_last_flip_arg <- 0
    g_runtime_submit_bridge_count <- 0u64
    g_runtime_submit_flip_bridge_count <- 0u64
    g_runtime_submit_done_bridge_count <- 0u64
    g_runtime_bridge_last_result <- ORBIS_OK
    g_gnm_artifact_renderer_initialized_emitted <- false
    g_gnm_artifact_submit_seen_emitted <- false
    g_gnm_artifact_submit_path_bridge_emitted <- false
    g_gnm_artifact_submit_path_native_emitted <- false

def gnm_artifact_renderer_initialized_emitted() -> bool:
    return g_gnm_artifact_renderer_initialized_emitted

def gnm_artifact_submit_seen_emitted() -> bool:
    return g_gnm_artifact_submit_seen_emitted

def gnm_artifact_submit_path_bridge_emitted() -> bool:
    return g_gnm_artifact_submit_path_bridge_emitted

def gnm_artifact_submit_path_native_emitted() -> bool:
    return g_gnm_artifact_submit_path_native_emitted

def gnm_record_liverpool_submit_gfx(dcb_addr: u64, dcb_size: u32, ccb_addr: u64, ccb_size: u32) -> void:
    g_liverpool_submit_gfx_count <- g_liverpool_submit_gfx_count + 1u64
    g_graphics_last_submit_dcb_addr <- dcb_addr
    g_graphics_last_submit_dcb_size <- dcb_size
    g_graphics_last_submit_ccb_addr <- ccb_addr
    g_graphics_last_submit_ccb_size <- ccb_size

def gnm_record_rasterizer_submit() -> void:
    g_rasterizer_on_submit_count <- g_rasterizer_on_submit_count + 1u64
    g_rasterizer_flush_count <- g_rasterizer_flush_count + 1u64

def GnmDriver_BindRuntimeFramePathCallbacks(submit_cb: GnmRuntimeSubmitCallback?,
                                            submit_flip_cb: GnmRuntimeSubmitAndFlipCallback?,
                                            submit_done_cb: GnmRuntimeSubmitDoneCallback?) -> void:
    g_runtime_submit_bridge_cb <- submit_cb
    g_runtime_submit_flip_bridge_cb <- submit_flip_cb
    g_runtime_submit_done_bridge_cb <- submit_done_cb

def GnmDriver_ClearRuntimeFramePathCallbacks() -> void:
    g_runtime_submit_bridge_cb <- null
    g_runtime_submit_flip_bridge_cb <- null
    g_runtime_submit_done_bridge_cb <- null

def gnm_try_runtime_submit_bridge(workload: u32, count: u32, dcb_gpu_addrs: u32&?, dcb_sizes_in_bytes: u32&?,
                                  ccb_gpu_addrs: u32&?, ccb_sizes_in_bytes: u32&?) -> int:
    if g_runtime_submit_bridge_cb == null:
        return GNM_RUNTIME_BRIDGE_UNBOUND
    submit_cb: GnmRuntimeSubmitCallback = g_runtime_submit_bridge_cb.cast[GnmRuntimeSubmitCallback]
    rc: int = submit_cb(workload, count, dcb_gpu_addrs, dcb_sizes_in_bytes, ccb_gpu_addrs, ccb_sizes_in_bytes)
    g_runtime_submit_bridge_count <- g_runtime_submit_bridge_count + 1u64
    g_runtime_bridge_last_result <- rc
    return rc

def gnm_try_runtime_submit_flip_bridge(workload: u32, count: u32, dcb_gpu_addrs: u32&?, dcb_sizes_in_bytes: u32&?,
                                       ccb_gpu_addrs: u32&?, ccb_sizes_in_bytes: u32&?,
                                       vo_handle: u32, buf_idx: u32, flip_mode: u32, flip_arg: i64) -> int:
    if g_runtime_submit_flip_bridge_cb == null:
        return GNM_RUNTIME_BRIDGE_UNBOUND
    submit_flip_cb: GnmRuntimeSubmitAndFlipCallback = g_runtime_submit_flip_bridge_cb.cast[GnmRuntimeSubmitAndFlipCallback]
    rc: int = submit_flip_cb(workload, count, dcb_gpu_addrs, dcb_sizes_in_bytes, ccb_gpu_addrs, ccb_sizes_in_bytes,
                             vo_handle, buf_idx, flip_mode, flip_arg)
    g_runtime_submit_flip_bridge_count <- g_runtime_submit_flip_bridge_count + 1u64
    g_runtime_bridge_last_result <- rc
    return rc

def gnm_try_runtime_submit_done_bridge() -> int:
    if g_runtime_submit_done_bridge_cb == null:
        return GNM_RUNTIME_BRIDGE_UNBOUND
    submit_done_cb: GnmRuntimeSubmitDoneCallback = g_runtime_submit_done_bridge_cb.cast[GnmRuntimeSubmitDoneCallback]
    rc: int = submit_done_cb()
    g_runtime_submit_done_bridge_count <- g_runtime_submit_done_bridge_count + 1u64
    g_runtime_bridge_last_result <- rc
    return rc

def gnm_drive_runtime_submit(dcb_addr: u64, dcb_size: u32, ccb_addr: u64, ccb_size: u32) -> void:
    g_runtime_scheduler_submit_count <- g_runtime_scheduler_submit_count + 1u64
    g_runtime_scheduler_last_tick <- g_runtime_scheduler_last_tick + 1u64
    _ = dcb_addr
    _ = dcb_size
    _ = ccb_addr
    _ = ccb_size

def gnm_drive_runtime_present(vo_handle: u32, buf_idx: u32, flip_mode: u32, flip_arg: i64, cpu_address: u64) -> void:
    g_runtime_present_prepare_count <- g_runtime_present_prepare_count + 1u64
    g_runtime_present_count <- g_runtime_present_count + 1u64
    g_runtime_present_success_count <- g_runtime_present_success_count + 1u64
    g_runtime_last_present_ok <- true
    g_runtime_last_flip_vo_handle <- vo_handle
    g_runtime_last_flip_buf_idx <- buf_idx
    g_runtime_last_flip_mode <- flip_mode
    g_runtime_last_flip_arg <- flip_arg
    if videoout_is_port_open(vo_handle.i64()):
        submit_rc: int = sceVideoOutSubmitFlip(vo_handle.i64(), buf_idx.i64(), flip_mode.i64(), flip_arg)
        if submit_rc == ORBIS_OK:
            wait_rc: int = sceVideoOutWaitVblank(vo_handle.i64())
            g_runtime_last_present_ok <- wait_rc == ORBIS_OK
        else:
            g_runtime_last_present_ok <- false
    _ = cpu_address

def gnm_record_submit_batch(count: u32, dcb_gpu_addrs: u32&, dcb_sizes_in_bytes: u32&,
                            ccb_gpu_addrs: u32&?, ccb_sizes_in_bytes: u32&?) -> void:
    if not g_gnm_artifact_submit_seen_emitted:
        c_GuestExec_EmitCusaArtifactKV("gnm_submit_seen", 1u64)
        g_gnm_artifact_submit_seen_emitted <- true
    if not g_gnm_artifact_renderer_initialized_emitted:
        c_GuestExec_EmitCusaArtifactKV("renderer_initialized", 1u64)
        g_gnm_artifact_renderer_initialized_emitted <- true
    if g_send_init_packet:
        g_graphics_init_packet_submit_count <- g_graphics_init_packet_submit_count + 1u64
        gnm_record_liverpool_submit_gfx(0u64, 0u32, 0u64, 0u32)
        g_send_init_packet <- false
    i: mutable u32 = 0u32
    while i < count:
        ccb_addr: mutable u64 = 0u64
        ccb_size: mutable u32 = 0u32
        if ccb_gpu_addrs != null:
            ccb_addr <- ccb_gpu_addrs[i].u64()
        if ccb_sizes_in_bytes != null:
            ccb_size <- ccb_sizes_in_bytes[i]
        g_graphics_submit_count <- g_graphics_submit_count + 1u64
        gnm_record_liverpool_submit_gfx(dcb_gpu_addrs[i].u64(), dcb_sizes_in_bytes[i], ccb_addr, ccb_size)
        gnm_record_rasterizer_submit()
        gnm_drive_runtime_submit(dcb_gpu_addrs[i].u64(), dcb_sizes_in_bytes[i], ccb_addr, ccb_size)
        i <- i + 1u32

# @port core/libraries/gnmdriver/gnmdriver.cpp::sceGnmAddEqEvent sha256=9943bd7b76cbfc1e oracle@a3773841
def sceGnmAddEqEvent(eq: OrbisKernelEqueue, id: u64, udata: void&?) -> s32:
    if eq == 0:
        return ORBIS_KERNEL_ERROR_EBADF
    _ = id
    _ = udata
    return 0

# @port core/libraries/gnmdriver/gnmdriver.cpp::sceGnmAreSubmitsAllowed sha256=f94062b183a34f25 oracle@a3773841
def sceGnmAreSubmitsAllowed() -> int:
    return 1 if g_submissions_lock == 0 else 0

# @port core/libraries/gnmdriver/gnmdriver.cpp::sceGnmBeginWorkload sha256=fa832b17bd517db0 oracle@a3773841
def sceGnmBeginWorkload(workload_stream: u32, workload: mutable u64&?) -> int:
    if workload == null:
        return 3
    workload[0] <- 0 if workload_stream >= 0x10 else 1
    return 1 if workload_stream > 0x0f else 0

# @port core/libraries/gnmdriver/gnmdriver.cpp::sceGnmComputeWaitOnAddress sha256=ce6cd565343deb23 oracle@a3773841
def sceGnmComputeWaitOnAddress(cmdbuf: mutable u32&?, size: u32, addr: u64, mask: u32, cmp_func: u32, ref: u32) -> s32:
    if cmdbuf == null or size != 0xe:
        return -1
    cmdbuf[0] <- 0xc0000000
    cmdbuf[1] <- size
    cmdbuf[2] <- addr.cast[u32]
    cmdbuf[3] <- (addr >> 32).u32()
    cmdbuf[4] <- mask
    cmdbuf[5] <- ref
    cmdbuf[6] <- cmp_func
    cmdbuf[7] <- (0x1 if addr > 0xffff else 0) | 0x30
    cmdbuf[8] <- 0
    cmdbuf[9] <- 0
    cmdbuf[10] <- 0
    cmdbuf[11] <- 0
    cmdbuf[12] <- 0
    cmdbuf[13] <- 0
    return ORBIS_OK

# @port core/libraries/gnmdriver/gnmdriver.cpp::sceGnmComputeWaitSemaphore sha256=74dfba5959ea6acd oracle@a3773841
def sceGnmComputeWaitSemaphore() -> int:
    return 0

# @port core/libraries/gnmdriver/gnmdriver.cpp::sceGnmCreateWorkloadStream sha256=1c0d1a1f9160b52e oracle@a3773841
def sceGnmCreateWorkloadStream(param1: u64, workload_stream: mutable u32&?) -> int:
    if param1 == 0 or workload_stream == null:
        return 3
    workload_stream[0] <- 1
    return 0

