# @port core/libraries/gnmdriver/gnmdriver.cpp::sceGnmDeleteEqEvent sha256=a455bb85567f74e9 oracle@a3773841
def sceGnmDeleteEqEvent(eq: OrbisKernelEqueue, id: u64) -> s32:
