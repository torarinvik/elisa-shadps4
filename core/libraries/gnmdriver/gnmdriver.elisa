def sceGnmSetGsShader(cmdbuf: u32&?, size: u32, gs_regs: u32&?) -> s32:
    if cmdbuf == null or size < 0x1du32 or gs_regs == null or gs_regs[1] != 0u32:
        return -1
    index: mutable u32 = 0u32
    index <- gnm_write_set_sh_reg_2(cmdbuf, index, 0x88u, gs_regs[0])
    index <- gnm_write_set_sh_reg_3(cmdbuf, index, 0x8au, gs_regs[2], gs_regs[3], 0u32)
    index <- gnm_write_set_ctx_reg_2(cmdbuf, index, 0x2e5u, gs_regs[4])
    index <- gnm_write_set_ctx_reg_2(cmdbuf, index, 0x29bu, gs_regs[5])
    index <- gnm_write_set_ctx_reg_2(cmdbuf, index, 0x2e4u, gs_regs[6])
    gnm_write_trailing_nop(cmdbuf, index, 11u32)
    return ORBIS_OK

def sceGnmSetHsShader(cmdbuf: u32&?, size: u32, hs_regs: u32&?, param4: u32) -> s32:
    if cmdbuf == null or size < 0x1eu32 or hs_regs == null or hs_regs[1] != 0u32:
        return -1
    index: mutable u32 = 0u32
    index <- gnm_write_set_sh_reg_2(cmdbuf, index, 0x108u, hs_regs[0])
    index <- gnm_write_set_sh_reg_3(cmdbuf, index, 0x10au, hs_regs[2], hs_regs[3], 0u32)
    index <- gnm_write_set_ctx_reg_3(cmdbuf, index, 0x286u, hs_regs[5], hs_regs[6])
    index <- gnm_write_set_ctx_reg_2(cmdbuf, index, 0x2dbu, hs_regs[4])
    index <- gnm_write_set_ctx_reg_2(cmdbuf, index, 0x2d6u, param4)
    gnm_write_trailing_nop(cmdbuf, index, 11u32)
    return ORBIS_OK

def sceGnmSetLsShader(cmdbuf: u32&?, size: u32, ls_regs: u32&?, shader_modifier: u32) -> s32:
    modifier_mask: u32 = 0xfffffc3fu32 if (shader_modifier & 0xfffffc3fu32) == 0u32 else 0xfcfffc3fu32
    if cmdbuf == null or size < 0x17u32 or ls_regs == null or (shader_modifier & modifier_mask) != 0u32:
        return -1
    index: mutable u32 = 0u32
    modifier_value: u32 = ls_regs[2] if shader_modifier == 0u32 else ((ls_regs[2] & modifier_mask) | shader_modifier)
    index <- gnm_write_set_sh_reg_2(cmdbuf, index, 0x148u, ls_regs[0])
    index <- gnm_write_set_sh_reg_2(cmdbuf, index, 0x14bu, ls_regs[3])
    index <- gnm_write_set_sh_reg_3(cmdbuf, index, 0x14au, modifier_value, ls_regs[3])
    gnm_write_trailing_nop(cmdbuf, index, 11u32)
    return ORBIS_OK

def sceGnmSetPsShader(cmdbuf: u32&?, size: u32, ps_regs: u32&?) -> s32:
    if cmdbuf == null or size <= 0x27u32:
        return -1
    index: mutable u32 = 0u32
    if ps_regs == null:
        index <- gnm_write_set_sh_reg_2(cmdbuf, index, 8u, 0u32)
        index <- gnm_write_set_ctx_reg_2(cmdbuf, index, 0x203u, 0u32)
        gnm_write_trailing_nop(cmdbuf, index, 0x20u32)
        return ORBIS_OK
    if ps_regs[1] != 0u32:
        return -1
    index <- gnm_write_set_sh_reg_2(cmdbuf, index, 8u, ps_regs[0])
    index <- gnm_write_set_sh_reg_3(cmdbuf, index, 0xau, ps_regs[2], ps_regs[3], 0u32)
    index <- gnm_write_set_ctx_reg_3(cmdbuf, index, 0x1c4u, ps_regs[4], ps_regs[5])
    index <- gnm_write_set_ctx_reg_3(cmdbuf, index, 0x1b3u, ps_regs[6], ps_regs[7])
    index <- gnm_write_set_ctx_reg_2(cmdbuf, index, 0x1b6u, ps_regs[8])
    index <- gnm_write_set_ctx_reg_2(cmdbuf, index, 0x1b8u, ps_regs[9])
    index <- gnm_write_set_ctx_reg_2(cmdbuf, index, 0x203u, ps_regs[10])
    index <- gnm_write_set_ctx_reg_2(cmdbuf, index, 0x8fu, ps_regs[11])
    gnm_write_trailing_nop(cmdbuf, index, 11u32)
    return ORBIS_OK

def sceGnmSetPsShader350(cmdbuf: u32&?, size: u32, ps_regs: u32&?) -> s32:
    if cmdbuf == null or size <= 0x27u32:
        return -1
    index: mutable u32 = 0u32
    if ps_regs == null:
        index <- gnm_write_set_sh_reg_2(cmdbuf, index, 8u, 0u32)
        index <- gnm_write_set_ctx_reg_2(cmdbuf, index, 0x203u, 0u32)
        index <- gnm_write_set_ctx_reg_2(cmdbuf, index, 0x8fu, 0xfu)
        gnm_write_trailing_nop(cmdbuf, index, 0x1du32)
        return ORBIS_OK
    if ps_regs[1] != 0u32:
        return -1
    index <- gnm_write_set_sh_reg_2(cmdbuf, index, 8u, ps_regs[0])
    index <- gnm_write_set_sh_reg_3(cmdbuf, index, 0xau, ps_regs[2], ps_regs[3], 0u32)
    index <- gnm_write_set_ctx_reg_3(cmdbuf, index, 0x1c4u, ps_regs[4], ps_regs[5])
    index <- gnm_write_set_ctx_reg_3(cmdbuf, index, 0x1b3u, ps_regs[6], ps_regs[7])
    index <- gnm_write_set_ctx_reg_2(cmdbuf, index, 0x1b6u, ps_regs[8])
    index <- gnm_write_set_ctx_reg_2(cmdbuf, index, 0x1b8u, ps_regs[9])
    index <- gnm_write_set_ctx_reg_2(cmdbuf, index, 0x203u, ps_regs[10])
    index <- gnm_write_set_ctx_reg_2(cmdbuf, index, 0x8fu, ps_regs[11])
    gnm_write_trailing_nop(cmdbuf, index, 11u32)
    return ORBIS_OK

