def sceGnmInsertWaitFlipDone(cmdbuf: mutable u32&?, size: u32, vo_handle: s32, buf_idx: u32) -> s32:
    if cmdbuf == null or size != 7u32:
        return -1
    _ = vo_handle
    cmdbuf[0] <- gnm_create_pm4_header(0x37u32, 3u32)
    cmdbuf[1] <- 0x500u32
    dst_addr: u64 = (buf_idx.u64() * 8u64) & (~0x3u64)
    cmdbuf[2] <- (dst_addr & 0xffffffffu64).u32()
    cmdbuf[3] <- 0u32
    cmdbuf[4] <- 1u32
    cmdbuf[5] <- gnm_create_pm4_header(PM4ItOpcode_Nop, 1u32)
    cmdbuf[6] <- PM4CmdNop_DebugSetMarker
    return ORBIS_OK

