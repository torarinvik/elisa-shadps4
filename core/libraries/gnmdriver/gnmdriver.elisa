# @port core/libraries/gnmdriver/gnmdriver.cpp::sceGnmSetVgtControl sha256=fa3f9d47835a5a43 oracle@a3773841
def sceGnmSetVgtControl(cmdbuf: mutable u32&?, size: u32, prim_group_sz_minus_one: u32, partial_vs_wave_mode: u32, wd_switch_only_on_eop_mode: u32) -> s32:
    if cmdbuf == null or size != 3u32 or prim_group_sz_minus_one >= 0x100u32 or (partial_vs_wave_mode | wd_switch_only_on_eop_mode) >= 2u32:
        return -1
    index: mutable u32 = 0u32
    index <- gnm_write_set_ctx_reg_2(cmdbuf, index, 0x2aau, prim_group_sz_minus_one | ((partial_vs_wave_mode & 1u32) << 16u32))
    return ORBIS_OK

# @port core/libraries/gnmdriver/gnmdriver.cpp::sceGnmSetVsShader sha256=e60c60e0b4cf88a7 oracle@a3773841
def sceGnmSetVsShader(cmdbuf: mutable u32&?, size: u32, vs_regs: u32&?, shader_modifier: u32) -> s32:
    if cmdbuf == null or size < 0x1cu32 or vs_regs == null or (shader_modifier & 0xfcfffc3fu32) != 0u32 or vs_regs[1] != 0u32:
        return -1
    index: mutable u32 = 0u32
    var: u32 = vs_regs[2] if shader_modifier == 0u32 else ((vs_regs[2] & 0xfcfffc3fu32) | shader_modifier)
    index <- gnm_write_set_sh_reg_2(cmdbuf, index, 0x48u, vs_regs[0])
    index <- gnm_write_set_sh_reg_3(cmdbuf, index, 0x4au, var, vs_regs[3], 0u32)
    index <- gnm_write_set_ctx_reg_2(cmdbuf, index, 0x207u, vs_regs[6])
    index <- gnm_write_set_ctx_reg_2(cmdbuf, index, 0x1b1u, vs_regs[4])
    index <- gnm_write_set_ctx_reg_2(cmdbuf, index, 0x1c3u, vs_regs[5])
    gnm_write_trailing_nop(cmdbuf, index, 11u32)
    return ORBIS_OK

