# @port core/libraries/gnmdriver/gnmdriver.cpp::sceGnmInsertDingDongMarker sha256=583bc1ece0232355 oracle@a3773841
def sceGnmInsertDingDongMarker(cmdbuf: mutable u32&?, size: u32) -> s32:
    if cmdbuf == null or size != 4u32:
        return -1
    cmdbuf[0] <- gnm_create_pm4_header(PM4ItOpcode_Nop, 3u32)
    cmdbuf[1] <- 0u32
    cmdbuf[2] <- 0u32
    cmdbuf[3] <- 0u32
    return ORBIS_OK

# @port core/libraries/gnmdriver/gnmdriver.cpp::sceGnmInsertPopMarker sha256=86a82a51135f7627 oracle@a3773841
def sceGnmInsertPopMarker(cmdbuf: mutable u32&?, size: u32) -> s32:
    if cmdbuf == null or size != 6u32:
        return -1
    cmdbuf[0] <- gnm_create_pm4_header(PM4ItOpcode_Nop, 5u32)
    cmdbuf[1] <- PM4CmdNop_DebugMarkerPop
    cmdbuf[2] <- 0u32
    cmdbuf[3] <- 0u32
    cmdbuf[4] <- 0u32
    cmdbuf[5] <- 0u32
    return ORBIS_OK

# @port core/libraries/gnmdriver/gnmdriver.cpp::sceGnmInsertPushColorMarker sha256=d1a03202ac749692 oracle@a3773841
def sceGnmInsertPushColorMarker(cmdbuf: mutable u32&?, size: u32, marker: void&?, color: u32) -> s32:
    if cmdbuf == null or marker == null:
        return -1
    marker_buffer: u8& = marker.cast[u8&]
    marker_len: u32 = gnm_c_string_length(marker_buffer) + 1u32
    packet_size: u32 = ((marker_len + 0xcu32) >> 2u32) + ((marker_len + 0x10u32) >> 3u32) * 2u32
    if packet_size + 2u32 != size:
        return -1
    cmdbuf[0] <- gnm_create_pm4_header(PM4ItOpcode_Nop, packet_size)
    cmdbuf[1] <- PM4CmdNop_DebugColorMarkerPush
    bytes: mutable u8& = cmdbuf[1].cast[mutable u8&]
    for i in 0..<marker_len:
        bytes[4 + i] <- marker_buffer[i]
    bytes[4 + marker_len + 8u32] <- color.u8()
    bytes[4 + marker_len + 9u32] <- (color >> 8u32).u8()
    bytes[4 + marker_len + 10u32] <- (color >> 16u32).u8()
    bytes[4 + marker_len + 11u32] <- (color >> 24u32).u8()
    clear_len: u32 = packet_size * 4u32 - marker_len - 8u32 - 4u32
    for i in 0..<clear_len:
        bytes[4 + marker_len + 12u32 + i] <- 0u8
    return ORBIS_OK

# @port core/libraries/gnmdriver/gnmdriver.cpp::sceGnmInsertPushMarker sha256=ba8fadd3a9fbab26 oracle@a3773841
def sceGnmInsertPushMarker(cmdbuf: mutable u32&?, size: u32, marker: void&?) -> s32:
    if cmdbuf == null or marker == null:
        return -1
    marker_buffer: u8& = marker.cast[u8&]
    marker_len: u32 = gnm_c_string_length(marker_buffer) + 1u32
    packet_size: u32 = ((marker_len + 8u32) >> 2u32) + ((marker_len + 0xcu32) >> 3u32) * 2u32
    if packet_size + 2u32 != size:
        return -1
    cmdbuf[0] <- gnm_create_pm4_header(PM4ItOpcode_Nop, packet_size)
    cmdbuf[1] <- PM4CmdNop_DebugMarkerPush
    bytes: mutable u8& = cmdbuf[1].cast[mutable u8&]
    for i in 0..<marker_len:
        bytes[4 + i] <- marker_buffer[i]
    clear_len: u32 = packet_size * 4u32 - marker_len
    for i in 0..<clear_len:
        bytes[4 + marker_len + i] <- 0u8
    return ORBIS_OK

