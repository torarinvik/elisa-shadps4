    cmdbuf[1] <- index_count
    cmdbuf[2] <- index_count
    cmdbuf[3] <- flags
    cmdbuf[4] <- 0
    cmdbuf[5] <- 0
    cmdbuf[6] <- 0
    cmdbuf[7] <- 0
    cmdbuf[8] <- 0
    return ORBIS_OK

