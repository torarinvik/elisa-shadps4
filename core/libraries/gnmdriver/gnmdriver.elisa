# @port core/libraries/gnmdriver/gnmdriver.cpp::sceGnmEndWorkload sha256=59fac7bcf95907b5 oracle@a3773841
def sceGnmEndWorkload(workload: u64) -> int:
    if workload != 0u64:
        if 0xfu64 < ((workload >> 0x38u64) & 0xffu64):
            return 2
        return 0
    return 2

