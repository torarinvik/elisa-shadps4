def avsrc_null_open_file(obj: void&?, path: i8&?) -> i32:
    _ = obj
    _ = path
    return -1

def avsrc_null_close_file(obj: void&?) -> i32:
    _ = obj
    return 0

def avsrc_null_read_offset_file(obj: void&?, buf: mutable u8&, pos: u64, length: u32) -> i32:
    _ = obj
    _ = buf
    _ = pos
    _ = length
    return 0

def avsrc_null_size_file(obj: void&?) -> u64:
    _ = obj
    return 0u64

def avsrc_set_file_replacement(slot: int, object_ptr: void&?, open_cb: void&?, close_cb: void&?, read_offset_cb: void&?, size_cb: void&?):
    avsrc_file_object[slot] <- object_ptr
    avsrc_file_fd[slot] <- -1
    avsrc_file_position[slot] <- 0u64
    avsrc_file_size_bytes[slot] <- 0u64
    if open_cb == null:
        avsrc_file_replacement_enabled[slot] <- false
        avsrc_file_open[slot] <- avsrc_null_open_file
        avsrc_file_close[slot] <- avsrc_null_close_file
        avsrc_file_read_offset[slot] <- avsrc_null_read_offset_file
        avsrc_file_size[slot] <- avsrc_null_size_file
        return
    avsrc_file_replacement_enabled[slot] <- true
    avsrc_file_open[slot] <- open_cb.cast[AvsrcOpenFile]
    avsrc_file_close[slot] <- avsrc_null_close_file if close_cb == null else close_cb.cast[AvsrcCloseFile]
    avsrc_file_read_offset[slot] <- avsrc_null_read_offset_file if read_offset_cb == null else read_offset_cb.cast[AvsrcReadOffsetFile]
    avsrc_file_size[slot] <- avsrc_null_size_file if size_cb == null else size_cb.cast[AvsrcSizeFile]

def avsrc_file_close_if_open(slot: int):
    if avsrc_file_replacement_enabled[slot] and avsrc_file_fd[slot] >= 0:
        close_cb: AvsrcCloseFile = avsrc_file_close[slot]
        _ = close_cb(avsrc_file_object[slot])
    avsrc_file_fd[slot] <- -1
    avsrc_file_position[slot] <- 0u64
    avsrc_file_size_bytes[slot] <- 0u64

def avsrc_file_reset(slot: int):
    avsrc_file_position[slot] <- 0u64

def avsrc_file_read_packet(slot: int, buffer: mutable u8&?, requested_size: i32) -> i32:
    if not avsrc_file_replacement_enabled[slot] or avsrc_file_fd[slot] < 0 or buffer == null:
        return -1
    if requested_size <= 0:
        return 0
    if avsrc_file_position[slot] >= avsrc_file_size_bytes[slot]:
        return -1
    remaining: u64 = avsrc_file_size_bytes[slot] - avsrc_file_position[slot]
    size: mutable u32 = requested_size.u32()
    if size.u64() > remaining:
        size <- remaining.u32()
    read_cb: AvsrcReadOffsetFile = avsrc_file_read_offset[slot]
    bytes_read: i32 = read_cb(avsrc_file_object[slot], buffer.ref[mutable u8&], avsrc_file_position[slot], size)
    if bytes_read == 0 and size != 0:
        return -1
    if bytes_read > 0:
        avsrc_file_position[slot] <- avsrc_file_position[slot] + bytes_read.u64()
    return bytes_read

def avsrc_file_clamp_position(value: i64, max_value: u64) -> u64:
    if value <= 0:
        return 0u64
    if value.u64() > max_value:
        return max_value
    return value.u64()

def avsrc_file_seek(slot: int, offset: i64, whence: i32) -> i64:
    if not avsrc_file_replacement_enabled[slot] or avsrc_file_fd[slot] < 0:
        return -1
    if (whence & AVSRC_AVSEEK_SIZE) != 0:
        return avsrc_file_size_bytes[slot].i64()
    if whence == AVSRC_SEEK_CUR:
        avsrc_file_position[slot] <- avsrc_file_clamp_position(avsrc_file_position[slot].i64() + offset, avsrc_file_size_bytes[slot])
        return avsrc_file_position[slot].i64()
    if whence == AVSRC_SEEK_SET:
        avsrc_file_position[slot] <- avsrc_file_clamp_position(offset, avsrc_file_size_bytes[slot])
        return avsrc_file_position[slot].i64()
    if whence == AVSRC_SEEK_END:
        avsrc_file_position[slot] <- avsrc_file_clamp_position(avsrc_file_size_bytes[slot].i64() + offset, avsrc_file_size_bytes[slot])
        return avsrc_file_position[slot].i64()
    return -1

def avsrc_video_q_idx(slot: int, q_index: int) -> int:
    return slot * AVSRC_TS_QUEUE_CAP + q_index

def avsrc_audio_q_idx(slot: int, q_index: int) -> int:
    return slot * AVSRC_TS_QUEUE_CAP + q_index

def avsrc_video_pkt_q_idx(slot: int, q_index: int) -> int:
    return slot * AVSRC_TS_QUEUE_CAP + q_index

def avsrc_audio_pkt_q_idx(slot: int, q_index: int) -> int:
    return slot * AVSRC_TS_QUEUE_CAP + q_index

def avsrc_video_q_push(slot: int, value: u64):
    if avsrc_video_q_size[slot] >= AVSRC_TS_QUEUE_CAP:
        return
    qtail: mutable int = avsrc_video_q_tail[slot]
    avsrc_video_q_ts[avsrc_video_q_idx(slot, qtail)] <- value
    qtail <- qtail + 1
    if qtail >= AVSRC_TS_QUEUE_CAP:
        qtail <- 0
    avsrc_video_q_tail[slot] <- qtail
    avsrc_video_q_size[slot] <- avsrc_video_q_size[slot] + 1

def avsrc_audio_q_push(slot: int, value: u64):
    if avsrc_audio_q_size[slot] >= AVSRC_TS_QUEUE_CAP:
        return
    qtail: mutable int = avsrc_audio_q_tail[slot]
    avsrc_audio_q_ts[avsrc_audio_q_idx(slot, qtail)] <- value
    qtail <- qtail + 1
    if qtail >= AVSRC_TS_QUEUE_CAP:
        qtail <- 0
    avsrc_audio_q_tail[slot] <- qtail
    avsrc_audio_q_size[slot] <- avsrc_audio_q_size[slot] + 1

def avsrc_video_pkt_q_push(slot: int, value: u64):
    if avsrc_video_pkt_q_size[slot] >= AVSRC_TS_QUEUE_CAP:
        return
    qtail: mutable int = avsrc_video_pkt_q_tail[slot]
    avsrc_video_pkt_q_ts[avsrc_video_pkt_q_idx(slot, qtail)] <- value
    qtail <- qtail + 1
    if qtail >= AVSRC_TS_QUEUE_CAP:
        qtail <- 0
    avsrc_video_pkt_q_tail[slot] <- qtail
    avsrc_video_pkt_q_size[slot] <- avsrc_video_pkt_q_size[slot] + 1

def avsrc_audio_pkt_q_push(slot: int, value: u64):
    if avsrc_audio_pkt_q_size[slot] >= AVSRC_TS_QUEUE_CAP:
        return
    qtail: mutable int = avsrc_audio_pkt_q_tail[slot]
    avsrc_audio_pkt_q_ts[avsrc_audio_pkt_q_idx(slot, qtail)] <- value
    qtail <- qtail + 1
    if qtail >= AVSRC_TS_QUEUE_CAP:
        qtail <- 0
    avsrc_audio_pkt_q_tail[slot] <- qtail
    avsrc_audio_pkt_q_size[slot] <- avsrc_audio_pkt_q_size[slot] + 1

def avsrc_video_q_pop(slot: int, out_ts: mutable u64&) -> bool:
    if avsrc_video_q_size[slot] <= 0:
        return false
    qhead: mutable int = avsrc_video_q_head[slot]
    out_ts <- avsrc_video_q_ts[avsrc_video_q_idx(slot, qhead)]
    qhead <- qhead + 1
    if qhead >= AVSRC_TS_QUEUE_CAP:
        qhead <- 0
    avsrc_video_q_head[slot] <- qhead
    avsrc_video_q_size[slot] <- avsrc_video_q_size[slot] - 1
    return true

def avsrc_video_q_peek(slot: int, out_ts: mutable u64&) -> bool:
    if avsrc_video_q_size[slot] <= 0:
        return false
    qhead: int = avsrc_video_q_head[slot]
    out_ts <- avsrc_video_q_ts[avsrc_video_q_idx(slot, qhead)]
    return true

def avsrc_audio_q_pop(slot: int, out_ts: mutable u64&) -> bool:
    if avsrc_audio_q_size[slot] <= 0:
        return false
