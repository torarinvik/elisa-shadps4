include "./avplayer_ffmpeg_ffi.elisa"
include "./avplayer_error.elisa"

struct AvsrcHostTimeval:
    tv_sec: i64
    tv_usec: i64

extern gettimeofday(tv: mutable AvsrcHostTimeval&?, tz: void&?) -> int

def high_resolution_now_ns() -> i64:
    tv: mutable AvsrcHostTimeval = zeroed
    if gettimeofday(tv.ref[mutable AvsrcHostTimeval&], null) != 0:
        return 0
    return (tv.tv_sec * 1000000000) + (tv.tv_usec * 1000)

const AVPLAYER_MAX_STREAMS: int = 8
const AVSRC_MAX_HANDLES: int = 64
const AVSRC_TS_QUEUE_CAP: int = 64
const AVSRC_DEMUX_BURST_MAX: int = 8
const AVSRC_OUTPUT_FILL_MAX: int = 8

const AVPLAYER_STREAM_TYPE_VIDEO: u32 = 0
const AVPLAYER_STREAM_TYPE_AUDIO: u32 = 1
const AVPLAYER_STREAM_TYPE_TIMED_TEXT: u32 = 2
const AVPLAYER_STREAM_TYPE_UNKNOWN: u32 = 3
const AVPLAYER_AV_SYNC_MODE_DEFAULT: i32 = 0
const AVPLAYER_AV_SYNC_MODE_NONE: i32 = 1
const AVSRC_PREFETCH_TARGET: int = 2
const AVSRC_DEFAULT_VIDEO_FRAMEBUFFERS: i32 = 2
const AVSRC_MAX_VIDEO_FRAMEBUFFERS: i32 = 16
const AVSRC_SEEK_SET: i32 = 0
const AVSRC_SEEK_CUR: i32 = 1
const AVSRC_SEEK_END: i32 = 2
const AVSRC_AVSEEK_SIZE: i32 = 0x10000

type AvsrcOpenFile = func(void&?, i8&?) -> i32
type AvsrcCloseFile = func(void&?) -> i32
type AvsrcReadOffsetFile = func(void&?, mutable u8&, u64, u32) -> i32
type AvsrcSizeFile = func(void&?) -> u64

