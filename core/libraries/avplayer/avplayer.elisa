            avplayer_copy_language_codes(video_info.details, avsrc_get_stream_language(handle - 1, video_stream_index.u32()))
            video_width: mutable u32 = avsrc_get_video_width(handle - 1)
            video_height: mutable u32 = avsrc_get_video_height(handle - 1)
            if video_width == 0 or video_height == 0:
                typ: mutable u32 = 0
                duration: mutable u64 = 0
                start_time: mutable u64 = 0
                audio_channels: mutable u32 = 0
                audio_sample_rate: mutable u32 = 0
                if avsrc_get_stream_info(handle - 1, video_stream_index.u32(), typ, duration, start_time, video_width, video_height, audio_channels, audio_sample_rate) and typ == AVPLAYER_STREAM_TYPE_VIDEO:
                    video_info.details.video.width <- video_width
                    video_info.details.video.height <- video_height
                    if video_height > 0:
                        video_info.details.video.aspect_ratio <- video_width.f32() / video_height.f32()
            else:
                video_info.details.video.width <- video_width
                video_info.details.video.height <- video_height
                if video_height > 0:
                    video_info.details.video.aspect_ratio <- video_width.f32() / video_height.f32()
            aspect_num: u32 = avsrc_get_last_video_aspect_num(handle - 1)
            aspect_den: u32 = avsrc_get_last_video_aspect_den(handle - 1)
            if aspect_num > 0 and aspect_den > 0:
                video_info.details.video.aspect_ratio <- aspect_num.f32() / aspect_den.f32()
            video_info.p_data <- avplayer_ensure_video_payload(handle - 1, video_info.details.video.width, video_info.details.video.height).cast[mutable u8&?]
        g_handle_current_time[handle - 1] <- video_info.timestamp
    avplayer_controller_tick(handle - 1)
    return ok

def sceAvPlayerGetVideoDataEx(handle: AvPlayerHandle, video_info: mutable AvPlayerFrameInfoEx&?) -> bool:
    if not avplayer_valid_handle(handle) or video_info == null:
        return false
    pending_warning: mutable i32 = 0
    if avsrc_consume_warning(handle - 1, pending_warning):
        avs_on_warning(handle - 1, pending_warning)
    video_info.p_data <- null
    video_info.reserved[0] <- 0
    video_info.reserved[1] <- 0
    video_info.reserved[2] <- 0
    video_info.reserved[3] <- 0
    avplayer_clear_stream_details_ex(video_info.details)
    pre_video_width: u32 = avsrc_get_video_width(handle - 1)
    pre_video_height: u32 = avsrc_get_video_height(handle - 1)
    pre_video_size: u32 = avplayer_video_payload_size(pre_video_width, pre_video_height)
    pre_video_payload: void&? = avplayer_ensure_video_payload(handle - 1, pre_video_width, pre_video_height)
    ok: bool = avsrc_get_video_data_into(handle - 1, video_info.timestamp, pre_video_payload.cast[mutable u8&?], pre_video_size)
    has_frames_for_play: bool = avsrc_has_frames(handle - 1, 0)
    has_frames_for_buffer_resume: bool = avsrc_has_frames(handle - 1, 1)
    if not ok:
        if not avsrc_is_active(handle - 1) and avsrc_should_signal_eof(handle - 1):
            avs_on_eof(handle - 1)
        avs_update_buffering_state(handle - 1, has_frames_for_play, has_frames_for_buffer_resume)
    else:
        avs_update_buffering_state(handle - 1, has_frames_for_play, has_frames_for_buffer_resume)
        video_stream_index: i32 = avsrc_get_video_stream_index(handle - 1)
        if video_stream_index >= 0:
            cached_video_start_time: u64 = avsrc_get_video_start_time(handle - 1)
            if cached_video_start_time > 0:
                video_info.timestamp <- cached_video_start_time + video_info.timestamp
            avplayer_copy_language_codes_ex(video_info.details, avsrc_get_stream_language(handle - 1, video_stream_index.u32()))
            video_width: mutable u32 = avsrc_get_video_width(handle - 1)
            video_height: mutable u32 = avsrc_get_video_height(handle - 1)
            if video_width == 0 or video_height == 0:
                typ: mutable u32 = 0
                duration: mutable u64 = 0
                start_time: mutable u64 = 0
                audio_channels: mutable u32 = 0
                audio_sample_rate: mutable u32 = 0
                if avsrc_get_stream_info(handle - 1, video_stream_index.u32(), typ, duration, start_time, video_width, video_height, audio_channels, audio_sample_rate) and typ == AVPLAYER_STREAM_TYPE_VIDEO:
                    video_info.details.video.width <- video_width
                    video_info.details.video.height <- video_height
                    if video_height > 0:
                        video_info.details.video.aspect_ratio <- video_width.f32() / video_height.f32()
            else:
                video_info.details.video.width <- video_width
                video_info.details.video.height <- video_height
                if video_height > 0:
                    video_info.details.video.aspect_ratio <- video_width.f32() / video_height.f32()
            aspect_num: u32 = avsrc_get_last_video_aspect_num(handle - 1)
            aspect_den: u32 = avsrc_get_last_video_aspect_den(handle - 1)
            if aspect_num > 0 and aspect_den > 0:
                video_info.details.video.aspect_ratio <- aspect_num.f32() / aspect_den.f32()
            frame_interval_ms: u32 = avsrc_get_video_frame_interval_ms(handle - 1)
            if frame_interval_ms > 0:
                video_info.details.video.framerate <- 1000 / frame_interval_ms
            else:
                video_info.details.video.framerate <- 30
            video_info.details.video.crop_left_offset <- 0
            video_info.details.video.crop_right_offset <- 0
            video_info.details.video.crop_top_offset <- 0
            video_info.details.video.crop_bottom_offset <- 0
            if video_info.details.video.width > 0:
                delivered_pitch: u32 = avsrc_get_last_video_pitch(handle - 1)
                if delivered_pitch > 0:
                    video_info.details.video.pitch <- delivered_pitch
                else:
                    video_info.details.video.pitch <- video_info.details.video.width
                video_info.details.video.luma_bit_depth <- 8
                video_info.details.video.chroma_bit_depth <- 8
                video_info.details.video.video_full_range_flag <- avsrc_get_last_video_full_range(handle - 1)
            video_info.p_data <- avplayer_ensure_video_payload(handle - 1, video_info.details.video.width, video_info.details.video.height)
        g_handle_current_time[handle - 1] <- video_info.timestamp
    avplayer_controller_tick(handle - 1)
    return ok

def sceAvPlayerInit(data: mutable AvPlayerInitData&?) -> AvPlayerHandle:
    if data == null:
        return 0
    handle: AvPlayerHandle = avplayer_alloc_handle()
    if handle != 0:
        g_handle_auto_start[handle - 1] <- data.auto_start
        g_handle_default_language[handle - 1] <- data.default_language
        g_handle_event_object[handle - 1] <- data.event_replacement.object_ptr
        if data.event_replacement.event_callback != null:
            g_handle_event_callback[handle - 1] <- data.event_replacement.event_callback.cast[AvPlayerEventCallback]
        else:
            g_handle_event_callback[handle - 1] <- avplayer_null_event_callback
        avplayer_store_allocator(handle - 1, data.memory_replacement)
        avsrc_set_max_video_framebuffers(handle - 1, data.num_output_video_framebuffers)
        requested_pool_count: mutable int = data.num_output_video_framebuffers
        if requested_pool_count < 2:
            requested_pool_count <- 2
        if requested_pool_count > AVPLAYER_VIDEO_PAYLOAD_POOL_MAX:
            requested_pool_count <- AVPLAYER_VIDEO_PAYLOAD_POOL_MAX
        g_handle_video_payload_count[handle - 1] <- requested_pool_count
    return handle

def sceAvPlayerInitEx(p_data: AvPlayerInitData&?, p_player: mutable AvPlayerHandle&?) -> i32:
    if p_data == null or p_player == null:
        return ORBIS_AVPLAYER_ERROR_INVALID_PARAMS
    p_player <- avplayer_alloc_handle()
    if p_player == 0:
        return ORBIS_AVPLAYER_ERROR_OPERATION_FAILED
    g_handle_auto_start[p_player - 1] <- p_data.auto_start
    g_handle_default_language[p_player - 1] <- p_data.default_language
    g_handle_event_object[p_player - 1] <- p_data.event_replacement.object_ptr
    if p_data.event_replacement.event_callback != null:
        g_handle_event_callback[p_player - 1] <- p_data.event_replacement.event_callback.cast[AvPlayerEventCallback]
    else:
        g_handle_event_callback[p_player - 1] <- avplayer_null_event_callback
    avplayer_store_allocator(p_player - 1, p_data.memory_replacement)
    avsrc_set_max_video_framebuffers(p_player - 1, p_data.num_output_video_framebuffers)
    requested_pool_count: mutable int = p_data.num_output_video_framebuffers
    if requested_pool_count < 2:
        requested_pool_count <- 2
    if requested_pool_count > AVPLAYER_VIDEO_PAYLOAD_POOL_MAX:
        requested_pool_count <- AVPLAYER_VIDEO_PAYLOAD_POOL_MAX
    g_handle_video_payload_count[p_player - 1] <- requested_pool_count
    return ORBIS_OK

def sceAvPlayerIsActive(handle: AvPlayerHandle) -> bool:
    if not avplayer_valid_handle(handle):
        return false
    return avsrc_is_active(handle - 1) and g_handle_active_playback[handle - 1]

def sceAvPlayerJumpToTime(handle: AvPlayerHandle, target_time: u64) -> i32:
    _ = target_time
    if not avplayer_valid_handle(handle):
        return ORBIS_AVPLAYER_ERROR_INVALID_PARAMS
    avplayer_controller_tick(handle - 1)
    return ORBIS_OK

def sceAvPlayerPause(handle: AvPlayerHandle) -> i32:
    if not avplayer_valid_handle(handle):
        return ORBIS_AVPLAYER_ERROR_INVALID_PARAMS
    if not avs_pause(handle - 1):
        return ORBIS_AVPLAYER_ERROR_OPERATION_FAILED
    avplayer_controller_tick(handle - 1)
    avsrc_pause(handle - 1)
    g_handle_active_playback[handle - 1] <- false
    return ORBIS_OK

def sceAvPlayerPostInit(handle: AvPlayerHandle, data: mutable AvPlayerPostInitData&?) -> i32:
    if not avplayer_valid_handle(handle) or data == null:
        return ORBIS_AVPLAYER_ERROR_INVALID_PARAMS
    return ORBIS_OK

def sceAvPlayerPrintf(format: i8&?) -> i32:
    _ = format
    return ORBIS_OK

def sceAvPlayerResume(handle: AvPlayerHandle) -> i32:
    if not avplayer_valid_handle(handle):
        return ORBIS_AVPLAYER_ERROR_INVALID_PARAMS
    if not avs_resume(handle - 1):
        return ORBIS_AVPLAYER_ERROR_OPERATION_FAILED
    avplayer_controller_tick(handle - 1)
    avsrc_resume(handle - 1)
    g_handle_active_playback[handle - 1] <- true
    return ORBIS_OK

def sceAvPlayerSetAvSyncMode(handle: AvPlayerHandle, sync_mode: i32) -> i32:
    if not avplayer_valid_handle(handle):
        return ORBIS_AVPLAYER_ERROR_INVALID_PARAMS
    avsrc_set_av_sync_mode(handle - 1, sync_mode)
    avplayer_controller_tick(handle - 1)
    return ORBIS_OK

def sceAvPlayerSetLogCallback(log_cb: void&?, user_data: void&?) -> i32:
    _ = log_cb
    _ = user_data
    return ORBIS_OK

def sceAvPlayerSetLooping(handle: AvPlayerHandle, loop_flag: bool) -> i32:
    if not avplayer_valid_handle(handle):
        return ORBIS_AVPLAYER_ERROR_INVALID_PARAMS
    if not avsrc_set_looping(handle - 1, loop_flag):
        return ORBIS_AVPLAYER_ERROR_OPERATION_FAILED
    g_handle_looping[handle - 1] <- loop_flag
    avplayer_controller_tick(handle - 1)
    return ORBIS_OK

def sceAvPlayerSetTrickSpeed(handle: AvPlayerHandle, trick_speed: i32) -> i32:
    _ = trick_speed
    if not avplayer_valid_handle(handle):
        return ORBIS_AVPLAYER_ERROR_INVALID_PARAMS
    avplayer_controller_tick(handle - 1)
    return ORBIS_OK

def sceAvPlayerStart(handle: AvPlayerHandle) -> i32:
    if not avplayer_valid_handle(handle):
        return ORBIS_AVPLAYER_ERROR_INVALID_PARAMS
    if not avs_start(handle - 1):
        return ORBIS_AVPLAYER_ERROR_OPERATION_FAILED
    avplayer_controller_tick(handle - 1)
    if not avsrc_start(handle - 1):
        return ORBIS_AVPLAYER_ERROR_OPERATION_FAILED
    g_handle_active_playback[handle - 1] <- true
    return ORBIS_OK

def sceAvPlayerStop(handle: AvPlayerHandle) -> i32:
    if not avplayer_valid_handle(handle):
        return ORBIS_AVPLAYER_ERROR_INVALID_PARAMS
    if not avs_stop(handle - 1):
        return ORBIS_AVPLAYER_ERROR_OPERATION_FAILED
    avplayer_controller_tick(handle - 1)
    if not avsrc_stop(handle - 1):
        return ORBIS_AVPLAYER_ERROR_OPERATION_FAILED
    g_handle_active_playback[handle - 1] <- false
    return ORBIS_OK

def sceAvPlayerStreamCount(handle: AvPlayerHandle) -> i32:
    if not avplayer_valid_handle(handle):
        return ORBIS_AVPLAYER_ERROR_INVALID_PARAMS
    return avsrc_get_stream_count(handle - 1)

def sceAvPlayerVprintf(format: i8&?, args: void&?) -> i32:
    _ = format
    _ = args
    return ORBIS_OK

def AvPlayer_RegisterLib(sym: void&?) -> void:
    _ = sym
