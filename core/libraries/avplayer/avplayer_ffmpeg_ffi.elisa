extern memcpy(dest: mutable void&, src: void&, n: usize) -> mutable void&

def avffmpeg_free_packet(pkt: void&?):
    if pkt == null:
        return
    box: mutable void&?[1] = zeroed
    box[0] <- pkt
    av_packet_free(box[0])

def avffmpeg_free_frame(frame: void&?):
    if frame == null:
        return
    box: mutable void&?[1] = zeroed
    box[0] <- frame
    av_frame_free(box[0])

def avffmpeg_free_codec_context(codec_ctx: void&?):
    if codec_ctx == null:
        return
    box: mutable void&?[1] = zeroed
    box[0] <- codec_ctx
    avcodec_free_context(box[0])

def avffmpeg_close_input(ctx: void&?):
    if ctx == null:
        return
    box: mutable void&?[1] = zeroed
    box[0] <- ctx
    avformat_close_input(box[0])

def avffmpeg_free_swr(ctx: void&?):
    if ctx == null:
        return
    box: mutable void&?[1] = zeroed
    box[0] <- ctx
    swr_free(box[0])

global mutable avffmpeg_contexts: void&?[AVPLAYER_FFMPEG_MAX_HANDLES] = zeroed
global mutable avffmpeg_started: bool[AVPLAYER_FFMPEG_MAX_HANDLES] = zeroed
global mutable avffmpeg_paused: bool[AVPLAYER_FFMPEG_MAX_HANDLES] = zeroed
global mutable avffmpeg_next_ts_audio: u64[AVPLAYER_FFMPEG_MAX_HANDLES] = zeroed
global mutable avffmpeg_next_ts_video: u64[AVPLAYER_FFMPEG_MAX_HANDLES] = zeroed
global mutable avffmpeg_last_stream_ts: u64[AVPLAYER_FFMPEG_MAX_HANDLES * AVPLAYER_FFMPEG_MAX_STREAMS.int()] = zeroed
global mutable avffmpeg_stream_eof_drained: bool[AVPLAYER_FFMPEG_MAX_HANDLES * AVPLAYER_FFMPEG_MAX_STREAMS.int()] = zeroed

def avffmpeg_slot(handle: i32) -> int:
    return (handle - 1).int()

def avffmpeg_stream_slot(handle: i32, stream_index: u32) -> int:
    return avffmpeg_slot(handle) * AVPLAYER_FFMPEG_MAX_STREAMS.int() + stream_index.int()

def avffmpeg_valid_handle(handle: i32) -> bool:
    if handle <= 0 or handle > AVPLAYER_FFMPEG_MAX_HANDLES.i32():
        return false
    return avffmpeg_contexts[avffmpeg_slot(handle)] != null

def avplayer_ffmpeg_context(handle: i32) -> void&?:
    if not avffmpeg_valid_handle(handle):
        return null
    return avffmpeg_contexts[avffmpeg_slot(handle)]

def avplayer_ffmpeg_store_context(ctx: void&?) -> i32:
    if ctx == null:
        return -1
    i: mutable int = 0
    while i < AVPLAYER_FFMPEG_MAX_HANDLES:
        if avffmpeg_contexts[i] == null:
            avffmpeg_contexts[i] <- ctx
            avffmpeg_started[i] <- false
            avffmpeg_paused[i] <- false
            avffmpeg_next_ts_audio[i] <- 0
            avffmpeg_next_ts_video[i] <- 0
            j: mutable int = 0
            while j < AVPLAYER_FFMPEG_MAX_STREAMS.int():
                stream_slot: int = i * AVPLAYER_FFMPEG_MAX_STREAMS.int() + j
                avffmpeg_last_stream_ts[stream_slot] <- 0
                avffmpeg_stream_eof_drained[stream_slot] <- false
                j <- j + 1
            return (i + 1).i32()
        i <- i + 1
    return -1

def avplayer_ffmpeg_open(path: i8&?) -> i32:
    if path == null:
        return -1

    ctx_box: mutable void&?[1] = zeroed
    if avformat_open_input(ctx_box[0], path, null, null) < 0:
        return -1
    ctx: void&? = ctx_box[0]
    if avformat_find_stream_info(ctx, null) < 0:
        avffmpeg_close_input(ctx)
        return -1

    handle: i32 = avplayer_ffmpeg_store_context(ctx)
    if handle <= 0:
        avffmpeg_close_input(ctx)
        return -1
    return handle

def avplayer_ffmpeg_close(handle: i32) -> void:
    if not avffmpeg_valid_handle(handle):
        return
    slot: int = avffmpeg_slot(handle)
    ctx: void&? = avffmpeg_contexts[slot]
    avffmpeg_close_input(ctx)
    avffmpeg_contexts[slot] <- null
    avffmpeg_started[slot] <- false
    avffmpeg_paused[slot] <- false

def avplayer_ffmpeg_stream_count(handle: i32) -> i32:
    if not avffmpeg_valid_handle(handle):
        return -1
    ctx: AVFormatContextPublicPrefix&? = avffmpeg_contexts[avffmpeg_slot(handle)].cast[AVFormatContextPublicPrefix&?]
    if ctx == null:
        return -1
    if ctx[0].nb_streams > AVPLAYER_FFMPEG_MAX_STREAMS:
        return AVPLAYER_FFMPEG_MAX_STREAMS.i32()
    return ctx[0].nb_streams.i32()

def avplayer_ffmpeg_enable_stream(handle: i32, stream_index: u32) -> i32:
    if not avffmpeg_valid_handle(handle):
        return -1
    count: i32 = avplayer_ffmpeg_stream_count(handle)
    if count < 0 or stream_index >= count.u32():
        return -1
    return 0

def avplayer_ffmpeg_disable_stream(handle: i32, stream_index: u32) -> i32:
    if not avffmpeg_valid_handle(handle):
        return -1
    count: i32 = avplayer_ffmpeg_stream_count(handle)
    if count < 0 or stream_index >= count.u32():
        return -1
    return 0

def avplayer_ffmpeg_start(handle: i32) -> i32:
    if not avffmpeg_valid_handle(handle):
        return -1
    slot: int = avffmpeg_slot(handle)
    avffmpeg_started[slot] <- true
    avffmpeg_paused[slot] <- false
    avffmpeg_next_ts_audio[slot] <- 0
    avffmpeg_next_ts_video[slot] <- 0
    i: mutable int = 0
    while i < AVPLAYER_FFMPEG_MAX_STREAMS.int():
        stream_slot: int = slot * AVPLAYER_FFMPEG_MAX_STREAMS.int() + i
        avffmpeg_last_stream_ts[stream_slot] <- 0
        avffmpeg_stream_eof_drained[stream_slot] <- false
        i <- i + 1
    return 0

def avplayer_ffmpeg_stop(handle: i32) -> i32:
    if not avffmpeg_valid_handle(handle):
        return -1
    slot: int = avffmpeg_slot(handle)
    avffmpeg_started[slot] <- false
    avffmpeg_paused[slot] <- false
    return 0

def avplayer_ffmpeg_pause(handle: i32) -> i32:
    if not avffmpeg_valid_handle(handle):
        return -1
    avffmpeg_paused[avffmpeg_slot(handle)] <- true
    return 0

def avplayer_ffmpeg_resume(handle: i32) -> i32:
    if not avffmpeg_valid_handle(handle):
        return -1
    avffmpeg_paused[avffmpeg_slot(handle)] <- false
    return 0

def avplayer_ffmpeg_packet_timestamp(handle: i32, pkt: AVPacketPublicPrefix&, out_ts: mutable u64&) -> bool:
    if not avffmpeg_valid_handle(handle):
        return false
    slot: int = avffmpeg_slot(handle)
    ctx: AVFormatContextPublicPrefix&? = avffmpeg_contexts[slot].cast[AVFormatContextPublicPrefix&?]
    if ctx == null or ctx[0].streams == null:
        return false
    if pkt.stream_index < 0 or pkt.stream_index >= ctx[0].nb_streams.i32():
        return false
    stream_ptrs: void&?&? = ctx[0].streams.cast[void&?&?]
    if stream_ptrs == null:
        return false
    raw_stream: void&? = stream_ptrs[pkt.stream_index]
    if raw_stream == null:
        return false
    stream: AVStreamPublicPrefix& = raw_stream.cast[AVStreamPublicPrefix&]
    ts: mutable i64 = pkt.pts
    if ts < 0:
        ts <- pkt.dts
    if ts < 0:
        ts <- 0
    if stream.time_base.num > 0 and stream.time_base.den > 0:
        out_ts <- ((ts.u64() * 1000) * stream.time_base.num.u64()) / stream.time_base.den.u64()
    else:
        out_ts <- ts.u64() * 1000
    return true

def avplayer_ffmpeg_get_audio_ts(handle: i32, out_ts: mutable u64&) -> i32:
    if not avffmpeg_valid_handle(handle):
        return -1
    slot: int = avffmpeg_slot(handle)
    if not avffmpeg_started[slot] or avffmpeg_paused[slot]:
        return -1
    pkt: mutable void&? = av_packet_alloc()
    if pkt == null:
        return -1
    rc: i32 = av_read_frame(avffmpeg_contexts[slot], pkt)
    if rc < 0:
        avffmpeg_free_packet(pkt)
        return -1
    p: AVPacketPublicPrefix& = pkt.cast[AVPacketPublicPrefix&]
    if avplayer_ffmpeg_packet_timestamp(handle, p, out_ts):
        avffmpeg_next_ts_audio[slot] <- out_ts
    else:
        avffmpeg_next_ts_audio[slot] <- avffmpeg_next_ts_audio[slot] + 33
        out_ts <- avffmpeg_next_ts_audio[slot]
    avffmpeg_free_packet(pkt)
    return 0

def avplayer_ffmpeg_get_video_ts(handle: i32, out_ts: mutable u64&) -> i32:
    if not avffmpeg_valid_handle(handle):
        return -1
    slot: int = avffmpeg_slot(handle)
    if not avffmpeg_started[slot] or avffmpeg_paused[slot]:
        return -1
    pkt: mutable void&? = av_packet_alloc()
    if pkt == null:
        return -1
    rc: i32 = av_read_frame(avffmpeg_contexts[slot], pkt)
    if rc < 0:
        avffmpeg_free_packet(pkt)
        return -1
    p: AVPacketPublicPrefix& = pkt.cast[AVPacketPublicPrefix&]
    if avplayer_ffmpeg_packet_timestamp(handle, p, out_ts):
        avffmpeg_next_ts_video[slot] <- out_ts
    else:
        avffmpeg_next_ts_video[slot] <- avffmpeg_next_ts_video[slot] + 33
        out_ts <- avffmpeg_next_ts_video[slot]
    avffmpeg_free_packet(pkt)
    return 0

def avplayer_ffmpeg_read_stream_packet_ts(handle: i32, stream_index: u32, out_ts: mutable u64&) -> i32:
    if not avffmpeg_valid_handle(handle):
        return -1
    slot: int = avffmpeg_slot(handle)
    if not avffmpeg_started[slot] or avffmpeg_paused[slot]:
        return -1
    ctx: AVFormatContextPublicPrefix&? = avffmpeg_contexts[slot].cast[AVFormatContextPublicPrefix&?]
    if ctx == null or ctx[0].streams == null or stream_index >= ctx[0].nb_streams:
        return -1
    pkt: mutable void&? = av_packet_alloc()
    if pkt == null:
        return -1
    tries: mutable int = 0
    while tries < 512:
        tries <- tries + 1
        rc: i32 = av_read_frame(avffmpeg_contexts[slot], pkt)
        if rc < 0:
            avffmpeg_free_packet(pkt)
            return -2
        p: AVPacketPublicPrefix& = pkt.cast[AVPacketPublicPrefix&]
        if p.stream_index == stream_index.i32():
            if avplayer_ffmpeg_packet_timestamp(handle, p, out_ts):
                av_packet_unref(pkt)
                avffmpeg_free_packet(pkt)
                return 0
            av_packet_unref(pkt)
            avffmpeg_free_packet(pkt)
            return -1
        av_packet_unref(pkt)
    avffmpeg_free_packet(pkt)
    return -1

def avplayer_ffmpeg_get_stream_info(handle: i32, stream_index: u32, out_type: mutable u32&, out_duration: mutable u64&, out_start_time: mutable u64&, out_video_width: mutable u32&, out_video_height: mutable u32&, out_audio_channels: mutable u32&, out_audio_sample_rate: mutable u32&) -> i32:
    if not avffmpeg_valid_handle(handle):
        return -1
    out_type <- 3
    out_duration <- 0
    out_start_time <- 0
    out_video_width <- 0
    out_video_height <- 0
    out_audio_channels <- 0
    out_audio_sample_rate <- 0

    ctx: AVFormatContextPublicPrefix&? = avffmpeg_contexts[avffmpeg_slot(handle)].cast[AVFormatContextPublicPrefix&?]
    if ctx == null or ctx[0].streams == null or stream_index >= ctx[0].nb_streams:
        return -1

    stream_ptrs: void&?&? = ctx[0].streams.cast[void&?&?]
    if stream_ptrs == null:
        return -1
    raw_stream: void&? = stream_ptrs[stream_index.int()]
    if raw_stream == null:
        return -1
    stream: AVStreamPublicPrefix& = raw_stream.cast[AVStreamPublicPrefix&]
    if stream.codecpar == null:
        return -1
    codecpar: AVCodecParametersPublicPrefix = stream.codecpar[0]
    out_start_time <- stream.start_time.u64()
    out_duration <- stream.duration.u64()

    if codecpar.codec_type == AVMEDIA_TYPE_VIDEO:
        out_type <- 0
        if codecpar.width > 0:
            out_video_width <- codecpar.width.u32()
        if codecpar.height > 0:
            out_video_height <- codecpar.height.u32()
    elif codecpar.codec_type == AVMEDIA_TYPE_AUDIO:
        out_type <- 1
        if codecpar.ch_layout.nb_channels > 0:
            out_audio_channels <- codecpar.ch_layout.nb_channels.u32()
        if codecpar.sample_rate > 0:
            out_audio_sample_rate <- codecpar.sample_rate.u32()
    elif codecpar.codec_type == AVMEDIA_TYPE_SUBTITLE:
        out_type <- 2

    return 0

def avplayer_ffmpeg_get_stream_codecpar_shape(handle: i32, stream_index: u32, out_codec_type: mutable i32&, out_width: mutable i32&, out_height: mutable i32&, out_channels: mutable i32&, out_sample_rate: mutable i32&) -> i32:
    out_codec_type <- -1
    out_width <- 0
    out_height <- 0
    out_channels <- 0
    out_sample_rate <- 0
    if not avffmpeg_valid_handle(handle):
        return -1
    ctx: AVFormatContextPublicPrefix&? = avffmpeg_contexts[avffmpeg_slot(handle)].cast[AVFormatContextPublicPrefix&?]
    if ctx == null or ctx[0].streams == null or stream_index >= ctx[0].nb_streams:
        return -1
    stream_ptrs: void&?&? = ctx[0].streams.cast[void&?&?]
    if stream_ptrs == null:
        return -1
    raw_stream: void&? = stream_ptrs[stream_index.int()]
    if raw_stream == null:
        return -1
    stream: AVStreamPublicPrefix& = raw_stream.cast[AVStreamPublicPrefix&]
    if stream.codecpar == null:
        return -1
    codecpar: AVCodecParametersPublicPrefix = stream.codecpar[0]
    out_codec_type <- codecpar.codec_type
    out_width <- codecpar.width
    out_height <- codecpar.height
    out_channels <- codecpar.ch_layout.nb_channels
    out_sample_rate <- codecpar.sample_rate
    return 0

def avplayer_ffmpeg_get_stream_language(handle: i32, stream_index: u32) -> i8&?:
    if not avffmpeg_valid_handle(handle):
        return null
    ctx: AVFormatContextPublicPrefix&? = avffmpeg_contexts[avffmpeg_slot(handle)].cast[AVFormatContextPublicPrefix&?]
    if ctx == null or ctx[0].streams == null or stream_index >= ctx[0].nb_streams:
        return null
    stream_ptrs: void&?&? = ctx[0].streams.cast[void&?&?]
    if stream_ptrs == null:
        return null
    raw_stream: void&? = stream_ptrs[stream_index.int()]
    if raw_stream == null:
        return null
    stream: AVStreamPublicPrefix& = raw_stream.cast[AVStreamPublicPrefix&]
    if stream.metadata == null:
        return null
    language_key: i8&? = "language".cast[i8&?]
    entry_bits: void&? = av_dict_get(stream.metadata, language_key, null, 0)
    if entry_bits == null:
        return null
    entry: AVDictionaryEntryPublicPrefix&? = entry_bits.cast[AVDictionaryEntryPublicPrefix&?]
    if entry == null:
        return null
    return entry[0].value

def avplayer_ffmpeg_get_stream_color_range(handle: i32, stream_index: u32) -> i32:
    if not avffmpeg_valid_handle(handle):
        return -1
    ctx: AVFormatContextPublicPrefix&? = avffmpeg_contexts[avffmpeg_slot(handle)].cast[AVFormatContextPublicPrefix&?]
    if ctx == null or ctx[0].streams == null or stream_index >= ctx[0].nb_streams:
        return -1
    stream_ptrs: void&?&? = ctx[0].streams.cast[void&?&?]
    if stream_ptrs == null:
        return -1
    raw_stream: void&? = stream_ptrs[stream_index.int()]
    if raw_stream == null:
        return -1
    stream: AVStreamPublicPrefix& = raw_stream.cast[AVStreamPublicPrefix&]
    if stream.codecpar == null:
        return -1
    params: AVCodecParametersPublicPrefix = stream.codecpar[0]
    return params.color_range

def avplayer_ffmpeg_find_decoder_for_stream(handle: i32, stream_index: u32) -> void&?:
    if not avffmpeg_valid_handle(handle):
        return null
    ctx: AVFormatContextPublicPrefix&? = avffmpeg_contexts[avffmpeg_slot(handle)].cast[AVFormatContextPublicPrefix&?]
    if ctx == null or ctx[0].streams == null or stream_index >= ctx[0].nb_streams:
        return null
    stream_ptrs: void&?&? = ctx[0].streams.cast[void&?&?]
    if stream_ptrs == null:
        return null
    raw_stream: void&? = stream_ptrs[stream_index.int()]
    if raw_stream == null:
        return null
    stream: AVStreamPublicPrefix& = raw_stream.cast[AVStreamPublicPrefix&]
    if stream.codecpar == null:
        return null
    params: AVCodecParametersPublicPrefix = stream.codecpar[0]
    return avcodec_find_decoder(params.codec_id)

def avplayer_ffmpeg_copy_stream_params_to_codec_ctx(handle: i32, stream_index: u32, codec_ctx: void&?) -> i32:
    if not avffmpeg_valid_handle(handle) or codec_ctx == null:
        return -1
    ctx: AVFormatContextPublicPrefix&? = avffmpeg_contexts[avffmpeg_slot(handle)].cast[AVFormatContextPublicPrefix&?]
    if ctx == null or ctx[0].streams == null or stream_index >= ctx[0].nb_streams:
        return -1
    stream_ptrs: void&?&? = ctx[0].streams.cast[void&?&?]
    if stream_ptrs == null:
        return -1
    raw_stream: void&? = stream_ptrs[stream_index.int()]
    if raw_stream == null:
        return -1
    stream: AVStreamPublicPrefix& = raw_stream.cast[AVStreamPublicPrefix&]
    if stream.codecpar == null:
        return -1
    return avcodec_parameters_to_context(codec_ctx, stream.codecpar.cast[void&?])

def avplayer_ffmpeg_decode_next_ts(handle: i32, stream_index: u32, codec_ctx: void&?, out_ts: mutable u64&) -> i32:
    out_dummy_audio_samples: mutable u32 = 0
    out_dummy_audio_sample_rate: mutable u32 = 0
    out_dummy_audio_channels: mutable u32 = 0
    out_dummy_video_width: mutable u32 = 0
    out_dummy_video_height: mutable u32 = 0
    out_dummy_video_pitch: mutable u32 = 0
    out_dummy_video_aspect_num: mutable u32 = 0
    out_dummy_video_aspect_den: mutable u32 = 0
    return avplayer_ffmpeg_decode_next_ts_ex(handle, stream_index, codec_ctx, out_ts, out_dummy_audio_samples, out_dummy_audio_sample_rate, out_dummy_audio_channels, out_dummy_video_width, out_dummy_video_height, out_dummy_video_pitch, out_dummy_video_aspect_num, out_dummy_video_aspect_den)

def avplayer_ffmpeg_decode_next_ts_ex(handle: i32, stream_index: u32, codec_ctx: void&?, out_ts: mutable u64&, out_audio_samples: mutable u32&, out_audio_sample_rate: mutable u32&, out_audio_channels: mutable u32&, out_video_width: mutable u32&, out_video_height: mutable u32&, out_video_pitch: mutable u32&, out_video_aspect_num: mutable u32&, out_video_aspect_den: mutable u32&) -> i32:
    return avplayer_ffmpeg_decode_next_ts_copy(handle, stream_index, codec_ctx, out_ts, out_audio_samples, out_audio_sample_rate, out_audio_channels, out_video_width, out_video_height, out_video_pitch, out_video_aspect_num, out_video_aspect_den, null, 0, false)

def avffmpeg_align16(value: u32) -> u32:
    if value == 0:
        return 0
    return (((value + 15u32) / 16u32) * 16u32)

def avffmpeg_copy_decoded_payload(decoded: AVFramePublicPrefix&, payload: mutable u8&?, payload_size: u32, is_video: bool):
    if payload == null or payload_size == 0:
        return
    if is_video:
        if decoded.width <= 0 or decoded.height <= 0 or decoded.data[0] == null:
            return
        src_width: u32 = decoded.width.u32()
        src_height: u32 = decoded.height.u32()
        dst_width: mutable u32 = src_width
        dst_height: mutable u32 = src_height
        aligned_width: u32 = avffmpeg_align16(src_width)
        aligned_height: u32 = avffmpeg_align16(src_height)
        aligned_size: u32 = (aligned_width * aligned_height * 3u32) / 2u32
        if (aligned_width != src_width or aligned_height != src_height) and payload_size >= aligned_size:
            dst_width <- aligned_width
            dst_height <- aligned_height
        target_size: mutable u32 = (dst_width * dst_height * 3u32) / 2u32
        if target_size > payload_size:
            target_size <- payload_size
        z: mutable u32 = 0u32
        while z < target_size:
            payload[z.usize()] <- 0u8
            z <- z + 1u32
        y_stride: mutable u32 = src_width
        if decoded.linesize[0] > 0:
            y_stride <- decoded.linesize[0].u32()
        y: mutable u32 = 0u32
        while y < src_height:
            dst_row_off: u32 = y * dst_width
            if dst_row_off >= payload_size:
                return
            remaining_luma: u32 = payload_size - dst_row_off
            row_copy: mutable u32 = src_width
            if row_copy > remaining_luma:
                row_copy <- remaining_luma
            src_row: mutable u8&? = decoded.data[0] + (y * y_stride).usize()
            dst_row: mutable u8& = payload + dst_row_off.usize()
            if src_row == null:
                return
            i: mutable u32 = 0u32
            while i < row_copy:
                dst_row[i.usize()] <- src_row[i.usize()]
                i <- i + 1u32
            y <- y + 1u32
        if decoded.data[1] != null:
            uv_plane_off: u32 = dst_width * dst_height
            uv_rows: u32 = src_height / 2u32
            uv_stride: mutable u32 = src_width
            if decoded.linesize[1] > 0:
                uv_stride <- decoded.linesize[1].u32()
            uv_y: mutable u32 = 0u32
            while uv_y < uv_rows:
                dst_uv_off: u32 = uv_plane_off + (uv_y * dst_width)
                if dst_uv_off >= payload_size:
                    return
                remaining_chroma: u32 = payload_size - dst_uv_off
                row_chroma_copy: mutable u32 = src_width
                if row_chroma_copy > remaining_chroma:
                    row_chroma_copy <- remaining_chroma
                src_uv_row: mutable u8&? = decoded.data[1] + (uv_y * uv_stride).usize()
                dst_uv_row: mutable u8& = payload + dst_uv_off.usize()
                if src_uv_row == null:
                    return
                i: mutable u32 = 0u32
                while i < row_chroma_copy:
                    dst_uv_row[i.usize()] <- src_uv_row[i.usize()]
                    i <- i + 1u32
                uv_y <- uv_y + 1u32
        return
    if decoded.data[0] == null:
        return
    audio_size: mutable u32 = payload_size
    if decoded.linesize[0] > 0 and decoded.linesize[0].u32() < audio_size:
        audio_size <- decoded.linesize[0].u32()
    audio_src: mutable u8&? = decoded.data[0]
    if audio_src == null:
        return
    audio_src_ref: u8& = audio_src.cast[u8&]
    _ = memcpy(payload.cast[mutable void&], audio_src_ref.cast[void&], audio_size.usize())

def avffmpeg_convert_video_to_nv12(frame: mutable void&?) -> mutable void&?:
    if frame == null:
        return null
    src: AVFramePublicPrefix& = frame.cast[AVFramePublicPrefix&]
    if src.format == AV_PIX_FMT_NV12:
        return frame
    if src.width <= 0 or src.height <= 0:
        return frame
    dst_frame: mutable void&? = av_frame_alloc()
    if dst_frame == null:
        return frame
    dst: mutable AVFramePublicPrefix& = dst_frame.cast[mutable AVFramePublicPrefix&]
    dst.format <- AV_PIX_FMT_NV12
    dst.width <- src.width
    dst.height <- src.height
    dst.sample_aspect_ratio <- src.sample_aspect_ratio
    if av_frame_get_buffer(dst_frame, 0) < 0:
        avffmpeg_free_frame(dst_frame)
        return frame
    sws_ctx: void&? = sws_getContext(src.width, src.height, src.format, dst.width, dst.height, AV_PIX_FMT_NV12, 2, null, null, null)
    if sws_ctx == null:
        avffmpeg_free_frame(dst_frame)
        return frame
    src_data_ptr: void&? = src.data.ref[void&?]
    dst_data_ptr: void&? = dst.data.ref[void&?]
    _ = sws_scale(sws_ctx, src_data_ptr.ref[void&], src.linesize[0], 0, src.height, dst_data_ptr.ref[void&], dst.linesize[0])
    sws_freeContext(sws_ctx)
    return dst_frame

def avffmpeg_convert_audio_to_s16(frame: mutable void&?) -> mutable void&?:
    if frame == null:
        return null
    src: AVFramePublicPrefix& = frame.cast[AVFramePublicPrefix&]
    if src.format == AV_SAMPLE_FMT_S16:
        return frame
    if src.nb_samples <= 0 or src.sample_rate <= 0:
        return frame
    dst_frame: mutable void&? = av_frame_alloc()
    if dst_frame == null:
        return frame
    dst: mutable AVFramePublicPrefix& = dst_frame.cast[mutable AVFramePublicPrefix&]
    dst.format <- AV_SAMPLE_FMT_S16
    dst.nb_samples <- src.nb_samples
    dst.sample_rate <- src.sample_rate
    if src.ch_layout.nb_channels > 0:
        if av_channel_layout_copy(dst.ch_layout.ref[mutable void&], src.ch_layout.ref[void&]) < 0:
            avffmpeg_free_frame(dst_frame)
            return frame
    else:
        av_channel_layout_default(dst.ch_layout.ref[mutable void&], 2)
    if av_frame_get_buffer(dst_frame, 0) < 0:
        avffmpeg_free_frame(dst_frame)
        return frame
    swr_ctx_box: mutable void&?[1] = zeroed
    swr_alloc_rc: mutable i32 = 0
    if src.ch_layout.nb_channels > 0:
        swr_alloc_rc <- swr_alloc_set_opts2(swr_ctx_box[0], dst.ch_layout.ref[void&], AV_SAMPLE_FMT_S16, src.sample_rate, src.ch_layout.ref[void&], src.format, src.sample_rate, 0, null)
    else:
        swr_alloc_rc <- swr_alloc_set_opts2(swr_ctx_box[0], dst.ch_layout.ref[void&], AV_SAMPLE_FMT_S16, src.sample_rate, dst.ch_layout.ref[void&], src.format, src.sample_rate, 0, null)
    if swr_alloc_rc < 0:
        avffmpeg_free_frame(dst_frame)
        return frame
    swr_ctx: void&? = swr_ctx_box[0]
    if swr_ctx == null:
        avffmpeg_free_frame(dst_frame)
        return frame
    if swr_init(swr_ctx) < 0:
        avffmpeg_free_swr(swr_ctx)
        avffmpeg_free_frame(dst_frame)
        return frame
    if swr_convert_frame(swr_ctx, dst_frame, frame) < 0:
        avffmpeg_free_swr(swr_ctx)
        avffmpeg_free_frame(dst_frame)
        return frame
    avffmpeg_free_swr(swr_ctx)
    return dst_frame

def avffmpeg_frame_channels(frame: AVFramePublicPrefix&) -> u32:
    if frame.ch_layout.nb_channels > 0:
        return frame.ch_layout.nb_channels.u32()
    return 0u32

def avffmpeg_copy_frame_metadata_and_payload(frame: mutable void&?, payload: mutable u8&?, payload_size: u32, payload_is_video: bool, out_audio_samples: mutable u32&, out_audio_sample_rate: mutable u32&, out_audio_channels: mutable u32&, out_video_width: mutable u32&, out_video_height: mutable u32&, out_video_pitch: mutable u32&, out_video_aspect_num: mutable u32&, out_video_aspect_den: mutable u32&):
    if frame == null:
        return
    converted: mutable void&? = frame
    if payload_is_video:
        converted <- avffmpeg_convert_video_to_nv12(frame)
    else:
        converted <- avffmpeg_convert_audio_to_s16(frame)
    if converted == null:
        converted <- frame
    decoded_ptr: AVFramePublicPrefix&? = converted.cast[AVFramePublicPrefix&?]
    if decoded_ptr == null:
        return
    if decoded_ptr[0].nb_samples > 0:
        out_audio_samples <- decoded_ptr[0].nb_samples.u32()
    if decoded_ptr[0].sample_rate > 0:
        out_audio_sample_rate <- decoded_ptr[0].sample_rate.u32()
    out_audio_channels <- avffmpeg_frame_channels(decoded_ptr[0])
    if decoded_ptr[0].width > 0:
        out_video_width <- decoded_ptr[0].width.u32()
    if decoded_ptr[0].height > 0:
        out_video_height <- decoded_ptr[0].height.u32()
    if decoded_ptr[0].linesize[0] > 0:
        out_video_pitch <- decoded_ptr[0].linesize[0].u32()
    if decoded_ptr[0].sample_aspect_ratio.num > 0 and decoded_ptr[0].sample_aspect_ratio.den > 0:
        out_video_aspect_num <- decoded_ptr[0].sample_aspect_ratio.num.u32()
        out_video_aspect_den <- decoded_ptr[0].sample_aspect_ratio.den.u32()
    avffmpeg_copy_decoded_payload(decoded_ptr[0], payload, payload_size, payload_is_video)
    if converted != frame:
        avffmpeg_free_frame(converted)

def avplayer_ffmpeg_decode_next_ts_copy(handle: i32, stream_index: u32, codec_ctx: void&?, out_ts: mutable u64&, out_audio_samples: mutable u32&, out_audio_sample_rate: mutable u32&, out_audio_channels: mutable u32&, out_video_width: mutable u32&, out_video_height: mutable u32&, out_video_pitch: mutable u32&, out_video_aspect_num: mutable u32&, out_video_aspect_den: mutable u32&, payload: mutable u8&?, payload_size: u32, payload_is_video: bool) -> i32:
    if not avffmpeg_valid_handle(handle) or codec_ctx == null:
        return -1
    out_audio_samples <- 0
    out_audio_sample_rate <- 0
    out_audio_channels <- 0
    out_video_width <- 0
    out_video_height <- 0
    out_video_pitch <- 0
    out_video_aspect_num <- 0
    out_video_aspect_den <- 0
    ctx: AVFormatContextPublicPrefix&? = avffmpeg_contexts[avffmpeg_slot(handle)].cast[AVFormatContextPublicPrefix&?]
    if ctx == null or ctx[0].streams == null or stream_index >= ctx[0].nb_streams:
        return -1
    stream_ptrs: void&?&? = ctx[0].streams.cast[void&?&?]
    if stream_ptrs == null:
        return -1
    raw_stream: void&? = stream_ptrs[stream_index.int()]
    if raw_stream == null:
        return -1
    stream: AVStreamPublicPrefix& = raw_stream.cast[AVStreamPublicPrefix&]
    stream_slot: int = avffmpeg_stream_slot(handle, stream_index)

    pkt: mutable void&? = av_packet_alloc()
    if pkt == null:
        return -1
    frame: mutable void&? = av_frame_alloc()
    if frame == null:
        avffmpeg_free_packet(pkt)
        return -1

    tries: mutable int = 0
    while tries < 4096:
        tries <- tries + 1
        rc: i32 = av_read_frame(avffmpeg_contexts[avffmpeg_slot(handle)], pkt)
        if rc < 0:
            if avffmpeg_stream_eof_drained[stream_slot]:
                avffmpeg_free_frame(frame)
                avffmpeg_free_packet(pkt)
                return -2
            send_flush_rc: i32 = avcodec_send_packet(codec_ctx, null)
            if send_flush_rc < 0 and send_flush_rc != AVERROR_EAGAIN_LINUX and send_flush_rc != AVERROR_EAGAIN_DARWIN:
                avffmpeg_free_frame(frame)
                avffmpeg_free_packet(pkt)
                return -1
            drain_rc: i32 = avcodec_receive_frame(codec_ctx, frame)
            if drain_rc == 0:
                avffmpeg_copy_frame_metadata_and_payload(frame, payload, payload_size, payload_is_video, out_audio_samples, out_audio_sample_rate, out_audio_channels, out_video_width, out_video_height, out_video_pitch, out_video_aspect_num, out_video_aspect_den)
                next_ts: u64 = avffmpeg_last_stream_ts[stream_slot] + 33
                avffmpeg_last_stream_ts[stream_slot] <- next_ts
                out_ts <- next_ts
                av_frame_unref(frame)
                avffmpeg_free_frame(frame)
                avffmpeg_free_packet(pkt)
                return 0
            avffmpeg_stream_eof_drained[stream_slot] <- true
            avffmpeg_free_frame(frame)
            avffmpeg_free_packet(pkt)
            return -2
        p: AVPacketPublicPrefix& = pkt.cast[AVPacketPublicPrefix&]
        if p.stream_index != stream_index.i32():
            av_packet_unref(pkt)
        else:
            send_rc: i32 = avcodec_send_packet(codec_ctx, pkt)
            local_dts: i64 = p.dts
            av_packet_unref(pkt)
            if send_rc < 0 and send_rc != AVERROR_EAGAIN_LINUX and send_rc != AVERROR_EAGAIN_DARWIN:
                avffmpeg_free_frame(frame)
                avffmpeg_free_packet(pkt)
                return -1
            recv_rc: i32 = avcodec_receive_frame(codec_ctx, frame)
            if recv_rc == 0:
                avffmpeg_copy_frame_metadata_and_payload(frame, payload, payload_size, payload_is_video, out_audio_samples, out_audio_sample_rate, out_audio_channels, out_video_width, out_video_height, out_video_pitch, out_video_aspect_num, out_video_aspect_den)
                pkt_dts_u64: mutable u64 = 0
                if local_dts > 0:
                    pkt_dts_u64 <- local_dts.u64()
                num: i32 = stream.time_base.num
                den: i32 = stream.time_base.den
                if num != 0 and den > 1:
                    out_ts <- ((pkt_dts_u64 * 1000) * num.u64()) / den.u64()
                else:
                    out_ts <- pkt_dts_u64 * 1000
                avffmpeg_last_stream_ts[stream_slot] <- out_ts
                av_frame_unref(frame)
                avffmpeg_free_frame(frame)
                avffmpeg_free_packet(pkt)
                return 0
            if recv_rc < 0 and recv_rc != AVERROR_EAGAIN_LINUX and recv_rc != AVERROR_EAGAIN_DARWIN:
                avffmpeg_free_frame(frame)
                avffmpeg_free_packet(pkt)
                return -1

    avffmpeg_free_frame(frame)
    avffmpeg_free_packet(pkt)
    return -1
