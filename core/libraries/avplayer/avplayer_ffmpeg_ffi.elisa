# Native FFmpeg ABI bindings plus a small Elisa-owned handle table.
# This replaces the hand-written avplayer_ffmpeg_bridge.cpp wrapper layer.
# Run with:
#   CPPFLAGS="$(pkg-config --cflags libavformat libavcodec libavutil)" \
#   go run ./src -emit c-bind-check ../elisa-shad-ps4-from-scratch/core/libraries/avplayer/avplayer_ffmpeg_ffi.elisa

const AVPLAYER_FFMPEG_MAX_HANDLES: int = 64
const AVPLAYER_FFMPEG_MAX_STREAMS: u32 = 8
const AVMEDIA_TYPE_VIDEO: i32 = 0
const AVMEDIA_TYPE_AUDIO: i32 = 1
const AVMEDIA_TYPE_SUBTITLE: i32 = 3

@c_bind_prefix("libavformat/avformat.h", "AVFormatContext")
struct AVFormatContextPublicPrefix layout c:
    av_class: void&?
    iformat: void&?
    oformat: void&?
    priv_data: void&?
    pb: void&?
    ctx_flags: i32
    nb_streams: u32
    streams: void&?

@c_bind_prefix("libavutil/rational.h", "AVRational")
struct AVRationalPublic layout c:
    num: i32
    den: i32

@c_bind_prefix("libavutil/channel_layout.h", "AVChannelLayout")
struct AVChannelLayoutPublicPrefix layout c:
    order: i32
    nb_channels: i32
    u: u64
    opaque: void&?

@c_bind_prefix("libavcodec/codec_par.h", "AVCodecParameters")
struct AVCodecParametersPublicPrefix layout c:
    codec_type: i32
    codec_id: i32
    codec_tag: u32
    extradata: mutable u8&?
    extradata_size: i32
    coded_side_data: void&?
    nb_coded_side_data: i32
    format: i32
    bit_rate: i64
    bits_per_coded_sample: i32
    bits_per_raw_sample: i32
    profile: i32
    level: i32
    width: i32
    height: i32
    sample_aspect_ratio: AVRationalPublic
    framerate: AVRationalPublic
    field_order: i32
    color_range: i32
    color_primaries: i32
    color_trc: i32
    color_space: i32
    chroma_location: i32
    video_delay: i32
    ch_layout: AVChannelLayoutPublicPrefix
    sample_rate: i32

@c_bind_prefix("libavformat/avformat.h", "AVStream")
struct AVStreamPublicPrefix layout c:
    av_class: void&?
    index: i32
    id: i32
    codecpar: AVCodecParametersPublicPrefix&?
    priv_data: void&?
    time_base: AVRationalPublic
    start_time: i64
    duration: i64
    nb_frames: i64
    disposition: i32
    discard: i32
    sample_aspect_ratio: AVRationalPublic
    metadata: void&?
    avg_frame_rate: AVRationalPublic
    attached_pic: u8[104]
    event_flags: i32
    r_frame_rate: AVRationalPublic
    pts_wrap_bits: i32

@c_bind_prefix("libavutil/dict.h", "AVDictionaryEntry")
struct AVDictionaryEntryPublicPrefix layout c:
    key: i8&?
    value: i8&?

@c_bind_prefix("libavcodec/packet.h", "AVPacket")
struct AVPacketPublicPrefix layout c:
    buf: void&?
    pts: i64
    dts: i64
    data: mutable u8&?
    size: i32
    stream_index: i32

@c_bind_prefix("libavutil/frame.h", "AVFrame")
struct AVFramePublicPrefix layout c:
    av_class: void&?
    data0: mutable u8&?
    data1: mutable u8&?
    data2: mutable u8&?
    data3: mutable u8&?
    data4: mutable u8&?
    data5: mutable u8&?
    data6: mutable u8&?
    data7: mutable u8&?
    linesize: i32[8]
    extended_data: mutable u8&?
    width: i32
    height: i32
    nb_samples: i32
    format: i32
    key_frame: i32
    pict_type: i32
    sample_aspect_ratio: AVRationalPublic
    pts: i64
    pkt_dts: i64
    time_base: AVRationalPublic
    quality: i32
    opaque: void&?
    repeat_pict: i32
    interlaced_frame: i32
    top_field_first: i32
    palette_has_changed: i32
    reordered_opaque: i64
    sample_rate: i32
    ch_layout: AVChannelLayoutPublicPrefix

@c_abi(c)
extern avformat_open_input(ps: mutable void&?&, url: i8&?, fmt: void&?, options: void&?) -> i32

@c_abi(c)
extern avformat_find_stream_info(ctx: void&?, options: void&?) -> i32

@c_abi(c)
extern avformat_close_input(ps: mutable void&?&) -> void

@c_abi(c)
extern av_read_frame(ctx: void&?, pkt: void&?) -> i32

@c_abi(c)
extern av_seek_frame(ctx: void&?, stream_index: i32, timestamp: i64, flags: i32) -> i32

@c_abi(c)
extern avformat_seek_file(ctx: void&?, stream_index: i32, min_ts: i64, ts: i64, max_ts: i64, flags: i32) -> i32

@c_abi(c)
extern av_packet_alloc() -> mutable void&?

@c_abi(c)
extern av_packet_free(pkt: mutable void&?&) -> void

@c_abi(c)
extern av_packet_unref(pkt: mutable void&?) -> void

@c_abi(c)
extern avcodec_find_decoder(id: i32) -> void&?

@c_abi(c)
extern avcodec_alloc_context3(codec: void&?) -> void&?

@c_abi(c)
extern avcodec_parameters_to_context(codec_ctx: void&?, codecpar: void&?) -> i32

@c_abi(c)
extern avcodec_open2(codec_ctx: void&?, codec: void&?, options: mutable void&?&) -> i32

@c_abi(c)
extern avcodec_flush_buffers(codec_ctx: void&?) -> void

@c_abi(c)
extern avcodec_send_packet(codec_ctx: void&?, pkt: void&?) -> i32

@c_abi(c)
extern avcodec_receive_frame(codec_ctx: void&?, frame: mutable void&?) -> i32

@c_abi(c)
extern avcodec_free_context(codec_ctx: mutable void&?&) -> void

@c_abi(c)
extern av_frame_alloc() -> mutable void&?

@c_abi(c)
extern av_frame_free(frame: mutable void&?&) -> void

@c_abi(c)
extern av_frame_unref(frame: mutable void&?) -> void

@c_abi(c)
extern av_dict_get(m: void&?, key: i8&?, prev: void&?, flags: i32) -> void&?

global mutable avffmpeg_contexts: void&?[AVPLAYER_FFMPEG_MAX_HANDLES] = zeroed
global mutable avffmpeg_started: bool[AVPLAYER_FFMPEG_MAX_HANDLES] = zeroed
global mutable avffmpeg_paused: bool[AVPLAYER_FFMPEG_MAX_HANDLES] = zeroed
global mutable avffmpeg_next_ts_audio: u64[AVPLAYER_FFMPEG_MAX_HANDLES] = zeroed
global mutable avffmpeg_next_ts_video: u64[AVPLAYER_FFMPEG_MAX_HANDLES] = zeroed
global mutable avffmpeg_last_stream_ts: u64[AVPLAYER_FFMPEG_MAX_HANDLES * AVPLAYER_FFMPEG_MAX_STREAMS.int()] = zeroed
global mutable avffmpeg_stream_eof_drained: bool[AVPLAYER_FFMPEG_MAX_HANDLES * AVPLAYER_FFMPEG_MAX_STREAMS.int()] = zeroed

def avffmpeg_slot(handle: i32) -> int:
    return (handle - 1).int()

def avffmpeg_stream_slot(handle: i32, stream_index: u32) -> int:
    return avffmpeg_slot(handle) * AVPLAYER_FFMPEG_MAX_STREAMS.int() + stream_index.int()

def avffmpeg_valid_handle(handle: i32) -> bool:
    if handle <= 0 or handle > AVPLAYER_FFMPEG_MAX_HANDLES.i32():
        return false
    return avffmpeg_contexts[avffmpeg_slot(handle)] != null

def avplayer_ffmpeg_context(handle: i32) -> void&?:
    if not avffmpeg_valid_handle(handle):
        return null
    return avffmpeg_contexts[avffmpeg_slot(handle)]

def avplayer_ffmpeg_open(path: i8&?) -> i32:
    if path == null:
        return -1

    ctx: void&? = null
    if avformat_open_input(ctx.ref[mutable void&?&], path, null, null) < 0:
        return -1
    if avformat_find_stream_info(ctx, null) < 0:
        avformat_close_input(ctx.ref[mutable void&?&])
        return -1

    i: mutable int = 0
    while i < AVPLAYER_FFMPEG_MAX_HANDLES:
        if avffmpeg_contexts[i] == null:
            avffmpeg_contexts[i] <- ctx
            avffmpeg_started[i] <- false
            avffmpeg_paused[i] <- false
            avffmpeg_next_ts_audio[i] <- 0
            avffmpeg_next_ts_video[i] <- 0
            return (i + 1).i32()
        i <- i + 1

    avformat_close_input(ctx.ref[mutable void&?&])
    return -1

def avplayer_ffmpeg_close(handle: i32) -> void:
    if not avffmpeg_valid_handle(handle):
        return
    slot: int = avffmpeg_slot(handle)
    ctx: void&? = avffmpeg_contexts[slot]
    avformat_close_input(ctx.ref[mutable void&?&])
    avffmpeg_contexts[slot] <- null
    avffmpeg_started[slot] <- false
    avffmpeg_paused[slot] <- false

def avplayer_ffmpeg_stream_count(handle: i32) -> i32:
    if not avffmpeg_valid_handle(handle):
        return -1
    ctx: AVFormatContextPublicPrefix&? = avffmpeg_contexts[avffmpeg_slot(handle)].cast[AVFormatContextPublicPrefix&?]
    if ctx == null:
        return -1
    if ctx[0].nb_streams > AVPLAYER_FFMPEG_MAX_STREAMS:
        return AVPLAYER_FFMPEG_MAX_STREAMS.i32()
    return ctx[0].nb_streams.i32()

def avplayer_ffmpeg_enable_stream(handle: i32, stream_index: u32) -> i32:
    if not avffmpeg_valid_handle(handle):
        return -1
    count: i32 = avplayer_ffmpeg_stream_count(handle)
    if count < 0 or stream_index >= count.u32():
        return -1
    return 0

def avplayer_ffmpeg_disable_stream(handle: i32, stream_index: u32) -> i32:
    if not avffmpeg_valid_handle(handle):
        return -1
    count: i32 = avplayer_ffmpeg_stream_count(handle)
    if count < 0 or stream_index >= count.u32():
        return -1
    return 0

def avplayer_ffmpeg_start(handle: i32) -> i32:
    if not avffmpeg_valid_handle(handle):
        return -1
    slot: int = avffmpeg_slot(handle)
    avffmpeg_started[slot] <- true
    avffmpeg_paused[slot] <- false
    avffmpeg_next_ts_audio[slot] <- 0
    avffmpeg_next_ts_video[slot] <- 0
    i: mutable int = 0
    while i < AVPLAYER_FFMPEG_MAX_STREAMS.int():
        stream_slot: int = slot * AVPLAYER_FFMPEG_MAX_STREAMS.int() + i
        avffmpeg_last_stream_ts[stream_slot] <- 0
        avffmpeg_stream_eof_drained[stream_slot] <- false
        i <- i + 1
    return 0

def avplayer_ffmpeg_stop(handle: i32) -> i32:
    if not avffmpeg_valid_handle(handle):
        return -1
    slot: int = avffmpeg_slot(handle)
    avffmpeg_started[slot] <- false
    avffmpeg_paused[slot] <- false
    return 0

def avplayer_ffmpeg_pause(handle: i32) -> i32:
    if not avffmpeg_valid_handle(handle):
        return -1
    avffmpeg_paused[avffmpeg_slot(handle)] <- true
    return 0

def avplayer_ffmpeg_resume(handle: i32) -> i32:
    if not avffmpeg_valid_handle(handle):
        return -1
    avffmpeg_paused[avffmpeg_slot(handle)] <- false
    return 0

def avplayer_ffmpeg_packet_timestamp(handle: i32, pkt: AVPacketPublicPrefix&, out_ts: mutable u64&) -> bool:
    if not avffmpeg_valid_handle(handle):
        return false
    slot: int = avffmpeg_slot(handle)
    ctx: AVFormatContextPublicPrefix&? = avffmpeg_contexts[slot].cast[AVFormatContextPublicPrefix&?]
    if ctx == null or ctx[0].streams == null:
        return false
    if pkt.stream_index < 0 or pkt.stream_index >= ctx[0].nb_streams.i32():
        return false
    stream_ptrs: void&?&? = ctx[0].streams.cast[void&?&?]
    if stream_ptrs == null:
        return false
    raw_stream: void&? = stream_ptrs[pkt.stream_index]
    if raw_stream == null:
        return false
    stream: AVStreamPublicPrefix& = raw_stream.ref[AVStreamPublicPrefix&]
    ts: mutable i64 = pkt.pts
    if ts < 0:
        ts <- pkt.dts
    if ts < 0:
        ts <- 0
    if stream.time_base.num > 0 and stream.time_base.den > 0:
        out_ts <- ((ts.u64() * 1000) * stream.time_base.num.u64()) / stream.time_base.den.u64()
    else:
        out_ts <- ts.u64() * 1000
    return true

def avplayer_ffmpeg_get_audio_ts(handle: i32, out_ts: mutable u64&) -> i32:
    if not avffmpeg_valid_handle(handle):
        return -1
    slot: int = avffmpeg_slot(handle)
    if not avffmpeg_started[slot] or avffmpeg_paused[slot]:
        return -1
    pkt: mutable void&? = av_packet_alloc()
    if pkt == null:
        return -1
    rc: i32 = av_read_frame(avffmpeg_contexts[slot], pkt)
    if rc < 0:
        av_packet_free(pkt.ref[mutable void&?&])
        return -1
    p: AVPacketPublicPrefix& = pkt.ref[AVPacketPublicPrefix&]
    if avplayer_ffmpeg_packet_timestamp(handle, p, out_ts):
        avffmpeg_next_ts_audio[slot] <- out_ts
    else:
        avffmpeg_next_ts_audio[slot] <- avffmpeg_next_ts_audio[slot] + 33
        out_ts <- avffmpeg_next_ts_audio[slot]
    av_packet_free(pkt.ref[mutable void&?&])
    return 0

def avplayer_ffmpeg_get_video_ts(handle: i32, out_ts: mutable u64&) -> i32:
    if not avffmpeg_valid_handle(handle):
        return -1
    slot: int = avffmpeg_slot(handle)
    if not avffmpeg_started[slot] or avffmpeg_paused[slot]:
        return -1
    pkt: mutable void&? = av_packet_alloc()
    if pkt == null:
        return -1
    rc: i32 = av_read_frame(avffmpeg_contexts[slot], pkt)
    if rc < 0:
        av_packet_free(pkt.ref[mutable void&?&])
        return -1
    p: AVPacketPublicPrefix& = pkt.ref[AVPacketPublicPrefix&]
    if avplayer_ffmpeg_packet_timestamp(handle, p, out_ts):
        avffmpeg_next_ts_video[slot] <- out_ts
    else:
        avffmpeg_next_ts_video[slot] <- avffmpeg_next_ts_video[slot] + 33
        out_ts <- avffmpeg_next_ts_video[slot]
    av_packet_free(pkt.ref[mutable void&?&])
    return 0

def avplayer_ffmpeg_read_stream_packet_ts(handle: i32, stream_index: u32, out_ts: mutable u64&) -> i32:
    if not avffmpeg_valid_handle(handle):
        return -1
    slot: int = avffmpeg_slot(handle)
    if not avffmpeg_started[slot] or avffmpeg_paused[slot]:
        return -1
    ctx: AVFormatContextPublicPrefix&? = avffmpeg_contexts[slot].cast[AVFormatContextPublicPrefix&?]
    if ctx == null or ctx[0].streams == null or stream_index >= ctx[0].nb_streams:
        return -1
    pkt: mutable void&? = av_packet_alloc()
    if pkt == null:
        return -1
    tries: mutable int = 0
    while tries < 512:
        tries <- tries + 1
        rc: i32 = av_read_frame(avffmpeg_contexts[slot], pkt)
        if rc < 0:
            av_packet_free(pkt.ref[mutable void&?&])
            return -2
        p: AVPacketPublicPrefix& = pkt.ref[AVPacketPublicPrefix&]
        if p.stream_index == stream_index.i32():
            if avplayer_ffmpeg_packet_timestamp(handle, p, out_ts):
                av_packet_unref(pkt)
                av_packet_free(pkt.ref[mutable void&?&])
                return 0
            av_packet_unref(pkt)
            av_packet_free(pkt.ref[mutable void&?&])
            return -1
        av_packet_unref(pkt)
    av_packet_free(pkt.ref[mutable void&?&])
    return -1

def avplayer_ffmpeg_get_stream_info(handle: i32, stream_index: u32, out_type: mutable u32&, out_duration: mutable u64&, out_start_time: mutable u64&, out_video_width: mutable u32&, out_video_height: mutable u32&, out_audio_channels: mutable u32&, out_audio_sample_rate: mutable u32&) -> i32:
    if not avffmpeg_valid_handle(handle):
        return -1
    out_type <- 3
    out_duration <- 0
    out_start_time <- 0
    out_video_width <- 0
    out_video_height <- 0
    out_audio_channels <- 0
    out_audio_sample_rate <- 0

    ctx: AVFormatContextPublicPrefix&? = avffmpeg_contexts[avffmpeg_slot(handle)].cast[AVFormatContextPublicPrefix&?]
    if ctx == null or ctx[0].streams == null or stream_index >= ctx[0].nb_streams:
        return -1

    stream_ptrs: void&?&? = ctx[0].streams.cast[void&?&?]
    if stream_ptrs == null:
        return -1
    raw_stream: void&? = stream_ptrs[stream_index.int()]
    if raw_stream == null:
        return -1
    stream: AVStreamPublicPrefix& = raw_stream.ref[AVStreamPublicPrefix&]
    if stream.codecpar == null:
        return -1
    codecpar: AVCodecParametersPublicPrefix& = stream.codecpar.ref[AVCodecParametersPublicPrefix&]
    out_start_time <- stream.start_time.u64()
    out_duration <- stream.duration.u64()

    if codecpar.codec_type == AVMEDIA_TYPE_VIDEO:
        out_type <- 0
        if codecpar.width > 0:
            out_video_width <- codecpar.width.u32()
        if codecpar.height > 0:
            out_video_height <- codecpar.height.u32()
    elif codecpar.codec_type == AVMEDIA_TYPE_AUDIO:
        out_type <- 1
        if codecpar.ch_layout.nb_channels > 0:
            out_audio_channels <- codecpar.ch_layout.nb_channels.u32()
        if codecpar.sample_rate > 0:
            out_audio_sample_rate <- codecpar.sample_rate.u32()
    elif codecpar.codec_type == AVMEDIA_TYPE_SUBTITLE:
        out_type <- 2

    return 0

def avplayer_ffmpeg_get_stream_language(handle: i32, stream_index: u32) -> i8&?:
    if not avffmpeg_valid_handle(handle):
        return null
    ctx: AVFormatContextPublicPrefix&? = avffmpeg_contexts[avffmpeg_slot(handle)].cast[AVFormatContextPublicPrefix&?]
    if ctx == null or ctx[0].streams == null or stream_index >= ctx[0].nb_streams:
        return null
    stream_ptrs: void&?&? = ctx[0].streams.cast[void&?&?]
    if stream_ptrs == null:
        return null
    raw_stream: void&? = stream_ptrs[stream_index.int()]
    if raw_stream == null:
        return null
    stream: AVStreamPublicPrefix& = raw_stream.ref[AVStreamPublicPrefix&]
    if stream.metadata == null:
        return null
    language_key: i8&? = "language".cast[i8&?]
    entry_bits: void&? = av_dict_get(stream.metadata, language_key, null, 0)
    if entry_bits == null:
        return null
    entry: AVDictionaryEntryPublicPrefix&? = entry_bits.cast[AVDictionaryEntryPublicPrefix&?]
    if entry == null:
        return null
    return entry[0].value

def avplayer_ffmpeg_find_decoder_for_stream(handle: i32, stream_index: u32) -> void&?:
    if not avffmpeg_valid_handle(handle):
        return null
    ctx: AVFormatContextPublicPrefix&? = avffmpeg_contexts[avffmpeg_slot(handle)].cast[AVFormatContextPublicPrefix&?]
    if ctx == null or ctx[0].streams == null or stream_index >= ctx[0].nb_streams:
        return null
    stream_ptrs: void&?&? = ctx[0].streams.cast[void&?&?]
    if stream_ptrs == null:
        return null
    raw_stream: void&? = stream_ptrs[stream_index.int()]
    if raw_stream == null:
        return null
    stream: AVStreamPublicPrefix& = raw_stream.ref[AVStreamPublicPrefix&]
    if stream.codecpar == null:
        return null
    params: AVCodecParametersPublicPrefix& = stream.codecpar.ref[AVCodecParametersPublicPrefix&]
    return avcodec_find_decoder(params.codec_id)

def avplayer_ffmpeg_copy_stream_params_to_codec_ctx(handle: i32, stream_index: u32, codec_ctx: void&?) -> i32:
    if not avffmpeg_valid_handle(handle) or codec_ctx == null:
        return -1
    ctx: AVFormatContextPublicPrefix&? = avffmpeg_contexts[avffmpeg_slot(handle)].cast[AVFormatContextPublicPrefix&?]
    if ctx == null or ctx[0].streams == null or stream_index >= ctx[0].nb_streams:
        return -1
    stream_ptrs: void&?&? = ctx[0].streams.cast[void&?&?]
    if stream_ptrs == null:
        return -1
    raw_stream: void&? = stream_ptrs[stream_index.int()]
    if raw_stream == null:
        return -1
    stream: AVStreamPublicPrefix& = raw_stream.ref[AVStreamPublicPrefix&]
    if stream.codecpar == null:
        return -1
    return avcodec_parameters_to_context(codec_ctx, stream.codecpar.cast[void&?])

def avplayer_ffmpeg_decode_next_ts(handle: i32, stream_index: u32, codec_ctx: void&?, out_ts: mutable u64&) -> i32:
    out_dummy_audio_samples: mutable u32 = 0
    out_dummy_audio_sample_rate: mutable u32 = 0
    out_dummy_audio_channels: mutable u32 = 0
    out_dummy_video_width: mutable u32 = 0
    out_dummy_video_height: mutable u32 = 0
    out_dummy_video_pitch: mutable u32 = 0
    out_dummy_video_aspect_num: mutable u32 = 0
    out_dummy_video_aspect_den: mutable u32 = 0
    return avplayer_ffmpeg_decode_next_ts_ex(handle, stream_index, codec_ctx, out_ts, out_dummy_audio_samples, out_dummy_audio_sample_rate, out_dummy_audio_channels, out_dummy_video_width, out_dummy_video_height, out_dummy_video_pitch, out_dummy_video_aspect_num, out_dummy_video_aspect_den)

def avplayer_ffmpeg_decode_next_ts_ex(handle: i32, stream_index: u32, codec_ctx: void&?, out_ts: mutable u64&, out_audio_samples: mutable u32&, out_audio_sample_rate: mutable u32&, out_audio_channels: mutable u32&, out_video_width: mutable u32&, out_video_height: mutable u32&, out_video_pitch: mutable u32&, out_video_aspect_num: mutable u32&, out_video_aspect_den: mutable u32&) -> i32:
    if not avffmpeg_valid_handle(handle) or codec_ctx == null:
        return -1
    out_audio_samples <- 0
    out_audio_sample_rate <- 0
    out_audio_channels <- 0
    out_video_width <- 0
    out_video_height <- 0
    out_video_pitch <- 0
    out_video_aspect_num <- 0
    out_video_aspect_den <- 0
    ctx: AVFormatContextPublicPrefix&? = avffmpeg_contexts[avffmpeg_slot(handle)].cast[AVFormatContextPublicPrefix&?]
    if ctx == null or ctx[0].streams == null or stream_index >= ctx[0].nb_streams:
        return -1
    stream_ptrs: void&?&? = ctx[0].streams.cast[void&?&?]
    if stream_ptrs == null:
        return -1
    raw_stream: void&? = stream_ptrs[stream_index.int()]
    if raw_stream == null:
        return -1
    stream: AVStreamPublicPrefix& = raw_stream.ref[AVStreamPublicPrefix&]
    stream_slot: int = avffmpeg_stream_slot(handle, stream_index)

    pkt: mutable void&? = av_packet_alloc()
    if pkt == null:
        return -1
    frame: mutable void&? = av_frame_alloc()
    if frame == null:
        av_packet_free(pkt.ref[mutable void&?&])
        return -1

    tries: mutable int = 0
    while tries < 128:
        tries <- tries + 1
        rc: i32 = av_read_frame(avffmpeg_contexts[avffmpeg_slot(handle)], pkt)
        if rc < 0:
            if avffmpeg_stream_eof_drained[stream_slot]:
                av_frame_free(frame.ref[mutable void&?&])
                av_packet_free(pkt.ref[mutable void&?&])
                return -2
            send_flush_rc: i32 = avcodec_send_packet(codec_ctx, null)
            if send_flush_rc < 0 and send_flush_rc != -11:
                av_frame_free(frame.ref[mutable void&?&])
                av_packet_free(pkt.ref[mutable void&?&])
                return -1
            drain_rc: i32 = avcodec_receive_frame(codec_ctx, frame)
            if drain_rc == 0:
                decoded: AVFramePublicPrefix& = frame.ref[AVFramePublicPrefix&]
                if decoded.nb_samples > 0:
                    out_audio_samples <- decoded.nb_samples.u32()
                if decoded.sample_rate > 0:
                    out_audio_sample_rate <- decoded.sample_rate.u32()
                if decoded.ch_layout.nb_channels > 0:
                    out_audio_channels <- decoded.ch_layout.nb_channels.u32()
                if decoded.width > 0:
                    out_video_width <- decoded.width.u32()
                if decoded.height > 0:
                    out_video_height <- decoded.height.u32()
                if decoded.linesize[0] > 0:
                    out_video_pitch <- decoded.linesize[0].u32()
                if decoded.sample_aspect_ratio.num > 0 and decoded.sample_aspect_ratio.den > 0:
                    out_video_aspect_num <- decoded.sample_aspect_ratio.num.u32()
                    out_video_aspect_den <- decoded.sample_aspect_ratio.den.u32()
                next_ts: u64 = avffmpeg_last_stream_ts[stream_slot] + 33
                avffmpeg_last_stream_ts[stream_slot] <- next_ts
                out_ts <- next_ts
                av_frame_unref(frame)
                av_frame_free(frame.ref[mutable void&?&])
                av_packet_free(pkt.ref[mutable void&?&])
                return 0
            avffmpeg_stream_eof_drained[stream_slot] <- true
            av_frame_free(frame.ref[mutable void&?&])
            av_packet_free(pkt.ref[mutable void&?&])
            return -2
        p: AVPacketPublicPrefix& = pkt.ref[AVPacketPublicPrefix&]
        if p.stream_index != stream_index.i32():
            av_packet_unref(pkt)
        else:
            send_rc: i32 = avcodec_send_packet(codec_ctx, pkt)
            local_dts: i64 = p.dts
            av_packet_unref(pkt)
            if send_rc < 0 and send_rc != -11:
                av_frame_free(frame.ref[mutable void&?&])
                av_packet_free(pkt.ref[mutable void&?&])
                return -1
            recv_rc: i32 = avcodec_receive_frame(codec_ctx, frame)
            if recv_rc == 0:
                decoded: AVFramePublicPrefix& = frame.ref[AVFramePublicPrefix&]
                if decoded.nb_samples > 0:
                    out_audio_samples <- decoded.nb_samples.u32()
                if decoded.sample_rate > 0:
                    out_audio_sample_rate <- decoded.sample_rate.u32()
                if decoded.ch_layout.nb_channels > 0:
                    out_audio_channels <- decoded.ch_layout.nb_channels.u32()
                if decoded.width > 0:
                    out_video_width <- decoded.width.u32()
                if decoded.height > 0:
                    out_video_height <- decoded.height.u32()
                if decoded.linesize[0] > 0:
                    out_video_pitch <- decoded.linesize[0].u32()
                if decoded.sample_aspect_ratio.num > 0 and decoded.sample_aspect_ratio.den > 0:
                    out_video_aspect_num <- decoded.sample_aspect_ratio.num.u32()
                    out_video_aspect_den <- decoded.sample_aspect_ratio.den.u32()
                pkt_dts_u64: mutable u64 = 0
                if local_dts > 0:
                    pkt_dts_u64 <- local_dts.u64()
                num: i32 = stream.time_base.num
                den: i32 = stream.time_base.den
                if num != 0 and den > 1:
                    out_ts <- ((pkt_dts_u64 * 1000) * num.u64()) / den.u64()
                else:
                    out_ts <- pkt_dts_u64 * 1000
                avffmpeg_last_stream_ts[stream_slot] <- out_ts
                av_frame_unref(frame)
                av_frame_free(frame.ref[mutable void&?&])
                av_packet_free(pkt.ref[mutable void&?&])
                return 0
            if recv_rc < 0 and recv_rc != -11:
                av_frame_free(frame.ref[mutable void&?&])
                av_packet_free(pkt.ref[mutable void&?&])
                return -1

    av_frame_free(frame.ref[mutable void&?&])
    av_packet_free(pkt.ref[mutable void&?&])
    return -1
