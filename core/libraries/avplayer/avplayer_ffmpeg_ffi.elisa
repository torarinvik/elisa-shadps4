# Native FFmpeg ABI bindings plus a small Elisa-owned handle table.
# This replaces the hand-written avplayer_ffmpeg_bridge.cpp wrapper layer.
# Run with:
#   CPPFLAGS="$(pkg-config --cflags libavformat libavcodec libavutil)" \
#   go run ./src -emit c-bind-check ../elisa-shad-ps4-from-scratch/core/libraries/avplayer/avplayer_ffmpeg_ffi.elisa

const AVPLAYER_FFMPEG_MAX_HANDLES: int = 64
const AVPLAYER_FFMPEG_MAX_STREAMS: u32 = 8
const AVMEDIA_TYPE_VIDEO: i32 = 0
const AVMEDIA_TYPE_AUDIO: i32 = 1
const AVMEDIA_TYPE_SUBTITLE: i32 = 3
const AV_PIX_FMT_NV12: i32 = 23
const AV_SAMPLE_FMT_S16: i32 = 1
const AV_SAMPLE_FMT_FLTP: i32 = 8
const AVERROR_EAGAIN_LINUX: i32 = -11
const AVERROR_EAGAIN_DARWIN: i32 = -35

@c_bind_prefix("libavformat/avformat.h", "AVFormatContext")
struct AVFormatContextPublicPrefix layout c:
    av_class: void&?
    iformat: void&?
    oformat: void&?
    priv_data: void&?
    pb: void&?
    ctx_flags: i32
    nb_streams: u32
    streams: void&?

@c_bind_prefix("libavutil/rational.h", "AVRational")
struct AVRationalPublic layout c:
    num: i32
    den: i32

@c_bind_prefix("libavutil/channel_layout.h", "AVChannelLayout")
struct AVChannelLayoutPublicPrefix layout c:
    order: i32
    nb_channels: i32
    u: u64
    opaque: void&?

@c_bind_prefix("libavcodec/codec_par.h", "AVCodecParameters")
struct AVCodecParametersPublicPrefix layout c:
    codec_type: i32
    codec_id: i32
    codec_tag: u32
    extradata: mutable u8&?
    extradata_size: i32
    coded_side_data: void&?
    nb_coded_side_data: i32
    format: i32
    bit_rate: i64
    bits_per_coded_sample: i32
    bits_per_raw_sample: i32
    profile: i32
    level: i32
    width: i32
    height: i32
    sample_aspect_ratio: AVRationalPublic
    framerate: AVRationalPublic
    field_order: i32
    color_range: i32
    color_primaries: i32
    color_trc: i32
    color_space: i32
    chroma_location: i32
    video_delay: i32
    ch_layout: AVChannelLayoutPublicPrefix
    sample_rate: i32

@c_bind_prefix("libavformat/avformat.h", "AVStream")
struct AVStreamPublicPrefix layout c:
    av_class: void&?
    index: i32
    id: i32
    codecpar: AVCodecParametersPublicPrefix&?
    priv_data: void&?
    time_base: AVRationalPublic
    start_time: i64
    duration: i64
    nb_frames: i64
    disposition: i32
    discard: i32
    sample_aspect_ratio: AVRationalPublic
    metadata: void&?
    avg_frame_rate: AVRationalPublic
    attached_pic: u8[104]
    event_flags: i32
    r_frame_rate: AVRationalPublic
    pts_wrap_bits: i32

@c_bind_prefix("libavutil/dict.h", "AVDictionaryEntry")
struct AVDictionaryEntryPublicPrefix layout c:
    key: i8&?
    value: i8&?

@c_bind_prefix("libavcodec/packet.h", "AVPacket")
struct AVPacketPublicPrefix layout c:
    buf: void&?
    pts: i64
    dts: i64
    data: mutable u8&?
    size: i32
    stream_index: i32

@c_bind_prefix("libavutil/frame.h", "AVFrame")
struct AVFramePublicPrefix layout c:
    data: mutable u8&?[8]
    linesize: mutable i32[8]
    extended_data: mutable u8&?
    width: mutable i32
    height: mutable i32
    nb_samples: mutable i32
    format: mutable i32
    pict_type: mutable i32
    sample_aspect_ratio: mutable AVRationalPublic
    pts: mutable i64
    pkt_dts: mutable i64
    time_base: mutable AVRationalPublic
    quality: mutable i32
    opaque: mutable void&?
    repeat_pict: mutable i32
    sample_rate: mutable i32
    buf: mutable void&?[8]
    extended_buf: mutable void&?
    nb_extended_buf: mutable i32
    side_data: mutable void&?
    nb_side_data: mutable i32
    flags: mutable i32
    color_range: mutable i32
    color_primaries: mutable i32
    color_trc: mutable i32
    colorspace: mutable i32
    chroma_location: mutable i32
    best_effort_timestamp: mutable i64
    metadata: mutable void&?
    decode_error_flags: mutable i32
    hw_frames_ctx: mutable void&?
    opaque_ref: mutable void&?
    crop_top: mutable usize
    crop_bottom: mutable usize
    crop_left: mutable usize
    crop_right: mutable usize
    private_ref: mutable void&?
    ch_layout: mutable AVChannelLayoutPublicPrefix

