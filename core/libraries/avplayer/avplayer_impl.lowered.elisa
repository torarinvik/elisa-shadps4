const AVPLAYER_SOURCE_TYPE_UNKNOWN: i32 = 0

const AVPLAYER_SOURCE_TYPE_FILE_MP4: i32 = 1

const AVPLAYER_SOURCE_TYPE_HLS: i32 = 8

def avimpl_status_from_bool(ok: bool, ok_code: i32, fail_code: i32) -> i32:
    if ok:
        return ok_code
    return fail_code

def avimpl_ascii_lower(ch: u8) -> u8:
    if ((ch >= 'A'.u8()) and (ch <= 'Z'.u8())):
        return (ch + 32u8)
    return ch

def avimpl_ext_eq(path: i8&?, start: usize, end_: usize, ext: static u8&) -> bool:
    ext_len: usize = runtime_strlen(ext)
    if (end_ <= start):
        return false
    if (((end_ - start)) != ext_len):
        return false
    i: mutable usize = 0
    while (i < ext_len):
        lhs: u8 = avimpl_ascii_lower(path[(start + i)].u8())
        rhs: u8 = avimpl_ascii_lower(ext[i].u8())
        if (lhs != rhs):
            return false
        i <- (i + 1)
    return true

def avimpl_get_source_type_from_path(path: i8&?) -> i32:
    if (path == null):
        return AVPLAYER_SOURCE_TYPE_UNKNOWN
    path_len: usize = runtime_strlen(path)
    if (path_len == 0):
        return AVPLAYER_SOURCE_TYPE_UNKNOWN
    has_uri_scheme: mutable bool = false
    i: mutable usize = 0
    while ((i + 2) < path_len):
        if (((path[i].u8() == ':'.u8()) and (path[(i + 1)].u8() == '/'.u8())) and (path[(i + 2)].u8() == '/'.u8())):
            has_uri_scheme <- true
            break
        i <- (i + 1)
    name_end: mutable usize = path_len
    if has_uri_scheme:
        i <- 0
        while (i < path_len):
            ch: u8 = path[i].u8()
            if ((ch == '?'.u8()) or (ch == '#'.u8())):
                name_end <- i
                break
            i <- (i + 1)
        if (name_end == 0):
            return AVPLAYER_SOURCE_TYPE_UNKNOWN
    dot_pos: mutable usize = name_end
    i <- 0
    while (i < name_end):
        if (path[i].u8() == '.'.u8()):
            dot_pos <- i
        i <- (i + 1)
    if (dot_pos == name_end):
        return AVPLAYER_SOURCE_TYPE_UNKNOWN
    ext_end: mutable usize = name_end
    i <- dot_pos
    while (i < name_end):
        if (path[i].u8() == '/'.u8()):
            ext_end <- i
            break
        i <- (i + 1)
    if (ext_end <= dot_pos):
        return AVPLAYER_SOURCE_TYPE_UNKNOWN
    if ((((avimpl_ext_eq(path, dot_pos, ext_end, ".mp4") or avimpl_ext_eq(path, dot_pos, ext_end, ".m4v")) or avimpl_ext_eq(path, dot_pos, ext_end, ".m3d")) or avimpl_ext_eq(path, dot_pos, ext_end, ".m4a")) or avimpl_ext_eq(path, dot_pos, ext_end, ".mov")):
        return AVPLAYER_SOURCE_TYPE_FILE_MP4
    if avimpl_ext_eq(path, dot_pos, ext_end, ".m3u8"):
        return AVPLAYER_SOURCE_TYPE_HLS
    return AVPLAYER_SOURCE_TYPE_UNKNOWN

def avimpl_resolve_source_type(path: i8&?, source_type: i32) -> i32:
    if (source_type != AVPLAYER_SOURCE_TYPE_UNKNOWN):
        return source_type
    return avimpl_get_source_type_from_path(path)

def avimpl_validate_source_type(path: i8&?, source_type: i32) -> i32:
    resolved: i32 = avimpl_resolve_source_type(path, source_type)
    if (resolved == AVPLAYER_SOURCE_TYPE_HLS):
        return ORBIS_AVPLAYER_ERROR_NOT_SUPPORTED
    return ORBIS_OK
