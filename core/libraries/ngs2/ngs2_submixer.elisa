@fixed_layout
struct OrbisNgs2SubmixerRackOption:
    rack_option: OrbisNgs2RackOption
    max_channels: u32
    max_envelope_points: u32
    max_filters: u32
    max_inputs: u32
    num_peak_meter_blocks: u32

@fixed_layout
struct OrbisNgs2SubmixerVoiceSetupParam:
    header: OrbisNgs2VoiceParamHeader
    num_io_channels: u32
    flags: u32

@fixed_layout
struct OrbisNgs2SubmixerVoiceEnvelopeParam:
    header: OrbisNgs2VoiceParamHeader
    num_forward_points: u32
    num_release_points: u32
    a_point: OrbisNgs2EnvelopePoint&?

@fixed_layout
struct OrbisNgs2SubmixerVoiceCompressorParam:
    header: OrbisNgs2VoiceParamHeader
    flags: u32
    threshold: f32
    ratio: f32
    knee: f32
    attack_time: f32
    release_time: f32
    level: f32
    reserved: u32

@fixed_layout
struct OrbisNgs2SubmixerVoiceDistortionParam:
    header: OrbisNgs2VoiceParamHeader
    flags: u32
    a: f32
    b: f32
    clip: f32
    gate: f32
    wet_level: f32
    dry_level: f32
    reserved: u32

@fixed_layout
struct OrbisNgs2SubmixerVoiceUserFxParam:
    header: OrbisNgs2VoiceParamHeader
    handler: OrbisNgs2UserFxProcessHandler
    user_data0: usize
    user_data1: usize
    user_data2: usize

@fixed_layout
struct OrbisNgs2SubmixerVoicePeakMeterParam:
    header: OrbisNgs2VoiceParamHeader
    enable_flag: u32
    reserved: u32

@fixed_layout
struct OrbisNgs2SubmixerVoiceFilterParam:
    header: OrbisNgs2VoiceParamHeader
    index: u32
    location: u32
    type: u32
    channel_mask: u32
    param: OrbisNgs2BiquadParam
    reserved3: u32

@fixed_layout
struct OrbisNgs2SubmixerVoiceNumFilters:
    header: OrbisNgs2VoiceParamHeader
    num_filters: u32
    reserved: u32

@fixed_layout
struct OrbisNgs2SubmixerVoiceState:
    voice_state: OrbisNgs2VoiceState
    envelope_height: f32
    peak_height: f32
    compressor_height: f32

@fixed_layout
struct OrbisNgs2SubmixerRackInfo:
    rack_info: OrbisNgs2RackInfo
    max_channels: u32
    max_envelope_points: u32
    max_filters: u32
    max_inputs: u32
