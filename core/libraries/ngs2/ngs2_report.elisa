type OrbisNgs2VaList = usize

# C callback pointer from the guest (opaque, may be null); never invoked HLE-side.
type OrbisNgs2ReportHandler = void&?

@fixed_layout
struct OrbisNgs2ReportDataHeader:
    size: usize
    handle: OrbisNgs2Handle
    type: u32
    result: s32

@fixed_layout
struct OrbisNgs2ReportMessageData:
    header: OrbisNgs2ReportDataHeader
    message: u8&?

@fixed_layout
struct OrbisNgs2ReportApiData:
    header: OrbisNgs2ReportDataHeader
    function_name: u8&?
    format: u8&?
    argument: OrbisNgs2VaList

@fixed_layout
struct OrbisNgs2ReportControlData:
    header: OrbisNgs2ReportDataHeader
    param: OrbisNgs2VoiceParamHeader&?

@fixed_layout
struct OrbisNgs2ReportOutputData:
    header: OrbisNgs2ReportDataHeader
    buffer_info: OrbisNgs2RenderBufferInfo&?
    buffer_index: u32
    sample_rate: u32
    num_grain_samples: u32
    reserved: u32

@fixed_layout
struct OrbisNgs2ReportCpuLoadData:
    header: OrbisNgs2ReportDataHeader
    total_ratio: f32
    flush_ratio: f32
    process_ratio: f32
    feedback_ratio: f32

@fixed_layout
struct OrbisNgs2ReportRenderStateData:
    header: OrbisNgs2ReportDataHeader
    state: u32
    reserved: u32

@fixed_layout
struct OrbisNgs2ReportVoiceWaveformData:
    header: OrbisNgs2ReportDataHeader
    location: u32
    waveform_type: u32
    num_channels: u32
    sample_rate: u32
    num_grain_samples: u32
    reserved: u32
    a_data: void&?&?
