include "../error_codes.elisa"
include "./ngs2_error.elisa"

alias OrbisNgs2Handle = u64
alias OrbisNgs2ParseReadHandler = func(user_data: usize, out_data: mutable void&?, request_size: usize, out_read_size: mutable usize&?) -> s32
alias OrbisNgs2ReportHandler = func(report_type: u32, user_data: usize, a_param: void&?) -> s32

struct OrbisNgs2SystemOption:
    grain_samples: u32
    sample_rate: u32
    user_data: usize

struct OrbisNgs2RackOption:
    flags: u32
    num_voices: u32
    user_data: usize

struct OrbisNgs2SystemInfo:
    grain_samples: u32
    sample_rate: u32

struct OrbisNgs2RackInfo:
    rack_id: u32
    num_voices: u32

struct OrbisNgs2VoiceState:
    state_flags: u32

struct OrbisNgs2WaveformFormat:
    codec: u32
    channels: u32
    sample_rate: u32

struct OrbisNgs2WaveformFrameInfo:
    frame_size: u32
    sample_count: u32

struct OrbisNgs2GeomListenerParam:
    reserved: u32

struct OrbisNgs2GeomSourceParam:
    reserved: u32

struct OrbisNgs2GeomListenerWork:
    reserved: u32

struct OrbisNgs2PanWork:
    reserved: u32

struct OrbisNgs2PanParam:
    reserved: u32

struct OrbisNgs2CustomModuleInfo:
    module_id: u32


global mutable g_next_system: OrbisNgs2Handle = 0x200000
global mutable g_next_rack: OrbisNgs2Handle = 0x300000
global mutable g_next_voice: OrbisNgs2Handle = 0x400000

def _is_system(h: OrbisNgs2Handle) -> bool:
    return h >= 0x200000 and h < 0x300000

def _is_rack(h: OrbisNgs2Handle) -> bool:
    return h >= 0x300000 and h < 0x400000

def _is_voice(h: OrbisNgs2Handle) -> bool:
    return h >= 0x400000

# Stub-style waveform helpers
def sceNgs2CalcWaveformBlock(format: OrbisNgs2WaveformFormat&?, sample_pos: u32, out_block: mutable u32&?) -> s32:
    _ = sample_pos
    if format == null or out_block == null:
        return ORBIS_NGS2_ERROR_INVALID_PARAM
    out_block^ <- 0
    return ORBIS_OK

def sceNgs2GetWaveformFrameInfo(format: OrbisNgs2WaveformFormat&?, frame_index: u32, out_info: mutable OrbisNgs2WaveformFrameInfo&?) -> s32:
    _ = frame_index
    if format == null or out_info == null:
        return ORBIS_NGS2_ERROR_INVALID_PARAM
    out_info^.frame_size <- 0
    out_info^.sample_count <- 0
    return ORBIS_OK

def sceNgs2ParseWaveformData(data: void&?, data_size: usize, out_format: mutable OrbisNgs2WaveformFormat&?) -> s32:
    if data == null or data_size == 0:
        return ORBIS_NGS2_ERROR_INVALID_WAVEFORM_DATA
    if out_format == null:
        return ORBIS_NGS2_ERROR_INVALID_OUT_ADDRESS
    return ORBIS_OK

def sceNgs2ParseWaveformFile(path: u8&?, offset: u64, out_format: mutable OrbisNgs2WaveformFormat&?) -> s32:
    _ = offset
    if path == null:
        return ORBIS_NGS2_ERROR_INVALID_WAVEFORM_ADDRESS
    if out_format == null:
        return ORBIS_NGS2_ERROR_INVALID_OUT_ADDRESS
    return ORBIS_OK

def sceNgs2ParseWaveformUser(handler: OrbisNgs2ParseReadHandler, user_data: usize, out_format: mutable OrbisNgs2WaveformFormat&?) -> s32:
    _ = handler
    _ = user_data
    if out_format == null:
        return ORBIS_NGS2_ERROR_INVALID_OUT_ADDRESS
    return ORBIS_OK

# Rack
def sceNgs2RackCreate(system_handle: OrbisNgs2Handle, rack_id: u32, option: OrbisNgs2RackOption&?, mem: void&?, mem_size: usize, out_rack: mutable OrbisNgs2Handle&?) -> s32:
    _ = rack_id
    _ = option
    _ = mem
    _ = mem_size
    if not _is_system(system_handle) or out_rack == null:
        return ORBIS_NGS2_ERROR_INVALID_HANDLE
    g_next_rack <- g_next_rack + 1
    out_rack^ <- g_next_rack
    return ORBIS_OK

def sceNgs2RackCreateWithAllocator(system_handle: OrbisNgs2Handle, rack_id: u32, option: OrbisNgs2RackOption&?, allocator: void&?, out_rack: mutable OrbisNgs2Handle&?) -> s32:
    _ = rack_id
    _ = option
    _ = allocator
    if not _is_system(system_handle) or out_rack == null:
        return ORBIS_NGS2_ERROR_INVALID_HANDLE
    g_next_rack <- g_next_rack + 1
    out_rack^ <- g_next_rack
    return ORBIS_OK

def sceNgs2RackDestroy(rack_handle: OrbisNgs2Handle, option: void&?) -> s32:
    _ = option
    if not _is_rack(rack_handle):
        return ORBIS_NGS2_ERROR_INVALID_HANDLE
    return ORBIS_OK

def sceNgs2RackGetInfo(rack_handle: OrbisNgs2Handle, out_info: mutable OrbisNgs2RackInfo&?, info_size: usize) -> s32:
    _ = info_size
    if not _is_rack(rack_handle) or out_info == null:
        return ORBIS_NGS2_ERROR_INVALID_HANDLE
    return ORBIS_OK

def sceNgs2RackGetUserData(rack_handle: OrbisNgs2Handle, out_user_data: mutable usize&?) -> s32:
    if not _is_rack(rack_handle) or out_user_data == null:
        return ORBIS_NGS2_ERROR_INVALID_HANDLE
    out_user_data^ <- 0
    return ORBIS_OK

def sceNgs2RackGetVoiceHandle(rack_handle: OrbisNgs2Handle, voice_index: u32, out_voice: mutable OrbisNgs2Handle&?) -> s32:
    _ = voice_index
    if not _is_rack(rack_handle) or out_voice == null:
        return ORBIS_NGS2_ERROR_INVALID_HANDLE
    g_next_voice <- g_next_voice + 1
    out_voice^ <- g_next_voice
    return ORBIS_OK

def sceNgs2RackLock(rack_handle: OrbisNgs2Handle) -> s32:
    return ORBIS_OK

def sceNgs2RackQueryBufferSize(rack_id: u32, option: OrbisNgs2RackOption&?, out_size: mutable usize&?) -> s32:
    _ = rack_id
    _ = option
    if out_size == null:
        return ORBIS_NGS2_ERROR_INVALID_PARAM
    out_size^ <- 0
    return ORBIS_OK

def sceNgs2RackSetUserData(rack_handle: OrbisNgs2Handle, user_data: usize) -> s32:
    _ = user_data
    if not _is_rack(rack_handle):
        return ORBIS_NGS2_ERROR_INVALID_HANDLE
    return ORBIS_OK

def sceNgs2RackUnlock(rack_handle: OrbisNgs2Handle) -> s32:
    _ = rack_handle
    return ORBIS_OK

# System
def sceNgs2SystemCreate(option: OrbisNgs2SystemOption&?, mem: void&?, mem_size: usize, out_system: mutable OrbisNgs2Handle&?) -> s32:
    _ = option
    _ = mem
    _ = mem_size
    if out_system == null:
        return ORBIS_NGS2_ERROR_INVALID_PARAM
    g_next_system <- g_next_system + 1
    out_system^ <- g_next_system
    return ORBIS_OK

def sceNgs2SystemCreateWithAllocator(option: OrbisNgs2SystemOption&?, allocator: void&?, out_system: mutable OrbisNgs2Handle&?) -> s32:
    _ = option
    _ = allocator
    if out_system == null:
        return ORBIS_NGS2_ERROR_INVALID_PARAM
    g_next_system <- g_next_system + 1
    out_system^ <- g_next_system
    return ORBIS_OK

def sceNgs2SystemDestroy(system_handle: OrbisNgs2Handle, option: void&?) -> s32:
    _ = option
    if not _is_system(system_handle):
        return ORBIS_NGS2_ERROR_INVALID_HANDLE
    return ORBIS_OK

def sceNgs2SystemEnumHandles(out_handle: mutable OrbisNgs2Handle&?, max_handles: u32) -> s32:
    _ = max_handles
    if out_handle == null:
        return ORBIS_NGS2_ERROR_INVALID_PARAM
    out_handle^ <- 0
    return ORBIS_OK

def sceNgs2SystemEnumRackHandles(system_handle: OrbisNgs2Handle, out_handles: mutable OrbisNgs2Handle&?, max_handles: u32) -> s32:
    _ = max_handles
    if not _is_system(system_handle) or out_handles == null:
        return ORBIS_NGS2_ERROR_INVALID_HANDLE
    out_handles^ <- 0
    return ORBIS_OK

def sceNgs2SystemGetInfo(system_handle: OrbisNgs2Handle, out_info: mutable OrbisNgs2SystemInfo&?, info_size: usize) -> s32:
    _ = info_size
    if not _is_system(system_handle) or out_info == null:
        return ORBIS_NGS2_ERROR_INVALID_HANDLE
    return ORBIS_OK

def sceNgs2SystemGetUserData(system_handle: OrbisNgs2Handle, out_user_data: mutable usize&?) -> s32:
    if not _is_system(system_handle) or out_user_data == null:
        return ORBIS_NGS2_ERROR_INVALID_HANDLE
    out_user_data^ <- 0
    return ORBIS_OK

def sceNgs2SystemLock(system_handle: OrbisNgs2Handle) -> s32:
    if not _is_system(system_handle):
        return ORBIS_NGS2_ERROR_INVALID_HANDLE
    return ORBIS_OK

def sceNgs2SystemQueryBufferSize(option: OrbisNgs2SystemOption&?, out_size: mutable usize&?) -> s32:
    _ = option
    if out_size == null:
        return ORBIS_NGS2_ERROR_INVALID_PARAM
    out_size^ <- 0
    return ORBIS_OK

def sceNgs2SystemRender(system_handle: OrbisNgs2Handle, out_data: void&?, in_data: void&?) -> s32:
    _ = out_data
    _ = in_data
    if not _is_system(system_handle):
        return ORBIS_NGS2_ERROR_INVALID_HANDLE
    return ORBIS_OK

def sceNgs2SystemResetOption(out_option: mutable OrbisNgs2SystemOption&?) -> s32:
    if out_option == null:
        return ORBIS_NGS2_ERROR_INVALID_PARAM
    out_option^.grain_samples <- 0
    out_option^.sample_rate <- 0
    out_option^.user_data <- 0
    return ORBIS_OK

def sceNgs2SystemSetGrainSamples(system_handle: OrbisNgs2Handle, num_samples: u32) -> s32:
    _ = num_samples
    if not _is_system(system_handle):
        return ORBIS_NGS2_ERROR_INVALID_HANDLE
    return ORBIS_OK

def sceNgs2SystemSetSampleRate(system_handle: OrbisNgs2Handle, sample_rate: u32) -> s32:
    _ = sample_rate
    if not _is_system(system_handle):
        return ORBIS_NGS2_ERROR_INVALID_HANDLE
    return ORBIS_OK

def sceNgs2SystemSetUserData(system_handle: OrbisNgs2Handle, user_data: usize) -> s32:
    _ = user_data
    if not _is_system(system_handle):
        return ORBIS_NGS2_ERROR_INVALID_HANDLE
    return ORBIS_OK

def sceNgs2SystemUnlock(system_handle: OrbisNgs2Handle) -> s32:
    if not _is_system(system_handle):
        return ORBIS_NGS2_ERROR_INVALID_HANDLE
    return ORBIS_OK

# Voice
def sceNgs2VoiceControl(voice_handle: OrbisNgs2Handle, command: u32, a_param: void&?) -> s32:
    _ = command
    _ = a_param
    if not _is_voice(voice_handle):
        return ORBIS_NGS2_ERROR_INVALID_HANDLE
    return ORBIS_OK

def sceNgs2VoiceGetMatrixInfo(voice_handle: OrbisNgs2Handle, matrix_id: u32, out_info: mutable void&?) -> s32:
    _ = matrix_id
    if not _is_voice(voice_handle) or out_info == null:
        return ORBIS_NGS2_ERROR_INVALID_HANDLE
    return ORBIS_OK

def sceNgs2VoiceGetOwner(voice_handle: OrbisNgs2Handle, out_rack: mutable OrbisNgs2Handle&?, out_index: mutable u32&?) -> s32:
    if not _is_voice(voice_handle) or out_rack == null or out_index == null:
        return ORBIS_NGS2_ERROR_INVALID_HANDLE
    out_rack^ <- 0
    out_index^ <- 0
    return ORBIS_OK

def sceNgs2VoiceGetPortInfo(voice_handle: OrbisNgs2Handle, port: u32, out_info: mutable void&?) -> s32:
    _ = port
    if not _is_voice(voice_handle) or out_info == null:
        return ORBIS_NGS2_ERROR_INVALID_HANDLE
    return ORBIS_OK

def sceNgs2VoiceGetState(voice_handle: OrbisNgs2Handle, out_state: mutable OrbisNgs2VoiceState&?, state_size: usize) -> s32:
    _ = state_size
    if not _is_voice(voice_handle) or out_state == null:
        return ORBIS_NGS2_ERROR_INVALID_HANDLE
    out_state^.state_flags <- 0
    return ORBIS_OK

def sceNgs2VoiceGetStateFlags(voice_handle: OrbisNgs2Handle, out_flags: mutable u32&?) -> s32:
    if not _is_voice(voice_handle) or out_flags == null:
        return ORBIS_NGS2_ERROR_INVALID_HANDLE
    out_flags^ <- 0
    return ORBIS_OK

# Module helpers
def sceNgs2CustomRackGetModuleInfo(rack_handle: OrbisNgs2Handle, module_index: u32, out_info: mutable OrbisNgs2CustomModuleInfo&?) -> s32:
    _ = module_index
    if not _is_rack(rack_handle) or out_info == null:
        return ORBIS_NGS2_ERROR_INVALID_HANDLE
    out_info^.module_id <- 0
    return ORBIS_OK

def sceNgs2GeomResetListenerParam(out_listener_param: mutable OrbisNgs2GeomListenerParam&?) -> s32:
    _ = out_listener_param
    return ORBIS_OK

def sceNgs2GeomResetSourceParam(out_source_param: mutable OrbisNgs2GeomSourceParam&?) -> s32:
    _ = out_source_param
    return ORBIS_OK

def sceNgs2GeomCalcListener(param: OrbisNgs2GeomListenerParam&?, out_work: mutable OrbisNgs2GeomListenerWork&?) -> s32:
    _ = param
    _ = out_work
    return ORBIS_OK

def sceNgs2GeomApply(listener: OrbisNgs2GeomListenerWork&?, source: OrbisNgs2GeomSourceParam&?, out_gain: mutable f32&?) -> s32:
    _ = listener
    _ = source
    _ = out_gain
    return ORBIS_OK

def sceNgs2PanInit(work: mutable OrbisNgs2PanWork&?, a_speaker_angle: f32&?, unit_angle: f32, num_channels: u32) -> s32:
    _ = a_speaker_angle
    _ = unit_angle
    _ = num_channels
    _ = work
    return ORBIS_OK

def sceNgs2PanGetVolumeMatrix(work: OrbisNgs2PanWork&?, a_param: OrbisNgs2PanParam&?, out_volume: mutable f32&?) -> s32:
    _ = work
    _ = a_param
    _ = out_volume
    return ORBIS_OK

def sceNgs2ReportRegisterHandler(report_type: u32, handler: OrbisNgs2ReportHandler, user_data: usize, out_report_handle: mutable OrbisNgs2Handle&?) -> s32:
    _ = report_type
    _ = handler
    _ = user_data
    if out_report_handle == null:
        return ORBIS_NGS2_ERROR_INVALID_PARAM
    out_report_handle^ <- 0x500000
    return ORBIS_OK

def sceNgs2ReportUnregisterHandler(report_handle: OrbisNgs2Handle) -> s32:
    _ = report_handle
    return ORBIS_OK

