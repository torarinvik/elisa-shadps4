    return ORBIS_OK

def sceNgs2PanInit(work: mutable OrbisNgs2PanWork&?, a_speaker_angle: f32&?, unit_angle: f32, num_channels: u32) -> s32:
    _ = a_speaker_angle
    _ = unit_angle
    _ = num_channels
    _ = work
    return ORBIS_OK

def sceNgs2PanGetVolumeMatrix(work: OrbisNgs2PanWork&?, a_param: OrbisNgs2PanParam&?, out_volume: mutable f32&?) -> s32:
