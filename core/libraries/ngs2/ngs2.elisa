    _ = matrix_format
    _ = out_volume
    return ORBIS_OK

def sceNgs2ReportRegisterHandler(report_type: u32, handler: OrbisNgs2ReportHandler, user_data: usize, out_report_handle: mutable OrbisNgs2Handle&?) -> s32:
    _ = report_type
    _ = user_data
    _ = out_report_handle
    if handler == null:
        return ORBIS_NGS2_ERROR_INVALID_REPORT_HANDLE
    return ORBIS_OK

def sceNgs2ReportUnregisterHandler(report_handle: OrbisNgs2Handle) -> s32:
    if report_handle == 0:
        return ORBIS_NGS2_ERROR_INVALID_REPORT_HANDLE
    return ORBIS_OK

