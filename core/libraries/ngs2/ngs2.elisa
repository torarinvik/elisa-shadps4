    _ = param
    _ = out_work
    return ORBIS_OK

def sceNgs2GeomApply(listener: OrbisNgs2GeomListenerWork&?, source: OrbisNgs2GeomSourceParam&?, out_gain: mutable f32&?) -> s32:
