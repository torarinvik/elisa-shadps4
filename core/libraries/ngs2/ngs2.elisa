include "./ngs2_error.elisa"

type OrbisNgs2Handle = u64
type OrbisNgs2ParseReadHandler = func(usize, u32, mutable void&?, usize) -> s32
type OrbisNgs2ReportHandler = func(u32, usize, void&?) -> s32
type OrbisNgs2BufferAllocHandler = func(mutable OrbisNgs2ContextBufferInfo&?) -> s32
type OrbisNgs2BufferFreeHandler = func(mutable OrbisNgs2ContextBufferInfo&?) -> s32

struct OrbisNgs2ContextBufferInfo:
    host_buffer: mutable void&?
    host_buffer_size: mutable usize
    reserved0: mutable usize
    reserved1: mutable usize
    reserved2: mutable usize
    reserved3: mutable usize
    reserved4: mutable usize
    user_data: mutable usize

struct OrbisNgs2SystemOption:
    size: mutable usize
    name: mutable u8[16]
    flags: mutable u32
    max_grain_samples: mutable u32
    num_grain_samples: mutable u32
    sample_rate: mutable u32
    a_reserved: mutable u32[6]

struct OrbisNgs2RackOption:
    size: mutable usize
    name: mutable u8[16]
    flags: mutable u32
    max_grain_samples: mutable u32
    max_voices: mutable u32
    max_input_delay_blocks: mutable u32
    max_matrices: mutable u32
    max_ports: mutable u32
    a_reserved: mutable u32[20]

struct OrbisNgs2SystemInfo:
    name: mutable u8[16]
    system_handle: mutable OrbisNgs2Handle
    buffer_info: mutable OrbisNgs2ContextBufferInfo
    uid: mutable u32
    min_grain_samples: mutable u32
    max_grain_samples: mutable u32
    state_flags: mutable u32
    rack_count: mutable u32
    last_render_ratio: mutable f32
    last_render_tick: mutable s64
    render_count: mutable s64
    sample_rate: mutable u32
    num_grain_samples: mutable u32

struct OrbisNgs2RackInfo:
    name: mutable u8[16]
    rack_handle: mutable OrbisNgs2Handle
    buffer_info: mutable OrbisNgs2ContextBufferInfo
    owner_system_handle: mutable OrbisNgs2Handle
    type: mutable u32
    rack_id: mutable u32
    uid: mutable u32
    min_grain_samples: mutable u32
    max_grain_samples: mutable u32
    max_voices: mutable u32
    max_channel_works: mutable u32
    max_inputs: mutable u32
    max_matrices: mutable u32
    max_ports: mutable u32
    state_flags: mutable u32
    last_process_ratio: mutable f32
    last_process_tick: mutable u64
    render_count: mutable u64
    active_voice_count: mutable u32
    active_channel_work_count: mutable u32

struct OrbisNgs2VoiceState:
    state_flags: mutable u32

struct OrbisNgs2WaveformFormat:
    waveform_type: mutable u32
    num_channels: mutable u32
    sample_rate: mutable u32
    config_data: mutable u32
    frame_offset: mutable u32
    frame_margin: mutable u32

struct OrbisNgs2WaveformBlock:
    data_offset: mutable u32
    data_size: mutable u32
    num_repeats: mutable u32
    num_skip_samples: mutable u32
    num_samples: mutable u32
    reserved: mutable u32
    user_data: mutable usize

struct OrbisNgs2WaveformInfo:
    format: mutable OrbisNgs2WaveformFormat
    data_offset: mutable u32
    data_size: mutable u32
    loop_begin_position: mutable u32
    loop_end_position: mutable u32
    num_samples: mutable u32
    audio_unit_size: mutable u32
    num_audio_unit_samples: mutable u32
    num_audio_unit_per_frame: mutable u32
    audio_frame_size: mutable u32
    num_audio_frame_samples: mutable u32
    num_delay_samples: mutable u32
    num_blocks: mutable u32
    a_block0: mutable OrbisNgs2WaveformBlock

struct OrbisNgs2VoiceParamHeader:
    size: u16
    next: s16
    id: u32

struct OrbisNgs2VoiceMatrixInfo:
    num_levels: mutable u32
    a_level: mutable f32[64]

struct OrbisNgs2VoicePortInfo:
    matrix_id: mutable s32
    volume: mutable f32
    num_delay_samples: mutable u32
    dest_input_id: mutable u32
    dest_handle: mutable OrbisNgs2Handle

struct OrbisNgs2RenderBufferInfo:
    buffer: void&?
    buffer_size: usize
    waveform_type: u32
    num_channels: u32

struct OrbisNgs2CustomModuleInfo:
    module_id: u32

struct OrbisNgs2BufferAllocator:
    alloc_handler: OrbisNgs2BufferAllocHandler
    free_handler: OrbisNgs2BufferFreeHandler
    user_data: usize

struct OrbisNgs2VoiceMatrixLevelsParam:
    header: OrbisNgs2VoiceParamHeader
    matrix_id: u32
    num_levels: u32
    a_level: f32&?

struct OrbisNgs2VoicePortVolumeParam:
    header: OrbisNgs2VoiceParamHeader
    port: u32
    level: f32

struct OrbisNgs2VoicePatchParam:
    header: OrbisNgs2VoiceParamHeader
    port: u32
    dest_input_id: u32
    dest_handle: OrbisNgs2Handle

struct OrbisNgs2VoiceEventParam:
    header: OrbisNgs2VoiceParamHeader
    event_id: u32

struct OrbisNgs2VoiceCallbackParam:
    header: OrbisNgs2VoiceParamHeader
    callback_handler: void&?
    callback_data: usize
    flags: u32
    reserved: u32

struct OrbisNgs2CustomSamplerVoiceSetupParam:
    header: OrbisNgs2VoiceParamHeader
    format: OrbisNgs2WaveformFormat
    flags: u32
    reserved: u32

struct OrbisNgs2CustomSamplerVoiceWaveformBlocksParam:
    header: OrbisNgs2VoiceParamHeader
    data: void&?
    flags: u32
    num_blocks: u32
    a_block: OrbisNgs2WaveformBlock&?

struct OrbisNgs2CustomSamplerVoiceWaveformAddressParam:
    header: OrbisNgs2VoiceParamHeader
    from_addr: void&?
    to_addr: void&?

struct OrbisNgs2CustomSamplerVoiceWaveformFrameOffsetParam:
    header: OrbisNgs2VoiceParamHeader
    frame_offset: u32
    reserved: u32

struct OrbisNgs2CustomSamplerVoicePitchParam:
    header: OrbisNgs2VoiceParamHeader
    ratio: f32
    reserved: u32

struct OrbisNgs2CustomSamplerVoiceState:
    voice_state: mutable OrbisNgs2VoiceState
    padding: mutable u8[32]
    waveform_data: mutable void&?
    num_decoded_samples: mutable u64
    decoded_data_size: mutable u64
    user_data: mutable u64
    reserved: mutable u32
    reserved2: mutable u32

struct OrbisNgs2GeomListenerParam:
    reserved: u32
struct OrbisNgs2GeomSourceParam:
    reserved: u32
struct OrbisNgs2GeomListenerWork:
    reserved: u32
struct OrbisNgs2PanWork:
    reserved: u32
struct OrbisNgs2PanParam:
    reserved: u32

const DEFAULT_MAX_VOICES: u32 = 64
const SYSTEM_OPTION_SIZE: usize = 64
const MIN_SYSTEM_BUFFER_SIZE: usize = 8
const NGS2_MAX_SYSTEMS: int = 8
const NGS2_MAX_RACKS: int = 32
const NGS2_MAX_VOICES_TRACKED: u32 = 4096u32
const MAX_TRACKED_PORTS: u32 = 16u32
const MAX_TRACKED_MATRICES: u32 = 16u32
const MAX_MATRIX_LEVELS: u32 = 64u32
const NGS2_MAX_VOICE_STATE_SLOTS: usize = 131072
const NGS2_MAX_PORT_SLOTS: usize = 2097152
const NGS2_MAX_MATRIX_SLOTS: usize = 2097152
const NGS2_MAX_MATRIX_LEVEL_SLOTS: usize = 134217728
const VOICE_STATE_ACTIVE: u32 = 1u32
const VOICE_PARAM_ID_MATRIX_LEVELS: u32 = 1u32
const VOICE_PARAM_ID_PORT_VOLUME: u32 = 2u32
const VOICE_PARAM_ID_EVENT: u32 = 3u32
const VOICE_PARAM_ID_CALLBACK: u32 = 5u32
const VOICE_PARAM_ID_PATCH: u32 = 6u32
const CUSTOM_VOICE_PARAM_ID_SETUP: u32 = 0x10000000u32
const CUSTOM_VOICE_PARAM_ID_WAVEFORM_BLOCKS: u32 = 0x10000001u32
const CUSTOM_VOICE_PARAM_ID_WAVEFORM_ADDRESS: u32 = 0x10000002u32
const CUSTOM_VOICE_PARAM_ID_WAVEFORM_FRAME_OFFSET: u32 = 0x10000003u32
const CUSTOM_VOICE_PARAM_ID_PITCH: u32 = 0x10000005u32

@fixed_layout
struct Ngs2SystemSlot:
    used: mutable bool
    handle: mutable OrbisNgs2Handle
    buffer_info: mutable OrbisNgs2ContextBufferInfo
    user_data: mutable usize
    sample_rate: mutable u32
    max_grain_samples: mutable u32
    num_grain_samples: mutable u32
    render_count: mutable s64
    rack_count: mutable u32

@fixed_layout
struct Ngs2RackSlot:
    used: mutable bool
    handle: mutable OrbisNgs2Handle
    buffer_info: mutable OrbisNgs2ContextBufferInfo
    system_handle: mutable OrbisNgs2Handle
    user_data: mutable usize
    rack_id: mutable u32
    max_voices: mutable u32
    voice_base: mutable OrbisNgs2Handle
    render_count: mutable u64

global mutable next_handle: OrbisNgs2Handle = 0x100000
global mutable ngs2_systems: array[Ngs2SystemSlot, NGS2_MAX_SYSTEMS]
global mutable ngs2_racks: array[Ngs2RackSlot, NGS2_MAX_RACKS]
global mutable last_system_handle: OrbisNgs2Handle = 0
global mutable last_rack_handle: OrbisNgs2Handle = 0
global mutable last_voice_handle: OrbisNgs2Handle = 0
global mutable last_system_user_data: usize = 0
global mutable last_rack_user_data: usize = 0
global mutable last_system_sample_rate: u32 = 48000
global mutable last_system_max_grain_samples: u32 = 512
global mutable last_system_num_grain_samples: u32 = 256
global mutable last_rack_id: u32 = 0
global mutable last_rack_max_voices: u32 = DEFAULT_MAX_VOICES
global mutable last_voice_index: u32 = 0
global mutable last_system_render_count: s64 = 0
global mutable last_rack_render_count: u64 = 0
global mutable voice_state_flags: u32[NGS2_MAX_VOICE_STATE_SLOTS]
global mutable voice_waveform_ptrs: void&?[NGS2_MAX_VOICE_STATE_SLOTS]
global mutable voice_decoded_samples: u64[NGS2_MAX_VOICE_STATE_SLOTS]
global mutable voice_decoded_data_sizes: u64[NGS2_MAX_VOICE_STATE_SLOTS]
global mutable voice_callback_data: usize[NGS2_MAX_VOICE_STATE_SLOTS]
global mutable voice_frame_offsets: u32[NGS2_MAX_VOICE_STATE_SLOTS]
global mutable voice_port_matrix_ids: s32[NGS2_MAX_PORT_SLOTS]
global mutable voice_port_volumes: f32[NGS2_MAX_PORT_SLOTS]
global mutable voice_port_dest_input_ids: u32[NGS2_MAX_PORT_SLOTS]
global mutable voice_port_dest_handles: OrbisNgs2Handle[NGS2_MAX_PORT_SLOTS]
global mutable voice_matrix_num_levels: u32[NGS2_MAX_MATRIX_SLOTS]
global mutable voice_matrix_levels: f32[NGS2_MAX_MATRIX_LEVEL_SLOTS]

def _alloc() -> OrbisNgs2Handle:
    next_handle <- next_handle + 1
    return next_handle

def _find_system_slot(handle: OrbisNgs2Handle) -> int:
    i: mutable int = 0
    while i < NGS2_MAX_SYSTEMS:
        if ngs2_systems[i].used and ngs2_systems[i].handle == handle:
            return i
        i <- i + 1
    return -1

def _find_free_system_slot() -> int:
    i: mutable int = 0
    while i < NGS2_MAX_SYSTEMS:
        if not ngs2_systems[i].used:
            return i
        i <- i + 1
    return -1

def _find_rack_slot(handle: OrbisNgs2Handle) -> int:
    i: mutable int = 0
    while i < NGS2_MAX_RACKS:
        if ngs2_racks[i].used and ngs2_racks[i].handle == handle:
            return i
        i <- i + 1
    return -1

def _find_free_rack_slot() -> int:
    i: mutable int = 0
    while i < NGS2_MAX_RACKS:
        if not ngs2_racks[i].used:
            return i
        i <- i + 1
    return -1

def _find_voice_rack_slot(handle: OrbisNgs2Handle) -> int:
    i: mutable int = 0
    while i < NGS2_MAX_RACKS:
        rack_voice_end: OrbisNgs2Handle = ngs2_racks[i].voice_base + (ngs2_racks[i].max_voices as OrbisNgs2Handle)
        if ngs2_racks[i].used and handle >= ngs2_racks[i].voice_base and handle < rack_voice_end:
            return i
        i <- i + 1
    return -1

def _voice_index_for_handle(rack_slot: int, handle: OrbisNgs2Handle) -> u32:
    return (handle - ngs2_racks[rack_slot].voice_base) as u32

def _voice_state_index(rack_slot: int, voice_index: u32) -> usize:
    return (rack_slot as usize) * (NGS2_MAX_VOICES_TRACKED as usize) + (voice_index as usize)

def _voice_port_index(rack_slot: int, voice_index: u32, port: u32) -> usize:
    return _voice_state_index(rack_slot, voice_index) * (MAX_TRACKED_PORTS as usize) + (port as usize)

def _voice_matrix_index(rack_slot: int, voice_index: u32, matrix_id: u32) -> usize:
    return _voice_state_index(rack_slot, voice_index) * (MAX_TRACKED_MATRICES as usize) + (matrix_id as usize)

def _voice_matrix_level_index(rack_slot: int, voice_index: u32, matrix_id: u32, level: u32) -> usize:
    return _voice_matrix_index(rack_slot, voice_index, matrix_id) * (MAX_MATRIX_LEVELS as usize) + (level as usize)

def _clear_voice_slot_state(rack_slot: int, voice_index: u32) -> void:
    state_index: usize = _voice_state_index(rack_slot, voice_index)
    voice_state_flags[state_index] <- 0u32
    voice_waveform_ptrs[state_index] <- null
    voice_decoded_samples[state_index] <- 0u64
    voice_decoded_data_sizes[state_index] <- 0u64
    voice_callback_data[state_index] <- 0
    voice_frame_offsets[state_index] <- 0u32
    port: mutable u32 = 0u32
    while port < MAX_TRACKED_PORTS:
        port_index: usize = _voice_port_index(rack_slot, voice_index, port)
        voice_port_matrix_ids[port_index] <- -1
        voice_port_volumes[port_index] <- 1.0
        voice_port_dest_input_ids[port_index] <- 0u32
        voice_port_dest_handles[port_index] <- 0
        port <- port + 1u32
    matrix_id: mutable u32 = 0u32
    while matrix_id < MAX_TRACKED_MATRICES:
        matrix_index: usize = _voice_matrix_index(rack_slot, voice_index, matrix_id)
        voice_matrix_num_levels[matrix_index] <- 0u32
        level: mutable u32 = 0u32
        while level < MAX_MATRIX_LEVELS:
            voice_matrix_levels[_voice_matrix_level_index(rack_slot, voice_index, matrix_id, level)] <- 0.0
            level <- level + 1u32
        matrix_id <- matrix_id + 1u32

def _is_system(handle: OrbisNgs2Handle) -> bool:
    return handle != 0 and _find_system_slot(handle) >= 0

def _is_rack(handle: OrbisNgs2Handle) -> bool:
    return handle != 0 and _find_rack_slot(handle) >= 0

def _is_voice(handle: OrbisNgs2Handle) -> bool:
    if handle == 0:
        return false
    return _find_voice_rack_slot(handle) >= 0

def _valid_sample_rate(sample_rate: u32) -> bool:
    return sample_rate == 11025u32 or sample_rate == 12000u32 or sample_rate == 22050u32 or sample_rate == 24000u32 or sample_rate == 44100u32 or sample_rate == 48000u32 or sample_rate == 88200u32 or sample_rate == 96000u32 or sample_rate == 176400u32 or sample_rate == 192000u32

def _validate_system_option(option: OrbisNgs2SystemOption&?) -> s32:
    if option == null:
        return ORBIS_OK
    if option.size != SYSTEM_OPTION_SIZE:
        return ORBIS_NGS2_ERROR_INVALID_OPTION_SIZE
    if option.max_grain_samples < 64u32 or option.max_grain_samples > 1024u32 or (option.max_grain_samples & 63u32) != 0u32:
        return ORBIS_NGS2_ERROR_INVALID_MAX_GRAIN_SAMPLES
    if option.num_grain_samples < 64u32 or option.num_grain_samples > 1024u32 or (option.num_grain_samples & 63u32) != 0u32:
        return ORBIS_NGS2_ERROR_INVALID_NUM_GRAIN_SAMPLES
    if not _valid_sample_rate(option.sample_rate):
        return ORBIS_NGS2_ERROR_INVALID_SAMPLE_RATE
    return ORBIS_OK

def sceNgs2CalcWaveformBlock(format: OrbisNgs2WaveformFormat&?, sample_pos: u32, num_samples: u32, out_block: mutable OrbisNgs2WaveformBlock&?) -> s32:
    _ = sample_pos
    if format == null:
        return ORBIS_NGS2_ERROR_INVALID_WAVEFORM_FORMAT
    if out_block == null:
        return ORBIS_NGS2_ERROR_INVALID_WAVEFORM_BLOCK_ADDRESS
    out_block.num_repeats <- 1
    out_block.num_samples <- num_samples
    return ORBIS_OK

def sceNgs2GetWaveformFrameInfo(format: OrbisNgs2WaveformFormat&?, out_frame_size: mutable u32&?, out_num_frame_samples: mutable u32&?, out_units_per_frame: mutable u32&?, out_num_delay_samples: mutable u32&?) -> s32:
    if format == null:
        return ORBIS_NGS2_ERROR_INVALID_WAVEFORM_FORMAT
    if out_frame_size == null or out_num_frame_samples == null or out_units_per_frame == null or out_num_delay_samples == null:
        return ORBIS_NGS2_ERROR_INVALID_OUT_ADDRESS
    out_frame_size <- 1
    out_num_frame_samples <- 1
    out_units_per_frame <- 1
    out_num_delay_samples <- 0
    return ORBIS_OK

# keep remaining functions from current file for now

def _fill_fallback_waveform_info(has_data: bool, data_size: usize, out_info: mutable OrbisNgs2WaveformInfo&?) -> void:
    if out_info == null:
        return
    info: mutable OrbisNgs2WaveformInfo = zeroed
    info.format.num_channels <- 1u32
    info.format.sample_rate <- 48000u32
    info.data_size <- data_size as u32
    info.audio_unit_size <- 1u32
    info.num_audio_unit_samples <- 1u32
    info.num_audio_unit_per_frame <- 1u32
    info.audio_frame_size <- 1u32
    info.num_audio_frame_samples <- 1u32
    if has_data:
        info.num_blocks <- 1u32
        info.a_block0.data_size <- data_size as u32
        info.a_block0.num_repeats <- 1u32
        info.a_block0.user_data <- data_size
    cxx_copy_value_to[OrbisNgs2WaveformInfo](out_info.cast[mutable void&], info)

def sceNgs2ParseWaveformData(data: void&?, data_size: usize, out_info: mutable OrbisNgs2WaveformInfo&?) -> s32:
    if data == null or data_size == 0:
        return ORBIS_NGS2_ERROR_INVALID_WAVEFORM_DATA
    if out_info == null:
        return ORBIS_NGS2_ERROR_INVALID_OUT_ADDRESS
    _fill_fallback_waveform_info(true, data_size, out_info)
    return ORBIS_OK

def sceNgs2ParseWaveformFile(path: u8&?, offset: u64, out_info: mutable OrbisNgs2WaveformInfo&?) -> s32:
    _ = offset
    if path == null:
        return ORBIS_NGS2_ERROR_INVALID_WAVEFORM_ADDRESS
    if out_info == null:
        return ORBIS_NGS2_ERROR_INVALID_OUT_ADDRESS
    _fill_fallback_waveform_info(false, 0, out_info)
    return ORBIS_OK

def sceNgs2ParseWaveformUser(handler: OrbisNgs2ParseReadHandler, user_data: usize, out_info: mutable OrbisNgs2WaveformInfo&?) -> s32:
    _ = handler
    _ = user_data
    if out_info == null:
        return ORBIS_NGS2_ERROR_INVALID_OUT_ADDRESS
    _fill_fallback_waveform_info(false, 0, out_info)
    return ORBIS_OK

# Rack
def sceNgs2RackCreate(system_handle: OrbisNgs2Handle, rack_id: u32, option: OrbisNgs2RackOption&?, buffer_info: OrbisNgs2ContextBufferInfo&?, out_rack: mutable OrbisNgs2Handle&?) -> s32:
    if system_handle == 0:
        return ORBIS_NGS2_ERROR_INVALID_SYSTEM_HANDLE
    if out_rack == null:
        return ORBIS_NGS2_ERROR_INVALID_OUT_ADDRESS
    system_slot: int = _find_system_slot(system_handle)
    if system_slot < 0:
        return ORBIS_NGS2_ERROR_INVALID_SYSTEM_HANDLE
    rack_slot: int = _find_free_rack_slot()
    if rack_slot < 0:
        return ORBIS_NGS2_ERROR_FAIL
    rack_handle: OrbisNgs2Handle = _alloc()
    max_voices: mutable u32 = DEFAULT_MAX_VOICES
    if option != null and option.max_voices != 0u32:
        max_voices <- option.max_voices
    if max_voices > NGS2_MAX_VOICES_TRACKED:
        max_voices <- NGS2_MAX_VOICES_TRACKED
    voice_base: OrbisNgs2Handle = next_handle + 1
    next_handle <- next_handle + (max_voices as OrbisNgs2Handle)
    ngs2_racks[rack_slot].used <- true
    ngs2_racks[rack_slot].handle <- rack_handle
    ngs2_racks[rack_slot].buffer_info <- zeroed
    if buffer_info != null:
        ngs2_racks[rack_slot].buffer_info.host_buffer <- buffer_info.host_buffer
        ngs2_racks[rack_slot].buffer_info.host_buffer_size <- buffer_info.host_buffer_size
        ngs2_racks[rack_slot].buffer_info.reserved0 <- buffer_info.reserved0
        ngs2_racks[rack_slot].buffer_info.reserved1 <- buffer_info.reserved1
        ngs2_racks[rack_slot].buffer_info.reserved2 <- buffer_info.reserved2
        ngs2_racks[rack_slot].buffer_info.reserved3 <- buffer_info.reserved3
        ngs2_racks[rack_slot].buffer_info.reserved4 <- buffer_info.reserved4
        ngs2_racks[rack_slot].buffer_info.user_data <- buffer_info.user_data
    ngs2_racks[rack_slot].system_handle <- system_handle
    ngs2_racks[rack_slot].user_data <- 0
    ngs2_racks[rack_slot].rack_id <- rack_id
    ngs2_racks[rack_slot].max_voices <- max_voices
    ngs2_racks[rack_slot].voice_base <- voice_base
    ngs2_racks[rack_slot].render_count <- 0u64
    voice_init_index: mutable u32 = 0u32
    while voice_init_index < max_voices:
        _clear_voice_slot_state(rack_slot, voice_init_index)
        voice_init_index <- voice_init_index + 1u32
    ngs2_systems[system_slot].rack_count <- ngs2_systems[system_slot].rack_count + 1u32
    last_rack_handle <- rack_handle
    last_rack_id <- rack_id
    last_rack_user_data <- 0
    last_rack_max_voices <- max_voices
    out_rack <- rack_handle
    return ORBIS_OK

def sceNgs2RackCreateWithAllocator(system_handle: OrbisNgs2Handle, rack_id: u32, option: OrbisNgs2RackOption&?, allocator: OrbisNgs2BufferAllocator&?, out_rack: mutable OrbisNgs2Handle&?) -> s32:
    if system_handle == 0:
        return ORBIS_NGS2_ERROR_INVALID_SYSTEM_HANDLE
    if allocator == null:
        return ORBIS_NGS2_ERROR_INVALID_BUFFER_ALLOCATOR
    if out_rack == null:
        return ORBIS_NGS2_ERROR_INVALID_OUT_ADDRESS
    buffer_info: mutable OrbisNgs2ContextBufferInfo = zeroed
    buffer_info.user_data <- allocator.user_data
    max_voices: mutable u32 = DEFAULT_MAX_VOICES
    if option != null and option.max_voices != 0u32:
        max_voices <- option.max_voices
    buffer_info.host_buffer_size <- size_of(Ngs2RackSlot) + (max_voices as usize) * size_of(OrbisNgs2VoiceState)
    alloc_result: s32 = allocator.alloc_handler(buffer_info.ref[mutable OrbisNgs2ContextBufferInfo&])
    if alloc_result < 0:
        return alloc_result
    result: s32 = sceNgs2RackCreate(system_handle, rack_id, option, buffer_info.ref[OrbisNgs2ContextBufferInfo&], out_rack)
    if result < 0:
        _ = allocator.free_handler(buffer_info.ref[mutable OrbisNgs2ContextBufferInfo&])
    return result

def sceNgs2RackDestroy(rack_handle: OrbisNgs2Handle, out_buffer_info: mutable OrbisNgs2ContextBufferInfo&?) -> s32:
    slot: int = _find_rack_slot(rack_handle)
    if rack_handle == 0 or slot < 0:
        return ORBIS_NGS2_ERROR_INVALID_RACK_HANDLE
    if out_buffer_info != null:
        out_buffer_info <- ngs2_racks[slot].buffer_info
    system_slot: int = _find_system_slot(ngs2_racks[slot].system_handle)
    if system_slot >= 0 and ngs2_systems[system_slot].rack_count > 0u32:
        ngs2_systems[system_slot].rack_count <- ngs2_systems[system_slot].rack_count - 1u32
    voice_clear_index: mutable u32 = 0u32
    while voice_clear_index < ngs2_racks[slot].max_voices:
        _clear_voice_slot_state(slot, voice_clear_index)
        voice_clear_index <- voice_clear_index + 1u32
    ngs2_racks[slot].used <- false
    if last_rack_handle == rack_handle:
        last_rack_handle <- 0
    if _find_voice_rack_slot(last_voice_handle) < 0:
        last_voice_handle <- 0
    last_voice_index <- 0u32
    return ORBIS_OK

def sceNgs2RackGetInfo(rack_handle: OrbisNgs2Handle, out_info: mutable OrbisNgs2RackInfo&?, info_size: usize) -> s32:
    if rack_handle == 0:
        return ORBIS_NGS2_ERROR_INVALID_RACK_HANDLE
    if out_info == null:
        return ORBIS_NGS2_ERROR_INVALID_OUT_ADDRESS
    if info_size < size_of(OrbisNgs2RackInfo):
        return ORBIS_NGS2_ERROR_INVALID_OUT_SIZE
    slot: int = _find_rack_slot(rack_handle)
    if slot < 0:
        return ORBIS_NGS2_ERROR_INVALID_RACK_HANDLE
    out_info.rack_handle <- rack_handle
    out_info.buffer_info <- ngs2_racks[slot].buffer_info
    out_info.owner_system_handle <- ngs2_racks[slot].system_handle
    out_info.rack_id <- ngs2_racks[slot].rack_id
    out_info.uid <- rack_handle as u32
    out_info.max_voices <- ngs2_racks[slot].max_voices
    out_info.render_count <- ngs2_racks[slot].render_count
    voice_count: mutable u32 = 0u32
    while voice_count < ngs2_racks[slot].max_voices:
        if voice_state_flags[_voice_state_index(slot, voice_count)] != 0u32:
            out_info.active_voice_count <- out_info.active_voice_count + 1u32
        voice_count <- voice_count + 1u32
    return ORBIS_OK

def sceNgs2RackGetUserData(rack_handle: OrbisNgs2Handle, out_user_data: mutable usize&?) -> s32:
    if rack_handle == 0:
        return ORBIS_NGS2_ERROR_INVALID_RACK_HANDLE
    if out_user_data == null:
        return ORBIS_NGS2_ERROR_INVALID_OUT_ADDRESS
    slot: int = _find_rack_slot(rack_handle)
    if slot < 0:
        return ORBIS_NGS2_ERROR_INVALID_RACK_HANDLE
    out_user_data <- ngs2_racks[slot].user_data
    return ORBIS_OK

def sceNgs2RackGetVoiceHandle(rack_handle: OrbisNgs2Handle, voice_index: u32, out_voice: mutable OrbisNgs2Handle&?) -> s32:
    if rack_handle == 0:
        return ORBIS_NGS2_ERROR_INVALID_RACK_HANDLE
    if out_voice == null:
        return ORBIS_NGS2_ERROR_INVALID_OUT_ADDRESS
    slot: int = _find_rack_slot(rack_handle)
    if slot < 0:
        return ORBIS_NGS2_ERROR_INVALID_RACK_HANDLE
    if voice_index >= ngs2_racks[slot].max_voices:
        return ORBIS_NGS2_ERROR_INVALID_VOICE_INDEX
    last_voice_handle <- ngs2_racks[slot].voice_base + (voice_index as OrbisNgs2Handle)
    last_voice_index <- voice_index
    out_voice <- last_voice_handle
    return ORBIS_OK

def sceNgs2RackLock(rack_handle: OrbisNgs2Handle) -> s32:
    _ = rack_handle
    return ORBIS_OK

def sceNgs2RackQueryBufferSize(rack_id: u32, option: OrbisNgs2RackOption&?, out_size: mutable usize&?) -> s32:
    _ = rack_id
    if out_size == null:
        return ORBIS_NGS2_ERROR_INVALID_OUT_ADDRESS
    max_voices: mutable u32 = DEFAULT_MAX_VOICES
    if option != null and option.max_voices != 0u32:
        max_voices <- option.max_voices
    out_size <- size_of(Ngs2RackSlot) + (max_voices as usize) * size_of(OrbisNgs2VoiceState)
    return ORBIS_OK

def sceNgs2RackSetUserData(rack_handle: OrbisNgs2Handle, user_data: usize) -> s32:
    slot: int = _find_rack_slot(rack_handle)
    if rack_handle == 0 or slot < 0:
        return ORBIS_NGS2_ERROR_INVALID_RACK_HANDLE
    ngs2_racks[slot].user_data <- user_data
    if last_rack_handle == rack_handle:
        last_rack_user_data <- user_data
    return ORBIS_OK

def sceNgs2RackUnlock(rack_handle: OrbisNgs2Handle) -> s32:
    _ = rack_handle
    return ORBIS_OK

# System
def sceNgs2SystemCreate(option: OrbisNgs2SystemOption&?, buffer_info: OrbisNgs2ContextBufferInfo&?, out_system: mutable OrbisNgs2Handle&?) -> s32:
    if buffer_info == null:
        return ORBIS_NGS2_ERROR_INVALID_BUFFER_INFO
    if out_system == null:
        return ORBIS_NGS2_ERROR_INVALID_OUT_ADDRESS
    validation: s32 = _validate_system_option(option)
    if validation != ORBIS_OK:
        return validation
    if buffer_info.host_buffer == null:
        return ORBIS_NGS2_ERROR_INVALID_BUFFER_ADDRESS
    if buffer_info.host_buffer_size < MIN_SYSTEM_BUFFER_SIZE:
        return ORBIS_NGS2_ERROR_INVALID_BUFFER_SIZE
    slot: int = _find_free_system_slot()
    if slot < 0:
        return ORBIS_NGS2_ERROR_FAIL
    handle: OrbisNgs2Handle = _alloc()
    ngs2_systems[slot].used <- true
    ngs2_systems[slot].handle <- handle
    ngs2_systems[slot].buffer_info.host_buffer <- buffer_info.host_buffer
    ngs2_systems[slot].buffer_info.host_buffer_size <- buffer_info.host_buffer_size
    ngs2_systems[slot].buffer_info.reserved0 <- buffer_info.reserved0
    ngs2_systems[slot].buffer_info.reserved1 <- buffer_info.reserved1
    ngs2_systems[slot].buffer_info.reserved2 <- buffer_info.reserved2
    ngs2_systems[slot].buffer_info.reserved3 <- buffer_info.reserved3
    ngs2_systems[slot].buffer_info.reserved4 <- buffer_info.reserved4
    ngs2_systems[slot].buffer_info.user_data <- buffer_info.user_data
    ngs2_systems[slot].user_data <- buffer_info.user_data
    ngs2_systems[slot].sample_rate <- 48000u32
    ngs2_systems[slot].max_grain_samples <- 512u32
    ngs2_systems[slot].num_grain_samples <- 256u32
    ngs2_systems[slot].render_count <- 0
    ngs2_systems[slot].rack_count <- 0u32
    if option != null:
        if option.sample_rate != 0u32:
            ngs2_systems[slot].sample_rate <- option.sample_rate
        if option.max_grain_samples != 0u32:
            ngs2_systems[slot].max_grain_samples <- option.max_grain_samples
        if option.num_grain_samples != 0u32:
            ngs2_systems[slot].num_grain_samples <- option.num_grain_samples
    last_system_handle <- handle
    last_system_user_data <- ngs2_systems[slot].user_data
    last_system_sample_rate <- ngs2_systems[slot].sample_rate
    last_system_max_grain_samples <- ngs2_systems[slot].max_grain_samples
    last_system_num_grain_samples <- ngs2_systems[slot].num_grain_samples
    out_system <- handle
    return ORBIS_OK

def sceNgs2SystemCreateWithAllocator(option: OrbisNgs2SystemOption&?, allocator: OrbisNgs2BufferAllocator&?, out_system: mutable OrbisNgs2Handle&?) -> s32:
    if allocator == null:
        return ORBIS_NGS2_ERROR_INVALID_BUFFER_ALLOCATOR
    if out_system == null:
        return ORBIS_NGS2_ERROR_INVALID_OUT_ADDRESS
    validation: s32 = _validate_system_option(option)
    if validation != ORBIS_OK:
        return validation
    buffer_info: mutable OrbisNgs2ContextBufferInfo = zeroed
    buffer_info.user_data <- allocator.user_data
    query_result: s32 = sceNgs2SystemQueryBufferSize(option, buffer_info.host_buffer_size.ref[mutable usize&])
    if query_result < 0:
        return query_result
    alloc_result: s32 = allocator.alloc_handler(buffer_info.ref[mutable OrbisNgs2ContextBufferInfo&])
    if alloc_result < 0:
        return alloc_result
    result: s32 = sceNgs2SystemCreate(option, buffer_info.ref[OrbisNgs2ContextBufferInfo&], out_system)
    if result < 0:
        _ = allocator.free_handler(buffer_info.ref[mutable OrbisNgs2ContextBufferInfo&])
    return result

def sceNgs2SystemDestroy(system_handle: OrbisNgs2Handle, out_buffer_info: mutable OrbisNgs2ContextBufferInfo&?) -> s32:
    slot: int = _find_system_slot(system_handle)
    if system_handle == 0 or slot < 0:
        return ORBIS_NGS2_ERROR_INVALID_SYSTEM_HANDLE
    if out_buffer_info != null:
        out_buffer_info <- ngs2_systems[slot].buffer_info
    i: mutable int = 0
    while i < NGS2_MAX_RACKS:
        if ngs2_racks[i].used and ngs2_racks[i].system_handle == system_handle:
            voice_clear_index: mutable u32 = 0u32
            while voice_clear_index < ngs2_racks[i].max_voices:
                _clear_voice_slot_state(i, voice_clear_index)
                voice_clear_index <- voice_clear_index + 1u32
            ngs2_racks[i].used <- false
        i <- i + 1
    ngs2_systems[slot].used <- false
    if last_system_handle == system_handle:
        last_system_handle <- 0
    if _find_rack_slot(last_rack_handle) < 0:
        last_rack_handle <- 0
    if _find_voice_rack_slot(last_voice_handle) < 0:
        last_voice_handle <- 0
    last_voice_index <- 0u32
    return ORBIS_OK

def sceNgs2SystemEnumHandles(out_handle: mutable OrbisNgs2Handle&?, max_handles: u32) -> s32:
    if out_handle == null and max_handles != 0u32:
        return ORBIS_NGS2_ERROR_INVALID_OUT_ADDRESS
    count: mutable u32 = 0u32
    i: mutable int = 0
    while i < NGS2_MAX_SYSTEMS and count < max_handles:
        if ngs2_systems[i].used:
            out_handle <- ngs2_systems[i].handle
            count <- count + 1u32
        i <- i + 1
    return count as s32

def sceNgs2SystemEnumRackHandles(system_handle: OrbisNgs2Handle, out_handles: mutable OrbisNgs2Handle&?, max_handles: u32) -> s32:
    if system_handle == 0:
        return ORBIS_NGS2_ERROR_INVALID_SYSTEM_HANDLE
    if out_handles == null and max_handles != 0u32:
        return ORBIS_NGS2_ERROR_INVALID_OUT_ADDRESS
    if _find_system_slot(system_handle) < 0:
        return ORBIS_NGS2_ERROR_INVALID_SYSTEM_HANDLE
    count: mutable u32 = 0u32
    i: mutable int = 0
    while i < NGS2_MAX_RACKS and count < max_handles:
        if ngs2_racks[i].used and ngs2_racks[i].system_handle == system_handle:
            out_handles <- ngs2_racks[i].handle
            count <- count + 1u32
        i <- i + 1
    return count as s32

def sceNgs2SystemGetInfo(system_handle: OrbisNgs2Handle, out_info: mutable OrbisNgs2SystemInfo&?, info_size: usize) -> s32:
    if system_handle == 0:
        return ORBIS_NGS2_ERROR_INVALID_SYSTEM_HANDLE
    if out_info == null:
        return ORBIS_NGS2_ERROR_INVALID_OUT_ADDRESS
    if info_size < size_of(OrbisNgs2SystemInfo):
        return ORBIS_NGS2_ERROR_INVALID_OUT_SIZE
    slot: int = _find_system_slot(system_handle)
    if slot < 0:
        return ORBIS_NGS2_ERROR_INVALID_SYSTEM_HANDLE
    out_info.system_handle <- system_handle
    out_info.buffer_info <- ngs2_systems[slot].buffer_info
    out_info.uid <- system_handle as u32
    out_info.min_grain_samples <- ngs2_systems[slot].num_grain_samples
    out_info.max_grain_samples <- ngs2_systems[slot].max_grain_samples
    out_info.sample_rate <- ngs2_systems[slot].sample_rate
    out_info.num_grain_samples <- ngs2_systems[slot].num_grain_samples
    out_info.render_count <- ngs2_systems[slot].render_count
    out_info.rack_count <- ngs2_systems[slot].rack_count
    return ORBIS_OK

def sceNgs2SystemGetUserData(system_handle: OrbisNgs2Handle, out_user_data: mutable usize&?) -> s32:
    if system_handle == 0:
        return ORBIS_NGS2_ERROR_INVALID_SYSTEM_HANDLE
    if out_user_data == null:
        return ORBIS_NGS2_ERROR_INVALID_OUT_ADDRESS
    slot: int = _find_system_slot(system_handle)
    if slot < 0:
        return ORBIS_NGS2_ERROR_INVALID_SYSTEM_HANDLE
    out_user_data <- ngs2_systems[slot].user_data
    return ORBIS_OK

def sceNgs2SystemLock(system_handle: OrbisNgs2Handle) -> s32:
    if system_handle == 0:
        return ORBIS_NGS2_ERROR_INVALID_SYSTEM_HANDLE
    return ORBIS_OK

def sceNgs2SystemQueryBufferSize(option: OrbisNgs2SystemOption&?, out_size: mutable usize&?) -> s32:
    if out_size == null:
        return ORBIS_NGS2_ERROR_INVALID_OUT_ADDRESS
    validation: s32 = _validate_system_option(option)
    if validation != ORBIS_OK:
        return validation
    out_size <- MIN_SYSTEM_BUFFER_SIZE
    return ORBIS_OK

def sceNgs2SystemRender(system_handle: OrbisNgs2Handle, a_buffer_info: void&?, num_buffer_info: u32) -> s32:
    slot: int = _find_system_slot(system_handle)
    if system_handle == 0 or slot < 0:
        return ORBIS_NGS2_ERROR_INVALID_SYSTEM_HANDLE
    if a_buffer_info != null:
        buffer_index: mutable u32 = 0u32
        while buffer_index < num_buffer_info:
            buffer_info: OrbisNgs2RenderBufferInfo = cxx_read_array_at[OrbisNgs2RenderBufferInfo](a_buffer_info, buffer_index as usize)
            if buffer_info.buffer != null and buffer_info.buffer_size > 0:
                _ = cxx_zero_memory(buffer_info.buffer.cast[mutable void&], buffer_info.buffer_size)
            buffer_index <- buffer_index + 1u32
    ngs2_systems[slot].render_count <- ngs2_systems[slot].render_count + 1
    i: mutable int = 0
    while i < NGS2_MAX_RACKS:
        if ngs2_racks[i].used and ngs2_racks[i].system_handle == system_handle:
            ngs2_racks[i].render_count <- ngs2_racks[i].render_count + 1u64
        i <- i + 1
    last_system_render_count <- ngs2_systems[slot].render_count
    return ORBIS_OK

def sceNgs2SystemResetOption(out_option: mutable OrbisNgs2SystemOption&?) -> s32:
    if out_option == null:
        return ORBIS_NGS2_ERROR_INVALID_OPTION_ADDRESS
    option: mutable OrbisNgs2SystemOption = zeroed
    option.size <- SYSTEM_OPTION_SIZE
    option.max_grain_samples <- 512u32
    option.num_grain_samples <- 256u32
    option.sample_rate <- 48000u32
    cxx_copy_value_to[OrbisNgs2SystemOption](out_option.cast[mutable void&], option)
    return ORBIS_OK

def sceNgs2SystemSetGrainSamples(system_handle: OrbisNgs2Handle, num_samples: u32) -> s32:
    slot: int = _find_system_slot(system_handle)
    if system_handle == 0 or slot < 0:
        return ORBIS_NGS2_ERROR_INVALID_SYSTEM_HANDLE
    ngs2_systems[slot].num_grain_samples <- num_samples
    if last_system_handle == system_handle:
        last_system_num_grain_samples <- num_samples
    return ORBIS_OK

def sceNgs2SystemSetSampleRate(system_handle: OrbisNgs2Handle, sample_rate: u32) -> s32:
    slot: int = _find_system_slot(system_handle)
    if system_handle == 0 or slot < 0:
        return ORBIS_NGS2_ERROR_INVALID_SYSTEM_HANDLE
    ngs2_systems[slot].sample_rate <- sample_rate
    if last_system_handle == system_handle:
        last_system_sample_rate <- sample_rate
    return ORBIS_OK

def sceNgs2SystemSetUserData(system_handle: OrbisNgs2Handle, user_data: usize) -> s32:
    slot: int = _find_system_slot(system_handle)
    if system_handle == 0 or slot < 0:
        return ORBIS_NGS2_ERROR_INVALID_SYSTEM_HANDLE
    ngs2_systems[slot].user_data <- user_data
    if last_system_handle == system_handle:
        last_system_user_data <- user_data
    return ORBIS_OK

def sceNgs2SystemUnlock(system_handle: OrbisNgs2Handle) -> s32:
    if system_handle == 0:
        return ORBIS_NGS2_ERROR_INVALID_SYSTEM_HANDLE
    return ORBIS_OK

# Voice
def sceNgs2VoiceControl(voice_handle: OrbisNgs2Handle, param_list: void&?) -> s32:
    if voice_handle == 0:
        return ORBIS_NGS2_ERROR_INVALID_VOICE_HANDLE
    if param_list == null:
        return ORBIS_NGS2_ERROR_INVALID_VOICE_CONTROL_ADDRESS
    rack_slot: int = _find_voice_rack_slot(voice_handle)
    if rack_slot < 0:
        return ORBIS_NGS2_ERROR_INVALID_VOICE_HANDLE
    voice_index: u32 = _voice_index_for_handle(rack_slot, voice_handle)
    header: OrbisNgs2VoiceParamHeader = cxx_read_value[OrbisNgs2VoiceParamHeader](param_list)
    if header.id == VOICE_PARAM_ID_EVENT:
        event_param: OrbisNgs2VoiceEventParam = cxx_read_value[OrbisNgs2VoiceEventParam](param_list)
        state_index: usize = _voice_state_index(rack_slot, voice_index)
        if event_param.event_id == 0u32:
            voice_state_flags[state_index] <- voice_state_flags[state_index] | VOICE_STATE_ACTIVE
        elif event_param.event_id == 1u32:
            voice_state_flags[state_index] <- voice_state_flags[state_index] & (~VOICE_STATE_ACTIVE)
    elif header.id == VOICE_PARAM_ID_PORT_VOLUME:
        volume_param: OrbisNgs2VoicePortVolumeParam = cxx_read_value[OrbisNgs2VoicePortVolumeParam](param_list)
        if volume_param.port < MAX_TRACKED_PORTS:
            voice_port_volumes[_voice_port_index(rack_slot, voice_index, volume_param.port)] <- volume_param.level
    elif header.id == VOICE_PARAM_ID_PATCH:
        patch_param: OrbisNgs2VoicePatchParam = cxx_read_value[OrbisNgs2VoicePatchParam](param_list)
        if patch_param.port < MAX_TRACKED_PORTS:
            port_index: usize = _voice_port_index(rack_slot, voice_index, patch_param.port)
            voice_port_dest_input_ids[port_index] <- patch_param.dest_input_id
            voice_port_dest_handles[port_index] <- patch_param.dest_handle
    elif header.id == VOICE_PARAM_ID_MATRIX_LEVELS:
        matrix_param: OrbisNgs2VoiceMatrixLevelsParam = cxx_read_value[OrbisNgs2VoiceMatrixLevelsParam](param_list)
        if matrix_param.matrix_id < MAX_TRACKED_MATRICES and matrix_param.a_level != null:
            matrix_index: usize = _voice_matrix_index(rack_slot, voice_index, matrix_param.matrix_id)
            count: mutable u32 = matrix_param.num_levels
            if count > MAX_MATRIX_LEVELS:
                count <- MAX_MATRIX_LEVELS
            voice_matrix_num_levels[matrix_index] <- count
            level: mutable u32 = 0u32
            while level < count:
                voice_matrix_levels[_voice_matrix_level_index(rack_slot, voice_index, matrix_param.matrix_id, level)] <- matrix_param.a_level[level as usize]
                level <- level + 1u32
    elif header.id == VOICE_PARAM_ID_CALLBACK:
        callback_param: OrbisNgs2VoiceCallbackParam = cxx_read_value[OrbisNgs2VoiceCallbackParam](param_list)
        voice_callback_data[_voice_state_index(rack_slot, voice_index)] <- callback_param.callback_data
    elif header.id == CUSTOM_VOICE_PARAM_ID_SETUP:
        setup_param: OrbisNgs2CustomSamplerVoiceSetupParam = cxx_read_value[OrbisNgs2CustomSamplerVoiceSetupParam](param_list)
        _ = setup_param
    elif header.id == CUSTOM_VOICE_PARAM_ID_WAVEFORM_BLOCKS:
        blocks_param: OrbisNgs2CustomSamplerVoiceWaveformBlocksParam = cxx_read_value[OrbisNgs2CustomSamplerVoiceWaveformBlocksParam](param_list)
        state_index: usize = _voice_state_index(rack_slot, voice_index)
        voice_waveform_ptrs[state_index] <- blocks_param.data
        voice_decoded_data_sizes[state_index] <- 0u64
        voice_decoded_samples[state_index] <- 0u64
        if blocks_param.a_block != null and blocks_param.num_blocks != 0u32:
            block_count: mutable u32 = blocks_param.num_blocks
            if block_count > 4u32:
                block_count <- 4u32
            block_index: mutable u32 = 0u32
            while block_index < block_count:
                block: OrbisNgs2WaveformBlock = blocks_param.a_block[block_index as usize]
                voice_decoded_data_sizes[state_index] <- voice_decoded_data_sizes[state_index] + (block.data_size as u64)
                voice_decoded_samples[state_index] <- voice_decoded_samples[state_index] + (block.num_samples as u64)
                block_index <- block_index + 1u32
    elif header.id == CUSTOM_VOICE_PARAM_ID_WAVEFORM_ADDRESS:
        address_param: OrbisNgs2CustomSamplerVoiceWaveformAddressParam = cxx_read_value[OrbisNgs2CustomSamplerVoiceWaveformAddressParam](param_list)
        voice_waveform_ptrs[_voice_state_index(rack_slot, voice_index)] <- address_param.from_addr
    elif header.id == CUSTOM_VOICE_PARAM_ID_WAVEFORM_FRAME_OFFSET:
        offset_param: OrbisNgs2CustomSamplerVoiceWaveformFrameOffsetParam = cxx_read_value[OrbisNgs2CustomSamplerVoiceWaveformFrameOffsetParam](param_list)
        voice_frame_offsets[_voice_state_index(rack_slot, voice_index)] <- offset_param.frame_offset
    elif header.id == CUSTOM_VOICE_PARAM_ID_PITCH:
        pitch_param: OrbisNgs2CustomSamplerVoicePitchParam = cxx_read_value[OrbisNgs2CustomSamplerVoicePitchParam](param_list)
        _ = pitch_param
    return ORBIS_OK

def sceNgs2VoiceGetMatrixInfo(voice_handle: OrbisNgs2Handle, matrix_id: u32, out_info: mutable void&?, out_info_size: usize) -> s32:
    if voice_handle == 0:
        return ORBIS_NGS2_ERROR_INVALID_VOICE_HANDLE
    if out_info == null:
        return ORBIS_NGS2_ERROR_INVALID_OUT_ADDRESS
    if out_info_size < size_of(OrbisNgs2VoiceMatrixInfo):
        return ORBIS_NGS2_ERROR_INVALID_OUT_SIZE
    rack_slot: int = _find_voice_rack_slot(voice_handle)
    if rack_slot < 0:
        return ORBIS_NGS2_ERROR_INVALID_VOICE_HANDLE
    info: mutable OrbisNgs2VoiceMatrixInfo = zeroed
    if matrix_id < MAX_TRACKED_MATRICES:
        voice_index: u32 = _voice_index_for_handle(rack_slot, voice_handle)
        matrix_index: usize = _voice_matrix_index(rack_slot, voice_index, matrix_id)
        info.num_levels <- voice_matrix_num_levels[matrix_index]
        level: mutable u32 = 0u32
        while level < info.num_levels and level < MAX_MATRIX_LEVELS:
            info.a_level[level as usize] <- voice_matrix_levels[_voice_matrix_level_index(rack_slot, voice_index, matrix_id, level)]
            level <- level + 1u32
    cxx_copy_value_to[OrbisNgs2VoiceMatrixInfo](out_info, info)
    return ORBIS_OK

def sceNgs2VoiceGetOwner(voice_handle: OrbisNgs2Handle, out_rack: mutable OrbisNgs2Handle&?, out_index: mutable u32&?) -> s32:
    if voice_handle == 0:
        return ORBIS_NGS2_ERROR_INVALID_VOICE_HANDLE
    if out_rack == null or out_index == null:
        return ORBIS_NGS2_ERROR_INVALID_OUT_ADDRESS
    slot: int = _find_voice_rack_slot(voice_handle)
    if slot < 0:
        return ORBIS_NGS2_ERROR_INVALID_VOICE_HANDLE
    out_rack <- ngs2_racks[slot].handle
    out_index <- (voice_handle - ngs2_racks[slot].voice_base) as u32
    return ORBIS_OK

def sceNgs2VoiceGetPortInfo(voice_handle: OrbisNgs2Handle, port: u32, out_info: mutable void&?, out_info_size: usize) -> s32:
    if voice_handle == 0:
        return ORBIS_NGS2_ERROR_INVALID_VOICE_HANDLE
    if out_info == null:
        return ORBIS_NGS2_ERROR_INVALID_OUT_ADDRESS
    if out_info_size < size_of(OrbisNgs2VoicePortInfo):
        return ORBIS_NGS2_ERROR_INVALID_OUT_SIZE
    rack_slot: int = _find_voice_rack_slot(voice_handle)
    if rack_slot < 0:
        return ORBIS_NGS2_ERROR_INVALID_VOICE_HANDLE
    info: mutable OrbisNgs2VoicePortInfo = zeroed
    info.matrix_id <- -1
    info.volume <- 1.0
    if port < MAX_TRACKED_PORTS:
        voice_index: u32 = _voice_index_for_handle(rack_slot, voice_handle)
        port_index: usize = _voice_port_index(rack_slot, voice_index, port)
        info.matrix_id <- voice_port_matrix_ids[port_index]
        info.volume <- voice_port_volumes[port_index]
        info.dest_input_id <- voice_port_dest_input_ids[port_index]
        info.dest_handle <- voice_port_dest_handles[port_index]
    cxx_copy_value_to[OrbisNgs2VoicePortInfo](out_info, info)
    return ORBIS_OK

def sceNgs2VoiceGetState(voice_handle: OrbisNgs2Handle, out_state: mutable OrbisNgs2VoiceState&?, state_size: usize) -> s32:
    if voice_handle == 0:
        return ORBIS_NGS2_ERROR_INVALID_VOICE_HANDLE
    if out_state == null:
        return ORBIS_NGS2_ERROR_INVALID_OUT_ADDRESS
    if state_size < size_of(OrbisNgs2VoiceState):
        return ORBIS_NGS2_ERROR_INVALID_OUT_SIZE
    rack_slot: int = _find_voice_rack_slot(voice_handle)
    if rack_slot < 0:
        return ORBIS_NGS2_ERROR_INVALID_VOICE_HANDLE
    voice_index: u32 = _voice_index_for_handle(rack_slot, voice_handle)
    state_index: usize = _voice_state_index(rack_slot, voice_index)
    if state_size >= size_of(OrbisNgs2CustomSamplerVoiceState):
        custom_state: mutable OrbisNgs2CustomSamplerVoiceState = zeroed
        custom_state.voice_state.state_flags <- voice_state_flags[state_index]
        custom_state.waveform_data <- voice_waveform_ptrs[state_index]
        custom_state.num_decoded_samples <- voice_decoded_samples[state_index]
        custom_state.decoded_data_size <- voice_decoded_data_sizes[state_index]
        custom_state.user_data <- voice_callback_data[state_index] as u64
        cxx_copy_value_to[OrbisNgs2CustomSamplerVoiceState](out_state.ref[mutable void&], custom_state)
    else:
        out_state.state_flags <- voice_state_flags[state_index]
    return ORBIS_OK

def sceNgs2VoiceGetStateFlags(voice_handle: OrbisNgs2Handle, out_flags: mutable u32&?) -> s32:
    if voice_handle == 0:
        return ORBIS_NGS2_ERROR_INVALID_VOICE_HANDLE
    if out_flags == null:
        return ORBIS_NGS2_ERROR_INVALID_OUT_ADDRESS
    rack_slot: int = _find_voice_rack_slot(voice_handle)
    if rack_slot < 0:
        return ORBIS_NGS2_ERROR_INVALID_VOICE_HANDLE
    out_flags <- voice_state_flags[_voice_state_index(rack_slot, _voice_index_for_handle(rack_slot, voice_handle))]
    return ORBIS_OK

