# @port core/libraries/rtc/rtc.cpp::sceRtcSetCurrentTick sha256=25478c734742ea19 oracle@a3773841
def sceRtcSetCurrentTick(p_tick: mutable OrbisRtcTick&?) -> int:
    if p_tick == null:
        return ORBIS_RTC_ERROR_INVALID_POINTER
    if p_tick.tick <= UNIX_EPOCH_TICKS.u64():
        return ORBIS_RTC_ERROR_INVALID_VALUE
    return ORBIS_OK

# @port core/libraries/rtc/rtc.cpp::sceRtcSetDosTime sha256=8a7c9747b9f46c4e oracle@a3773841
def sceRtcSetDosTime(p_time: mutable OrbisRtcDateTime&?, dos_time: u32) -> int:
    if p_time == null:
        return ORBIS_RTC_ERROR_INVALID_POINTER
    p_time.microsecond <- 0
    p_time.second <- ((dos_time << 1) & 0x3E).u16()
    p_time.minute <- ((dos_time >> 5) & 0x3F).u16()
    p_time.hour <- ((dos_time >> 11) & 0x1F).u16()
    days: u32 = dos_time >> 16
    p_time.day <- (days & 0x1F).u16()
    p_time.month <- ((days >> 5) & 0x0F).u16()
    p_time.year <- ((days >> 9) + 1980).u16()
    return ORBIS_OK

# @port core/libraries/rtc/rtc.cpp::sceRtcSetTime_t sha256=1bdd2ad5fc7db9eb oracle@a3773841
def sceRtcSetTime_t(p_time: mutable OrbisRtcDateTime&?, ll_time: s64) -> int:
    if p_time == null:
        return ORBIS_RTC_ERROR_INVALID_POINTER
    if ll_time < 0:
        return ORBIS_RTC_ERROR_INVALID_VALUE
    tick: mutable OrbisRtcTick = zeroed
    tick.tick <- (ll_time * 1000000 + UNIX_EPOCH_TICKS).u64()
    return sceRtcSetTick(p_time, tick)

# @port core/libraries/rtc/rtc.cpp::sceRtcSetWin32FileTime sha256=85f02fe271c038d7 oracle@a3773841
def sceRtcSetWin32FileTime(p_time: mutable OrbisRtcDateTime&?, ul_win32_time: s64) -> int:
    if p_time == null:
        return ORBIS_RTC_ERROR_INVALID_POINTER
    tick: mutable OrbisRtcTick = zeroed
    tick.tick <- ((ul_win32_time / 10 + WIN32_FILETIME_EPOCH_TICKS).u64())
    return sceRtcSetTick(p_time, tick)

# @port core/libraries/rtc/rtc.cpp::sceRtcTickAddDays sha256=7a41aa5458e057cd oracle@a3773841
