        return valid
    time_tick: mutable OrbisRtcTick = zeroed
    _ = sceRtcGetTick(p_time, time_tick)
    if time_tick.tick < WIN32_FILETIME_EPOCH_TICKS.u64():
        ul_win32_time <- 0
    else:
        ul_win32_time <- (time_tick.tick - WIN32_FILETIME_EPOCH_TICKS.u64()) * 10
    return ORBIS_OK

# @port core/libraries/rtc/rtc.cpp::sceRtcParseDateTime sha256=ceda770ce3d4f7a5 oracle@a3773841
def sceRtcParseDateTime(p_tick_utc: mutable OrbisRtcTick&?, psz_date_time: u8&?) -> int:
    if p_tick_utc == null or psz_date_time == null:
        return ORBIS_RTC_ERROR_INVALID_POINTER
    if psz_date_time[4] == '-':
        return sceRtcParseRFC3339(p_tick_utc, psz_date_time)
    dt: mutable OrbisRtcDateTime = zeroed
    if psz_date_time[19] == ':':
        dt.day <- _atoi2(psz_date_time, 5).u16()
        dt.month <- _month_from_string(psz_date_time, 8).u16()
        dt.year <- _atoi4(psz_date_time, 12).u16()
        dt.hour <- _atoi2(psz_date_time, 17).u16()
        dt.minute <- _atoi2(psz_date_time, 20).u16()
        dt.second <- _atoi2(psz_date_time, 23).u16()
        dt.microsecond <- 0
        _ = sceRtcGetTick(dt, p_tick_utc)
        if psz_date_time[26] == '+' or psz_date_time[26] == '-':
            offset: mutable int = _atoi2(psz_date_time, 27) * 60 + _atoi2(psz_date_time, 29)
            if psz_date_time[26] == '-':
                offset <- -offset
            _ = sceRtcTickAddMinutes(p_tick_utc, p_tick_utc, offset.s64())
        return ORBIS_OK
    dt.month <- _month_from_string(psz_date_time, 4).u16()
    dt.day <- _atoi2(psz_date_time, 8).u16()
    dt.hour <- _atoi2(psz_date_time, 11).u16()
    dt.minute <- _atoi2(psz_date_time, 14).u16()
    dt.second <- _atoi2(psz_date_time, 17).u16()
    dt.year <- _atoi4(psz_date_time, 20).u16()
    dt.microsecond <- 0
    _ = sceRtcGetTick(dt, p_tick_utc)
    return ORBIS_OK

# @port core/libraries/rtc/rtc.cpp::sceRtcParseRFC3339 sha256=16de1f5c0de3d6b4 oracle@a3773841
def sceRtcParseRFC3339(p_tick_utc: mutable OrbisRtcTick&?, psz_date_time: u8&?) -> int:
    if p_tick_utc == null or psz_date_time == null:
        return ORBIS_RTC_ERROR_INVALID_POINTER
    dt: mutable OrbisRtcDateTime = zeroed
    dt.year <- _atoi4(psz_date_time, 0).u16()
    dt.month <- _atoi2(psz_date_time, 5).u16()
    dt.day <- _atoi2(psz_date_time, 8).u16()
    dt.hour <- _atoi2(psz_date_time, 11).u16()
    dt.minute <- _atoi2(psz_date_time, 14).u16()
    dt.second <- _atoi2(psz_date_time, 17).u16()
    tz_pos: mutable usize = 19
    dt.microsecond <- 0
    if psz_date_time[19] == '.':
        dt.microsecond <- (_atoi2(psz_date_time, 20) * 10000).u32()
        tz_pos <- 22
    _ = sceRtcGetTick(dt, p_tick_utc)
    if psz_date_time[tz_pos] == '+' or psz_date_time[tz_pos] == '-':
        tzm: mutable int = _atoi2(psz_date_time, tz_pos + 1) * 60 + _atoi2(psz_date_time, tz_pos + 4)
        if psz_date_time[tz_pos] == '-':
            tzm <- -tzm
        _ = sceRtcTickAddMinutes(p_tick_utc, p_tick_utc, tzm.s64())
    return ORBIS_OK

