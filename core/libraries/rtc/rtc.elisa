# @port core/libraries/rtc/rtc.cpp::sceRtcGetDosTime sha256=a2be739ad212c56c oracle@a3773841
def sceRtcGetDosTime(p_time: mutable OrbisRtcDateTime&?, dos_time: mutable u32&?) -> int:
    if p_time == null or dos_time == null:
        return ORBIS_RTC_ERROR_INVALID_POINTER
    valid: int = sceRtcCheckValid(p_time)
    if valid != ORBIS_OK:
        return valid
    dos_time <- 0
    dos_time <- dos_time | ((p_time.second / 2).u32() & 0x1F)
    dos_time <- dos_time | ((p_time.minute.u32() & 0x3F) << 5)
    dos_time <- dos_time | ((p_time.hour.u32() & 0x1F) << 11)
    dos_time <- dos_time | ((p_time.day.u32() & 0x1F) << 16)
    dos_time <- dos_time | ((p_time.month.u32() & 0x0F) << 21)
    dos_time <- dos_time | (((p_time.year - 1980).u32() & 0x7F) << 25)
    return ORBIS_OK

# @port core/libraries/rtc/rtc.cpp::sceRtcGetTime_t sha256=85e97e4d41d5ae8f oracle@a3773841
def sceRtcGetTime_t(p_time: mutable OrbisRtcDateTime&?, ll_time: mutable s64&?) -> int:
    if p_time == null or ll_time == null:
        return ORBIS_RTC_ERROR_INVALID_POINTER
    valid: int = sceRtcCheckValid(p_time)
    if valid != ORBIS_OK:
        return valid
    time_tick: mutable OrbisRtcTick = zeroed
    _ = sceRtcGetTick(p_time, time_tick)
    if time_tick.tick < UNIX_EPOCH_TICKS.u64():
        ll_time <- 0
    else:
        ll_time <- ((time_tick.tick - UNIX_EPOCH_TICKS.u64()) / 1000000).s64()
    return ORBIS_OK

# @port core/libraries/rtc/rtc.cpp::sceRtcGetWin32FileTime sha256=6f24cf5b5a152618 oracle@a3773841
def sceRtcGetWin32FileTime(p_time: mutable OrbisRtcDateTime&?, ul_win32_time: mutable u64&?) -> int:
