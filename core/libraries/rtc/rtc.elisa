# @port core/libraries/rtc/rtc.cpp::sceRtcTickAddMonths sha256=1fb77941e0bd7f9d oracle@a3773841
def sceRtcTickAddMonths(p_tick1: mutable OrbisRtcTick&?, p_tick2: mutable OrbisRtcTick&?, l_add: s32) -> int:
    if p_tick1 == null or p_tick2 == null:
        return ORBIS_RTC_ERROR_INVALID_POINTER
    if l_add == 0:
        p_tick1.tick <- p_tick2.tick
        return ORBIS_OK
    time_value: mutable OrbisRtcDateTime = zeroed
    _ = sceRtcSetTick(time_value, p_tick2)
    s: mutable s64 = 1
    if l_add < 0:
        s <- -1
    year_value: mutable s64 = time_value.year.s64() + (l_add.s64() / 12)
    temp_month: mutable s64 = time_value.month.s64() + (l_add.s64() % 12) - 1
    if temp_month > 11 or temp_month < 0:
        temp_month <- temp_month - (s * 12)
        year_value <- year_value + s
    time_value.year <- year_value.u16()
    time_value.month <- (temp_month + 1).u16()
    last_day: int = _days_in_month(time_value.year.int(), time_value.month.int())
    if time_value.day.int() > last_day:
        time_value.day <- last_day.u16()
    valid: int = sceRtcCheckValid(time_value)
    if valid == ORBIS_OK:
        return sceRtcGetTick(time_value, p_tick1)
    return valid
