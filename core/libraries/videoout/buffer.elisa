#
# Native Elisa port of core/libraries/videoout/buffer.h: VideoOut display
# buffer attributes. Enums (PixelFormat: u32, TilingMode: s32) are modeled as
# prefixed u32 constants. GetPixelFormatString returns the format name as a
# C string (static u8&); the C++ default branch (UNREACHABLE) returns "".
# VideoOutBuffer's C++ `s32 group_index{-1}` default is provided via the
# VideoOutBuffer_New constructor (zeroed gives 0, so it is set explicitly).

const VIDEO_OUT_MAX_DISPLAY_BUFFERS: u32 = 16
const VIDEO_OUT_MAX_DISPLAY_BUFFER_GROUPS: u32 = 4

# enum class PixelFormat : u32
const VIDEO_OUT_PIXEL_FORMAT_UNKNOWN: u32 = 0
const VIDEO_OUT_PIXEL_FORMAT_A8R8G8B8_SRGB: u32 = 0x80000000
const VIDEO_OUT_PIXEL_FORMAT_A8B8G8R8_SRGB: u32 = 0x80002200
const VIDEO_OUT_PIXEL_FORMAT_A2R10G10B10: u32 = 0x88060000
const VIDEO_OUT_PIXEL_FORMAT_A2R10G10B10_SRGB: u32 = 0x88000000
const VIDEO_OUT_PIXEL_FORMAT_A2R10G10B10_BT2020_PQ: u32 = 0x88740000
const VIDEO_OUT_PIXEL_FORMAT_A16R16G16B16_FLOAT: u32 = 0xC1060000

# enum class TilingMode : s32 (modeled as u32; values are 0/1)
const VIDEO_OUT_TILING_MODE_TILE: u32 = 0
const VIDEO_OUT_TILING_MODE_LINEAR: u32 = 1

# GetPixelFormatString: returns the name for each known format, else "".
# C++ default branch is UNREACHABLE_MSG; we return the empty string.
def GetPixelFormatString(format: u32) -> static u8&:
    if format == VIDEO_OUT_PIXEL_FORMAT_A8R8G8B8_SRGB:
        return "A8R8G8B8Srgb"
    if format == VIDEO_OUT_PIXEL_FORMAT_A8B8G8R8_SRGB:
        return "A8B8G8R8Srgb"
    if format == VIDEO_OUT_PIXEL_FORMAT_A2R10G10B10:
        return "A2R10G10B10"
    if format == VIDEO_OUT_PIXEL_FORMAT_A2R10G10B10_SRGB:
        return "A2R10G10B10Srgb"
    if format == VIDEO_OUT_PIXEL_FORMAT_A2R10G10B10_BT2020_PQ:
        return "A2R10G10B10Bt2020Pq"
    if format == VIDEO_OUT_PIXEL_FORMAT_A16R16G16B16_FLOAT:
        return "A16R16G16B16Float"
    return ""

struct BufferAttribute:
    pixel_format: mutable u32    # PixelFormat
    tiling_mode: mutable u32     # TilingMode
    aspect_ratio: mutable i32
    width: mutable u32
    height: mutable u32
    pitch_in_pixel: mutable u32
    option: mutable u32
    reserved0: mutable u32
    reserved1: mutable u64

struct BufferAttributeGroup:
    is_occupied: mutable bool
    attrib: mutable BufferAttribute

struct VideoOutBuffer:
    group_index: mutable i32     # C++ default is -1 (see VideoOutBuffer_New)
    address_left: mutable u64    # uintptr_t
    address_right: mutable u64   # uintptr_t

# Mirrors C++ `s32 group_index{-1}` default member initializer.
def VideoOutBuffer_New() -> VideoOutBuffer:
    out: mutable VideoOutBuffer = zeroed
    out.group_index <- -1
    return out
