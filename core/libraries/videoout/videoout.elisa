    return ORBIS_OK

def sceVideoOutGetEventId(a0: void&?) -> int:
    ev: OrbisKernelEvent&? = a0 as OrbisKernelEvent&?
    if ev == null:
        return ORBIS_VIDEO_OUT_ERROR_INVALID_ADDRESS
    if ev.filter.int() != EQUEUE_FILTER_VIDEOOUT:
        return ORBIS_VIDEO_OUT_ERROR_INVALID_EVENT
    if ev.ident == VIDEOOUT_INTERNAL_EVENT_FLIP:
        return VIDEOOUT_EVENT_ID_FLIP
    if ev.ident == VIDEOOUT_INTERNAL_EVENT_VBLANK or ev.ident == VIDEOOUT_INTERNAL_EVENT_SYS_VBLANK:
        return VIDEOOUT_EVENT_ID_VBLANK
    if ev.ident == VIDEOOUT_INTERNAL_EVENT_PRE_VBLANK_START:
        return VIDEOOUT_EVENT_ID_PRE_VBLANK_START
    if ev.ident == VIDEOOUT_INTERNAL_EVENT_SET_MODE:
        return VIDEOOUT_EVENT_ID_SET_MODE
    if ev.ident == VIDEOOUT_INTERNAL_EVENT_POSITION:
        return VIDEOOUT_EVENT_ID_POSITION
    return ORBIS_VIDEO_OUT_ERROR_INVALID_EVENT

def sceVideoOutGetEventData(a0: void&?, a1: void&?) -> int:
    ev: OrbisKernelEvent&? = a0 as OrbisKernelEvent&?
    out_data: mutable i64&? = a1 as mutable i64&?
    if ev == null or out_data == null:
        return ORBIS_VIDEO_OUT_ERROR_INVALID_ADDRESS
    if ev.filter.int() != EQUEUE_FILTER_VIDEOOUT:
        return ORBIS_VIDEO_OUT_ERROR_INVALID_EVENT

    event_data: u64 = ev.data >> 16u64
    if ev.ident != VIDEOOUT_INTERNAL_EVENT_FLIP or ev.data.cast[i64] >= 0:
        out_data[0] <- event_data.cast[i64]
    else:
        out_data[0] <- (event_data | 0xffff000000000000u64).cast[i64]
    return ORBIS_OK

def sceVideoOutGetEventCount(a0: void&?) -> int:
    ev: OrbisKernelEvent&? = a0 as OrbisKernelEvent&?
    if ev == null:
        return ORBIS_VIDEO_OUT_ERROR_INVALID_ADDRESS
    if ev.filter.int() != EQUEUE_FILTER_VIDEOOUT:
        return ORBIS_VIDEO_OUT_ERROR_INVALID_EVENT
    return ((ev.data >> 12u64) & 0xfu64).int()

