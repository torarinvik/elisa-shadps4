def sceVideoOutModeSetAny_(a0: void&?, a1: i64) -> void:
    if a0 == null or a1 < VIDEOOUT_MODE_STRUCT_SIZE:
        return
    bytes: mutable u8&? = a0 as mutable u8&?
    if bytes == null:
        return
    i: mutable i64 = 0
    while i < a1:
        bytes[i.usize()] <- 0xffu8
        i <- i + 1
    mode: mutable VideoOutMode&? = a0 as mutable VideoOutMode&?
    if mode != null:
        mode.size <- a1.u32()

def sceVideoOutConfigureOutputMode_(a0: i64, a1: i64, a2: void&?, a3: void&?, a4: i64, a5: i64) -> int:
    videoout_lazy_init()
    _ = a3
    _ = a5
    if not videoout_is_valid_handle(a0) or not g_videoout_is_open:
        return ORBIS_VIDEO_OUT_ERROR_INVALID_HANDLE
    if a2 == null or a4 < VIDEOOUT_MODE_STRUCT_SIZE:
        return ORBIS_VIDEO_OUT_ERROR_INVALID_ADDRESS
    if a1 != 0:
        return ORBIS_VIDEO_OUT_ERROR_INVALID_VALUE
    mode: VideoOutMode&? = a2 as VideoOutMode&?
    if mode == null:
        return ORBIS_VIDEO_OUT_ERROR_INVALID_ADDRESS
    if mode.colorimetry == VIDEOOUT_COLORIMETRY_ANY:
