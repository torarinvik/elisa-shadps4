include "../error_codes.elisa"
include "../kernel/lib_function_stub.elisa"
include "videoout_error.elisa"

@link_name(ElisaGuestExec_EmitCusaArtifactKV)
extern c_GuestExec_EmitCusaArtifactKV(key: static u8&?, value: u64) -> void

const SCE_VIDEO_OUT_BUS_TYPE_MAIN: i64 = 0
const SCE_VIDEO_OUT_REFRESH_RATE_59_94HZ: u64 = 3u64
const SCE_VIDEO_OUT_BUFFER_ATTRIBUTE_OPTION_NONE: u32 = 0u32

const SCE_VIDEO_OUT_PIXEL_FORMAT_A8R8G8B8_SRGB: u32 = 0x80000000u32
const SCE_VIDEO_OUT_PIXEL_FORMAT_A8B8G8R8_SRGB: u32 = 0x80002200u32
const SCE_VIDEO_OUT_PIXEL_FORMAT_A2R10G10B10: u32 = 0x88060000u32
const SCE_VIDEO_OUT_PIXEL_FORMAT_A2R10G10B10_SRGB: u32 = 0x88000000u32
const SCE_VIDEO_OUT_PIXEL_FORMAT_A2R10G10B10_BT2020_PQ: u32 = 0x88740000u32
const SCE_VIDEO_OUT_PIXEL_FORMAT_A16R16G16B16_FLOAT: u32 = 0xC1060000u32

const ORBIS_VIDEO_OUT_DEVICE_CAPABILITY_BT2020_PQ: u64 = 0x80u64

const VIDEOOUT_MAIN_HANDLE: int = 1
const VIDEOOUT_MAX_DISPLAY_BUFFERS: int = 16
const VIDEOOUT_MAX_DISPLAY_BUFFER_GROUPS: int = 4
const VIDEOOUT_MAX_EVENT_BINDINGS: int = 64
const VIDEOOUT_MAX_PENDING_REQUESTS: int = 64
const VIDEOOUT_MODE_STRUCT_SIZE: i64 = 32

const VIDEOOUT_TILING_TILE: i32 = 0
const VIDEOOUT_TILING_LINEAR: i32 = 1

const VIDEOOUT_COLORIMETRY_ANY: u8 = 0xffu8
const VIDEOOUT_COLORIMETRY_BT2020_PQ: u8 = 12u8

const VIDEOOUT_EVENT_ID_FLIP: int = 0
const VIDEOOUT_EVENT_ID_VBLANK: int = 1
const VIDEOOUT_EVENT_ID_PRE_VBLANK_START: int = 2
const VIDEOOUT_EVENT_ID_SET_MODE: int = 8
const VIDEOOUT_EVENT_ID_POSITION: int = 12

const VIDEOOUT_INTERNAL_EVENT_FLIP: u64 = 0x6u64
const VIDEOOUT_INTERNAL_EVENT_VBLANK: u64 = 0x7u64
const VIDEOOUT_INTERNAL_EVENT_SET_MODE: u64 = 0x51u64
const VIDEOOUT_INTERNAL_EVENT_POSITION: u64 = 0x58u64
const VIDEOOUT_INTERNAL_EVENT_PRE_VBLANK_START: u64 = 0x59u64
const VIDEOOUT_INTERNAL_EVENT_SYS_VBLANK: u64 = 0x63u64
const EQUEUE_FILTER_VIDEOOUT: int = -13
const EQUEUE_FLAG_ADD: u16 = 0x0001u16

@fixed_layout
struct OrbisKernelEvent:
    ident: mutable u64
    filter: mutable i16
    flags: mutable u16
    fflags: mutable u32
    data: mutable u64
    udata: mutable void&?

@fixed_layout
struct VideoOutBufferAttribute:
    pixel_format: mutable u32
    tiling_mode: mutable i32
    aspect_ratio: mutable i32
    width: mutable u32
    height: mutable u32
    pitch_in_pixel: mutable u32
    option: mutable u32
    reserved0: mutable u32
    reserved1: mutable u64

@fixed_layout
struct VideoOutBufferAttributeGroupState:
    is_occupied: mutable bool
    attrib: mutable VideoOutBufferAttribute

@fixed_layout
struct VideoOutBufferSlot:
    group_index: mutable i32
    address_left: mutable u64
    address_right: mutable u64

@fixed_layout
struct FlipStatus:
    count: mutable u64
    process_time: mutable u64
    tsc: mutable u64
    flip_arg: mutable i64
    submit_tsc: mutable u64
    reserved0: mutable u64
    gc_queue_num: mutable i32
    flip_pending_num: mutable i32
    current_buffer: mutable i32
    reserved1: mutable u32

@fixed_layout
struct SceVideoOutResolutionStatus:
    full_width: mutable i32
    full_height: mutable i32
    pane_width: mutable i32
    pane_height: mutable i32
    refresh_rate: mutable u64
    screen_size_in_inch: mutable f32
    flags: mutable u16
    reserved0: mutable u16
    reserved1: mutable u32[3]

@fixed_layout
struct SceVideoOutVblankStatus:
    count: mutable u64
    process_time: mutable u64
    tsc: mutable u64
    reserved: mutable u64[1]
    flags: mutable u8
    pad1: mutable u8[7]

@fixed_layout
struct SceVideoOutDeviceCapabilityInfo:
    capability: mutable u64

@fixed_layout
struct SceVideoOutColorSettings:
    gamma: mutable f32
    reserved: mutable u32[3]

@fixed_layout
struct VideoOutMode:
    size: mutable u32
    encoding: mutable u8
    range: mutable u8
    colorimetry: mutable u8
    depth: mutable u8
    refresh_rate: mutable u64
    resolution: mutable u64
    reserved: mutable u8[8]

@fixed_layout
struct VideoOutFlipRequest:
    index: mutable i32
    flip_arg: mutable i64
    is_eop: mutable bool

@fixed_layout
struct VideoOutEventBinding:
    used: mutable bool
    eq_handle: mutable int
    udata: mutable void&?

@fixed_layout
struct VideoOutPresenterState:
    present_count: mutable u64
    last_present_addr: mutable u64
    last_present_width: mutable u32
    last_present_height: mutable u32
    last_present_format: mutable u32
    hdr_enabled: mutable bool

global mutable g_videoout_initialized: bool = false
global mutable g_videoout_is_open: bool = false
global mutable g_videoout_is_hdr: bool = false
global mutable g_videoout_flip_rate: int = 0
global mutable g_videoout_prev_index: int = -1
global mutable g_videoout_color_gamma: f32 = 1.0
global mutable g_videoout_last_vblank_tsc: u64 = 0u64
global mutable g_videoout_vblank_frequency: u32 = 60u32
global mutable g_videoout_virtual_tsc: u64 = 0u64
global mutable g_videoout_virtual_process_time: u64 = 0u64

global mutable g_videoout_resolution: SceVideoOutResolutionStatus = zeroed
global mutable g_videoout_flip_status: FlipStatus = zeroed
global mutable g_videoout_vblank_status: SceVideoOutVblankStatus = zeroed

global mutable g_videoout_buffer_slots: VideoOutBufferSlot[VIDEOOUT_MAX_DISPLAY_BUFFERS] = zeroed
global mutable g_videoout_buffer_labels: u64[VIDEOOUT_MAX_DISPLAY_BUFFERS] = zeroed
global mutable g_videoout_groups: VideoOutBufferAttributeGroupState[VIDEOOUT_MAX_DISPLAY_BUFFER_GROUPS] = zeroed

global mutable g_videoout_flip_requests: VideoOutFlipRequest[VIDEOOUT_MAX_PENDING_REQUESTS] = zeroed
global mutable g_videoout_flip_request_head: int = 0
global mutable g_videoout_flip_request_tail: int = 0
global mutable g_videoout_flip_request_count: int = 0

global mutable g_videoout_flip_event_bindings: VideoOutEventBinding[VIDEOOUT_MAX_EVENT_BINDINGS] = zeroed
global mutable g_videoout_vblank_event_bindings: VideoOutEventBinding[VIDEOOUT_MAX_EVENT_BINDINGS] = zeroed

global mutable g_videoout_presenter_state: VideoOutPresenterState = zeroed
global mutable g_videoout_artifact_opened_emitted: bool = false
global mutable g_videoout_artifact_buffers_registered_emitted: bool = false
global mutable g_videoout_artifact_first_flip_emitted: bool = false
global mutable g_videoout_artifact_flip_completed_emitted: bool = false
global mutable g_videoout_artifact_first_frame_candidate_emitted: bool = false
global mutable g_videoout_artifact_event_emitted: bool = false

def videoout_is_supported_pixel_format(pixel_format: u32) -> bool:
    return pixel_format == SCE_VIDEO_OUT_PIXEL_FORMAT_A8R8G8B8_SRGB or pixel_format == SCE_VIDEO_OUT_PIXEL_FORMAT_A8B8G8R8_SRGB or pixel_format == SCE_VIDEO_OUT_PIXEL_FORMAT_A2R10G10B10 or pixel_format == SCE_VIDEO_OUT_PIXEL_FORMAT_A2R10G10B10_SRGB or pixel_format == SCE_VIDEO_OUT_PIXEL_FORMAT_A2R10G10B10_BT2020_PQ or pixel_format == SCE_VIDEO_OUT_PIXEL_FORMAT_A16R16G16B16_FLOAT

def videoout_is_valid_handle(handle: i64) -> bool:
    return handle == VIDEOOUT_MAIN_HANDLE.i64()

def videoout_clear_event_bindings() -> void:
    i: mutable int = 0
    while i < VIDEOOUT_MAX_EVENT_BINDINGS:
        g_videoout_flip_event_bindings[i] <- zeroed
        g_videoout_vblank_event_bindings[i] <- zeroed
        i <- i + 1

def videoout_reset_port_state() -> void:
    g_videoout_is_open <- false
    g_videoout_is_hdr <- false
    g_videoout_flip_rate <- 0
    g_videoout_prev_index <- -1

    g_videoout_flip_status <- zeroed
    g_videoout_flip_status.flip_arg <- -1
    g_videoout_flip_status.current_buffer <- -1
    g_videoout_vblank_status <- zeroed

    g_videoout_flip_request_head <- 0
    g_videoout_flip_request_tail <- 0
    g_videoout_flip_request_count <- 0

    i: mutable int = 0
    while i < VIDEOOUT_MAX_DISPLAY_BUFFERS:
        g_videoout_buffer_slots[i] <- zeroed
        g_videoout_buffer_slots[i].group_index <- -1
        g_videoout_buffer_labels[i] <- 0u64
        i <- i + 1

    group_index: mutable int = 0
    while group_index < VIDEOOUT_MAX_DISPLAY_BUFFER_GROUPS:
        g_videoout_groups[group_index] <- zeroed
        group_index <- group_index + 1

    videoout_clear_event_bindings()
    g_videoout_artifact_opened_emitted <- false
    g_videoout_artifact_buffers_registered_emitted <- false
    g_videoout_artifact_first_flip_emitted <- false
    g_videoout_artifact_flip_completed_emitted <- false
    g_videoout_artifact_first_frame_candidate_emitted <- false
    g_videoout_artifact_event_emitted <- false

def videoout_lazy_init() -> void:
    if g_videoout_initialized:
        return
    g_videoout_initialized <- true
    g_videoout_resolution <- zeroed
    g_videoout_resolution.full_width <- 1280
    g_videoout_resolution.full_height <- 720
    g_videoout_resolution.pane_width <- 1280
    g_videoout_resolution.pane_height <- 720
    g_videoout_resolution.refresh_rate <- SCE_VIDEO_OUT_REFRESH_RATE_59_94HZ
    g_videoout_resolution.screen_size_in_inch <- 50.0
    videoout_reset_port_state()
    g_videoout_last_vblank_tsc <- 0u64
    g_videoout_virtual_tsc <- 0u64
    g_videoout_virtual_process_time <- 0u64

def videoout_clock_step_us() -> u64:
    freq: mutable u32 = g_videoout_vblank_frequency
    if freq == 0u32:
        freq <- 60u32
    return 1000000u64 / freq.u64()

def videoout_advance_clock(step_us: u64) -> void:
    g_videoout_virtual_process_time <- g_videoout_virtual_process_time + step_us
    g_videoout_virtual_tsc <- g_videoout_virtual_tsc + (step_us * 1000u64)

def videoout_find_free_group() -> int:
    group_index: mutable int = 0
    while group_index < VIDEOOUT_MAX_DISPLAY_BUFFER_GROUPS:
        if not g_videoout_groups[group_index].is_occupied:
            return group_index
        group_index <- group_index + 1
    return -1

def videoout_validate_buffer_attribute(attribute: VideoOutBufferAttribute) -> int:
    if not videoout_is_supported_pixel_format(attribute.pixel_format):
        return ORBIS_VIDEO_OUT_ERROR_INVALID_PIXEL_FORMAT
    if attribute.reserved0 != 0u32 or attribute.reserved1 != 0u64:
        return ORBIS_VIDEO_OUT_ERROR_INVALID_VALUE
    if attribute.aspect_ratio != 0:
        return ORBIS_VIDEO_OUT_ERROR_INVALID_ASPECT_RATIO
    if attribute.width > attribute.pitch_in_pixel:
        return ORBIS_VIDEO_OUT_ERROR_INVALID_PITCH
    if attribute.tiling_mode < VIDEOOUT_TILING_TILE or attribute.tiling_mode > VIDEOOUT_TILING_LINEAR:
        return ORBIS_VIDEO_OUT_ERROR_INVALID_TILING_MODE
    return ORBIS_OK

def videoout_enqueue_flip_request(index: i32, flip_arg: i64, is_eop: bool) -> bool:
    if g_videoout_flip_request_count >= VIDEOOUT_MAX_PENDING_REQUESTS:
        return false
    g_videoout_flip_requests[g_videoout_flip_request_tail] <- VideoOutFlipRequest(index, flip_arg, is_eop)
    g_videoout_flip_request_tail <- (g_videoout_flip_request_tail + 1) % VIDEOOUT_MAX_PENDING_REQUESTS
    g_videoout_flip_request_count <- g_videoout_flip_request_count + 1
    return true

def videoout_try_add_event_binding(is_flip: bool, eq_handle: int, udata: void&?) -> bool:
    i: mutable int = 0
    while i < VIDEOOUT_MAX_EVENT_BINDINGS:
        if is_flip:
            if not g_videoout_flip_event_bindings[i].used:
                g_videoout_flip_event_bindings[i].used <- true
                g_videoout_flip_event_bindings[i].eq_handle <- eq_handle
                g_videoout_flip_event_bindings[i].udata <- udata
                return true
        else:
            if not g_videoout_vblank_event_bindings[i].used:
                g_videoout_vblank_event_bindings[i].used <- true
                g_videoout_vblank_event_bindings[i].eq_handle <- eq_handle
                g_videoout_vblank_event_bindings[i].udata <- udata
                return true
        i <- i + 1
    return false

def videoout_remove_event_binding(is_flip: bool, eq_handle: int) -> void:
    i: mutable int = 0
    while i < VIDEOOUT_MAX_EVENT_BINDINGS:
        if is_flip:
            if g_videoout_flip_event_bindings[i].used and g_videoout_flip_event_bindings[i].eq_handle == eq_handle:
                g_videoout_flip_event_bindings[i] <- zeroed
                return
        else:
            if g_videoout_vblank_event_bindings[i].used and g_videoout_vblank_event_bindings[i].eq_handle == eq_handle:
                g_videoout_vblank_event_bindings[i] <- zeroed
                return
        i <- i + 1

def videoout_trigger_events(is_flip: bool, ident: u64, payload: u64) -> void:
    _ = ident
    _ = payload
    did_emit: mutable bool = false
    i: mutable int = 0
    while i < VIDEOOUT_MAX_EVENT_BINDINGS:
        if is_flip:
            did_emit <- did_emit or g_videoout_flip_event_bindings[i].used
        else:
            did_emit <- did_emit or g_videoout_vblank_event_bindings[i].used
        i <- i + 1
    if did_emit and not g_videoout_artifact_event_emitted:
        c_GuestExec_EmitCusaArtifactKV("VIDEO_STAGE_event_emitted", 1u64)
        g_videoout_artifact_event_emitted <- true

def videoout_process_flip(index: i32, flip_arg: i64, is_eop: bool) -> void:
    frame_available: mutable bool = false
    if index == -1:
        frame_available <- true
        g_videoout_presenter_state.last_present_addr <- 0u64
        g_videoout_presenter_state.last_present_width <- g_videoout_resolution.pane_width.u32()
        g_videoout_presenter_state.last_present_height <- g_videoout_resolution.pane_height.u32()
        g_videoout_presenter_state.last_present_format <- SCE_VIDEO_OUT_PIXEL_FORMAT_A8R8G8B8_SRGB
    elif index >= 0 and index < VIDEOOUT_MAX_DISPLAY_BUFFERS:
        slot: VideoOutBufferSlot = g_videoout_buffer_slots[index.usize()]
        if slot.group_index >= 0 and slot.group_index < VIDEOOUT_MAX_DISPLAY_BUFFER_GROUPS:
            group_state: VideoOutBufferAttributeGroupState = g_videoout_groups[slot.group_index.usize()]
            frame_available <- true
            g_videoout_presenter_state.last_present_addr <- slot.address_left
            g_videoout_presenter_state.last_present_width <- group_state.attrib.width
            g_videoout_presenter_state.last_present_height <- group_state.attrib.height
            g_videoout_presenter_state.last_present_format <- group_state.attrib.pixel_format

    if not frame_available:
        if is_eop and g_videoout_flip_status.gc_queue_num > 0:
            g_videoout_flip_status.gc_queue_num <- g_videoout_flip_status.gc_queue_num - 1
        if g_videoout_flip_status.flip_pending_num > 0:
            g_videoout_flip_status.flip_pending_num <- g_videoout_flip_status.flip_pending_num - 1
        return

    g_videoout_flip_status.count <- g_videoout_flip_status.count + 1u64
    g_videoout_flip_status.process_time <- g_videoout_virtual_process_time
    g_videoout_flip_status.tsc <- g_videoout_virtual_tsc
    g_videoout_flip_status.flip_arg <- flip_arg
    g_videoout_flip_status.current_buffer <- index
    if is_eop and g_videoout_flip_status.gc_queue_num > 0:
        g_videoout_flip_status.gc_queue_num <- g_videoout_flip_status.gc_queue_num - 1
    if g_videoout_flip_status.flip_pending_num > 0:
        g_videoout_flip_status.flip_pending_num <- g_videoout_flip_status.flip_pending_num - 1
    g_videoout_presenter_state.present_count <- g_videoout_presenter_state.present_count + 1u64
    g_videoout_presenter_state.hdr_enabled <- g_videoout_is_hdr
    if not g_videoout_artifact_flip_completed_emitted:
        c_GuestExec_EmitCusaArtifactKV("VIDEO_STAGE_flip_completed", 1u64)
        g_videoout_artifact_flip_completed_emitted <- true
    if g_videoout_presenter_state.present_count > 0u64 and not g_videoout_artifact_first_frame_candidate_emitted:
        c_GuestExec_EmitCusaArtifactKV("VIDEO_STAGE_first_frame_candidate", 1u64)
        g_videoout_artifact_first_frame_candidate_emitted <- true

    flip_payload: u64 = VIDEOOUT_INTERNAL_EVENT_FLIP | (flip_arg.u64() << 16u64)
    videoout_trigger_events(true, VIDEOOUT_INTERNAL_EVENT_FLIP, flip_payload)

    if g_videoout_prev_index >= 0 and g_videoout_prev_index < VIDEOOUT_MAX_DISPLAY_BUFFERS:
        g_videoout_buffer_labels[g_videoout_prev_index.usize()] <- 0u64
    if index >= 0 and index < VIDEOOUT_MAX_DISPLAY_BUFFERS:
        g_videoout_buffer_labels[index.usize()] <- 1u64
    g_videoout_prev_index <- index.int()

def videoout_tick_one_vblank() -> void:
    flip_divisor: mutable u64 = (g_videoout_flip_rate + 1).u64()
    if flip_divisor == 0u64:
        flip_divisor <- 1u64
    if g_videoout_vblank_status.count % flip_divisor == 0u64 and g_videoout_flip_request_count > 0:
        req: VideoOutFlipRequest = g_videoout_flip_requests[g_videoout_flip_request_head]
        g_videoout_flip_request_head <- (g_videoout_flip_request_head + 1) % VIDEOOUT_MAX_PENDING_REQUESTS
        g_videoout_flip_request_count <- g_videoout_flip_request_count - 1
        videoout_process_flip(req.index, req.flip_arg, req.is_eop)

    vblank_payload: u64 = VIDEOOUT_INTERNAL_EVENT_VBLANK | (g_videoout_vblank_status.count << 16u64)
    videoout_trigger_events(false, VIDEOOUT_INTERNAL_EVENT_VBLANK, vblank_payload)

    g_videoout_vblank_status.count <- g_videoout_vblank_status.count + 1u64
    g_videoout_vblank_status.process_time <- g_videoout_virtual_process_time
    g_videoout_vblank_status.tsc <- g_videoout_virtual_tsc

def videoout_pump_present() -> void:
    videoout_lazy_init()
    step_us: mutable u64 = videoout_clock_step_us()
    if step_us == 0u64:
        step_us <- 1u64
    videoout_advance_clock(step_us)
    videoout_tick_one_vblank()

def sceVideoOutGetFlipStatus(a0: i64, a1: void&?) -> int:
    videoout_lazy_init()
    status: mutable FlipStatus&? = a1 as mutable FlipStatus&?
    if status == null:
        return ORBIS_VIDEO_OUT_ERROR_INVALID_ADDRESS
    if not videoout_is_valid_handle(a0):
        return ORBIS_VIDEO_OUT_ERROR_INVALID_HANDLE
    videoout_pump_present()
    status[0] <- g_videoout_flip_status
    return ORBIS_OK

def sceVideoOutSubmitFlip(a0: i64, a1: i64, a2: i64, a3: i64) -> int:
    videoout_lazy_init()
    if not videoout_is_valid_handle(a0):
        return ORBIS_VIDEO_OUT_ERROR_INVALID_HANDLE

    _ = a2
    buffer_index: i32 = a1.i32()
    if buffer_index < -1 or buffer_index >= VIDEOOUT_MAX_DISPLAY_BUFFERS:
        return ORBIS_VIDEO_OUT_ERROR_INVALID_INDEX
    if buffer_index != -1 and g_videoout_buffer_slots[buffer_index.usize()].group_index < 0:
        return ORBIS_VIDEO_OUT_ERROR_INVALID_INDEX

    if buffer_index != -1 and g_videoout_flip_status.flip_pending_num > 16:
        return ORBIS_VIDEO_OUT_ERROR_FLIP_QUEUE_FULL

    g_videoout_flip_status.flip_pending_num <- g_videoout_flip_status.flip_pending_num + 1
    g_videoout_flip_status.submit_tsc <- g_videoout_virtual_tsc
    if not videoout_enqueue_flip_request(buffer_index, a3, false):
        if g_videoout_flip_status.flip_pending_num > 0:
            g_videoout_flip_status.flip_pending_num <- g_videoout_flip_status.flip_pending_num - 1
        return ORBIS_VIDEO_OUT_ERROR_FLIP_QUEUE_FULL
    if not g_videoout_artifact_first_flip_emitted:
        c_GuestExec_EmitCusaArtifactKV("first_flip_submitted", 1u64)
        c_GuestExec_EmitCusaArtifactKV("VIDEO_STAGE_flip_submitted", 1u64)
        g_videoout_artifact_first_flip_emitted <- true
    return ORBIS_OK

def sceVideoOutRegisterBuffers(a0: i64, a1: i64, a2: void&?, a3: i64, a4: void&?) -> int:
    videoout_lazy_init()
    if a2 == null or a4 == null:
        return ORBIS_VIDEO_OUT_ERROR_INVALID_ADDRESS
    if not videoout_is_valid_handle(a0) or not g_videoout_is_open:
        return ORBIS_VIDEO_OUT_ERROR_INVALID_HANDLE

    start_index: int = a1.int()
    buffer_num: int = a3.int()
    if start_index < 0 or buffer_num <= 0 or start_index >= VIDEOOUT_MAX_DISPLAY_BUFFERS or buffer_num > VIDEOOUT_MAX_DISPLAY_BUFFERS or start_index > VIDEOOUT_MAX_DISPLAY_BUFFERS - buffer_num:
        return ORBIS_VIDEO_OUT_ERROR_INVALID_VALUE

    group_index: int = videoout_find_free_group()
    if group_index < 0:
        return ORBIS_VIDEO_OUT_ERROR_NO_EMPTY_SLOT

    range_index: mutable int = 0
    while range_index < buffer_num:
        slot_index: int = start_index + range_index
        if g_videoout_buffer_slots[slot_index.usize()].group_index != -1:
            return ORBIS_VIDEO_OUT_ERROR_SLOT_OCCUPIED
        range_index <- range_index + 1

    attribute_in: VideoOutBufferAttribute&? = a4 as VideoOutBufferAttribute&?
    if attribute_in == null:
        return ORBIS_VIDEO_OUT_ERROR_INVALID_ADDRESS
    attribute: VideoOutBufferAttribute = attribute_in[0]
    validate_result: int = videoout_validate_buffer_attribute(attribute)
    if validate_result != ORBIS_OK:
        return validate_result

    addresses: u64&? = a2 as u64&?
    if addresses == null:
        return ORBIS_VIDEO_OUT_ERROR_INVALID_ADDRESS

    entry_index: mutable int = 0
    while entry_index < buffer_num:
        slot_index2: int = start_index + entry_index
        addr_word: u64 = addresses[entry_index.usize()]
        if addr_word == 0u64:
            return ORBIS_VIDEO_OUT_ERROR_INVALID_ADDRESS
        g_videoout_buffer_slots[slot_index2.usize()].group_index <- group_index.i32()
        g_videoout_buffer_slots[slot_index2.usize()].address_left <- addr_word
        g_videoout_buffer_slots[slot_index2.usize()].address_right <- 0u64
        g_videoout_buffer_labels[slot_index2.usize()] <- 0u64
        entry_index <- entry_index + 1

    g_videoout_groups[group_index].is_occupied <- true
    g_videoout_groups[group_index].attrib <- attribute
    if not g_videoout_artifact_buffers_registered_emitted:
        c_GuestExec_EmitCusaArtifactKV("videoout_buffers_registered", 1u64)
