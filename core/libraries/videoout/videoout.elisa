def sceVideoOutOpen(a0: i64, a1: i64, a2: i64, a3: void&?) -> int:
    videoout_lazy_init()
    _ = a0
    _ = a3
    _ = a1
    if a2 != 0:
        return ORBIS_VIDEO_OUT_ERROR_INVALID_VALUE
    if g_videoout_is_open:
        return ORBIS_VIDEO_OUT_ERROR_RESOURCE_BUSY
    videoout_reset_port_state()
