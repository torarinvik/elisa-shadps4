def sceVideoOutUnregisterBuffers(a0: i64, a1: i64) -> int:
    videoout_lazy_init()
    if not videoout_is_valid_handle(a0) or not g_videoout_is_open:
        return ORBIS_VIDEO_OUT_ERROR_INVALID_HANDLE
    attribute_index: int = a1.int()
    if attribute_index < 0 or attribute_index >= VIDEOOUT_MAX_DISPLAY_BUFFER_GROUPS or not g_videoout_groups[attribute_index].is_occupied:
        return ORBIS_VIDEO_OUT_ERROR_INVALID_VALUE

    g_videoout_groups[attribute_index].is_occupied <- false
    i: mutable int = 0
    while i < VIDEOOUT_MAX_DISPLAY_BUFFERS:
        if g_videoout_buffer_slots[i].group_index == attribute_index.i32():
            g_videoout_buffer_slots[i].group_index <- -1
        i <- i + 1
    return ORBIS_OK

