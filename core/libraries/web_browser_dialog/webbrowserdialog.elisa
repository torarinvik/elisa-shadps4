include "../system/commondialog.elisa"

global mutable g_web_browser_dialog_status: u32 = ORBIS_COMMON_DIALOG_STATUS_NONE

# @port core/libraries/web_browser_dialog/webbrowserdialog.cpp::sceWebBrowserDialogClose sha256=215982cde2ebc40a oracle@a3773841
def sceWebBrowserDialogClose() -> u32:
    if g_web_browser_dialog_status != ORBIS_COMMON_DIALOG_STATUS_RUNNING:
        return ORBIS_COMMON_DIALOG_ERROR_NOT_RUNNING.u32()
    return ORBIS_OK.u32()

# @port core/libraries/web_browser_dialog/webbrowserdialog.cpp::sceWebBrowserDialogGetEvent sha256=7592dc463cbf4193 oracle@a3773841
def sceWebBrowserDialogGetEvent() -> int:
    return ORBIS_OK

# @port core/libraries/web_browser_dialog/webbrowserdialog.cpp::sceWebBrowserDialogGetResult sha256=5e0f9327e7dbce98 oracle@a3773841
def sceWebBrowserDialogGetResult() -> int:
    return ORBIS_OK

# @port core/libraries/web_browser_dialog/webbrowserdialog.cpp::sceWebBrowserDialogGetStatus sha256=f129b9073440af8d oracle@a3773841
def sceWebBrowserDialogGetStatus() -> u32:
    return g_web_browser_dialog_status

# @port core/libraries/web_browser_dialog/webbrowserdialog.cpp::sceWebBrowserDialogInitialize sha256=3cef793b3b4bfdc1 oracle@a3773841
def sceWebBrowserDialogInitialize() -> u32:
    if not g_isInitialized:
        return ORBIS_COMMON_DIALOG_ERROR_NOT_SYSTEM_INITIALIZED.u32()
    if g_web_browser_dialog_status != ORBIS_COMMON_DIALOG_STATUS_NONE:
        return ORBIS_COMMON_DIALOG_ERROR_ALREADY_INITIALIZED.u32()
    if g_isUsed:
        return ORBIS_COMMON_DIALOG_ERROR_BUSY.u32()
    g_web_browser_dialog_status <- ORBIS_COMMON_DIALOG_STATUS_INITIALIZED
    g_isUsed <- true
    return ORBIS_OK.u32()

# @port core/libraries/web_browser_dialog/webbrowserdialog.cpp::sceWebBrowserDialogNavigate sha256=bce99ae68686b614 oracle@a3773841
def sceWebBrowserDialogNavigate() -> int:
    return ORBIS_OK

# @port core/libraries/web_browser_dialog/webbrowserdialog.cpp::sceWebBrowserDialogOpen sha256=9f846060bd427b97 oracle@a3773841
def sceWebBrowserDialogOpen() -> u32:
    if g_web_browser_dialog_status != ORBIS_COMMON_DIALOG_STATUS_INITIALIZED and g_web_browser_dialog_status != ORBIS_COMMON_DIALOG_STATUS_FINISHED:
        return ORBIS_COMMON_DIALOG_ERROR_INVALID_STATE.u32()
    g_web_browser_dialog_status <- ORBIS_COMMON_DIALOG_STATUS_RUNNING
    return ORBIS_OK.u32()

# @port core/libraries/web_browser_dialog/webbrowserdialog.cpp::sceWebBrowserDialogOpenForPredeterminedContent sha256=2b42349a06ec8789 oracle@a3773841
def sceWebBrowserDialogOpenForPredeterminedContent() -> int:
    return ORBIS_OK

# @port core/libraries/web_browser_dialog/webbrowserdialog.cpp::sceWebBrowserDialogResetCookie sha256=7599b07707d3d2ad oracle@a3773841
def sceWebBrowserDialogResetCookie() -> int:
    return ORBIS_OK

# @port core/libraries/web_browser_dialog/webbrowserdialog.cpp::sceWebBrowserDialogSetCookie sha256=35dc8e46dbbf87c4 oracle@a3773841
def sceWebBrowserDialogSetCookie() -> int:
    return ORBIS_OK

# @port core/libraries/web_browser_dialog/webbrowserdialog.cpp::sceWebBrowserDialogSetZoom sha256=15d328082748a385 oracle@a3773841
def sceWebBrowserDialogSetZoom() -> int:
    return ORBIS_OK

# @port core/libraries/web_browser_dialog/webbrowserdialog.cpp::sceWebBrowserDialogTerminate sha256=2b0f7556a064d163 oracle@a3773841
def sceWebBrowserDialogTerminate() -> u32:
    if g_web_browser_dialog_status == ORBIS_COMMON_DIALOG_STATUS_RUNNING:
        _ = sceWebBrowserDialogClose()
    if g_web_browser_dialog_status == ORBIS_COMMON_DIALOG_STATUS_NONE:
        return ORBIS_COMMON_DIALOG_ERROR_NOT_INITIALIZED.u32()
    g_web_browser_dialog_status <- ORBIS_COMMON_DIALOG_STATUS_NONE
    g_isUsed <- false
    return ORBIS_OK.u32()

# @port core/libraries/web_browser_dialog/webbrowserdialog.cpp::sceWebBrowserDialogUpdateStatus sha256=e0e6c58f0d23ee1f oracle@a3773841
def sceWebBrowserDialogUpdateStatus() -> u32:
    if g_web_browser_dialog_status == ORBIS_COMMON_DIALOG_STATUS_RUNNING:
        g_web_browser_dialog_status <- ORBIS_COMMON_DIALOG_STATUS_FINISHED
    return g_web_browser_dialog_status

def Func_F2BE042771625F8C() -> int:
    return ORBIS_OK

def WebBrowserDialog_RegisterLib(sym: void&?) -> void:
    _ = sym
