include "../error_codes.elisa"
include "./hmd_ffi.elisa"
include "./hmd_setup_dialog_nids.elisa"

const ORBIS_COMMON_DIALOG_RESULT_USER_CANCELED: s32 = 1
const ORBIS_COMMON_DIALOG_STATUS_FINISHED: s32 = 3

struct OrbisHmdSetupDialogParam:
    # Keep this opaque for now; API is currently stubbed and does not inspect fields.
    opaque: mutable u8[112]

struct OrbisHmdSetupDialogResult:
    result: mutable s32
    reserved: mutable u8[32]

# @port core/libraries/hmd/hmd_setup_dialog.cpp::sceHmdSetupDialogInitialize sha256=410b23739f901f16 oracle@a3773841
def sceHmdSetupDialogInitialize() -> s32:
    return ORBIS_OK

# @port core/libraries/hmd/hmd_setup_dialog.cpp::sceHmdSetupDialogClose sha256=a80601b34d02c167 oracle@a3773841
def sceHmdSetupDialogClose() -> s32:
    return ORBIS_OK

# @port core/libraries/hmd/hmd_setup_dialog.cpp::sceHmdSetupDialogOpen sha256=385519ae60cc7743 oracle@a3773841
def sceHmdSetupDialogOpen(param: OrbisHmdSetupDialogParam&?) -> s32:
    _ = param
    return ORBIS_OK

# @port core/libraries/hmd/hmd_setup_dialog.cpp::sceHmdSetupDialogGetResult sha256=aba4510876181fe9 oracle@a3773841
def sceHmdSetupDialogGetResult(result: mutable OrbisHmdSetupDialogResult&?) -> s32:
    if result == null:
        return ORBIS_OK
    result.result <- ORBIS_COMMON_DIALOG_RESULT_USER_CANCELED
    return ORBIS_OK

# @port core/libraries/hmd/hmd_setup_dialog.cpp::sceHmdSetupDialogUpdateStatus sha256=d87b406feab65fc9 oracle@a3773841
def sceHmdSetupDialogUpdateStatus() -> s32:
    return ORBIS_COMMON_DIALOG_STATUS_FINISHED

# @port core/libraries/hmd/hmd_setup_dialog.cpp::sceHmdSetupDialogGetStatus sha256=aa49b894f3c59dd5 oracle@a3773841
def sceHmdSetupDialogGetStatus() -> s32:
    return ORBIS_COMMON_DIALOG_STATUS_FINISHED

# @port core/libraries/hmd/hmd_setup_dialog.cpp::sceHmdSetupDialogTerminate sha256=10e4cbe26b2e0940 oracle@a3773841
def sceHmdSetupDialogTerminate() -> s32:
    return ORBIS_OK

def HmdSetupDialog_RegisterLib(sym: void&?) -> void:
    HmdElisa_RegisterHmdSetupDialogLib(sym)
