include "../error_codes.elisa"
include "./hmd_error.elisa"
include "./hmd_distortion_nids.elisa"

global mutable hmd_distortion_library_initialized: bool = false

# @port core/libraries/hmd/hmd_distortion.cpp::sceHmdDistortionInitialize sha256=244806b868cf6af9 oracle@a3773841
def sceHmdDistortionInitialize(reserved: void&?) -> s32:
    _ = reserved
    hmd_distortion_library_initialized <- true
    return ORBIS_OK

# @port core/libraries/hmd/hmd_distortion.cpp::sceHmdDistortionGet2dVrCommand sha256=9c71d9aae53c8b57 oracle@a3773841
