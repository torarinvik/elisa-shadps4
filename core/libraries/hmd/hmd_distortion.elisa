# @port core/libraries/hmd/hmd_distortion.cpp::sceHmdDistortionTerminate sha256=cfe5f4ce905693c8 oracle@a3773841
def sceHmdDistortionTerminate() -> s32:
    if not hmd_distortion_library_initialized:
        return ORBIS_HMD_ERROR_NOT_INITIALIZED
    hmd_distortion_library_initialized <- false
    return ORBIS_OK

def Func_B614F290B67FB59B() -> s32:
    return ORBIS_OK

def RegisterDistortion(sym: void&?) -> void:
    _ = sym
