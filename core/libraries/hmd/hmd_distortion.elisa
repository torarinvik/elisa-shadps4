def Func_B26430EA74FC3DC0() -> s32:
    return ORBIS_HMD_ERROR_PARAMETER_INVALID

# @port core/libraries/hmd/hmd_distortion.cpp::sceHmdGetDistortionParams sha256=aea70e68b9763366 oracle@a3773841
def sceHmdGetDistortionParams() -> s32:
