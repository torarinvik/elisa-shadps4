include "../error_codes.elisa"
include "./hmd_error.elisa"

global mutable hmd_distortion_library_initialized: bool = false

def sceHmdDistortionInitialize(reserved: void&?) -> s32:
    _ = reserved
    hmd_distortion_library_initialized <- true
    return ORBIS_OK

def sceHmdDistortionGet2dVrCommand() -> s32:
    return ORBIS_OK

def sceHmdDistortionGetCompoundEyeCorrectionCommand() -> s32:
    return ORBIS_HMD_ERROR_PARAMETER_INVALID

def sceHmdDistortionGetCorrectionCommand() -> s32:
    return ORBIS_OK

def sceHmdDistortionGetWideNearCorrectionCommand() -> s32:
    return ORBIS_OK

def sceHmdDistortionGetWorkMemoryAlign() -> s32:
    return 0x400

def sceHmdDistortionGetWorkMemorySize() -> s32:
    return 0x20000

def sceHmdDistortionSetOutputMinColor() -> s32:
    return ORBIS_OK

def Func_B26430EA74FC3DC0() -> s32:
    return ORBIS_HMD_ERROR_PARAMETER_INVALID

def sceHmdGetDistortionParams() -> s32:
    return ORBIS_OK

def sceHmdDistortionTerminate() -> s32:
    if not hmd_distortion_library_initialized:
        return ORBIS_HMD_ERROR_NOT_INITIALIZED
    hmd_distortion_library_initialized <- false
    return ORBIS_OK

def Func_B614F290B67FB59B() -> s32:
    return ORBIS_OK

def RegisterDistortion(sym: void&?) -> void:
    _ = sym
