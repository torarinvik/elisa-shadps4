def sceNetCtlRegisterCallbackForNpToolkit(func: i64, arg: u8&?, cid: mutable int&?) -> int:
    if (func == 0):
        return ORBIS_NET_CTL_ERROR_INVALID_ADDR
    if (cid == null):
        return ORBIS_NET_CTL_ERROR_INVALID_ADDR
    i: usize = 0
    while (i < ORBIS_NETCTL_MAX_CALLBACKS):
        slot: mutable OrbisNetCtlCallbackState& = g_netctl_nptool_callbacks[i].ref[mutable OrbisNetCtlCallbackState&]
        if (not slot.in_use):
            slot.in_use <- true
            slot.callback_func <- func.cast[OrbisNetCtlCallbackFunc]
            slot.callback_arg <- arg
            cid <- i.int()
            return ORBIS_OK
        i += 1
    return ORBIS_NET_CTL_ERROR_CALLBACK_MAX

