const ORBIS_OK: int = 0x00000000

const ORBIS_FAIL: int = 0xFFFFFFFF

const ORBIS_NET_CTL_ERROR_CALLBACK_MAX: int = 0x80412103

const ORBIS_NET_CTL_ERROR_ID_NOT_FOUND: int = 0x80412104

const ORBIS_NET_CTL_ERROR_INVALID_ID: int = 0x80412105

const ORBIS_NET_CTL_ERROR_INVALID_ADDR: int = 0x80412107

const ORBIS_NET_CTL_ERROR_NOT_CONNECTED: int = 0x80412108

const ORBIS_NET_CTL_ERROR_NOT_AVAIL: int = 0x80412109

const ORBIS_NET_CTL_ERROR_NETWORK_DISABLED: int = 0x8041210D

const ORBIS_NET_CTL_ERROR_DISCONNECT_REQ: int = 0x8041210E

const ORBIS_NET_CTL_ERROR_ETHERNET_PLUGOUT: int = 0x80412115

const ORBIS_NET_CTL_ERROR_WIFI_DEAUTHED: int = 0x80412116

const ORBIS_NET_CTL_ERROR_WIFI_BEACON_LOST: int = 0x80412117

const ORBIS_NET_CTL_STATE_DISCONNECTED: int = 0

const ORBIS_NET_CTL_STATE_CONNECTING: int = 1

const ORBIS_NET_CTL_STATE_IPOBTAINING: int = 2

const ORBIS_NET_CTL_STATE_IPOBTAINED: int = 3

const ORBIS_NET_CTL_EVENT_TYPE_DISCONNECTED: int = 1

const ORBIS_SCE_NET_CTL_EVENT_TYPE_DISCONNECT_REQ_FINISHED: int = 2

const ORBIS_NET_CTL_EVENT_TYPE_IPOBTAINED: int = 3

const ORBIS_NET_CTL_DEVICE_WIRED: int = 0

const ORBIS_NET_CTL_DEVICE_WIRELESS: int = 1

const ORBIS_NET_CTL_LINK_DISCONNECTED: int = 0

const ORBIS_NET_CTL_LINK_CONNECTED: int = 1

@link_name(NetElisa_netctl_get_info)
@c_abi(c)
extern c_netctl_get_info(code: int, info: u8&?) -> int

@link_name(NetElisa_netctl_get_state)
@c_abi(c)
extern c_netctl_get_state(state: mutable int&?) -> int

enum LogLevel:
    Trace
    Debug
    Info
    Warning
    Error
    Critical
    Off

struct Logger:
    name: mutable static u8&
    level: mutable LogLevel

global mutable g_should_append: bool = false

global mutable ALL_LOGGERS: darray[Logger]

@c_abi(c)
extern spdlog_setup(log_filename: static u8&, append: bool) -> void

@c_abi(c)
extern spdlog_shutdown() -> void

@c_abi(c)
extern spdlog_flush_all() -> void

@c_abi(c)
extern spdlog_drop_all() -> void

@c_abi(c)
extern spdlog_log(logger_name: static u8&, level: LogLevel, message: static u8&) -> void

def Log_to_string_view(level: LogLevel) -> static u8&:
    match level:
        LogLevel.Trace:
            return "Trace"
        LogLevel.Debug:
            return "Debug"
        LogLevel.Info:
            return "Info"
        LogLevel.Warning:
            return "Warning"
        LogLevel.Error:
            return "Error"
        LogLevel.Critical:
            return "Critical"
        LogLevel.Off:
            return "Off"

def Setup(log_filename: static u8&) -> void:
    spdlog_setup(log_filename, g_should_append)

def Shutdown() -> void:
    spdlog_shutdown()

def Flush() -> void:
    spdlog_flush_all()

def Terminate() -> void:
    spdlog_drop_all()

def LOG_GENERIC(log_class: static u8&, log_level: LogLevel, message: static u8&) -> void:
    spdlog_log(log_class, log_level, message)

const ORBIS_NETCTL_MAX_CALLBACKS: usize = 8

type OrbisNetCtlCallbackFunc = func(int, u8&?) -> void

struct OrbisNetCtlCallbackState:
    in_use: mutable bool
    callback_func: mutable OrbisNetCtlCallbackFunc
    callback_arg: mutable u8&?

struct OrbisNetCtlInfo:
    device: mutable u32
    ether_addr: mutable array[u8, 6]
    mtu: mutable u32
    link: mutable u32
    ip_config: mutable u32
    ip_address: mutable array[u8, 16]
    netmask: mutable array[u8, 16]
    default_route: mutable array[u8, 16]
    primary_dns: mutable array[u8, 16]
    secondary_dns: mutable array[u8, 16]
    http_proxy_config: mutable u32
    http_proxy_server: mutable array[u8, 256]
    http_proxy_port: mutable u16

global mutable g_netctl_initialized: bool = false

global mutable g_netctl_state: i32 = ORBIS_NET_CTL_STATE_DISCONNECTED

global mutable g_netctl_callbacks: array[OrbisNetCtlCallbackState, ORBIS_NETCTL_MAX_CALLBACKS] = zeroed

global mutable g_netctl_nptool_callbacks: array[OrbisNetCtlCallbackState, ORBIS_NETCTL_MAX_CALLBACKS] = zeroed

const ORBIS_NET_CTL_INFO_DEVICE: int = 1

const ORBIS_NET_CTL_INFO_ETHER_ADDR: int = 2

const ORBIS_NET_CTL_INFO_MTU: int = 3

const ORBIS_NET_CTL_INFO_LINK: int = 4

const ORBIS_NET_CTL_INFO_IP_CONFIG: int = 11

const ORBIS_NET_CTL_INFO_IP_ADDRESS: int = 14

const ORBIS_NET_CTL_INFO_NETMASK: int = 15

const ORBIS_NET_CTL_INFO_DEFAULT_ROUTE: int = 16

const ORBIS_NET_CTL_INFO_PRIMARY_DNS: int = 17

const ORBIS_NET_CTL_INFO_SECONDARY_DNS: int = 18

const ORBIS_NET_CTL_INFO_HTTP_PROXY_CONFIG: int = 19

const ORBIS_NET_CTL_INFO_HTTP_PROXY_SERVER: int = 20

const ORBIS_NET_CTL_INFO_HTTP_PROXY_PORT: int = 21

def _NetCtl_NullCallback(event_type: int, arg: u8&?) -> void:
    _ = event_type
    _ = arg

def _NetCtl_ResetCallbacks() -> void:
    i: usize = 0
    while (i < ORBIS_NETCTL_MAX_CALLBACKS):
        g_netctl_callbacks[i].in_use <- false
        g_netctl_callbacks[i].callback_func <- _NetCtl_NullCallback
        g_netctl_callbacks[i].callback_arg <- null
        g_netctl_nptool_callbacks[i].in_use <- false
        g_netctl_nptool_callbacks[i].callback_func <- _NetCtl_NullCallback
        g_netctl_nptool_callbacks[i].callback_arg <- null
        i += 1

def _NetCtl_CurrentEventType() -> int:
    state: mutable int = ORBIS_NET_CTL_STATE_DISCONNECTED
    if ((c_netctl_get_state(state) == ORBIS_OK) and (state == ORBIS_NET_CTL_STATE_IPOBTAINED)):
        return ORBIS_NET_CTL_EVENT_TYPE_IPOBTAINED
    return ORBIS_NET_CTL_EVENT_TYPE_DISCONNECTED

def _NetCtl_CopyBytes(dst: mutable u8&, src: mutable u8&, count: usize) -> void:
    i: usize = 0
    while (i < count):
        ((dst + i)) <- ((src + i))
        i += 1

def _NetCtl_CopyInfoPayload(code: int, info: mutable OrbisNetCtlInfo&, payload: mutable u8&) -> void:
    if (code == ORBIS_NET_CTL_INFO_DEVICE):
        info.device <- payload.cast[mutable u32&]
    else:
        if (code == ORBIS_NET_CTL_INFO_ETHER_ADDR):
            _NetCtl_CopyBytes(info.ether_addr[0].ref[mutable u8&], payload, 6)
        else:
            if (code == ORBIS_NET_CTL_INFO_MTU):
                info.mtu <- payload.cast[mutable u32&]
            else:
                if (code == ORBIS_NET_CTL_INFO_LINK):
                    info.link <- payload.cast[mutable u32&]
                else:
                    if (code == ORBIS_NET_CTL_INFO_IP_CONFIG):
                        info.ip_config <- payload.cast[mutable u32&]
                    else:
                        if (code == ORBIS_NET_CTL_INFO_IP_ADDRESS):
                            _NetCtl_CopyBytes(info.ip_address[0].ref[mutable u8&], payload, 16)
                        else:
                            if (code == ORBIS_NET_CTL_INFO_NETMASK):
                                _NetCtl_CopyBytes(info.netmask[0].ref[mutable u8&], payload, 16)
                            else:
                                if (code == ORBIS_NET_CTL_INFO_DEFAULT_ROUTE):
                                    _NetCtl_CopyBytes(info.default_route[0].ref[mutable u8&], payload, 16)
                                else:
                                    if (code == ORBIS_NET_CTL_INFO_PRIMARY_DNS):
                                        _NetCtl_CopyBytes(info.primary_dns[0].ref[mutable u8&], payload, 16)
                                    else:
                                        if (code == ORBIS_NET_CTL_INFO_SECONDARY_DNS):
                                            _NetCtl_CopyBytes(info.secondary_dns[0].ref[mutable u8&], payload, 16)
                                        else:
                                            if (code == ORBIS_NET_CTL_INFO_HTTP_PROXY_CONFIG):
                                                info.http_proxy_config <- payload.cast[mutable u32&]
                                            else:
                                                if (code == ORBIS_NET_CTL_INFO_HTTP_PROXY_SERVER):
                                                    _NetCtl_CopyBytes(info.http_proxy_server[0].ref[mutable u8&], payload, 256)
                                                else:
                                                    if (code == ORBIS_NET_CTL_INFO_HTTP_PROXY_PORT):
                                                        info.http_proxy_port <- payload.cast[mutable u16&]

