def sceNetCtlGetInfo(code: int, info: mutable OrbisNetCtlInfo&?) -> int:
    if (info == null):
        return ORBIS_NET_CTL_ERROR_INVALID_ADDR
    if (code == ORBIS_NET_CTL_INFO_DEVICE):
        info.device <- ORBIS_NET_CTL_DEVICE_WIRED.u32()
    else:
        if (code == ORBIS_NET_CTL_INFO_ETHER_ADDR):
            info.ether_addr[0] <- 0
            info.ether_addr[1] <- 0
            info.ether_addr[2] <- 0
            info.ether_addr[3] <- 0
            info.ether_addr[4] <- 0
            info.ether_addr[5] <- 0
        else:
            if (code == ORBIS_NET_CTL_INFO_MTU):
                info.mtu <- 1500
            else:
                if (code == ORBIS_NET_CTL_INFO_LINK):
                    if (g_netctl_state == ORBIS_NET_CTL_STATE_IPOBTAINED):
                        info.link <- ORBIS_NET_CTL_LINK_CONNECTED.u32()
                    else:
                        info.link <- ORBIS_NET_CTL_LINK_DISCONNECTED.u32()
                else:
                    if (code == ORBIS_NET_CTL_INFO_IP_ADDRESS):
                        info.ip_address[0] <- '1'.u8()
                        info.ip_address[1] <- '2'.u8()
                        info.ip_address[2] <- '7'.u8()
                        info.ip_address[3] <- '.'.u8()
                        info.ip_address[4] <- '0'.u8()
                        info.ip_address[5] <- '.'.u8()
                        info.ip_address[6] <- '0'.u8()
                        info.ip_address[7] <- '.'.u8()
                        info.ip_address[8] <- '1'.u8()
                        info.ip_address[9] <- 0
                    else:
                        if (code == ORBIS_NET_CTL_INFO_NETMASK):
                            info.netmask[0] <- 0
                        else:
                            if (code == ORBIS_NET_CTL_INFO_DEFAULT_ROUTE):
                                info.default_route[0] <- 0
                            else:
                                if (code == ORBIS_NET_CTL_INFO_PRIMARY_DNS):
                                    info.primary_dns[0] <- '1'.u8()
                                    info.primary_dns[1] <- '.'.u8()
                                    info.primary_dns[2] <- '1'.u8()
                                    info.primary_dns[3] <- '.'.u8()
                                    info.primary_dns[4] <- '1'.u8()
                                    info.primary_dns[5] <- '.'.u8()
                                    info.primary_dns[6] <- '1'.u8()
                                    info.primary_dns[7] <- 0
                                else:
                                    if (code == ORBIS_NET_CTL_INFO_SECONDARY_DNS):
                                        info.secondary_dns <- info.primary_dns
                                    else:
                                        if (code == ORBIS_NET_CTL_INFO_HTTP_PROXY_CONFIG):
                                            info.http_proxy_config <- 0
                                        else:
                                            if (code == ORBIS_NET_CTL_INFO_HTTP_PROXY_SERVER):
                                                info.http_proxy_server[0] <- 0
                                            else:
                                                if (code == ORBIS_NET_CTL_INFO_HTTP_PROXY_PORT):
                                                    info.http_proxy_port <- 0
                                                else:
                                                    if (code == ORBIS_NET_CTL_INFO_IP_CONFIG):
                                                        info.ip_config <- 1
                                                    else:
                                                        LOG_ERROR("Lib_NetCtl", "unsupported getinfo code")
    return ORBIS_OK

