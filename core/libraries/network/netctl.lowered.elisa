# @port core/libraries/network/netctl.cpp::sceNetCtlCheckCallback sha256=172baf771aa38a8a oracle@a3773841
def sceNetCtlCheckCallback() -> int:
    event_type: int = _NetCtl_CurrentEventType()
    i: usize = 0
    while (i < ORBIS_NETCTL_MAX_CALLBACKS):
        slot: mutable OrbisNetCtlCallbackState& = g_netctl_callbacks[i].ref[mutable OrbisNetCtlCallbackState&]
        if slot.in_use:
            slot.callback_func(event_type, slot.callback_arg)
        i += 1
    return ORBIS_OK

