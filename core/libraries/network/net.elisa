def sceNetEpollControl(epollid: i64, op: int, id: i64, event: u8&?) -> int:
    epoll_index: int = sceNet_FindEpoll(epollid)
    if epoll_index < 0:
        sceNet_SetErr(ORBIS_NET_ERROR_EBADF)
        return ORBIS_NET_ERROR_EBADF

    resolver_index: int = sceNet_FindResolver(id)
    if resolver_index >= 0:
        watch_index: int = sceNet_EpollFindWatch(epoll_index, id)
        if op == ORBIS_NET_EPOLL_CTL_ADD:
            if event == null:
                sceNet_SetErr(ORBIS_NET_ERROR_EINVAL)
                return ORBIS_NET_ERROR_EINVAL
            if watch_index >= 0:
                sceNet_SetErr(ORBIS_NET_ERROR_EEXIST)
                return ORBIS_NET_ERROR_EEXIST
            watch_index <- sceNet_EpollFindFreeWatch(epoll_index)
            if watch_index < 0:
                sceNet_SetErr(ORBIS_NET_ERROR_ENOSPC)
                return ORBIS_NET_ERROR_ENOSPC
            requested: mutable OrbisNetEpollEventWire& = event.cast[mutable OrbisNetEpollEventWire&]
            watch: mutable OrbisNetEpollWatch& = g_net_epolls[epoll_index.usize()].watches[watch_index.usize()].ref[mutable OrbisNetEpollWatch&]
            watch.in_use <- true
            watch.id <- id
            watch.event_mask <- requested.events
            watch.event_data_u64 <- requested.data_u64
            watch.is_resolver <- true
            sceNet_EpollQueueResolver(epoll_index, id)
            sceNet_SetErr(ORBIS_OK)
            return ORBIS_OK
        if op == ORBIS_NET_EPOLL_CTL_MOD:
            if event == null:
                sceNet_SetErr(ORBIS_NET_ERROR_EINVAL)
                return ORBIS_NET_ERROR_EINVAL
            if watch_index < 0:
                sceNet_SetErr(ORBIS_NET_ERROR_EBADF)
                return ORBIS_NET_ERROR_EBADF
            sceNet_SetErr(ORBIS_OK)
            return ORBIS_OK
        if op == ORBIS_NET_EPOLL_CTL_DEL:
            if event != null:
                sceNet_SetErr(ORBIS_NET_ERROR_EINVAL)
                return ORBIS_NET_ERROR_EINVAL
            if watch_index < 0:
                sceNet_SetErr(ORBIS_NET_ERROR_EBADF)
                return ORBIS_NET_ERROR_EBADF
            sceNet_EpollDequeueResolver(epoll_index, id)
            g_net_epolls[epoll_index.usize()].watches[watch_index.usize()] <- zeroed
            sceNet_SetErr(ORBIS_OK)
            return ORBIS_OK
        sceNet_SetErr(ORBIS_NET_ERROR_EINVAL)
        return ORBIS_NET_ERROR_EINVAL

    bridge_epollid: int = g_net_epolls[epoll_index.usize()].bridge_epollid
    result: int = c_epoll_control(bridge_epollid, op, id.int(), event)
    if result == ORBIS_OK:
        sceNet_SetErr(ORBIS_OK)
    else:
        sceNet_SetErr(result)
    return result

def sceNetEpollCreate(name: u8&?, flags: int) -> int:
    if flags != 0:
        sceNet_SetErr(ORBIS_NET_ERROR_EINVAL)
        return ORBIS_NET_ERROR_EINVAL
    bridge_epollid: int = c_epoll_create(name, flags)
    if bridge_epollid < 0:
        return bridge_epollid
    epoll_index: usize = 0
    while epoll_index < ORBIS_NET_MAX_EPOLLS:
        ep: mutable OrbisNetEpollState& = g_net_epolls[epoll_index].ref[mutable OrbisNetEpollState&]
        if not ep.in_use:
            ep.in_use <- true
            ep.handle <- bridge_epollid.i64()
            ep.bridge_epollid <- bridge_epollid
            ep.resolver_queue_count <- 0
            sceNet_SetErr(ORBIS_OK)
            return ep.handle.int()
        epoll_index += 1
    _ = c_epoll_destroy(bridge_epollid)
    sceNet_SetErr(ORBIS_NET_ERROR_ENOSPC)
    return ORBIS_NET_ERROR_ENOSPC

def sceNetEpollDestroy(epollid: i64) -> int:
    epoll_index: int = sceNet_FindEpoll(epollid)
    if epoll_index < 0:
        sceNet_SetErr(ORBIS_NET_ERROR_EBADF)
        return ORBIS_NET_ERROR_EBADF
    bridge_epollid: int = g_net_epolls[epoll_index.usize()].bridge_epollid
    result: int = c_epoll_destroy(bridge_epollid)
    if result != ORBIS_OK:
        sceNet_SetErr(result)
        return result
    g_net_epolls[epoll_index.usize()] <- zeroed
    sceNet_SetErr(ORBIS_OK)
    return ORBIS_OK

def sceNetEpollWait(epollid: i64, events: u8&?, maxevents: int, timeout: int) -> int:
    epoll_index: int = sceNet_FindEpoll(epollid)
    if epoll_index < 0:
        sceNet_SetErr(ORBIS_NET_ERROR_EBADF)
        return ORBIS_NET_ERROR_EBADF

    result: int = c_epoll_wait(g_net_epolls[epoll_index.usize()].bridge_epollid, events, maxevents, timeout)
    if result < 0:
        sceNet_SetErr(result)
        return result

    emitted: int = result
    ep: mutable OrbisNetEpollState& = g_net_epolls[epoll_index.usize()].ref[mutable OrbisNetEpollState&]
    while ep.resolver_queue_count > 0 and emitted < maxevents:
        rid: i64 = ep.resolver_queue[0]
        shift_index: int = 0
        while shift_index + 1 < ep.resolver_queue_count:
            ep.resolver_queue[shift_index.usize()] <- ep.resolver_queue[(shift_index + 1).usize()]
            shift_index += 1
        ep.resolver_queue_count <- ep.resolver_queue_count - 1

        resolver_index: int = sceNet_FindResolver(rid)
        if resolver_index < 0:
            continue
        sceNet_ResolveQueuedResolver(resolver_index)
        resolver: mutable OrbisNetResolverState& = g_net_resolvers[resolver_index.usize()].ref[mutable OrbisNetResolverState&]
        if resolver.resolution_error != ORBIS_OK:
            continue
        watch_index: int = sceNet_EpollFindWatch(epoll_index, rid)
        if watch_index < 0:
            continue
        watch: mutable OrbisNetEpollWatch& = ep.watches[watch_index.usize()].ref[mutable OrbisNetEpollWatch&]
        sceNet_EpollWriteEvent(events, emitted, ORBIS_NET_EPOLLDESCID, rid, watch.event_data_u64)
        emitted <- emitted + 1
    sceNet_SetErr(ORBIS_OK)
    return emitted

