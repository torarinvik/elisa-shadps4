        if ep.resolver_queue[i.usize()] == rid:
            return
        i += 1
    ep.resolver_queue[ep.resolver_queue_count.usize()] <- rid
    ep.resolver_queue_count <- ep.resolver_queue_count + 1

def sceNet_EpollDequeueResolver(epoll_index: int, rid: i64) -> void:
    ep: mutable OrbisNetEpollState& = g_net_epolls[epoll_index.usize()].ref[mutable OrbisNetEpollState&]
    i: mutable int = 0
    while i < ep.resolver_queue_count:
        if ep.resolver_queue[i.usize()] == rid:
            shift_index: int = i
