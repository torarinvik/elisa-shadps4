def sceNet_EpollQueueResolver(epoll_index: int, rid: i64) -> void:
    ep: mutable OrbisNetEpollState& = g_net_epolls[epoll_index.usize()].ref[mutable OrbisNetEpollState&]
    if ep.resolver_queue_count >= ORBIS_NET_MAX_EPOLL_WATCHES.int():
        return
