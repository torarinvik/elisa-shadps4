def sceNetRecv(s: i64, buf: u8&?, len: u64, flags: int) -> int:
    err: int = sceNet_RequireInit()
    if err != ORBIS_OK:
        return err
    idx: int = sceNet_FindSocket(s)
    if idx < 0:
        sceNet_SetErr(ORBIS_NET_ERROR_ENOTSOCK)
        return ORBIS_NET_ERROR_ENOTSOCK
    if sceNet_IsP2PSocket(idx):
        sceNet_SetErr(ORBIS_NET_ERROR_EAGAIN)
        return ORBIS_NET_ERROR_EAGAIN
    result: isize = c_recvfrom(s.int(), buf, len.usize(), flags | ORBIS_NET_RECV_FLAGS, null, null)
    return sceNet_FfiSizeResult(result, ORBIS_NET_ERROR_EAGAIN)

def sceNetRecvfrom(s: i64, buf: u8&?, len: u64, flags: int, addr: u8&?, paddrlen: u32&?) -> int:
    err: int = sceNet_RequireInit()
    if err != ORBIS_OK:
        return err
    idx: int = sceNet_FindSocket(s)
    if idx < 0:
        sceNet_SetErr(ORBIS_NET_ERROR_ENOTSOCK)
        return ORBIS_NET_ERROR_ENOTSOCK
    if sceNet_IsP2PSocket(idx):
        sceNet_SetErr(ORBIS_NET_ERROR_EAGAIN)
        return ORBIS_NET_ERROR_EAGAIN
    result: isize = c_recvfrom(s.int(), buf, len.usize(), flags | ORBIS_NET_RECV_FLAGS, addr, paddrlen)
    return sceNet_FfiSizeResult(result, ORBIS_NET_ERROR_EAGAIN)

def sceNetRecvmsg(s: i64, msg: u8&?, flags: int) -> int:
    err: int = sceNet_RequireInit()
    if err != ORBIS_OK:
