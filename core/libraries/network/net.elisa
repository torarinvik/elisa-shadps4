def sceNetAccept(s: i64, addr: u8&?, paddrlen: u8&?) -> int:
    err: int = sceNet_RequireInit()
    if err != ORBIS_OK:
        return err
    idx: int = sceNet_FindSocket(s)
    if idx < 0:
        sceNet_SetErr(ORBIS_NET_ERROR_ENOTSOCK)
        return ORBIS_NET_ERROR_ENOTSOCK
    listener: mutable OrbisNetSocketState& = g_net_sockets[idx.usize()].ref[mutable OrbisNetSocketState&]
    if not listener.listening:
        sceNet_SetErr(ORBIS_NET_ERROR_ENOTCONN)
        return ORBIS_NET_ERROR_ENOTCONN
    client_idx: int = -1
    i: usize = 0
    while i < ORBIS_NET_MAX_SOCKETS:
        candidate: mutable OrbisNetSocketState& = g_net_sockets[i].ref[mutable OrbisNetSocketState&]
        if not candidate.in_use:
            candidate.in_use <- true
            candidate.handle <- g_net_next_socket_handle
            g_net_next_socket_handle <- g_net_next_socket_handle + 1
            candidate.connected <- true
            client_idx <- i.int()
            break
        i += 1
    if client_idx < 0:
        sceNet_SetErr(ORBIS_NET_ERROR_ENFILE)
        return ORBIS_NET_ERROR_ENFILE
    if paddrlen != null:
        paddrlen <- 0
    _ = addr
    client: mutable OrbisNetSocketState& = g_net_sockets[client_idx.usize()].ref[mutable OrbisNetSocketState&]
    sceNet_SetErr(ORBIS_OK)
    return client.handle.int()

