def sceNetResolverStartNtoa(resolverid: i64, hostname: u8&?, addr: u8&?, timeout: int, retry: int, flags: int) -> int:
    resolver_index: int = sceNet_FindResolver(resolverid)
    if resolver_index < 0:
        sceNet_SetErr(ORBIS_NET_ERROR_EBADF)
        return ORBIS_NET_ERROR_EBADF

    resolver: mutable OrbisNetResolverState& = g_net_resolvers[resolver_index.usize()].ref[mutable OrbisNetResolverState&]
    if c_is_connected_to_network() == 0:
        resolver.resolution_error <- ORBIS_NET_ERROR_RESOLVER_ENODNS
        sceNet_SetErr(ORBIS_NET_RESOLVER_ENODNS)
        return ORBIS_NET_ERROR_RESOLVER_ENODNS

    if (flags & ORBIS_NET_RESOLVER_ASYNC) != 0:
        if resolver.pending:
            sceNet_SetErr(ORBIS_NET_ERROR_RESOLVER_EBUSY)
            return ORBIS_NET_ERROR_RESOLVER_EBUSY
        resolver.pending <- true
        resolver.pending_hostname <- hostname
        resolver.pending_addr <- addr
        resolver.pending_timeout <- timeout
        resolver.pending_retry <- retry
        resolver.pending_flags <- flags
        resolver.resolution_error <- ORBIS_OK
        sceNet_SetErr(ORBIS_OK)
        return ORBIS_OK

    ret: int = sceNet_ResolveHostname(hostname, addr)
    if ret != ORBIS_OK:
        sceNet_SetErr(ret)
        return (0 - ret) | ORBIS_NET_ERROR_BASE
    sceNet_SetErr(ORBIS_OK)
    return ORBIS_OK

def sceNetResolverStartNtoa6() -> int:
    LOG_ERROR("Lib_Net", "(STUBBED) called")
    return ORBIS_OK

def sceNetResolverStartNtoaMultipleRecords(resolverid: i64, hostname: u8&?, info: u8&?, timeout: int, retry: int, flags: int) -> int:
    addr: mutable u32 = 0u32
    result: int = sceNetResolverStartNtoa(resolverid, hostname, addr.ref[mutable u32&].cast[mutable u8&], timeout, retry, flags)
    if result == ORBIS_OK and info != null:
        info.cast[mutable u32&] <- addr
        af_ptr: mutable u8& = info + 16
        af_ptr.cast[mutable u32&] <- ORBIS_NET_AF_INET.u32()
        records_ptr: mutable u8& = info + 320
        records_ptr.cast[mutable u32&] <- 1u32
        recordsv4_ptr: mutable u8& = info + 324
        recordsv4_ptr.cast[mutable u32&] <- 1u32
    return result

