def sceNetHtonl(host32: u32) -> u32:
    b0: u32 = (host32 & 0xff) << 24
    b1: u32 = (host32 & 0xff00) << 8
    b2: u32 = (host32 >> 8) & 0xff00
    b3: u32 = (host32 >> 24) & 0xff
    return b0 | b1 | b2 | b3

def sceNetHtonll(host64: u64) -> u64:
    lo: u64 = sceNetHtonl((host64 & 0xffffffffu64).u32()).u64()
    hi: u64 = sceNetHtonl((host64 >> 32).u32()).u64()
    return (lo << 32) | hi

def sceNetHtons(host16: u16) -> u16:
    return ((host16 & 0xff) << 8) | ((host16 >> 8) & 0xff)

def sceNetInetNtop(af: int, src: u8&?, dst: u8&?, size: u32) -> u8&?:
    if src == null or dst == null:
        sceNet_SetErr(ORBIS_NET_ENOSPC)
        return null
    native_af: int = 0
    if af == ORBIS_NET_AF_INET:
        native_af <- NATIVE_AF_INET
    elif af == ORBIS_NET_AF_INET6:
        native_af <- NATIVE_AF_INET6
    else:
        sceNet_SetErr(ORBIS_NET_EAFNOSUPPORT)
        return null
    result: u8&? = c_inet_ntop(native_af, src, dst, size)
    if result == null:
        sceNet_SetErr(ORBIS_NET_ENOSPC)
    else:
        sceNet_SetErr(ORBIS_OK)
    return result

def sceNetInetNtopWithScopeId() -> int:
    LOG_ERROR("Lib_Net", "(STUBBED) called")
    return ORBIS_OK

def sceNetInetPton(af: int, src: u8&?, dst: u8&?) -> int:
    native_af: int = 0
    if af == ORBIS_NET_AF_INET:
        native_af <- NATIVE_AF_INET
    elif af == ORBIS_NET_AF_INET6:
        native_af <- NATIVE_AF_INET6
    else:
        sceNet_SetErr(ORBIS_NET_EAFNOSUPPORT)
        return -1
    result: int = c_inet_pton(native_af, src, dst)
    if result >= 0:
        sceNet_SetErr(ORBIS_OK)
    return result

def sceNetInetPtonEx(af: int, src: u8&?, dst: u8&?, flags: int) -> int:
    _ = flags
    return sceNetInetPton(af, src, dst)

