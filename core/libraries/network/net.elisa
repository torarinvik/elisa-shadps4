def sceNetHtonl(host32: u32) -> u32:
    return ((host32 & 0xff) << 24) | ((host32 & 0xff00) << 8) |
        ((host32 >> 8) & 0xff00) | ((host32 >> 24) & 0xff)

def sceNetHtonll(host64: u64) -> u64:
    return ((sceNetHtonl((host64 & 0xffffffffu64).u32()).u64()) << 32) |
        sceNetHtonl((host64 >> 32).u32()).u64()

def sceNetHtons(host16: u16) -> u16:
    return ((host16 & 0xff) << 8) | ((host16 >> 8) & 0xff)

