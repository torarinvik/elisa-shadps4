def sceNetResolverCreate(name: u8&?, poolid: int, flags: int) -> int:
    err: int = sceNet_RequireInit()
    if err != ORBIS_OK:
        return ORBIS_NET_ERROR_ENOTINIT
    if flags != 0:
        sceNet_SetErr(ORBIS_NET_ERROR_EINVAL)
        return ORBIS_NET_ERROR_EINVAL
    i: usize = 0
    while i < ORBIS_NET_MAX_RESOLVERS:
        slot: mutable OrbisNetResolverState& = g_net_resolvers[i].ref[mutable OrbisNetResolverState&]
        if not slot.in_use:
            slot.in_use <- true
            slot.handle <- g_net_next_resolver_handle
            slot.pool_id <- poolid
            slot.flags <- flags
            slot.last_error <- ORBIS_OK
            g_net_next_resolver_handle <- g_net_next_resolver_handle + 1
            sceNet_SetErr(ORBIS_OK)
            return slot.handle.int()
        i += 1
    sceNet_SetErr(ORBIS_NET_ERROR_RESOLVER_EBUSY)
    return -1

def sceNetResolverDestroy(resolverid: i64) -> int:
    err: int = sceNet_RequireInit()
    if err != ORBIS_OK:
        return err
    idx: int = sceNet_FindResolver(resolverid)
    if idx < 0:
        sceNet_SetErr(ORBIS_NET_ERROR_EBADF)
        return ORBIS_NET_ERROR_EBADF
    g_net_resolvers[idx.usize()] <- zeroed
    sceNet_SetErr(ORBIS_OK)
    return ORBIS_OK

def sceNetResolverGetError(resolverid: i64, status: mutable int&?) -> int:
    err: int = sceNet_RequireInit()
    if err != ORBIS_OK:
        return err
    if status == null:
        sceNet_SetErr(ORBIS_NET_ERROR_EINVAL)
        return ORBIS_NET_ERROR_EINVAL
    idx: int = sceNet_FindResolver(resolverid)
    if idx < 0:
        status <- ORBIS_NET_ERROR_EBADF
        sceNet_SetErr(ORBIS_NET_ERROR_EBADF)
        return ORBIS_NET_ERROR_EBADF
    i: usize = 0
    while i < ORBIS_NET_MAX_RESOLVERS:
        slot: mutable OrbisNetResolverState& = g_net_resolvers[i].ref[mutable OrbisNetResolverState&]
        if slot.in_use and slot.handle == resolverid:
            status <- slot.last_error
            return ORBIS_OK
        i += 1
    sceNet_SetErr(ORBIS_NET_ERROR_EBADF)
    return ORBIS_NET_ERROR_EBADF

