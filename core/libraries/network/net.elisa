def sceNetAccept(s: i64, addr: u8&?, paddrlen: u32&?) -> int:
    err: int = sceNet_RequireInit()
    if err != ORBIS_OK:
        return err
    idx: int = sceNet_FindSocket(s)
    if idx < 0:
        sceNet_SetErr(ORBIS_NET_ERROR_ENOTSOCK)
        return ORBIS_NET_ERROR_ENOTSOCK
    if sceNet_IsP2PSocket(idx):
        sceNet_SetErr(ORBIS_NET_ERROR_EAGAIN)
        return ORBIS_NET_ERROR_EAGAIN
    accepted_fd: int = c_accept(s.int(), addr, paddrlen)
    if accepted_fd < 0:
        return sceNet_FfiIntResult(accepted_fd, ORBIS_NET_ERROR_EBADF)
    client_idx: int = -1
    i: mutable usize = 0
    while i < ORBIS_NET_MAX_SOCKETS:
        candidate: mutable OrbisNetSocketState& = g_net_sockets[i].ref[mutable OrbisNetSocketState&]
        if not candidate.in_use:
            candidate.in_use <- true
            candidate.handle <- accepted_fd.i64()
            candidate.socket_type <- 0
            candidate.connected <- true
            client_idx <- i.int()
            break
        i += 1
    if client_idx < 0:
        _ = c_close(accepted_fd)
        sceNet_SetErr(ORBIS_NET_ERROR_ENFILE)
        return ORBIS_NET_ERROR_ENFILE
    sceNet_SetErr(ORBIS_OK)
    return accepted_fd

