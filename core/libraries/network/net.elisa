def sceNetResolverCreate(name: u8&?, poolid: int, flags: int) -> int:
    _ = name
    _ = poolid
    if flags != 0:
        sceNet_SetErr(ORBIS_NET_ERROR_EINVAL)
        return ORBIS_NET_ERROR_EINVAL
    resolver_index: usize = 0
    while resolver_index < ORBIS_NET_MAX_RESOLVERS:
        resolver: mutable OrbisNetResolverState& = g_net_resolvers[resolver_index].ref[mutable OrbisNetResolverState&]
        if not resolver.in_use:
            resolver.in_use <- true
            resolver.handle <- g_net_next_resolver_handle
            resolver.resolution_error <- ORBIS_OK
            resolver.pending <- false
            resolver.pending_hostname <- null
            resolver.pending_addr <- null
            resolver.pending_timeout <- 0
            resolver.pending_retry <- 0
            resolver.pending_flags <- 0
            g_net_next_resolver_handle <- g_net_next_resolver_handle + 1
            sceNet_SetErr(ORBIS_OK)
            return resolver.handle.int()
        resolver_index += 1
    sceNet_SetErr(ORBIS_NET_ERROR_ENOSPC)
    return ORBIS_NET_ERROR_ENOSPC

def sceNetResolverDestroy(resolverid: i64) -> int:
    resolver_index: int = sceNet_FindResolver(resolverid)
    if resolver_index < 0:
        sceNet_SetErr(ORBIS_NET_ERROR_EBADF)
        return ORBIS_NET_ERROR_EBADF
    sceNet_ResolverClearFromEpolls(resolverid)
    g_net_resolvers[resolver_index.usize()] <- zeroed
    sceNet_SetErr(ORBIS_OK)
    return ORBIS_OK

def sceNetResolverGetError(resolverid: i64, status: mutable int&?) -> int:
    if status == null:
        sceNet_SetErr(ORBIS_NET_ERROR_EINVAL)
        return ORBIS_NET_ERROR_EINVAL
    resolver_index: int = sceNet_FindResolver(resolverid)
    if resolver_index < 0:
        sceNet_SetErr(ORBIS_NET_ERROR_EBADF)
        return ORBIS_NET_ERROR_EBADF
    status <- g_net_resolvers[resolver_index.usize()].resolution_error
    sceNet_SetErr(ORBIS_OK)
    return ORBIS_OK

