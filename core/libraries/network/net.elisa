        return ORBIS_NET_ERROR_EBADF
    slot: mutable OrbisNetResolverState& = g_net_resolvers[idx.usize()].ref[mutable OrbisNetResolverState&]
    _ = hostname
    _ = addr
    _ = timeout
    _ = retry
    _ = flags
    if slot.last_error == ORBIS_OK:
        slot.last_error <- ORBIS_NET_RESOLVER_ENOHOST
    sceNet_SetErr(slot.last_error)
    return ORBIS_OK

