const ORBIS_NET_MAX_EPOLLS: usize = 32

const ORBIS_NET_MAX_EPOLL_WATCHES: usize = 64

const ORBIS_NET_RESOLVER_ASYNC: int = 1

const ORBIS_NET_EPOLL_CTL_ADD: int = 1

const ORBIS_NET_EPOLL_CTL_MOD: int = 2

const ORBIS_NET_EPOLL_CTL_DEL: int = 3

const ORBIS_NET_EPOLLIN: u32 = 0x1u32

const ORBIS_NET_EPOLLOUT: u32 = 0x2u32

const ORBIS_NET_EPOLLERR: u32 = 0x8u32

const ORBIS_NET_EPOLLHUP: u32 = 0x10u32

const ORBIS_NET_EPOLLDESCID: u32 = 0x10000u32

const ORBIS_NET_EPOLL_EVENT_SIZE: usize = 24

const ORBIS_NET_SEND_FLAGS: int = 0x40020000

const ORBIS_NET_RECV_FLAGS: int = 0x40000000

const ORBIS_NET_AF_UNIX: int = 1

const ORBIS_NET_AF_INET: int = 2

const ORBIS_NET_AF_INET6: int = 28

const ORBIS_NET_SOCK_DGRAM_P2P: int = 6

const ORBIS_NET_SOCK_STREAM_P2P: int = 10

const NATIVE_AF_INET: int = 2

const NATIVE_AF_INET6: int = 30

struct OrbisNetSocketState:
    in_use: mutable bool
    handle: mutable i64
    socket_type: mutable int
    connected: mutable bool
    listening: mutable bool
    shutdown_state: mutable int

struct OrbisNetResolverState:
    in_use: mutable bool
    handle: mutable i64
    resolution_error: mutable int
    pending: mutable bool
    pending_hostname: mutable u8&?
    pending_addr: mutable u8&?
    pending_timeout: mutable int
    pending_retry: mutable int
    pending_flags: mutable int

struct OrbisNetEpollWatch:
    in_use: mutable bool
    id: mutable i64
    event_mask: mutable u32
    event_data_u64: mutable u64
    is_resolver: mutable bool

struct OrbisNetEpollState:
    in_use: mutable bool
    handle: mutable i64
    bridge_epollid: mutable int
    resolver_queue_count: mutable int
    resolver_queue: mutable array[i64, ORBIS_NET_MAX_EPOLL_WATCHES]
    watches: mutable array[OrbisNetEpollWatch, ORBIS_NET_MAX_EPOLL_WATCHES]

struct OrbisNetEpollEventWire:
    events: mutable u32
    pad: mutable u32
    ident: mutable u64
    data_u64: mutable u64

global mutable g_net_initialized: bool = false

global mutable g_net_last_error: int = ORBIS_OK

global mutable g_net_next_socket_handle: i64 = 1

global mutable g_net_next_pool_handle: int = 1

global mutable g_net_next_resolver_handle: i64 = 0x10000

global mutable g_net_sockets: array[OrbisNetSocketState, ORBIS_NET_MAX_SOCKETS] = zeroed

global mutable g_net_resolvers: array[OrbisNetResolverState, ORBIS_NET_MAX_RESOLVERS] = zeroed

global mutable g_net_epolls: array[OrbisNetEpollState, ORBIS_NET_MAX_EPOLLS] = zeroed

global mutable g_net_active_resolver: i64 = 0

def sceNet_SetErr(err: int) -> void:
    g_net_last_error <- err

def sceNet_ResetState() -> void:
    idx: usize = 0
    while (idx < ORBIS_NET_MAX_SOCKETS):
        g_net_sockets[idx] <- zeroed
        idx += 1
    idx <- 0
    while (idx < ORBIS_NET_MAX_RESOLVERS):
        g_net_resolvers[idx] <- zeroed
        idx += 1
    idx <- 0
    while (idx < ORBIS_NET_MAX_EPOLLS):
        if g_net_epolls[idx].in_use:
            _ = c_epoll_destroy(g_net_epolls[idx].bridge_epollid)
        g_net_epolls[idx] <- zeroed
        idx += 1
    g_net_next_resolver_handle <- 0x10000
    g_net_active_resolver <- 0

def sceNet_FindSocket(handle: i64) -> int:
    idx: usize = 0
    while (idx < ORBIS_NET_MAX_SOCKETS):
        slot: mutable OrbisNetSocketState& = g_net_sockets[idx].ref[mutable OrbisNetSocketState&]
        if (slot.in_use and (slot.handle == handle)):
            return idx.int()
        idx += 1
    return (-1)

def sceNet_RequireInit() -> int:
    if (not g_net_initialized):
        sceNet_SetErr(ORBIS_NET_ERROR_ENOTINIT)
        return ORBIS_NET_ERROR_ENOTINIT
    return ORBIS_OK

def sceNet_FindResolver(handle: i64) -> int:
    idx: usize = 0
    while (idx < ORBIS_NET_MAX_RESOLVERS):
        slot: mutable OrbisNetResolverState& = g_net_resolvers[idx].ref[mutable OrbisNetResolverState&]
        if (slot.in_use and (slot.handle == handle)):
            return idx.int()
        idx += 1
    return (-1)

def sceNet_FindEpoll(handle: i64) -> int:
    idx: usize = 0
    while (idx < ORBIS_NET_MAX_EPOLLS):
        slot: mutable OrbisNetEpollState& = g_net_epolls[idx].ref[mutable OrbisNetEpollState&]
        if (slot.in_use and (slot.handle == handle)):
            return idx.int()
        idx += 1
    return (-1)

def sceNet_EpollFindWatch(epoll_index: int, id: i64) -> int:
    watch_index: usize = 0
    while (watch_index < ORBIS_NET_MAX_EPOLL_WATCHES):
        watch: mutable OrbisNetEpollWatch& = g_net_epolls[epoll_index.usize()].watches[watch_index].ref[mutable OrbisNetEpollWatch&]
        if (watch.in_use and (watch.id == id)):
            return watch_index.int()
        watch_index += 1
    return (-1)

def sceNet_EpollFindFreeWatch(epoll_index: int) -> int:
    watch_index: usize = 0
    while (watch_index < ORBIS_NET_MAX_EPOLL_WATCHES):
        watch: mutable OrbisNetEpollWatch& = g_net_epolls[epoll_index.usize()].watches[watch_index].ref[mutable OrbisNetEpollWatch&]
        if (not watch.in_use):
            return watch_index.int()
        watch_index += 1
    return (-1)

def sceNet_EpollQueueResolver(epoll_index: int, rid: i64) -> void:
    ep: mutable OrbisNetEpollState& = g_net_epolls[epoll_index.usize()].ref[mutable OrbisNetEpollState&]
    if (ep.resolver_queue_count >= ORBIS_NET_MAX_EPOLL_WATCHES.int()):
        return
    i: int = 0
    while (i < ep.resolver_queue_count):
        if (ep.resolver_queue[i.usize()] == rid):
            return
        i += 1
    ep.resolver_queue[ep.resolver_queue_count.usize()] <- rid
    ep.resolver_queue_count <- (ep.resolver_queue_count + 1)

def sceNet_EpollDequeueResolver(epoll_index: int, rid: i64) -> void:
    ep: mutable OrbisNetEpollState& = g_net_epolls[epoll_index.usize()].ref[mutable OrbisNetEpollState&]
    i: int = 0
    while (i < ep.resolver_queue_count):
        if (ep.resolver_queue[i.usize()] == rid):
            shift_index: int = i
            while ((shift_index + 1) < ep.resolver_queue_count):
                ep.resolver_queue[shift_index.usize()] <- ep.resolver_queue[((shift_index + 1)).usize()]
                shift_index += 1
            ep.resolver_queue_count <- (ep.resolver_queue_count - 1)
            return
        i += 1

def sceNet_ResolveHostname(hostname: u8&?, addr: u8&?) -> int:
    if ((hostname == null) or (addr == null)):
        return ORBIS_NET_ERETURN
    hints: mutable NativeAddrInfo = zeroed
    hints.ai_family <- NATIVE_AF_INET
    info: mutable void&? = null
    gai_result: int = c_getaddrinfo(hostname, null, hints.ref[mutable NativeAddrInfo&].cast[void&?], info.ref[mutable void&?&])
    if ((gai_result != 0) or (info == null)):
        return ORBIS_NET_ERETURN
    head: mutable NativeAddrInfo& = info.cast[mutable NativeAddrInfo&]
    if (head.ai_addr == null):
        c_freeaddrinfo(info)
        return ORBIS_NET_ERETURN
    native_addr: mutable NativeSockaddrIn& = head.ai_addr.cast[mutable NativeSockaddrIn&]
    addr.cast[mutable u32&] <- native_addr.sin_addr
    c_freeaddrinfo(info)
    return ORBIS_OK

def sceNet_ResolveQueuedResolver(resolver_index: int) -> void:
    resolver: mutable OrbisNetResolverState& = g_net_resolvers[resolver_index.usize()].ref[mutable OrbisNetResolverState&]
    if (c_is_connected_to_network() == 0):
        resolver.resolution_error <- ORBIS_NET_ERROR_RESOLVER_ENODNS
        resolver.pending <- false
        return
    if (not resolver.pending):
        return
    ret: int = sceNet_ResolveHostname(resolver.pending_hostname, resolver.pending_addr)
    resolver.resolution_error <- ret
    if (ret != ORBIS_OK):
        resolver.resolution_error <- (((0 - ret)) | ORBIS_NET_ERROR_BASE)
    resolver.pending <- false

def sceNet_EpollWriteEvent(events: u8&?, index: int, mask: u32, id: i64, data_u64: u64) -> void:
    if (events == null):
        return
    offset: usize = (index.usize() * ORBIS_NET_EPOLL_EVENT_SIZE)
    event_ptr: mutable u8& = (events + offset)
    out: mutable OrbisNetEpollEventWire& = event_ptr.cast[mutable OrbisNetEpollEventWire&]
    out.events <- mask
    out.pad <- 0u32
    out.ident <- id.u64()
    out.data_u64 <- data_u64

def sceNet_ResolverClearFromEpolls(resolver_handle: i64) -> void:
    epoll_index: usize = 0
    while (epoll_index < ORBIS_NET_MAX_EPOLLS):
        ep: mutable OrbisNetEpollState& = g_net_epolls[epoll_index].ref[mutable OrbisNetEpollState&]
        if ep.in_use:
            sceNet_EpollDequeueResolver(epoll_index.int(), resolver_handle)
            watch_index: usize = 0
            while (watch_index < ORBIS_NET_MAX_EPOLL_WATCHES):
                watch: mutable OrbisNetEpollWatch& = ep.watches[watch_index].ref[mutable OrbisNetEpollWatch&]
                if ((watch.in_use and (watch.id == resolver_handle)) and watch.is_resolver):
                    watch <- zeroed
                watch_index += 1
        epoll_index += 1

def sceNet_IsP2PSocket(socket_index: int) -> bool:
    if ((socket_index < 0) or (socket_index >= ORBIS_NET_MAX_SOCKETS.int())):
        return false
    slot: mutable OrbisNetSocketState& = g_net_sockets[socket_index.usize()].ref[mutable OrbisNetSocketState&]
    return ((slot.socket_type == ORBIS_NET_SOCK_DGRAM_P2P) or (slot.socket_type == ORBIS_NET_SOCK_STREAM_P2P))

def sceNet_FfiIntResult(result: int, fallback: int) -> int:
    if (result < 0):
        mapped: int = sceNet_MapNativeErrno(fallback)
        sceNet_SetErr(mapped)
        return mapped
    sceNet_SetErr(ORBIS_OK)
    return result

def sceNet_FfiSizeResult(result: isize, fallback: int) -> int:
    if (result < 0):
        mapped: int = sceNet_MapNativeErrno(fallback)
        sceNet_SetErr(mapped)
        return mapped
    sceNet_SetErr(ORBIS_OK)
    return result.int()

def sceNet_MapNativeErrno(fallback: int) -> int:
    err: int = c_net_errno()
    if (err < 0):
        err <- (-err)
    if (err == 0):
        return fallback
    if (err == ORBIS_NET_ENOTSOCK):
        err <- ORBIS_NET_EBADF
    else:
        if (err == ORBIS_NET_ENETINTR):
            err <- ORBIS_NET_EINTR
    if (err > 255):
        return fallback
    return (ORBIS_NET_ERROR_BASE | err)

