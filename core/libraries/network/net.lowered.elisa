def sceNetSend(s: i64, buf: u8&?, len: u64, flags: int) -> int:
    err: int = sceNet_RequireInit()
    if (err != ORBIS_OK):
        return err
    idx: int = sceNet_FindSocket(s)
    if (idx < 0):
        sceNet_SetErr(ORBIS_NET_ERROR_ENOTSOCK)
        return ORBIS_NET_ERROR_ENOTSOCK
    result: isize = c_sendto(s.int(), buf, len.usize(), (flags | ORBIS_NET_SEND_FLAGS), null, 0)
    return sceNet_FfiSizeResult(result, ORBIS_NET_ERROR_EPIPE)

def sceNetSendmsg(s: i64, msg: u8&?, flags: int) -> int:
    err: int = sceNet_RequireInit()
    if (err != ORBIS_OK):
        return err
    idx: int = sceNet_FindSocket(s)
    if (idx < 0):
        sceNet_SetErr(ORBIS_NET_ERROR_ENOTSOCK)
        return ORBIS_NET_ERROR_ENOTSOCK
    result: isize = c_sendmsg(s.int(), msg, (flags | ORBIS_NET_SEND_FLAGS))
    return sceNet_FfiSizeResult(result, ORBIS_NET_ERROR_EPIPE)

def sceNetSendto(s: i64, buf: u8&?, len: u64, flags: int, addr: u8&?, addrlen: int) -> int:
    err: int = sceNet_RequireInit()
    if (err != ORBIS_OK):
        return err
    idx: int = sceNet_FindSocket(s)
    if (idx < 0):
        sceNet_SetErr(ORBIS_NET_ERROR_ENOTSOCK)
        return ORBIS_NET_ERROR_ENOTSOCK
    result: isize = c_sendto(s.int(), buf, len.usize(), (flags | ORBIS_NET_SEND_FLAGS), addr, addrlen.u32())
    return sceNet_FfiSizeResult(result, ORBIS_NET_ERROR_EPIPE)

