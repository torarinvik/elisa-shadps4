def sceNetResolverStartNtoa(resolverid: i64, hostname: u8&?, addr: u8&?, timeout: int, retry: int, flags: int) -> int:
    idx: int = sceNet_FindResolver(resolverid)
    if (idx < 0):
        sceNet_SetErr(ORBIS_NET_ERROR_EBADF)
        return ORBIS_NET_ERROR_EBADF
    slot: mutable OrbisNetResolverState& = g_net_resolvers[idx.usize()].ref[mutable OrbisNetResolverState&]
    if (hostname == null):
        slot.last_error <- ORBIS_NET_ERROR_EINVAL
        sceNet_SetErr(ORBIS_NET_ERROR_EINVAL)
        return ORBIS_NET_ERROR_EINVAL
    native_result: mutable void&? = null
    lookup: int = c_getaddrinfo(hostname, null, null, native_result)
    if (lookup != 0):
        slot.last_error <- ORBIS_NET_ERROR_RESOLVER_ENOHOST
        sceNet_SetErr(ORBIS_NET_ERROR_RESOLVER_ENOHOST)
        return ORBIS_NET_ERROR_RESOLVER_ENOHOST
    if (native_result != null):
        info: mutable NativeAddrInfo& = native_result.cast[mutable NativeAddrInfo&]
        if ((addr != null) and (info.ai_addr != null)):
            sockaddr: mutable NativeSockaddrIn& = info.ai_addr.cast[mutable NativeSockaddrIn&]
            out: mutable u32& = addr.cast[mutable u32&]
            out <- sockaddr.sin_addr
        c_freeaddrinfo(native_result)
    slot.last_error <- ORBIS_OK
    _ = timeout
    _ = retry
    _ = flags
    sceNet_SetErr(ORBIS_OK)
    return ORBIS_OK

def sceNetResolverStartNtoa6() -> int:
