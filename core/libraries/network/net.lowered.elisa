def sceNetNtohll(net64: u64) -> u64:
    lo: u64 = sceNetNtohl(((net64 & 0xffffffffu64)).u32()).u64()
    hi: u64 = sceNetNtohl(((net64 >> 32)).u32()).u64()
    return (((lo << 32)) | hi)

