struct NativeAddrInfo layout c:
    ai_flags: mutable i32
    ai_family: mutable i32
    ai_socktype: mutable i32
    ai_protocol: mutable i32
    ai_addrlen: mutable u32
    ai_canonname: mutable u8&?
    ai_addr: mutable void&?
    ai_next: mutable void&?

@c_bind(netinet/in.h, struct sockaddr_in)
struct NativeSockaddrIn layout c:
    sin_len: mutable u8
    sin_family: mutable u8
    sin_port: mutable u16
    sin_addr: mutable u32
    sin_zero: mutable array[u8, 8]

enum LogLevel:
    Trace
    Debug
    Info
    Warning
    Error
    Critical
    Off

struct Logger:
    name: mutable static u8&
    level: mutable LogLevel

global mutable g_should_append: bool = false

global mutable ALL_LOGGERS: darray[Logger]

@c_abi(c)
extern spdlog_setup(log_filename: static u8&, append: bool) -> void

@c_abi(c)
extern spdlog_shutdown() -> void

@c_abi(c)
extern spdlog_flush_all() -> void

@c_abi(c)
extern spdlog_drop_all() -> void

@c_abi(c)
extern spdlog_log(logger_name: static u8&, level: LogLevel, message: static u8&) -> void

def Log_to_string_view(level: LogLevel) -> static u8&:
    match level:
        LogLevel.Trace:
            return "Trace"
        LogLevel.Debug:
            return "Debug"
        LogLevel.Info:
            return "Info"
        LogLevel.Warning:
            return "Warning"
        LogLevel.Error:
            return "Error"
        LogLevel.Critical:
            return "Critical"
        LogLevel.Off:
            return "Off"

def Setup(log_filename: static u8&) -> void:
    spdlog_setup(log_filename, g_should_append)

def Shutdown() -> void:
    spdlog_shutdown()

def Flush() -> void:
    spdlog_flush_all()

def Terminate() -> void:
    spdlog_drop_all()

def LOG_GENERIC(log_class: static u8&, log_level: LogLevel, message: static u8&) -> void:
    spdlog_log(log_class, log_level, message)

extern windows_format_message(error_code: int, buffer: mutable stack u8&, buffer_size: usize) -> bool

extern windows_get_last_error() -> int

extern gnu_strerror_r(error_code: int, buffer: mutable stack u8&, buffer_size: usize) -> static u8&

extern xsi_strerror_r(error_code: int, buffer: mutable stack u8&, buffer_size: usize) -> int

extern posix_errno() -> int

const USE_GNU_STRERROR_R = target.libc.gnu_strerror_r

def NativeErrorToString(e: int) -> static u8&:
    err_str: mutable u8[255]
    static if PLATFORM_WINDOWS:
        if (not windows_format_message(e, err_str[0].ref[mutable stack u8&], 255)):
            return "(FormatMessageA failed to format error)"
        return err_str[0].ref[static u8&]
    static elif USE_GNU_STRERROR_R:
        return gnu_strerror_r(e, err_str[0].ref[mutable stack u8&], 255)
    static else:
        second_err: int = xsi_strerror_r(e, err_str[0].ref[mutable stack u8&], 255)
        if (second_err != 0):
            return "(strerror_r failed to format error)"
        return err_str[0].ref[static u8&]

def GetLastErrorMsg() -> static u8&:
    static if PLATFORM_WINDOWS:
        return NativeErrorToString(windows_get_last_error())
    static else:
        return NativeErrorToString(posix_errno())

const ORBIS_NET_MAX_SOCKETS: usize = 64

const ORBIS_NET_MAX_RESOLVERS: usize = 16

const ORBIS_NET_RESOLVER_ASYNC: int = 1

const ORBIS_NET_SEND_FLAGS: int = 0x40020000

const ORBIS_NET_RECV_FLAGS: int = 0x40000000

const ORBIS_NET_AF_INET: int = 2

const ORBIS_NET_AF_INET6: int = 28

const NATIVE_AF_INET: int = 2

const NATIVE_AF_INET6: int = 30

struct OrbisNetSocketState:
    in_use: mutable bool
    handle: mutable i64
    connected: mutable bool
    listening: mutable bool
    shutdown_state: mutable int

struct OrbisNetResolverState:
    in_use: mutable bool
    handle: mutable i64
    pool_id: mutable int
    flags: mutable int
    last_error: mutable int

global mutable g_net_initialized: bool = false

global mutable g_net_last_error: int = ORBIS_OK

global mutable g_net_next_socket_handle: i64 = 1

global mutable g_net_next_resolver_handle: i64 = 1

global mutable g_net_next_pool_handle: int = 1

global mutable g_net_sockets: array[OrbisNetSocketState, ORBIS_NET_MAX_SOCKETS] = zeroed

global mutable g_net_resolvers: array[OrbisNetResolverState, ORBIS_NET_MAX_RESOLVERS] = zeroed

global mutable g_net_active_resolver: i64 = 0

def sceNet_SetErr(err: int) -> void:
    g_net_last_error <- err

def sceNet_ResetState() -> void:
    idx: usize = 0
    while (idx < ORBIS_NET_MAX_SOCKETS):
        g_net_sockets[idx] <- zeroed
        idx += 1
    idx = 0
    while (idx < ORBIS_NET_MAX_RESOLVERS):
        g_net_resolvers[idx] <- zeroed
        idx += 1
    g_net_active_resolver <- 0

def sceNet_FindSocket(handle: i64) -> int:
    idx: usize = 0
    while (idx < ORBIS_NET_MAX_SOCKETS):
        slot: mutable OrbisNetSocketState& = g_net_sockets[idx].ref[mutable OrbisNetSocketState&]
        if (slot.in_use and (slot.handle == handle)):
            return idx.int()
        idx += 1
    return (-1)

def sceNet_FindResolver(handle: i64) -> int:
    idx: usize = 0
    while (idx < ORBIS_NET_MAX_RESOLVERS):
        slot: mutable OrbisNetResolverState& = g_net_resolvers[idx].ref[mutable OrbisNetResolverState&]
        if (slot.in_use and (slot.handle == handle)):
            return idx.int()
        idx += 1
    return (-1)

def sceNet_RequireInit() -> int:
    if (not g_net_initialized):
        sceNet_SetErr(ORBIS_NET_ERROR_ENOTINIT)
        return ORBIS_NET_ERROR_ENOTINIT
    return ORBIS_OK

def sceNet_FfiIntResult(result: int, fallback: int) -> int:
    if (result < 0):
        mapped: int = sceNet_MapNativeErrno(fallback)
        sceNet_SetErr(mapped)
        return mapped
    sceNet_SetErr(ORBIS_OK)
    return result

def sceNet_FfiSizeResult(result: isize, fallback: int) -> int:
    if (result < 0):
        mapped: int = sceNet_MapNativeErrno(fallback)
        sceNet_SetErr(mapped)
        return mapped
    sceNet_SetErr(ORBIS_OK)
    return result.int()

def sceNet_MapNativeErrno(fallback: int) -> int:
    err: int = posix_errno()
    if (err < 0):
        err <- (-err)
    if (err == 0):
        return fallback
    if (err > 255):
        return fallback
    return (ORBIS_NET_ERROR_BASE | err)

