def sceNetGetMacAddress(addr: mutable u8&?, flags: int) -> int:
    if (addr == null):
        return ORBIS_NET_EINVAL
    out: mutable u8& = addr.cast[mutable u8&]
    out <- 0x02u8
    ((out + 1usize)) <- 0x00u8
    ((out + 2usize)) <- 0x00u8
    ((out + 3usize)) <- 0x00u8
    ((out + 4usize)) <- 0x00u8
    ((out + 5usize)) <- 0x01u8
    _ = flags
    return ORBIS_OK

