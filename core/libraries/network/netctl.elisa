def _NetCtl_NullCallback(event_type: int, arg: u8&?) -> void:
    _ = event_type
    _ = arg

def _NetCtl_ResetCallbacks() -> void:
    i: usize = 0
    while i < ORBIS_NETCTL_MAX_CALLBACKS:
        g_netctl_callbacks[i].in_use <- false
        g_netctl_callbacks[i].callback_func <- _NetCtl_NullCallback
        g_netctl_callbacks[i].callback_arg <- null
        g_netctl_nptool_callbacks[i].in_use <- false
        g_netctl_nptool_callbacks[i].callback_func <- _NetCtl_NullCallback
        g_netctl_nptool_callbacks[i].callback_arg <- null
        i += 1

def _NetCtl_CurrentEventType() -> int:
    state: mutable int = ORBIS_NET_CTL_STATE_DISCONNECTED
    if c_netctl_get_state(state) == ORBIS_OK and state == ORBIS_NET_CTL_STATE_IPOBTAINED:
        return ORBIS_NET_CTL_EVENT_TYPE_IPOBTAINED
    return ORBIS_NET_CTL_EVENT_TYPE_DISCONNECTED

def _NetCtl_CopyBytes(dst: mutable u8&, src: mutable u8&, count: usize) -> void:
    i: usize = 0
    while i < count:
        (dst + i) <- (src + i)
        i += 1

def _NetCtl_CopyInfoPayload(code: int, info: mutable OrbisNetCtlInfo&, payload: mutable u8&) -> void:
    if code == ORBIS_NET_CTL_INFO_DEVICE:
        info.device <- payload.cast[mutable u32&]
    elif code == ORBIS_NET_CTL_INFO_ETHER_ADDR:
        _NetCtl_CopyBytes(info.ether_addr[0].ref[mutable u8&], payload, 6usize)
    elif code == ORBIS_NET_CTL_INFO_MTU:
        info.mtu <- payload.cast[mutable u32&]
    elif code == ORBIS_NET_CTL_INFO_LINK:
        info.link <- payload.cast[mutable u32&]
    elif code == ORBIS_NET_CTL_INFO_IP_CONFIG:
        info.ip_config <- payload.cast[mutable u32&]
    elif code == ORBIS_NET_CTL_INFO_IP_ADDRESS:
        _NetCtl_CopyBytes(info.ip_address[0].ref[mutable u8&], payload, 16usize)
    elif code == ORBIS_NET_CTL_INFO_NETMASK:
        _NetCtl_CopyBytes(info.netmask[0].ref[mutable u8&], payload, 16usize)
    elif code == ORBIS_NET_CTL_INFO_DEFAULT_ROUTE:
        _NetCtl_CopyBytes(info.default_route[0].ref[mutable u8&], payload, 16usize)
    elif code == ORBIS_NET_CTL_INFO_PRIMARY_DNS:
        _NetCtl_CopyBytes(info.primary_dns[0].ref[mutable u8&], payload, 16usize)
    elif code == ORBIS_NET_CTL_INFO_SECONDARY_DNS:
        _NetCtl_CopyBytes(info.secondary_dns[0].ref[mutable u8&], payload, 16usize)
    elif code == ORBIS_NET_CTL_INFO_HTTP_PROXY_CONFIG:
        info.http_proxy_config <- payload.cast[mutable u32&]
    elif code == ORBIS_NET_CTL_INFO_HTTP_PROXY_SERVER:
        _NetCtl_CopyBytes(info.http_proxy_server[0].ref[mutable u8&], payload, 256usize)
    elif code == ORBIS_NET_CTL_INFO_HTTP_PROXY_PORT:
        info.http_proxy_port <- payload.cast[mutable u16&]

