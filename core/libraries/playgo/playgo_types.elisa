type OrbisPlayGoHandle = u32
type OrbisPlayGoChunkId = u16
type OrbisPlayGoEta = s64
type OrbisPlayGoLanguageMask = u64
type OrbisPlayGoLocus = i8
type OrbisPlayGoInstallSpeed = s32

struct OrbisPlayGoInitParams:
    bufAddr: void&?
    bufSize: u32
    reserved: u32

struct OrbisPlayGoToDo:
    chunkId: OrbisPlayGoChunkId
    locus: OrbisPlayGoLocus
    reserved: i8

struct OrbisPlayGoProgress:
    progressSize: mutable u64
    totalSize: mutable u64

const ORBIS_PLAYGO_LOCUS_NOT_DOWNLOADED: OrbisPlayGoLocus = 0
const ORBIS_PLAYGO_LOCUS_LOCAL_SLOW: OrbisPlayGoLocus = 2
const ORBIS_PLAYGO_LOCUS_LOCAL_FAST: OrbisPlayGoLocus = 3

const ORBIS_PLAYGO_INSTALL_SPEED_SUSPENDED: OrbisPlayGoInstallSpeed = 0
const ORBIS_PLAYGO_INSTALL_SPEED_TRICKLE: OrbisPlayGoInstallSpeed = 1
const ORBIS_PLAYGO_INSTALL_SPEED_FULL: OrbisPlayGoInstallSpeed = 2

