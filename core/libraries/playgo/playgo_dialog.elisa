# @port core/libraries/playgo/playgo_dialog.cpp::scePlayGoDialogOpen sha256=e03f8f4602d9a508 oracle@a3773841
def scePlayGoDialogOpen(param: OrbisPlayGoDialogParam&?) -> int:
    if param == null:
        return 0x80B8000D
    return 0

# @port core/libraries/playgo/playgo_dialog.cpp::scePlayGoDialogTerminate sha256=53194874804fc21b oracle@a3773841
