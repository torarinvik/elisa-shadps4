include "./commondialog.elisa"

type OrbisMsgDialogProgressBarTarget = u32
@fixed_layout
struct DialogResult:
    mode: mutable u32
    result: mutable u32
    button_id: mutable u32
    reserved: mutable u8[32]
@fixed_layout
struct OrbisParam:
    opaque: mutable u8[256]

def sceMsgDialogClose() -> u32:
    return ORBIS_OK.u32()

def sceMsgDialogGetResult(result: mutable u32&?) -> u32:
    _ = result
    return ORBIS_OK.u32()

def sceMsgDialogGetStatus() -> u32:
    return ORBIS_COMMON_DIALOG_STATUS_FINISHED

def sceMsgDialogInitialize() -> u32:
    return ORBIS_OK.u32()

def sceMsgDialogOpen(param: mutable void&?) -> u32:
    _ = param
    return ORBIS_OK.u32()

def sceMsgDialogProgressBarInc(arg0: int, delta: u32) -> u32:
    _ = arg0
    _ = delta
    return ORBIS_OK.u32()

def sceMsgDialogProgressBarSetMsg(arg0: int, msg: mutable u8&?) -> u32:
    _ = arg0
    _ = msg
    return ORBIS_OK.u32()

def sceMsgDialogProgressBarSetValue(arg0: int, value: u32) -> u32:
    _ = arg0
    _ = value
    return ORBIS_OK.u32()

def sceMsgDialogTerminate() -> u32:
    return ORBIS_OK.u32()

def sceMsgDialogUpdateStatus() -> u32:
    return ORBIS_COMMON_DIALOG_STATUS_FINISHED

def MsgDialog_RegisterLib(sym: void&?) -> void:
    _ = sym
