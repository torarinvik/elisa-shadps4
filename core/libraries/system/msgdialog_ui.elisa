include "./commondialog.elisa"

const MSG_DIALOG_MODE_USER_MSG: u32 = 1
const MSG_DIALOG_MODE_PROGRESS_BAR: u32 = 2
const MSG_DIALOG_MODE_SYSTEM_MSG: u32 = 3

type OrbisUserServiceUserId = int
type MsgDialogMode = u32
type ButtonId = u32
type ButtonType = u32
type ProgressBarType = u32
type SystemMessageType = u32
type OrbisMsgDialogProgressBarTarget = u32
@fixed_layout
struct ButtonsParam:
    msg1: mutable u8&?
    msg2: mutable u8&?
    reserved: mutable u8[32]
@fixed_layout
struct UserMessageParam:
    button_type: mutable u32
    reserved0: mutable u32
    msg: mutable u8&?
    buttons_param: mutable ButtonsParam&?
    reserved: mutable u8[24]
@fixed_layout
struct ProgressBarParam:
    bar_type: mutable u32
    reserved0: mutable u32
    msg: mutable u8&?
    reserved: mutable u8[64]
@fixed_layout
struct SystemMessageParam:
    sys_msg_type: mutable u32
    reserved: mutable u8[32]
@fixed_layout
struct OrbisParam:
    base_param: mutable BaseParam
    size: mutable usize
    mode: mutable u32
    reserved0: mutable u32
    user_msg_param: mutable UserMessageParam&?
    prog_bar_param: mutable ProgressBarParam&?
    sys_msg_param: mutable SystemMessageParam&?
    user_id: mutable int
    reserved: mutable u8[40]
    reserved1: mutable u32
@fixed_layout
struct DialogResult:
    mode: mutable u32
    result: mutable u32
    button_id: mutable u32
    reserved: mutable u8[32]
