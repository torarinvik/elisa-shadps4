include "../error_codes.elisa"
include "./userservice.elisa"
include "./systemservice_error.elisa"
include "./systemservice_ffi_bridge.elisa"

type OrbisSystemServiceParamId = int
type OrbisSystemParamDateFormat = int
type OrbisSystemParamTimeFormat = int
type OrbisSystemParamGameParentalLevel = int
type OrbisSystemParamEnterButtonAssign = int
type OrbisSystemServiceEventType = int

const ORBIS_SYSTEM_SERVICE_PARAM_ID_LANG: OrbisSystemServiceParamId = 1
const ORBIS_SYSTEM_SERVICE_PARAM_ID_DATE_FORMAT: OrbisSystemServiceParamId = 2
const ORBIS_SYSTEM_SERVICE_PARAM_ID_TIME_FORMAT: OrbisSystemServiceParamId = 3
const ORBIS_SYSTEM_SERVICE_PARAM_ID_TIME_ZONE: OrbisSystemServiceParamId = 4
const ORBIS_SYSTEM_SERVICE_PARAM_ID_SUMMERTIME: OrbisSystemServiceParamId = 5
const ORBIS_SYSTEM_SERVICE_PARAM_ID_GAME_PARENTAL_LEVEL: OrbisSystemServiceParamId = 7
const ORBIS_SYSTEM_SERVICE_PARAM_ID_ENTER_BUTTON_ASSIGN: OrbisSystemServiceParamId = 10
@fixed_layout
struct OrbisSystemServiceStatus:
    event_num: mutable int
    is_system_ui_overlaid: mutable bool
    is_in_background_execution: mutable bool
    is_cpu_mode7_cpu_normal: mutable bool
    is_game_live_streaming_on_air: mutable bool
    is_out_of_vr_play_area: mutable bool
@fixed_layout
struct OrbisSystemServiceDisplaySafeAreaInfo:
    ratio: mutable f32
    reserved: mutable u8[128]
@fixed_layout
struct OrbisSystemServiceEvent:
    event_type: mutable int
    param: mutable u8[8192]

global mutable g_systemservice_event_type_q: int[16] = zeroed
global mutable g_systemservice_event_head: int = 0
global mutable g_systemservice_event_tail: int = 0
global mutable g_systemservice_event_count: int = 0
global mutable g_systemservice_use_ffi_bridge: bool = false

def SystemService_SetUseFfiBridge(enabled: bool) -> void:
    g_systemservice_use_ffi_bridge <- enabled

