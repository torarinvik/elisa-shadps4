# @port core/libraries/system/systemservice.cpp::sceSystemServiceReceiveEvent sha256=e62a003e8b6e1b96 oracle@a3773841
def sceSystemServiceReceiveEvent(event: mutable void&?) -> int:
    if g_systemservice_use_ffi_bridge and event != null:
        ffi_event: mutable OrbisSystemServiceEvent& = event.cast[mutable OrbisSystemServiceEvent&]
        ffi_r: int = SystemService_FfiReceiveEvent(ffi_event)
        if ffi_r != ELISA_FFI_BRIDGE_UNAVAILABLE:
            return ffi_r
    if event == null:
        return ORBIS_SYSTEM_SERVICE_ERROR_PARAMETER
    if g_systemservice_event_count == 0:
        return ORBIS_SYSTEM_SERVICE_ERROR_NO_EVENT
    out_event: mutable OrbisSystemServiceEvent& = event.cast[mutable OrbisSystemServiceEvent&]
    out_event.event_type <- g_systemservice_event_type_q[g_systemservice_event_head.usize()]
    g_systemservice_event_head <- (g_systemservice_event_head + 1) % 16
    g_systemservice_event_count <- g_systemservice_event_count - 1
    return ORBIS_OK

def SystemService_PushEventForTests(event_type: int) -> void:
    if g_systemservice_use_ffi_bridge:
        ffi_r: int = SystemService_FfiTestPushEvent(event_type)
        if ffi_r != ELISA_FFI_BRIDGE_UNAVAILABLE:
            return
    if g_systemservice_event_count >= 16:
        return
    g_systemservice_event_type_q[g_systemservice_event_tail.usize()] <- event_type
    g_systemservice_event_tail <- (g_systemservice_event_tail + 1) % 16
    g_systemservice_event_count <- g_systemservice_event_count + 1

