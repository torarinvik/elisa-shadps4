# @port core/libraries/system/systemservice.cpp::sceSystemServiceGetStatus sha256=01d97f9d7b3e48ae oracle@a3773841
def sceSystemServiceGetStatus(status: mutable u32&?) -> int:
    if g_systemservice_use_ffi_bridge and status != null:
        ffi_status: mutable OrbisSystemServiceStatus& = status.cast[mutable OrbisSystemServiceStatus&]
        ffi_r: int = SystemService_FfiGetStatus(ffi_status)
        if ffi_r != ELISA_FFI_BRIDGE_UNAVAILABLE:
            return ffi_r
    if status == null:
        return ORBIS_SYSTEM_SERVICE_ERROR_PARAMETER
    out_status: mutable OrbisSystemServiceStatus& = status.cast[mutable OrbisSystemServiceStatus&]
    out_status.event_num <- g_systemservice_event_count
    out_status.is_system_ui_overlaid <- false
    out_status.is_in_background_execution <- false
    out_status.is_cpu_mode7_cpu_normal <- true
    out_status.is_game_live_streaming_on_air <- false
    out_status.is_out_of_vr_play_area <- false
    return ORBIS_OK

