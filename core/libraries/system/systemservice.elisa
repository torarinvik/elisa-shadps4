def sceSystemServiceLoadExec(path: mutable u8&?, arg1: mutable void&?) -> int:
    if g_systemservice_use_ffi_bridge:
        ffi_r: int = SystemService_FfiLoadExec(path, arg1)
        if ffi_r != ELISA_FFI_BRIDGE_UNAVAILABLE:
            return ffi_r
    _ = arg1
    if path == null:
        return ORBIS_SYSTEM_SERVICE_ERROR_PARAMETER
