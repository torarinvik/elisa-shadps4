global mutable g_systemservice_timezone_minutes: int = 120
global mutable g_systemservice_summertime: int = 1
global mutable g_systemservice_game_parental_level: int = 0
global mutable g_systemservice_enter_button_assign: int = 1
global mutable g_systemservice_splash_status: bool = true

def SystemService_SetLanguage(lang: int) -> void:
    g_systemservice_lang <- lang

def SystemService_IsSplashVisibleForTests() -> bool:
    return g_systemservice_splash_status

# @port core/libraries/system/systemservice.cpp::sceSystemServiceParamGetInt sha256=411522c0b3936297 oracle@a3773841
def sceSystemServiceParamGetInt(param_id: int, value: mutable int&?) -> int:
    if value == null:
        return ORBIS_SYSTEM_SERVICE_ERROR_PARAMETER
    if param_id == 1:
        value <- g_systemservice_lang
        return ORBIS_OK
    if param_id == 2:
        value <- g_systemservice_date_format
        return ORBIS_OK
    if param_id == 3:
        value <- g_systemservice_time_format
        return ORBIS_OK
    if param_id == 4:
        value <- g_systemservice_timezone_minutes
        return ORBIS_OK
    if param_id == 5:
        value <- g_systemservice_summertime
        return ORBIS_OK
    if param_id == 7:
        value <- g_systemservice_game_parental_level
        return ORBIS_OK
    if param_id == 1000:
        value <- g_systemservice_enter_button_assign
        return ORBIS_OK
    value <- 0
    return ORBIS_OK

