include "../error_codes.elisa"
include "./userservice_error.elisa"
include "./userservice_ffi_bridge.elisa"
include "../../guest_exec.elisa"

@link_name(ElisaGuestExec_EmitCusaArtifactKV)
extern c_GuestExec_EmitCusaArtifactKV(key: static u8&?, value: u64) -> void

const ORBIS_USER_SERVICE_MAX_LOGIN_USERS: int = 4
const ORBIS_USER_SERVICE_MAX_REGISTER_USERS: int = 16
const ORBIS_USER_SERVICE_MAX_USER_NAME_LENGTH: int = 16
const ORBIS_USER_SERVICE_USER_ID_SYSTEM: int = 0xFF
const ORBIS_USER_SERVICE_USER_ID_INVALID: int = -1
const ORBIS_USER_SERVICE_KERNEL_PRIO_FIFO_LOWEST: int = 0x2FF
const ORBIS_USER_SERVICE_KERNEL_PRIO_FIFO_NORMAL: int = 0x2BC
const ORBIS_USER_SERVICE_KERNEL_PRIO_FIFO_HIGHEST: int = 0x100

type OrbisUserServiceUserId = int
@fixed_layout
struct OrbisUserServiceInitializeParams:
    priority: mutable int
@fixed_layout
struct OrbisUserServiceLoginUserIdList:
    user_id: mutable int[4]
@fixed_layout
struct OrbisUserServiceRegisteredUserIdList:
    user_id: mutable int[16]
@fixed_layout
struct OrbisUserServiceEvent:
    event: mutable u32
    user_id: mutable int

global mutable g_userservice_initial_user: int = 1
global mutable g_userservice_slot_user_id: int[4] = [1, 2, -1, -1]
global mutable g_userservice_slot_color: u32[4] = [0, 1, 0, 0]
global mutable g_userservice_event_kind_q: u32[16] = zeroed
global mutable g_userservice_event_user_q: int[16] = zeroed
global mutable g_userservice_event_head: int = 0
global mutable g_userservice_event_tail: int = 0
global mutable g_userservice_event_count: int = 0
global mutable g_userservice_use_ffi_bridge: bool = false

def userservice_emit_u64(key: static u8&, value: u64) -> void:
    if GuestExec_IsEnabled():
        c_GuestExec_EmitCusaArtifactKV(key, value)

def UserService_SetUseFfiBridge(enabled: bool) -> void:
    g_userservice_use_ffi_bridge <- enabled

def UserService_FindSlotById(user_id: int) -> int:
    i: mutable int = 0
    while i < ORBIS_USER_SERVICE_MAX_LOGIN_USERS:
        if g_userservice_slot_user_id[i.usize()] == user_id:
            return i
        i <- i + 1
    return -1

def UserService_ResolveUserId(user_id: int, resolved_out: mutable int&?) -> bool:
    if resolved_out == null:
        return false
    if user_id == ORBIS_USER_SERVICE_USER_ID_INVALID:
        return false
    if user_id == ORBIS_USER_SERVICE_USER_ID_SYSTEM:
        resolved_out <- g_userservice_initial_user
    else:
        resolved_out <- user_id
    if UserService_FindSlotById(resolved_out) < 0:
        return false
    return true

def UserService_WriteNameForSlot(slot: int, user_name: mutable u8&?, size: int) -> int:
    if user_name == null:
        return ORBIS_USER_SERVICE_ERROR_INVALID_ARGUMENT
    if slot == 0:
        if size <= 5:
            return ORBIS_USER_SERVICE_ERROR_BUFFER_TOO_SHORT
        user_name[0] <- 'U'.u8()
        user_name[1] <- 's'.u8()
        user_name[2] <- 'e'.u8()
        user_name[3] <- 'r'.u8()
        user_name[4] <- '1'.u8()
        user_name[5] <- 0
        return ORBIS_OK
    if slot == 1:
        if size <= 5:
            return ORBIS_USER_SERVICE_ERROR_BUFFER_TOO_SHORT
        user_name[0] <- 'U'.u8()
        user_name[1] <- 's'.u8()
        user_name[2] <- 'e'.u8()
        user_name[3] <- 'r'.u8()
        user_name[4] <- '2'.u8()
        user_name[5] <- 0
        return ORBIS_OK
    if size <= 1:
        return ORBIS_USER_SERVICE_ERROR_BUFFER_TOO_SHORT
    user_name[0] <- 0
    return ORBIS_OK

