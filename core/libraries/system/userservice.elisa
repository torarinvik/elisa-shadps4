# @port core/libraries/system/userservice.cpp::sceUserServiceGetUserColor sha256=c6270922ddc1571d oracle@a3773841
def sceUserServiceGetUserColor(user_id: int, color: mutable u32&?) -> int:
    if g_userservice_use_ffi_bridge:
        ffi_r: int = UserService_FfiGetUserColor(user_id, color)
        if ffi_r != ELISA_FFI_BRIDGE_UNAVAILABLE:
            return ffi_r
    if color == null:
        return ORBIS_USER_SERVICE_ERROR_INVALID_ARGUMENT
    resolved: mutable int = ORBIS_USER_SERVICE_USER_ID_INVALID
    if not UserService_ResolveUserId(user_id, resolved):
        return ORBIS_USER_SERVICE_ERROR_INVALID_ARGUMENT
    slot: int = UserService_FindSlotById(resolved)
    if slot < 0:
        return ORBIS_USER_SERVICE_ERROR_INVALID_ARGUMENT
    color <- g_userservice_slot_color[slot.usize()]
    return ORBIS_OK

