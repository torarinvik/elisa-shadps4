# @port core/libraries/system/userservice.cpp::sceUserServiceGetInitialUser sha256=3cc2565d859eca2a oracle@a3773841
def sceUserServiceGetInitialUser(user_id: mutable int&?) -> int:
    if g_userservice_use_ffi_bridge:
        ffi_r: int = UserService_FfiGetInitialUser(user_id)
        if ffi_r != ELISA_FFI_BRIDGE_UNAVAILABLE:
            return ffi_r
    if user_id == null:
        return ORBIS_USER_SERVICE_ERROR_INVALID_ARGUMENT
    user_id <- g_userservice_initial_user
    userservice_emit_u64("user_service_initial_user", g_userservice_initial_user.u64())
    return ORBIS_OK

