# @port core/libraries/system/userservice.cpp::sceUserServiceGetLoginUserIdList sha256=dec0c0768ebb9035 oracle@a3773841
def sceUserServiceGetLoginUserIdList(userIdList: mutable void&?) -> int:
    if g_userservice_use_ffi_bridge and userIdList != null:
        ffi_list: mutable OrbisUserServiceLoginUserIdList& = userIdList.cast[mutable OrbisUserServiceLoginUserIdList&]
        ffi_r: int = UserService_FfiGetLoginUserIdList(ffi_list)
        if ffi_r != ELISA_FFI_BRIDGE_UNAVAILABLE:
            if ffi_r == ORBIS_OK:
                count: mutable u64 = 0u64
                i_count: mutable int = 0
                while i_count < ORBIS_USER_SERVICE_MAX_LOGIN_USERS:
                    if ffi_list.user_id[i_count.usize()] != ORBIS_USER_SERVICE_USER_ID_INVALID:
                        count <- count + 1u64
                    i_count <- i_count + 1
                userservice_emit_u64("user_service_login_user_count", count)
            return ffi_r
    if userIdList == null:
        return ORBIS_USER_SERVICE_ERROR_INVALID_ARGUMENT
    list: mutable OrbisUserServiceLoginUserIdList& = userIdList.cast[mutable OrbisUserServiceLoginUserIdList&]
    i: mutable int = 0
    while i < ORBIS_USER_SERVICE_MAX_LOGIN_USERS:
        list.user_id[i.usize()] <- ORBIS_USER_SERVICE_USER_ID_INVALID
        i <- i + 1
    i <- 0
    while i < ORBIS_USER_SERVICE_MAX_LOGIN_USERS:
        list.user_id[i.usize()] <- g_userservice_slot_user_id[i.usize()]
        i <- i + 1
    userservice_emit_u64("user_service_login_user_count", ORBIS_USER_SERVICE_MAX_LOGIN_USERS as u64)
    return ORBIS_OK

