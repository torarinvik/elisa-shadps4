# @port core/libraries/system/userservice.cpp::sceUserServiceGetEvent sha256=58fbcb42918e35b9 oracle@a3773841
def sceUserServiceGetEvent(event: mutable void&?) -> int:
    if g_userservice_use_ffi_bridge and event != null:
        out_event_ffi: mutable OrbisUserServiceEvent& = event.cast[mutable OrbisUserServiceEvent&]
        ffi_r: int = UserService_FfiGetEvent(out_event_ffi)
        if ffi_r != ELISA_FFI_BRIDGE_UNAVAILABLE:
            return ffi_r
    if g_userservice_event_count == 0:
        return ORBIS_USER_SERVICE_ERROR_NO_EVENT
    if event == null:
        return ORBIS_USER_SERVICE_ERROR_INVALID_ARGUMENT
    out_event: mutable OrbisUserServiceEvent& = event.cast[mutable OrbisUserServiceEvent&]
    out_event.event <- g_userservice_event_kind_q[g_userservice_event_head.usize()]
    out_event.user_id <- g_userservice_event_user_q[g_userservice_event_head.usize()]
    g_userservice_event_head <- (g_userservice_event_head + 1) % 16
    g_userservice_event_count <- g_userservice_event_count - 1
    return ORBIS_OK

