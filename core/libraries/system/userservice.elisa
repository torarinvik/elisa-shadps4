# @port core/libraries/system/userservice.cpp::sceUserServiceGetUserName sha256=35dc3f0b61b52427 oracle@a3773841
def sceUserServiceGetUserName(user_id: int, user_name: mutable u8&?, size: int) -> int:
    if g_userservice_use_ffi_bridge:
        ffi_r: int = UserService_FfiGetUserName(user_id, user_name, size.usize())
        if ffi_r != ELISA_FFI_BRIDGE_UNAVAILABLE:
            return ffi_r
    if user_name == null:
        return ORBIS_USER_SERVICE_ERROR_INVALID_ARGUMENT
    resolved: mutable int = ORBIS_USER_SERVICE_USER_ID_INVALID
    if not UserService_ResolveUserId(user_id, resolved):
        return ORBIS_USER_SERVICE_ERROR_INVALID_ARGUMENT
    slot: int = UserService_FindSlotById(resolved)
    if slot < 0:
        return ORBIS_USER_SERVICE_ERROR_INVALID_ARGUMENT
    return UserService_WriteNameForSlot(slot, user_name, size)

def UserService_PushEventForTests(event_kind: u32, user_id: int) -> void:
    if g_userservice_use_ffi_bridge:
        ffi_r: int = UserService_FfiTestPushEvent(event_kind, user_id)
        if ffi_r != ELISA_FFI_BRIDGE_UNAVAILABLE:
            return
    if g_userservice_event_count >= 16:
        return
    g_userservice_event_kind_q[g_userservice_event_tail.usize()] <- event_kind
    g_userservice_event_user_q[g_userservice_event_tail.usize()] <- user_id
    g_userservice_event_tail <- (g_userservice_event_tail + 1) % 16
    g_userservice_event_count <- g_userservice_event_count + 1

