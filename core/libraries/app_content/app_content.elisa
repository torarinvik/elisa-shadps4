def sceAppContentAddcontMount(service_label: u32, entitlement_label: OrbisNpUnifiedEntitlementLabel&?, mount_point: mutable OrbisAppContentMountPoint&?) -> int:
    _ = service_label
    if entitlement_label == null or mount_point == null:
        return ORBIS_APP_CONTENT_ERROR_PARAMETER
    i: mutable s32 = 0
    while i < addcont_count:
        if labels_equal(entitlement_label.data, addcont_info[i].entitlement_label):
            write_addcont_mountpoint(i.int(), mount_point)
            return ORBIS_OK
        i <- i + 1
    return ORBIS_APP_CONTENT_ERROR_NOT_FOUND

def sceAppContentAppParamGetInt(paramId: u32, out_value: mutable s32&?) -> int:
    if out_value == null:
        return ORBIS_APP_CONTENT_ERROR_PARAMETER
    if paramId == ORBIS_APP_CONTENT_APPPARAM_ID_SKU_FLAG:
        out_value <- ORBIS_APP_CONTENT_APPPARAM_SKU_FLAG_FULL
        return ORBIS_OK
    if paramId == ORBIS_APP_CONTENT_APPPARAM_ID_USER_DEFINED_PARAM_1 or paramId == ORBIS_APP_CONTENT_APPPARAM_ID_USER_DEFINED_PARAM_2 or paramId == ORBIS_APP_CONTENT_APPPARAM_ID_USER_DEFINED_PARAM_3 or paramId == ORBIS_APP_CONTENT_APPPARAM_ID_USER_DEFINED_PARAM_4:
        out_value <- 0
        return ORBIS_OK
    return ORBIS_APP_CONTENT_ERROR_PARAMETER

def sceAppContentDownloadDataGetAvailableSpaceKb(mountPoint: mutable OrbisAppContentMountPoint&?, availableSpaceKb: mutable u64&?) -> int:
    _ = mountPoint
    if availableSpaceKb != null:
        availableSpaceKb <- DUMMY_SPACE_KB
    return ORBIS_OK

def sceAppContentGetAddcontInfo(service_label: u32, entitlementLabel: OrbisNpUnifiedEntitlementLabel&?, info: mutable OrbisAppContentAddcontInfo&?) -> int:
    _ = service_label
    if entitlementLabel == null or info == null:
        return ORBIS_APP_CONTENT_ERROR_PARAMETER
    i: mutable s32 = 0
    while i < addcont_count:
        if labels_equal(entitlementLabel.data, addcont_info[i].entitlement_label):
            out_label: mutable i8[17]& = info.entitlement_label.data.ref[mutable i8[17]&]
            copy_label_to_out(addcont_info[i].entitlement_label, out_label)
            info.status <- addcont_info[i].status
            return ORBIS_OK
        i <- i + 1
    return ORBIS_APP_CONTENT_ERROR_DRM_NO_ENTITLEMENT

def sceAppContentGetAddcontInfoList(service_label: u32, list: mutable OrbisAppContentAddcontInfo&?, list_num: u32, hit_num: mutable u32&?) -> int:
    _ = service_label
    if list_num == 0 or list == null:
        if hit_num == null:
            return ORBIS_APP_CONTENT_ERROR_PARAMETER
        hit_num <- addcont_count.u32()
        return ORBIS_OK
    dlcs_to_list: mutable s32 = addcont_count
    if list_num < dlcs_to_list.u32():
        dlcs_to_list <- list_num.cast[s32]
    i: mutable s32 = 0
    while i < dlcs_to_list:
        out_label: mutable i8[17]& = list[i].entitlement_label.data.ref[mutable i8[17]&]
        copy_label_to_out(addcont_info[i].entitlement_label, out_label)
        list[i].status <- addcont_info[i].status
        i <- i + 1
    if hit_num != null:
        hit_num <- dlcs_to_list.u32()
    return ORBIS_OK

def sceAppContentGetEntitlementKey(service_label: u32, entitlement_label: OrbisNpUnifiedEntitlementLabel&?, key: mutable OrbisAppContentGetEntitlementKey&?) -> int:
    _ = service_label
    if entitlement_label == null or key == null:
        return ORBIS_APP_CONTENT_ERROR_PARAMETER
    i: mutable s32 = 0
    while i < addcont_count:
        if labels_equal(entitlement_label.data, addcont_info[i].entitlement_label):
            j: mutable int = 0
            while j < ORBIS_APP_CONTENT_ENTITLEMENT_KEY_SIZE:
                key.data[j] <- addcont_info[i].key.data[j]
                j <- j + 1
            return ORBIS_OK
        i <- i + 1
    return ORBIS_APP_CONTENT_ERROR_DRM_NO_ENTITLEMENT

def sceAppContentInitialize(initParam: OrbisAppContentInitParam&?, bootParam: mutable OrbisAppContentBootParam&?) -> int:
    _ = initParam
    _ = bootParam
    if sdk_ver >= SDK_15_00_00 and is_initialized:
        return ORBIS_APP_CONTENT_ERROR_BUSY
    is_initialized <- true
    return ORBIS_OK

def sceAppContentTemporaryDataGetAvailableSpaceKb(mountPoint: OrbisAppContentMountPoint&?, availableSpaceKb: mutable u64&?) -> int:
    _ = mountPoint
    if availableSpaceKb != null:
        availableSpaceKb <- DUMMY_SPACE_KB
    return ORBIS_OK

def sceAppContentTemporaryDataMount2(option: u32, mountPoint: mutable OrbisAppContentMountPoint&?) -> int:
    _ = option
    if mountPoint == null:
        return ORBIS_APP_CONTENT_ERROR_PARAMETER
    mountPoint.data[0] <- '/'.i8()
    mountPoint.data[1] <- 't'.i8()
    mountPoint.data[2] <- 'e'.i8()
    mountPoint.data[3] <- 'm'.i8()
    mountPoint.data[4] <- 'p'.i8()
    mountPoint.data[5] <- '0'.i8()
    mountPoint.data[6] <- 0
    return ORBIS_OK

def sceAppContentAddcontMountByEntitlementId(service_label: u32, entitlement_label: OrbisNpUnifiedEntitlementLabel&?, mount_point: mutable OrbisAppContentMountPoint&?) -> int:
    return sceAppContentAddcontMount(service_label, entitlement_label, mount_point)

def sceAppContentGetAddcontInfoByEntitlementId(service_label: u32, entitlement_label: OrbisNpUnifiedEntitlementLabel&?, info: mutable OrbisAppContentAddcontInfo&?) -> int:
    return sceAppContentGetAddcontInfo(service_label, entitlement_label, info)

def sceAppContentGetAddcontInfoListByIroTag(service_label: u32, list: mutable OrbisAppContentAddcontInfo&?, list_num: u32, hit_num: mutable u32&?) -> int:
    return sceAppContentGetAddcontInfoList(service_label, list, list_num, hit_num)

# Loader hooks so emulator-side discovery code can populate this table.
def sceAppContentDebugReset() -> int:
    addcont_info <- zeroed
    addcont_count <- 0
    is_initialized <- false
    app_content_init_defaults()
    return ORBIS_OK

def sceAppContentDebugSetAddcontCount(count: s32) -> int:
    if count < 0 or count > 2500:
        return ORBIS_APP_CONTENT_ERROR_PARAMETER
    addcont_count <- count
    return ORBIS_OK

def sceAppContentDebugSetAddcontEntry(index: s32, label: OrbisNpUnifiedEntitlementLabel&?, status: u32, key: OrbisAppContentGetEntitlementKey&?) -> int:
    if label == null or key == null:
        return ORBIS_APP_CONTENT_ERROR_PARAMETER
    if index < 0 or index >= 2500:
        return ORBIS_APP_CONTENT_ERROR_PARAMETER

    copy_label_to_out(label.data, addcont_info[index].entitlement_label)
    addcont_info[index].status <- status

    j: mutable int = 0
    while j < ORBIS_APP_CONTENT_ENTITLEMENT_KEY_SIZE:
        addcont_info[index].key.data[j] <- key.data[j]
        j <- j + 1

    if addcont_count <= index:
        addcont_count <- index + 1
    return ORBIS_OK

# Convenience helper: accepts 16-byte entitlement payload in plain bytes and null-terminates.
def sceAppContentDebugSetAddcontEntryLabel16(index: s32, label16: i8[16]&, status: u32, key: OrbisAppContentGetEntitlementKey&?) -> int:
    if key == null:
        return ORBIS_APP_CONTENT_ERROR_PARAMETER
    if index < 0 or index >= 2500:
        return ORBIS_APP_CONTENT_ERROR_PARAMETER

    i: mutable int = 0
    while i < 16:
        addcont_info[index].entitlement_label[i] <- label16[i]
        i <- i + 1
    addcont_info[index].entitlement_label[16] <- 0
    addcont_info[index].status <- status

    j: mutable int = 0
    while j < ORBIS_APP_CONTENT_ENTITLEMENT_KEY_SIZE:
        addcont_info[index].key.data[j] <- key.data[j]
        j <- j + 1

    if addcont_count <= index:
        addcont_count <- index + 1
    return ORBIS_OK

# Bulk bridge: discovery layer can hand over already-parsed entries directly.
def sceAppContentLoadDiscoveredEntries(entries: AppContentDiscoveredEntry16&?, entry_count: s32) -> int:
    if entries == null:
        return ORBIS_APP_CONTENT_ERROR_PARAMETER
    if entry_count < 0 or entry_count > 2500:
        return ORBIS_APP_CONTENT_ERROR_PARAMETER

    reset_res: int = sceAppContentDebugReset()
    if reset_res != ORBIS_OK:
        return reset_res

    i: mutable s32 = 0
    while i < entry_count:
        set_res: int = sceAppContentDebugSetAddcontEntryLabel16(i, entries[i].label16.ref[i8[16]&], entries[i].status, entries[i].key.ref[OrbisAppContentGetEntitlementKey&])
        if set_res != ORBIS_OK:
            return set_res
        i <- i + 1

    addcont_count <- entry_count
    return ORBIS_OK

def AppContent_RegisterLib(sym: void&?) -> void:
    _ = sym
