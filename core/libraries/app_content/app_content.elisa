include "./app_content_error.elisa"

const SDK_15_00_00: s32 = 0x1500000
const DUMMY_SPACE_KB: u64 = 1048576

const ORBIS_APP_CONTENT_APPPARAM_ID_SKU_FLAG: u32 = 0
const ORBIS_APP_CONTENT_APPPARAM_ID_USER_DEFINED_PARAM_1: u32 = 1
const ORBIS_APP_CONTENT_APPPARAM_ID_USER_DEFINED_PARAM_2: u32 = 2
const ORBIS_APP_CONTENT_APPPARAM_ID_USER_DEFINED_PARAM_3: u32 = 3
const ORBIS_APP_CONTENT_APPPARAM_ID_USER_DEFINED_PARAM_4: u32 = 4
const ORBIS_APP_CONTENT_APPPARAM_SKU_FLAG_FULL: int = 3
const ORBIS_APP_CONTENT_MOUNTPOINT_DATA_MAXSIZE: int = 16
const ORBIS_NP_UNIFIED_ENTITLEMENT_LABEL_SIZE: int = 17
const ORBIS_APP_CONTENT_ENTITLEMENT_KEY_SIZE: int = 16
const ORBIS_APP_CONTENT_INFO_LIST_MAX_SIZE: int = 2500
const ORBIS_APP_CONTENT_DOWNLOAD_STATUS_INSTALLED: u32 = 4

struct OrbisAppContentInitParam:
    reserved: i8[32]

struct OrbisAppContentBootParam:
    reserved1: i8[4]
    attr: u32
    reserved2: i8[32]

struct OrbisAppContentMountPoint:
    data: mutable i8[16]

struct OrbisNpUnifiedEntitlementLabel:
    data: i8[17]
    padding: i8[3]

struct OrbisAppContentAddcontInfo:
    entitlement_label: mutable OrbisNpUnifiedEntitlementLabel
    status: mutable u32

struct OrbisAppContentGetEntitlementKey:
    data: mutable u8[16]

struct AddContInfo:
    entitlement_label: mutable i8[17]
    status: mutable u32
    key: mutable OrbisAppContentGetEntitlementKey

struct AppContentDiscoveredEntry16:
    label16: i8[16]
    status: u32
    key: OrbisAppContentGetEntitlementKey

global mutable addcont_info: AddContInfo[2500] = zeroed
global mutable sdk_ver: s32 = 0
global mutable addcont_count: s32 = 0
global mutable is_initialized: bool = false

def labels_equal(lhs: i8[ORBIS_NP_UNIFIED_ENTITLEMENT_LABEL_SIZE]&, rhs: i8[ORBIS_NP_UNIFIED_ENTITLEMENT_LABEL_SIZE]&) -> bool:
    i: mutable int = 0
    while i < ORBIS_NP_UNIFIED_ENTITLEMENT_LABEL_SIZE - 1:
        if lhs[i] != rhs[i]:
            return false
        i <- i + 1
    return true

def copy_label_to_out(src: i8[ORBIS_NP_UNIFIED_ENTITLEMENT_LABEL_SIZE]&, dst: mutable i8[17]&):
    i: mutable int = 0
    while i < ORBIS_NP_UNIFIED_ENTITLEMENT_LABEL_SIZE:
        dst[i] <- src[i]
        i <- i + 1

def write_addcont_mountpoint(index: int, mount_point: mutable OrbisAppContentMountPoint&):
    mount_point.data[0] <- '/'.i8()
    mount_point.data[1] <- 'a'.i8()
    mount_point.data[2] <- 'd'.i8()
    mount_point.data[3] <- 'd'.i8()
    mount_point.data[4] <- 'c'.i8()
    mount_point.data[5] <- 'o'.i8()
    mount_point.data[6] <- 'n'.i8()
    mount_point.data[7] <- 't'.i8()
    if index >= 0 and index <= 9:
        mount_point.data[8] <- ('0'.i8() + index.i8())
        mount_point.data[9] <- 0
    else:
        mount_point.data[8] <- '0'.i8()
        mount_point.data[9] <- 0

def app_content_init_defaults():
    i: mutable int = 0
    while i < 16:
        addcont_info[0].entitlement_label[i] <- '0'.i8()
        i <- i + 1
    addcont_info[0].entitlement_label[16] <- 0
    addcont_info[0].status <- ORBIS_APP_CONTENT_DOWNLOAD_STATUS_INSTALLED

# Mostly stubbed API functions kept as in C++; keep the local helper named to
# avoid colliding with other libraries that expose the same mangled stub.
