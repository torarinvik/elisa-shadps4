include "../../../../compiler/runtime/elisacore_std/elisacore_runtime.elisa"
include "./videodec_native.elisa"

@test
def videodec_native_bridge_forwards_v1() -> void:
    can Abort.Panic:
        cfg: mutable OrbisVideodecConfigInfo = zeroed
        cfg.thisSize <- size_of(OrbisVideodecConfigInfo).u64()
        rsrc: mutable OrbisVideodecResourceInfo = zeroed
        rsrc.thisSize <- size_of(OrbisVideodecResourceInfo).u64()
        assert sceVideodecQueryResourceInfo(cfg.ref[OrbisVideodecConfigInfo&], rsrc.ref[mutable OrbisVideodecResourceInfo&]) == 0
        assert rsrc.frameBufferAlignment == 0x100u32
        ctrl: mutable OrbisVideodecCtrl = zeroed
        assert sceVideodecCreateDecoder(cfg.ref[OrbisVideodecConfigInfo&], rsrc.ref[OrbisVideodecResourceInfo&], ctrl.ref[mutable OrbisVideodecCtrl&]) == 0
        assert ctrl.handle != null
        input: mutable OrbisVideodecInputData = zeroed
        input.thisSize <- size_of(OrbisVideodecInputData).u64()
        input.pAuData <- 1usize as void&?
        input.auSize <- 4u64
        input.ptsData <- 77u64
        frame: mutable OrbisVideodecFrameBuffer = zeroed
        frame.thisSize <- size_of(OrbisVideodecFrameBuffer).u64()
        picture: mutable OrbisVideodecPictureInfo = zeroed
        assert sceVideodecDecode(ctrl.ref[mutable OrbisVideodecCtrl&], input.ref[OrbisVideodecInputData&], frame.ref[mutable OrbisVideodecFrameBuffer&], picture.ref[mutable OrbisVideodecPictureInfo&]) == 0
        assert picture.isValid == 1u32
        assert picture.ptsData == 77u64
        assert sceVideodecDeleteDecoder(ctrl.ref[mutable OrbisVideodecCtrl&]) == 0

@test
def videodec_native_bridge_forwards_v2() -> void:
    can Abort.Panic:
        cfg: mutable OrbisVideodec2DecoderConfigInfo = zeroed
        cfg.thisSize <- size_of(OrbisVideodec2DecoderConfigInfo).u64()
        mem: mutable OrbisVideodec2DecoderMemoryInfo = zeroed
        mem.thisSize <- size_of(OrbisVideodec2DecoderMemoryInfo).u64()
        assert sceVideodec2QueryDecoderMemoryInfo(cfg.ref[OrbisVideodec2DecoderConfigInfo&], mem.ref[mutable OrbisVideodec2DecoderMemoryInfo&]) == 0
        assert mem.frameBufferAlignment == 0x100u32
        decoder: mutable OrbisVideodec2Decoder = null
        assert sceVideodec2CreateDecoder(cfg.ref[OrbisVideodec2DecoderConfigInfo&], mem.ref[OrbisVideodec2DecoderMemoryInfo&], decoder.ref[mutable OrbisVideodec2Decoder&]) == 0
        assert decoder != null
        input: mutable OrbisVideodec2InputData = zeroed
        input.thisSize <- size_of(OrbisVideodec2InputData).u64()
        input.auData <- 2usize as void&?
        input.auSize <- 4u64
        frame: mutable OrbisVideodec2FrameBuffer = zeroed
        frame.thisSize <- size_of(OrbisVideodec2FrameBuffer).u64()
        output: mutable OrbisVideodec2OutputInfo = zeroed
        output.thisSize <- size_of(OrbisVideodec2OutputInfo).u64()
        assert sceVideodec2Decode(decoder, input.ref[OrbisVideodec2InputData&], frame.ref[mutable OrbisVideodec2FrameBuffer&], output.ref[mutable OrbisVideodec2OutputInfo&]) == 0
        assert frame.isAccepted
        assert output.isValid
        assert sceVideodec2DeleteDecoder(decoder) == 0
