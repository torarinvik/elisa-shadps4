#
# Native Elisa port of core/libraries/videodec/native_shims/common/alignment.h.
# Rounds a value up to the next multiple of `alignment`.
#
# The C++ original is a single function template `Common::AlignUp<T>`. Elisa
# numeric casts inside generics are awkward, so we provide concrete unsigned
# instantiations for the common widths instead. The formula is identical for
# each: ((value + alignment - 1) / alignment) * alignment.

def AlignUp_u64(value: u64, alignment: u64) -> u64:
    return ((value + alignment - 1u64) / alignment) * alignment

def AlignUp_u32(value: u32, alignment: u32) -> u32:
    return ((value + alignment - 1u32) / alignment) * alignment

def AlignUp_usize(value: usize, alignment: usize) -> usize:
    return ((value + alignment - 1usize) / alignment) * alignment
