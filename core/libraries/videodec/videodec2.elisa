# Port of core/libraries/videodec/videodec2.h value structs.
# Pointers (void*) and typedef'd handles (OrbisVideodec2Decoder = VdecDecoder*,
# OrbisVideodec2ComputeQueue = void*) are represented as u64.
# sce* functions and RegisterLib are deferred. The C++ static_assert sizes are
# documented per struct but NOT enforced (Elisa layout/alignment may differ).

# expected C++ sizeof == 0x48
struct OrbisVideodec2DecoderConfigInfo:
    thisSize: mutable u64
    resourceType: mutable u32
    codecType: mutable u32
    profile: mutable u32
    maxLevel: mutable u32
    maxFrameWidth: mutable i32
    maxFrameHeight: mutable i32
    maxDpbFrameCount: mutable i32
    decodePipelineDepth: mutable u32
    computeQueue: mutable u64
    cpuAffinityMask: mutable u64
    cpuThreadPriority: mutable i32
    optimizeProgressiveVideo: mutable bool
    checkMemoryType: mutable bool
    reserved0: mutable u8
    reserved1: mutable u8
    extraConfigInfo: mutable u64

# expected C++ sizeof == 0x48
struct OrbisVideodec2DecoderMemoryInfo:
    thisSize: mutable u64
    cpuMemorySize: mutable u64
    cpuMemory: mutable u64
    gpuMemorySize: mutable u64
    gpuMemory: mutable u64
    cpuGpuMemorySize: mutable u64
    cpuGpuMemory: mutable u64
    maxFrameBufferSize: mutable u64
    frameBufferAlignment: mutable u32
    reserved0: mutable u32

# expected C++ sizeof == 0x30
struct OrbisVideodec2InputData:
    thisSize: mutable u64
    auData: mutable u64
    auSize: mutable u64
    ptsData: mutable u64
    dtsData: mutable u64
    attachedData: mutable u64

# expected C++ sizeof == 0x38
struct OrbisVideodec2OutputInfo:
    thisSize: mutable u64
    isValid: mutable bool
    isErrorFrame: mutable bool
    pictureCount: mutable u8
    codecType: mutable u32
    frameWidth: mutable u32
    framePitch: mutable u32
    frameHeight: mutable u32
    frameBuffer: mutable u64
    frameBufferSize: mutable u64
    frameFormat: mutable u32
    framePitchInBytes: mutable u32

# expected C++ sizeof == 0x20
struct OrbisVideodec2FrameBuffer:
    thisSize: mutable u64
    frameBuffer: mutable u64
    frameBufferSize: mutable u64
    isAccepted: mutable bool

# expected C++ sizeof == 0x18
struct OrbisVideodec2ComputeMemoryInfo:
    thisSize: mutable u64
    cpuGpuMemorySize: mutable u64
    cpuGpuMemory: mutable u64

# expected C++ sizeof == 0x10
struct OrbisVideodec2ComputeConfigInfo:
    thisSize: mutable u64
    computePipeId: mutable u16
    computeQueueId: mutable u16
    checkMemoryType: mutable bool
    reserved0: mutable u8
    reserved1: mutable u16
