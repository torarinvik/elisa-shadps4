include "./videodec_ffi.elisa"

type OrbisVideodecConfigInfo = VideodecElisaConfigInfo
type OrbisVideodecResourceInfo = VideodecElisaResourceInfo
type OrbisVideodecCtrl = VideodecElisaCtrl
type OrbisVideodecFrameBuffer = VideodecElisaFrameBuffer
type OrbisVideodecPictureInfo = VideodecElisaPictureInfo
type OrbisVideodecInputData = VideodecElisaInputData

type OrbisVideodec2DecoderConfigInfo = Videodec2ElisaDecoderConfigInfo
type OrbisVideodec2DecoderMemoryInfo = Videodec2ElisaDecoderMemoryInfo
type OrbisVideodec2InputData = Videodec2ElisaInputData
type OrbisVideodec2OutputInfo = Videodec2ElisaOutputInfo
type OrbisVideodec2FrameBuffer = Videodec2ElisaFrameBuffer
type OrbisVideodec2ComputeMemoryInfo = Videodec2ElisaComputeMemoryInfo
type OrbisVideodec2ComputeConfigInfo = Videodec2ElisaComputeConfigInfo
type OrbisVideodec2AvcPictureInfo = Videodec2ElisaAvcPictureInfo

def videodec_native_result(rc: s32) -> int:
    return (rc as u32) as int

def sceVideodecCreateDecoder(pCfgInfoIn: OrbisVideodecConfigInfo&?, pRsrcInfoIn: OrbisVideodecResourceInfo&?, pCtrlOut: mutable OrbisVideodecCtrl&?) -> int:
    return videodec_native_result(c_videodec_create_decoder(pCfgInfoIn, pRsrcInfoIn, pCtrlOut))

def sceVideodecDecode(pCtrlIn: mutable OrbisVideodecCtrl&?, pInputDataIn: OrbisVideodecInputData&?, pFrameBufferInOut: mutable OrbisVideodecFrameBuffer&?, pPictureInfoOut: mutable OrbisVideodecPictureInfo&?) -> int:
    return videodec_native_result(c_videodec_decode(pCtrlIn, pInputDataIn, pFrameBufferInOut, pPictureInfoOut))

def sceVideodecDeleteDecoder(pCtrlIn: mutable OrbisVideodecCtrl&?) -> int:
    return videodec_native_result(c_videodec_delete_decoder(pCtrlIn))

def sceVideodecFlush(pCtrlIn: mutable OrbisVideodecCtrl&?, pFrameBufferInOut: mutable OrbisVideodecFrameBuffer&?, pPictureInfoOut: mutable OrbisVideodecPictureInfo&?) -> int:
    return videodec_native_result(c_videodec_flush(pCtrlIn, pFrameBufferInOut, pPictureInfoOut))

def sceVideodecMapMemory() -> int:
    return videodec_native_result(c_videodec_map_memory())

def sceVideodecQueryResourceInfo(pCfgInfoIn: OrbisVideodecConfigInfo&?, pRsrcInfoOut: mutable OrbisVideodecResourceInfo&?) -> int:
    return videodec_native_result(c_videodec_query_resource_info(pCfgInfoIn, pRsrcInfoOut))

def sceVideodecReset(pCtrlIn: mutable OrbisVideodecCtrl&?) -> int:
    return videodec_native_result(c_videodec_reset(pCtrlIn))

def sceVideodec2QueryComputeMemoryInfo(computeMemInfo: mutable OrbisVideodec2ComputeMemoryInfo&?) -> s32:
    return c_videodec2_query_compute_memory_info(computeMemInfo)

def sceVideodec2AllocateComputeQueue(computeCfgInfo: OrbisVideodec2ComputeConfigInfo&?, computeMemInfo: OrbisVideodec2ComputeMemoryInfo&?, computeQueue: mutable OrbisVideodec2ComputeQueue&?) -> s32:
    return c_videodec2_allocate_compute_queue(computeCfgInfo, computeMemInfo, computeQueue)

def sceVideodec2ReleaseComputeQueue(computeQueue: OrbisVideodec2ComputeQueue) -> s32:
    return c_videodec2_release_compute_queue(computeQueue)

def sceVideodec2QueryDecoderMemoryInfo(decoderCfgInfo: OrbisVideodec2DecoderConfigInfo&?, decoderMemInfo: mutable OrbisVideodec2DecoderMemoryInfo&?) -> s32:
    return c_videodec2_query_decoder_memory_info(decoderCfgInfo, decoderMemInfo)

def sceVideodec2CreateDecoder(decoderCfgInfo: OrbisVideodec2DecoderConfigInfo&?, decoderMemInfo: OrbisVideodec2DecoderMemoryInfo&?, decoder: mutable OrbisVideodec2Decoder&?) -> s32:
    return c_videodec2_create_decoder(decoderCfgInfo, decoderMemInfo, decoder)

def sceVideodec2DeleteDecoder(decoder: OrbisVideodec2Decoder) -> s32:
    return c_videodec2_delete_decoder(decoder)

def sceVideodec2Decode(decoder: OrbisVideodec2Decoder, inputData: OrbisVideodec2InputData&?, frameBuffer: mutable OrbisVideodec2FrameBuffer&?, outputInfo: mutable OrbisVideodec2OutputInfo&?) -> s32:
    return c_videodec2_decode(decoder, inputData, frameBuffer, outputInfo)

def sceVideodec2Flush(decoder: OrbisVideodec2Decoder, frameBuffer: mutable OrbisVideodec2FrameBuffer&?, outputInfo: mutable OrbisVideodec2OutputInfo&?) -> s32:
    return c_videodec2_flush(decoder, frameBuffer, outputInfo)

def sceVideodec2Reset(decoder: OrbisVideodec2Decoder) -> s32:
    return c_videodec2_reset(decoder)

def sceVideodec2GetPictureInfo(outputInfo: OrbisVideodec2OutputInfo&?, p1stPictureInfoOut: mutable void&?, p2ndPictureInfoOut: mutable void&?) -> s32:
    return c_videodec2_get_picture_info(outputInfo, p1stPictureInfoOut, p2ndPictureInfoOut)

def sceVideodec2GetAvcPictureInfo(outputInfo: OrbisVideodec2OutputInfo&?, p1stPictureInfoOut: mutable void&?, p2ndPictureInfoOut: mutable void&?) -> s32:
    return c_videodec2_get_avc_picture_info(outputInfo, p1stPictureInfoOut, p2ndPictureInfoOut)

def Videodec_RegisterLib(sym: void&?) -> void:
    c_videodec_register_lib(sym)

def Videodec2_RegisterLib(sym: void&?) -> void:
    c_videodec2_register_lib(sym)
