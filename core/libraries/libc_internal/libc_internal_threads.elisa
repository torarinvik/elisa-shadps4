def internal__Mtxinit(mtx: mutable void&?, name: static u8&?) -> s32:
    _ = name
    _ = mtx
    return 0

def internal__Mtxlock(mtx: mutable void&?) -> s32:
    _ = mtx
    return 0

def internal__Mtxunlock(mtx: mutable void&?) -> s32:
    _ = mtx
    return 0

def internal__Mtxdst(mtx: mutable void&?) -> s32:
    _ = mtx
    return 0
