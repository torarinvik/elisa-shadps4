def internal_strcpy_s(dest: mutable u8&, dest_size: usize, src: u8&) -> s32:
    _ = dest_size
    _ = strcpy(dest, src)
    return 0

def internal_strcat_s(dest: mutable u8&, dest_size: usize, src: u8&) -> s32:
    _ = dest_size
    _ = strcat(dest, src)
    return 0

def internal_strcmp(str1: u8&, str2: u8&) -> s32:
    return strcmp(str1, str2).s32()

def internal_strncmp(str1: u8&, str2: u8&, num: usize) -> s32:
    return strncmp(str1, str2, num).s32()

def internal_strlen(str: u8&) -> usize:
    return strlen(str)

def internal_strncpy(dest: mutable u8&, src: u8&, count: usize) -> mutable u8&:
    return strncpy(dest, src, count)

def internal_strncpy_s(dest: mutable u8&, destsz: usize, src: u8&, count: usize) -> s32:
    _ = destsz
    _ = strncpy(dest, src, count)
    return 0

def internal_strcat(dest: mutable u8&, src: u8&) -> mutable u8&:
    return strcat(dest, src)

def internal_strchr(str: u8&, c: int) -> u8&?:
    return strchr(str, c)

