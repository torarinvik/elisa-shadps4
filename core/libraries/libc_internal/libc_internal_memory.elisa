extern malloc(size: usize) -> mutable void&?
extern free(ptr: mutable void&) -> void
extern memcmp(s1: void&, s2: void&, n: usize) -> s32

def internal_memset(s: mutable void&, c: int, n: usize) -> mutable void&:
    return memset(s, c, n)

def internal_memcpy(dest: mutable void&, src: void&, n: usize) -> mutable void&:
    return memcpy(dest, src, n)

def internal_memcpy_s(dest: mutable void&, destsz: usize, src: void&, count: usize) -> s32:
    _ = destsz
    _ = memcpy(dest, src, count)
    return 0

def internal_memcmp(s1: void&, s2: void&, n: usize) -> s32:
    return memcmp(s1, s2, n)

# Guest-heap arena for the libc malloc HLE.
#
# shadPS4's internal_malloc is `return std::malloc(size);` — but that only works
# because shadPS4 runs on x86 hosts where the emulator process and the guest share one
# clean libc world. On Elisa's cross-substrate model (x86_64 guest under Rosetta,
# host TLS via %gs, guest TLS via an LDT %fs, guest code on a guest stack), calling
# host libsystem malloc from inside guarded guest execution faults: libsystem reads a
# null zone pointer from its global zone table (the 0x68 boot fault, root-caused via
# the emergency tape). The contract internal_malloc must satisfy is only "return a
# writable, guest-usable block"; under single-view memory (guest VA == host VA) a host
# anonymous mapping satisfies that directly. So back the HLE with our own arena instead
# of dragging host libsystem's hidden global state into the guest world.
#
# Bump allocator over one large anonymous region (reserved once). free() is a no-op for
# now (the region is large enough for boot/libc init); a size-classed free list is the
# obvious follow-up if a workload exhausts the arena.
const LIBC_HEAP_ARENA_SIZE: u64 = 256 * 1024 * 1024
const LIBC_HEAP_ALIGN: u64 = 16
global mutable libc_heap_cursor: u64 = 0
global mutable libc_heap_limit: u64 = 0
global mutable libc_heap_bytes_served: u64 = 0

# Uninitialized-memory poisoning (opt-in via ELISA_POISON_UNINIT). malloc memory is
# uninitialized by contract, so filling each freshly-handed-out block with a recognizable
# non-canonical pattern (0xBE bytes -> 8-byte reads = 0xBEBEBEBEBEBEBEBE) turns a
# use-before-init bug from a silent wrong value into a loud, self-identifying fault: a
# pointer read from the block dereferences 0xBEBE... (non-canonical -> debug_referee flags
# it; the fault address screams "poisoned/uninitialized" instead of looking like garbage).
# Safe because the block's contents are undefined until the caller writes them; never
# applied to .bss/loaded segments (which must keep their zero/file contents).
const LIBC_POISON_BYTE: int = 0xBE
# 0=unchecked, 1=on, 2=off. Resolved once from the environment.
global mutable libc_poison_state: int = 0

def libc_heap_poison_enabled() -> bool:
    if libc_heap_poison_state_unset():
        if getenv("ELISA_POISON_UNINIT".cast[u8&]) != null:
            libc_poison_state <- 1
        else:
            libc_poison_state <- 2
    return libc_poison_state == 1

def libc_heap_poison_state_unset() -> bool:
    return libc_poison_state == 0

def libc_heap_align_up(value: u64, alignment: u64) -> u64:
    remainder: u64 = value % alignment
    if remainder == 0:
        return value
    return value + (alignment - remainder)

def libc_heap_alloc(size: u64) -> mutable void&? can[Unsafe.SegmentMutation, Segment.Host]:
    request: mutable u64 = size
    if request == 0:
        request <- 1
    request <- libc_heap_align_up(request, LIBC_HEAP_ALIGN)
    if libc_heap_limit == 0:
        base: VAddr = GuestExec_AllocateRegion(LIBC_HEAP_ARENA_SIZE, 3)
        if base == 0.uintptr():
            return null
        libc_heap_cursor <- base.u64()
        libc_heap_limit <- base.u64() + LIBC_HEAP_ARENA_SIZE
    start: u64 = libc_heap_align_up(libc_heap_cursor, LIBC_HEAP_ALIGN)
    if start + request > libc_heap_limit:
        return null
    libc_heap_cursor <- start + request
    libc_heap_bytes_served <- libc_heap_bytes_served + request
    block: mutable void&? = start.uintptr().cast[mutable void&?]
    if block != null and libc_heap_poison_enabled():
        _ = memset(block.cast[mutable void&], LIBC_POISON_BYTE, request.usize())
    return block

# @port core/libraries/libc_internal/libc_internal_memory.cpp::internal_malloc
# Oracle: `void* internal_malloc(u64 size) { return std::malloc(size); }` (NID
# gQX+4GDQjpM). Backed by the guest-heap arena (see above) rather than host malloc,
# to avoid host libsystem's null-zone fault under guarded guest execution.
def internal_malloc(size: u64) -> mutable void&? can[Unsafe.SegmentMutation, Segment.Host, Memory.Allocate]:
    result: mutable void&? = null
    can Unsafe.SegmentMutation, Segment.Host, Memory.Allocate:
        GuestExec_RecordRuntimeHle("libSceLibcInternal", "malloc_enter", size.uintptr(), 0.uintptr(), 0.uintptr(), 0.uintptr())
        result <- libc_heap_alloc(size)
        GuestExec_RecordRuntimeHle("libSceLibcInternal", "malloc", size.uintptr(), 0.uintptr(), 0.uintptr(), result.uintptr())
        # Canary: only record when the guest-heap arena hands back NULL (arena not
        # reserved, exhausted, or oversized request). a=size, b=cursor, c=limit, d=0.
        # Low-noise: nothing is emitted on the common success path.
        if result == null:
            GuestExec_EmergencyMark(141, size.uintptr(), libc_heap_cursor.uintptr(), libc_heap_limit.uintptr(), 0.uintptr())
    return result

# @port core/libraries/libc_internal/libc_internal_memory.cpp::internal_free
# Oracle: `void internal_free(void* ptr) { std::free(ptr); }` (NID tIhsqj0qsFE).
# No-op against the bump arena for now (see LIBC_HEAP note); records the call.
def internal_free(ptr: void&?) -> void can[Unsafe.SegmentMutation, Segment.Host, Memory.Allocate]:
    can Unsafe.SegmentMutation, Segment.Host, Memory.Allocate:
        GuestExec_RecordRuntimeHle("libSceLibcInternal", "free_enter", ptr.uintptr(), 0.uintptr(), 0.uintptr(), 0.uintptr())
        _ = ptr
        GuestExec_RecordRuntimeHle("libSceLibcInternal", "free", ptr.uintptr(), 0.uintptr(), 0.uintptr(), 0.uintptr())

def sceLibcMspaceCreate(name: void&?, base: mutable void&?, capacity: u64, flags: u64) -> mutable void&? can[Unsafe.SegmentMutation, Segment.Host, Memory.Allocate]:
    can Unsafe.SegmentMutation, Segment.Host, Memory.Allocate:
        GuestExec_RecordRuntimeHle("libSceLibcInternal", "sceLibcMspaceCreate_enter", name.uintptr(), base.uintptr(), capacity.uintptr(), flags.uintptr())

        # shadPS4 resolves this Aerolib entry as a callable stub and the common
        # stub returns zero. Preserve that behavior while making the NID resolve
        # to executable code instead of the libc_application_heap_api data slot.
        GuestExec_RecordRuntimeHle("libSceLibcInternal", "sceLibcMspaceCreate", name.uintptr(), base.uintptr(), capacity.uintptr(), 0.uintptr())

        # Faithful aerolib-fallback stub (matches shadPS4's AeroLib::GetStub → 0).
        # This is only reachable if the loaded guest libc.prx does NOT export
        # sceLibcMspaceCreate; normally resolution finds the real PRX export and
        # the mspace is created by guest code, so this stub is never hit.
        return null
