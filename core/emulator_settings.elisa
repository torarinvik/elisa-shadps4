include "../common/types.elisa"

enum ConfigMode:
    Default
    Global
    Clean

struct GameInstallDir:
    path: mutable static u8&
    enabled: mutable bool

struct EmulatorSettingsImpl:
    game_install_dirs: mutable darray[GameInstallDir]
    addon_install_dir: mutable static u8&
    home_dir: mutable static u8&
    sys_modules_dir: mutable static u8&
    fonts_dir: mutable static u8&
    show_fps_counter: mutable bool
    full_screen: mutable bool
    config_mode: mutable ConfigMode
    loaded: mutable bool
    log_append: mutable bool

global mutable emulator_settings_singleton: EmulatorSettingsImpl = EmulatorSettingsImpl(
    [],
    "",
    "",
    "",
    "",
    false,
    false,
    ConfigMode.Default,
    false,
    false
)

def EmulatorSettings_New() -> EmulatorSettingsImpl:
    return EmulatorSettingsImpl([], "", "", "", "", false, false, ConfigMode.Default, false, false)

def EmulatorSettings_GetInstance() -> mutable EmulatorSettingsImpl&:
    return emulator_settings_singleton.ref[mutable EmulatorSettingsImpl&]

def EmulatorSettings_SetInstance(instance: EmulatorSettingsImpl&) -> void:
    emulator_settings_singleton <- instance

def EmulatorSettings_Load(self: mutable EmulatorSettingsImpl&, serial: static u8&) -> bool:
    _ = serial
    if self.loaded:
        return true
    if self.home_dir.len == 0:
        self.home_dir <- "./user"
    if self.sys_modules_dir.len == 0:
        self.sys_modules_dir <- "./sys_modules"
    if self.fonts_dir.len == 0:
        self.fonts_dir <- "./fonts"
    self.loaded <- true
    return true

def EmulatorSettings_Save(self: EmulatorSettingsImpl&, serial: static u8&) -> bool:
    _ = self
    _ = serial
    return true

def EmulatorSettings_SetDefaultValues(self: mutable EmulatorSettingsImpl&) -> void:
    self.game_install_dirs.clear()
    self.addon_install_dir <- ""
    self.home_dir <- "./user"
    self.sys_modules_dir <- "./sys_modules"
    self.fonts_dir <- "./fonts"
    self.show_fps_counter <- false
    self.full_screen <- false
    self.config_mode <- ConfigMode.Default
    self.loaded <- true
    self.log_append <- false

def EmulatorSettings_TransferSettings(self: EmulatorSettingsImpl&) -> bool:
    _ = self
    return true

def EmulatorSettings_GetConfigMode(self: EmulatorSettingsImpl&) -> ConfigMode:
    return self.config_mode

def EmulatorSettings_SetConfigMode(self: mutable EmulatorSettingsImpl&, mode: ConfigMode) -> void:
    self.config_mode <- mode

def EmulatorSettings_ClearGameSpecificOverrides(self: mutable EmulatorSettingsImpl&) -> void:
    _ = self

def EmulatorSettings_ResetGameSpecificValue(self: mutable EmulatorSettingsImpl&, key: static u8&) -> void:
    _ = key
    _ = self

def EmulatorSettings_AddGameInstallDir(self: mutable EmulatorSettingsImpl&, dir: static u8&, enabled: bool) -> bool:
    for i in 0..<self.game_install_dirs.count:
        if streq(self.game_install_dirs[i].path, dir) == 1:
            self.game_install_dirs[i].enabled <- enabled
            return false
    self.game_install_dirs.push(GameInstallDir(dir, enabled))
    return true

def EmulatorSettings_GetGameInstallDirs(self: EmulatorSettingsImpl&) -> darray[static u8&]:
    out: mutable darray[static u8&] = []
    for i in 0..<self.game_install_dirs.count:
        if self.game_install_dirs[i].enabled:
            out.push(self.game_install_dirs[i].path)
    return out

def EmulatorSettings_GetAllGameInstallDirs(self: EmulatorSettingsImpl&) -> darray[GameInstallDir]:
    return self.game_install_dirs

def EmulatorSettings_SetAllGameInstallDirs(self: mutable EmulatorSettingsImpl&, dirs: darray[GameInstallDir]) -> void:
    self.game_install_dirs <- dirs

def EmulatorSettings_RemoveGameInstallDir(self: mutable EmulatorSettingsImpl&, dir: static u8&) -> void:
    i: mutable usize = 0
    while i < self.game_install_dirs.count:
        if streq(self.game_install_dirs[i].path, dir) == 1:
            j: mutable usize = i
            while j + 1 < self.game_install_dirs.count:
                self.game_install_dirs[j] <- self.game_install_dirs[j + 1]
                j <- j + 1
            _ = self.game_install_dirs.pop()
            return
        i <- i + 1

def EmulatorSettings_SetGameInstallDirEnabled(self: mutable EmulatorSettingsImpl&, dir: static u8&, enabled: bool) -> void:
    for i in 0..<self.game_install_dirs.count:
        if streq(self.game_install_dirs[i].path, dir) == 1:
            self.game_install_dirs[i].enabled <- enabled
            return

def EmulatorSettings_GetHomeDir(self: EmulatorSettingsImpl&) -> static u8&:
    return self.home_dir

def EmulatorSettings_SetHomeDir(self: mutable EmulatorSettingsImpl&, dir: static u8&) -> void:
    self.home_dir <- dir

def EmulatorSettings_GetSysModulesDir(self: EmulatorSettingsImpl&) -> static u8&:
    return self.sys_modules_dir

def EmulatorSettings_SetSysModulesDir(self: mutable EmulatorSettingsImpl&, dir: static u8&) -> void:
    self.sys_modules_dir <- dir

def EmulatorSettings_GetFontsDir(self: EmulatorSettingsImpl&) -> static u8&:
    return self.fonts_dir

def EmulatorSettings_SetFontsDir(self: mutable EmulatorSettingsImpl&, dir: static u8&) -> void:
    self.fonts_dir <- dir

def EmulatorSettings_GetAddonInstallDir(self: EmulatorSettingsImpl&) -> static u8&:
    return self.addon_install_dir

def EmulatorSettings_SetAddonInstallDir(self: mutable EmulatorSettingsImpl&, dir: static u8&) -> void:
    self.addon_install_dir <- dir

def EmulatorSettings_IsShowFpsCounter(self: EmulatorSettingsImpl&) -> bool:
    return self.show_fps_counter

def EmulatorSettings_SetShowFpsCounter(self: mutable EmulatorSettingsImpl&, enabled: bool) -> void:
    self.show_fps_counter <- enabled

def EmulatorSettings_IsFullScreen(self: EmulatorSettingsImpl&) -> bool:
    return self.full_screen

def EmulatorSettings_SetFullScreen(self: mutable EmulatorSettingsImpl&, enabled: bool) -> void:
    self.full_screen <- enabled

def EmulatorSettings_IsLogAppend(self: EmulatorSettingsImpl&) -> bool:
    return self.log_append

def EmulatorSettings_SetLogAppend(self: mutable EmulatorSettingsImpl&, enabled: bool) -> void:
    self.log_append <- enabled
