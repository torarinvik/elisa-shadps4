struct SRandomDevice:
    handle: mutable u32

def SRandomDevice_new(handle: u32) -> SRandomDevice:
    return SRandomDevice(handle)

def SRandomDevice_Create(handle: u32, path: static u8& = "", flags: s32 = 0, mode: u16 = 0) -> SRandomDevice:
    _ = path
    _ = flags
    _ = mode
    return SRandomDevice_new(handle)

def SRandomDevice_ioctl(self: mutable SRandomDevice&, cmd: u64, args: mutable VaCtx&?) -> s32:
    _ = self
    return Device_StubIoctl("SRandomDevice ioctl stubbed", cmd, args)

def SRandomDevice_write(self: mutable SRandomDevice&, buf: void&?, nbytes: u64) -> s64:
    _ = self
    return Device_StubWrite("SRandomDevice write stubbed", buf, nbytes)

def SRandomDevice_readv(self: mutable SRandomDevice&, iov: OrbisKernelIovec&?, iovcnt: s32) -> s64:
    _ = self
    return Device_StubReadv("SRandomDevice readv stubbed", iov, iovcnt)

def SRandomDevice_writev(self: mutable SRandomDevice&, iov: OrbisKernelIovec&?, iovcnt: s32) -> s64:
    _ = self
    return Device_StubWritev("SRandomDevice writev stubbed", iov, iovcnt)

def SRandomDevice_preadv(self: mutable SRandomDevice&, iov: OrbisKernelIovec&?, iovcnt: s32, offset: s64) -> s64:
    _ = self
    return Device_StubPreadv("SRandomDevice preadv stubbed", iov, iovcnt, offset)

def SRandomDevice_lseek(self: mutable SRandomDevice&, offset: s64, whence: s32) -> s64:
    _ = self
    return Device_StubLseek("SRandomDevice lseek stubbed", offset, whence)

def SRandomDevice_read(self: mutable SRandomDevice&, buf: mutable void&?, nbytes: u64) -> s64:
    _ = self
    return Device_FillRandom(buf, nbytes, false)

def SRandomDevice_fstat(self: mutable SRandomDevice&, sb: mutable OrbisKernelStat&?) -> s32:
    _ = self
    return Device_StatCharacter(sb)

def SRandomDevice_fsync(self: mutable SRandomDevice&) -> s32:
    _ = self
    return Device_StubFsync("SRandomDevice fsync stubbed")

def SRandomDevice_ftruncate(self: mutable SRandomDevice&, length: s64) -> s32:
    _ = self
    return Device_StubFtruncate("SRandomDevice ftruncate stubbed", length)

def SRandomDevice_getdents(self: mutable SRandomDevice&, buf: mutable void&?, nbytes: u32, basep: mutable s64&?) -> s64:
    _ = self
    return Device_StubGetdents("SRandomDevice getdents stubbed", buf, nbytes, basep)

def SRandomDevice_pwrite(self: mutable SRandomDevice&, buf: void&?, nbytes: u64, offset: s64) -> s64:
    _ = self
    return Device_StubPwrite("SRandomDevice pwrite stubbed", buf, nbytes, offset)
