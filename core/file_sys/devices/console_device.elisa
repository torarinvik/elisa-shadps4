struct ConsoleDevice:
    handle: mutable u32

def ConsoleDevice_new(handle: u32) -> ConsoleDevice:
    return ConsoleDevice(handle)

def ConsoleDevice_Create(handle: u32, path: static u8& = "", flags: s32 = 0, mode: u16 = 0) -> ConsoleDevice:
    _ = path
    _ = flags
    _ = mode
    return ConsoleDevice_new(handle)

def ConsoleDevice_ioctl(self: mutable ConsoleDevice&, cmd: u64, args: mutable VaCtx&?) -> s32:
    _ = self
    return Device_StubIoctl("ConsoleDevice ioctl stubbed", cmd, args)

def ConsoleDevice_write(self: mutable ConsoleDevice&, buf: void&?, nbytes: u64) -> s64:
    _ = self
    return Device_StubWrite("ConsoleDevice write stubbed", buf, nbytes)

def ConsoleDevice_readv(self: mutable ConsoleDevice&, iov: OrbisKernelIovec&?, iovcnt: s32) -> s64:
    _ = self
    return Device_StubReadv("ConsoleDevice readv stubbed", iov, iovcnt)

def ConsoleDevice_writev(self: mutable ConsoleDevice&, iov: OrbisKernelIovec&?, iovcnt: s32) -> s64:
