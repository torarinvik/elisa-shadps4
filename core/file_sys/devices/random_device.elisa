const DEVICE_CHAR_MODE: u32 = 8703

struct RandomDevice:
    handle: mutable u32

def RandomDevice_new(handle: u32) -> RandomDevice:
    return RandomDevice(handle)

def RandomDevice_Create(handle: u32, path: static u8& = "", flags: s32 = 0, mode: u16 = 0) -> RandomDevice:
    _ = path
    _ = flags
    _ = mode
    return RandomDevice_new(handle)

def Device_FillRandom(buf: mutable void&?, nbytes: u64, mask_byte: bool) -> s64:
    if buf == null:
        return 0
    out: mutable u8& = buf.cast[mutable u8&]
    i: mutable u64 = 0
    while i < nbytes:
        value: mutable int = rand()
        if mask_byte:
            value <- value & 0xff
        out[i.usize()] <- value.u8()
        i <- i + 1
    return nbytes.i64()

def Device_StatCharacter(sb: mutable OrbisKernelStat&?) -> s32:
    if sb == null:
        return 0
    stat: mutable OrbisKernelStat& = sb
    stat.st_mode <- DEVICE_CHAR_MODE
    return 0

def RandomDevice_ioctl(self: mutable RandomDevice&, cmd: u64, args: mutable VaCtx&?) -> s32:
    _ = self
    return Device_StubIoctl("RandomDevice ioctl stubbed", cmd, args)

def RandomDevice_write(self: mutable RandomDevice&, buf: void&?, nbytes: u64) -> s64:
    _ = self
    return Device_StubWrite("RandomDevice write stubbed", buf, nbytes)

def RandomDevice_readv(self: mutable RandomDevice&, iov: OrbisKernelIovec&?, iovcnt: s32) -> s64:
    _ = self
    return Device_StubReadv("RandomDevice readv stubbed", iov, iovcnt)

def RandomDevice_writev(self: mutable RandomDevice&, iov: OrbisKernelIovec&?, iovcnt: s32) -> s64:
    _ = self
    return Device_StubWritev("RandomDevice writev stubbed", iov, iovcnt)

def RandomDevice_preadv(self: mutable RandomDevice&, iov: OrbisKernelIovec&?, iovcnt: s32, offset: s64) -> s64:
    _ = self
    return Device_StubPreadv("RandomDevice preadv stubbed", iov, iovcnt, offset)

def RandomDevice_lseek(self: mutable RandomDevice&, offset: s64, whence: s32) -> s64:
    _ = self
    return Device_StubLseek("RandomDevice lseek stubbed", offset, whence)

def RandomDevice_read(self: mutable RandomDevice&, buf: mutable void&?, nbytes: u64) -> s64:
    _ = self
    return Device_FillRandom(buf, nbytes, true)

def RandomDevice_fstat(self: mutable RandomDevice&, sb: mutable OrbisKernelStat&?) -> s32:
    _ = self
    return Device_StatCharacter(sb)

def RandomDevice_fsync(self: mutable RandomDevice&) -> s32:
    _ = self
    return Device_StubFsync("RandomDevice fsync stubbed")

def RandomDevice_ftruncate(self: mutable RandomDevice&, length: s64) -> s32:
    _ = self
    return Device_StubFtruncate("RandomDevice ftruncate stubbed", length)

def RandomDevice_getdents(self: mutable RandomDevice&, buf: mutable void&?, nbytes: u32, basep: mutable s64&?) -> s64:
    _ = self
    return Device_StubGetdents("RandomDevice getdents stubbed", buf, nbytes, basep)

def RandomDevice_pwrite(self: mutable RandomDevice&, buf: void&?, nbytes: u64, offset: s64) -> s64:
    _ = self
    return Device_StubPwrite("RandomDevice pwrite stubbed", buf, nbytes, offset)
