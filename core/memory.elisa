include "../common/types.elisa"
include "./address_space.elisa"
include "./guest_exec.elisa"
include "./ord.elisa"

type MemoryProt = u32
const MemoryProt_NoAccess: MemoryProt = 0
const MemoryProt_CpuRead: MemoryProt = 1
const MemoryProt_CpuWrite: MemoryProt = 2
const MemoryProt_CpuReadWrite: MemoryProt = 3
const MemoryProt_CpuExec: MemoryProt = 4
const MemoryProt_GpuRead: MemoryProt = 16
const MemoryProt_GpuWrite: MemoryProt = 32
const MemoryProt_GpuReadWrite: MemoryProt = 48

type MemoryMapFlags = u32
const MemoryMapFlags_NoFlags: MemoryMapFlags = 0
const MemoryMapFlags_Shared: MemoryMapFlags = 1
const MemoryMapFlags_Private: MemoryMapFlags = 2
const MemoryMapFlags_Fixed: MemoryMapFlags = 0x10
const MemoryMapFlags_NoOverwrite: MemoryMapFlags = 0x80
const MemoryMapFlags_Void: MemoryMapFlags = 0x100
const MemoryMapFlags_Stack: MemoryMapFlags = 0x400
const MemoryMapFlags_Anon: MemoryMapFlags = 0x1000

const ORBIS_KERNEL_FLEXIBLE_MEMORY_BASE: u64 = 64 * 1024 * 1024
const ORBIS_KERNEL_FLEXIBLE_MEMORY_SIZE: u64 = 512 * 1024 * 1024
const ORBIS_KERNEL_TOTAL_MEM: u64 = 5248 * 1024 * 1024

# Maps at/above this size skip the byte-by-byte MappedMemoryBytes backing under guest-exec
# (single view: native MAP_FIXED is the real storage). 64MB sits above the largest guest
# module image (~48MB eboot, which still needs a backing for relocation reads) and below
# the guest's large runtime heaps/direct-memory pools (256MB..GBs), which do not.
const MEMORY_NATIVE_ONLY_BACKING_THRESHOLD: u64 = 64 * 1024 * 1024

type PhysicalMemoryType = u32
const PhysicalMemoryType_Free: PhysicalMemoryType = 0
const PhysicalMemoryType_Allocated: PhysicalMemoryType = 1
const PhysicalMemoryType_Mapped: PhysicalMemoryType = 2
const PhysicalMemoryType_Pooled: PhysicalMemoryType = 3
const PhysicalMemoryType_Committed: PhysicalMemoryType = 4
const PhysicalMemoryType_Flexible: PhysicalMemoryType = 5

type VMAType = u32
const VMAType_Free: VMAType = 0
const VMAType_Reserved: VMAType = 1
const VMAType_Direct: VMAType = 2
const VMAType_Flexible: VMAType = 3
const VMAType_Pooled: VMAType = 4
const VMAType_PoolReserved: VMAType = 5
const VMAType_Stack: VMAType = 6
const VMAType_Code: VMAType = 7
const VMAType_File: VMAType = 8

struct PhysicalMemoryArea:
    base: mutable PAddr
    size: mutable u64
    memory_type: mutable s32
    dma_type: mutable PhysicalMemoryType

struct PhysicalMemoryAreaBaseKey:
    base: mutable PAddr

impl Ord for PhysicalMemoryAreaBaseKey:
    def le(self: PhysicalMemoryAreaBaseKey, o: PhysicalMemoryAreaBaseKey) -> bool:
        return self.base <= o.base

def PhysicalMemoryArea_BaseKey(area: PhysicalMemoryArea) -> PhysicalMemoryAreaBaseKey:
    return PhysicalMemoryAreaBaseKey(area.base)

def PhysicalMemoryArea_BaseKeysSorted(items: darray[PhysicalMemoryArea]) -> bool:
    if items.count < 2:
        return true
    i: mutable usize = 1
    while i < items.count:
        if not PhysicalMemoryArea_BaseKey(items[i - 1]).le(PhysicalMemoryArea_BaseKey(items[i])):
            return false
        i <- i + 1
    return true

struct VirtualMemoryArea:
    base: mutable VAddr
    size: mutable u64
    vma_type: mutable VMAType
    prot: mutable MemoryProt
    name: mutable static u8&
    fd: mutable s32
    disallow_merge: mutable bool
    # Set while a bulk-write window is active and this VMA received a deferred
    # (un-restored) native write; MemoryManager_EndBulkWriteWindow reprotects and
    # clears it. Independent of the bounded writable-page cache, so it is correct
    # even when that cache overflows/evicts during a large relocation burst.
    bulk_dirty: mutable bool

# Linear map transaction: produced by MemoryManager_MapBegin once the
# AddressSpace mapping has been recorded, and MUST be consumed exactly once by
# either MemoryManager_MapCommit (finalize vma + backing) or
# MemoryManager_MapRollback (undo the AddressSpace mapping). The affine
# discipline makes a partial-failure desync — AddressSpace mapped but the map
# never committed and never rolled back — a compile-time impossibility.
linear struct MapTxn:
    mapped: VAddr
    size: u64

struct MappedMemoryBytes:
    base: mutable VAddr
    size: mutable u64
    bytes: mutable darray[u8]

struct PrtArea:
    start: mutable VAddr
    end: mutable VAddr
    mapped: mutable bool

struct MemoryManager:
    address_space: mutable AddressSpace
    dmem_areas: mutable darray[PhysicalMemoryArea]
    vma_areas: mutable darray[VirtualMemoryArea]
    mapped_bytes: mutable darray[MappedMemoryBytes]
    total_direct_size: mutable u64
    total_flexible_size: mutable u64
    flexible_usage: mutable u64
    pool_budget: mutable u64
    prt_areas: mutable PrtArea[3]

# Persistent arena owning the memory manager's bookkeeping darrays (physical/
# virtual area tables) and, critically, the guest memory backing buffers. These
# all outlive the calls that grow them, so they must NOT be grown inside a
# transient local arena (which is freed on return, leaving the guest memory map
# and GOT in use-after-free storage and making guest execution nondeterministic).
global mutable memory_arena: Arena = zeroed
global mutable memory_last_backing_index: s32 = -1

def Memory_ResetArena() -> void:
    memory_arena <- zeroed
    memory_last_backing_index <- -1

global mutable memory_singleton: MemoryManager = MemoryManager(
    AddressSpace_New(),
    zeroed,
    zeroed,
    zeroed,
    0.u64(),
    0.u64(),
    0.u64(),
    0.u64(),
    [PrtArea(0.uintptr(), 0.uintptr(), false), PrtArea(0.uintptr(), 0.uintptr(), false), PrtArea(0.uintptr(), 0.uintptr(), false)]
)

def MemoryManager_New() -> MemoryManager:
    return MemoryManager(
        AddressSpace_New(),
        zeroed,
        zeroed,
        zeroed,
        0.u64(),
        0.u64(),
        0.u64(),
        0.u64(),
        [PrtArea(0.uintptr(), 0.uintptr(), false), PrtArea(0.uintptr(), 0.uintptr(), false), PrtArea(0.uintptr(), 0.uintptr(), false)]
    )

def Memory_Instance() -> mutable MemoryManager&:
    return &memory_singleton

def MemoryManager_ResetNativeMappings(self: mutable MemoryManager&) -> void:
    if not GuestExec_IsSupported():
        return
    for i in 0..<self.vma_areas.count:
        _ = GuestExec_UnmapRegion(self.vma_areas[i].base, self.vma_areas[i].size)

def Memory_Reset() -> void:
    MemoryManager_ResetNativeMappings(memory_singleton)
    Memory_ResetArena()
    memory_singleton <- MemoryManager_New()

def MemoryManager_GetAddressSpace(self: mutable MemoryManager&) -> mutable AddressSpace&:
    return &self.address_space

def MemoryManager_GetTotalDirectSize(self: MemoryManager&) -> u64:
    ensure result == self.total_direct_size
    return self.total_direct_size

def MemoryManager_GetTotalFlexibleSize(self: MemoryManager&) -> u64:
    ensure result == self.total_flexible_size
    return self.total_flexible_size

def MemoryManager_GetAvailableFlexibleSize(self: MemoryManager&) -> u64:
    # Available flexible memory is always a subset of the total (and the subtraction
    # never underflows — guarded by the usage>=total early return).
    ensure result <= self.total_flexible_size
    if self.flexible_usage >= self.total_flexible_size:
        return 0
    return self.total_flexible_size - self.flexible_usage

def MemoryManager_SystemReservedVirtualBase(self: MemoryManager&) -> VAddr:
    return AddressSpace_SystemReservedVirtualBase(self.address_space)

def MemoryManager_IsValidGpuMapping(self: MemoryManager&, virtual_addr: VAddr, size: u64) -> bool:
    _ = self
    max_gpu_address: VAddr = 0x10000000000.uintptr()
    return virtual_addr < max_gpu_address and size <= (max_gpu_address - virtual_addr).u64()

def VirtualMemoryArea_Contains(self: VirtualMemoryArea&, addr: VAddr, size: u64) -> bool:
    if addr < self.base:
        return false
    if not AddressSpace_RangeNoOverflow(addr.u64(), size) or not AddressSpace_RangeNoOverflow(self.base.u64(), self.size):
        return false
    offset: u64 = (addr - self.base).u64()
    return offset <= self.size and size <= (self.size - offset)

def VirtualMemoryArea_Overlaps(self: VirtualMemoryArea&, addr: VAddr, size: u64) -> bool:
    return AddressSpace_RangesOverlap(addr.u64(), size, self.base.u64(), self.size)

def MemoryProt_NormalizeCpu(prot: MemoryProt) -> MemoryProt:
    normalized: mutable MemoryProt = prot
    if (normalized & MemoryProt_CpuWrite) != 0:
        normalized <- normalized | MemoryProt_CpuRead
    return normalized

def MemoryManager_OverlapsMappedArea(self: MemoryManager&, virtual_addr: VAddr, size: u64, allow_reserved: bool) -> bool:
    for i in 0..<self.vma_areas.count:
        area: VirtualMemoryArea = self.vma_areas[i]
        if VirtualMemoryArea_Overlaps(area, virtual_addr, size):
            if allow_reserved and area.vma_type == VMAType_Reserved:
                continue
            return true
    return false

def MemoryManager_FindBestVmaIndex(self: MemoryManager&, addr: VAddr, size: u64) -> s32:
    best_index: mutable s32 = -1
    best_size: mutable u64 = 0xFFFFFFFFFFFFFFFF.u64()
    for i in 0..<self.vma_areas.count:
        area: VirtualMemoryArea = self.vma_areas[i]
        if not VirtualMemoryArea_Contains(area, addr, size):
            continue
        if area.base == addr and area.size == size:
            return i.s32()
        if best_index < 0 or area.size < best_size:
            best_index <- i.s32()
            best_size <- area.size
    return best_index

def MemoryManager_IsValidMapping(self: MemoryManager&, virtual_addr: VAddr, size: u64) -> bool:
    if size == 0:
        for i in 0..<self.vma_areas.count:
            if VirtualMemoryArea_Contains(self.vma_areas[i], virtual_addr, 1):
                return true
        return false
    remaining: mutable u64 = size
    probe: mutable VAddr = virtual_addr
    while remaining > 0:
        can Unsafe.AssumeProgress:
            found: mutable bool = false
            for i in 0..<self.vma_areas.count:
                area: VirtualMemoryArea = self.vma_areas[i]
                if VirtualMemoryArea_Contains(area, probe, 1):
                    found <- true
                    offset: u64 = (probe - area.base).u64()
                    covered: mutable u64 = area.size - offset
                    if covered > remaining:
                        covered <- remaining
                    remaining <- remaining - covered
                    probe <- probe + covered.uintptr()
            if not found:
                return false
    return true

def MemoryManager_AddressIsMapped(self: MemoryManager&, virtual_addr: VAddr, size: u64) -> bool:
    probe_size: mutable u64 = size
    if probe_size == 0:
        probe_size <- 1
    return MemoryManager_IsValidMapping(self, virtual_addr, probe_size)

def MemoryManager_FindNearestVmaRange(self: MemoryManager&, addr: VAddr, start: mutable VAddr&, end: mutable VAddr&, prot: mutable u32&) -> bool:
    if self.vma_areas.count == 0:
        start <- 0.uintptr()
        end <- 0.uintptr()
        prot <- 0
        return false
    best_index: mutable usize = 0
    best_distance: mutable u64 = 0xffffffffffffffff
    for i in 0..<self.vma_areas.count:
        area: VirtualMemoryArea = self.vma_areas[i]
        area_end: VAddr = area.base + area.size.uintptr()
        distance: mutable u64 = 0
        if addr < area.base:
            distance <- (area.base - addr).u64()
        elif addr >= area_end:
            distance <- (addr - area_end).u64()
        if distance < best_distance:
            best_distance <- distance
            best_index <- i
    nearest: VirtualMemoryArea = self.vma_areas[best_index]
    start <- nearest.base
    end <- nearest.base + nearest.size.uintptr()
    prot <- nearest.prot
    return true

def MemoryManager_ClampRangeSize(self: MemoryManager&, virtual_addr: VAddr, size: u64) -> u64:
    # The clamp never returns more than the requested size, so a caller that reads
    # `result` bytes from virtual_addr stays within the bound it asked about.
    ensure result <= size
    if size == 0:
        return 0
    if MemoryManager_IsValidMapping(self, virtual_addr, size):
        return size
    i: mutable u64 = size
    while i > 0:
        if MemoryManager_IsValidMapping(self, virtual_addr, i):
            invariant i <= size
            return i
        i <- i - 1
    return 0

def MemoryManager_SetPrtArea(self: mutable MemoryManager&, id: u32, address: VAddr, size: u64) -> void:
    if id >= 3:
        return
    self.prt_areas[id.usize()] <- PrtArea(address, address + size.uintptr(), true)

def MemoryManager_CopySparseMemory(self: MemoryManager&, source: VAddr, dest: mutable u8&, size: u64) -> void:
    can Memory.Allocate:
        i: mutable u64 = 0
        while i < size:
            dest[i.usize()] <- MemoryManager_ReadU8(self, source + i.uintptr())
            i <- i + 1

def MemoryManager_TryWriteBacking(self: mutable MemoryManager&, address: void&?, data: void&?, size: u64) -> bool:
    # DOGFOOD (guest-exec-fault-path): the backing-write entry point on the relocation /
    # RELRO copy path (the macOS "write the PHYSICAL backing, not the ResolveGuestAddress
    # shadow" fix routes through MemoryManager_WriteBytes below). A null data pointer with a
    # nonzero size is a malformed write request; we surface that as `false` rather than
    # dereferencing. NOTE: a tighter postcondition `(data != null) or (not result) or
    # (size == 0)` does NOT discharge under -strict -smt at the `data != null` return
    # (memory.elisa return of MemoryManager_WriteBytes): the prover drops the `data != null`
    # guard fact across the disjunction (a flow-sensitivity gap, not an unsound call). The
    # null-data branch itself is locally provable; see findings doc.
    can Memory.Allocate:
        if address == null:
            return false
        if data == null:
            return size == 0
        return MemoryManager_WriteBytes(self, address.cast[VAddr], data.cast[u8&], size)

def MemoryManager_TryWriteGuestMemory(self: mutable MemoryManager&, address: void&?, data: void&?, size: u64) -> bool:
    can Memory.Allocate:
        return MemoryManager_TryWriteBacking(self, address, data, size)

def MemoryManager_SetupMemoryRegions(self: mutable MemoryManager&, flexible_size: u64, use_extended_mem1: bool, use_extended_mem2: bool) -> void:
    ensure self.flexible_usage == 0
    ensure self.pool_budget == self.total_flexible_size
    _ = use_extended_mem1
    total_size: mutable u64 = ORBIS_KERNEL_TOTAL_MEM
    if not use_extended_mem2:
        total_size <- total_size - (128 * 1024 * 1024).u64()
    if flexible_size < total_size:
        self.total_direct_size <- total_size - flexible_size
    else:
        self.total_direct_size <- 0
    if flexible_size > ORBIS_KERNEL_FLEXIBLE_MEMORY_BASE:
        self.total_flexible_size <- flexible_size - ORBIS_KERNEL_FLEXIBLE_MEMORY_BASE
    else:
        self.total_flexible_size <- flexible_size
    self.pool_budget <- self.total_flexible_size
    self.flexible_usage <- 0
    owner: mutable Arena& = &memory_arena
    in owner:
        self.dmem_areas.count <- 0
        self.dmem_areas.push(PhysicalMemoryArea(0.uintptr(), self.total_direct_size, 0, PhysicalMemoryType_Free))

def MemoryManager_InsertDmemArea(self: mutable MemoryManager&, index: usize, area: PhysicalMemoryArea) -> void:
    owner: mutable Arena& = &memory_arena
    in owner:
        self.dmem_areas.push(area)
    j: mutable usize = self.dmem_areas.count - 1
    while j > index:
        self.dmem_areas[j] <- self.dmem_areas[j - 1]
        j <- j - 1
    self.dmem_areas[index] <- area

def MemoryManager_RemoveDmemArea(self: mutable MemoryManager&, index: usize) -> void:
    j: mutable usize = index
    can Unsafe.AssumeProgress:
        while j + 1 < self.dmem_areas.count:
            decreases self.dmem_areas.count - j
            self.dmem_areas[j] <- self.dmem_areas[j + 1]
            j <- j + 1
    if self.dmem_areas.count > 0:
        self.dmem_areas.count <- self.dmem_areas.count - 1

def MemoryManager_PoolExpand(self: mutable MemoryManager&, search_start: PAddr, search_end: PAddr, size: u64, alignment: u64) -> PAddr:
    _ = self
    _ = search_end
    _ = alignment
    return search_start + size.uintptr()

def MemoryManager_Allocate(self: mutable MemoryManager&, search_start: PAddr, search_end: PAddr, size: u64, alignment: u64, memory_type: s32) -> PAddr:
    # @port oracle: `alignment = alignment > 0 ? alignment : 16_KB;`
    align: mutable u64 = alignment
    if align == 0:
        align <- 16 * 1024
    owner: mutable Arena& = &memory_arena
    in owner:
        for i in 0..<self.dmem_areas.count:
            area: PhysicalMemoryArea = self.dmem_areas[i]
            if area.dma_type != PhysicalMemoryType_Free:
                continue
            area_start: u64 = area.base.u64()
            if not AddressSpace_RangeNoOverflow(area_start, area.size):
                continue
            area_end: u64 = area_start + area.size
            min_start: mutable u64 = search_start.u64()
            if min_start < area_start:
                min_start <- area_start
            alloc_start: mutable u64 = min_start
            remainder: u64 = alloc_start % align
            if remainder != 0:
                if not AddressSpace_RangeNoOverflow(alloc_start, align - remainder):
                    continue
                alloc_start <- alloc_start + (align - remainder)
            if not AddressSpace_RangeNoOverflow(alloc_start, size):
                continue
            alloc_end: u64 = alloc_start + size
            limit_end: mutable u64 = search_end.u64()
            if limit_end > area_end:
                limit_end <- area_end
            if size == 0 or alloc_end <= alloc_start or alloc_end > limit_end:
                continue

            before_size: u64 = alloc_start - area_start
            after_size: u64 = area_end - alloc_end
            MemoryManager_RemoveDmemArea((&self).cast[mutable MemoryManager&], i)
            if after_size != 0:
                MemoryManager_InsertDmemArea((&self).cast[mutable MemoryManager&], i, PhysicalMemoryArea(alloc_end.uintptr(), after_size, 0, PhysicalMemoryType_Free))
            MemoryManager_InsertDmemArea((&self).cast[mutable MemoryManager&], i, PhysicalMemoryArea(alloc_start.uintptr(), size, memory_type, PhysicalMemoryType_Allocated))
            if before_size != 0:
                MemoryManager_InsertDmemArea((&self).cast[mutable MemoryManager&], i, PhysicalMemoryArea(area_start.uintptr(), before_size, 0, PhysicalMemoryType_Free))
            return alloc_start.uintptr()
    return search_end

# @port core/memory.cpp::MemoryManager::DirectQueryAvailable
# Derives the largest free direct-memory run within [search_start, search_end)
# from the dmem area map (mirrors shadPS4's FindDmemArea scan), rather than from
# a bump cursor. Writes the aligned base and size of that run to the out-params.
def MemoryManager_DirectQueryAvailable(self: MemoryManager&, search_start: PAddr, search_end: PAddr, alignment: u64, phys_addr_out: mutable PAddr&, size_out: mutable u64&) -> s32:
    ensure result == 0
    ss: u64 = search_start.u64()
    se: u64 = search_end.u64()
    paddr: mutable u64 = 0
    max_size: mutable u64 = 0
    for i in 0..<self.dmem_areas.count:
        area: PhysicalMemoryArea = self.dmem_areas[i]
        if area.dma_type != PhysicalMemoryType_Free:
            continue
        area_base: u64 = area.base.u64()
        if not AddressSpace_RangeNoOverflow(area_base, area.size):
            continue
        area_end: u64 = area_base + area.size
        aligned_base: mutable u64 = area_base
        if alignment > 0:
            rem: u64 = area_base % alignment
            if rem != 0:
                if not AddressSpace_RangeNoOverflow(area_base, alignment - rem):
                    continue
                aligned_base <- area_base + (alignment - rem)
        alignment_size: u64 = aligned_base - area_base
        remaining_size: mutable u64 = 0
        if area.size >= alignment_size:
            remaining_size <- area.size - alignment_size
        if area_base < ss:
            # Trim remaining_size to ignore addresses before search_start.
            if remaining_size > (ss - area_base):
                remaining_size <- remaining_size - (ss - area_base)
            else:
                remaining_size <- 0
            if alignment > 0:
                rem2: u64 = ss % alignment
                if rem2 != 0:
                    if not AddressSpace_RangeNoOverflow(ss, alignment - rem2):
                        remaining_size <- 0
                        continue
                    aligned_base <- ss + (alignment - rem2)
                else:
                    aligned_base <- ss
            else:
                aligned_base <- ss
        if area_end > se:
            # Trim remaining_size to ignore addresses beyond search_end.
            if remaining_size > (area_end - se):
                remaining_size <- remaining_size - (area_end - se)
            else:
                remaining_size <- 0
        if remaining_size > max_size:
            paddr <- aligned_base
            max_size <- remaining_size
    phys_addr_out <- paddr.uintptr()
    size_out <- max_size
    return 0

# @port core/memory.cpp::MemoryManager::DirectMemoryType
# Finds the dmem area containing `addr` (mirrors shadPS4's FindDmemArea scan).
# Returns true and writes the area's memory_type + [base, end) when addr lies
# inside a non-free area (allocated/mapped/pooled/committed/flexible); returns
# false when addr falls in a Free run or outside every tracked area, i.e. it is
# not a live direct-memory address. The `ensure` pins the core contract: a true
# result always reports a range that actually contains addr.
def MemoryManager_DirectMemoryType(self: MemoryManager&, addr: PAddr, type_out: mutable s32&, start_out: mutable PAddr&, end_out: mutable PAddr&) -> bool:
    ensure not result or (start_out.u64() <= addr.u64() and addr.u64() < end_out.u64())
    a: u64 = addr.u64()
    for i in 0..<self.dmem_areas.count:
        area: PhysicalMemoryArea = self.dmem_areas[i]
        area_base: u64 = area.base.u64()
        if not AddressSpace_RangeNoOverflow(area_base, area.size):
            continue
        area_end: u64 = area_base + area.size
        if a >= area_base and a < area_end:
            if area.dma_type == PhysicalMemoryType_Free:
                return false
            type_out <- area.memory_type
            start_out <- area.base
            end_out <- area_end.uintptr()
            invariant start_out.u64() <= addr.u64() and addr.u64() < end_out.u64()
            return true
    return false

def MemoryManager_MarkDirectMapped(self: mutable MemoryManager&, phys_addr: PAddr, size: u64, memory_type: s32) -> bool:
    if size == 0:
        return false
    mark_start: u64 = phys_addr.u64()
    if not AddressSpace_RangeNoOverflow(mark_start, size):
        return false
    mark_end: u64 = mark_start + size
    if mark_end <= mark_start:
        return false
    owner: mutable Arena& = &memory_arena
    in owner:
        for i in 0..<self.dmem_areas.count:
            area: PhysicalMemoryArea = self.dmem_areas[i]
            area_start: u64 = area.base.u64()
            if not AddressSpace_RangeNoOverflow(area_start, area.size):
                continue
            area_end: u64 = area_start + area.size
            if mark_start < area_start or mark_end > area_end:
                continue
            if area.dma_type == PhysicalMemoryType_Allocated or area.dma_type == PhysicalMemoryType_Mapped:
                return true
            if area.dma_type != PhysicalMemoryType_Free:
                return false

            before_size: u64 = mark_start - area_start
            after_size: u64 = area_end - mark_end
            MemoryManager_RemoveDmemArea((&self).cast[mutable MemoryManager&], i)
            if after_size != 0:
                MemoryManager_InsertDmemArea((&self).cast[mutable MemoryManager&], i, PhysicalMemoryArea(mark_end.uintptr(), after_size, 0, PhysicalMemoryType_Free))
            MemoryManager_InsertDmemArea((&self).cast[mutable MemoryManager&], i, PhysicalMemoryArea(mark_start.uintptr(), size, memory_type, PhysicalMemoryType_Mapped))
            if before_size != 0:
                MemoryManager_InsertDmemArea((&self).cast[mutable MemoryManager&], i, PhysicalMemoryArea(area_start.uintptr(), before_size, 0, PhysicalMemoryType_Free))
            return true
    return false

def MemoryManager_Free(self: mutable MemoryManager&, phys_addr: PAddr, size: u64, is_checked: bool) -> s32:
    ensure result == 0 or result == -1
    _ = is_checked
    for i in 0..<self.dmem_areas.count:
        if self.dmem_areas[i].base == phys_addr and self.dmem_areas[i].size == size:
            self.dmem_areas[i] <- PhysicalMemoryArea(phys_addr, size, 0, PhysicalMemoryType_Free)
            return 0
    return -1

def MemoryManager_MapMemory(self: mutable MemoryManager&, out_addr: mutable VAddr&, virtual_addr: VAddr, size: u64, prot: MemoryProt, flags: MemoryMapFlags, vma_type: VMAType, name: static u8&, validate_dmem: bool, phys_addr: PAddr, alignment: u64) -> s32:
    ensure result == 0 or result == -1
    _ = validate_dmem
    _ = alignment
    if size == 0 or not AddressSpace_PageAligned(virtual_addr.u64()) or not AddressSpace_PageAligned(size):
        out_addr <- 0.uintptr()
        return -1
    if virtual_addr != 0.uintptr() and not AddressSpace_InAnyReservation(self.address_space, virtual_addr, size):
        out_addr <- 0.uintptr()
        return -1
    if (flags & MemoryMapFlags_NoOverwrite) != 0 and MemoryManager_OverlapsMappedArea(self, virtual_addr, size, false):
        out_addr <- 0.uintptr()
        return -1
    effective_prot: MemoryProt = MemoryProt_NormalizeCpu(prot)
    txn: MapTxn = MemoryManager_MapBegin((&self).cast[mutable MemoryManager&], virtual_addr, size, effective_prot, vma_type, phys_addr)
    mapped: VAddr = txn.mapped
    out_addr <- mapped
    if mapped == 0.uintptr():
        MemoryManager_MapRollback((&self).cast[mutable MemoryManager&], move txn)
        return -1
    if GuestExec_IsEnabled() and GuestExec_IsSupported() and not GuestExec_MapRegion(mapped, size, effective_prot):
        MemoryManager_MapRollback((&self).cast[mutable MemoryManager&], move txn)
        return -1
    MemoryManager_MapCommit((&self).cast[mutable MemoryManager&], move txn, vma_type, effective_prot, name)
    return 0

# Records the AddressSpace mapping and hands back an affine MapTxn that the
# caller must consume via MemoryManager_MapCommit or MemoryManager_MapRollback.
def MemoryManager_MapBegin(self: mutable MemoryManager&, virtual_addr: VAddr, size: u64, effective_prot: MemoryProt, vma_type: VMAType, phys_addr: PAddr) -> MapTxn:
    # Match memory.cpp's impl.Map(mapped_addr, size, phys_addr, is_exec): a Direct
    # mapping is dmem-backed at phys_addr; every other vma_type (Stack/Code/Flexible/
    # Reserved/...) is anonymous-private, which AddressSpace_Map encodes as the -1
    # sentinel. The previous hardcoded 0 made every anonymous region alias dmem
    # offset 0 once AddressSpace began performing real native mappings.
    eff_phys: PAddr = phys_addr if vma_type == VMAType_Direct else AddressSpace_MapFailed()
    mapped: VAddr = AddressSpace_Map(self.address_space, virtual_addr, size, eff_phys, (effective_prot & MemoryProt_CpuExec) != 0)
    return MapTxn(mapped, size)

# Consumes the transaction and finalizes the mapping (vma record + backing).
def MemoryManager_MapCommit(self: mutable MemoryManager&, txn: MapTxn, vma_type: VMAType, effective_prot: MemoryProt, name: static u8&) -> void:
    m: VAddr = txn.mapped
    sz: u64 = txn.size
    _ = move txn
    map_owner: mutable Arena& = &memory_arena
    in map_owner:
        self.vma_areas.push(VirtualMemoryArea(m, sz, vma_type, effective_prot, name, 0, false, false))
    # AddBacking fills a MappedMemoryBytes buffer one byte at a time. For the guest's own
    # large runtime regions (libc heap / direct-memory pools, hundreds of MB to GBs) that
    # is catastrophic — a 3GB libc-heap MapDirectMemory would push ~3.2 billion bytes and
    # trip the guarded-run watchdog. Those large regions are guest-owned and accessed via
    # the native single-view MAP_FIXED mapping, never through the byte buffer (only module
    # images, which are small, are read via the backing for relocation). So skip the byte
    # backing for large maps under guest-exec; keep it for small (module-sized) maps.
    if vma_type != VMAType_Reserved:
        skip_backing: bool = GuestExec_IsEnabled() and GuestExec_IsSupported() and sz >= MEMORY_NATIVE_ONLY_BACKING_THRESHOLD
        if not skip_backing:
            MemoryManager_AddBacking((&self).cast[mutable MemoryManager&], m, sz)

# Consumes the transaction and undoes the AddressSpace mapping (and the native
# guest-exec map, if any) so no half-mapped state survives a failed map.
def MemoryManager_MapRollback(self: mutable MemoryManager&, txn: MapTxn) -> void:
    m: VAddr = txn.mapped
    sz: u64 = txn.size
    _ = move txn
    if m != 0.uintptr():
        if GuestExec_IsEnabled() and GuestExec_IsSupported():
            _ = GuestExec_UnmapRegion(m, sz)
        AddressSpace_Unmap(self.address_space, m, sz)

def MemoryManager_MapFile(self: mutable MemoryManager&, out_addr: mutable VAddr&, virtual_addr: VAddr, size: u64, prot: MemoryProt, flags: MemoryMapFlags, fd: s32, phys_addr: s64) -> s32:
    ensure result == 0 or result == -1
    _ = flags
    if size == 0 or not AddressSpace_PageAligned(virtual_addr.u64()) or not AddressSpace_PageAligned(size):
        out_addr <- 0.uintptr()
        return -1
    if virtual_addr != 0.uintptr() and not AddressSpace_InAnyReservation(self.address_space, virtual_addr, size):
        out_addr <- 0.uintptr()
        return -1
    effective_prot: MemoryProt = MemoryProt_NormalizeCpu(prot)
    txn: MapTxn = MemoryManager_MapFileBegin((&self).cast[mutable MemoryManager&], virtual_addr, size, effective_prot, fd, phys_addr)
    mapped: VAddr = txn.mapped
    out_addr <- mapped
    if mapped == 0.uintptr():
        MemoryManager_MapRollback((&self).cast[mutable MemoryManager&], move txn)
        return -1
    if GuestExec_IsEnabled() and GuestExec_IsSupported() and not GuestExec_MapRegion(mapped, size, effective_prot):
        MemoryManager_MapRollback((&self).cast[mutable MemoryManager&], move txn)
        return -1
    MemoryManager_MapFileCommit((&self).cast[mutable MemoryManager&], move txn, effective_prot, fd)
    return 0

# Records the file-backed AddressSpace mapping and hands back an affine MapTxn
# the caller must consume via MemoryManager_MapFileCommit or MapRollback.
def MemoryManager_MapFileBegin(self: mutable MemoryManager&, virtual_addr: VAddr, size: u64, effective_prot: MemoryProt, fd: s32, phys_addr: s64) -> MapTxn:
    mapped: VAddr = AddressSpace_MapFile(self.address_space, virtual_addr, size, phys_addr.u64(), effective_prot, fd.uintptr())
    return MapTxn(mapped, size)

# Consumes the transaction and finalizes the file mapping (vma record + backing).
def MemoryManager_MapFileCommit(self: mutable MemoryManager&, txn: MapTxn, effective_prot: MemoryProt, fd: s32) -> void:
    m: VAddr = txn.mapped
    sz: u64 = txn.size
    _ = move txn
    file_owner: mutable Arena& = &memory_arena
    in file_owner:
        self.vma_areas.push(VirtualMemoryArea(m, sz, VMAType_File, effective_prot, "file", fd, false, false))
    MemoryManager_AddBacking((&self).cast[mutable MemoryManager&], m, sz)

def MemoryManager_PoolDecommit(self: mutable MemoryManager&, virtual_addr: VAddr, size: u64) -> s32:
    return MemoryManager_UnmapMemory((&self).cast[mutable MemoryManager&], virtual_addr, size)

def MemoryManager_UnmapMemory(self: mutable MemoryManager&, virtual_addr: VAddr, size: u64) -> s32:
    ensure result == 0 or result == -1
    if GuestExec_IsEnabled() and GuestExec_IsSupported():
        _ = GuestExec_UnmapRegion(virtual_addr, size)
    AddressSpace_Unmap(self.address_space, virtual_addr, size)
    MemoryManager_RemoveBacking((&self).cast[mutable MemoryManager&], virtual_addr, size)
    for i in 0..<self.vma_areas.count:
        if self.vma_areas[i].base == virtual_addr and self.vma_areas[i].size == size:
            j: mutable usize = i
            can Unsafe.AssumeProgress:
                while j + 1 < self.vma_areas.count:
                    decreases self.vma_areas.count - j
                    self.vma_areas[j] <- self.vma_areas[j + 1]
                    j <- j + 1
            self.vma_areas.count <- self.vma_areas.count - 1
            return 0
    return -1

def MemoryManager_QueryProtection(self: MemoryManager&, addr: VAddr, start: mutable VAddr&, end: mutable VAddr&, prot: mutable u32&) -> s32:
    ensure result == 0 or result == -1
    index: s32 = MemoryManager_FindBestVmaIndex(self, addr, 1)
    if index >= 0:
        start <- self.vma_areas[index.usize()].base
        end <- self.vma_areas[index.usize()].base + self.vma_areas[index.usize()].size.uintptr()
        prot <- self.vma_areas[index.usize()].prot
        return 0
    return -1

def MemoryManager_Protect(self: mutable MemoryManager&, addr: VAddr, size: u64, prot: MemoryProt) -> s32:
    ensure result == 0 or result == -1
    if size == 0:
        return 0
    effective_prot: MemoryProt = MemoryProt_NormalizeCpu(prot)
    AddressSpace_Protect(self.address_space, addr, size, effective_prot)
    if GuestExec_IsEnabled() and GuestExec_IsSupported() and not GuestExec_ProtectRegion(addr, size, effective_prot):
        return -1
    index: s32 = MemoryManager_FindBestVmaIndex(self, addr, size)
    if index >= 0:
        self.vma_areas[index.usize()].prot <- effective_prot
        return 0
    return -1

# Bulk-write window: while active, per-write native-protection restores are deferred
# (the touched page stays writable+cached so repeated relocation writes to it skip the
# make-writable mprotect entirely). MemoryManager_EndBulkWriteWindow then restores
# exactly the pages that were made writable, each to its declared VMA protection,
# faithfully reproducing the per-write end state in one pass — the ~2.6x relocation win
# without leaving any executable page RWX (the W^X hazard on Apple Silicon).
global mutable memory_bulk_write_window_active: bool = false

def MemoryManager_BeginBulkWriteWindow() -> void:
    memory_bulk_write_window_active <- true

def MemoryManager_EndBulkWriteWindow(self: mutable MemoryManager&) -> void:
    if not memory_bulk_write_window_active:
        return
    memory_bulk_write_window_active <- false
    # Reprotect every VMA that took a deferred write back to its declared protection
    # (whole-VMA, exactly as the per-write restore did — covers every touched page even
    # if the writable-page cache evicted some), then drop the cache once. VMAs that are
    # CpuWrite (or never matched a VMA) were never marked, mirroring the per-write path,
    # which leaves those untouched.
    for i in 0..<self.vma_areas.count:
        if self.vma_areas[i].bulk_dirty:
            self.vma_areas[i].bulk_dirty <- false
            if GuestExec_IsEnabled() and GuestExec_IsSupported():
                _ = GuestExec_ProtectRegion(self.vma_areas[i].base, self.vma_areas[i].size, self.vma_areas[i].prot)
    GuestExec_ClearWritablePageCache()

def MemoryManager_RestoreNativeProtectionAfterWrite(self: mutable MemoryManager&, addr: VAddr, size: u64) -> bool:
    if size == 0 or not GuestExec_IsEnabled() or not GuestExec_IsSupported():
        return true
    index: s32 = MemoryManager_FindBestVmaIndex(self, addr, size)
    if memory_bulk_write_window_active:
        # Defer the reprotect: mark the VMA dirty (skip CpuWrite VMAs, exactly as the
        # immediate path below early-returns for them) and leave the page writable+cached
        # so subsequent writes to it skip the make-writable mprotect entirely.
        if index >= 0 and (self.vma_areas[index.usize()].prot & MemoryProt_CpuWrite) == 0:
            self.vma_areas[index.usize()].bulk_dirty <- true
        return true
    if index < 0:
        return true
    area: VirtualMemoryArea = self.vma_areas[index.usize()]
    if (area.prot & MemoryProt_CpuWrite) != 0:
        return true
    return GuestExec_ProtectRegion(area.base, area.size, area.prot)

def MemoryManager_NameVirtualRange(self: mutable MemoryManager&, virtual_addr: VAddr, size: u64, name: static u8&) -> void:
    for i in 0..<self.vma_areas.count:
        if self.vma_areas[i].base == virtual_addr and self.vma_areas[i].size == size:
            self.vma_areas[i].name <- name
            return

def MemoryManager_InvalidateMemory(self: MemoryManager&, addr: VAddr, size: u64) -> void:
    _ = self
    _ = addr
    _ = size

def MemoryManager_AddBacking(self: mutable MemoryManager&, base: VAddr, size: u64) -> void:
    if size == 0:
        return
    bytes: mutable darray[u8] = []
    backing_owner: mutable Arena& = &memory_arena
    in backing_owner:
        while bytes.count < size.usize():
            can Unsafe.AssumeProgress:
                bytes.push(0)
        self.mapped_bytes.push(MappedMemoryBytes(base, size, bytes))

def MemoryManager_RemoveBacking(self: mutable MemoryManager&, base: VAddr, size: u64) -> void:
    i: mutable usize = 0
    while i < self.mapped_bytes.count:
        if self.mapped_bytes[i].base == base and self.mapped_bytes[i].size == size:
            memory_last_backing_index <- -1
            j: mutable usize = i
            can Unsafe.AssumeProgress:
                while j + 1 < self.mapped_bytes.count:
                    decreases self.mapped_bytes.count - j
                    self.mapped_bytes[j] <- self.mapped_bytes[j + 1]
                    j <- j + 1
            self.mapped_bytes.count <- self.mapped_bytes.count - 1
            return
        i <- i + 1

def MemoryManager_FindBackingIndex(self: MemoryManager&, addr: VAddr, size: u64) -> s32:
    if memory_last_backing_index >= 0 and memory_last_backing_index.usize() < self.mapped_bytes.count:
        cached: MappedMemoryBytes = self.mapped_bytes[memory_last_backing_index.usize()]
        if addr >= cached.base:
            cached_offset: u64 = (addr - cached.base).u64()
            if cached_offset <= cached.size and size <= (cached.size - cached_offset):
                return memory_last_backing_index
    for i in 0..<self.mapped_bytes.count:
        entry: MappedMemoryBytes = self.mapped_bytes[i]
        if addr >= entry.base:
            offset: u64 = (addr - entry.base).u64()
            if offset <= entry.size and size <= (entry.size - offset):
                memory_last_backing_index <- i.s32()
                return i.s32()
    return -1

# Validate a guest [addr, addr+width) access against a resolved backing buffer and
# return the in-buffer byte offset, or -1 if the access would fall outside the buffer.
# The bound is the ACTUAL backing length (entry.bytes.count), not the nominal entry.size:
# the loops below index entry.bytes, and bytes.count is the only true buffer bound. On the
# success path the two are equal (MemoryManager_AddBacking fills bytes to size), so this is
# byte-identical to the unchecked path; only the previously-unchecked out-of-range case
# (addr < base, or offset+width past the buffer) now refuses instead of writing OOB.
def MemoryManager_BackingOffset(entry: MappedMemoryBytes, addr: VAddr, width: u64) -> s64:
    if addr < entry.base:
        return -1
    offset: u64 = (addr - entry.base).u64()
    if offset > entry.bytes.count.u64():
        return -1
    if width > (entry.bytes.count.u64() - offset):
        return -1
    return offset.s64()

def MemoryManager_WriteU8(self: mutable MemoryManager&, addr: VAddr, value: u8) -> bool:
    can Memory.Allocate:
        index: s32 = MemoryManager_FindBackingIndex(self, addr, 1)
        if index < 0:
            return false
        if GuestExec_IsEnabled() and GuestExec_IsSupported():
            if not GuestExec_WriteBytes(addr, (&value).cast[void&?], 1):
                return false
            if not MemoryManager_RestoreNativeProtectionAfterWrite(self, addr, 1.u64()):
                return false
        soffset: s64 = MemoryManager_BackingOffset(self.mapped_bytes[index.usize()], addr, 1)
        if soffset < 0:
            return false
        offset: usize = soffset.usize()
        self.mapped_bytes[index.usize()].bytes[offset] <- value
        return true

def MemoryManager_ReadU8(self: MemoryManager&, addr: VAddr) -> u8:
    can Memory.Allocate:
        index: s32 = MemoryManager_FindBackingIndex(self, addr, 1)
        if index < 0:
            return 0
        # Single-view: read the native MAP_FIXED mapping when guest-exec is active (see
        # MemoryManager_ReadU64). The low byte of the native 8-read at addr is the byte
        # at addr; the region is mapped (backing-index check) so the read is in-bounds.
        if GuestExec_IsEnabled() and GuestExec_IsSupported():
            return (GuestExec_ReadNativeU64(addr).u64() & 0xff).u8()
        soffset: s64 = MemoryManager_BackingOffset(self.mapped_bytes[index.usize()], addr, 1)
        if soffset < 0:
            return 0
        offset: usize = soffset.usize()
        return self.mapped_bytes[index.usize()].bytes[offset]

def MemoryManager_WriteBytes(self: mutable MemoryManager&, addr: VAddr, data: u8&, size: u64) -> bool:
    can Memory.Allocate:
        index: s32 = MemoryManager_FindBackingIndex(self, addr, size)
        if index < 0:
            return false
        if GuestExec_IsEnabled() and GuestExec_IsSupported():
            if not GuestExec_WriteBytes(addr, data.cast[void&?], size):
                return false
            if not MemoryManager_RestoreNativeProtectionAfterWrite(self, addr, size):
                return false
        sbase: s64 = MemoryManager_BackingOffset(self.mapped_bytes[index.usize()], addr, size)
        if sbase < 0:
            return false
        base_offset: usize = sbase.usize()
        for i in 0..<size.usize():
            self.mapped_bytes[index.usize()].bytes[base_offset + i] <- data[i]
        return true

def MemoryManager_WriteU64(self: mutable MemoryManager&, addr: VAddr, value: u64) -> bool:
    can Memory.Allocate:
        index: s32 = MemoryManager_FindBackingIndex(self, addr, 8)
        if index < 0:
            return false
        if GuestExec_IsEnabled() and GuestExec_IsSupported():
            if not GuestExec_WriteU64(addr, value):
                return false
            if not MemoryManager_RestoreNativeProtectionAfterWrite(self, addr, 8.u64()):
                return false
        sbase: s64 = MemoryManager_BackingOffset(self.mapped_bytes[index.usize()], addr, 8)
        if sbase < 0:
            return false
        base_offset: usize = sbase.usize()
        for i in 0..<8:
            self.mapped_bytes[index.usize()].bytes[base_offset + i] <- ((value >> (i.u64() * 8)) & 0xff).u8()
        return true

def MemoryManager_WriteU64BackingOnly(self: mutable MemoryManager&, addr: VAddr, value: u64) -> bool:
    index: s32 = MemoryManager_FindBackingIndex(self, addr, 8)
    if index < 0:
        return false
    sbase: s64 = MemoryManager_BackingOffset(self.mapped_bytes[index.usize()], addr, 8)
    if sbase < 0:
        return false
    base_offset: usize = sbase.usize()
    for i in 0..<8:
        self.mapped_bytes[index.usize()].bytes[base_offset + i] <- ((value >> (i.u64() * 8)) & 0xff).u8()
    return true

def MemoryManager_ReadU64(self: MemoryManager&, addr: VAddr) -> u64:
    can Memory.Allocate:
        index: s32 = MemoryManager_FindBackingIndex(self, addr, 8)
        if index < 0:
            return 0
        # Single-view: when guest-exec is active, the native MAP_FIXED mapping at the
        # guest VA is the single source of truth (the same memory the guest executes
        # against, like shadPS4). The host-side backing buffer is legacy and can diverge
        # from native (deferred/partial writes, re-protection), which is the root of the
        # layer-mismatch bug class. The backing-index check above confirms the region is
        # mapped, so the native read is in-bounds.
        if GuestExec_IsEnabled() and GuestExec_IsSupported():
            return GuestExec_ReadNativeU64(addr).u64()
        sbase: s64 = MemoryManager_BackingOffset(self.mapped_bytes[index.usize()], addr, 8)
        if sbase < 0:
            return 0
        base_offset: usize = sbase.usize()
        value: mutable u64 = 0
        for i in 0..<8:
            value <- value | (self.mapped_bytes[index.usize()].bytes[base_offset + i].u64() << (i.u64() * 8))
        return value

def MemoryManager_SyncNativeBackingToGuestExec(self: mutable MemoryManager&) -> bool:
    can Memory.Allocate:
        if not GuestExec_IsEnabled() or not GuestExec_IsSupported():
            return true
        for i in 0..<self.mapped_bytes.count:
            entry: MappedMemoryBytes = self.mapped_bytes[i]
            if entry.size == 0 or entry.bytes.count == 0:
                continue
            if not GuestExec_WriteBytes(entry.base, (&entry.bytes[0]).cast[void&?], entry.size):
                return false
            if not MemoryManager_RestoreNativeProtectionAfterWrite(self, entry.base, entry.size):
                return false
        return true
