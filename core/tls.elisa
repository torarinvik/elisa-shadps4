include "../common/types.elisa"
include "../common/arch.elisa"

extern malloc(size: usize) -> mutable heap void&?
@reentrant_safe
extern memcpy(dest: mutable void&, src: void&, n: usize) -> mutable void&
extern mmap(addr: uintptr, length: usize, prot: int, flags: int, fd: int, offset: i64) -> uintptr

@link_name(i386_set_ldt)
extern tls_i386_set_ldt(start: int, desc: void&, num: int) -> int
@link_name(pthread_key_create)
extern tls_pthread_key_create(key: void&?, destructor: void&?) -> int
@link_name(pthread_getspecific)
extern tls_pthread_getspecific(key: u64) -> void&?
@link_name(pthread_setspecific)
extern tls_pthread_setspecific(key: u64, value: void&?) -> int

@segment_transition(guest)
extern ElisaTls_LoadGuestFsSelectorAsm(selector: GuestFsSelector) -> void can[Unsafe.SegmentMutation, Segment.Guest]
@segment_transition(host)
@reentrant_safe
extern ElisaTls_LoadHostFsSelectorAsm(selector: HostFsSelector) -> void can[Unsafe.SegmentMutation, Segment.Host]
@reentrant_safe
extern ElisaTls_ReadFsSelectorAsm() -> u16
@reentrant_safe
extern ElisaTls_ReadGsSelectorAsm() -> u16
@reentrant_safe
extern ElisaTls_ReadFs0Asm() -> SegmentSelfPointer
extern ElisaTls_AtomicExchangeU32Asm(ptr: HostPtr[u32], value: u32) -> u32
@segment_transition(host)
extern ElisaTls_CallGuestThreadEntryWithFsAsm(entry: GuestThreadEntry, arg: GuestThreadArg, guest_fs_selector: GuestFsSelector, host_fs_selector: HostFsSelector) -> GuestThreadResult can[Unsafe.SegmentMutation, Segment.Host, Segment.Guest]
@segment_transition(host)
extern ElisaTls_CallGuestInitEntryOnStackWithFsAsm(ctx: HostPtr[GuestInitCtx]) -> u64 can[Unsafe.SegmentMutation, Segment.Host, Segment.Guest]

@fixed_layout
@abi_layout(size, 56, align, 8, field, entry, 0, field, arg0, 8, field, arg1, 16, field, arg2, 24, field, stack_top, 32, field, guest_fs, 40, field, host_fs, 48)
struct GuestInitCtx:
    entry: mutable u64
    arg0: mutable u64
    arg1: mutable u64
    arg2: mutable u64
    stack_top: mutable u64
    guest_fs: mutable u64
    host_fs: mutable u64

@fixed_layout
@abi_layout(size, 16, align, 8, field, counter, 0, field, pointer, 8)
struct DtvEntry:
    counter: mutable usize
    pointer: mutable GuestTlsBlockPointer

@fixed_layout
@abi_layout(size, 32, align, 8, field, tcb_self, 0, field, tcb_dtv, 8, field, tcb_thread, 16, field, tcb_fiber, 24)
struct Tcb:
    tcb_self: mutable SegmentSelfPointer
    tcb_dtv: mutable GuestDtvPointer
    tcb_thread: mutable GuestThreadObjectPointer
    tcb_fiber: mutable GuestFiberPointer

global mutable tls_tcb_key: u32 = 1
global mutable tls_main_tcb: Tcb = Tcb(0.uintptr().cast[SegmentSelfPointer], 0.uintptr().cast[GuestDtvPointer], 0.uintptr().cast[GuestThreadObjectPointer], 0.uintptr().cast[GuestFiberPointer])
global mutable tls_initialized: bool = false
global mutable tls_primary_tcb_base: SegmentSelfPointer = 0.uintptr().cast[SegmentSelfPointer]
global mutable tls_primary_template_base: GuestTlsTemplatePointer = 0.uintptr().cast[GuestTlsTemplatePointer]
global mutable tls_primary_template_size: usize = 0
global mutable tls_primary_dtv_base: GuestDtvPointer = 0.uintptr().cast[GuestDtvPointer]
global mutable tls_primary_dtv_count: usize = 0
global mutable tls_darwin_ldt_initialized: bool = false
global mutable tls_darwin_next_ldt_index: u16 = 8
global mutable tls_darwin_ldt_lock: u32 = 0
global mutable tls_darwin_ldt_page_key: u64 = 0
global mutable tls_darwin_ldt_page_key_initialized: bool = false
global mutable tls_darwin_free_ldt_indices: u16[1024] = zeroed
global mutable tls_darwin_free_ldt_count: usize = 0
global mutable tls_debug_last_mmap: uintptr = 0.uintptr()
global mutable tls_debug_last_ldt_addr: uintptr = 0.uintptr()
global mutable tls_debug_last_ldt_ret: int = 0
global mutable tls_debug_last_selector: u16 = 0
global mutable tls_debug_last_fs0: uintptr = 0.uintptr()
global mutable tls_debug_ldt_lock_spins: u64 = 0
global mutable tls_debug_ldt_exhausted_count: u64 = 0
global mutable tls_debug_ldt_reuse_count: u64 = 0
global mutable tls_host_fs_selector: u16 = 0
global mutable tls_host_fs_selector_captured: bool = false
global mutable tls_host_gs_selector: u16 = 0
global mutable tls_host_gs_selector_captured: bool = false
global mutable tls_thread_install_count: u64 = 0
global mutable tls_thread_install_success_count: u64 = 0

@fixed_layout
struct DarwinLdtEntry:
    limit00: mutable u16
    base00: mutable u16
    base16: mutable u8
    access: mutable u8
    flags: mutable u8
    base24: mutable u8

@fixed_layout
struct DarwinLdtPage:
    tcb: mutable SegmentSelfPointer
    index: mutable u16
    padding: mutable u8[4086]

const TLS_DARWIN_LDT_REGION_BASE: uintptr = 0x4000.uintptr()
const TLS_DARWIN_LDT_REGION_SIZE: usize = 0x3FC000
const TLS_DARWIN_LDT_BLOCK_SIZE: uintptr = 0x1000.uintptr()
const TLS_DARWIN_LDT_INDEX_BASE: u16 = 8
const TLS_DARWIN_LDT_INDEX_TOTAL: usize = 1016
const TLS_DARWIN_LDT_ACCESS: u8 = 0xF2
const TLS_DARWIN_LDT_FLAGS: u8 = 0x40

def Tls_MapFailed() -> uintptr:
    return (0 - 1).uintptr()

def GetTcbKey() -> u32:
    return tls_tcb_key

def TLS_LdtLock() -> void:
    static if PLATFORM_APPLE and ARCH_X86_64:
        while ElisaTls_AtomicExchangeU32Asm((&tls_darwin_ldt_lock).cast[mutable u32&].uintptr().cast[HostPtr[u32]], 1) != 0:
            can Unsafe.AssumeProgress:
                tls_debug_ldt_lock_spins <- tls_debug_ldt_lock_spins + 1

def TLS_LdtUnlock() -> void:
    static if PLATFORM_APPLE and ARCH_X86_64:
        tls_darwin_ldt_lock <- 0

def TLS_RecordPreparedTcbBase(base: SegmentSelfPointer) -> void:
    tls_main_tcb.tcb_self <- base
    tls_main_tcb.tcb_thread <- (!base).cast[GuestThreadObjectPointer]
    tls_initialized <- true

@callconv(c)
def TLS_FreeLdtPage(raw: void&?) -> void:
    static if PLATFORM_APPLE and ARCH_X86_64:
        if raw == null:
            return
        page: DarwinLdtPage&? = raw.cast[DarwinLdtPage&?]
        if page == null:
            return
        TLS_LdtLock()
        if tls_darwin_free_ldt_count < TLS_DARWIN_LDT_INDEX_TOTAL:
            tls_darwin_free_ldt_indices[tls_darwin_free_ldt_count] <- page.index
            tls_darwin_free_ldt_count <- tls_darwin_free_ldt_count + 1
        TLS_LdtUnlock()

def TLS_DarwinLdtPageAddress(index: u16) -> DarwinLdtPageAddress:
    return (TLS_DARWIN_LDT_REGION_BASE + ((index - TLS_DARWIN_LDT_INDEX_BASE).uintptr() * TLS_DARWIN_LDT_BLOCK_SIZE)).cast[DarwinLdtPageAddress]

def TLS_DarwinCurrentLdtPage() -> mutable DarwinLdtPage&?:
    static if PLATFORM_APPLE and ARCH_X86_64:
        if not tls_darwin_ldt_page_key_initialized:
            return null
        raw: void&? = tls_pthread_getspecific(tls_darwin_ldt_page_key)
        if raw == null:
            return null
        return raw.cast[mutable DarwinLdtPage&?]
    static else:
        return null

def TLS_DarwinEnsureLdtRegionLocked() -> bool:
    static if PLATFORM_APPLE and ARCH_X86_64:
        if tls_darwin_ldt_initialized:
            return true
        mapped: uintptr = mmap(TLS_DARWIN_LDT_REGION_BASE, TLS_DARWIN_LDT_REGION_SIZE, 3, 0x1012, -1, 0)
        tls_debug_last_mmap <- mapped
        if mapped == Tls_MapFailed():
            return false
        can Unsafe.PointerCast:
            dtor: void&? = TLS_FreeLdtPage.cast[void&?]
            if tls_pthread_key_create((&tls_darwin_ldt_page_key).cast[void&], dtor) != 0:
                return false
        tls_darwin_ldt_page_key_initialized <- true
        tls_darwin_free_ldt_count <- 0
        i: mutable usize = 0
        while i < TLS_DARWIN_LDT_INDEX_TOTAL:
            tls_darwin_free_ldt_indices[i] <- (TLS_DARWIN_LDT_INDEX_BASE + i.u16())
            i <- i + 1
        tls_darwin_free_ldt_count <- TLS_DARWIN_LDT_INDEX_TOTAL
        tls_darwin_ldt_initialized <- true
        return true
    static else:
        return false

def TLS_DarwinAllocLdtIndexLocked() -> u16:
    static if PLATFORM_APPLE and ARCH_X86_64:
        if tls_darwin_free_ldt_count > 0:
            tls_darwin_free_ldt_count <- tls_darwin_free_ldt_count - 1
            tls_debug_ldt_reuse_count <- tls_debug_ldt_reuse_count + 1
            return tls_darwin_free_ldt_indices[tls_darwin_free_ldt_count]
        tls_debug_ldt_exhausted_count <- tls_debug_ldt_exhausted_count + 1
        return 0
    static else:
        return 0

def TLS_PrepareTcbBase(image_address: void&?) -> GuestFsSelector:
    base: mutable SegmentSelfPointer = 0.uintptr().cast[SegmentSelfPointer]
    if image_address != null:
        base <- image_address.cast[uintptr].cast[SegmentSelfPointer]
    result: mutable GuestFsSelector = 0.u32().cast[GuestFsSelector]
    static if PLATFORM_APPLE and ARCH_X86_64:
        TLS_LdtLock()
        existing_page: mutable DarwinLdtPage&? = TLS_DarwinCurrentLdtPage()
        if existing_page != null:
            existing_page.tcb <- base
            result <- (((existing_page.index << 3) | 7).u32()).cast[GuestFsSelector]
            ldt_addr_existing: uintptr = existing_page.cast[uintptr]
            tls_debug_last_ldt_addr <- ldt_addr_existing
        else:
            if TLS_DarwinEnsureLdtRegionLocked():
                ldt_index: u16 = TLS_DarwinAllocLdtIndexLocked()
                if ldt_index != 0:
                    ldt_addr: DarwinLdtPageAddress = TLS_DarwinLdtPageAddress(ldt_index)
                    if !ldt_addr != 0.uintptr():
                        tls_debug_last_ldt_addr <- !ldt_addr
                        desc: mutable DarwinLdtEntry = zeroed
                        desc.limit00 <- (TLS_DARWIN_LDT_BLOCK_SIZE - 1.uintptr()).u16()
                        desc.base00 <- (!ldt_addr & 0xffff.uintptr()).u16()
                        desc.base16 <- ((!ldt_addr >> 16.uintptr()) & 0xff.uintptr()).u8()
                        desc.access <- TLS_DARWIN_LDT_ACCESS
                        desc.flags <- TLS_DARWIN_LDT_FLAGS
                        desc.base24 <- ((!ldt_addr >> 24.uintptr()) & 0xff.uintptr()).u8()
                        ret: int = tls_i386_set_ldt(ldt_index.int(), (&desc).cast[void&], 1)
                        tls_debug_last_ldt_ret <- ret
                        if ret == ldt_index.int():
                            selector: u16 = ((ldt_index << 3) | 7)
                            tls_debug_last_selector <- selector
                            result <- selector.u32().cast[GuestFsSelector]
                            page: mutable DarwinLdtPage&? = (!ldt_addr).cast[mutable DarwinLdtPage&?]
                            if page != null:
                                page.tcb <- base
                                page.index <- ldt_index
                                _ = tls_pthread_setspecific(tls_darwin_ldt_page_key, page.cast[void&?])
            if not tls_host_fs_selector_captured:
                tls_host_fs_selector <- ElisaTls_ReadFsSelectorAsm()
                tls_host_fs_selector_captured <- true
        TLS_LdtUnlock()
    TLS_RecordPreparedTcbBase(base)
    return result

# Linux guest-TCB install via arch_prctl(ARCH_SET_GS). The guest TCB lives in the
# GS base (guest fs: accesses are rewritten to gs: by core/cpu_patches.elisa),
# mirroring shadPS4 tls.cpp SetTcbBase. SYS_arch_prctl=158, ARCH_SET_GS=0x1001.
@link_name(syscall)
extern tls_arch_prctl_syscall(number: i64, code: i64, addr: u64) -> i64
const TLS_SYS_ARCH_PRCTL: i64 = 158
const TLS_ARCH_SET_GS: i64 = 0x1001

def SetTcbBase(image_address: void&?) -> void can[Unsafe.SegmentMutation, Unsafe.GuestSegmentInstall, Segment.Guest]:
    selector: mutable GuestFsSelector = 0.u32().cast[GuestFsSelector]
    selector <- TLS_PrepareTcbBase(image_address)
    static if PLATFORM_APPLE and ARCH_X86_64:
        if !selector != 0:
            can Unsafe.SegmentMutation, Segment.Guest:
                ElisaTls_LoadGuestFsSelectorAsm(selector)
            tls_debug_last_fs0 <- !ElisaTls_ReadFs0Asm()
    static elif PLATFORM_LINUX and ARCH_X86_64:
        _ = selector
        if image_address != null:
            base: u64 = image_address.cast[uintptr].u64()
            can Unsafe.SegmentMutation, Unsafe.GuestSegmentInstall, Segment.Guest:
                _ = tls_arch_prctl_syscall(TLS_SYS_ARCH_PRCTL, TLS_ARCH_SET_GS, base)
            tls_debug_last_fs0 <- image_address.cast[uintptr]

def GetTcbBase() -> mutable Tcb&:
    static if PLATFORM_APPLE and ARCH_X86_64:
        base: uintptr = !ElisaTls_ReadFs0Asm()
        if base != 0.uintptr():
            tcb: mutable Tcb&? = base.cast[mutable Tcb&?]
            if tcb != null:
                return tcb
    return &tls_main_tcb

def InitializeTLS() -> void:
    if tls_initialized:
        return
    tls_main_tcb.tcb_self <- (&tls_main_tcb).cast[uintptr].cast[SegmentSelfPointer]
    tls_main_tcb.tcb_dtv <- 0.uintptr().cast[GuestDtvPointer]
    tls_main_tcb.tcb_thread <- (!tls_main_tcb.tcb_self).cast[GuestThreadObjectPointer]
    tls_main_tcb.tcb_fiber <- 0.uintptr().cast[GuestFiberPointer]
    tls_initialized <- true

def TLS_ResetForTests() -> void:
    tls_tcb_key <- 1
    tls_main_tcb <- Tcb(0.uintptr().cast[SegmentSelfPointer], 0.uintptr().cast[GuestDtvPointer], 0.uintptr().cast[GuestThreadObjectPointer], 0.uintptr().cast[GuestFiberPointer])
    tls_initialized <- false
    tls_primary_tcb_base <- 0.uintptr().cast[SegmentSelfPointer]
    tls_primary_template_base <- 0.uintptr().cast[GuestTlsTemplatePointer]
    tls_primary_template_size <- 0
    tls_primary_dtv_base <- 0.uintptr().cast[GuestDtvPointer]
    tls_primary_dtv_count <- 0
    tls_darwin_ldt_initialized <- false
    tls_darwin_next_ldt_index <- TLS_DARWIN_LDT_INDEX_BASE
    tls_darwin_ldt_lock <- 0
    tls_darwin_ldt_page_key <- 0
    tls_darwin_ldt_page_key_initialized <- false
    tls_darwin_free_ldt_indices <- zeroed
    tls_darwin_free_ldt_count <- 0
    tls_debug_last_mmap <- 0.uintptr()
    tls_debug_last_ldt_addr <- 0.uintptr()
    tls_debug_last_ldt_ret <- 0
    tls_debug_last_selector <- 0
    tls_debug_last_fs0 <- 0.uintptr()
    tls_debug_ldt_lock_spins <- 0
    tls_debug_ldt_exhausted_count <- 0
    tls_debug_ldt_reuse_count <- 0
    tls_host_fs_selector <- 0
    tls_host_fs_selector_captured <- false
    tls_thread_install_count <- 0
    tls_thread_install_success_count <- 0

def TLS_DebugLastMmap() -> uintptr:
    return tls_debug_last_mmap

def TLS_DebugLastLdtAddr() -> uintptr:
    return tls_debug_last_ldt_addr

def TLS_DebugLastLdtRet() -> int:
    return tls_debug_last_ldt_ret

@reentrant_safe
def TLS_DebugLastSelector() -> u16:
    return tls_debug_last_selector

def TLS_DebugLastFs0() -> uintptr:
    return tls_debug_last_fs0

def TLS_DebugThreadInstallCount() -> u64:
    return tls_thread_install_count

def TLS_DebugThreadInstallSuccessCount() -> u64:
    return tls_thread_install_success_count

def TLS_DebugLdtLockSpins() -> u64:
    return tls_debug_ldt_lock_spins

def TLS_DebugLdtExhaustedCount() -> u64:
    return tls_debug_ldt_exhausted_count

def TLS_DebugLdtReuseCount() -> u64:
    return tls_debug_ldt_reuse_count

def TLS_CaptureHostFsSelector() -> HostFsSelector:
    static if PLATFORM_APPLE and ARCH_X86_64:
        if not tls_host_fs_selector_captured:
            tls_host_fs_selector <- ElisaTls_ReadFsSelectorAsm()
            tls_host_fs_selector_captured <- true
        return tls_host_fs_selector.u32().cast[HostFsSelector]
    static else:
        return 0.u32().cast[HostFsSelector]

# gap-3 (UPDATE 9): capture the live HOST %gs selector. On macOS x86-64 the host TLS
# register is %gs; the HLE boundary thunk's optional gs-restore (ELISA_RESTORE_HOST_GS)
# uses this captured value instead of a hardcoded selector. Captured the first time it is
# called on the host thread (during module init, before any guest %gs swap), mirroring
# TLS_CaptureHostFsSelector. Returns 0 off-platform / when uncaptured.
def TLS_CaptureHostGsSelector() -> u16:
    static if PLATFORM_APPLE and ARCH_X86_64:
        if not tls_host_gs_selector_captured:
            tls_host_gs_selector <- ElisaTls_ReadGsSelectorAsm()
            tls_host_gs_selector_captured <- true
        return tls_host_gs_selector
    static else:
        return 0

@reentrant_safe
def TLS_HostGsSelector() -> u16:
    return tls_host_gs_selector

@reentrant_safe
def TLS_HostFsSelector() -> HostFsSelector:
    return tls_host_fs_selector.u32().cast[HostFsSelector]

@reentrant_safe
def TLS_HostFsSelectorRaw() -> u16:
    selector: HostFsSelector = TLS_HostFsSelector()
    return (!selector).u16()

@reentrant_safe
def TLS_RestoreHostFsSelector() -> void can[Unsafe.SegmentMutation, Segment.Host]:
    static if PLATFORM_APPLE and ARCH_X86_64:
        if tls_host_fs_selector_captured:
            can Unsafe.SegmentMutation, Segment.Host:
                ElisaTls_LoadHostFsSelectorAsm(tls_host_fs_selector.u32().cast[HostFsSelector])

def TLS_GuestFsSelector() -> GuestFsSelector:
    static if PLATFORM_APPLE and ARCH_X86_64:
        page: mutable DarwinLdtPage&? = TLS_DarwinCurrentLdtPage()
        if page != null:
            return (((page.index << 3) | 7).u32()).cast[GuestFsSelector]
        if tls_debug_last_selector != 0:
            return tls_debug_last_selector.u32().cast[GuestFsSelector]
        return 0.u32().cast[GuestFsSelector]
    static else:
        return 0.u32().cast[GuestFsSelector]

def TLS_GuestFsSelectorRaw() -> u16:
    selector: GuestFsSelector = TLS_GuestFsSelector()
    return (!selector).u16()

@reentrant_safe
def TLS_GuestFsSelectorRawReentrant() -> u16:
    return TLS_DebugLastSelector()

def TLS_SetPrimaryTcbBase(base: SegmentSelfPointer) -> void:
    tls_primary_tcb_base <- base

def TLS_RegisterPrimaryTemplate(base: GuestTlsTemplatePointer, size: usize, dtv_base: GuestDtvPointer, dtv_count: usize) -> void:
    tls_primary_template_base <- base
    tls_primary_template_size <- size
    tls_primary_dtv_base <- dtv_base
    tls_primary_dtv_count <- dtv_count

@reentrant_safe
def TLS_PrimaryTcbBase() -> SegmentSelfPointer:
    return tls_primary_tcb_base

def TLS_InstallPrimaryTcbBase() -> void can[Unsafe.SegmentMutation, Unsafe.GuestSegmentInstall, Segment.Guest]:
    if !tls_primary_tcb_base != 0.uintptr():
        can Unsafe.SegmentMutation, Unsafe.GuestSegmentInstall, Segment.Guest:
            SetTcbBase((!tls_primary_tcb_base).cast[void&?])

def TLS_InstallThreadTcbFromPrimaryTemplate() -> void can[Unsafe.SegmentMutation, Unsafe.GuestSegmentInstall, Segment.Guest, Memory.Allocate]:
    can Memory.Allocate:
        selector: GuestFsSelector = TLS_PrepareThreadTcbFromPrimaryTemplate()
        static if PLATFORM_APPLE and ARCH_X86_64:
            if !selector != 0:
                can Unsafe.SegmentMutation, Segment.Guest:
                    ElisaTls_LoadGuestFsSelectorAsm(selector)
                tls_debug_last_fs0 <- !ElisaTls_ReadFs0Asm()

def TLS_PrepareThreadTcbFromPrimaryTemplate() -> GuestFsSelector:
    tls_thread_install_count <- tls_thread_install_count + 1
    if !tls_primary_template_base == 0.uintptr() or tls_primary_template_size == 0 or !tls_primary_tcb_base == 0.uintptr():
        selector: GuestFsSelector = TLS_PrepareTcbBase((!tls_primary_tcb_base).cast[void&?])
        if !selector != 0:
            tls_thread_install_success_count <- tls_thread_install_success_count + 1
        return selector
    can Memory.Allocate:
        raw: mutable heap void&? = malloc(tls_primary_template_size)
        if raw == null:
            return TLS_PrepareTcbBase((!tls_primary_tcb_base).cast[void&?])
        new_base: uintptr = raw.cast[uintptr]
        can Unsafe.PointerCast:
            src: void& = (!tls_primary_template_base).cast[void&]
            dst: mutable void& = raw.cast[mutable void&]
            _ = memcpy(dst, src, tls_primary_template_size)
        tcb_offset: uintptr = !tls_primary_tcb_base - !tls_primary_template_base
        new_tcb_base: uintptr = new_base + tcb_offset
        tcb: mutable Tcb& = new_tcb_base.cast[mutable Tcb&]
        tcb.tcb_self <- new_tcb_base.cast[SegmentSelfPointer]
        tcb.tcb_thread <- new_tcb_base.cast[GuestThreadObjectPointer]
        if !tls_primary_dtv_base != 0.uintptr() and tls_primary_dtv_count != 0:
            dtv_size: usize = tls_primary_dtv_count * size_of(DtvEntry)
            dtv_raw: mutable heap void&? = malloc(dtv_size)
            if dtv_raw != null:
                can Unsafe.PointerCast:
                    src_dtv: void& = (!tls_primary_dtv_base).cast[void&]
                    dst_dtv: mutable void& = dtv_raw.cast[mutable void&]
                    _ = memcpy(dst_dtv, src_dtv, dtv_size)
                    dtv: mutable DtvEntry& = dtv_raw.cast[mutable DtvEntry&]
                    i: mutable usize = 0
                    while i < tls_primary_dtv_count:
                        ptr: uintptr = !dtv[i].pointer
                        if ptr >= !tls_primary_template_base and ptr < !tls_primary_template_base + tls_primary_template_size.uintptr():
                            dtv[i].pointer <- (new_base + (ptr - !tls_primary_template_base)).cast[GuestTlsBlockPointer]
                        i <- i + 1
                tcb.tcb_dtv <- dtv_raw.cast[uintptr].cast[GuestDtvPointer]
        selector2: GuestFsSelector = TLS_PrepareTcbBase(new_tcb_base.cast[void&?])
        if !selector2 != 0:
            tls_thread_install_success_count <- tls_thread_install_success_count + 1
        return selector2
    return 0.u32().cast[GuestFsSelector]

# Linear guard for the host->guest %fs segment swap. Producing it installs the
# guest TCB into %fs; it MUST be consumed by TLS_RestoreHostSegment, which
# restores the host selector. Because FsGuard is affine (must-consume), the
# compiler rejects any guest-entry path that installs the guest segment without
# restoring the host %fs — the catastrophic "host %fs left pointing at guest
# TCB" desync becomes un-writable.
linear struct FsGuard:
    active: bool

# Install the primary guest TCB into %fs and hand back the guard that must be
# restored. Use at single-threaded guest-entry boundaries (init/init-array).
def TLS_InstallGuestSegment() -> FsGuard can[Unsafe.SegmentMutation, Unsafe.GuestSegmentInstall, Segment.Guest]:
    can Unsafe.SegmentMutation, Unsafe.GuestSegmentInstall, Segment.Guest:
        TLS_InstallPrimaryTcbBase()
    return FsGuard(true)

# Install a per-thread TCB (cloned from the primary template) into %fs and hand
# back the guard. Use at worker-thread guest-entry boundaries.
def TLS_InstallThreadSegment() -> FsGuard can[Unsafe.SegmentMutation, Unsafe.GuestSegmentInstall, Segment.Guest, Memory.Allocate]:
    can Unsafe.SegmentMutation, Unsafe.GuestSegmentInstall, Segment.Guest, Memory.Allocate:
        TLS_InstallThreadTcbFromPrimaryTemplate()
    return FsGuard(true)

# Consume the guard and restore the host %fs selector. Consuming the affine
# guard is the only way to satisfy the must-consume obligation, so every
# install is forced to pair with exactly one restore on every path.
def TLS_RestoreHostSegment(g: FsGuard) -> void can[Unsafe.SegmentMutation, Segment.Host]:
    _ = move g
    can Unsafe.SegmentMutation, Segment.Host:
        TLS_RestoreHostFsSelector()

# Guard-witnessed indirect calls into guest code. Each borrows a live FsGuard
# (without consuming it), so the type system makes it impossible to jump to a
# guest entry without the guest TCB installed in %fs: the only way to obtain an
# FsGuard is TLS_Install*Segment, and the borrow does not discharge the
# must-consume obligation, so the caller still has to restore the host %fs.
def TLS_CallGuestInitEntry(guard: FsGuard&, fn: void&?, args: u64, argp: void&?, param: void&?) -> s32:
    _ = guard.active
    trusted Unsafe.IndirectCall:
        return fn.call_as[func(u64, void&?, void&?) -> s32](args, argp, param)

def TLS_CallGuestInitArrayEntry(guard: FsGuard&, fn: void&?) -> void:
    _ = guard.active
    trusted Unsafe.IndirectCall:
        fn.call_as[func() -> void]()

def TLS_CallGuestThreadEntry(guard: FsGuard&, fn: void&?, arg: void&?) -> void&?:
    _ = guard.active
    trusted Unsafe.IndirectCall:
        return fn.call_as[func(void&?) -> void&?](arg)

def TLS_CallGuestThreadEntryWithPreparedSegment(fn: void&?, arg: void&?, guest_selector: GuestFsSelector, host_selector: HostFsSelector) -> void&? can[Unsafe.SegmentMutation, Segment.Host, Segment.Guest]:
    static if PLATFORM_APPLE and ARCH_X86_64:
        if fn == null or !guest_selector == 0:
            return null
        result: mutable GuestThreadResult = 0.uintptr().cast[GuestThreadResult]
        can Unsafe.SegmentMutation, Segment.Host, Segment.Guest:
            result <- ElisaTls_CallGuestThreadEntryWithFsAsm(fn.uintptr().cast[GuestThreadEntry], arg.uintptr().cast[GuestThreadArg], guest_selector, host_selector)
        return result.uintptr().cast[void&?]
    static else:
        _ = fn
        _ = arg
        _ = guest_selector
        _ = host_selector
        return null

def TLS_CallGuestInitEntryOnStackWithPreparedSegment(fn: void&?, args: u64, argp: void&?, param: void&?, stack_top: uintptr, guest_selector: GuestFsSelector, host_selector: HostFsSelector) -> s32 can[Unsafe.SegmentMutation, Segment.Host, Segment.Guest]:
    static if PLATFORM_APPLE and ARCH_X86_64:
        if fn == null or stack_top == 0.uintptr() or !guest_selector == 0:
            return 0
        ctx: mutable u64[7] = zeroed
        ctx[0] <- fn.uintptr().u64()
        ctx[1] <- args
        ctx[2] <- argp.uintptr().u64()
        ctx[3] <- param.uintptr().u64()
        ctx[4] <- stack_top.u64()
        ctx[5] <- (!guest_selector).u64()
        ctx[6] <- (!host_selector).u64()
        result: mutable u64 = 0
        can Unsafe.SegmentMutation, Segment.Host, Segment.Guest:
            result <- ElisaTls_CallGuestInitEntryOnStackWithFsAsm((&ctx[0]).cast[u64&].uintptr().cast[HostPtr[GuestInitCtx]])
        return result.s32()
    static else:
        _ = fn
        _ = args
        _ = argp
        _ = param
        _ = stack_top
        _ = guest_selector
        _ = host_selector
        return 0

def TLS_EnterHostFromGuest() -> void can[Unsafe.SegmentMutation, Segment.Host]:
    static if PLATFORM_APPLE and ARCH_X86_64:
        can Unsafe.SegmentMutation, Segment.Host:
            TLS_RestoreHostFsSelector()

def TLS_ReturnGuestFromHost() -> void can[Unsafe.SegmentMutation, Segment.Guest]:
    static if PLATFORM_APPLE and ARCH_X86_64:
        selector: GuestFsSelector = TLS_GuestFsSelector()
        if !selector != 0:
            can Unsafe.SegmentMutation, Segment.Guest:
                ElisaTls_LoadGuestFsSelectorAsm(selector)
