const PM4ItOpcode_LoadConfigReg: u32 = 0x60
const PM4ItOpcode_LoadContextReg: u32 = 0x61
const PM4ItOpcode_SetConfigReg: u32 = 0x68
const PM4ItOpcode_SetContextReg: u32 = 0x69
const PM4ItOpcode_SetContextRegIndirect: u32 = 0x73
const PM4ItOpcode_SetShReg: u32 = 0x76
const PM4ItOpcode_SetShRegOffset: u32 = 0x77
const PM4ItOpcode_SetQueueReg: u32 = 0x78
const PM4ItOpcode_SetUconfigReg: u32 = 0x79
const PM4ItOpcode_LoadConstRam: u32 = 0x80
const PM4ItOpcode_WriteConstRam: u32 = 0x81
const PM4ItOpcode_DumpConstRam: u32 = 0x83
