const PM4ItOpcode_EventWriteEop: u32 = 0x47
const PM4ItOpcode_EventWriteEos: u32 = 0x48
const PM4ItOpcode_ReleaseMem: u32 = 0x49
const PM4ItOpcode_PreambleCntl: u32 = 0x4A
