@fixed_layout
struct ElisaImGuiVec2:
    x: mutable f32
    y: mutable f32

@fixed_layout
struct ElisaImGuiVec4:
    x: mutable f32
    y: mutable f32
    z: mutable f32
    w: mutable f32

@fixed_layout
struct ElisaImGuiIOState:
    display_size: mutable ElisaImGuiVec2
    delta_time: mutable f32
    nav_active: mutable bool

const ElisaImGuiCond_Always: int = 1
