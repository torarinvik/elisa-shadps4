def Devtools_Widget_RegPopup_DrawColorRows(popup: Devtools_Widget_RegPopup&) -> void:
    i: mutable usize = 0
    while i < Devtools_Widget_RegPopupColorRowCount:
        label: static u8& = Devtools_Widget_RegPopup_ColorRowLabel(i)
        if runtime_strlen(label) > 0:
            Devtools_Widget_RegPopup_DrawValueRow(label, Devtools_Widget_RegPopup_ColorRowValue(popup, i))
        i <- i + 1

def Devtools_Widget_RegPopup_DrawDepthBufferRows(popup: Devtools_Widget_RegPopup&) -> void:
    i: mutable usize = 0
    while i < Devtools_Widget_RegPopupDepthBufferRowCount:
        label: static u8& = Devtools_Widget_RegPopup_DepthBufferRowLabel(i)
        if runtime_strlen(label) > 0:
            Devtools_Widget_RegPopup_DrawValueRow(label, Devtools_Widget_RegPopup_DepthBufferRowValue(popup, i))
        i <- i + 1

def Devtools_Widget_RegPopup_DrawDepthControlRows(popup: Devtools_Widget_RegPopup&) -> void:
    i: mutable usize = 0
    while i < Devtools_Widget_RegPopupDepthControlRowCount:
        label: static u8& = Devtools_Widget_RegPopup_DepthControlRowLabel(i)
        if runtime_strlen(label) > 0:
            Devtools_Widget_RegPopup_DrawValueRow(label, Devtools_Widget_RegPopup_DepthControlRowValue(popup, i))
        i <- i + 1

def Devtools_Widget_RegPopup_Draw(popup: mutable Devtools_Widget_RegPopup&) -> void:
    if not popup.open:
        return
    if runtime_strlen(popup.window_name) == 0:
        can Memory.Allocate, Abort.Panic:
            Devtools_Widget_RegPopup_RefreshWindowName(popup)
    if elisa_imgui_begin(popup.window_name, popup.open, popup.flags):
        pos: ElisaImGuiVec2 = elisa_imgui_get_window_pos()
        if pos.x != popup.last_pos.x or pos.y != popup.last_pos.y:
            popup.moved <- true
        if popup.type == Devtools_Widget_RegPopupDataType.Color:
            if elisa_imgui_begin_table("COLOR_BUFFER", 2, ElisaImGuiTableFlags_Borders):
                Devtools_Widget_RegPopup_DrawColorRows(popup)
                elisa_imgui_end_table()
        elif popup.type == Devtools_Widget_RegPopupDataType.Depth:
            elisa_imgui_separator_text("Depth buffer")
            if elisa_imgui_begin_table("DEPTH_BUFFER", 2, ElisaImGuiTableFlags_Borders):
                Devtools_Widget_RegPopup_DrawDepthBufferRows(popup)
                elisa_imgui_end_table()
            elisa_imgui_separator_text("Depth control")
            if elisa_imgui_begin_table("DEPTH_CONTROL", 2, ElisaImGuiTableFlags_Borders):
                Devtools_Widget_RegPopup_DrawDepthControlRows(popup)
                elisa_imgui_end_table()
    elisa_imgui_end()
