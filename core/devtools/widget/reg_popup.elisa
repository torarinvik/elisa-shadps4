def Devtools_Widget_RegPopup_ColorRowValue(popup: Devtools_Widget_RegPopup&, index: usize) -> static u8&:
    if index == 0:
        return Devtools_Widget_RegPopup_HexU32(popup.color.base_address)
    if index == 1:
        return Devtools_Widget_RegPopup_HexU32(popup.color.pitch_tile_max)
    if index == 2:
        return Devtools_Widget_RegPopup_HexU32(popup.color.pitch_fmask_tile_max)
    if index == 3:
        return Devtools_Widget_RegPopup_HexU32(popup.color.slice_tile_max)
    if index == 4:
        return Devtools_Widget_RegPopup_HexU32(popup.color.view_slice_start)
    if index == 5:
        return Devtools_Widget_RegPopup_HexU32(popup.color.view_slice_max)
    if index == 8:
        return Devtools_Widget_RegPopup_HexU32(popup.color.cmask_base_address)
    if index == 9:
        return Devtools_Widget_RegPopup_HexU32(popup.color.fmask_base_address)
    if index == 10:
        return Devtools_Widget_RegPopup_HexU32(popup.color.fmask_slice_tile_max)
    if index == 11:
        return Devtools_Widget_RegPopup_HexU32(popup.color.clear_word0)
    if index == 12:
        return Devtools_Widget_RegPopup_HexU32(popup.color.clear_word1)
    if index == 13:
        return Devtools_Widget_RegPopup_HexU32(Devtools_Widget_ColorBufferSnapshot_Pitch(popup.color))
    if index == 14:
        return Devtools_Widget_RegPopup_HexU32(Devtools_Widget_ColorBufferSnapshot_Height(popup.color))
    if index == 15:
        return Devtools_Widget_RegPopup_HexU64(Devtools_Widget_ColorBufferSnapshot_Address(popup.color))
    if index == 16:
        return Devtools_Widget_RegPopup_HexU64(Devtools_Widget_ColorBufferSnapshot_CmaskAddress(popup.color))
    if index == 17:
        return Devtools_Widget_RegPopup_HexU64(Devtools_Widget_ColorBufferSnapshot_FmaskAddress(popup.color))
    if index == 18:
        return Devtools_Widget_RegPopup_HexU32(Devtools_Widget_ColorBufferSnapshot_NumSamples(popup.color))
    if index == 19:
        return Devtools_Widget_RegPopup_HexU32(Devtools_Widget_ColorBufferSnapshot_NumSlices(popup.color))
    if index == 20:
        return Devtools_Widget_RegPopup_HexU32(Devtools_Widget_ColorBufferSnapshot_GetColorSliceSize(popup.color))
    if index == 21:
        return Devtools_Widget_RegPopup_HexU32(Devtools_Widget_ColorBufferSnapshot_GetTileMode(popup.color))
    if index == 22:
        if Devtools_Widget_ColorBufferSnapshot_IsTiled(popup.color):
            return "1"
        return "0"
    if index == 23:
        return Devtools_Widget_RegPopup_HexU32(popup.color.info_number_type)
    return "0"

