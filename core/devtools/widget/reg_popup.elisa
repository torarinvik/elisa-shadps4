enum Devtools_Widget_RegPopupDataType:
    None
    Color
    Depth

struct Devtools_Widget_ColorBufferSnapshot:
    base_address: mutable u32
    pitch_tile_max: mutable u32
    pitch_fmask_tile_max: mutable u32
    slice_tile_max: mutable u32
    view_slice_start: mutable u32
    view_slice_max: mutable u32
    info_raw: mutable u32
    attrib_raw: mutable u32
    cmask_base_address: mutable u32
    fmask_base_address: mutable u32
    fmask_slice_tile_max: mutable u32
    clear_word0: mutable u32
    clear_word1: mutable u32
    info_linear_general: mutable bool
    attrib_num_fragments_log2: mutable u32
    info_format: mutable u32
    info_number_type: mutable u32
    tile_mode_index: mutable u32

struct Devtools_Widget_DepthBufferSnapshot:
    z_info_format: mutable u32
    z_info_num_samples: mutable u32
    z_info_tile_split: mutable u32
    z_info_tile_mode_index: mutable u32
    z_info_decompress_on_n_zplanes: mutable u32
    z_info_allow_expclear: mutable u32
    z_info_read_size: mutable u32
    z_info_tile_surface_enable: mutable u32
    z_info_clear_disallowed: mutable u32
    z_info_zrange_precision: mutable u32
    stencil_info_format: mutable u32
    z_read_base: mutable u32
    stencil_read_base: mutable u32
    z_write_base: mutable u32
    stencil_write_base: mutable u32
    depth_size_pitch_tile_max: mutable u32
    depth_size_height_tile_max: mutable u32
    depth_slice_tile_max: mutable u32

struct Devtools_Widget_DepthControlSnapshot:
    stencil_enable: mutable u32
    depth_enable: mutable u32
    depth_write_enable: mutable u32
    depth_bounds_enable: mutable u32
    depth_func: mutable u32
    backface_enable: mutable u32
    stencil_ref_func: mutable u32
    stencil_bf_func: mutable u32
    enable_color_writes_on_depth_fail: mutable u32
    disable_color_writes_on_depth_pass: mutable u32

struct Devtools_Widget_RegPopup:
    id: mutable int
    title: mutable static u8&
    window_name: mutable static u8&
    type: mutable Devtools_Widget_RegPopupDataType
    open: mutable bool
    moved: mutable bool
    last_pos: mutable ElisaImGuiVec2
    flags: mutable int
    cb_id: mutable u32
    color_base: mutable u64
    depth_base: mutable u64
    color: mutable Devtools_Widget_ColorBufferSnapshot
    depth_buffer: mutable Devtools_Widget_DepthBufferSnapshot
    depth_control: mutable Devtools_Widget_DepthControlSnapshot

const Devtools_Widget_RegPopupColorRowCount: usize = 24
const Devtools_Widget_RegPopupDepthBufferRowCount: usize = 25
const Devtools_Widget_RegPopupDepthControlRowCount: usize = 10

global mutable Devtools_Widget_RegPopupNextId: int = 0

def Devtools_Widget_RegPopup_New() -> Devtools_Widget_RegPopup:
    out: mutable Devtools_Widget_RegPopup = zeroed
    out.id <- Devtools_Widget_RegPopupNextId
    Devtools_Widget_RegPopupNextId <- Devtools_Widget_RegPopupNextId + 1
    out.title <- ""
    out.window_name <- ""
    out.type <- Devtools_Widget_RegPopupDataType.None
    out.flags <- ElisaImGuiWindowFlags_NoSavedSettings
    return out

def Devtools_Widget_RegPopup_U32ToDecimal(value: u32) -> static u8&:
    can Memory.Allocate, Abort.Panic:
        digits: mutable u32 = 1
        n: mutable u32 = value
        while n >= 10:
            n <- n / 10
            digits <- digits + 1
        out: mutable heap u8& = string_alloc(digits.usize() + 1)
        cursor: mutable int = digits.int() - 1
        x: mutable u32 = value
        while cursor >= 0:
            out[cursor.usize()] <- '0' + (x % 10).u8()
            x <- x / 10
            cursor <- cursor - 1
        out[digits.usize()] <- 0
        return out.cast[static u8&]
    return "0"

def Devtools_Widget_RegPopup_IntToDecimal(value: int) -> static u8&:
    if value < 0:
        can Memory.Allocate, Abort.Panic:
            builder: mutable heap StringBuilder& = string_builder_new("-")
            builder <- string_builder_append(builder, Devtools_Widget_RegPopup_U32ToDecimal((-value).u32()))
            return string_builder_finish(builder).cast[static u8&]
    return Devtools_Widget_RegPopup_U32ToDecimal(value.u32())

def Devtools_Widget_RegPopup_MakeColorTitle(base_title: static u8&, cb_id: u32) -> static u8&:
    can Memory.Allocate, Abort.Panic:
        builder: mutable heap StringBuilder& = string_builder_new(base_title)
        builder <- string_builder_append(builder, "/CB #")
        builder <- string_builder_append(builder, Devtools_Widget_RegPopup_U32ToDecimal(cb_id))
        return string_builder_finish(builder).cast[static u8&]
    return base_title

def Devtools_Widget_RegPopup_MakeDepthTitle(base_title: static u8&) -> static u8&:
    can Memory.Allocate, Abort.Panic:
        builder: mutable heap StringBuilder& = string_builder_new(base_title)
        builder <- string_builder_append(builder, "/Depth")
        return string_builder_finish(builder).cast[static u8&]
    return base_title

def Devtools_Widget_RegPopup_MakeWindowName(title: static u8&, id: int) -> static u8&:
    can Memory.Allocate, Abort.Panic:
        builder: mutable heap StringBuilder& = string_builder_new(title)
        builder <- string_builder_append(builder, "###reg_popup_")
        builder <- string_builder_append(builder, Devtools_Widget_RegPopup_IntToDecimal(id))
        return string_builder_finish(builder).cast[static u8&]
    return title

def Devtools_Widget_RegPopup_RefreshWindowName(popup: mutable Devtools_Widget_RegPopup&) -> void can[Memory.Allocate, Abort.Panic]:
    popup.window_name <- Devtools_Widget_RegPopup_MakeWindowName(popup.title, popup.id)

def Devtools_Widget_RegPopup_SetColorData(popup: mutable Devtools_Widget_RegPopup&, base_title: static u8&, color_base: u64, cb_id: u32) -> void:
    can Memory.Allocate, Abort.Panic:
        popup.title <- Devtools_Widget_RegPopup_MakeColorTitle(base_title, cb_id)
        Devtools_Widget_RegPopup_RefreshWindowName(popup)
    popup.type <- Devtools_Widget_RegPopupDataType.Color
    popup.color_base <- color_base
    popup.cb_id <- cb_id
    popup.color.base_address <- (color_base >> 8).u32()
    popup.open <- true

def Devtools_Widget_RegPopup_SetDepthData(popup: mutable Devtools_Widget_RegPopup&, base_title: static u8&, depth_base: u64) -> void:
    can Memory.Allocate, Abort.Panic:
        popup.title <- Devtools_Widget_RegPopup_MakeDepthTitle(base_title)
        Devtools_Widget_RegPopup_RefreshWindowName(popup)
    popup.type <- Devtools_Widget_RegPopupDataType.Depth
    popup.depth_base <- depth_base
    popup.depth_buffer.z_read_base <- (depth_base >> 8).u32()
    popup.open <- true

def Devtools_Widget_RegPopup_SetPos(popup: mutable Devtools_Widget_RegPopup&, pos: ElisaImGuiVec2, auto_resize: bool) -> void:
    if runtime_strlen(popup.window_name) == 0:
        can Memory.Allocate, Abort.Panic:
            Devtools_Widget_RegPopup_RefreshWindowName(popup)
    if elisa_imgui_begin(popup.window_name, popup.open, popup.flags):
        elisa_imgui_set_window_pos(pos.x, pos.y)
        if auto_resize:
            if popup.type == Devtools_Widget_RegPopupDataType.Color:
                elisa_imgui_set_window_size(365.0, 520.0)
            elif popup.type == Devtools_Widget_RegPopupDataType.Depth:
                elisa_imgui_set_window_size(404.0, 543.0)
        popup.last_pos <- elisa_imgui_get_window_pos()
        popup.moved <- false
    elisa_imgui_end()

def Devtools_Widget_RegPopup_DrawValueRow(label: static u8&, value: static u8&) -> void:
    elisa_imgui_table_next_row()
    elisa_imgui_table_set_column_index(0)
    elisa_imgui_text_unformatted(label)
    elisa_imgui_table_set_column_index(1)
    elisa_imgui_text_unformatted(value)

def Devtools_Widget_RegPopup_HexU32(value: u32) -> static u8&:
    return Devtools_Widget_MemoryEditor_FormatAddress(value.usize(), 1, true)

def Devtools_Widget_RegPopup_HexU64(value: u64) -> static u8&:
    return Devtools_Widget_MemoryEditor_FormatAddress(value.usize(), 1, true)

def Devtools_Widget_ColorBufferSnapshot_Pitch(buffer: Devtools_Widget_ColorBufferSnapshot&) -> u32:
    return (buffer.pitch_tile_max + 1) << 3

def Devtools_Widget_ColorBufferSnapshot_Height(buffer: Devtools_Widget_ColorBufferSnapshot&) -> u32:
    pitch: u32 = Devtools_Widget_ColorBufferSnapshot_Pitch(buffer)
    if pitch == 0:
        return 0
    return ((buffer.slice_tile_max + 1) * 64) / pitch

def Devtools_Widget_ColorBufferSnapshot_Address(buffer: Devtools_Widget_ColorBufferSnapshot&) -> u64:
    address: mutable u64 = buffer.base_address.u64() << 8
    if buffer.info_linear_general:
        address <- address | (buffer.view_slice_start & 0xff).u64()
    return address

def Devtools_Widget_ColorBufferSnapshot_CmaskAddress(buffer: Devtools_Widget_ColorBufferSnapshot&) -> u64:
    return buffer.cmask_base_address.u64() << 8

def Devtools_Widget_ColorBufferSnapshot_FmaskAddress(buffer: Devtools_Widget_ColorBufferSnapshot&) -> u64:
    return buffer.fmask_base_address.u64() << 8

def Devtools_Widget_ColorBufferSnapshot_NumSamples(buffer: Devtools_Widget_ColorBufferSnapshot&) -> u32:
    return 1.u32() << buffer.attrib_num_fragments_log2

def Devtools_Widget_ColorBufferSnapshot_NumSlices(buffer: Devtools_Widget_ColorBufferSnapshot&) -> u32:
    return buffer.view_slice_max + 1

def Devtools_Widget_AmdGpu_NumBitsPerBlock(data_format: u32) -> u32:
    # Mirrors AmdGpu::NumBitsPerBlock(DataFormat) from pixel_format.cpp.
    if data_format == 1:
        return 8
    if data_format == 2:
        return 16
    if data_format == 3:
        return 16
    if data_format == 4:
        return 32
    if data_format == 5:
        return 32
    if data_format == 6:
        return 32
    if data_format == 7:
        return 32
    if data_format == 8:
        return 32
    if data_format == 9:
        return 32
    if data_format == 10:
        return 32
    if data_format == 11:
        return 64
    if data_format == 12:
        return 64
    if data_format == 13:
        return 96
    if data_format == 14:
        return 128
    if data_format == 16:
        return 16
    if data_format == 17:
        return 16
    if data_format == 18:
        return 16
    if data_format == 19:
        return 16
    if data_format == 20:
        return 32
    if data_format == 21:
        return 32
    if data_format == 22:
        return 64
    if data_format == 32:
        return 16
    if data_format == 33:
        return 16
    if data_format == 34:
        return 32
    if data_format == 35:
        return 64
    if data_format == 36:
        return 128
    if data_format == 37:
        return 128
    if data_format == 38:
        return 64
    if data_format == 39:
        return 128
    if data_format == 40:
        return 128
    if data_format == 41:
        return 128
    return 0

def Devtools_Widget_ColorBufferSnapshot_GetColorSliceSize(buffer: Devtools_Widget_ColorBufferSnapshot&) -> u32:
    num_bits_per_block: u32 = Devtools_Widget_AmdGpu_NumBitsPerBlock(buffer.info_format)
    num_bytes_per_element: u32 = num_bits_per_block / 8
    return num_bytes_per_element * (buffer.slice_tile_max + 1) * 64 * Devtools_Widget_ColorBufferSnapshot_NumSamples(buffer)

def Devtools_Widget_ColorBufferSnapshot_GetTileMode(buffer: Devtools_Widget_ColorBufferSnapshot&) -> u32:
    if buffer.info_linear_general:
        return 8
    return buffer.tile_mode_index

def Devtools_Widget_ColorBufferSnapshot_IsTiled(buffer: Devtools_Widget_ColorBufferSnapshot&) -> bool:
    mode: u32 = Devtools_Widget_ColorBufferSnapshot_GetTileMode(buffer)
    return mode != 7 and mode != 8

def Devtools_Widget_DepthBufferSnapshot_Pitch(buffer: Devtools_Widget_DepthBufferSnapshot&) -> u32:
    return (buffer.depth_size_pitch_tile_max + 1) << 3

def Devtools_Widget_DepthBufferSnapshot_Height(buffer: Devtools_Widget_DepthBufferSnapshot&) -> u32:
    return (buffer.depth_size_height_tile_max + 1) << 3

def Devtools_Widget_DepthBufferSnapshot_DepthAddress(buffer: Devtools_Widget_DepthBufferSnapshot&) -> u64:
    return buffer.z_read_base.u64() << 8

def Devtools_Widget_DepthBufferSnapshot_StencilAddress(buffer: Devtools_Widget_DepthBufferSnapshot&) -> u64:
    return buffer.stencil_read_base.u64() << 8

def Devtools_Widget_DepthBufferSnapshot_NumSamples(buffer: Devtools_Widget_DepthBufferSnapshot&) -> u32:
    return 1.u32() << buffer.z_info_num_samples

def Devtools_Widget_DepthBufferSnapshot_NumBits(buffer: Devtools_Widget_DepthBufferSnapshot&) -> u32:
    if buffer.z_info_format == 3:
        return 32
    return 16

def Devtools_Widget_DepthBufferSnapshot_GetDepthSliceSize(buffer: Devtools_Widget_DepthBufferSnapshot&) -> u32:
    bytes_per_element: u32 = Devtools_Widget_DepthBufferSnapshot_NumBits(buffer) >> 3
    return (buffer.depth_slice_tile_max + 1) * 64 * bytes_per_element * Devtools_Widget_DepthBufferSnapshot_NumSamples(buffer)

