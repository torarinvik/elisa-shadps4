enum Devtools_Widget_MemoryDataFormat:
    Bin
    Dec
    Hex

struct Devtools_Widget_MemoryEditorSizes:
    AddrDigitsCount: mutable int
    LineHeight: mutable f32
    GlyphWidth: mutable f32
    HexCellWidth: mutable f32
    SpacingBetweenMidCols: mutable f32
    PosHexStart: mutable f32
    PosHexEnd: mutable f32
    PosAsciiStart: mutable f32
    PosAsciiEnd: mutable f32
    WindowWidth: mutable f32

struct Devtools_Widget_MemoryEditor:
    Open: mutable bool
    ReadOnly: mutable bool
    Cols: mutable int
    OptShowOptions: mutable bool
    OptShowDataPreview: mutable bool
    OptShowHexII: mutable bool
    OptShowAscii: mutable bool
    OptGreyOutZeroes: mutable bool
    OptUpperCaseHex: mutable bool
    OptMidColsCount: mutable int
    OptAddrDigitsCount: mutable int
    OptFooterExtraHeight: mutable f32
    MouseHovered: mutable bool
    MouseHoveredAddr: mutable usize
    ContentsWidthChanged: mutable bool
    DataPreviewAddr: mutable usize
    DataEditingAddr: mutable usize
    DataEditingTakeFocus: mutable bool
    GotoAddr: mutable usize
    HighlightMin: mutable usize
    HighlightMax: mutable usize
    PreviewEndianness: mutable int
    PreviewDataType: mutable int

def Devtools_Widget_MemoryEditor_New() -> Devtools_Widget_MemoryEditor:
    out: mutable Devtools_Widget_MemoryEditor = zeroed
    out.Open <- true
    out.Cols <- 16
    out.OptShowOptions <- true
    out.OptShowAscii <- true
    out.OptGreyOutZeroes <- true
    out.OptUpperCaseHex <- true
    out.OptMidColsCount <- 8
    out.DataPreviewAddr <- 18446744073709551615.usize()
    out.DataEditingAddr <- 18446744073709551615.usize()
    out.GotoAddr <- 18446744073709551615.usize()
    out.HighlightMin <- 18446744073709551615.usize()
    out.HighlightMax <- 18446744073709551615.usize()
    return out

def Devtools_Widget_MemoryEditor_GotoAddrAndHighlight(editor: mutable Devtools_Widget_MemoryEditor&, addr_min: usize, addr_max: usize) -> void:
    editor.GotoAddr <- addr_min
    editor.HighlightMin <- addr_min
    editor.HighlightMax <- addr_max

def Devtools_Widget_MemoryEditor_CalcAddrDigits(editor: Devtools_Widget_MemoryEditor&, mem_size: usize, base_display_addr: usize) -> int:
    if editor.OptAddrDigitsCount != 0:
        return editor.OptAddrDigitsCount
    n: mutable usize = base_display_addr + mem_size - 1
    digits: mutable int = 0
    while n > 0:
        digits <- digits + 1
        n <- n >> 4
    return digits

def Devtools_Widget_MemoryEditor_ReadByte(mem: static u8&, off: usize) -> u8:
    return mem[off]

def Devtools_Widget_MemoryEditor_WriteByte(mem: mutable u8&, off: usize, value: u8, read_only: bool) -> void:
    if read_only:
        return
    mem[off] <- value
