struct DevtoolsOptions:
    disassembler_cli_isa: mutable static u8&
    disassembler_cli_spv: mutable static u8&
    frame_dump_render_on_collapse: mutable bool

global mutable Devtools_Option_DisassemblerCliIsa: static u8&? = null
global mutable Devtools_Option_DisassemblerCliSpv: static u8&? = null
global mutable Devtools_Option_FrameDumpRenderOnCollapse: bool = false

def Devtools_GetDisassemblerCliIsa() -> static u8&:
    if Devtools_Option_DisassemblerCliIsa == null:
        return "clrxdisasm --raw {src}"
    return Devtools_Option_DisassemblerCliIsa.cast[static u8&]

def Devtools_GetDisassemblerCliSpv() -> static u8&:
    if Devtools_Option_DisassemblerCliSpv == null:
        return "spirv-cross -V {src}"
    return Devtools_Option_DisassemblerCliSpv.cast[static u8&]

def Devtools_GetOptions() -> DevtoolsOptions:
    return DevtoolsOptions(Devtools_GetDisassemblerCliIsa(), Devtools_GetDisassemblerCliSpv(), Devtools_Option_FrameDumpRenderOnCollapse)

def Devtools_StringStartsWith(input: static u8&, prefix: static u8&) -> bool:
    prefix_len: usize = runtime_strlen(prefix)
    if runtime_strlen(input) < prefix_len:
        return false
    return string_slice_eq(input, 0, prefix_len, prefix) == 1

def Devtools_ConfigValue(line: static u8&, key: static u8&) -> static u8& can[Memory.Allocate, Abort.Panic]:
    key_len: usize = runtime_strlen(key)
    can Memory.Allocate, Abort.Panic:
        return string_substr(line, key_len, runtime_strlen(line) - key_len)
    return ""

def Devtools_ParseBool(value: static u8&) -> bool:
    if runtime_strlen(value) == 0:
        return false
    return value[0] != '0'

def Devtools_LoadOptionsConfig(line: static u8&) -> void can[Memory.Allocate, Abort.Panic]:
    key_isa: static u8& = "disassembler_cli_isa="
    key_spv: static u8& = "disassembler_cli_spv="
    key_collapse: static u8& = "frame_dump_render_on_collapse="

    if Devtools_StringStartsWith(line, key_isa):
        can Memory.Allocate, Abort.Panic:
            Devtools_Option_DisassemblerCliIsa <- Devtools_ConfigValue(line, key_isa)
        return
    if Devtools_StringStartsWith(line, key_spv):
        can Memory.Allocate, Abort.Panic:
            Devtools_Option_DisassemblerCliSpv <- Devtools_ConfigValue(line, key_spv)
        return
    if Devtools_StringStartsWith(line, key_collapse):
        can Memory.Allocate, Abort.Panic:
            Devtools_Option_FrameDumpRenderOnCollapse <- Devtools_ParseBool(Devtools_ConfigValue(line, key_collapse))
        return

def Devtools_SerializeOptionsConfig() -> static u8&:
    can Memory.Allocate, Abort.Panic:
        builder: mutable heap StringBuilder& = string_builder_new("disassembler_cli_isa=")
        builder <- string_builder_append(builder, Devtools_GetDisassemblerCliIsa())
        builder <- string_builder_append(builder, "\n")
        builder <- string_builder_append(builder, "disassembler_cli_spv=")
        builder <- string_builder_append(builder, Devtools_GetDisassemblerCliSpv())
        builder <- string_builder_append(builder, "\nframe_dump_render_on_collapse=")
        builder <- string_builder_append(builder, "1" if Devtools_Option_FrameDumpRenderOnCollapse else "0")
        builder <- string_builder_append(builder, "\n")
        return string_builder_finish(builder).cast[static u8&]
    return ""
