struct Devtools_LayerState:
    show_simple_fps: mutable bool
    show_quit_window: mutable bool
    show_volume: mutable bool
    volume_start_time: mutable f32
    fps_scale: mutable f32
    dump_frame_count: mutable i32
    debug_popup_timing: mutable f32
    frame_graph: mutable Devtools_Widget_FrameGraph
    memory_map: mutable Devtools_Widget_MemoryMapViewer
    shader_list: mutable Devtools_Widget_ShaderList
    module_list: mutable Devtools_Widget_ModuleList

global mutable Devtools_Layer_Data: Devtools_LayerState = Devtools_LayerState(
    false,
    false,
    false,
    0.0,
    1.0,
    1,
    3.0,
    Devtools_Widget_FrameGraph_New(),
    Devtools_Widget_MemoryMapViewer_New(),
    zeroed,
    zeroed
)

def Devtools_Layer_SetupSettings() -> void:
    Devtools_Layer_Data.frame_graph.is_open <- true

def Devtools_Layer_LoadSettingLine(line: static u8&) -> void:
    if Devtools_StringStartsWith(line, "fps_scale="):
        value: static u8& = Devtools_ConfigValue(line, "fps_scale=")
        parsed: int = config_parse_int(value)
        if parsed > 0:
            Devtools_Layer_Data.fps_scale <- parsed.f32() / 100.0
        return
    if Devtools_StringStartsWith(line, "dump_frame_count="):
        value2: static u8& = Devtools_ConfigValue(line, "dump_frame_count=")
        parsed2: int = config_parse_int(value2)
        if parsed2 >= 1 and parsed2 <= 5:
            Devtools_Layer_Data.dump_frame_count <- parsed2.i32()
        return
    if Devtools_StringStartsWith(line, "show_simple_fps="):
        value3: static u8& = Devtools_ConfigValue(line, "show_simple_fps=")
        Devtools_Layer_Data.show_simple_fps <- Devtools_ParseBool(value3)
        return

def Devtools_Layer_SerializeSettings() -> static u8&:
    can Memory.Allocate, Abort.Panic:
        b: mutable heap StringBuilder& = string_builder_new("fps_scale=")
        b <- string_builder_append(b, int_to_string_scratch((Devtools_Layer_Data.fps_scale * 100.0).i64()).cast[static u8&])
        b <- string_builder_append(b, "\n")
        b <- string_builder_append(b, "dump_frame_count=")
        b <- string_builder_append(b, int_to_string_scratch(Devtools_Layer_Data.dump_frame_count.i64()).cast[static u8&])
        b <- string_builder_append(b, "\n")
        b <- string_builder_append(b, "show_simple_fps=")
        b <- string_builder_append(b, "1" if Devtools_Layer_Data.show_simple_fps else "0")
        b <- string_builder_append(b, "\n")
        return string_builder_finish(b).cast[static u8&]
    return ""

def Devtools_Layer_DrawSimple() -> void:
    elisa_imgui_text_unformatted("FPS overlay enabled")

def Devtools_Layer_DrawAdvanced() -> void:
    if elisa_imgui_begin("Devtools", null, ElisaImGuiWindowFlags_MenuBar):
        elisa_imgui_text_unformatted("GPU Tools")
        elisa_imgui_same_line(0.0, -1.0)
        if elisa_imgui_button("Frame Info"):
            Devtools_Layer_Data.frame_graph.is_open <- not Devtools_Layer_Data.frame_graph.is_open
        elisa_imgui_same_line(0.0, -1.0)
        if elisa_imgui_button("Shaders"):
            Devtools_Layer_Data.shader_list.open <- not Devtools_Layer_Data.shader_list.open
        elisa_imgui_same_line(0.0, -1.0)
        if elisa_imgui_button("Memory"):
            Devtools_Layer_Data.memory_map.open <- not Devtools_Layer_Data.memory_map.open
        elisa_imgui_same_line(0.0, -1.0)
        if elisa_imgui_button("Modules"):
            Devtools_Layer_Data.module_list.open <- not Devtools_Layer_Data.module_list.open
    elisa_imgui_end()

    Devtools_Widget_FrameGraph_Draw(Devtools_Layer_Data.frame_graph)
    if Devtools_Layer_Data.memory_map.open:
        Devtools_Widget_MemoryMapViewer_Draw(Devtools_Layer_Data.memory_map)
    if Devtools_Layer_Data.shader_list.open:
        Devtools_Widget_ShaderList_Draw(Devtools_Layer_Data.shader_list)
    if Devtools_Layer_Data.module_list.open:
        Devtools_Widget_ModuleList_Draw(Devtools_Layer_Data.module_list)

def Devtools_Layer_Draw() -> void:
    if Devtools_Layer_Data.show_simple_fps:
        if elisa_imgui_begin("Video Info", null, 0):
            Devtools_Layer_DrawSimple()
        elisa_imgui_end()
    Devtools_Layer_DrawAdvanced()
    if Devtools_Layer_Data.show_quit_window:
        if elisa_imgui_begin("Quit Notification", Devtools_Layer_Data.show_quit_window, 0):
            elisa_imgui_text_unformatted("Are you sure you want to quit?")
            elisa_imgui_text_unformatted("Press Escape or Circle/B button to cancel")
            elisa_imgui_text_unformatted("Press Enter or Cross/A button to quit")
        elisa_imgui_end()
    if Devtools_Layer_Data.show_volume:
        now: f32 = elisa_imgui_get_time()
        if now - Devtools_Layer_Data.volume_start_time >= 3.0:
            Devtools_Layer_Data.show_volume <- false
        else:
            if elisa_imgui_begin("Volume Window", Devtools_Layer_Data.show_volume, 0):
                elisa_imgui_text_unformatted("Volume")
            elisa_imgui_end()

def Devtools_Overlay_TextCentered(text: static u8&) -> void:
    avail: ElisaImGuiVec2 = elisa_imgui_get_content_region_avail()
    text_size: ElisaImGuiVec2 = elisa_imgui_font_calc_text_size(0, elisa_imgui_font_size(0), text)
    indent: mutable f32 = (avail.x - text_size.x) * 0.5
    if indent < 0.0:
        indent <- 0.0
    elisa_imgui_set_cursor_pos_x(indent)
    elisa_imgui_text_unformatted(text)

def Devtools_Overlay_ToggleSimpleFps() -> void:
    Devtools_Layer_Data.show_simple_fps <- not Devtools_Layer_Data.show_simple_fps

def Devtools_Overlay_SetSimpleFps(enabled: bool) -> void:
    Devtools_Layer_Data.show_simple_fps <- enabled

def Devtools_Overlay_ToggleQuitWindow() -> void:
    Devtools_Layer_Data.show_quit_window <- not Devtools_Layer_Data.show_quit_window

def Devtools_Overlay_ShowVolume() -> void:
    Devtools_Layer_Data.volume_start_time <- elisa_imgui_get_time()
    Devtools_Layer_Data.show_volume <- true
