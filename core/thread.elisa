include "../common/types.elisa"

type ThreadFuncPtr = uintptr

struct NativeThread:
    native_handle: mutable uintptr
    tid: mutable u64
    started: mutable bool

global mutable native_thread_next_tid: u64 = 1

def NativeThread_New() -> NativeThread:
    return NativeThread(0.uintptr(), 0.u64(), false)

def NativeThread_Create(self: mutable NativeThread&, func: ThreadFuncPtr, arg: void&?) -> int:
    _ = arg
    if func == 0.uintptr():
        return -1
    self.tid <- native_thread_next_tid
    native_thread_next_tid <- native_thread_next_tid + 1
    self.native_handle <- self.tid.uintptr()
    self.started <- true
    return 0

def NativeThread_Exit(self: mutable NativeThread&) -> void:
    self.started <- false

def NativeThread_Initialize(self: mutable NativeThread&) -> void:
    if self.tid == 0:
        self.tid <- native_thread_next_tid
        native_thread_next_tid <- native_thread_next_tid + 1
        self.native_handle <- self.tid.uintptr()

def NativeThread_GetHandle(self: NativeThread&) -> uintptr:
    return self.native_handle

def NativeThread_GetTid(self: NativeThread&) -> u64:
    return self.tid
