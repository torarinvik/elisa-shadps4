include "../../common/io_file.elisa"

# Persistent arena owning the buffers grown while parsing an ELF/SELF (segment
# bytes, program/section headers, self segments). These outlive the individual
# helper calls that append to them, so they must NOT be grown from a transient
# local arena (whose storage is freed on return -> use-after-free).
global mutable elf_parse_arena: Arena = zeroed

def Elf_ResetParseArena() -> void:
    elf_parse_arena <- zeroed

const EI_MAG0: u8 = 0
const EI_MAG1: u8 = 1
const EI_MAG2: u8 = 2
const EI_MAG3: u8 = 3
const ELFMAG0: u8 = 0x7F
const ELFMAG1: u8 = 0x45
const ELFMAG2: u8 = 0x4c
const ELFMAG3: u8 = 0x46

const ET_SCE_EXEC: u16 = 0xfe00
const ET_SCE_STUBLIB: u16 = 0xfe0c
const ET_SCE_DYNEXEC: u16 = 0xfe10
const ET_SCE_DYNAMIC: u16 = 0xfe18
const EM_X86_64: u16 = 62
const EV_CURRENT: u32 = 1

const PT_NULL: u32 = 0x0
const PT_LOAD: u32 = 0x1
const PT_DYNAMIC: u32 = 0x2
const PT_INTERP: u32 = 0x3
const PT_NOTE: u32 = 0x4
const PT_SHLIB: u32 = 0x5
const PT_PHDR: u32 = 0x6
const PT_TLS: u32 = 0x7
const PT_NUM: u32 = 0x8
const PT_SCE_RELA: u32 = 0x60000000
const PT_SCE_DYNLIBDATA: u32 = 0x61000000
const PT_SCE_PROCPARAM: u32 = 0x61000001
const PT_SCE_MODULE_PARAM: u32 = 0x61000002
const PT_SCE_RELRO: u32 = 0x61000010
const PT_GNU_EH_FRAME: u32 = 0x6474e550
const PT_GNU_STACK: u32 = 0x6474e551
const PT_GNU_RELRO: u32 = 0x6474e552
const PT_SCE_COMMENT: u32 = 0x6fffff00
const PT_SCE_LIBVERSION: u32 = 0x6fffff01

const PF_NONE: u32 = 0x0
const PF_EXEC: u32 = 0x1
const PF_WRITE: u32 = 0x2
const PF_READ: u32 = 0x4

const DT_NULL: i64 = 0.i64()
const DT_NEEDED: i64 = 0x00000001
const DT_STRTAB: i64 = 0x00000005
const DT_SYMTAB: i64 = 0x00000006
const DT_RELA: i64 = 0x00000007
const DT_STRSZ: i64 = 0x0000000a
const DT_SYMENT: i64 = 0x0000000b
const DT_INIT: i64 = 0x0000000c
const DT_FINI: i64 = 0x0000000d
const DT_DEBUG: i64 = 0x00000015
const DT_TEXTREL: i64 = 0x00000016
const DT_INIT_ARRAY: i64 = 0x00000019
const DT_FINI_ARRAY: i64 = 0x0000001a
const DT_INIT_ARRAYSZ: i64 = 0x0000001b
const DT_FINI_ARRAYSZ: i64 = 0x0000001c
const DT_FLAGS: i64 = 0x0000001e
const DT_PREINIT_ARRAY: i64 = 0x00000020
const DT_PREINIT_ARRAYSZ: i64 = 0x00000021
const DT_SCE_FINGERPRINT: i64 = 0x61000007
const DT_SCE_ORIGINAL_FILENAME: i64 = 0x61000009
const DT_SCE_MODULE_INFO: i64 = 0x6100000d
const DT_SCE_NEEDED_MODULE: i64 = 0x6100000f
const DT_SCE_MODULE_ATTR: i64 = 0x61000011
const DT_SCE_EXPORT_LIB: i64 = 0x61000013
const DT_SCE_IMPORT_LIB: i64 = 0x61000015
const DT_SCE_IMPORT_LIB_ATTR: i64 = 0x61000019
const DT_SCE_HASH: i64 = 0x61000025
const DT_SCE_PLTGOT: i64 = 0x61000027
const DT_SCE_JMPREL: i64 = 0x61000029
const DT_SCE_PLTREL: i64 = 0x6100002b
const DT_SCE_PLTRELSZ: i64 = 0x6100002d
const DT_SCE_RELA: i64 = 0x6100002f
const DT_SCE_RELASZ: i64 = 0x61000031
const DT_SCE_RELAENT: i64 = 0x61000033
const DT_SCE_STRTAB: i64 = 0x61000035
const DT_SCE_STRSZ: i64 = 0x61000037
const DT_SCE_SYMTAB: i64 = 0x61000039
const DT_SCE_SYMENT: i64 = 0x6100003b
const DT_SCE_HASHSZ: i64 = 0x6100003d
const DT_SCE_SYMTABSZ: i64 = 0x6100003f

const STB_LOCAL: u8 = 0
const STB_GLOBAL: u8 = 1
const STB_WEAK: u8 = 2
const STT_NOTYPE: u8 = 0
const STT_OBJECT: u8 = 1
const STT_FUN: u8 = 2
const STT_SECTION: u8 = 3
const STT_FILE: u8 = 4
const STT_COMMON: u8 = 5
const STT_TLS: u8 = 6
const STT_LOOS: u8 = 10
const STT_SCE: u8 = 11
const STT_HIOS: u8 = 12
const STT_LOPRO: u8 = 13
const STT_HIPROC: u8 = 15
const STV_DEFAULT: u8 = 0
const STV_INTERNAL: u8 = 1
const STV_HIDDEN: u8 = 2
const STV_PROTECTED: u8 = 3

const R_X86_64_64: u32 = 1
const R_X86_64_GLOB_DAT: u32 = 6
const R_X86_64_JUMP_SLOT: u32 = 7
const R_X86_64_RELATIVE: u32 = 8
const R_X86_64_DTPMOD64: u32 = 16

struct self_header:
    magic: mutable u32
    version: mutable u8
    mode: mutable u8
    endian: mutable u8
    attributes: mutable u8
    category: mutable u8
    program_type: mutable u8
    padding1: mutable u16
    header_size: mutable u16
    meta_size: mutable u16
    file_size: mutable u32
    padding2: mutable u32
    segment_count: mutable u16
    unknown1A: mutable u16
    padding3: mutable u32

struct elf_ident:
    magic: mutable u8[4]
    ei_class: mutable u8
    ei_data: mutable u8
    ei_version: mutable u8
    ei_osabi: mutable u8
    ei_abiversion: mutable u8
    pad: mutable u8[7]

struct elf_header:
    e_ident: mutable elf_ident
    e_type: mutable u16
    e_machine: mutable u16
    e_version: mutable u32
    e_entry: mutable u64
    e_phoff: mutable u64
    e_shoff: mutable u64
    e_flags: mutable u32
    e_ehsize: mutable u16
    e_phentsize: mutable u16
    e_phnum: mutable u16
    e_shentsize: mutable u16
    e_shnum: mutable u16
    e_shstrndx: mutable u16

struct elf_program_header:
    p_type: mutable u32
    p_flags: mutable u32
    p_offset: mutable u64
    p_vaddr: mutable u64
    p_paddr: mutable u64
    p_filesz: mutable u64
    p_memsz: mutable u64
    p_align: mutable u64

struct elf_section_header:
    sh_name: mutable u32
    sh_type: mutable u32
    sh_flags: mutable u64
    sh_addr: mutable u64
    sh_offset: mutable u64
    sh_size: mutable u64
    sh_link: mutable u32
    sh_info: mutable u32
    sh_addralign: mutable u64
    sh_entsize: mutable u64

struct elf_dynamic:
    d_tag: mutable i64
    d_un: mutable u64

struct elf_symbol:
    st_name: mutable u32
    st_info: mutable u8
    st_other: mutable u8
    st_shndx: mutable u16
    st_value: mutable u64
    st_size: mutable u64

struct elf_relocation:
    rel_offset: mutable u64
    rel_info: mutable u64
    rel_addend: mutable i64

struct eh_frame_hdr:
    version: mutable u8
    eh_frame_ptr_enc: mutable u8
    fde_count_enc: mutable u8
    table_enc: mutable u8
    eh_frame_ptr: mutable u32
    fde_count: mutable u32

struct self_segment_header:
    flags: mutable u64
    file_offset: mutable u64
    file_size: mutable u64
    memory_size: mutable u64

struct elf_program_id_header:
    authid: mutable u64
    program_type: mutable u64
    appver: mutable u64
    firmver: mutable u64
    digest: mutable u8[32]

struct Elf:
    f: mutable IOFile
    self: mutable self_header
    elf_header_value: mutable elf_header
    is_self: mutable bool
    program_headers: mutable darray[elf_program_header]
    section_headers: mutable darray[elf_section_header]
    self_segments: mutable darray[self_segment_header]
    self_id_header: mutable elf_program_id_header

def Elf_new() -> Elf:
    return Elf(IOFile_new(), zeroed, zeroed, false, zeroed, zeroed, zeroed, zeroed)

def Elf_IsOpen(self: Elf&) -> bool:
    return IOFile_IsOpen(self.f)

def Elf_ResizeBytes(out: mutable darray[u8]&, size: usize) -> void:
    owner: mutable Arena& = elf_parse_arena.ref[mutable Arena&]
    in owner:
        while out.count < size:
            out.push(0)

def Elf_ResizeSelfSegments(out: mutable darray[self_segment_header]&, size: usize) -> void:
    owner: mutable Arena& = elf_parse_arena.ref[mutable Arena&]
    in owner:
        while out.count < size:
            out.push(zeroed.cast[self_segment_header])

def Elf_ResizeProgramHeaders(out: mutable darray[elf_program_header]&, size: usize) -> void:
    owner: mutable Arena& = elf_parse_arena.ref[mutable Arena&]
    in owner:
        while out.count < size:
            out.push(zeroed.cast[elf_program_header])

def Elf_ResizeSectionHeaders(out: mutable darray[elf_section_header]&, size: usize) -> void:
    owner: mutable Arena& = elf_parse_arena.ref[mutable Arena&]
    in owner:
        while out.count < size:
            out.push(zeroed.cast[elf_section_header])

def Elf_PushSelfSegment(out: mutable darray[self_segment_header]&, value: self_segment_header) -> void:
    owner: mutable Arena& = elf_parse_arena.ref[mutable Arena&]
    in owner:
        out.push(value)

def Elf_PushProgramHeader(out: mutable darray[elf_program_header]&, value: elf_program_header) -> void:
    owner: mutable Arena& = elf_parse_arena.ref[mutable Arena&]
    in owner:
        out.push(value)

def Elf_PushSectionHeader(out: mutable darray[elf_section_header]&, value: elf_section_header) -> void:
    owner: mutable Arena& = elf_parse_arena.ref[mutable Arena&]
    in owner:
        out.push(value)

def Elf_ReadU8(f: IOFile&) -> u8:
    value: mutable u8 = 0
    _ = IOFile_ReadRaw(f, value.ref[mutable u8&].cast[mutable void&], 1, 1)
    return value

def Elf_ReadU16(f: IOFile&) -> u16:
    value: mutable u16 = 0
    _ = IOFile_ReadRaw(f, value.ref[mutable u16&].cast[mutable void&], 2, 1)
    return value

def Elf_ReadU32(f: IOFile&) -> u32:
    value: mutable u32 = 0
    _ = IOFile_ReadRaw(f, value.ref[mutable u32&].cast[mutable void&], 4, 1)
    return value

def Elf_ReadU64(f: IOFile&) -> u64:
    value: mutable u64 = 0
    _ = IOFile_ReadRaw(f, value.ref[mutable u64&].cast[mutable void&], 8, 1)
    return value

def Elf_ReadI64(f: IOFile&) -> i64:
    return Elf_ReadU64(f).i64()

def Elf_ReadSelfHeader(f: IOFile&) -> self_header:
    out: mutable self_header = zeroed
    out.magic <- Elf_ReadU32(f)
    out.version <- Elf_ReadU8(f)
    out.mode <- Elf_ReadU8(f)
    out.endian <- Elf_ReadU8(f)
    out.attributes <- Elf_ReadU8(f)
    out.category <- Elf_ReadU8(f)
    out.program_type <- Elf_ReadU8(f)
    out.padding1 <- Elf_ReadU16(f)
    out.header_size <- Elf_ReadU16(f)
    out.meta_size <- Elf_ReadU16(f)
    out.file_size <- Elf_ReadU32(f)
    out.padding2 <- Elf_ReadU32(f)
    out.segment_count <- Elf_ReadU16(f)
    out.unknown1A <- Elf_ReadU16(f)
    out.padding3 <- Elf_ReadU32(f)
    return out

def Elf_ReadSelfSegmentHeader(f: IOFile&) -> self_segment_header:
    out: mutable self_segment_header = zeroed
    out.flags <- Elf_ReadU64(f)
    out.file_offset <- Elf_ReadU64(f)
    out.file_size <- Elf_ReadU64(f)
    out.memory_size <- Elf_ReadU64(f)
    return out

def Elf_ReadIdent(f: IOFile&) -> elf_ident:
    ident: mutable elf_ident = zeroed
    ident.magic[0] <- Elf_ReadU8(f)
    ident.magic[1] <- Elf_ReadU8(f)
    ident.magic[2] <- Elf_ReadU8(f)
    ident.magic[3] <- Elf_ReadU8(f)
    ident.ei_class <- Elf_ReadU8(f)
    ident.ei_data <- Elf_ReadU8(f)
    ident.ei_version <- Elf_ReadU8(f)
    ident.ei_osabi <- Elf_ReadU8(f)
    ident.ei_abiversion <- Elf_ReadU8(f)
    for i in 0..<7:
        ident.pad[i] <- Elf_ReadU8(f)
    return ident

def Elf_ReadElfHeader(f: IOFile&) -> elf_header:
    out: mutable elf_header = zeroed
    out.e_ident <- Elf_ReadIdent(f)
    out.e_type <- Elf_ReadU16(f)
    out.e_machine <- Elf_ReadU16(f)
    out.e_version <- Elf_ReadU32(f)
    out.e_entry <- Elf_ReadU64(f)
    out.e_phoff <- Elf_ReadU64(f)
    out.e_shoff <- Elf_ReadU64(f)
    out.e_flags <- Elf_ReadU32(f)
    out.e_ehsize <- Elf_ReadU16(f)
    out.e_phentsize <- Elf_ReadU16(f)
    out.e_phnum <- Elf_ReadU16(f)
    out.e_shentsize <- Elf_ReadU16(f)
    out.e_shnum <- Elf_ReadU16(f)
    out.e_shstrndx <- Elf_ReadU16(f)
    return out

def Elf_ReadProgramHeader(f: IOFile&) -> elf_program_header:
    out: mutable elf_program_header = zeroed
    out.p_type <- Elf_ReadU32(f)
    out.p_flags <- Elf_ReadU32(f)
    out.p_offset <- Elf_ReadU64(f)
    out.p_vaddr <- Elf_ReadU64(f)
    out.p_paddr <- Elf_ReadU64(f)
    out.p_filesz <- Elf_ReadU64(f)
    out.p_memsz <- Elf_ReadU64(f)
    out.p_align <- Elf_ReadU64(f)
    return out

def Elf_ReadSectionHeader(f: IOFile&) -> elf_section_header:
    out: mutable elf_section_header = zeroed
    out.sh_name <- Elf_ReadU32(f)
    out.sh_type <- Elf_ReadU32(f)
    out.sh_flags <- Elf_ReadU64(f)
    out.sh_addr <- Elf_ReadU64(f)
    out.sh_offset <- Elf_ReadU64(f)
    out.sh_size <- Elf_ReadU64(f)
    out.sh_link <- Elf_ReadU32(f)
    out.sh_info <- Elf_ReadU32(f)
    out.sh_addralign <- Elf_ReadU64(f)
    out.sh_entsize <- Elf_ReadU64(f)
    return out

def SelfSegment_IsBlocked(seg: self_segment_header&) -> bool:
    return (seg.flags & 0x800) != 0

def SelfSegment_GetId(seg: self_segment_header&) -> u32:
    return ((seg.flags >> 20) & 0xFFF).u32()

def SelfSegment_IsOrdered(seg: self_segment_header&) -> bool:
    return (seg.flags & 0x1) != 0

def SelfSegment_IsEncrypted(seg: self_segment_header&) -> bool:
    return (seg.flags & 0x2) != 0

def SelfSegment_IsSigned(seg: self_segment_header&) -> bool:
    return (seg.flags & 0x4) != 0

def SelfSegment_IsCompressed(seg: self_segment_header&) -> bool:
    return (seg.flags & 0x8) != 0

def ElfSymbol_GetBind(sym: elf_symbol&) -> u8:
    return sym.st_info >> 4

def ElfSymbol_GetType(sym: elf_symbol&) -> u8:
    return sym.st_info & 0x0F

def ElfSymbol_GetVisibility(sym: elf_symbol&) -> u8:
    return sym.st_other & 0x03

def ElfRelocation_GetSymbol(rel: elf_relocation&) -> u32:
    return (rel.rel_info >> 32).u32()

def ElfRelocation_GetType(rel: elf_relocation&) -> u32:
    return (rel.rel_info & 0xffffffff).u32()

def Elf_IsSelfFile(self: Elf&) -> bool:
    if self.self.magic != 0x1D3D154F:
        return false
    if self.self.version != 0x00 or self.self.mode != 0x01 or self.self.endian != 0x01:
        return false
    if self.self.attributes != 0x12:
        return false
    if self.self.category != 0x01 or self.self.program_type != 0x01:
        return false
    return true

def Elf_IsElfFile(self: Elf&) -> bool:
    ident: elf_ident = self.elf_header_value.e_ident
    if ident.magic[EI_MAG0.int()] != ELFMAG0 or ident.magic[EI_MAG1.int()] != ELFMAG1 or ident.magic[EI_MAG2.int()] != ELFMAG2 or ident.magic[EI_MAG3.int()] != ELFMAG3:
        return false
    if ident.ei_class != 0x02 or ident.ei_data != 0x01 or ident.ei_version != 0x01:
        return false
    if ident.ei_osabi != 0x09 or ident.ei_abiversion != 0x00:
        return false
    if self.elf_header_value.e_type != ET_SCE_DYNEXEC and self.elf_header_value.e_type != ET_SCE_DYNAMIC and self.elf_header_value.e_type != ET_SCE_EXEC:
        return false
    if self.elf_header_value.e_machine != EM_X86_64:
        return false
    if self.elf_header_value.e_version != EV_CURRENT:
        return false
    if self.elf_header_value.e_phentsize != size_of(elf_program_header).u16():
        return false
    if self.elf_header_value.e_shentsize > 0 and self.elf_header_value.e_shentsize != size_of(elf_section_header).u16():
        return false
    return true

def Elf_Open(self: mutable Elf&, file_name: static u8&) -> void:
    self.f <- IOFile_opened(file_name, FileAccessMode.Read)
    if not IOFile_IsOpen(self.f):
        return
    self.self <- Elf_ReadSelfHeader(self.f)
    self.is_self <- Elf_IsSelfFile(self.ref[Elf&])
    if not self.is_self:
        _ = IOFile_Seek(self.f, 0)
    else:
        i: mutable u16 = 0
        while i < self.self.segment_count:
            seg: self_segment_header = Elf_ReadSelfSegmentHeader(self.f)
            Elf_PushSelfSegment(self.self_segments, seg)
            i <- i + 1
    elf_header_pos: i64 = IOFile_Tell(self.f)
    self.elf_header_value <- Elf_ReadElfHeader(self.f)
    if not Elf_IsElfFile(self.ref[Elf&]):
        return
    if self.elf_header_value.e_phoff > 0 and self.elf_header_value.e_phnum > 0:
        _ = IOFile_Seek(self.f, elf_header_pos + self.elf_header_value.e_phoff.i64())
        i: mutable u16 = 0
        while i < self.elf_header_value.e_phnum:
            phdr: elf_program_header = Elf_ReadProgramHeader(self.f)
            Elf_PushProgramHeader(self.program_headers, phdr)
            i <- i + 1
    if self.elf_header_value.e_shoff > 0 and self.elf_header_value.e_shnum > 0:
        _ = IOFile_Seek(self.f, elf_header_pos + self.elf_header_value.e_shoff.i64())
        i: mutable u16 = 0
        while i < self.elf_header_value.e_shnum:
            shdr: elf_section_header = Elf_ReadSectionHeader(self.f)
            Elf_PushSectionHeader(self.section_headers, shdr)
            i <- i + 1

    if self.is_self:
        header_size: mutable u64 = 0
        header_size <- header_size + size_of(self_header).u64()
        header_size <- header_size + (size_of(self_segment_header).u64() * self.self.segment_count.u64())
        header_size <- header_size + size_of(elf_header).u64()
        header_size <- header_size + (self.elf_header_value.e_phnum.u64() * self.elf_header_value.e_phentsize.u64())
        header_size <- header_size + (self.elf_header_value.e_shnum.u64() * self.elf_header_value.e_shentsize.u64())
        header_size <- (header_size + 15) & (~15)
        if self.elf_header_value.e_ehsize.u64() >= (header_size + size_of(elf_program_id_header).u64()):
            _ = IOFile_Seek(self.f, header_size.i64())
            # Explicit [T]: generic inference does not flow through the auto-ref
            # of the field argument, so bind T at the call site.
            _ = IOFile_ReadObject[elf_program_id_header](self.f, self.self_id_header)

def Elf_LoadSegment(self: mutable Elf&, virtual_addr: uintptr, file_offset: u64, size: usize) -> bool:
    if Elf_SeekSegment(self.ref[mutable Elf&], file_offset):
        return IOFile_ReadRaw(self.f, virtual_addr.cast[mutable void&], 1, size) == size
    return false

def Elf_LoadSegmentBytes(self: mutable Elf&, out: mutable darray[u8]&, file_offset: u64, size: usize, target_arena: mutable Arena&) -> bool:
    if not Elf_SeekSegment(self.ref[mutable Elf&], file_offset):
        return false
    # Grow the destination buffer in the arena chosen by the caller. Segment
    # data that outlives the load (dynamic data, symbol/relocation tables, the
    # module image) must use a persistent arena; using a transient local arena
    # here previously freed the backing on return, so symbol/relocation reads
    # hit use-after-free memory and import resolution was nondeterministic.
    in target_arena:
        i: mutable usize = 0
        while i < size:
            b: u8 = Elf_ReadU8(self.f)
            out.push(b)
            i <- i + 1
    return true

def Elf_SeekSegment(self: mutable Elf&, file_offset: u64) -> bool:
    if not self.is_self:
        return IOFile_Seek(self.f, file_offset.i64())
    i: mutable usize = 0
    while i < self.self_segments.count:
        seg: self_segment_header = self.self_segments[i]
        if SelfSegment_IsBlocked(seg):
            phdr_id: u32 = SelfSegment_GetId(seg)
            if phdr_id.usize() < self.program_headers.count:
                phdr: elf_program_header& = self.program_headers[phdr_id.usize()].ref[elf_program_header&]
                if file_offset >= phdr.p_offset and file_offset < (phdr.p_offset + phdr.p_filesz):
                    mapped_off: u64 = (file_offset - phdr.p_offset) + seg.file_offset
                    return IOFile_Seek(self.f, mapped_off.i64())
        i <- i + 1
    return false

def Elf_GetProgramHeader(self: Elf&, index: usize) -> elf_program_header&:
    return self.program_headers[index].ref[elf_program_header&]

def Elf_GetSElfHeader(self: Elf&) -> self_header:
    return self.self

def Elf_GetElfHeader(self: Elf&) -> elf_header:
    return self.elf_header_value

def Elf_GetElfEntry(self: Elf&) -> u64:
    return self.elf_header_value.e_entry

def Elf_IsSharedLib(self: Elf&) -> bool:
    return self.elf_header_value.e_type == ET_SCE_DYNAMIC

def ElfPheaderTypeStr(ptype: u32) -> static u8&:
    if ptype == 0:
        return "Null"
    if ptype == 1:
        return "Loadable"
    if ptype == 2:
        return "Dynamic"
    if ptype == 3:
        return "Interpreter Path"
    if ptype == 4:
        return "Note"
    if ptype == 5:
        return "Section Header Library"
    if ptype == 6:
        return "Program Header"
    if ptype == 7:
        return "Thread-Local Storage"
    if ptype == 8:
        return "Defined Sections Number"
    if ptype == 0x60000000:
        return "SCE Relative"
    if ptype == 0x61000000:
        return "SCE Dynamic Library Data"
    if ptype == 0x61000001:
        return "SCE Processor Parameters"
    if ptype == 0x61000002:
        return "SCE Module Parameters"
    if ptype == 0x61000010:
        return "SCE Read-Only After Relocation"
    if ptype == 0x6474e550:
        return "GNU Entry Header Frame"
    if ptype == 0x6474e551:
        return "GNU Stack (executability)"
    if ptype == 0x6474e552:
        return "GNU Read-Only After Relocation"
    if ptype == 0x6fffff00:
        return "SCE Comment"
    if ptype == 0x6fffff01:
        return "SCE Library Version"
    return "Unknown Section"

def ElfPheaderFlagsStr(flags: u32) -> static u8&:
    _ = flags
    return "(flags)"

def ElfPHeaderStr(self: Elf&, no: u16) -> static u8&:
    _ = self
    _ = no
    return "====== PROGRAM HEADER ========\n"

