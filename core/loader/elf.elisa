    _ = self
    _ = no
    return "====== SEGMENT HEADER ========\n"

def ElfHeaderStr(self: Elf&) -> static u8&:
    _ = self
    return "======= Elf header ===========\n"

def PHeaderDebugDump(self: Elf&, file_name: static u8&) -> void:
    f: mutable IOFile = IOFile_opened(file_name, FileAccessMode.Create, FileType.TextFile)
    if not IOFile_IsOpen(f):
        return
    if self.elf_header_value.e_phentsize > 0u16:
        i: mutable u16 = 0u16
        while i < self.elf_header_value.e_phnum:
            s: static u8& = ElfPHeaderStr(self.ref[Elf&], i)
            _ = IOFile_WriteSpan(f, s[0].ref[u8&], static_strlen(s))
            i <- i + 1u16
    _ = IOFile_Flush(f)
    IOFile_Close(f)

def ElfHeaderDebugDump(self: Elf&, file_name: static u8&) -> void:
    f: mutable IOFile = IOFile_opened(file_name, FileAccessMode.Create, FileType.TextFile)
    if not IOFile_IsOpen(f):
        return
    s: static u8& = ElfHeaderStr(self.ref[Elf&])
    _ = IOFile_WriteSpan(f, s[0].ref[u8&], static_strlen(s))
    _ = IOFile_Flush(f)
    IOFile_Close(f)

def SelfHeaderDebugDump(self: Elf&, file_name: static u8&) -> void:
    f: mutable IOFile = IOFile_opened(file_name, FileAccessMode.Create, FileType.TextFile)
    if not IOFile_IsOpen(f):
        return
    s: static u8& = SElfHeaderStr(self.ref[Elf&])
    _ = IOFile_WriteSpan(f, s[0].ref[u8&], static_strlen(s))
    _ = IOFile_Flush(f)
    IOFile_Close(f)

def SelfSegHeaderDebugDump(self: Elf&, file_name: static u8&) -> void:
    f: mutable IOFile = IOFile_opened(file_name, FileAccessMode.Create, FileType.TextFile)
    if not IOFile_IsOpen(f):
        return
    i: mutable u16 = 0u16
    while i < self.self.segment_count:
        s: static u8& = SELFSegHeader(self.ref[Elf&], i)
        _ = IOFile_WriteSpan(f, s[0].ref[u8&], static_strlen(s))
        i <- i + 1u16
    _ = IOFile_Flush(f)
    IOFile_Close(f)
