# Thread-affinity referee: mutable state that must only be touched by one thread
# (e.g. per-thread TLS bookkeeping, the crash-guard jmp_buf) registers a slot;
# the first touch captures the owning thread id, and any later touch by a
# different thread is a cross-thread violation -- recorded, traced, and (if
# armed) trapped. Catches the racy-shared-state class (the racy LDT index, a
# cross-thread siglongjmp) at runtime. thread_id is injectable so call sites
# pass ge_pthread_self() while tests can simulate distinct threads.
global mutable ge_affinity_owner: u64[16] = zeroed
global mutable ge_affinity_set: bool[16] = zeroed
global mutable ge_affinity_violation_count: u64 = 0
global mutable ge_affinity_last_slot: usize = 0
global mutable ge_affinity_last_owner: u64 = 0
global mutable ge_affinity_last_intruder: u64 = 0
global mutable ge_debug_trap_on_affinity: bool = false

def ge_thread_affinity_reset() -> void:
    i: mutable usize = 0
    while i < GE_AFFINITY_SLOTS:
        ge_affinity_owner[i] <- 0
        ge_affinity_set[i] <- false
        i <- i + 1
    ge_affinity_violation_count <- 0
    ge_affinity_last_slot <- 0
    ge_affinity_last_owner <- 0
    ge_affinity_last_intruder <- 0

# Returns true if the access is permitted (first touch or same owner); false on
# a cross-thread violation.
def ge_thread_affinity_check(slot: usize, thread_id: u64) -> bool:
    if slot >= GE_AFFINITY_SLOTS:
        return false
    if not ge_affinity_set[slot]:
        ge_affinity_owner[slot] <- thread_id
        ge_affinity_set[slot] <- true
        return true
    if ge_affinity_owner[slot] == thread_id:
        return true
    ge_affinity_violation_count <- ge_affinity_violation_count + 1
    ge_affinity_last_slot <- slot
    ge_affinity_last_owner <- ge_affinity_owner[slot]
    ge_affinity_last_intruder <- thread_id
    ge_debug_trace_boundary("guest-exec-thread-affinity-violation", slot.uintptr(), ge_affinity_owner[slot].uintptr(), thread_id.uintptr())
    if ge_debug_trap_on_affinity:
        ge_debug_trap_count <- ge_debug_trap_count + 1
        ge_debug_trap_reason <- GE_DEBUG_TRAP_THREAD_AFFINITY_STATUS.u64()
        ge_debug_trap_value <- thread_id.uintptr()
        ge_last_status <- GE_DEBUG_TRAP_THREAD_AFFINITY_STATUS
    return false

@reentrant_safe
def ge_debug_trace_boundary(label: cstr, a: uintptr, b: uintptr, c: uintptr) -> void:
    static if DEBUG:
        if not ge_debug_trace_enabled:
            return
        ge_debug_trace_record(DEBUG_TRACE_KIND_BOUNDARY, label, a, b, c)
    static else:
        _ = label
        _ = a
        _ = b
        _ = c

def ge_debug_trace_checkpoint(label: cstr) -> void:
    static if DEBUG:
        if not ge_debug_trace_enabled:
            return
        ge_debug_trace_record(DEBUG_TRACE_KIND_CHECKPOINT, label, 0.uintptr(), 0.uintptr(), 0.uintptr())
    static else:
        _ = label

def ge_debug_trace_reset() -> void:
    static if DEBUG:
        if not ge_debug_trace_enabled:
            return
        debug_trace_sequence <- 0
        debug_trace_event_count <- 0.usize()
        debug_trace_overflowed <- false
        debug_trace_hash <- DEBUG_TRACE_HASH_INITIAL
        debug_trace_last_event <- DebugTraceEvent(0, 0, 0.uintptr(), 0.uintptr(), 0.uintptr(), "")

@reentrant_safe
def ge_debug_trace_mix_word(word: uintptr) -> void:
    static if DEBUG:
        debug_trace_hash <- (debug_trace_hash ^ word.u64()) * DEBUG_TRACE_HASH_PRIME
    static else:
        _ = word

@reentrant_safe
def ge_debug_trace_record(kind: int, label: cstr, a: uintptr, b: uintptr, c: uintptr) -> void:
    static if DEBUG:
        if not ge_debug_trace_enabled:
            return
        debug_trace_sequence <- debug_trace_sequence + 1
        ge_debug_trace_mix_word(kind.uintptr())
        ge_debug_trace_mix_word(a)
        ge_debug_trace_mix_word(b)
        ge_debug_trace_mix_word(c)
        event: DebugTraceEvent = DebugTraceEvent(debug_trace_sequence, kind, a, b, c, label)
        debug_trace_last_event <- event
        if debug_trace_event_count < DEBUG_TRACE_TAPE_CAP:
            debug_trace_events[debug_trace_event_count] <- event
            debug_trace_event_count <- debug_trace_event_count + 1.usize()
        else:
            debug_trace_overflowed <- true
    static else:
        _ = kind
        _ = label
        _ = a
        _ = b
        _ = c

def ge_map_failed() -> uintptr:
    return 0xFFFFFFFFFFFFFFFF.uintptr()

# Reinterpret a raw guest/host address as an opaque pointer for libc calls.
@reentrant_safe
def ge_addr_to_ptr(address: uintptr) -> void&?:
    p: mutable void&? = null
    trusted Unsafe.PointerCast:
        p <- address.cast[void&?]
    return p

def ge_native_prot(prot: u32) -> int:
    np: mutable int = 0
    if (prot & 1) != 0:
        np <- np | 1
    if (prot & 2) != 0:
        np <- np | 2
    if (prot & 4) != 0:
        np <- np | 4
    return np

def ge_mmap_anon_flags() -> int:
    static if PLATFORM_APPLE:
        return 0x0002 | 0x1000
    static else:
        return 0x0002 | 0x20

def ge_mmap_fixed_flags() -> int:
    static if PLATFORM_APPLE:
        return 0x0002 | 0x1000 | 0x0010
    static elif PLATFORM_LINUX:
        return 0x0002 | 0x20 | 0x100000
    static else:
        return 0x0002 | 0x20 | 0x0010

def ge_page_size() -> uintptr:
    static if PLATFORM_APPLE:
        ps: i64 = ge_sysconf(29)
        return ps.uintptr() if ps > 0 else 4096.uintptr()
    static elif PLATFORM_LINUX:
        ps: i64 = ge_sysconf(30)
        return ps.uintptr() if ps > 0 else 4096.uintptr()
    static else:
        return 4096.uintptr()

def ge_flush_instruction_cache(address: uintptr, size: u64) -> void:
    static if PLATFORM_APPLE and ARCH_ARM64:
        ge_sys_icache_invalidate(address, size.usize())
    static else:
        _ = address
        _ = size

@reentrant_safe
def ge_region_contains(base: uintptr, rsize: u64, address: uintptr, size: u64) -> bool:
    # DOGFOOD (guest-exec-fault-path): the published-exec containment law that gates the
    # entry jump (ge_check_entry_published -> ge_is_published_exec -> here). The two facts
    # the entry boundary relies on are the no-wrap of `base + rsize` and that a contained
    # `[address, address+size)` stays inside the window. The subtraction `rsize - offset`
    # only happens after `offset <= rsize` is established, so it never underflows; this is
    # the same no-underflow shape as MemoryManager_FindBackingIndex and is what makes the
    # publish-window check provably safe rather than a runtime-only guard.
    #   result ==> address >= base                  (offset is well-defined)
    #   result ==> size <= rsize - offset, offset <= rsize  (no over-read past window end)
    ensure (not result) or (address.u64() >= base.u64())
    if base == 0.uintptr() or rsize == 0:
        return false
    if address.u64() < base.u64():
        return false
    offset: u64 = address.u64() - base.u64()
    return offset <= rsize and size <= (rsize - offset)

@reentrant_safe
def ge_find_native_region(address: uintptr, size: u64) -> s32:
    best: mutable s32 = -1
    best_size: mutable u64 = 0xFFFFFFFFFFFFFFFF
    i: mutable u32 = 0
    can Unsafe.AssumeProgress:
        while i < ge_native_region_count and i < GE_NATIVE_REGION_CAP:
            decreases GE_NATIVE_REGION_CAP - i
            r: GeNativeRegion = ge_native_regions[i.usize()]
            if r.active != 0 and ge_region_contains(r.base, r.size, address, size):
                if r.size < best_size:
                    best <- i.s32()
                    best_size <- r.size
            i <- i + 1
    return best

def ge_record_native_region(base: uintptr, size: u64, prot: u32) -> void:
    if base == 0.uintptr() or size == 0:
        return
    existing: s32 = ge_find_native_region(base, size)
    if existing >= 0 and existing.u32() < GE_NATIVE_REGION_CAP:
        idx: u32 = existing.u32()
        cur: GeNativeRegion = ge_native_regions[idx.usize()]
        if cur.base == base and cur.size == size:
            ge_native_regions[idx.usize()] <- GeNativeRegion(base, size, prot, 1)
            return
    if ge_native_region_count >= GE_NATIVE_REGION_CAP:
        return
    idx: u32 = ge_native_region_count
    if idx < GE_NATIVE_REGION_CAP:
        ge_native_regions[idx.usize()] <- GeNativeRegion(base, size, prot, 1)
        ge_native_region_count <- ge_native_region_count + 1

def ge_forget_native_region(base: uintptr, size: u64) -> void:
    i: mutable u32 = 0
    can Unsafe.AssumeProgress:
        while i < ge_native_region_count and i < GE_NATIVE_REGION_CAP:
            decreases GE_NATIVE_REGION_CAP - i
            cur: GeNativeRegion = ge_native_regions[i.usize()]
            if cur.active != 0 and cur.base == base and cur.size == size:
                ge_native_regions[i.usize()] <- GeNativeRegion(base, size, cur.prot, 0)
                return
            i <- i + 1

@reentrant_safe
def ge_native_prot_at(address: uintptr, size: u64) -> u32:
    index: s32 = ge_find_native_region(address, size)
    if index >= 0 and index.u32() < GE_NATIVE_REGION_CAP:
        return ge_native_regions[index.usize()].prot
    return 0xffffffff

# Per-dump cap on emitted region ENTRY events. The emergency tape is a 256-entry
# ring shared with all other diagnostics, and the table can hold thousands of active
# regions, so a full dump would wrap the ring and evict the META header. Instead we
# emit the few regions most relevant to the query (the one containing the lookup, plus
# the nearest regions on either side) followed by a bounded forward sample, then a
# TRUNC event recording how many active regions were not emitted (no silent cap).
const GE_NATIVE_REGION_DUMP_CAP: u32 = 24

@reentrant_safe
def ge_emit_native_region_entry(index: u32) -> void:
    r: GeNativeRegion = ge_native_regions[index.usize()]
    d: u64 = (r.active.u64() << 32) | index.u64()
    ge_emergency_mark(GE_EV_NATIVE_REGION_ENTRY, r.base, r.size.uintptr(), r.prot.u64().uintptr(), d.uintptr())

# ge_dump_native_regions records the live native-region table to the emergency tape
# (decoded by tools/cusa_triage.py) plus a stderr breadcrumb. Call it at a fault or
# from a guard when a region lookup unexpectedly misses (e.g. ge_find_native_region
# returning -1 for an address that should be mapped), to see the actual table vs the
# queried address. lookup_addr/lookup_size describe the query that motivated the dump
# (pass 0/0 for an unconditional snapshot). The META event is emitted both first and
# last so it survives even if the entry stream wraps the ring.
@reentrant_safe
def ge_dump_native_regions(lookup_addr: uintptr, lookup_size: u64) -> void:
    found: s32 = ge_find_native_region(lookup_addr, lookup_size) if lookup_addr != 0.uintptr() else -1
    found_index: u64 = found.u32().u64() if found >= 0 else 0xffffffff
    # Single pass: count active regions and find the active region nearest below and
    # nearest above the lookup address (by base), so the dump brackets the query.
    active: mutable u32 = 0
    below_idx: mutable s32 = -1
    below_base: mutable u64 = 0
    above_idx: mutable s32 = -1
    above_base: mutable u64 = 0xFFFFFFFFFFFFFFFF
    lookup_u: u64 = lookup_addr.u64()
    i: mutable u32 = 0
    can Unsafe.AssumeProgress:
        while i < ge_native_region_count and i < GE_NATIVE_REGION_CAP:
            decreases GE_NATIVE_REGION_CAP - i
            r: GeNativeRegion = ge_native_regions[i.usize()]
            if r.active != 0:
                active <- active + 1
                b: u64 = r.base.u64()
                if b <= lookup_u and b >= below_base:
                    below_base <- b
                    below_idx <- i.s32()
                if b > lookup_u and b <= above_base:
                    above_base <- b
                    above_idx <- i.s32()
            i <- i + 1
    _ = ge_raw_write(2, "GE_NATIVE_REGIONS dump\n".cast[void&], 23)
    ge_emergency_mark(GE_EV_NATIVE_REGION_META, active.u64().uintptr(), lookup_addr, lookup_size.uintptr(), found_index.uintptr())
    emitted: mutable u32 = 0
    # The region actually containing the lookup (if the table claims one).
    if found >= 0 and found.u32() < GE_NATIVE_REGION_CAP:
        ge_emit_native_region_entry(found.u32())
        emitted <- emitted + 1
    if below_idx >= 0 and below_idx.s32() != found:
        ge_emit_native_region_entry(below_idx.u32())
        emitted <- emitted + 1
    if above_idx >= 0 and above_idx.s32() != found:
        ge_emit_native_region_entry(above_idx.u32())
        emitted <- emitted + 1
    # Bounded forward sample for general context, skipping any already emitted above.
    i <- 0
    can Unsafe.AssumeProgress:
        while i < ge_native_region_count and i < GE_NATIVE_REGION_CAP:
            decreases GE_NATIVE_REGION_CAP - i
            r: GeNativeRegion = ge_native_regions[i.usize()]
            if r.active != 0 and i.s32() != found and i.s32() != below_idx and i.s32() != above_idx:
                if emitted >= GE_NATIVE_REGION_DUMP_CAP:
                    ge_emergency_mark(GE_EV_NATIVE_REGION_TRUNC, emitted.u64().uintptr(), active.u64().uintptr(), 0.uintptr(), 0.uintptr())
                    ge_emergency_mark(GE_EV_NATIVE_REGION_META, active.u64().uintptr(), lookup_addr, lookup_size.uintptr(), found_index.uintptr())
                    return
                ge_emit_native_region_entry(i)
                emitted <- emitted + 1
            i <- i + 1
    # Re-emit META last so latest(META) always resolves even without truncation.
    ge_emergency_mark(GE_EV_NATIVE_REGION_META, active.u64().uintptr(), lookup_addr, lookup_size.uintptr(), found_index.uintptr())

@reentrant_safe
def ge_find_hle_thunk_target_from_stack_value(value: uintptr) -> uintptr:
    if value == 0.uintptr():
        return 0.uintptr()
    i: mutable u64 = 0
    can Unsafe.AssumeProgress:
        while i < ge_hle_thunk_contract_count and i < GE_HLE_THUNK_CONTRACT_CAP:
            decreases GE_HLE_THUNK_CONTRACT_CAP - i
            base: uintptr = ge_hle_thunk_contract_addrs[i.usize()]
            size: mutable u64 = ge_hle_thunk_contract_sizes[i.usize()]
            if size == 0:
                size <- 4096
            if base != 0.uintptr() and value >= base and value < base + size.uintptr():
                return ge_hle_thunk_contract_targets[i.usize()]
            i <- i + 1
    return 0.uintptr()

def ge_boundary_guard_reason_for_value(value: uintptr) -> u64:
    if value.u64() == GE_BOUNDARY_POISON_WORD:
        return GE_BOUNDARY_GUARD_POISON
    if value != 0.uintptr() and value.u64() < GE_BOUNDARY_NEAR_NULL_LIMIT and ge_native_prot_at(value, 8) == 0xffffffff:
        return GE_BOUNDARY_GUARD_NEAR_NULL_UNMAPPED
    return GE_BOUNDARY_GUARD_NONE

def ge_guest_pointer_guard_reason_for_value(value: uintptr) -> u64:
    base_reason: u64 = ge_boundary_guard_reason_for_value(value)
    if base_reason != GE_BOUNDARY_GUARD_NONE:
        return base_reason
    if value == 0.uintptr():
        return GE_BOUNDARY_GUARD_NONE
    if ge_is_noncanonical_x86_address(value):
        return GE_BOUNDARY_GUARD_NON_CANONICAL
    if ge_native_prot_at(value, 1) == 0xffffffff:
        return GE_BOUNDARY_GUARD_UNMAPPED_POINTER
    return GE_BOUNDARY_GUARD_NONE

def ge_is_noncanonical_x86_address(value: uintptr) -> bool:
    raw: u64 = value.u64()
    sign: u64 = (raw >> 47) & 1
    upper: u64 = raw >> 48
    if sign == 0:
        return upper != 0
    return upper != 0xffff

def ge_callable_guard_reason_for_value(value: uintptr) -> u64:
    base_reason: u64 = ge_boundary_guard_reason_for_value(value)
    if base_reason != GE_BOUNDARY_GUARD_NONE:
        return base_reason
    if ge_is_noncanonical_x86_address(value):
        return GE_BOUNDARY_GUARD_NON_CANONICAL
    prot: u32 = ge_native_prot_at(value, 1)
    if prot == 0xffffffff or (prot & 4) == 0:
        return GE_BOUNDARY_GUARD_UNMAPPED_EXEC
    return GE_BOUNDARY_GUARD_NONE

def ge_record_published_exec(address: PublishedExecutableAddr, size: u64) -> void:
    if !address == 0.uintptr() or size == 0:
        return
    i: mutable u32 = 0
    can Unsafe.AssumeProgress:
        while i < ge_published_exec_count and i < 2048:
            decreases 2048 - i
            if ge_published_exec_bases[i.usize()] == address:
                ge_published_exec_sizes[i.usize()] <- size
                return
            i <- i + 1
    if ge_published_exec_count < 2048:
        ge_published_exec_bases[ge_published_exec_count.usize()] <- address
        ge_published_exec_sizes[ge_published_exec_count.usize()] <- size
        ge_published_exec_count <- ge_published_exec_count + 1

def ge_is_published_exec(address: uintptr, size: u64) -> bool:
    if address == 0.uintptr() or size == 0:
        return false
    i: mutable u32 = 0
    can Unsafe.AssumeProgress:
        while i < ge_published_exec_count and i < 2048:
            decreases 2048 - i
            base: uintptr = !ge_published_exec_bases[i.usize()]
            rsize: u64 = ge_published_exec_sizes[i.usize()]
            if ge_region_contains(base, rsize, address, size):
                return true
            i <- i + 1
    return false

def ge_check_entry_published(entry_addr: uintptr) -> bool:
    if not ge_debug_trap_on_unpublished_exec:
        return true
    if ge_is_published_exec(entry_addr, 1):
        return true
    ge_debug_trap_count <- ge_debug_trap_count + 1
    ge_debug_trap_reason <- GE_DEBUG_TRAP_UNPUBLISHED_EXEC_STATUS.u64()
    ge_debug_trap_value <- entry_addr
    ge_debug_trap_sequence <- ge_debug_trap_count
    ge_last_status <- GE_DEBUG_TRAP_UNPUBLISHED_EXEC_STATUS
    return false

def ge_debug_guard_callable_target(target: uintptr, sequence: u64) -> bool:
    if not ge_debug_trap_on_callable_guard:
        return true
    if ge_debug_trap_sequence != 0:
        return false
    reason: u64 = ge_callable_guard_reason_for_value(target)
    if reason == GE_BOUNDARY_GUARD_NONE:
        return true
    ge_debug_trap_count <- ge_debug_trap_count + 1
    ge_debug_trap_reason <- reason
    ge_debug_trap_value <- target
    ge_debug_trap_sequence <- sequence if sequence != 0 else ge_debug_trap_count
    ge_debug_trap_return_addr <- !ge_runtime_hle_guest_return_addr
    ge_debug_trap_arg0 <- ge_runtime_hle_guest_rdi
    ge_debug_trap_arg1 <- ge_runtime_hle_guest_rsi
    ge_debug_trap_arg2 <- ge_runtime_hle_guest_rdx
    ge_last_status <- GE_DEBUG_TRAP_CALLABLE_GUARD_STATUS
    ge_debug_trace_boundary("guest-exec-callable-guard-stop", target, reason.uintptr(), ge_debug_trap_return_addr)
    return false

@reentrant_safe
def ge_establish_host_fs_for_abort(site: cstr) -> void can[Unsafe.SegmentMutation, Segment.Host]:
    static if PLATFORM_APPLE and ARCH_X86_64:
        can Unsafe.SegmentMutation, Segment.Host:
            TLS_RestoreHostFsSelector()
        ge_shadow_fs_transition(site, GE_FS_OWNER_HOST)
    static else:
        _ = site

@reentrant_safe
def ge_abort_active_guard_for_debug_trap(status: s32) -> void can[Unsafe.SegmentMutation, Segment.Host]:
    fr: ElisaGuestExecForkReport&? = ge_fork_report
    if fr != null:
        fr.status <- status
        fr.signal <- 0
    if ge_guard_active == 0:
        return
    # Once a referee has decided to unwind, the first diagnostic has already
    # been recorded. Keep the abort path tiny and non-recursive: it must restore
    # host state and leave, not trigger the same referee again while longjmping.
    ge_fs_state_check_enabled <- false
    ge_fs_state_trap_on_mismatch <- false
    can Unsafe.SegmentMutation, Segment.Host:
        ge_establish_host_fs_for_abort("debug-trap-abort-host-fs-restored")
    current_thread: uintptr = !ge_pthread_self()
    if ge_guard_target_thread == 0.uintptr() or current_thread == ge_guard_target_thread:
        ge_mark_guard_longjmp(status, GE_LONGJMP_SOURCE_DEBUG_TRAP_ABORT, ge_debug_trap_value)
        ge_siglongjmp((&ge_jmp_buf[0]).cast[void&], 1)
    ge_cross_thread_signal_count <- ge_cross_thread_signal_count + 1
    ge_cross_thread_signal_guard_thread <- ge_guard_target_thread
    ge_cross_thread_signal_fault_thread <- current_thread
    ge_cross_thread_signal_number <- status
    if fr != null:
        fr.cross_thread_signal_count <- ge_cross_thread_signal_count
        fr.cross_thread_signal_guard_thread <- ge_guard_target_thread
        fr.cross_thread_signal_fault_thread <- current_thread
        fr.cross_thread_signal_number <- status
    ge_exit_now((0 - status).int())

def GuestExec_AbortGuestFatalHle(reason: uintptr) -> void can[Unsafe.SegmentMutation, Segment.Host]:
    ge_debug_trap_count <- ge_debug_trap_count + 1
    ge_debug_trap_reason <- GE_GUEST_FATAL_HLE_STATUS.u64()
    ge_debug_trap_value <- reason
    ge_debug_trap_sequence <- ge_debug_trap_count
    ge_last_status <- GE_GUEST_FATAL_HLE_STATUS
    can Unsafe.SegmentMutation, Segment.Host:
        ge_abort_active_guard_for_debug_trap(GE_GUEST_FATAL_HLE_STATUS)

def ge_debug_guard_guest_pointer(target: uintptr, sequence: u64) -> bool can[Unsafe.SegmentMutation, Segment.Host]:
    if not ge_debug_trap_on_boundary_guard:
        return true
    if ge_debug_trap_sequence != 0:
        return false
    reason: u64 = ge_guest_pointer_guard_reason_for_value(target)
    if reason == GE_BOUNDARY_GUARD_NONE:
        return true
    ge_debug_trap_count <- ge_debug_trap_count + 1
    ge_debug_trap_reason <- reason
    ge_debug_trap_value <- target
    ge_debug_trap_sequence <- sequence if sequence != 0 else ge_debug_trap_count
    ge_debug_trap_return_addr <- !ge_runtime_hle_guest_return_addr
    ge_debug_trap_arg0 <- ge_runtime_hle_guest_rdi
    ge_debug_trap_arg1 <- ge_runtime_hle_guest_rsi
    ge_debug_trap_arg2 <- ge_runtime_hle_guest_rdx
    ge_last_status <- GE_DEBUG_TRAP_BOUNDARY_GUARD_STATUS
    ge_debug_trace_boundary("guest-exec-pointer-guard-stop", target, reason.uintptr(), ge_debug_trap_return_addr)
    can Unsafe.SegmentMutation, Segment.Host:
        ge_abort_active_guard_for_debug_trap(GE_DEBUG_TRAP_BOUNDARY_GUARD_STATUS)
    return false

@reentrant_safe
def ge_classify_fs_owner(actual_selector: u16, host_selector: u16, guest_selector: u16) -> u32:
    if guest_selector != 0 and actual_selector == guest_selector:
        return GE_FS_OWNER_GUEST
    if actual_selector == host_selector:
        return GE_FS_OWNER_HOST
    return GE_FS_OWNER_UNKNOWN

@reentrant_safe
def ge_expected_fs_selector(expected_owner: u32, host_selector: u16, guest_selector: u16) -> uintptr:
    if expected_owner == GE_FS_OWNER_GUEST:
        return guest_selector.uintptr()
    if expected_owner == GE_FS_OWNER_HOST:
        return host_selector.uintptr()
    return 0.uintptr()

@reentrant_safe
def ge_fs_owner_is_valid(owner: u32) -> bool:
    return owner == GE_FS_OWNER_HOST or owner == GE_FS_OWNER_GUEST or owner == GE_FS_OWNER_UNKNOWN

@reentrant_safe
def ge_shadow_fs_transition(site: cstr, owner: u32) -> void:
    if not ge_fs_state_check_enabled:
        return
    normalized_owner: mutable u32 = owner
    if not ge_fs_owner_is_valid(owner):
        normalized_owner <- GE_FS_OWNER_UNKNOWN
    ge_fs_state_shadow_owner <- normalized_owner
    ge_fs_state_shadow_transition_count <- ge_fs_state_shadow_transition_count + 1
    ge_fs_state_shadow_last_site <- site

@reentrant_safe
def ge_copy_fs_state_to_fork_report() -> void:
    fr: ElisaGuestExecForkReport&? = ge_fork_report
    if fr == null:
        return
    fr.fs_state_observation_count <- ge_fs_state_observation_count
    fr.fs_state_mismatch_count <- ge_fs_state_mismatch_count
    fr.fs_state_last_site <- ge_fs_state_last_site
    fr.fs_state_last_expect_guest <- 1 if ge_fs_state_last_expect_guest else 0
    fr.fs_state_last_expected <- ge_fs_state_last_expected
    fr.fs_state_last_actual <- ge_fs_state_last_actual
    fr.fs_state_last_expected_owner <- ge_fs_state_last_expected_owner
    fr.fs_state_last_actual_owner <- ge_fs_state_last_actual_owner
    fr.fs_state_last_guest_selector <- ge_fs_state_last_guest_selector
    fr.fs_state_last_host_selector <- ge_fs_state_last_host_selector
    fr.fs_state_last_tcb_base <- ge_fs_state_last_tcb_base
    fr.fs_state_last_fs0 <- ge_fs_state_last_fs0
    fr.fs_state_last_hle_return_addr <- ge_fs_state_last_hle_return_addr
    fr.fs_state_last_hle_module <- ge_fs_state_last_hle_module
    fr.fs_state_last_hle_symbol <- ge_fs_state_last_hle_symbol

@reentrant_safe
def ge_record_fs_state_mismatch(site: cstr, expected_owner: u32, actual_owner: u32, actual_selector: uintptr) -> void can[Unsafe.SegmentMutation, Segment.Host]:
    ge_fs_state_mismatch_count <- ge_fs_state_mismatch_count + 1
    ge_debug_trap_count <- ge_debug_trap_count + 1
    ge_debug_trap_reason <- expected_owner.u64()
    ge_debug_trap_value <- actual_selector
    ge_debug_trap_sequence <- ge_runtime_hle_sequence
    ge_debug_trap_return_addr <- !ge_runtime_hle_guest_return_addr
    ge_debug_trap_arg0 <- ge_runtime_hle_guest_rdi
    ge_debug_trap_arg1 <- ge_runtime_hle_guest_rsi
    ge_debug_trap_arg2 <- ge_runtime_hle_guest_rdx
    ge_copy_fs_state_to_fork_report()
    ge_debug_trace_boundary(site, actual_selector, expected_owner.u64().uintptr(), actual_owner.u64().uintptr())
    if ge_fs_state_trap_on_mismatch:
        ge_last_status <- GE_DEBUG_TRAP_FS_STATE_STATUS
        can Unsafe.SegmentMutation, Segment.Host:
            ge_abort_active_guard_for_debug_trap(GE_DEBUG_TRAP_FS_STATE_STATUS)

@reentrant_safe
def ge_reconcile_shadow_fs_owner(site: cstr, expected_owner: u32) -> bool can[Unsafe.SegmentMutation, Segment.Host]:
    if not ge_fs_state_check_enabled:
        return true
    if expected_owner == GE_FS_OWNER_UNKNOWN or ge_fs_state_shadow_owner == GE_FS_OWNER_UNKNOWN:
        return true
    if ge_fs_state_shadow_owner == expected_owner:
        return true
    ge_fs_state_shadow_mismatch_count <- ge_fs_state_shadow_mismatch_count + 1
    ge_fs_state_last_site <- site
    ge_fs_state_last_expect_guest <- expected_owner == GE_FS_OWNER_GUEST
    ge_fs_state_last_expected <- expected_owner.u64().uintptr()
    ge_fs_state_last_actual <- ge_fs_state_shadow_owner.u64().uintptr()
    ge_fs_state_last_expected_owner <- expected_owner
    ge_fs_state_last_actual_owner <- ge_fs_state_shadow_owner
    ge_fs_state_last_guest_selector <- TLS_GuestFsSelectorRawReentrant().uintptr()
    ge_fs_state_last_host_selector <- TLS_HostFsSelectorRaw().uintptr()
    ge_fs_state_last_tcb_base <- !TLS_PrimaryTcbBase()
    ge_fs_state_last_fs0 <- 0.uintptr()
    ge_fs_state_last_hle_return_addr <- !ge_runtime_hle_guest_return_addr
    ge_fs_state_last_hle_module <- ge_runtime_hle_module if ge_runtime_hle_module != null else ""
    ge_fs_state_last_hle_symbol <- ge_runtime_hle_symbol if ge_runtime_hle_symbol != null else ""
    can Unsafe.SegmentMutation, Segment.Host:
        ge_record_fs_state_mismatch("guest-exec-fs-shadow-mismatch", expected_owner, ge_fs_state_shadow_owner, ge_fs_state_shadow_owner.u64().uintptr())
    return false

# Observe the %fs owner at a host<->guest boundary transition. The referee only
# reads %fs:[0] when the selector is already classified as the expected owner,
# so a broken segment base cannot knock out the diagnostic path itself.
@reentrant_safe
def ge_observe_fs_owner_state(site: cstr, expected_owner: u32) -> void can[Unsafe.SegmentMutation, Segment.Host]:
    if not ge_fs_state_check_enabled:
        return
    can Unsafe.SegmentMutation, Segment.Host:
        if not ge_reconcile_shadow_fs_owner(site, expected_owner):
            return
    static if PLATFORM_APPLE and ARCH_X86_64:
        actual_selector: u16 = ElisaTls_ReadFsSelectorAsm()
        guest_selector: u16 = TLS_GuestFsSelectorRawReentrant()
        host_selector: u16 = TLS_HostFsSelectorRaw()
        actual_owner: u32 = ge_classify_fs_owner(actual_selector, host_selector, guest_selector)
        ok: bool = expected_owner == GE_FS_OWNER_UNKNOWN or actual_owner == expected_owner
        ge_fs_state_observation_count <- ge_fs_state_observation_count + 1
        ge_fs_state_last_site <- site
        ge_fs_state_last_expect_guest <- expected_owner == GE_FS_OWNER_GUEST
        ge_fs_state_last_expected <- ge_expected_fs_selector(expected_owner, host_selector, guest_selector)
        ge_fs_state_last_actual <- actual_selector.uintptr()
        ge_fs_state_last_expected_owner <- expected_owner
        ge_fs_state_last_actual_owner <- actual_owner
        ge_fs_state_last_guest_selector <- guest_selector.uintptr()
        ge_fs_state_last_host_selector <- host_selector.uintptr()
        ge_fs_state_last_tcb_base <- !TLS_PrimaryTcbBase()
        ge_fs_state_last_fs0 <- 0.uintptr()
        ge_fs_state_last_hle_return_addr <- !ge_runtime_hle_guest_return_addr
        ge_fs_state_last_hle_module <- ge_runtime_hle_module if ge_runtime_hle_module != null else ""
        ge_fs_state_last_hle_symbol <- ge_runtime_hle_symbol if ge_runtime_hle_symbol != null else ""
        if ok and actual_owner == GE_FS_OWNER_GUEST:
            ge_fs_state_last_fs0 <- !ElisaTls_ReadFs0Asm()
        if not ok:
            can Unsafe.SegmentMutation, Segment.Host:
                ge_record_fs_state_mismatch("guest-exec-fs-owner-mismatch", expected_owner, actual_owner, actual_selector.uintptr())
        fr: ElisaGuestExecForkReport&? = ge_fork_report
        if fr != null:
            ge_copy_fs_state_to_fork_report()
    static else:
        _ = site
        _ = expected_owner

# Compatibility wrapper for older call sites.
def ge_observe_fs_owner(site: cstr, expect_guest: bool) -> void can[Unsafe.SegmentMutation, Segment.Host]:
    can Unsafe.SegmentMutation, Segment.Host:
        ge_observe_fs_owner_state(site, GE_FS_OWNER_GUEST if expect_guest else GE_FS_OWNER_HOST)

@reentrant_safe
def ge_assert_host_fs_owner(site: cstr) -> void can[Unsafe.SegmentMutation, Segment.Host]:
    can Unsafe.SegmentMutation, Segment.Host:
        ge_observe_fs_owner_state(site, GE_FS_OWNER_HOST)

def ge_assert_guest_fs_owner(site: cstr) -> void can[Unsafe.SegmentMutation, Segment.Host]:
    can Unsafe.SegmentMutation, Segment.Host:
        ge_observe_fs_owner_state(site, GE_FS_OWNER_GUEST)

def ge_debug_guard_mapped_guest_pointer(site: cstr, target: uintptr, size: u64, nearest_base: uintptr, nearest_end: uintptr, nearest_prot: u32, sequence: u64) -> bool can[Memory.Allocate, Unsafe.SegmentMutation, Segment.Host]:
    if target == 0.uintptr():
        return true
    ge_debug_trace_boundary(site, target, nearest_base, nearest_end)
    if not ge_debug_trap_on_boundary_guard:
        return false
    if ge_debug_trap_sequence != 0:
        return false
    ge_debug_trap_count <- ge_debug_trap_count + 1
    ge_debug_trap_reason <- GE_BOUNDARY_GUARD_UNMAPPED_POINTER
    ge_debug_trap_value <- target
    ge_debug_trap_sequence <- sequence if sequence != 0 else ge_debug_trap_count
    ge_debug_trap_return_addr <- !ge_runtime_hle_guest_return_addr
    ge_debug_trap_arg0 <- ge_runtime_hle_guest_rdi
    ge_debug_trap_arg1 <- ge_runtime_hle_guest_rsi
    ge_debug_trap_arg2 <- ge_runtime_hle_guest_rdx
    ge_debug_trap_pointer_size <- size
    ge_debug_trap_nearest_mapping_base <- nearest_base
    ge_debug_trap_nearest_mapping_end <- nearest_end
    ge_debug_trap_nearest_mapping_prot <- nearest_prot
    tcb_base: uintptr = !TLS_PrimaryTcbBase()
    ge_debug_trap_tcb_base <- tcb_base
    can Memory.Allocate:
        ge_debug_trap_tcb_self <- ge_read_context_word(tcb_base)
    ge_debug_trap_install_fs0 <- TLS_DebugLastFs0()
    ge_last_status <- GE_DEBUG_TRAP_GUEST_PTR_UNMAPPED_STATUS
    can Unsafe.SegmentMutation, Segment.Host:
        ge_abort_active_guard_for_debug_trap(GE_DEBUG_TRAP_GUEST_PTR_UNMAPPED_STATUS)
    return false

# Oracle slice for shadPS4 parity diffing: emit the first-HLE-boundary facts once
# into the emergency tape (decoded by tools/decode_gewd.py). Symbol/module names
# are already surfaced via the boundary-guard getters / fork report, so this only
# carries the numeric facts that distinguish "wrong / unmapped / unpublished
# continuation": the continuation address, its native protection, whether it is
# published in the native exec table, the owning region index, and the top guest
# stack words at the boundary.
def ge_emit_oracle_first_boundary(saved_return: uintptr, reason: u64, sequence: u64) -> void:
    if ge_oracle_first_boundary_emitted != 0:
        return
    ge_oracle_first_boundary_emitted <- 1
    prot: uintptr = ge_native_prot_at(saved_return, 1).u64().uintptr()
    published: uintptr = 1.uintptr() if ge_is_published_exec(saved_return, 1) else 0.uintptr()
    region: uintptr = ge_find_native_region(saved_return, 1).i64().u64().uintptr()
    ge_emergency_mark(GE_EV_ORACLE_BOUNDARY_CONT, saved_return, prot, published, region)
    ge_emergency_mark(GE_EV_ORACLE_BOUNDARY_STACK, !ge_runtime_hle_guest_rsp, ge_runtime_hle_guest_stack_word0, ge_runtime_hle_guest_stack_word1, ge_runtime_hle_guest_stack_word2)
    ge_emergency_mark(GE_EV_ORACLE_BOUNDARY_META, reason.uintptr(), !ge_runtime_hle_guest_rbp, !ge_runtime_hle_guest_return_addr, sequence.uintptr())

def ge_debug_guard_guest_return_continuation(sequence: u64) -> bool can[Unsafe.SegmentMutation, Segment.Host]:
    if not ge_debug_trap_on_boundary_guard:
        return true
    if ge_debug_trap_sequence != 0:
        return false
    saved_return: uintptr = !ge_runtime_hle_guest_return_addr
    ge_raw_breadcrumb("GE:RETG_SAVED\n", 14)
    if saved_return == 0.uintptr():
        ge_debug_trap_count <- ge_debug_trap_count + 1
        ge_debug_trap_reason <- GE_BOUNDARY_GUARD_UNMAPPED_EXEC
        ge_debug_trap_value <- saved_return
        ge_debug_trap_sequence <- sequence if sequence != 0 else ge_debug_trap_count
        ge_debug_trap_return_addr <- !ge_runtime_hle_guest_return_addr
        ge_debug_trap_arg0 <- ge_runtime_hle_guest_rdi
        ge_debug_trap_arg1 <- ge_runtime_hle_guest_rsi
        ge_debug_trap_arg2 <- ge_runtime_hle_guest_rdx
        ge_last_status <- GE_DEBUG_TRAP_BOUNDARY_GUARD_STATUS
        ge_debug_trace_boundary("guest-exec-return-guard-zero", saved_return, !ge_runtime_hle_guest_rbp, ge_debug_trap_return_addr)
        can Unsafe.SegmentMutation, Segment.Host:
            ge_abort_active_guard_for_debug_trap(GE_DEBUG_TRAP_BOUNDARY_GUARD_STATUS)
        return false
    frame: uintptr = !ge_runtime_hle_guest_rbp
    ge_raw_breadcrumb("GE:RETG_FRAME\n", 14)
    if frame != 0.uintptr():
        _ = ge_guest_pointer_guard_reason_for_value(frame)
        ge_raw_breadcrumb("GE:RETG_FRAME_CHECKED\n", 22)
    ge_raw_breadcrumb("GE:RETG_REASON\n", 15)
    reason: mutable u64 = ge_boundary_guard_reason_for_value(saved_return)
    ge_raw_breadcrumb("GE:RETG_CANON\n", 14)
    if reason == GE_BOUNDARY_GUARD_NONE and ge_is_noncanonical_x86_address(saved_return):
        reason <- GE_BOUNDARY_GUARD_NON_CANONICAL
    ge_raw_breadcrumb("GE:RETG_PROT\n", 13)
    if reason == GE_BOUNDARY_GUARD_NONE and ge_native_prot_at(saved_return, 1) == 0xffffffff:
        reason <- GE_BOUNDARY_GUARD_UNMAPPED_EXEC
    ge_raw_breadcrumb("GE:RETG_PUB\n", 12)
    if reason == GE_BOUNDARY_GUARD_NONE and ge_debug_trap_on_unpublished_exec and not ge_is_published_exec(saved_return, 1):
        reason <- GE_BOUNDARY_GUARD_UNPUBLISHED_EXEC
    ge_raw_breadcrumb("GE:RETG_DECIDE\n", 15)
    if reason == GE_BOUNDARY_GUARD_NONE:
        return true
    ge_debug_trap_count <- ge_debug_trap_count + 1
    ge_debug_trap_reason <- reason
    ge_debug_trap_value <- saved_return
    ge_debug_trap_sequence <- sequence if sequence != 0 else ge_debug_trap_count
    ge_debug_trap_return_addr <- !ge_runtime_hle_guest_return_addr
    ge_debug_trap_arg0 <- ge_runtime_hle_guest_rdi
    ge_debug_trap_arg1 <- ge_runtime_hle_guest_rsi
    ge_debug_trap_arg2 <- ge_runtime_hle_guest_rdx
    ge_last_status <- GE_DEBUG_TRAP_UNPUBLISHED_EXEC_STATUS if reason == GE_BOUNDARY_GUARD_UNPUBLISHED_EXEC else GE_DEBUG_TRAP_BOUNDARY_GUARD_STATUS
    ge_debug_trace_boundary("guest-exec-return-guard-stop", saved_return, reason.uintptr(), ge_debug_trap_return_addr)
    ge_raw_breadcrumb("GE:RETG_ABORT\n", 14)
    can Unsafe.SegmentMutation, Segment.Host:
        ge_abort_active_guard_for_debug_trap(ge_last_status)
    return false

def ge_debug_guard_guest_frame_for_tests(sequence: u64) -> bool can[Unsafe.SegmentMutation, Segment.Host]:
    if !ge_runtime_hle_guest_rbp == 0.uintptr():
        ge_debug_trap_count <- ge_debug_trap_count + 1
        ge_debug_trap_reason <- GE_BOUNDARY_GUARD_UNMAPPED_POINTER
        ge_debug_trap_value <- !ge_runtime_hle_guest_rbp
        ge_debug_trap_sequence <- sequence if sequence != 0 else ge_debug_trap_count
        ge_debug_trap_return_addr <- !ge_runtime_hle_guest_return_addr
        ge_debug_trap_arg0 <- ge_runtime_hle_guest_rdi
        ge_debug_trap_arg1 <- ge_runtime_hle_guest_rsi
        ge_debug_trap_arg2 <- ge_runtime_hle_guest_rdx
        ge_last_status <- GE_DEBUG_TRAP_BOUNDARY_GUARD_STATUS
        ge_debug_trace_boundary("guest-exec-return-guard-missing-rbp", !ge_runtime_hle_guest_rbp, ge_debug_trap_return_addr, sequence.uintptr())
        can Unsafe.SegmentMutation, Segment.Host:
            ge_abort_active_guard_for_debug_trap(GE_DEBUG_TRAP_BOUNDARY_GUARD_STATUS)
        return false
    return true

@reentrant_safe
def ge_read_native_word(address: uintptr) -> uintptr:
    can Memory.Allocate:
        if address == 0.uintptr():
            return 0.uintptr()
        index: s32 = ge_find_native_region(address, 8)
        if index < 0 or index.u32() >= GE_NATIVE_REGION_CAP:
            return 0.uintptr()
        if (ge_native_regions[index.usize()].prot & 1) == 0:
            return 0.uintptr()
        out: mutable u64 = 0
        _ = ge_memcpy((&out).cast[void&], ge_addr_to_ptr(address), 8)
        return out.uintptr()

@reentrant_safe
def ge_read_native_u8(address: uintptr) -> u8:
    can Memory.Allocate:
        return (ge_read_native_word(address).u64() & 0xff).u8()

@reentrant_safe
def ge_read_native_u32(address: uintptr) -> u32:
    can Memory.Allocate:
        b0: u32 = ge_read_native_u8(address).u32()
        b1: u32 = ge_read_native_u8(address + 1.uintptr()).u32()
        b2: u32 = ge_read_native_u8(address + 2.uintptr()).u32()
        b3: u32 = ge_read_native_u8(address + 3.uintptr()).u32()
        return b0 | (b1 << 8) | (b2 << 16) | (b3 << 24)

@reentrant_safe
def ge_sign_extend_u32_to_u64(v: u32) -> u64:
    s: s32 = v.s32()
    return s.i64().u64()

def ge_maybe_debug_trap_boundary_guard() -> void:
    if not ge_debug_trap_on_boundary_guard:
        return
    if ge_runtime_hle_boundary_guard_reason == GE_BOUNDARY_GUARD_NONE:
        return
    if ge_debug_trap_sequence != 0:
        return
    ge_debug_trap_count <- ge_debug_trap_count + 1
    ge_debug_trap_reason <- ge_runtime_hle_boundary_guard_reason
    ge_debug_trap_value <- ge_runtime_hle_boundary_guard_value
    ge_debug_trap_sequence <- ge_runtime_hle_boundary_guard_sequence
    ge_last_status <- GE_DEBUG_TRAP_BOUNDARY_GUARD_STATUS
    fr: ElisaGuestExecForkReport&? = ge_fork_report
    if fr != null:
        fr.status <- GE_DEBUG_TRAP_BOUNDARY_GUARD_STATUS
        fr.signal <- 0
    if ge_guard_active != 0:
        current_thread: uintptr = !ge_pthread_self()
        if ge_guard_target_thread == 0.uintptr() or current_thread == ge_guard_target_thread:
            ge_mark_guard_longjmp(GE_DEBUG_TRAP_BOUNDARY_GUARD_STATUS, GE_LONGJMP_SOURCE_BOUNDARY_GUARD, ge_runtime_hle_boundary_guard_value)
            ge_siglongjmp((&ge_jmp_buf[0]).cast[void&], 1)
        ge_cross_thread_signal_count <- ge_cross_thread_signal_count + 1
        ge_cross_thread_signal_guard_thread <- ge_guard_target_thread
        ge_cross_thread_signal_fault_thread <- current_thread
        ge_cross_thread_signal_number <- GE_DEBUG_TRAP_BOUNDARY_GUARD_STATUS
        if fr != null:
            fr.cross_thread_signal_count <- ge_cross_thread_signal_count
            fr.cross_thread_signal_guard_thread <- ge_guard_target_thread
            fr.cross_thread_signal_fault_thread <- current_thread
            fr.cross_thread_signal_number <- GE_DEBUG_TRAP_BOUNDARY_GUARD_STATUS
        ge_exit_now(90)

def ge_clear_writable_page_cache() -> void:
    i: mutable usize = 0
    while i < 65536:
        ge_writable_pages[i] <- 0.uintptr().cast[WritableExecutableAddr]
        i <- i + 1
    ge_writable_page_count <- 0

def ge_page_cached_writable(page: uintptr) -> bool:
    slot: u64 = (page.u64() >> 12) % GE_WRITABLE_PAGE_CAP
    if slot < GE_WRITABLE_PAGE_CAP:
        return !ge_writable_pages[slot.usize()] == page
    return false

def ge_cache_writable_page(page: uintptr) -> void:
    slot: u64 = (page.u64() >> 12) % GE_WRITABLE_PAGE_CAP
    if slot < GE_WRITABLE_PAGE_CAP:
        if !ge_writable_pages[slot.usize()] == 0.uintptr():
            ge_writable_page_count <- ge_writable_page_count + 1
        ge_writable_pages[slot.usize()] <- page.cast[WritableExecutableAddr]

def ge_make_writable_cached(address: uintptr, size: u64) -> s32:
    if address == 0.uintptr() or size == 0:
        return 0
    ps: uintptr = ge_page_size()
    ps64: u64 = ps.u64()
    mask: u64 = 0xFFFFFFFFFFFFFFFF ^ (ps64 - 1)
    start: u64 = address.u64() & mask
    end: u64 = (address.u64() + size + ps64 - 1) & mask
    page: mutable u64 = start
    can Unsafe.AssumeProgress:
        while page < end:
            decreases end - page
            if not ge_page_cached_writable(page.uintptr()):
                static if PLATFORM_WINDOWS:
                    return -1
                static else:
                    if ge_mprotect(page.uintptr(), ps.usize(), 7) != 0:
                        return -1
                ge_cache_writable_page(page.uintptr())
            page <- page + ps64
    return 0

def c_GuestExec_MapRegion(address: uintptr, size: u64, prot: u32) -> s32:
    if address == 0.uintptr() or size == 0:
        return -1
    ge_clear_writable_page_cache()
    static if PLATFORM_WINDOWS:
        return -1
    static else:
        np: int = ge_native_prot(prot)
        result: uintptr = mmap(address, size.usize(), np, ge_mmap_fixed_flags(), -1, 0)
        if result != ge_map_failed() and result == address:
            ge_record_native_region(address, size, prot)
            return 0
        # Reservation+commit overlap (Linux MAP_FIXED_NOREPLACE EEXIST, etc.):
        # promote the existing subrange via mprotect instead of leaving it.
        if ge_mprotect(address, size.usize(), np) == 0:
            ge_record_native_region(address, size, prot)
            return 0
        return -1

def c_GuestExec_ProtectRegion(address: uintptr, size: u64, prot: u32) -> s32:
    if address == 0.uintptr() or size == 0:
        return -1
    ge_clear_writable_page_cache()
    static if PLATFORM_WINDOWS:
        return -1
    static else:
        np: int = ge_native_prot(prot)
        if ge_mprotect(address, size.usize(), np) == 0:
            ge_record_native_region(address, size, prot)
            return 0
        return -1

def c_GuestExec_UnmapRegion(address: uintptr, size: u64) -> s32:
    if address == 0.uintptr() or size == 0:
        return -1
    static if PLATFORM_WINDOWS:
        return -1
    static else:
        if ge_munmap(address.cast[heap void&], size.usize()) == 0:
            ge_forget_native_region(address, size)
            return 0
        return -1

def c_GuestExec_AllocateRegion(size: u64, prot: u32) -> uintptr:
    if size == 0:
        return 0.uintptr()
    static if PLATFORM_WINDOWS:
        return 0.uintptr()
    static else:
        np: int = ge_native_prot(prot)
        hint: mutable uintptr = 0.uintptr()
        static if PLATFORM_APPLE and ARCH_X86_64:
            # The x64 game runner shrinks __PAGEZERO and reserves low memory for
            # LDT/TCB pages. With that layout mmap(NULL, ...) can hand out those
            # low pages; executable HLE thunks must live in normal host space.
            hint <- 0x600000000000.uintptr()
        result: uintptr = mmap(hint, size.usize(), np, ge_mmap_anon_flags(), -1, 0)
        if result == ge_map_failed():
            return 0.uintptr()
        ge_record_native_region(result, size, prot)
        return result

def c_GuestExec_WriteBytes(address: uintptr, data: void&?, size: u64) -> s32:
    can Memory.Allocate:
        if address == 0.uintptr() or (data == null and size != 0):
            return -1
        if size != 0:
            if ge_make_writable_cached(address, size) != 0:
                return -1
            _ = ge_memcpy(ge_addr_to_ptr(address), data, size.usize())
            ge_flush_instruction_cache(address, size)
        return 0

def c_GuestExec_WriteU64(address: uintptr, value: u64) -> s32:
    can Memory.Allocate:
        if address == 0.uintptr():
            return -1
        if ge_make_writable_cached(address, 8) != 0:
            return -1
        v: mutable u64 = value
        _ = ge_memcpy(ge_addr_to_ptr(address), (&v).cast[void&], 8)
        ge_flush_instruction_cache(address, 8)
        return 0

def ge_write_u16_le(out: mutable u8&, offset: usize, value: u16) -> void:
    out[offset] <- (value & 0xff).u8()
    out[offset + 1] <- ((value >> 8) & 0xff).u8()

def ge_write_u64_le(out: mutable u8&, offset: usize, value: u64) -> void:
    i: mutable usize = 0
    while i < 8:
        shift: u64 = i.u64() * 8
        out[offset + i] <- ((value >> shift) & 0xff).u8()
        i <- i + 1

def ge_create_host_fs_entry_thunk(target: uintptr) -> HostSegmentAgnosticEntry can[Unsafe.MachineCodeBuilder, Unsafe.ExecutableCodePublish]:
    static if PLATFORM_APPLE and ARCH_X86_64:
        if target == 0.uintptr():
            return 0.uintptr().cast[HostSegmentAgnosticEntry]
        _ = TLS_CaptureHostFsSelector()
        host_selector: u16 = TLS_HostFsSelectorRaw()
        code: mutable u8[22] = zeroed
        # movw $host_selector, %r10w; movw %r10w, %fs
        code[0] <- 0x66
        code[1] <- 0x41
        code[2] <- 0xBA
        ge_write_u16_le((&code[0]).cast[mutable u8&], 3, host_selector)
        code[5] <- 0x66
        code[6] <- 0x41
        code[7] <- 0x8E
        code[8] <- 0xE2
        # movabs $target, %r11; jmp *%r11
        code[9] <- 0x49
        code[10] <- 0xBB
        ge_write_u64_le((&code[0]).cast[mutable u8&], 11, target.u64())
        code[19] <- 0x41
        code[20] <- 0xFF
        code[21] <- 0xE3
        thunk: uintptr = c_GuestExec_AllocateRegion(4096, 5)
        if thunk == 0.uintptr():
            return target.cast[HostSegmentAgnosticEntry]
        can Memory:
            if c_GuestExec_WriteBytes(thunk, (&code[0]).cast[void&], GE_HOST_FS_ENTRY_THUNK_SIZE) != 0:
                return target.cast[HostSegmentAgnosticEntry]
        can Unsafe.ExecutableCodePublish:
            if c_GuestExec_PublishExecutableCode(thunk, GE_HOST_FS_ENTRY_THUNK_SIZE) != 0:
                return target.cast[HostSegmentAgnosticEntry]
        return thunk.cast[HostSegmentAgnosticEntry]
    static else:
        return target.cast[HostSegmentAgnosticEntry]

def ge_create_host_fs_entry_thunk_trusted(target: uintptr) -> HostSegmentAgnosticEntry:
    trusted Unsafe.MachineCodeBuilder, Unsafe.ExecutableCodePublish:
        return ge_create_host_fs_entry_thunk(target)

def c_GuestExec_PublishExecutableCode(address: uintptr, size: u64) -> s32 can[Unsafe.ExecutableCodePublish]:
    ge_publish_executable_last_addr <- address.cast[PublishedExecutableAddr]
    ge_publish_executable_last_size <- size
    ge_publish_executable_last_prot <- ge_native_prot_at(address, size)
    if address == 0.uintptr() or size == 0:
        ge_publish_executable_reject_count <- ge_publish_executable_reject_count + 1
        ge_publish_executable_last_result <- -1
        return -1
    if ge_publish_executable_last_prot == 0xffffffff or (ge_publish_executable_last_prot & 4) == 0:
        ge_publish_executable_reject_count <- ge_publish_executable_reject_count + 1
        ge_publish_executable_last_result <- -2
        return -2
    ge_flush_instruction_cache(address, size)
    ge_publish_executable_count <- ge_publish_executable_count + 1
    ge_record_published_exec(address.cast[PublishedExecutableAddr], size)
    ge_publish_executable_last_result <- 0
    return 0

def c_GuestExec_NativeRegionCount() -> u32:
    n: mutable u32 = 0
    i: mutable u32 = 0
    can Unsafe.AssumeProgress:
        while i < ge_native_region_count and i < GE_NATIVE_REGION_CAP:
            decreases GE_NATIVE_REGION_CAP - i
            if ge_native_regions[i.usize()].active != 0:
                n <- n + 1
            i <- i + 1
    return n

def c_GuestExec_AddressNativeProt(address: uintptr) -> u32:
    return ge_native_prot_at(address, 8)

def c_GuestExec_ReadNativeU64(address: uintptr) -> uintptr:
    can Memory.Allocate:
        return ge_read_native_word(address)

@c_abi(c)
def c_GuestExec_ReadContextU64(address: uintptr) -> uintptr:
    can Memory.Allocate:
        return ge_read_context_word(address)

def c_GuestExec_PublishExecutableCount() -> u64:
    return ge_publish_executable_count

def c_GuestExec_PublishExecutableRejectCount() -> u64:
    return ge_publish_executable_reject_count

def c_GuestExec_PublishExecutableLastAddr() -> uintptr:
    return !ge_publish_executable_last_addr

def c_GuestExec_PublishExecutableLastSize() -> u64:
    return ge_publish_executable_last_size

def c_GuestExec_PublishExecutableLastProt() -> u32:
    return ge_publish_executable_last_prot

def c_GuestExec_PublishExecutableLastResult() -> s32:
    return ge_publish_executable_last_result

def c_GuestExec_Sse4aExtrqHandledCount() -> u64:
    return ge_sse4a_extrq_handled_count

def c_GuestExec_Sse4aInsertqHandledCount() -> u64:
    return ge_sse4a_insertq_handled_count

def c_GuestExec_Sse4aLastPc() -> uintptr:
    return ge_sse4a_last_pc

def c_GuestExec_Sse4aLastWord() -> u32:
    return ge_sse4a_last_word

def c_GuestExec_PublishedExecutableCount() -> u32:
    return ge_published_exec_count

def c_GuestExec_IsExecutableCodePublished(address: uintptr, size: u64) -> s32:
    return 1 if ge_is_published_exec(address, size) else 0

def c_GuestExec_RecordHleBoundaryThunkContract(thunk: uintptr, target: uintptr, size: u64, host_selector: u16) -> void:
    idx: u64 = ge_hle_thunk_contract_count
    ge_hle_thunk_contract_count <- idx + 1
    ge_hle_thunk_contract_last_thunk <- thunk
    ge_hle_thunk_contract_last_target <- target
    ge_hle_thunk_contract_last_size <- size
    ge_hle_thunk_contract_last_host_selector <- host_selector.uintptr()
    if idx < GE_HLE_THUNK_CONTRACT_CAP:
        ge_hle_thunk_contract_addrs[idx.usize()] <- thunk
        ge_hle_thunk_contract_targets[idx.usize()] <- target
        ge_hle_thunk_contract_sizes[idx.usize()] <- size

def c_GuestExec_DebugTrapCount() -> u64:
    return ge_debug_trap_count

def c_GuestExec_DebugTrapReason() -> u64:
    return ge_debug_trap_reason

def c_GuestExec_DebugTrapValue() -> uintptr:
    return ge_debug_trap_value

def c_GuestExec_DebugTrapSequence() -> u64:
    return ge_debug_trap_sequence

def c_GuestExec_DebugTrapReturnAddr() -> uintptr:
    return ge_debug_trap_return_addr

def c_GuestExec_DebugTrapArg0() -> uintptr:
    return ge_debug_trap_arg0

def c_GuestExec_DebugTrapArg1() -> uintptr:
    return ge_debug_trap_arg1

def c_GuestExec_DebugTrapArg2() -> uintptr:
    return ge_debug_trap_arg2

def c_GuestExec_DebugTrapPointerSize() -> u64:
    return ge_debug_trap_pointer_size

def c_GuestExec_DebugTrapNearestMappingBase() -> uintptr:
    return ge_debug_trap_nearest_mapping_base

def c_GuestExec_DebugTrapNearestMappingEnd() -> uintptr:
    return ge_debug_trap_nearest_mapping_end

def c_GuestExec_DebugTrapNearestMappingProt() -> u32:
    return ge_debug_trap_nearest_mapping_prot

def c_GuestExec_DebugTrapTcbBase() -> uintptr:
    return ge_debug_trap_tcb_base

def c_GuestExec_DebugTrapTcbSelf() -> uintptr:
    return ge_debug_trap_tcb_self

def c_GuestExec_DebugTrapInstallFs0() -> uintptr:
    return ge_debug_trap_install_fs0

# ============================================================
# x86_64 signal/ucontext crash-capture foundation (Stage C+D+E, part 1).
# Inert until the atomic swap wires it in; the signal handler and guards mirror
# guest_exec_runtime.c. ucontext register extraction uses raw offset reads (no
# struct modeling) — the same fields upstream shadPS4 reads via uc_mcontext->__ss.
# ============================================================
@link_name(sigaction)
extern ge_sigaction(signum: int, act: void&?, oldact: void&?) -> int
@link_name(sigaltstack)
extern ge_sigaltstack(ss: void&?, oldss: void&?) -> int
@link_name(siglongjmp)
@reentrant_safe
extern ge_siglongjmp(env: void&?, val: int) -> void
@link_name(dladdr)
extern ge_dladdr(addr: void&?, info: void&?) -> int
@link_name(write)
@reentrant_safe
extern ge_raw_write(fd: int, buf: void&, count: usize) -> isize
@link_name(open)
@reentrant_safe
extern ge_raw_open(path: static u8&, flags: int, mode: int) -> int
@link_name(close)
@reentrant_safe
extern ge_raw_close(fd: int) -> int
@link_name(fchmod)
@reentrant_safe
extern ge_raw_fchmod(fd: int, mode: int) -> int

@reentrant_safe
def ge_raw_breadcrumb(msg: static u8&, count: usize) -> void:
    _ = ge_raw_write(2, msg.cast[void&], count)

const GE_EMERGENCY_CAP: usize = 256
const GE_EMERGENCY_DUMP_BYTES: usize = 12288
const GE_EMERGENCY_DUMP_PATH: static u8& = "/tmp/elisa_gewd.bin"
const GE_O_WRONLY: int = 0x0001
const GE_O_CREAT: int = 0x0200
