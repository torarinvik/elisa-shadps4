    if fr.pc_native_prot != 0u32:
        ge_pc_native_prot <- fr.pc_native_prot
    if fr.pc_was_fallback != 0:
        ge_last_pc_was_fallback <- 1
    if fr.native_phase != 0:
        ge_last_native_phase <- fr.native_phase
    if fr.runtime_hle_symbol != null:
