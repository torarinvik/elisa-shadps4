def ge_pc_source_is_fallback(source: s32) -> bool:
    return source == GE_PC_SOURCE_FALLBACK_CHILD_SIGLONGJMP or source == GE_PC_SOURCE_FALLBACK_PARENT_SILENT_CHILD or source == GE_PC_SOURCE_FALLBACK_PARENT_STATUS

# --- Runtime-HLE recording (ported; recorder + getters move together) ---
def c_GuestExec_RecordRuntimeHle(module: static u8&?, symbol: static u8&?, arg0: uintptr, arg1: uintptr, arg2: uintptr, ret: uintptr) -> void:
    ge_runtime_hle_sequence <- ge_runtime_hle_sequence + 1u64
    ge_runtime_hle_module <- module if module != null else ""
    ge_runtime_hle_symbol <- symbol if symbol != null else ""
    ge_runtime_hle_arg0 <- arg0
    ge_runtime_hle_arg1 <- arg1
    ge_runtime_hle_arg2 <- arg2
    ge_runtime_hle_ret <- ret
    ge_debug_trace_boundary("guest-exec-hle-args", arg0, arg1, arg2)
    ge_debug_trace_boundary("guest-exec-hle-ret", ret, ge_runtime_hle_sequence.uintptr(), ge_runtime_hle_guest_return_addr)
    ge_runtime_hle_arg0_native_prot <- ge_native_prot_at(arg0, 8u64)
    ge_runtime_hle_arg0_word0 <- ge_read_native_word(arg0)
    if ge_runtime_hle_first_bad_arg0_sequence == 0u64 and arg0 != 0.uintptr() and arg0 < 4096.uintptr() and ge_runtime_hle_arg0_native_prot == 0xffffffffu32:
        ge_runtime_hle_first_bad_arg0_sequence <- ge_runtime_hle_sequence
        ge_runtime_hle_first_bad_arg0_module <- ge_runtime_hle_module
        ge_runtime_hle_first_bad_arg0_symbol <- ge_runtime_hle_symbol
        ge_runtime_hle_first_bad_arg0_value <- arg0
        ge_runtime_hle_first_bad_arg0_return_addr <- ge_runtime_hle_guest_return_addr
        ge_runtime_hle_first_bad_arg0_rsi <- ge_runtime_hle_guest_rsi
        ge_runtime_hle_first_bad_arg0_rdx <- ge_runtime_hle_guest_rdx
    if ge_runtime_hle_first_tiny_unmapped_arg_sequence == 0u64:
        tiny_arg: mutable uintptr = 0.uintptr()
        tiny_index: mutable u64 = 0u64
        if arg0 != 0.uintptr() and arg0 < 4096.uintptr() and ge_runtime_hle_arg0_native_prot == 0xffffffffu32:
            tiny_arg <- arg0
            tiny_index <- 0u64
        elif arg1 != 0.uintptr() and arg1 < 4096.uintptr() and ge_native_prot_at(arg1, 8u64) == 0xffffffffu32:
            tiny_arg <- arg1
            tiny_index <- 1u64
        elif arg2 != 0.uintptr() and arg2 < 4096.uintptr() and ge_native_prot_at(arg2, 8u64) == 0xffffffffu32:
            tiny_arg <- arg2
            tiny_index <- 2u64
        if tiny_arg != 0.uintptr():
            ge_runtime_hle_first_tiny_unmapped_arg_sequence <- ge_runtime_hle_sequence
            ge_runtime_hle_first_tiny_unmapped_arg_index <- tiny_index
            ge_runtime_hle_first_tiny_unmapped_arg_module <- ge_runtime_hle_module
            ge_runtime_hle_first_tiny_unmapped_arg_symbol <- ge_runtime_hle_symbol
            ge_runtime_hle_first_tiny_unmapped_arg_value <- tiny_arg
            ge_runtime_hle_first_tiny_unmapped_arg_return_addr <- ge_runtime_hle_guest_return_addr
    if ge_runtime_hle_boundary_guard_sequence == 0u64:
        guard_value: mutable uintptr = 0.uintptr()
        guard_index: mutable u64 = 0u64
        guard_reason: mutable u64 = ge_boundary_guard_reason_for_value(arg0)
        if guard_reason != GE_BOUNDARY_GUARD_NONE:
            guard_value <- arg0
            guard_index <- 0u64
        else:
            guard_reason <- ge_boundary_guard_reason_for_value(arg1)
            if guard_reason != GE_BOUNDARY_GUARD_NONE:
                guard_value <- arg1
                guard_index <- 1u64
            else:
                guard_reason <- ge_boundary_guard_reason_for_value(arg2)
                if guard_reason != GE_BOUNDARY_GUARD_NONE:
                    guard_value <- arg2
                    guard_index <- 2u64
        if guard_reason != GE_BOUNDARY_GUARD_NONE:
            ge_runtime_hle_boundary_guard_sequence <- ge_runtime_hle_sequence
            ge_runtime_hle_boundary_guard_index <- guard_index
            ge_runtime_hle_boundary_guard_reason <- guard_reason
            ge_runtime_hle_boundary_guard_module <- ge_runtime_hle_module
            ge_runtime_hle_boundary_guard_symbol <- ge_runtime_hle_symbol
            ge_runtime_hle_boundary_guard_value <- guard_value
            ge_runtime_hle_boundary_guard_return_addr <- ge_runtime_hle_guest_return_addr
    ge_runtime_hle_recorder_stack_word0 <- 0.uintptr()
    ge_runtime_hle_recorder_stack_word1 <- 0.uintptr()
    static if ARCH_X86_64:
        sp: uintptr = ElisaGuestExec_CurrentStackPointerAsm()
        ge_runtime_hle_recorder_stack_word0 <- ge_read_context_word(sp)
        ge_runtime_hle_recorder_stack_word1 <- ge_read_context_word(sp + 8.uintptr())
    fr: ElisaGuestExecForkReport&? = ge_fork_report
    if fr != null:
        if ge_runtime_hle_guest_rsp != 0.uintptr():
            ge_runtime_hle_guest_stack_word0 <- ge_read_context_word(ge_runtime_hle_guest_rsp)
            ge_runtime_hle_guest_stack_word1 <- ge_read_context_word(ge_runtime_hle_guest_rsp + 8.uintptr())
            ge_runtime_hle_guest_stack_word2 <- ge_read_context_word(ge_runtime_hle_guest_rsp + 16.uintptr())
            ge_runtime_hle_guest_stack_word3 <- ge_read_context_word(ge_runtime_hle_guest_rsp + 24.uintptr())
        if ge_runtime_hle_guest_rbp != 0.uintptr():
            ge_runtime_hle_guest_frame_word0 <- ge_read_context_word(ge_runtime_hle_guest_rbp)
            ge_runtime_hle_guest_frame_word1 <- ge_read_context_word(ge_runtime_hle_guest_rbp + 8.uintptr())
            ge_runtime_hle_guest_frame_word2 <- ge_read_context_word(ge_runtime_hle_guest_rbp + 16.uintptr())
            ge_runtime_hle_guest_frame_word3 <- ge_read_context_word(ge_runtime_hle_guest_rbp + 24.uintptr())
            caller_frame: uintptr = ge_runtime_hle_guest_frame_word0
            if caller_frame != 0.uintptr():
                ge_runtime_hle_caller_frame_word0 <- ge_read_context_word(caller_frame)
                ge_runtime_hle_caller_frame_word1 <- ge_read_context_word(caller_frame + 8.uintptr())
                ge_runtime_hle_caller_frame_word2 <- ge_read_context_word(caller_frame + 16.uintptr())
                ge_runtime_hle_caller_frame_word3 <- ge_read_context_word(caller_frame + 24.uintptr())
        fr.runtime_hle_module <- ge_runtime_hle_module
        fr.runtime_hle_symbol <- ge_runtime_hle_symbol
        fr.runtime_hle_arg0 <- arg0
        fr.runtime_hle_arg1 <- arg1
        fr.runtime_hle_arg2 <- arg2
        fr.runtime_hle_ret <- ret
        fr.runtime_hle_arg0_native_prot <- ge_runtime_hle_arg0_native_prot
        fr.runtime_hle_arg0_word0 <- ge_runtime_hle_arg0_word0
        fr.runtime_hle_sequence <- ge_runtime_hle_sequence
        fr.runtime_hle_first_bad_arg0_sequence <- ge_runtime_hle_first_bad_arg0_sequence
        fr.runtime_hle_first_bad_arg0_module <- ge_runtime_hle_first_bad_arg0_module
        fr.runtime_hle_first_bad_arg0_symbol <- ge_runtime_hle_first_bad_arg0_symbol
        fr.runtime_hle_first_bad_arg0_value <- ge_runtime_hle_first_bad_arg0_value
        fr.runtime_hle_first_bad_arg0_return_addr <- ge_runtime_hle_first_bad_arg0_return_addr
        fr.runtime_hle_first_bad_arg0_rsi <- ge_runtime_hle_first_bad_arg0_rsi
        fr.runtime_hle_first_bad_arg0_rdx <- ge_runtime_hle_first_bad_arg0_rdx
        fr.runtime_hle_first_tiny_unmapped_arg_sequence <- ge_runtime_hle_first_tiny_unmapped_arg_sequence
        fr.runtime_hle_first_tiny_unmapped_arg_index <- ge_runtime_hle_first_tiny_unmapped_arg_index
        fr.runtime_hle_first_tiny_unmapped_arg_module <- ge_runtime_hle_first_tiny_unmapped_arg_module
        fr.runtime_hle_first_tiny_unmapped_arg_symbol <- ge_runtime_hle_first_tiny_unmapped_arg_symbol
        fr.runtime_hle_first_tiny_unmapped_arg_value <- ge_runtime_hle_first_tiny_unmapped_arg_value
        fr.runtime_hle_first_tiny_unmapped_arg_return_addr <- ge_runtime_hle_first_tiny_unmapped_arg_return_addr
        fr.runtime_hle_boundary_guard_sequence <- ge_runtime_hle_boundary_guard_sequence
        fr.runtime_hle_boundary_guard_index <- ge_runtime_hle_boundary_guard_index
        fr.runtime_hle_boundary_guard_reason <- ge_runtime_hle_boundary_guard_reason
        fr.runtime_hle_boundary_guard_module <- ge_runtime_hle_boundary_guard_module
        fr.runtime_hle_boundary_guard_symbol <- ge_runtime_hle_boundary_guard_symbol
        fr.runtime_hle_boundary_guard_value <- ge_runtime_hle_boundary_guard_value
        fr.runtime_hle_boundary_guard_return_addr <- ge_runtime_hle_boundary_guard_return_addr
        fr.runtime_hle_recorder_stack_word0 <- ge_runtime_hle_recorder_stack_word0
        fr.runtime_hle_recorder_stack_word1 <- ge_runtime_hle_recorder_stack_word1
        fr.runtime_hle_guest_return_addr <- ge_runtime_hle_guest_return_addr
        fr.runtime_hle_guest_rsp <- ge_runtime_hle_guest_rsp
        fr.runtime_hle_guest_rbp <- ge_runtime_hle_guest_rbp
        fr.runtime_hle_guest_rdi <- ge_runtime_hle_guest_rdi
        fr.runtime_hle_guest_rsi <- ge_runtime_hle_guest_rsi
        fr.runtime_hle_guest_rdx <- ge_runtime_hle_guest_rdx
        fr.runtime_hle_guest_rcx <- ge_runtime_hle_guest_rcx
        fr.runtime_hle_guest_r8 <- ge_runtime_hle_guest_r8
        fr.runtime_hle_guest_r9 <- ge_runtime_hle_guest_r9
        fr.runtime_hle_guest_stack_word0 <- ge_runtime_hle_guest_stack_word0
        fr.runtime_hle_guest_stack_word1 <- ge_runtime_hle_guest_stack_word1
        fr.runtime_hle_guest_stack_word2 <- ge_runtime_hle_guest_stack_word2
        fr.runtime_hle_guest_stack_word3 <- ge_runtime_hle_guest_stack_word3
        fr.runtime_hle_guest_frame_word0 <- ge_runtime_hle_guest_frame_word0
        fr.runtime_hle_guest_frame_word1 <- ge_runtime_hle_guest_frame_word1
        fr.runtime_hle_guest_frame_word2 <- ge_runtime_hle_guest_frame_word2
        fr.runtime_hle_guest_frame_word3 <- ge_runtime_hle_guest_frame_word3
        fr.runtime_hle_caller_frame_word0 <- ge_runtime_hle_caller_frame_word0
        fr.runtime_hle_caller_frame_word1 <- ge_runtime_hle_caller_frame_word1
        fr.runtime_hle_caller_frame_word2 <- ge_runtime_hle_caller_frame_word2
        fr.runtime_hle_caller_frame_word3 <- ge_runtime_hle_caller_frame_word3
    ge_maybe_debug_trap_boundary_guard()

