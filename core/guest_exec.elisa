const GE_EV_RELOC_TABLE_END: u32 = 87
const GE_EV_RELOC_MODULE_END: u32 = 88
const GE_EV_SSE4A_SIGILL_ENTER: u32 = 110
const GE_EV_SSE4A_EXTRQ_HANDLED: u32 = 111
const GE_EV_SSE4A_INSERTQ_HANDLED: u32 = 112
const GE_EV_SSE4A_UNHANDLED: u32 = 113
# Oracle slice: consolidated first-HLE-boundary facts for shadPS4 parity diffing.
# CONT  payload = (continuation_addr, native_prot_at(cont), is_published?1:0, owning_region_index)
# STACK payload = (guest_rsp, stack[0], stack[1], stack[2])
# META  payload = (boundary_guard_reason, guest_rbp, guest_return_addr, sequence)
const GE_EV_ORACLE_BOUNDARY_CONT: u32 = 120
const GE_EV_ORACLE_BOUNDARY_STACK: u32 = 121
const GE_EV_ORACLE_BOUNDARY_META: u32 = 122
# Crash backtrace: each mark carries (stack_addr, word_value) for one guest
# stack slot at/above the faulting SP, so a post-run symbolizer can reconstruct
# the guest call chain from the emergency tape without touching live guest state.
const GE_EV_STACK_DUMP: u32 = 123
# Value-watchpoint hit: (watched_addr, observed_value, poll_site, hle_sequence).
const GE_EV_WATCH_HIT: u32 = 124
# Per-HLE-boundary guest rsp trace: (guest_rsp, guest_return_addr, hle_seq, 0).
const GE_EV_HLE_RSP: u32 = 125
const GE_EV_WRITE_BUFFER_META: u32 = 126
const GE_EV_WRITE_BUFFER_CHUNK: u32 = 127
const GE_EV_DEBUG_RAISE: u32 = 128
const GE_EV_HLE_RING_SYMBOL: u32 = 129
const GE_EV_HLE_RING_TARGET: u32 = 130
const GE_EV_HLE_KNOWN_TARGET: u32 = 131
const GE_EV_DEBUG_RAISE_STACK: u32 = 132
const GE_EV_SIGNAL_CALLEE_SAVED: u32 = 133
const GE_EV_SIGNAL_GPRS: u32 = 134
# Diagnostic: bytes of the faulting instruction (raw read at the fault PC) so the
# segment prefix (0x64=fs / 0x65=gs) of a TLS-deref fault can be read off the tape.
const GE_EV_SIGNAL_FAULT_INSN: u32 = 135
# Diagnostic: segment selectors from the faulting thread state (__ss): fs(+152),
# gs(+160), cs(+144). Distinguishes guest-fs vs host-gs faults.
const GE_EV_SIGNAL_SEGMENTS: u32 = 136
# Diagnostic: if the instruction at fault_pc-16 is `mov rax,[rip+disp32]` (48 8b 05),
# resolve that RIP-relative global's address and read its value. Tells us whether the
# null that drove the fault came from a genuinely-null/zeroed global (and its address,
# to classify shadowed-by-guest-mapping vs uninitialized).
const GE_EV_SIGNAL_FAULT_GLOBAL: u32 = 137
# Native-region table dump (ge_dump_native_regions). META carries the query context:
#   a = active_region_count, b = lookup_addr, c = lookup_size, d = found_index (0xffffffff = none).
# ENTRY carries one region: a = base, b = size, c = prot, d = (active<<32)|table_index.
# TRUNC is emitted instead of further ENTRYs when the per-dump entry cap is hit:
#   a = emitted_count, b = total_active, c = 0, d = 0  (no silent truncation).
const GE_EV_NATIVE_REGION_META: u32 = 138
const GE_EV_NATIVE_REGION_ENTRY: u32 = 139
const GE_EV_NATIVE_REGION_TRUNC: u32 = 140
# libc_internal malloc HLE result: a=size, b=heap_cursor, c=heap_limit, d=result_ptr
# (d==0 => malloc returned NULL). Lets the tape show whether/why the guest-heap arena
# handed back null (arena not reserved, exhausted, or oversized request).
const GE_EV_LIBC_MALLOC: u32 = 141
# Page watchpoint armed: a=watched_addr, b=page_base, c=arm_prot (1=PROT_READ traps
# writes, 0=PROT_NONE traps reads+writes), d=0. Lets triage distinguish "armed but
# never written (uninitialized slot)" from "no watch was set".
const GE_EV_WATCH_ARM: u32 = 142
const GE_EV_MUTEX_INIT: u32 = 1001

const GE_LONGJMP_SOURCE_DEBUG_TRAP_ABORT: u32 = 1
const GE_LONGJMP_SOURCE_BOUNDARY_GUARD: u32 = 2
const GE_LONGJMP_SOURCE_ALARM: u32 = 3
const GE_LONGJMP_SOURCE_PC_SAMPLER: u32 = 4
const GE_LONGJMP_SOURCE_SIGNAL: u32 = 5

@fixed_layout
struct GeEmergencyEvent:
    seq: mutable u64
    kind: mutable u32
    phase: mutable u32
    a: mutable uintptr
    b: mutable uintptr
    c: mutable uintptr
    d: mutable uintptr

global mutable ge_emergency_events: GeEmergencyEvent[256] = zeroed
global mutable ge_emergency_seq: u64 = 0
global mutable ge_emergency_watchdog_failfast: bool = false
global mutable ge_emergency_dump_fd: int = -1
global mutable ge_current_hle_id: u32 = 0
global mutable ge_current_guest_pc: uintptr = 0.uintptr()
global mutable ge_current_return_pc: uintptr = 0.uintptr()
global mutable ge_current_guest_sp: uintptr = 0.uintptr()
global mutable ge_current_segment_owner: u32 = GE_FS_OWNER_UNKNOWN
global mutable ge_last_write_fd: int = -1
global mutable ge_last_write_nbytes: u64 = 0
global mutable ge_last_write_limit: usize = 0
global mutable ge_last_write_hle_seq: u64 = 0
global mutable ge_last_write_bytes: u8[128] = zeroed
global mutable ge_write_stream_len: usize = 0
global mutable ge_write_stream_bytes: u8[512] = zeroed
global mutable ge_known_kernel_file_write_target: u64 = 0
global mutable ge_known_posix_write_target: u64 = 0
global mutable ge_known_sce_kernel_write_target: u64 = 0

@reentrant_safe
def ge_emergency_mark(kind: u32, a: uintptr, b: uintptr, c: uintptr, d: uintptr) -> void:
    seq: u64 = ge_emergency_seq + 1
    ge_emergency_seq <- seq
    i: usize = (seq & 255).usize()
    ge_emergency_events[i].seq <- seq
    ge_emergency_events[i].kind <- kind
    ge_emergency_events[i].phase <- ge_last_native_phase.u32()
    ge_emergency_events[i].a <- a
    ge_emergency_events[i].b <- b
    ge_emergency_events[i].c <- c
    ge_emergency_events[i].d <- d

@reentrant_safe
def GuestExec_EmergencyMark(kind: u32, a: uintptr, b: uintptr, c: uintptr, d: uintptr) -> void:
    ge_emergency_mark(kind, a, b, c, d)

@reentrant_safe
def ge_mark_guard_longjmp(status: s32, source: u32, value: uintptr) -> void:
    ge_emergency_mark(GE_EV_GUARD_LONGJMP, status.u64().uintptr(), source.u64().uintptr(), value, ge_last_status.u64().uintptr())

@reentrant_safe
def ge_emergency_dump_raw() -> void:
    _ = ge_raw_write(2, "GEWD1\n".cast[void&], 6)
    fd: int = ge_raw_open(GE_EMERGENCY_DUMP_PATH, GE_O_WRONLY | GE_O_CREAT | GE_O_TRUNC, GE_CREATE_MODE_0644)
    if fd >= 0:
        _ = ge_raw_fchmod(fd, GE_CREATE_MODE_0644)
        _ = ge_raw_write(fd, (&ge_emergency_events[0]).cast[void&], GE_EMERGENCY_DUMP_BYTES)
        _ = ge_raw_close(fd)

def ge_pack_bytes_u64(bytes: u8&, start: usize, limit: usize) -> u64:
    value: mutable u64 = 0
    j: mutable usize = 0
    while j < 8:
        idx: usize = start + j
        if idx < limit:
            value <- value | (bytes[idx].u64() << (j.u64() * 8))
        j <- j + 1
    return value

def GuestExec_RecordWriteBuffer(fd: int, buf: void&?, nbytes: u64) -> void:
    if buf == null or nbytes == 0:
        return
    limit: mutable usize = nbytes.usize()
    if limit > 128:
        limit <- 128
    ge_last_write_fd <- fd
    ge_last_write_nbytes <- nbytes
    ge_last_write_limit <- limit
    ge_last_write_hle_seq <- ge_runtime_hle_sequence
    source: u8& = buf.cast[u8&]
    copy_i: mutable usize = 0
    while copy_i < limit:
        ge_last_write_bytes[copy_i] <- source[copy_i]
        copy_i <- copy_i + 1
    if fd == 1 or fd == 2:
        append_limit: mutable usize = limit
        if append_limit > 512:
            append_limit <- 512
        if ge_write_stream_len + append_limit > 512:
            drop: usize = ge_write_stream_len + append_limit - 512
            keep: usize = ge_write_stream_len - drop
            move_i: mutable usize = 0
            while move_i < keep:
                ge_write_stream_bytes[move_i] <- ge_write_stream_bytes[move_i + drop]
                move_i <- move_i + 1
            ge_write_stream_len <- keep
        append_i: mutable usize = 0
        while append_i < append_limit:
            ge_write_stream_bytes[ge_write_stream_len + append_i] <- source[append_i]
            append_i <- append_i + 1
        ge_write_stream_len <- ge_write_stream_len + append_limit
    ge_emergency_mark(GE_EV_WRITE_BUFFER_META, fd.u64().uintptr(), nbytes.uintptr(), limit.uintptr(), ge_runtime_hle_sequence.uintptr())
    offset: mutable usize = 0
    chunk_index: mutable u64 = 0
    while offset < limit:
        a: u64 = ge_pack_bytes_u64(source, offset, limit)
        b: u64 = ge_pack_bytes_u64(source, offset + 8, limit)
        c: u64 = ge_pack_bytes_u64(source, offset + 16, limit)
        d: u64 = ge_pack_bytes_u64(source, offset + 24, limit)
        ge_emergency_mark(GE_EV_WRITE_BUFFER_CHUNK, chunk_index.uintptr(), a.uintptr(), b.uintptr(), c.uintptr())
        ge_emergency_mark(GE_EV_WRITE_BUFFER_CHUNK, (chunk_index | 0x80000000).uintptr(), d.uintptr(), 0.uintptr(), 0.uintptr())
        offset <- offset + 32
        chunk_index <- chunk_index + 1

def GuestExec_ReemitLastWriteBuffer() -> void:
    if ge_last_write_limit == 0:
        return
    ge_emergency_mark(GE_EV_WRITE_BUFFER_META, ge_last_write_fd.u64().uintptr(), ge_last_write_nbytes.uintptr(), ge_last_write_limit.uintptr(), ge_last_write_hle_seq.uintptr())
    offset: mutable usize = 0
    chunk_index: mutable u64 = 0
    while offset < ge_last_write_limit:
        a: u64 = ge_pack_bytes_u64(ge_last_write_bytes[0], offset, ge_last_write_limit)
        b: u64 = ge_pack_bytes_u64(ge_last_write_bytes[0], offset + 8, ge_last_write_limit)
        c: u64 = ge_pack_bytes_u64(ge_last_write_bytes[0], offset + 16, ge_last_write_limit)
        d: u64 = ge_pack_bytes_u64(ge_last_write_bytes[0], offset + 24, ge_last_write_limit)
        ge_emergency_mark(GE_EV_WRITE_BUFFER_CHUNK, chunk_index.uintptr(), a.uintptr(), b.uintptr(), c.uintptr())
        ge_emergency_mark(GE_EV_WRITE_BUFFER_CHUNK, (chunk_index | 0x80000000).uintptr(), d.uintptr(), 0.uintptr(), 0.uintptr())
        offset <- offset + 32
        chunk_index <- chunk_index + 1

def GuestExec_ReemitWriteStream() -> void:
    if ge_write_stream_len == 0:
        return
    ge_emergency_mark(GE_EV_WRITE_BUFFER_META, 0xffff.uintptr(), ge_write_stream_len.u64().uintptr(), ge_write_stream_len.uintptr(), ge_runtime_hle_sequence.uintptr())
    offset: mutable usize = 0
    chunk_index: mutable u64 = 0
    while offset < ge_write_stream_len:
        a: u64 = ge_pack_bytes_u64(ge_write_stream_bytes[0], offset, ge_write_stream_len)
        b: u64 = ge_pack_bytes_u64(ge_write_stream_bytes[0], offset + 8, ge_write_stream_len)
        c: u64 = ge_pack_bytes_u64(ge_write_stream_bytes[0], offset + 16, ge_write_stream_len)
        d: u64 = ge_pack_bytes_u64(ge_write_stream_bytes[0], offset + 24, ge_write_stream_len)
        ge_emergency_mark(GE_EV_WRITE_BUFFER_CHUNK, chunk_index.uintptr(), a.uintptr(), b.uintptr(), c.uintptr())
        ge_emergency_mark(GE_EV_WRITE_BUFFER_CHUNK, (chunk_index | 0x80000000).uintptr(), d.uintptr(), 0.uintptr(), 0.uintptr())
        offset <- offset + 32
        chunk_index <- chunk_index + 1

def GuestExec_RecordDebugRaise(err_code: int, unk: i64) -> void:
    can Memory.Allocate:
        GuestExec_ReemitWriteStream()
        GuestExec_ReemitLastWriteBuffer()
        ge_emergency_mark(GE_EV_HLE_KNOWN_TARGET, 1.uintptr(), ge_known_kernel_file_write_target.uintptr(), ge_known_posix_write_target.uintptr(), ge_known_sce_kernel_write_target.uintptr())
        sp: uintptr = !ge_runtime_hle_guest_rsp
        ge_emergency_mark(GE_EV_DEBUG_RAISE_STACK, sp, ge_read_native_word(sp), ge_read_native_word(sp + 8.uintptr()), ge_read_native_word(sp + 16.uintptr()))
        ge_emergency_mark(GE_EV_DEBUG_RAISE_STACK, sp + 24.uintptr(), ge_read_native_word(sp + 24.uintptr()), ge_read_native_word(sp + 32.uintptr()), ge_read_native_word(sp + 40.uintptr()))
        ge_emergency_mark(GE_EV_DEBUG_RAISE, err_code.u64().uintptr(), unk.u64().uintptr(), !ge_runtime_hle_guest_return_addr, !ge_runtime_hle_guest_rsp)

def ge_symbol_is_kernel_write(symbol: static u8&?) -> bool:
    if symbol == null:
        return false
    s: static u8& = (&symbol).cast[static u8&]
    return s[0] == 0x46 and s[1] == 0x78 and s[2] == 0x56 and s[3] == 0x5a and s[4] == 0x71 and s[5] == 0x42 and s[6] == 0x41 and s[7] == 0x41 and s[8] == 0x37 and s[9] == 0x6b and s[10] == 0x73 and s[11] == 0

def GuestExec_RecordHleRingSymbol(seq: u64, symbol: static u8&?) -> void:
    if symbol == null:
        ge_emergency_mark(GE_EV_HLE_RING_SYMBOL, seq.uintptr(), 0.uintptr(), 0.uintptr(), 0.uintptr())
        return
    text: u8& = (&symbol).cast[u8&]
    a: u64 = ge_pack_bytes_u64(text, 0, 24)
    b: u64 = ge_pack_bytes_u64(text, 8, 24)
    c: u64 = ge_pack_bytes_u64(text, 16, 24)
    ge_emergency_mark(GE_EV_HLE_RING_SYMBOL, seq.uintptr(), a.uintptr(), b.uintptr(), c.uintptr())

def GuestExec_RecordHleRingTarget(seq: u64, target: u64) -> void:
    ge_emergency_mark(GE_EV_HLE_RING_TARGET, seq.uintptr(), target.uintptr(), 0.uintptr(), 0.uintptr())

# macOS struct sigaction (16 bytes): handler ptr, sa_mask (u32), sa_flags (int).
# Linux's is larger/different — modeled for the validated macOS path; Linux is
# a follow-up (like the Windows memory stubs).
@fixed_layout
struct GeSigaction:
    handler: mutable void&?
    mask: mutable u32
    flags: mutable int

# stack_t: { void *ss_sp; size_t ss_size; int ss_flags; }
@fixed_layout
struct GeStackT:
    ss_sp: mutable void&?
    ss_size: mutable usize
    ss_flags: mutable int

# Alternate signal stack so the fault handlers (SIGSEGV/BUS/ILL/FPE/TRAP) run on
# a known-good stack rather than the possibly-corrupted/exhausted guest stack —
# matching shadPS4 signals.cpp which installs its handler with SA_ONSTACK.
const GE_SIGSTKSZ: usize = 131072
global mutable ge_alt_signal_stack: u8[131072] = zeroed
global mutable ge_alt_signal_stack_installed: s32 = 0

# Dl_info: { const char* dli_fname; void* dli_fbase; const char* dli_sname; void* dli_saddr; }
@fixed_layout
struct GeDlInfo:
    dli_fname: mutable static u8&?
    dli_fbase: mutable void&?
    dli_sname: mutable static u8&?
    dli_saddr: mutable void&?

global mutable ge_guard_active: s32 = 0
global mutable ge_old_segv: GeSigaction = zeroed
global mutable ge_old_bus: GeSigaction = zeroed
global mutable ge_old_ill: GeSigaction = zeroed
global mutable ge_old_fpe: GeSigaction = zeroed
global mutable ge_old_trap: GeSigaction = zeroed
global mutable ge_old_alrm: GeSigaction = zeroed
global mutable ge_jmp_buf: u8[256] = zeroed
global mutable ge_cross_thread_signal_count: u64 = 0
global mutable ge_cross_thread_signal_guard_thread: uintptr = 0.uintptr()
global mutable ge_cross_thread_signal_fault_thread: uintptr = 0.uintptr()
global mutable ge_cross_thread_signal_number: s32 = 0

const GE_SIG_SEGV: int = 11
const GE_SIG_ILL: int = 4
const GE_SIG_FPE: int = 8
const GE_SIG_TRAP: int = 5
const GE_SIG_ALRM: int = 14
@reentrant_safe
def ge_sig_bus() -> int:
    static if PLATFORM_APPLE:
        return 10
    static else:
        return 7
def ge_sa_siginfo() -> int:
    return 0x40

@reentrant_safe
def ge_set_native_phase(phase: s32) -> void:
    ge_last_native_phase <- phase
    fr: ElisaGuestExecForkReport&? = ge_fork_report
    if fr != null:
        fr.native_phase <- phase

# Lowest address ge_read/write_context_word will touch. One 4 KiB page: anything
# below is the null page (uninitialized/zero context plus a small field offset).
const GE_MIN_READABLE_ADDRESS: u64 = 0x1000

# Raw read of a uintptr at an arbitrary host address (signal/stack context).
@reentrant_safe
def ge_read_context_word(address: uintptr) -> uintptr:
    can Memory.Allocate:
        # Null-page guard: reject the whole first page, not just exact 0. Diagnostic
        # probes read word triples at addr+8/+16/+24; when the source context was
        # never established (addr==0), those offsets become tiny unmapped addresses
        # (8/16/24) that the bare `== 0` check let through, faulting in ge_memcpy.
        # Every legitimate read — guest VAs (>=0x800000000) and host uctx/mcontext
        # pointers — sits far above the null page, so this never rejects a real read.
        if address.u64() < GE_MIN_READABLE_ADDRESS:
            return 0.uintptr()
        out: mutable u64 = 0
        _ = ge_memcpy((&out).cast[void&], ge_addr_to_ptr(address), 8)
        return out.uintptr()

@reentrant_safe
def ge_write_context_word(address: uintptr, value: uintptr) -> void:
    can Memory.Allocate:
        if address.u64() < GE_MIN_READABLE_ADDRESS:
            return
        v: mutable u64 = value.u64()
        _ = ge_memcpy(ge_addr_to_ptr(address), (&v).cast[void&], 8)

@reentrant_safe
def ge_uctx_word(uctx: void&?, offset: u64) -> uintptr:
    can Memory.Allocate:
        if uctx == null:
            return 0.uintptr()
        return ge_read_context_word(uctx.uintptr() + offset.uintptr())

@reentrant_safe
def ge_extract_mctx(uctx: void&?) -> MachineContextPtr:
    static if ARCH_X86_64 and PLATFORM_APPLE:
        return ge_uctx_word(uctx, 48).cast[MachineContextPtr]
    static elif ARCH_X86_64 and PLATFORM_LINUX:
        return (uctx.uintptr() + 40.uintptr()).cast[MachineContextPtr] if uctx != null else 0.uintptr().cast[MachineContextPtr]
    static else:
        _ = uctx
        return 0.uintptr().cast[MachineContextPtr]

# x86_64 ucontext register extraction (raw offsets). macOS: uc_mcontext ptr at
# uctx+48 -> mcontext64.{__es, __ss, __fs}; thread registers begin after the
# 16-byte exception state, so __ss.__rip is mctx+16+128. Linux: inline
# uc_mcontext.gregs at uctx+40.
const GE_DARWIN_MCONTEXT64_SS_OFFSET: uintptr = 16.uintptr()

@reentrant_safe
def ge_darwin_mcontext64_ss(uctx: void&?) -> uintptr:
    can Memory.Allocate:
        mctx: uintptr = ge_uctx_word(uctx, 48)
        if mctx == 0.uintptr():
            return 0.uintptr()
        return mctx + GE_DARWIN_MCONTEXT64_SS_OFFSET

@reentrant_safe
def ge_extract_pc(uctx: void&?) -> GuestPC:
    static if ARCH_X86_64 and PLATFORM_APPLE:
        ss: uintptr = ge_darwin_mcontext64_ss(uctx)
        return ge_read_context_word(ss + 128.uintptr()).cast[GuestPC]
    static elif ARCH_X86_64 and PLATFORM_LINUX:
        return ge_uctx_word(uctx, 40 + 16 * 8).cast[GuestPC]
    static else:
        return 0.uintptr().cast[GuestPC]

@reentrant_safe
def ge_extract_sp(uctx: void&?) -> GuestStackPointer:
    static if ARCH_X86_64 and PLATFORM_APPLE:
        ss: uintptr = ge_darwin_mcontext64_ss(uctx)
        return ge_read_context_word(ss + 56.uintptr()).cast[GuestStackPointer]
    static elif ARCH_X86_64 and PLATFORM_LINUX:
        return ge_uctx_word(uctx, 40 + 15 * 8).cast[GuestStackPointer]
    static else:
        return 0.uintptr().cast[GuestStackPointer]

@reentrant_safe
def ge_extract_bp(uctx: void&?) -> GuestFramePointer:
    static if ARCH_X86_64 and PLATFORM_APPLE:
        ss: uintptr = ge_darwin_mcontext64_ss(uctx)
        return ge_read_context_word(ss + 48.uintptr()).cast[GuestFramePointer]
    static elif ARCH_X86_64 and PLATFORM_LINUX:
        return ge_uctx_word(uctx, 40 + 10 * 8).cast[GuestFramePointer]
    static else:
        return 0.uintptr().cast[GuestFramePointer]

# reg index: 0=rdi 1=rsi 2=rax 3=rbx 4=rdx 5=rcx 6=r8 7=r9
#            8=r12 9=r13 10=r14 11=r15
@reentrant_safe
def ge_extract_greg(uctx: void&?, reg: int) -> uintptr:
    static if ARCH_X86_64 and PLATFORM_APPLE:
        ss: uintptr = ge_darwin_mcontext64_ss(uctx)
        off: mutable u64 = 0
        if reg == 0:
            off <- 32
        elif reg == 1:
            off <- 40
        elif reg == 2:
            off <- 0
        elif reg == 3:
            off <- 8
        elif reg == 4:
            off <- 24
        elif reg == 5:
            off <- 16
        elif reg == 6:
            off <- 64
        elif reg == 7:
            off <- 72
        elif reg == 8:
            off <- 96
        elif reg == 9:
            off <- 104
        elif reg == 10:
            off <- 112
        elif reg == 11:
            off <- 120
        else:
            return 0.uintptr()
        return ge_read_context_word(ss + off.uintptr())
    static elif ARCH_X86_64 and PLATFORM_LINUX:
        gi: mutable u64 = 0
        if reg == 0:
            gi <- 8
        elif reg == 1:
            gi <- 9
        elif reg == 2:
            gi <- 13
        elif reg == 3:
            gi <- 11
        elif reg == 4:
            gi <- 12
        elif reg == 5:
            gi <- 14
        elif reg == 6:
            gi <- 0
        elif reg == 7:
            gi <- 1
        elif reg == 8:
            gi <- 4
        elif reg == 9:
            gi <- 5
        elif reg == 10:
            gi <- 6
        elif reg == 11:
            gi <- 7
        else:
            return 0.uintptr()
        return ge_uctx_word(uctx, 40 + gi * 8)
    static else:
        return 0.uintptr()

@reentrant_safe
def ge_write_pc(uctx: void&?, pc: GuestPC) -> void:
    static if ARCH_X86_64 and PLATFORM_APPLE:
        mctx: uintptr = ge_uctx_word(uctx, 48)
        ge_write_context_word(mctx + 128.uintptr(), !pc)
    static elif ARCH_X86_64 and PLATFORM_LINUX:
        if uctx != null:
            ge_write_context_word(uctx.uintptr() + 168.uintptr(), !pc)
        else:
            _ = pc
    static else:
        _ = uctx
        _ = pc

@reentrant_safe
def ge_xmm_addr_from_mctx(mctx: uintptr, idx: u8) -> uintptr:
    static if ARCH_X86_64 and PLATFORM_APPLE:
        return mctx + 352.uintptr() + (idx.u64() * 16).uintptr()
    static elif ARCH_X86_64 and PLATFORM_LINUX:
        can Memory.Allocate:
            fpregs: uintptr = ge_read_context_word(mctx + 184.uintptr())
            if fpregs == 0.uintptr():
                return 0.uintptr()
            return fpregs + 160.uintptr() + (idx.u64() * 16).uintptr()
    static else:
        _ = mctx
        _ = idx
        return 0.uintptr()

@reentrant_safe
def ge_read_xmm_low(mctx: uintptr, idx: u8) -> u64:
    can Memory.Allocate:
        return ge_read_context_word(ge_xmm_addr_from_mctx(mctx, idx)).u64()

@reentrant_safe
def ge_read_xmm_high(mctx: uintptr, idx: u8) -> u64:
    can Memory.Allocate:
        return ge_read_context_word(ge_xmm_addr_from_mctx(mctx, idx) + 8.uintptr()).u64()

@reentrant_safe
def ge_write_xmm_low_zero_high(mctx: uintptr, idx: u8, value: u64) -> void:
    can Memory.Allocate:
        ge_write_context_word(ge_xmm_addr_from_mctx(mctx, idx), value.uintptr())
        ge_write_context_word(ge_xmm_addr_from_mctx(mctx, idx) + 8.uintptr(), 0.uintptr())

@reentrant_safe
def ge_sse4a_mask(length_raw: u64) -> u64:
    length: u64 = length_raw & 0x3F
    if length == 0:
        return 0xffffffffffffffff
    return (1 << length) - 1

@reentrant_safe
def ge_try_handle_sse4a_sigill(uctx: void&?) -> bool:
    static if ARCH_X86_64 and (PLATFORM_APPLE or PLATFORM_LINUX):
        mctx_ptr: MachineContextPtr = ge_extract_mctx(uctx)
        mctx: uintptr = !mctx_ptr
        pc: GuestPC = ge_extract_pc(uctx)
        if mctx == 0.uintptr() or !pc == 0.uintptr():
            return false
        word: u32 = (ge_read_context_word(!pc).u64() & 0xffffffff).u32()
        b0: u8 = (word & 0xff).u8()
        b1: u8 = ((word >> 8) & 0xff).u8()
        b2: u8 = ((word >> 16) & 0xff).u8()
        modrm: u8 = ((word >> 24) & 0xff).u8()
        ge_emergency_mark(GE_EV_SSE4A_SIGILL_ENTER, !pc, word.u64().uintptr(), 0.uintptr(), 0.uintptr())
        if b1 != 0x0f or (b2 != 0x79 and b2 != 0x78):
            ge_emergency_mark(GE_EV_SSE4A_UNHANDLED, !pc, word.u64().uintptr(), 1.uintptr(), 0.uintptr())
            return false
        mod_bits: u8 = (modrm >> 6) & 0x03
        if mod_bits != 0x03:
            ge_emergency_mark(GE_EV_SSE4A_UNHANDLED, !pc, word.u64().uintptr(), 2.uintptr(), 0.uintptr())
            return false
        dst: u8 = (modrm >> 3) & 0x07
        src: u8 = modrm & 0x07
        immediate_form: bool = b2 == 0x78
        imm_length: mutable u64 = 0
        imm_index: mutable u64 = 0
        if immediate_form:
            imm_word: u64 = ge_read_context_word(!pc + 4.uintptr()).u64()
            imm_length <- imm_word & 0xff
            imm_index <- (imm_word >> 8) & 0xff
        if b0 == 0x66:
            dst_low: u64 = ge_read_xmm_low(mctx, dst)
            src_low: u64 = ge_read_xmm_low(mctx, src)
            length: u64 = imm_length if immediate_form else (src_low & 0x3F)
            index: mutable u64 = imm_index if immediate_form else ((src_low >> 8) & 0x3F)
            index <- index & 0x3F
            mask: u64 = ge_sse4a_mask(length)
            result: u64 = (dst_low >> index) & mask
            ge_write_xmm_low_zero_high(mctx, dst, result)
            advance: uintptr = 6.uintptr() if immediate_form else 4.uintptr()
            ge_write_pc(uctx, (!pc + advance).cast[GuestPC])
            ge_sse4a_extrq_handled_count <- ge_sse4a_extrq_handled_count + 1
            ge_sse4a_last_pc <- !pc
            ge_sse4a_last_word <- word
            ge_emergency_mark(GE_EV_SSE4A_EXTRQ_HANDLED, !pc, word.u64().uintptr(), result.uintptr(), ge_sse4a_extrq_handled_count.uintptr())
            return true
        if b0 == 0xf2:
            src_low: u64 = ge_read_xmm_low(mctx, src)
            src_high: u64 = ge_read_xmm_high(mctx, src)
            dst_low: u64 = ge_read_xmm_low(mctx, dst)
            length: u64 = imm_length if immediate_form else (src_high & 0x3F)
            index: mutable u64 = imm_index if immediate_form else ((src_high >> 8) & 0x3F)
            index <- index & 0x3F
            mask: u64 = ge_sse4a_mask(length)
            result: u64 = (dst_low & ~(mask << index)) | ((src_low & mask) << index)
            ge_write_xmm_low_zero_high(mctx, dst, result)
            advance: uintptr = 6.uintptr() if immediate_form else 4.uintptr()
            ge_write_pc(uctx, (!pc + advance).cast[GuestPC])
            ge_sse4a_insertq_handled_count <- ge_sse4a_insertq_handled_count + 1
            ge_sse4a_last_pc <- !pc
            ge_sse4a_last_word <- word
            ge_emergency_mark(GE_EV_SSE4A_INSERTQ_HANDLED, !pc, word.u64().uintptr(), result.uintptr(), ge_sse4a_insertq_handled_count.uintptr())
            return true
        ge_emergency_mark(GE_EV_SSE4A_UNHANDLED, !pc, word.u64().uintptr(), 3.uintptr(), 0.uintptr())
        return false
    static else:
        _ = uctx
        return false

# si_addr lives at a per-OS offset inside siginfo_t (macOS 24, Linux 16).
@reentrant_safe
def ge_siginfo_fault_addr(info: void&?) -> GuestFaultAddress:
    can Memory.Allocate:
        if info == null:
            return 0.uintptr().cast[GuestFaultAddress]
        static if PLATFORM_APPLE:
            return ge_read_context_word(info.uintptr() + 24.uintptr()).cast[GuestFaultAddress]
        static elif PLATFORM_LINUX:
            return ge_read_context_word(info.uintptr() + 16.uintptr()).cast[GuestFaultAddress]
        static else:
            return 0.uintptr().cast[GuestFaultAddress]

# dladdr a code address into symbol + image name; store into the stack-context
# or pc-context globals.
def ge_resolve_pc_symbol(address: uintptr, is_stack: bool) -> void:
    sym: mutable static u8&? = ""
    img: mutable static u8&? = ""
    if address != 0.uintptr():
        info: mutable GeDlInfo = zeroed
        if ge_dladdr(ge_addr_to_ptr(address), (&info).cast[void&]) != 0:
            if info.dli_sname != null:
                sym <- info.dli_sname
            if info.dli_fname != null:
                img <- info.dli_fname
    if is_stack:
        ge_signal_stack_symbol0 <- sym
        ge_signal_stack_image0 <- img
    else:
        ge_signal_pc_symbol <- sym
        ge_signal_pc_image <- img

# Symbolize the recorded fault PC (and the immediate stack-word caller) via dladdr.
# Must be called from HOST context AFTER the guard returns (dladdr is not
# async-signal-safe, so the signal handler only records raw PCs). Names the host
# libsystem function that faulted -- decisive for host-side HLE-call faults.
def GuestExec_ResolveSignalSymbols() -> void:
    ge_resolve_pc_symbol(!ge_last_guest_pc, false)
    ge_resolve_pc_symbol(ge_signal_stack_word0, true)

def ge_install_guards() -> void:
    # Install an alternate signal stack once, so the fault handlers run on a
    # known-good stack even when the guest stack is corrupted or exhausted
    # (shadPS4 installs its access-violation handler with SA_ONSTACK).
    fault_flags: mutable int = ge_sa_siginfo()
    static if PLATFORM_APPLE and ARCH_X86_64:
        if ge_alt_signal_stack_installed == 0:
            ss: mutable GeStackT = zeroed
            ss.ss_sp <- (&ge_alt_signal_stack[0]).cast[void&]
            ss.ss_size <- GE_SIGSTKSZ
            ss.ss_flags <- 0
            if ge_sigaltstack((&ss).cast[void&], null) == 0:
                ge_alt_signal_stack_installed <- 1
        if ge_alt_signal_stack_installed != 0:
            # SA_ONSTACK = 0x0001 on macOS.
            fault_flags <- fault_flags | 0x1
    sa: mutable GeSigaction = zeroed
    static if PLATFORM_APPLE and ARCH_X86_64:
        if !ge_signal_handler_entry_thunk == 0.uintptr():
            ge_signal_handler_entry_thunk <- ge_create_host_fs_entry_thunk_trusted((ge_signal_handler.cast[void&?]).uintptr())
        sa.handler <- ge_addr_to_ptr(!ge_signal_handler_entry_thunk)
    static else:
        sa.handler <- ge_signal_handler.cast[void&?]
    sa.mask <- 0
    sa.flags <- fault_flags
    _ = ge_sigaction(GE_SIG_SEGV, (&sa).cast[void&], (&ge_old_segv).cast[void&])
    _ = ge_sigaction(ge_sig_bus(), (&sa).cast[void&], (&ge_old_bus).cast[void&])
    _ = ge_sigaction(GE_SIG_ILL, (&sa).cast[void&], (&ge_old_ill).cast[void&])
    _ = ge_sigaction(GE_SIG_FPE, (&sa).cast[void&], (&ge_old_fpe).cast[void&])
    _ = ge_sigaction(GE_SIG_TRAP, (&sa).cast[void&], (&ge_old_trap).cast[void&])
    alarm_sa: mutable GeSigaction = zeroed
    static if PLATFORM_APPLE and ARCH_X86_64:
        if ge_pc_sampler_enabled:
            if !ge_pc_sampler_handler_entry_thunk == 0.uintptr():
                ge_pc_sampler_handler_entry_thunk <- ge_create_host_fs_entry_thunk_trusted((ge_pc_sampler_alarm_handler.cast[void&?]).uintptr())
            alarm_sa.handler <- ge_addr_to_ptr(!ge_pc_sampler_handler_entry_thunk)
        else:
            if !ge_alarm_handler_entry_thunk == 0.uintptr():
                ge_alarm_handler_entry_thunk <- ge_create_host_fs_entry_thunk_trusted((ge_alarm_handler.cast[void&?]).uintptr())
            alarm_sa.handler <- ge_addr_to_ptr(!ge_alarm_handler_entry_thunk)
    static else:
        alarm_sa.handler <- (ge_pc_sampler_alarm_handler.cast[void&?]) if ge_pc_sampler_enabled else (ge_alarm_handler.cast[void&?])
    alarm_sa.mask <- 0
    alarm_sa.flags <- 0
    if ge_pc_sampler_enabled:
        alarm_sa.flags <- alarm_sa.flags | ge_sa_siginfo()
    static if PLATFORM_APPLE and ARCH_X86_64:
        if ge_alt_signal_stack_installed != 0:
            alarm_sa.flags <- alarm_sa.flags | 0x1
    _ = ge_sigaction(GE_SIG_ALRM, (&alarm_sa).cast[void&], (&ge_old_alrm).cast[void&])

def ge_restore_guards() -> void:
    _ = ge_sigaction(GE_SIG_SEGV, (&ge_old_segv).cast[void&], null)
    _ = ge_sigaction(ge_sig_bus(), (&ge_old_bus).cast[void&], null)
    _ = ge_sigaction(GE_SIG_ILL, (&ge_old_ill).cast[void&], null)
    _ = ge_sigaction(GE_SIG_FPE, (&ge_old_fpe).cast[void&], null)
    _ = ge_sigaction(GE_SIG_TRAP, (&ge_old_trap).cast[void&], null)
    _ = ge_sigaction(GE_SIG_ALRM, (&ge_old_alrm).cast[void&], null)

@c_abi(c)
@async_entry
@segment_establishing
@reentrant_safe
def ge_alarm_handler(sig: int) -> void:
    ge_emergency_mark(GE_EV_ALARM_FIRED, sig.u64().uintptr(), ge_current_hle_id.u64().uintptr(), ge_current_guest_pc, ge_current_return_pc)
    if ge_emergency_watchdog_failfast:
        ge_timeout_fired <- 1
        ge_last_status <- -3
        ge_last_signal <- sig.s32()
        ge_emergency_dump_raw()
        ge_exit_now(128 + sig)
    ge_raw_breadcrumb("GE:ALRM_ENTER\n", 14)
    static if PLATFORM_APPLE and ARCH_X86_64:
        can Unsafe.SegmentMutation, Segment.Host:
            TLS_RestoreHostFsSelector()
        ge_raw_breadcrumb("GE:ALRM_HOSTFS\n", 15)
        ge_shadow_fs_transition("alarm-handler-host-fs-restored", GE_FS_OWNER_HOST)
        can Unsafe.SegmentMutation, Segment.Host:
            ge_assert_host_fs_owner("alarm-handler-after-host-fs-restore")
    _ = sig
    ge_set_native_phase(GE_PHASE_ALARM_HANDLER_ENTERED)
    ge_timeout_fired <- 1
    ge_last_status <- -3
    ge_last_signal <- GE_SIG_ALRM.s32()
    fr: ElisaGuestExecForkReport&? = ge_fork_report
    if fr != null:
        fr.status <- -3
        fr.signal <- GE_SIG_ALRM.s32()
        fr.fault_thread <- !ge_pthread_self()
        fr.guard_thread <- ge_guard_target_thread
        if fr.execution_stage < 4:
            fr.execution_stage <- 4
    if ge_guard_active != 0:
        current_thread: uintptr = !ge_pthread_self()
        if ge_guard_target_thread == 0.uintptr() or current_thread == ge_guard_target_thread:
            ge_raw_breadcrumb("GE:ALRM_LONGJMP\n", 16)
            ge_mark_guard_longjmp(-3, GE_LONGJMP_SOURCE_ALARM, ge_current_return_pc)
            ge_siglongjmp((&ge_jmp_buf[0]).cast[void&], 1)
        ge_cross_thread_signal_count <- ge_cross_thread_signal_count + 1
        ge_cross_thread_signal_guard_thread <- ge_guard_target_thread
        ge_cross_thread_signal_fault_thread <- current_thread
        ge_cross_thread_signal_number <- GE_SIG_ALRM.s32()
        if fr != null:
            fr.cross_thread_signal_count <- ge_cross_thread_signal_count
            fr.cross_thread_signal_guard_thread <- ge_guard_target_thread
            fr.cross_thread_signal_fault_thread <- current_thread
            fr.cross_thread_signal_number <- GE_SIG_ALRM.s32()
        ge_exit_now(128 + GE_SIG_ALRM)

@c_abi(c)
@async_entry
@segment_establishing
@reentrant_safe
def ge_pc_sampler_alarm_handler(sig: int, info: void&?, uctx: void&?) -> void:
    static if PLATFORM_APPLE and ARCH_X86_64:
        can Unsafe.SegmentMutation, Segment.Host:
            TLS_RestoreHostFsSelector()
        ge_shadow_fs_transition("pc-sampler-alarm-host-fs-restored", GE_FS_OWNER_HOST)
    pc: GuestPC = ge_extract_pc(uctx)
    sp: GuestStackPointer = ge_extract_sp(uctx)
    idx: usize = (ge_pc_sampler_count.u64() & 127).usize()
    ge_pc_sampler_samples[idx] <- pc
    ge_pc_sampler_sps[idx] <- sp
    ge_pc_sampler_last_pc <- pc
    ge_pc_sampler_last_sp <- sp
    ge_last_guest_pc <- pc
    ge_last_guest_sp <- sp
    ge_signal_guest_pc <- pc
    ge_signal_pc_valid <- 1 if !pc != 0.uintptr() else 0
    ge_signal_sp_valid <- 1 if !sp != 0.uintptr() else 0
    ge_last_pc_source <- (GE_PC_SOURCE_SIGNAL_UCONTEXT if ge_signal_pc_valid != 0 else GE_PC_SOURCE_NONE)
    ge_pc_sampler_count <- ge_pc_sampler_count + 1
    ge_emergency_mark(GE_EV_PC_SAMPLE, ge_pc_sampler_count.u64().uintptr(), !pc, !sp, sig.u64().uintptr())
    _ = info
    if ge_pc_sampler_max_samples != 0 and ge_pc_sampler_count >= ge_pc_sampler_max_samples:
        ge_set_native_phase(GE_PHASE_ALARM_HANDLER_ENTERED)
        ge_timeout_fired <- 1
        ge_last_status <- -3
        ge_last_signal <- GE_SIG_ALRM.s32()
        ge_mark_guard_longjmp(-3, GE_LONGJMP_SOURCE_PC_SAMPLER, !pc)
        ge_siglongjmp((&ge_jmp_buf[0]).cast[void&], 1)

# --- Instruction-precise page watchpoint (debug) ---------------------------
# Arming write-protects the page containing the watched address. A guest write
# to that page faults (SEGV/BUS); the handler logs the writer PC if the write
# targets the watched 8 bytes, then unprotects the page and single-steps over
# the write (TF), re-protecting on the resulting SIGTRAP. Single-step is
# confirmed working under Rosetta, so this catches the exact corrupting
# instruction (unlike the polling value-watch).
global mutable ge_pw_page_base: uintptr = 0.uintptr()
global mutable ge_pw_watch_addr: uintptr = 0.uintptr()
global mutable ge_pw_armed: bool = false
global mutable ge_pw_arm_prot: int = 1  # PROT_READ default (traps writes); 0=PROT_NONE traps reads too
global mutable ge_pw_stepping: bool = false
global mutable ge_pw_pending_value_record: bool = false
global mutable ge_pw_hit_count: u64 = 0

def GuestExec_SetPageWatch(addr: uintptr) -> void can[Unsafe.SegmentMutation, Segment.Host]:
    ge_pw_watch_addr <- addr
    ge_pw_page_base <- (addr.u64() & 0xfffffffffffff000).uintptr()
    ge_pw_armed <- addr != 0.uintptr()
    ge_pw_stepping <- false
    ge_pw_hit_count <- 0
    if ge_pw_armed:
        prot_before: u32 = ge_native_prot_at(ge_pw_watch_addr, 8)
        if prot_before == 0xffffffff:
            ge_raw_breadcrumb("GE:PW_ARM_UNMAPPED\n", 19)
        if getenv("ELISA_PAGEWATCH_PROT_NONE".cast[u8&]) != null:
            ge_pw_arm_prot <- 0  # PROT_NONE: trap reads AND writes to the page
        mp: int = ge_mprotect(ge_pw_page_base, 0x1000, ge_pw_arm_prot)
        if mp == 0:
            ge_raw_breadcrumb("GE:PW_ARM_OK\n", 13)
            # Record the arm so triage can report "armed, N writes observed" — crucially
            # distinguishing "never written (uninitialized)" from "watch was never set".
            ge_emergency_mark(GE_EV_WATCH_ARM, ge_pw_watch_addr, ge_pw_page_base, ge_pw_arm_prot.u64().uintptr(), 0.uintptr())
        else:
            ge_raw_breadcrumb("GE:PW_ARM_FAIL\n", 15)

def GuestExec_PageWatchHitCount() -> u64:
    return ge_pw_hit_count

@reentrant_safe
def ge_pw_set_tf(uctx: void&?, on: bool) -> void:
    static if ARCH_X86_64 and PLATFORM_APPLE:
        ss: uintptr = ge_darwin_mcontext64_ss(uctx)
        rf: mutable u64 = ge_read_context_word(ss + 136.uintptr()).u64()
        if on:
            rf <- rf | 0x100
        else:
            rf <- rf & 0xfffffffffffffeff
        ge_write_context_word(ss + 136.uintptr(), rf.uintptr())
    static else:
        _ = uctx
        _ = on

# Handle a fault under the page watchpoint. Returns true if the fault was a
# watchpoint event the handler consumed (caller must then return immediately).
@reentrant_safe
def ge_pw_handle(sig: int, info: void&?, uctx: void&?) -> bool can[Memory.Allocate, Unsafe.SegmentMutation, Segment.Host]:
    if not ge_pw_armed:
        return false
    if sig == GE_SIG_TRAP and ge_pw_stepping:
        # Single-step completed: re-arm the protection and clear TF. If the write
        # targeted the watched slot, record the value that was just stored so the
        # timeline shows real-return vs corrupting-value writes.
        if ge_pw_pending_value_record:
            can Memory.Allocate:
                ge_emergency_mark(GE_EV_WATCH_HIT, ge_pw_watch_addr, ge_read_context_word(ge_pw_watch_addr), ge_pw_hit_count.uintptr(), 0xA10E.uintptr())
            ge_pw_pending_value_record <- false
        _ = ge_mprotect(ge_pw_page_base, 0x1000, ge_pw_arm_prot)
        ge_pw_set_tf(uctx, false)
        ge_pw_stepping <- false
        return true
    if sig == GE_SIG_SEGV or sig == ge_sig_bus():
        fault: mutable uintptr = 0.uintptr()
        can Memory.Allocate:
            fault <- (!ge_siginfo_fault_addr(info))
        if fault.u64() >= ge_pw_page_base.u64() and fault.u64() < (ge_pw_page_base.u64() + 0x1000):
            if fault.u64() >= ge_pw_watch_addr.u64() and fault.u64() < (ge_pw_watch_addr.u64() + 8):
                ge_pw_hit_count <- ge_pw_hit_count + 1
                ge_pw_pending_value_record <- true
                ge_emergency_mark(GE_EV_WATCH_HIT, fault, (!ge_extract_pc(uctx)), ge_pw_hit_count.uintptr(), (!ge_extract_sp(uctx)))
            # Let the write proceed, then single-step to re-protect.
            _ = ge_mprotect(ge_pw_page_base, 0x1000, 3)  # PROT_READ|PROT_WRITE
            ge_pw_set_tf(uctx, true)
            ge_pw_stepping <- true
            return true
    return false

@c_abi(c)
@async_entry
@segment_establishing
@reentrant_safe
def ge_signal_handler(sig: int, info: void&?, uctx: void&?) -> void:
    can Memory.Allocate, Unsafe.SegmentMutation, Segment.Host:
        # Instruction-precise page watchpoint: consume watchpoint write faults and
        # single-step traps first, before any breadcrumb/FS work, so watched writes
        # are not treated as fatal and do not flood the emergency tape.
        if ge_pw_handle(sig, info, uctx):
            return
        ge_raw_breadcrumb("GE:SIGNAL_ENTRY_RAW\n", 20)
        ge_emergency_mark(GE_EV_SIGNAL_ENTRY_RAW, sig.u64().uintptr(), info.uintptr(), uctx.uintptr(), 0.uintptr())
        fr_raw: ElisaGuestExecForkReport&? = ge_fork_report
        if fr_raw != null:
            fr_raw.signal <- sig.s32()
            fr_raw.signal_uctx <- uctx.uintptr() if uctx != null else info.uintptr()
        static if PLATFORM_APPLE and ARCH_X86_64:
            can Unsafe.SegmentMutation, Segment.Host:
                TLS_RestoreHostFsSelector()
            ge_raw_breadcrumb("GE:SIGNAL_AFTER_RESTORE\n", 24)
            ge_emergency_mark(GE_EV_SIGNAL_AFTER_RESTORE, sig.u64().uintptr(), info.uintptr(), uctx.uintptr(), 0.uintptr())
            ge_shadow_fs_transition("signal-handler-host-fs-restored", GE_FS_OWNER_HOST)
            ge_raw_breadcrumb("GE:SIGNAL_AFTER_SHADOW\n", 23)
            ge_emergency_mark(GE_EV_SIGNAL_AFTER_SHADOW, sig.u64().uintptr(), info.uintptr(), uctx.uintptr(), 0.uintptr())
            can Unsafe.SegmentMutation, Segment.Host:
                ge_assert_host_fs_owner("signal-handler-after-host-fs-restore")
            ge_raw_breadcrumb("GE:SIGNAL_AFTER_ASSERT\n", 23)
            ge_emergency_mark(GE_EV_SIGNAL_AFTER_ASSERT, sig.u64().uintptr(), info.uintptr(), uctx.uintptr(), 0.uintptr())
        ge_set_native_phase(GE_PHASE_SIGNAL_HANDLER_ENTERED)
        ge_last_status <- (0 - sig).s32()
        ge_last_signal <- sig.s32()
        if sig == GE_SIG_ILL and ge_try_handle_sse4a_sigill(uctx):
            return
        fault_thread: uintptr = !ge_pthread_self()
        ge_signal_uctx <- ((uctx.uintptr() if uctx != null else info.uintptr()).cast[SignalContextPtr])
        ge_signal_mctx <- ge_extract_mctx(uctx)
        ge_last_fault_address <- ge_siginfo_fault_addr(info)
        ge_signal_fault_addr_valid <- 1 if info != null else 0
        ge_signal_guest_pc <- ge_extract_pc(uctx)
        ge_signal_pc_valid <- 1 if !ge_signal_guest_pc != 0.uintptr() else 0
        ge_fallback_guest_pc <- 0.uintptr().cast[GuestPC]
        ge_last_pc_was_fallback <- 0
        ge_last_pc_source <- (GE_PC_SOURCE_SIGNAL_UCONTEXT if ge_signal_pc_valid != 0 else GE_PC_SOURCE_NONE)
        ge_last_guest_pc <- ge_signal_guest_pc
        ge_last_guest_sp <- ge_extract_sp(uctx)
        ge_last_guest_bp <- ge_extract_bp(uctx)
        ge_last_guest_rdi <- ge_extract_greg(uctx, 0)
        ge_last_guest_rsi <- ge_extract_greg(uctx, 1)
        ge_last_guest_rax <- ge_extract_greg(uctx, 2)
        ge_last_guest_rbx <- ge_extract_greg(uctx, 3)
        ge_last_guest_rdx <- ge_extract_greg(uctx, 4)
        ge_last_guest_rcx <- ge_extract_greg(uctx, 5)
        ge_last_guest_r8 <- ge_extract_greg(uctx, 6)
        ge_last_guest_r9 <- ge_extract_greg(uctx, 7)
        ge_emergency_mark(GE_EV_SIGNAL_GPRS, ge_last_guest_rax, ge_last_guest_rbx, ge_last_guest_rcx, ge_last_guest_rdx)
        ge_emergency_mark(GE_EV_SIGNAL_CALLEE_SAVED, ge_extract_greg(uctx, 8), ge_extract_greg(uctx, 9), ge_extract_greg(uctx, 10), ge_extract_greg(uctx, 11))
        # Raw bytes of the faulting instruction (works for libsystem PCs, which are not
        # in the native-region table) + the live segment selectors, to read off whether
        # the faulting TLS access used %fs (0x64) or %gs (0x65) and what the selectors are.
        static if ARCH_X86_64 and PLATFORM_APPLE:
            fault_pc: uintptr = (!ge_signal_guest_pc)
            ss_seg: uintptr = ge_darwin_mcontext64_ss(uctx)
            ge_emergency_mark(GE_EV_SIGNAL_FAULT_INSN, fault_pc, ge_read_context_word(fault_pc), ge_read_context_word(fault_pc + 8.uintptr()), ge_read_context_word(fault_pc + 16.uintptr()))
            ge_emergency_mark(GE_EV_SIGNAL_FAULT_INSN, fault_pc - 16.uintptr(), ge_read_context_word(fault_pc - 16.uintptr()), ge_read_context_word(fault_pc - 8.uintptr()), ge_last_guest_rdi)
            # Wider preceding window (pc-48 .. pc-16) to find the instruction that loaded
            # the null zone into rdi (e.g. a %gs-relative per-thread default-zone read).
            ge_emergency_mark(GE_EV_SIGNAL_FAULT_INSN, fault_pc - 48.uintptr(), ge_read_context_word(fault_pc - 48.uintptr()), ge_read_context_word(fault_pc - 40.uintptr()), ge_read_context_word(fault_pc - 32.uintptr()))
            ge_emergency_mark(GE_EV_SIGNAL_FAULT_INSN, fault_pc - 24.uintptr(), ge_read_context_word(fault_pc - 24.uintptr()), ge_read_context_word(fault_pc - 16.uintptr()), ge_read_context_word(fault_pc - 8.uintptr()))
            # If fault_pc-16 is `mov rax,[rip+disp32]` (opcode 48 8b 05), resolve the
            # global it loaded and read its value to confirm the null source.
            pre_word: u64 = ge_read_context_word(fault_pc - 16.uintptr()).u64()
            if (pre_word & 0xffffff) == 0x058b48:
                disp32: u64 = (pre_word >> 24) & 0xffffffff
                disp_se: mutable u64 = disp32
                if (disp32 & 0x80000000) != 0:
                    disp_se <- disp32 | 0xffffffff00000000
                global_addr: uintptr = (fault_pc - 16.uintptr() + 7.uintptr()) + disp_se.uintptr()
                ge_emergency_mark(GE_EV_SIGNAL_FAULT_GLOBAL, global_addr, ge_read_context_word(global_addr), pre_word.uintptr(), disp32.uintptr())
            ge_emergency_mark(GE_EV_SIGNAL_SEGMENTS, ge_read_context_word(ss_seg + 152.uintptr()), ge_read_context_word(ss_seg + 160.uintptr()), ge_read_context_word(ss_seg + 144.uintptr()), ss_seg)
        ge_signal_sp_valid <- 1 if !ge_signal_mctx != 0.uintptr() else 0
        ge_signal_bp_valid <- ge_signal_sp_valid
        ge_signal_rdi_valid <- ge_signal_sp_valid
        ge_signal_rsi_valid <- ge_signal_sp_valid
        ge_signal_native_region_index <- ge_find_native_region(!ge_last_guest_pc, 8)
        ge_pc_native_prot <- ge_native_prot_at(!ge_last_guest_pc, 8)
        # Snapshot the native-region table to the tape, keyed by the faulting PC, so a
        # near-null / unmapped-deref fault can be diagnosed against the actual regions.
        ge_dump_native_regions(!ge_last_guest_pc, 8)
        # Re-emit page-watch status at fault time so it survives the ring wrap: the
        # arm event from setup is long gone by now. d = writes observed; 0 writes on an
        # armed slot => the slot was never initialized.
        if ge_pw_watch_addr != 0.uintptr():
            ge_emergency_mark(GE_EV_WATCH_ARM, ge_pw_watch_addr, ge_pw_page_base, ge_pw_arm_prot.u64().uintptr(), ge_pw_hit_count.uintptr())
        ge_fault_word0 <- ge_read_native_word(!ge_last_guest_pc)
        ge_fault_word1 <- ge_read_native_word(!ge_last_guest_pc + 8.uintptr())
        ge_signal_stack_word0 <- ge_read_context_word(!ge_last_guest_sp)
        ge_signal_stack_word1 <- ge_read_context_word(!ge_last_guest_sp + 8.uintptr())
        ge_signal_stack_word_m1 <- 0.uintptr()
        if (!ge_last_guest_sp).u64() >= 8:
            ge_signal_stack_word_m1 <- ge_read_context_word(!ge_last_guest_sp - 8.uintptr())
        ge_fault_transfer_class <- 0
        if !ge_last_guest_pc != 0.uintptr() and (!ge_last_guest_pc).u64() < 4096 and ge_pc_native_prot == 0xffffffff:
            ge_fault_transfer_class <- 1
            if !ge_last_guest_pc == ge_signal_stack_word_m1:
                ge_fault_transfer_class <- 2
            elif !ge_last_guest_pc == ge_signal_stack_word0:
                ge_fault_transfer_class <- 3
            elif !ge_last_guest_pc == ge_signal_stack_word1:
                ge_fault_transfer_class <- 4
        # Symbolization uses dladdr and is not async-signal-safe. The handler records
        # raw PCs/stack words only; host code can symbolize them after the jump/exit.
        ge_signal_stack_symbol0 <- ""
        ge_signal_stack_image0 <- ""
        ge_signal_pc_symbol <- ""
        ge_signal_pc_image <- ""
        fr: ElisaGuestExecForkReport&? = ge_fork_report
        if fr != null:
            fr.status <- ge_last_status
            fr.signal <- sig.s32()
            fr.fault_thread <- fault_thread
            fr.guard_thread <- ge_guard_target_thread
            fr.fault_address <- !ge_last_fault_address
            fr.guest_pc <- !ge_last_guest_pc
            fr.guest_sp <- !ge_last_guest_sp
            fr.guest_bp <- !ge_last_guest_bp
            fr.guest_rdi <- ge_last_guest_rdi
            fr.guest_rsi <- ge_last_guest_rsi
            fr.guest_rdx <- ge_last_guest_rdx
            fr.guest_rcx <- ge_last_guest_rcx
            fr.guest_r8 <- ge_last_guest_r8
            fr.guest_r9 <- ge_last_guest_r9
            fr.guest_rax <- ge_last_guest_rax
            fr.guest_rbx <- ge_last_guest_rbx
            fr.fault_word0 <- ge_fault_word0
            fr.fault_word1 <- ge_fault_word1
            fr.signal_stack_word0 <- ge_signal_stack_word0
            fr.signal_stack_word1 <- ge_signal_stack_word1
            fr.signal_stack_word_m1 <- ge_signal_stack_word_m1
            fr.fault_transfer_class <- ge_fault_transfer_class
            fr.signal_stack_symbol0 <- ge_signal_stack_symbol0
            fr.signal_stack_image0 <- ge_signal_stack_image0
            fr.signal_pc_symbol <- ge_signal_pc_symbol
            fr.signal_pc_image <- ge_signal_pc_image
            fr.signal_guest_pc <- !ge_signal_guest_pc
            fr.fallback_guest_pc <- !ge_fallback_guest_pc
            fr.signal_pc_valid <- ge_signal_pc_valid
            fr.signal_sp_valid <- ge_signal_sp_valid
            fr.signal_bp_valid <- ge_signal_bp_valid
            fr.signal_rdi_valid <- ge_signal_rdi_valid
            fr.signal_rsi_valid <- ge_signal_rsi_valid
            fr.signal_uctx <- !ge_signal_uctx
            fr.signal_mctx <- !ge_signal_mctx
            fr.signal_fault_addr_valid <- ge_signal_fault_addr_valid
            fr.signal_native_region_index <- ge_signal_native_region_index
            fr.pc_source <- ge_last_pc_source
            fr.pc_was_fallback <- ge_last_pc_was_fallback
            fr.pc_native_prot <- ge_pc_native_prot
            if fr.execution_stage < 6:
                fr.execution_stage <- 6
        ge_emergency_mark(GE_EV_SIGNAL_FIRED, sig.u64().uintptr(), (!ge_last_guest_pc), (!ge_last_guest_sp), (!ge_last_fault_address))
        ge_emergency_mark(GE_EV_SIGNAL_STACK_WORDS, ge_signal_stack_word_m1, ge_signal_stack_word0, ge_signal_stack_word1, ge_fault_transfer_class.uintptr())
        # Crash backtrace window: dump 32 stack slots at/above the faulting SP into
        # the tape so a post-run symbolizer can recover the guest call chain. Reads
        # only upward (older, mapped frames) to avoid faulting past the stack top.
        if !ge_last_guest_sp != 0.uintptr():
            # Stop at the stack page top so the window never reads into the unmapped
            # guard page above it (which would fault recursively inside the handler).
            bt_page_end: u64 = ((!ge_last_guest_sp).u64() | 0xfff) + 1
            bt_i: mutable u64 = 0
            can Unsafe.AssumeProgress:
                while bt_i < 32:
                    decreases 32 - bt_i
                    bt_addr: uintptr = !ge_last_guest_sp + (bt_i * 8).uintptr()
                    if bt_addr.u64() + 8 > bt_page_end:
                        bt_i <- 32
                    else:
                        bt_word: uintptr = ge_read_context_word(bt_addr)
                        ge_emergency_mark(GE_EV_STACK_DUMP, bt_i.uintptr(), bt_addr, bt_word, 0.uintptr())
                        bt_target: uintptr = ge_find_hle_thunk_target_from_stack_value(bt_word)
                        if bt_target != 0.uintptr():
                            ge_emergency_mark(GE_EV_SIGNAL_CALL_TARGET, bt_word, bt_target, bt_i.uintptr(), ge_native_prot_at(bt_target, 8).u64().uintptr())
                        bt_i <- bt_i + 1
        return_call_start: mutable uintptr = 0.uintptr()
        return_direct_target: mutable uintptr = 0.uintptr()
        return_callsite_window: mutable uintptr = 0.uintptr()
        if ge_signal_stack_word0.u64() >= 8:
            return_callsite_window <- ge_read_native_word(ge_signal_stack_word0 - 8.uintptr())
            if ge_signal_stack_word0.u64() >= 5 and ge_read_native_u8(ge_signal_stack_word0 - 5.uintptr()) == 0xe8.u8():
                return_call_start <- ge_signal_stack_word0 - 5.uintptr()
                rel32: u32 = ge_read_native_u32(ge_signal_stack_word0 - 4.uintptr())
                return_direct_target <- ge_signal_stack_word0 + ge_sign_extend_u32_to_u64(rel32).uintptr()
        ge_emergency_mark(GE_EV_SIGNAL_RETURN_CALLSITE, ge_signal_stack_word0, return_call_start, return_direct_target, return_callsite_window)
        ge_emergency_mark(GE_EV_SIGNAL_CALL_TARGET, return_direct_target, ge_read_native_word(return_direct_target), ge_read_native_word(return_direct_target + 8.uintptr()), ge_native_prot_at(return_direct_target, 8).u64().uintptr())
        if ge_guard_active != 0:
            if ge_guard_target_thread == 0.uintptr() or fault_thread == ge_guard_target_thread:
                ge_mark_guard_longjmp(ge_last_status, GE_LONGJMP_SOURCE_SIGNAL, !ge_last_guest_pc)
                ge_siglongjmp((&ge_jmp_buf[0]).cast[void&], 1)
            ge_cross_thread_signal_count <- ge_cross_thread_signal_count + 1
            ge_cross_thread_signal_guard_thread <- ge_guard_target_thread
            ge_cross_thread_signal_fault_thread <- fault_thread
            ge_cross_thread_signal_number <- sig.s32()
            if fr != null:
                fr.cross_thread_signal_count <- ge_cross_thread_signal_count
                fr.cross_thread_signal_guard_thread <- ge_guard_target_thread
                fr.cross_thread_signal_fault_thread <- fault_thread
                fr.cross_thread_signal_number <- sig.s32()
            if sig > 0 and sig < 128:
                ge_exit_now(128 + sig)
            ge_exit_now(1)

# ---- Orchestration plumbing (atomic core, part 2a; inert until swap) ----
extern __sigsetjmp(env: void&?, savemask: int) -> int
def ge_sigsetjmp(env: void&?, savemask: int) -> int:
    return __sigsetjmp(env, savemask)
@reentrant_safe
extern pthread_self() -> void&?
@link_name(_exit)
@reentrant_safe
extern ge_exit_now(code: int) -> void
@link_name(pause)
extern ge_pause() -> int
extern memset(dest: mutable void&, value: int, n: usize) -> mutable void&
extern ElisaGuestExec_CurrentStackPointerAsm() -> HostStackPointer
extern ElisaGuestExec_LoadOrbisFpStateAsm(mxcsr: HostPtr[u32], fpucw: HostPtr[u16]) -> void
extern ElisaGuestExec_EnterMainEntryAsm(params: HostPtr[GuestEntryParams], exit_func: ExitFunction) -> void
extern ElisaGuestExec_CallMainEntryAsm(entry: GuestEntryPoint, params: HostPtr[GuestEntryParams], exit_func: ExitFunction) -> void
extern ElisaGuestExec_JumpMainEntryAsm(entry: GuestEntryPoint, params: HostPtr[GuestEntryParams], exit_func: ExitFunction) -> void
extern ElisaGuestExec_JumpMainEntryOnStackAsm(entry: GuestEntryPoint, params: HostPtr[GuestEntryParams], exit_func: ExitFunction, stack_top: GuestStackTop) -> void
@segment_transition(guest)
extern ElisaGuestExec_JumpMainEntryWithFsAsm(entry: GuestEntryPoint, params: HostPtr[GuestEntryParams], exit_func: ExitFunction, guest_fs_selector: GuestFsSelector) -> void can[Unsafe.SegmentMutation, Segment.Guest]
@segment_transition(guest)
extern ElisaGuestExec_JumpMainEntryOnStackWithFsAsm(entry: GuestEntryPoint, params: HostPtr[GuestEntryParams], exit_func: ExitFunction, stack_top: GuestStackTop, guest_fs_selector: GuestFsSelector) -> void can[Unsafe.SegmentMutation, Segment.Guest]
extern ElisaGuestExec_AeroLibFallbackUnknownStubAsm() -> u64

global mutable ge_fork_report_addr: uintptr = 0.uintptr()
global mutable ge_guard_target_thread: uintptr = 0.uintptr()

@reentrant_safe
def ge_pthread_self() -> HostThreadId:
    return pthread_self().uintptr().cast[HostThreadId]

def ge_memset(dst: void&?, value: int, n: usize) -> void&?:
    if dst == null:
        return dst
    can Memory.Allocate:
        _ = memset(dst.cast[mutable void&], value, n)
    return dst

def ge_record_fallback_pc(pc: uintptr, source: s32) -> void:
    if pc == 0.uintptr():
        return
    ge_fallback_guest_pc <- pc.cast[GuestPC]
    ge_last_guest_pc <- pc.cast[GuestPC]
    ge_last_pc_was_fallback <- 1
    ge_last_pc_source <- source
    fr: ElisaGuestExecForkReport&? = ge_fork_report
    if fr != null:
        fr.fallback_guest_pc <- pc
        fr.guest_pc <- pc
        fr.pc_source <- source
        fr.pc_was_fallback <- 1

def ge_current_stack_pointer() -> HostStackPointer:
    static if ARCH_X86_64 and not PLATFORM_WINDOWS:
        return ElisaGuestExec_CurrentStackPointerAsm()
    static else:
        return 0.uintptr().cast[HostStackPointer]

def ge_map_shared_anon_flags() -> int:
    static if PLATFORM_APPLE:
        return 0x0001 | 0x1000
    static else:
        return 0x0001 | 0x20

def ge_reset_fork_report() -> void:
    can Memory.Allocate:
        if ge_fork_report != null:
            _ = ge_memset(ge_addr_to_ptr(ge_fork_report_addr), 0, 4096)

def ge_ensure_fork_report() -> s32:
    can Memory.Allocate:
        static if PLATFORM_WINDOWS:
            return 0
        static else:
            if ge_fork_report != null:
                ge_reset_fork_report()
                return 0
            mapped: uintptr = mmap(0.uintptr(), 4096, 3, ge_map_shared_anon_flags(), -1, 0)
            if mapped == ge_map_failed():
                ge_fork_report <- null
                ge_fork_report_addr <- 0.uintptr()
                return -1
            ge_fork_report_addr <- mapped
            trusted [Unsafe.PointerCast, Unsafe.StaleRef]:
                ge_fork_report <- mapped.cast[ElisaGuestExecForkReport&?]
            ge_reset_fork_report()
            return 0

@c_abi(c)
def ge_default_exit(code: int) -> void:
    _ = code
    while true:
        can Unsafe.NonProgress:
            _ = ge_pause()

@c_abi(c)
def ge_guarded_exit(code: int) -> void:
    _ = code
    ge_last_status <- 0
    fr: ElisaGuestExecForkReport&? = ge_fork_report
    if fr != null:
        if fr.execution_stage < 4:
            fr.execution_stage <- 4

def ge_call_main_entry(params: mutable GuestEntryParams&, exit_func: uintptr) -> void:
    ef: mutable uintptr = exit_func
    if ef == 0.uintptr():
        ef <- ge_default_exit.cast[uintptr]
    static if ARCH_X86_64:
        ElisaGuestExec_LoadOrbisFpStateAsm((&ge_orbis_mxcsr).cast[u32&].uintptr().cast[HostPtr[u32]], (&ge_orbis_fpucw).cast[u16&].uintptr().cast[HostPtr[u16]])
    ElisaGuestExec_CallMainEntryAsm(params.entry_addr.cast[GuestEntryPoint], (&params).cast[void&].uintptr().cast[HostPtr[GuestEntryParams]], ef.cast[ExitFunction])

def ge_jump_main_entry(params: mutable GuestEntryParams&, exit_func: uintptr) -> void can[Unsafe.SegmentMutation, Segment.Host, Segment.Guest]:
    ef: mutable uintptr = exit_func
    if ef == 0.uintptr():
        ef <- ge_default_exit.cast[uintptr]
    ge_prejump_rdi <- (&params).cast[void&].uintptr()
    ge_prejump_rsp <- (&params).cast[void&].uintptr()
    fr: ElisaGuestExecForkReport&? = ge_fork_report
    if fr != null:
        fr.prejump_rdi <- ge_prejump_rdi
        fr.prejump_rsp <- ge_prejump_rsp
    static if PLATFORM_APPLE and ARCH_X86_64:
        guarded_exit_addr: uintptr = ge_guarded_exit.cast[uintptr]
        if ef == guarded_exit_addr:
            ef <- !ge_create_host_fs_entry_thunk_trusted(ef)
    guest_fs_selector: mutable GuestFsSelector = 0.u32().cast[GuestFsSelector]
    static if PLATFORM_APPLE and ARCH_X86_64:
        guest_fs_selector <- TLS_PrepareTcbBase((!TLS_PrimaryTcbBase()).cast[void&?])
    ge_prejump_rsi <- ef
    if fr != null:
        fr.prejump_rsi <- ge_prejump_rsi
    static if ARCH_X86_64:
        ElisaGuestExec_LoadOrbisFpStateAsm((&ge_orbis_mxcsr).cast[u32&].uintptr().cast[HostPtr[u32]], (&ge_orbis_fpucw).cast[u16&].uintptr().cast[HostPtr[u16]])
    can Unsafe.SegmentMutation, Segment.Host:
        ge_observe_fs_owner("pre-main-host-before-easm", false)
    static if PLATFORM_APPLE and ARCH_X86_64:
        if !guest_fs_selector != 0:
            if guest_exec_main_stack_top != 0.uintptr():
                ge_shadow_fs_transition("pre-main-easm-transition-to-guest", GE_FS_OWNER_GUEST)
                can Unsafe.SegmentMutation, Segment.Guest:
                    ElisaGuestExec_JumpMainEntryOnStackWithFsAsm(params.entry_addr.cast[GuestEntryPoint], ge_prejump_rdi.cast[HostPtr[GuestEntryParams]], ef.cast[ExitFunction], guest_exec_main_stack_top.cast[GuestStackTop], guest_fs_selector)
            ge_shadow_fs_transition("pre-main-easm-transition-to-guest", GE_FS_OWNER_GUEST)
            can Unsafe.SegmentMutation, Segment.Guest:
                ElisaGuestExec_JumpMainEntryWithFsAsm(params.entry_addr.cast[GuestEntryPoint], ge_prejump_rdi.cast[HostPtr[GuestEntryParams]], ef.cast[ExitFunction], guest_fs_selector)
    if guest_exec_main_stack_top != 0.uintptr():
        ElisaGuestExec_JumpMainEntryOnStackAsm(params.entry_addr.cast[GuestEntryPoint], ge_prejump_rdi.cast[HostPtr[GuestEntryParams]], ef.cast[ExitFunction], guest_exec_main_stack_top.cast[GuestStackTop])
    ElisaGuestExec_JumpMainEntryAsm(params.entry_addr.cast[GuestEntryPoint], ge_prejump_rdi.cast[HostPtr[GuestEntryParams]], ef.cast[ExitFunction])

def ge_absorb_fork_report() -> void:
    fr: ElisaGuestExecForkReport&? = ge_fork_report
    if fr == null:
        return
    if fr.status == 0 and fr.signal == 0 and fr.execution_stage >= 4:
        fr.status <- -11
        if fr.guest_pc == 0.uintptr() and fr.signal_pc_valid == 0:
            ge_record_fallback_pc(fr.entry_addr, GE_PC_SOURCE_FALLBACK_PARENT_SILENT_CHILD)
    if fr.status < 0 and fr.guest_pc == 0.uintptr() and fr.signal_pc_valid == 0 and fr.entry_addr != 0.uintptr():
        ge_record_fallback_pc(fr.entry_addr, GE_PC_SOURCE_FALLBACK_PARENT_STATUS)
    if fr.status != 0:
        ge_last_status <- fr.status
    if fr.signal != 0:
        ge_last_signal <- fr.signal
    if fr.fault_address != 0.uintptr() or fr.status < 0:
        ge_last_fault_address <- fr.fault_address.cast[GuestFaultAddress]
    if fr.guest_pc != 0.uintptr():
        ge_last_guest_pc <- fr.guest_pc.cast[GuestPC]
