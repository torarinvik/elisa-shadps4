# ---- Synthetic test fixtures (@c_abi(c), address-taken; atomic core 2b) ----
@c_abi(c)
def ge_synthetic_crash(arg0: u64, arg1: u64) -> u64:
    _ = arg0
    _ = arg1
    out: mutable u64 = 0u64
    trusted Unsafe.PointerCast:
        r: u64& = 0.uintptr().cast[u64&]
        out <- r
    return out

@c_abi(c)
def ge_synthetic_add(arg0: u64, arg1: u64) -> u64:
    return arg0 + arg1 + 0x1234u64

@c_abi(c)
def ge_synthetic_spin(arg0: u64, arg1: u64) -> u64:
    sink: mutable u64 = arg0 ^ arg1
    while true:
        sink <- sink + 1u64
    return sink

@c_abi(c)
def ge_synthetic_main_return(params: GuestEntryParams&?, exit_func: void&?) -> void:
    ge_synthetic_observed_stack <- ge_current_stack_pointer()
    ge_synthetic_observed_params <- params.uintptr()
    ge_synthetic_observed_exit_func <- exit_func.uintptr()
    if params != null:
        ge_synthetic_observed_argc <- params.argc
        ge_synthetic_observed_argv0 <- params.argv[0].uintptr()
        ge_synthetic_observed_entry <- params.entry_addr
    if params == null or params.argc != 77:
        ge_last_status <- -4
        return
    ge_last_status <- 1

@c_abi(c)
def ge_synthetic_boundary_callback(reason: u64) -> void:
    ge_boundary_callback_count <- ge_boundary_callback_count + 1
    ge_boundary_callback_reason <- reason
    ge_last_status <- 2

@c_abi(c)
def ge_synthetic_main_call_boundary(params: GuestEntryParams&?, exit_func: void&?) -> void:
    _ = exit_func
    if params == null or params.argc != 88 or params.argv[0] == null:
        ge_last_status <- -5
        return
    static if ARCH_X86_64 and not PLATFORM_WINDOWS:
        boundary: func(u64) -> void = params.argv[0].uintptr() as func(u64) -> void
        boundary(0xB000000000000042u64)
    static else:
        _ = params

@c_abi(c)
def ge_non_synthetic_main_report_boundary(params: GuestEntryParams&?, exit_func: void&?) -> void:
    _ = params
    _ = exit_func
    ge_report_first_boundary(1)

@c_abi(c)
def ge_synthetic_hle_boundary_probe() -> u64:
    GuestExec_RecordFirstBoundary(GUEST_EXEC_BOUNDARY_REASON_NATIVE_HLE)
    GuestExec_RecordRuntimeHle("synthetic", "synthetic_hle_boundary_probe", 0.uintptr(), 0.uintptr(), 0.uintptr(), 0xB10C.u64().uintptr())
    return 0xB10Cu64

def ge_is_synthetic_main_entry(entry_addr: uintptr) -> bool:
    return entry_addr == (ge_synthetic_main_return as uintptr) or entry_addr == (ge_synthetic_main_call_boundary as uintptr)

# ---- AeroLib fallback stub recorder ----
# NOTE: the fully-attributing guest-reachable stub (which captures
# __builtin_return_address and tail-calls this recorder) is deferred — it needs
# an EASM function that calls back into Elisa. The plain fallback stub below
# still must be a real nonzero callable address: shadPS4 patches unresolved
# AeroLib imports to a concrete stub function, and R_X86_64_64 relocations may
# carry addends. Returning 0 here leaves tiny addend-only addresses in guest
# memory, which turns unresolved imports into bogus low pointers.
def ge_read_byte(addr: uintptr) -> u8:
    out: mutable u8 = 0u8
    _ = ge_memcpy(out.ref[void&], ge_addr_to_ptr(addr), 1usize)
    return out

def ge_read_disp32(addr: uintptr) -> s32:
    out: mutable u32 = 0u32
    _ = ge_memcpy(out.ref[void&], ge_addr_to_ptr(addr), 4usize)
    return out.s32()

@c_abi(c)
def ge_aerolib_fallback_record(caller_pc: uintptr) -> u64:
    fr: ElisaGuestExecForkReport&? = ge_fork_report
    if fr != null:
        fr.aerolib_fallback_invocations <- fr.aerolib_fallback_invocations + 1u64
        if fr.aerolib_fallback_caller_pc == 0.uintptr() and caller_pc != 0.uintptr():
            fr.aerolib_fallback_caller_pc <- caller_pc
            raw: mutable u64 = 0u64
            i: mutable int = 1
            while i <= 8:
                raw <- (raw << 8u64) | ge_read_byte(caller_pc - i.uintptr()).u64()
                i <- i + 1
            fr.aerolib_fallback_callsite_bytes <- raw
            slot_va: mutable uintptr = 0.uintptr()
            b6: u8 = ge_read_byte(caller_pc - 6.uintptr())
            b5: u8 = ge_read_byte(caller_pc - 5.uintptr())
            if b6 == 0xFFu8 and b5 == 0x15u8:
                disp: s32 = ge_read_disp32(caller_pc - 4.uintptr())
                slot_va <- (caller_pc.i64() + disp.i64()).uintptr()
            elif b5 == 0xE8u8:
                rel: s32 = ge_read_disp32(caller_pc - 4.uintptr())
                plt: uintptr = (caller_pc.i64() + rel.i64()).uintptr()
                fr.aerolib_fallback_plt_va <- plt
                pltraw: mutable u64 = 0u64
                j: mutable int = 7
                while j >= 0:
                    pltraw <- (pltraw << 8u64) | ge_read_byte(plt + j.uintptr()).u64()
                    j <- j - 1
                fr.aerolib_fallback_plt_bytes <- pltraw
                q0: u8 = ge_read_byte(plt)
                q1: u8 = ge_read_byte(plt + 1.uintptr())
                if q0 == 0xFFu8 and q1 == 0x25u8:
                    disp2: s32 = ge_read_disp32(plt + 2.uintptr())
                    slot_va <- (plt.i64() + 6i64 + disp2.i64()).uintptr()
            fr.aerolib_fallback_slot_va <- slot_va
    ge_report_first_boundary(2)
    return 0u64

def ge_aerolib_fallback_stub_address() -> uintptr:
    static if ARCH_X86_64:
        return ElisaGuestExec_AeroLibFallbackUnknownStubAsm as uintptr
    static else:
        return 0.uintptr()

# ---- Synthetic-fixture address getters (atomic core 2b) ----
def ge_get_synthetic_add_address() -> uintptr:
    return ge_synthetic_add as uintptr

def ge_get_synthetic_crash_address() -> uintptr:
    return ge_synthetic_crash as uintptr

def ge_get_synthetic_spin_address() -> uintptr:
    return ge_synthetic_spin as uintptr

def ge_get_synthetic_main_return_address() -> uintptr:
    return ge_synthetic_main_return as uintptr

def ge_get_synthetic_main_call_boundary_address() -> uintptr:
    return ge_synthetic_main_call_boundary as uintptr

def ge_get_synthetic_boundary_callback_address() -> uintptr:
    return ge_synthetic_boundary_callback as uintptr

def ge_get_non_synthetic_main_report_boundary_address() -> uintptr:
    return ge_non_synthetic_main_report_boundary as uintptr

def ge_get_synthetic_hle_boundary_probe_address() -> uintptr:
    return ge_synthetic_hle_boundary_probe as uintptr

# ---- Run orchestration + crash getters (atomic core, part 2c; inert) ----
@link_name(fork)
extern ge_fork() -> int
@link_name(waitpid)
extern ge_waitpid(pid: int, status: mutable int&, options: int) -> int
@link_name(kill)
extern ge_kill(pid: int, sig: int) -> int
@link_name(usleep)
extern ge_usleep(usec: u32) -> int
@link_name(setitimer)
extern ge_setitimer(which: int, value: void&?, old: void&?) -> int

@fixed_layout
struct GeTimeval:
    tv_sec: mutable i64
    tv_usec: mutable i32
    tv_pad: mutable i32
@fixed_layout
struct GeItimerval:
    interval: mutable GeTimeval
    value: mutable GeTimeval

const GE_WNOHANG: int = 1
const GE_ITIMER_REAL: int = 0
const GE_SENTINEL_MAX: u64 = 0xFFFFFFFFFFFFFFFFu64

def ge_wif_signaled(status: int) -> bool:
    low: int = status & 0x7f
    return low != 0 and low != 0x7f
def ge_wtermsig(status: int) -> int:
    return status & 0x7f
def ge_wif_exited(status: int) -> bool:
    return (status & 0x7f) == 0
def ge_wexitstatus(status: int) -> int:
    return (status >> 8) & 0xff
def ge_wif_stopped(status: int) -> bool:
    return (status & 0xff) == 0x7f

def ge_arm_timer(timeout_ms: u32) -> void:
    if timeout_ms != 0u32:
        timer: mutable GeItimerval = zeroed
        timer.value.tv_sec <- (timeout_ms / 1000u32).i64()
        timer.value.tv_usec <- ((timeout_ms % 1000u32) * 1000u32).i32()
        _ = ge_setitimer(GE_ITIMER_REAL, timer.ref[void&], null)

def ge_disarm_timer() -> void:
    timer_off: mutable GeItimerval = zeroed
    _ = ge_setitimer(GE_ITIMER_REAL, timer_off.ref[void&], null)

def ge_run_synthetic_function(entry_addr: uintptr, arg0: u64, arg1: u64) -> u64:
    ge_debug_trace_boundary("guest-exec-synthetic-entry", entry_addr, arg0.uintptr(), arg1.uintptr())
    if entry_addr == 0.uintptr():
        ge_last_status <- -1
        ge_debug_trace_boundary("guest-exec-synthetic-stop", entry_addr, GE_SENTINEL_MAX.uintptr(), 0.uintptr())
        return GE_SENTINEL_MAX
    static if ARCH_X86_64 and not PLATFORM_WINDOWS:
        if not ge_debug_guard_callable_target(entry_addr, 1u64):
            ge_debug_trace_boundary("guest-exec-synthetic-stop", entry_addr, (GE_SENTINEL_MAX - 5u64).uintptr(), ge_debug_trap_reason.uintptr())
            return GE_SENTINEL_MAX - 5u64
        if not ge_check_entry_published(entry_addr):
            ge_debug_trace_boundary("guest-exec-synthetic-stop", entry_addr, (GE_SENTINEL_MAX - 4u64).uintptr(), GE_DEBUG_TRAP_UNPUBLISHED_EXEC_STATUS.u64().uintptr())
            return GE_SENTINEL_MAX - 4u64
        ge_reset_crash_state()
        ge_install_guards()
        ge_guard_active <- 1
        ge_guard_target_thread <- ge_pthread_self()
        if ge_sigsetjmp(ge_jmp_buf[0usize].ref[void&], 1) != 0:
            ge_guard_active <- 0
            ge_restore_guards()
            ge_debug_trace_boundary("guest-exec-synthetic-stop", entry_addr, (GE_SENTINEL_MAX - 2u64).uintptr(), ge_last_status.u64().uintptr())
            return GE_SENTINEL_MAX - 2u64
        fn: func(u64, u64) -> u64 = entry_addr as func(u64, u64) -> u64
        result: u64 = fn(arg0, arg1)
        ge_guard_active <- 0
        ge_restore_guards()
        ge_last_status <- 1
        ge_debug_trace_boundary("guest-exec-synthetic-result", entry_addr, result.uintptr(), ge_last_status.u64().uintptr())
        return result
    static else:
        _ = arg0
        _ = arg1
        ge_last_status <- -2
        ge_debug_trace_boundary("guest-exec-synthetic-stop", entry_addr, (GE_SENTINEL_MAX - 1u64).uintptr(), ge_last_status.u64().uintptr())
        return GE_SENTINEL_MAX - 1u64

def ge_run_synthetic_function_with_timeout(entry_addr: uintptr, arg0: u64, arg1: u64, timeout_ms: u32) -> u64:
    ge_debug_trace_boundary("guest-exec-synthetic-timeout-entry", entry_addr, arg0.uintptr(), arg1.uintptr())
    if entry_addr == 0.uintptr():
        ge_last_status <- -1
        ge_debug_trace_boundary("guest-exec-synthetic-timeout-stop", entry_addr, GE_SENTINEL_MAX.uintptr(), 0.uintptr())
        return GE_SENTINEL_MAX
    static if ARCH_X86_64 and not PLATFORM_WINDOWS:
        if not ge_debug_guard_callable_target(entry_addr, 1u64):
            ge_debug_trace_boundary("guest-exec-synthetic-timeout-stop", entry_addr, (GE_SENTINEL_MAX - 5u64).uintptr(), ge_debug_trap_reason.uintptr())
            return GE_SENTINEL_MAX - 5u64
        if not ge_check_entry_published(entry_addr):
            ge_debug_trace_boundary("guest-exec-synthetic-timeout-stop", entry_addr, (GE_SENTINEL_MAX - 4u64).uintptr(), GE_DEBUG_TRAP_UNPUBLISHED_EXEC_STATUS.u64().uintptr())
            return GE_SENTINEL_MAX - 4u64
        ge_reset_crash_state()
        ge_install_guards()
        ge_guard_active <- 1
        ge_guard_target_thread <- ge_pthread_self()
        ge_arm_timer(timeout_ms)
        if ge_sigsetjmp(ge_jmp_buf[0usize].ref[void&], 1) != 0:
            ge_disarm_timer()
            ge_guard_active <- 0
            ge_restore_guards()
            if ge_timeout_fired != 0:
                ge_last_status <- -3
                ge_debug_trace_boundary("guest-exec-synthetic-timeout-stop", entry_addr, (GE_SENTINEL_MAX - 3u64).uintptr(), ge_last_status.u64().uintptr())
                return GE_SENTINEL_MAX - 3u64
            ge_debug_trace_boundary("guest-exec-synthetic-timeout-stop", entry_addr, (GE_SENTINEL_MAX - 2u64).uintptr(), ge_last_status.u64().uintptr())
            return GE_SENTINEL_MAX - 2u64
        fn: func(u64, u64) -> u64 = entry_addr as func(u64, u64) -> u64
        result: u64 = fn(arg0, arg1)
        ge_disarm_timer()
        ge_guard_active <- 0
        ge_restore_guards()
        ge_last_status <- 1
        ge_debug_trace_boundary("guest-exec-synthetic-timeout-result", entry_addr, result.uintptr(), ge_last_status.u64().uintptr())
        return result
    static else:
        _ = arg0
        _ = arg1
        _ = timeout_ms
        ge_last_status <- -2
        ge_debug_trace_boundary("guest-exec-synthetic-timeout-stop", entry_addr, (GE_SENTINEL_MAX - 1u64).uintptr(), ge_last_status.u64().uintptr())
        return GE_SENTINEL_MAX - 1u64

def ge_run_main_entry(params: mutable GuestEntryParams&, exit_func: void&?) -> void:
    static if ARCH_X86_64 and not PLATFORM_WINDOWS:
        ef: mutable uintptr = exit_func.uintptr()
        if ef == 0.uintptr():
            ef <- ge_default_exit as uintptr
        ElisaGuestExec_EnterMainEntryAsm(params.ref[void&].uintptr(), ef)
    static else:
        _ = params
        _ = exit_func

def ge_prepare_main_entry_snapshot(params: mutable GuestEntryParams&) -> void:
    ge_expected_entry_params <- params.ref[void&].uintptr()
    ge_expected_stack_word0 <- params.argc.u32().uintptr()
    ge_expected_stack_word1 <- params.argv[0].uintptr()
    ge_entry_stack_word0 <- ge_expected_stack_word0
    ge_entry_stack_word1 <- ge_expected_stack_word1
    ge_entry_native_word0 <- ge_read_native_word(params.entry_addr)
    ge_entry_native_word1 <- ge_read_native_word(params.entry_addr + 8.uintptr())
    ge_entry_native_prot <- ge_native_prot_at(params.entry_addr, 8u64)
    fr: ElisaGuestExecForkReport&? = ge_fork_report
    if fr != null:
        fr.expected_entry_params <- ge_expected_entry_params
        fr.expected_stack_word0 <- ge_expected_stack_word0
        fr.expected_stack_word1 <- ge_expected_stack_word1
        fr.entry_stack_word0 <- ge_entry_stack_word0
        fr.entry_stack_word1 <- ge_entry_stack_word1
        fr.entry_native_word0 <- ge_entry_native_word0
        fr.entry_native_word1 <- ge_entry_native_word1
        fr.entry_native_prot <- ge_entry_native_prot

def ge_run_main_entry_guarded_in_process(params: mutable GuestEntryParams&, timeout_ms: u32) -> s32:
    ge_set_native_phase(GE_PHASE_FUNCTION_ENTRY)
    if params.entry_addr == 0.uintptr():
        ge_reset_crash_state()
        ge_set_native_phase(GE_PHASE_RETURN_BAD_PARAMS)
        ge_last_status <- -1
        return -1
    static if ARCH_X86_64 and not PLATFORM_WINDOWS:
        ge_reset_crash_state()
        ge_set_native_phase(GE_PHASE_AFTER_RESET)
        ge_prepare_main_entry_snapshot(params)
        ge_install_guards()
        ge_guard_active <- 1
        ge_guard_target_thread <- ge_pthread_self()
        ge_arm_timer(timeout_ms)
        ge_set_native_phase(GE_PHASE_SYNTHETIC_BEFORE_SIGSETJMP)
        if ge_sigsetjmp(ge_jmp_buf[0usize].ref[void&], 1) != 0:
            ge_disarm_timer()
            ge_guard_active <- 0
            ge_restore_guards()
            if ge_timeout_fired != 0:
                ge_last_status <- -3
            if ge_last_status == 0:
                ge_last_status <- -11
            return ge_last_status
        ge_set_native_phase(GE_PHASE_CHILD_BEFORE_MAIN_ENTRY)
        ge_jump_main_entry(params, ge_guarded_exit as uintptr)
        ge_disarm_timer()
        ge_guard_active <- 0
        ge_restore_guards()
        if ge_last_status == 0:
            ge_last_status <- 1
        return ge_last_status
    static else:
        _ = timeout_ms
        ge_reset_crash_state()
        ge_set_native_phase(GE_PHASE_UNSUPPORTED_RETURN)
        ge_last_status <- -2
        return -2

def ge_run_main_entry_guarded(params: mutable GuestEntryParams&, timeout_ms: u32) -> s32:
    ge_set_native_phase(GE_PHASE_FUNCTION_ENTRY)
    if params.entry_addr == 0.uintptr():
        ge_reset_crash_state()
        ge_set_native_phase(GE_PHASE_RETURN_BAD_PARAMS)
        ge_last_status <- -1
        return -1
    static if ARCH_X86_64 and not PLATFORM_WINDOWS:
        ge_reset_crash_state()
        ge_set_native_phase(GE_PHASE_AFTER_RESET)
        ge_last_errno <- -100
        if ge_is_synthetic_main_entry(params.entry_addr):
            ge_set_native_phase(GE_PHASE_SYNTHETIC_ENTRY)
            ge_install_guards()
            ge_guard_active <- 1
            ge_guard_target_thread <- ge_pthread_self()
            ge_arm_timer(timeout_ms)
            ge_set_native_phase(GE_PHASE_SYNTHETIC_BEFORE_SIGSETJMP)
            if ge_sigsetjmp(ge_jmp_buf[0usize].ref[void&], 1) != 0:
                ge_disarm_timer()
                ge_guard_active <- 0
                ge_restore_guards()
                if ge_timeout_fired != 0:
                    ge_last_status <- -3
                return ge_last_status
            ge_set_native_phase(GE_PHASE_SYNTHETIC_BEFORE_MAIN_ENTRY)
            ge_call_main_entry(params, ge_guarded_exit as uintptr)
            ge_disarm_timer()
            ge_guard_active <- 0
            ge_restore_guards()
            ge_last_status <- 1
            return 1
        ge_set_native_phase(GE_PHASE_BEFORE_FORK_REPORT_SETUP)
        if ge_ensure_fork_report() != 0:
            ge_set_native_phase(GE_PHASE_RETURN_FORK_REPORT_SETUP_FAILED)
            ge_last_errno <- -101
            ge_last_status <- -1
            return -1
        ge_set_native_phase(GE_PHASE_AFTER_FORK_REPORT_SETUP)
        ge_last_errno <- -102
        ge_set_native_phase(GE_PHASE_BEFORE_FORK)
        child: int = ge_fork()
        if child < 0:
            ge_set_native_phase(GE_PHASE_RETURN_FORK_FAILED)
            ge_last_errno <- -103
            ge_last_status <- -1
            return -1
        if child == 0:
            ge_run_child_main_entry(params)
        ge_set_native_phase(GE_PHASE_PARENT_BRANCH_ENTERED)
        waited_ms: mutable u32 = 0u32
        status: mutable int = 0
        while true:
            result: int = ge_waitpid(child, status.ref[mutable int&], GE_WNOHANG)
            if result == child:
                ge_set_native_phase(GE_PHASE_PARENT_WAITPID_CHILD)
                ge_last_errno <- -104
                if ge_wif_signaled(status):
                    ge_set_native_phase(GE_PHASE_PARENT_WIFSIGNALED)
                    sig: int = ge_wtermsig(status)
                    fr: ElisaGuestExecForkReport&? = ge_fork_report
                    if fr != null:
                        if fr.status == 0:
                            fr.status <- (0 - sig).s32()
                        if fr.signal == 0:
                            fr.signal <- sig.s32()
                    ge_absorb_fork_report()
                    if ge_last_status == 0:
                        ge_last_status <- (0 - sig).s32()
                    if ge_last_signal == 0:
                        ge_last_signal <- sig.s32()
                    return ge_last_status
                if ge_wif_exited(status):
                    ge_set_native_phase(GE_PHASE_PARENT_WIFEXITED)
                    code: int = ge_wexitstatus(status)
                    fr2: ElisaGuestExecForkReport&? = ge_fork_report
                    if fr2 != null:
                        if fr2.status == 0:
                            fr2.status <- (-11 if code == 0 else ((0 - (code - 128)) if code >= 128 else (0 - code))).s32()
                        if code >= 128 and fr2.signal == 0:
                            fr2.signal <- (code - 128).s32()
                    ge_absorb_fork_report()
                    if ge_last_status == 0:
                        ge_last_status <- (-11 if code == 0 else (0 - code)).s32()
                    return ge_last_status
                if ge_wif_stopped(status):
                    ge_set_native_phase(GE_PHASE_PARENT_WAIT_STATUS_OTHER)
                    continue
                ge_set_native_phase(GE_PHASE_PARENT_WAIT_STATUS_OTHER)
                ge_last_errno <- status.s32()
                ge_absorb_fork_report()
                if ge_last_status == 0:
                    ge_last_status <- -1
                return ge_last_status
            if result < 0:
                ge_set_native_phase(GE_PHASE_PARENT_WAITPID_ERROR)
                ge_last_errno <- -105
                ge_absorb_fork_report()
                if ge_last_status == 0:
                    ge_last_status <- -1
                return ge_last_status
            if timeout_ms != 0u32 and waited_ms >= timeout_ms:
                ge_set_native_phase(GE_PHASE_PARENT_TIMEOUT)
                _ = ge_kill(child, 9)
                _ = ge_waitpid(child, status.ref[mutable int&], 0)
                ge_timeout_fired <- 1
                ge_last_status <- -3
                ge_last_signal <- GE_SIG_ALRM.s32()
                fr3: ElisaGuestExecForkReport&? = ge_fork_report
                if fr3 != null:
                    fr3.status <- -3
                    fr3.signal <- GE_SIG_ALRM.s32()
                ge_absorb_fork_report()
                return -3
            _ = ge_usleep(1000u32)
            waited_ms <- waited_ms + 1u32
        return ge_last_status
    static else:
        _ = timeout_ms
        ge_reset_crash_state()
        ge_set_native_phase(GE_PHASE_UNSUPPORTED_RETURN)
        ge_last_status <- -2
        return -2

def ge_get_last_status() -> s32:
    return ge_last_status
def ge_get_last_signal() -> s32:
    return ge_last_signal
def ge_get_last_errno() -> s32:
