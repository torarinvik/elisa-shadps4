# ============================================================
# Guest memory ops + native-region table + writable-page cache (ported from
# guest_exec_runtime.c). POSIX path (mmap/mprotect/munmap) is the validated
# path on macOS/Linux; the Windows branch is a typed stub (deferred — not built
# on this host). Most libc externs are @link_name-aliased to ge_* names, but
# memcpy/memset use their canonical symbol names so compiler-generated copies
# and zeroing share the same dynamic import instead of splitting to memcpy.N.
# ============================================================
extern mmap(addr: uintptr, length: usize, prot: int, flags: int, fd: int, offset: i64) -> uintptr
@link_name(mprotect)
@reentrant_safe
extern ge_mprotect(addr: uintptr, length: usize, prot: int) -> int
@link_name(munmap)
extern ge_munmap(addr: heap void&, length: usize) -> int
# Unique name + @link_name: a bare `extern memcpy` call resolves to the compiler builtin
# memcpy (not @reentrant_safe), so the @reentrant_safe annotation here was ignored and
# ge_memcpy could not stay @reentrant_safe. Linking the C symbol under a distinct name fixes it.
@reentrant_safe
@link_name(memcpy)
extern ge_raw_memcpy(dest: mutable void&, src: void&, n: usize) -> mutable void&
@link_name(sysconf)
extern ge_sysconf(name: int) -> i64
@link_name(sys_icache_invalidate)
extern ge_sys_icache_invalidate(start: uintptr, len: usize) -> void

@reentrant_safe
def ge_memcpy(dst: void&?, src: void&?, n: usize) -> void&?:
    if dst == null or src == null:
        return dst
    can Memory.Allocate:
        _ = ge_raw_memcpy(dst.cast[mutable void&], src, n)
    return dst

