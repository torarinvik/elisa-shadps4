def GuestExec_DebugArmEmergencyTimer(timeout_ms: u32) -> void:
    if ge_emergency_dump_fd >= 0:
        _ = ge_raw_close(ge_emergency_dump_fd)
        ge_emergency_dump_fd <- -1
    ge_emergency_dump_fd <- ge_raw_open(GE_EMERGENCY_DUMP_PATH, GE_O_WRONLY | GE_O_CREAT | GE_O_TRUNC, GE_CREATE_MODE_0644)
    if ge_emergency_dump_fd >= 0:
        _ = ge_raw_fchmod(ge_emergency_dump_fd, GE_CREATE_MODE_0644)
    ge_install_guards()
    ge_guard_active <- 1
    ge_guard_target_thread <- !ge_pthread_self()
    ge_arm_timer(timeout_ms)

def GuestExec_DebugDisarmEmergencyTimer() -> void:
    ge_disarm_timer()
    ge_guard_active <- 0
    ge_restore_guards()
    if ge_emergency_dump_fd >= 0:
        _ = ge_raw_close(ge_emergency_dump_fd)
        ge_emergency_dump_fd <- -1

