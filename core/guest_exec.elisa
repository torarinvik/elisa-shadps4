global mutable ge_runtime_hle_guest_frame_word1: uintptr = 0.uintptr()
global mutable ge_runtime_hle_guest_frame_word2: uintptr = 0.uintptr()
global mutable ge_runtime_hle_guest_frame_word3: uintptr = 0.uintptr()
global mutable ge_runtime_hle_caller_frame_word0: uintptr = 0.uintptr()
global mutable ge_runtime_hle_caller_frame_word1: uintptr = 0.uintptr()
global mutable ge_runtime_hle_caller_frame_word2: uintptr = 0.uintptr()
global mutable ge_runtime_hle_caller_frame_word3: uintptr = 0.uintptr()
# Oracle trace ring enlarged 128 -> 2048 (diagnostic) to capture the full boot
# HLE sequence (~803 calls) without ring truncation, for first-divergence diff
# against shadPS4. Keep mask/cap/reset bounds below in sync (2047 / 2048).
global mutable ge_hle_oracle_modules: static u8&?[2048] = zeroed
global mutable ge_hle_oracle_symbols: static u8&?[2048] = zeroed
# Guest return address after the HLE call. Kept for shadPS4 oracle parity.
global mutable ge_hle_oracle_returns: uintptr[2048] = zeroed
# Actual value returned by the HLE implementation to guest code.
global mutable ge_hle_oracle_results: uintptr[2048] = zeroed
global mutable ge_hle_oracle_rdi: uintptr[2048] = zeroed
global mutable ge_hle_oracle_rsi: uintptr[2048] = zeroed
global mutable ge_hle_oracle_rdx: uintptr[2048] = zeroed
global mutable ge_failed_relocation_count: u64 = 0

