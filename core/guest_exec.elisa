def GuestExec_EmitCusaArtifactModule(module: static u8&?, host: static u8&?, shared: s32, relocations: u64, imports: u64, resolved: u64, native_hle: u64, prx_export: u64, aerolib_fallback: u64, malformed: u64, unresolved: u64) -> void:
    ElisaGuestExec_EmitCusaArtifactModule(module, host, shared, relocations, imports, resolved, native_hle, prx_export, aerolib_fallback, malformed, unresolved)

