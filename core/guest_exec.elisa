def ge_run_child_main_entry(params: mutable GuestEntryParams&) -> void can[Memory.Allocate, Unsafe.SegmentMutation, Segment.Host, Segment.Guest]:
    ge_set_native_phase(GE_PHASE_CHILD_BRANCH_ENTERED)
    ge_install_guards()
    ge_guard_active <- 1
    ge_guard_target_thread <- !ge_pthread_self()
    ge_set_native_phase(GE_PHASE_CHILD_GUARDS_INSTALLED)
    fr: ElisaGuestExecForkReport&? = ge_fork_report
    if fr != null:
        ge_expected_entry_params <- (&params).cast[void&].uintptr()
        ge_expected_stack_word0 <- params.argc.u32().uintptr()
        ge_expected_stack_word1 <- params.argv[0].uintptr()
        ge_entry_stack_word0 <- ge_expected_stack_word0
        ge_entry_stack_word1 <- ge_expected_stack_word1
        can Memory.Allocate:
            ge_entry_native_word0 <- ge_read_native_word(params.entry_addr)
            ge_entry_native_word1 <- ge_read_native_word(params.entry_addr + 8.uintptr())
        ge_entry_native_prot <- ge_native_prot_at(params.entry_addr, 8)
        fr.expected_entry_params <- ge_expected_entry_params
        fr.expected_stack_word0 <- ge_expected_stack_word0
        fr.expected_stack_word1 <- ge_expected_stack_word1
        fr.entry_stack_word0 <- ge_entry_stack_word0
        fr.entry_stack_word1 <- ge_entry_stack_word1
        fr.entry_native_word0 <- ge_entry_native_word0
        fr.entry_native_word1 <- ge_entry_native_word1
        fr.entry_native_prot <- ge_entry_native_prot
        fr.entry_addr <- params.entry_addr
        if fr.execution_stage < 4:
            fr.execution_stage <- 4
    ge_set_native_phase(GE_PHASE_CHILD_ENTRY_SNAPSHOT)
    ge_set_native_phase(GE_PHASE_CHILD_BEFORE_SIGSETJMP)
    if ge_sigsetjmp((&ge_jmp_buf[0]).cast[void&], 1) != 0:
        ge_set_native_phase(GE_PHASE_CHILD_SIGLONGJMP)
        can Unsafe.SegmentMutation, Segment.Host:
            ge_assert_host_fs_owner("child-after-longjmp-host-owner")
        status: mutable s32 = ge_last_status
        sig: mutable s32 = ge_last_signal
        fr2: ElisaGuestExecForkReport&? = ge_fork_report
        if fr2 != null:
            if fr2.status != 0:
                status <- fr2.status
            if fr2.signal != 0:
                sig <- fr2.signal
        if status == 0 and sig == 0:
            status <- -11
            ge_last_status <- status
        if fr2 != null:
            if fr2.status == 0:
                fr2.status <- status
            if fr2.signal == 0:
                fr2.signal <- sig
            if fr2.guest_pc == 0.uintptr() and fr2.signal_pc_valid == 0:
                ge_record_fallback_pc(params.entry_addr, GE_PC_SOURCE_FALLBACK_CHILD_SIGLONGJMP)
        ge_guard_active <- 0
        ge_restore_guards()
        if sig > 0 and sig < 128:
            ge_exit_now(128 + sig.int())
        if status < 0 and (0 - status) < 128:
            ge_exit_now((0 - status).int())
        ge_exit_now(1)
        return
    ge_set_native_phase(GE_PHASE_CHILD_BEFORE_MAIN_ENTRY)
    can Unsafe.SegmentMutation, Segment.Host:
        ge_assert_host_fs_owner("child-before-main-entry")
    can Unsafe.SegmentMutation, Segment.Host, Segment.Guest:
        ge_jump_main_entry(params, ge_guarded_exit.cast[uintptr])

# ---- Crash-state reset / boundary report (atomic core, part 2b; inert) ----
def ge_report_first_boundary(reason: s32) -> void:
    ge_set_native_phase(GE_PHASE_NATIVE_BOUNDARY_REPORTED)
    fr: ElisaGuestExecForkReport&? = ge_fork_report
    if fr != null:
        fr.boundary_reached <- 1
        if fr.boundary_reason == 0:
            fr.boundary_reason <- reason
        fr.execution_stage <- 5

def ge_reset_crash_state() -> void:
    ge_last_status <- 0
    ge_last_signal <- 0
    ge_last_errno <- 0
    ge_last_native_phase <- GE_PHASE_NONE
    ge_cross_thread_signal_count <- 0
    ge_cross_thread_signal_guard_thread <- 0.uintptr()
    ge_cross_thread_signal_fault_thread <- 0.uintptr()
    ge_cross_thread_signal_number <- 0
    ge_last_fault_address <- 0.uintptr().cast[GuestFaultAddress]
    ge_last_guest_pc <- 0.uintptr().cast[GuestPC]
