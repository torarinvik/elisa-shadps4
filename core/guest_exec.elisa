def ElisaGuestExec_SetFailedRelocationCount(count: u64) -> void:
    guest_exec_failed_relocation_count <- count

def GuestExec_SetFailedRelocationCount(count: u64) -> void:
    ElisaGuestExec_SetFailedRelocationCount(count)

def GuestExec_RecordLoad() -> void:
    if guest_exec_execution_stage < GUEST_EXEC_STAGE_LOAD:
        guest_exec_execution_stage <- GUEST_EXEC_STAGE_LOAD

def GuestExec_RecordLink() -> void:
    if guest_exec_execution_stage < GUEST_EXEC_STAGE_LINK:
        guest_exec_execution_stage <- GUEST_EXEC_STAGE_LINK

def GuestExec_RecordFirstBoundary(reason: s32) -> void:
    if guest_exec_main_run_count == 0:
        return
    guest_exec_first_boundary_reached <- true
    if guest_exec_first_boundary_reason == GUEST_EXEC_BOUNDARY_REASON_NONE:
        guest_exec_first_boundary_reason <- reason
    guest_exec_execution_stage <- GUEST_EXEC_STAGE_FIRST_BOUNDARY
    c_GuestExec_ReportFirstBoundary(reason)

def GuestExec_AbsorbNativeBoundaryReport() -> void:
    reported_stage: s32 = c_GuestExec_ReportedExecutionStage()
    if reported_stage > guest_exec_execution_stage:
        guest_exec_execution_stage <- reported_stage
    if c_GuestExec_ReportedBoundaryReached() == 0:
        return
    guest_exec_first_boundary_reached <- true
    reported_reason: s32 = c_GuestExec_ReportedBoundaryReason()
    if guest_exec_first_boundary_reason == GUEST_EXEC_BOUNDARY_REASON_NONE and reported_reason != GUEST_EXEC_BOUNDARY_REASON_NONE:
        guest_exec_first_boundary_reason <- reported_reason
    if guest_exec_execution_stage < GUEST_EXEC_STAGE_FIRST_BOUNDARY:
        guest_exec_execution_stage <- GUEST_EXEC_STAGE_FIRST_BOUNDARY

def GuestExec_RecordLastHle(module: static u8&, symbol: static u8&) -> void:
    guest_exec_last_hle_module <- module
    guest_exec_last_hle_symbol <- symbol

def GuestExec_RecordRuntimeHle(module: static u8&, symbol: static u8&, arg0: VAddr, arg1: VAddr, arg2: VAddr, ret: VAddr) -> void:
    c_GuestExec_RecordRuntimeHle(module, symbol, arg0, arg1, arg2, ret)

