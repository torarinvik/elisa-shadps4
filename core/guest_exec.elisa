include "../common/types.elisa"
include "../common/arch.elisa"
include "../../compiler/runtime/elisacore_std/debug_referee.elisai"

const GUEST_EXEC_MAX_ARGS: usize = 33

extern snprintf(buf: mutable u8&?, bufsize: usize, fmt: u8&, ...) -> int effects[Console.Format]
extern puts(s: u8&) -> int effects[Console.Write]
extern popen(command: u8&, mode: u8&) -> void&?
extern pclose(stream: void&) -> int
extern fgets(s: mutable u8&, size: int, stream: void&) -> mutable u8&?

@fixed_layout
@abi_layout(size, 280, align, 8, field, argc, 0, field, argv, 8, field, entry_addr, 272)
struct GuestEntryParams:
    argc: mutable s32
    padding: mutable u32
    argv: mutable static u8&?[33]
    entry_addr: mutable VAddr

# Platform-capability queries: ported from native C to pure Elisa using the
# compile-time target facts (common/arch.elisa). These resolve entirely at build
# time via `static if`, so the unselected branches are eliminated (no runtime
# checks). HostCanRunX64Subprocess uses libc process I/O FFI only for the Apple
# Silicon Rosetta probe.
def c_GuestExec_IsSupported() -> s32:
    static if PLATFORM_WINDOWS:
        return 0
    static elif ARCH_X86_64:
        return 1
    static else:
        return 0

def c_GuestExec_SupportedNativeExecution() -> s32:
    return c_GuestExec_IsSupported()

def c_GuestExec_HostArchitecture() -> static u8&?:
    static if ARCH_X86_64:
        return "x86_64"
    static elif ARCH_ARM64:
        return "arm64"
    static else:
        return "unknown"

def c_GuestExec_HostMode() -> static u8&?:
    static if PLATFORM_WINDOWS:
        return "Windows"
    static elif PLATFORM_APPLE:
        return "macOS"
    static elif PLATFORM_LINUX:
        return "Linux"
    static elif PLATFORM_FREEBSD:
        return "FreeBSD"
    static else:
        return "unknown"

def c_GuestExec_HostCanRunX64Subprocess() -> s32:
    static if ARCH_X86_64:
        return 1
    static elif PLATFORM_APPLE and ARCH_ARM64:
        line: mutable u8[64] = zeroed
        proc: void&? = popen("/usr/bin/arch -x86_64 /usr/bin/uname -m 2>/dev/null", "r")
        if proc == null:
            return 0
        has_x64: mutable s32 = 0
        read_result: mutable u8&? = fgets(line[0].ref[mutable u8&], 64, proc.cast[void&])
        if read_result != null:
            i: mutable usize = 0
            while i < 64usize:
                if line[i] == 0:
                    i <- 64usize
                elif line[i] == '\n' or line[i] == '\r':
                    line[i] <- 0
                    i <- 64usize
                else:
                    i <- i + 1
            if streq(line[0].ref[u8&].cast[static u8&], "x86_64") == 1:
                has_x64 <- 1
        status: int = pclose(proc.cast[void&])
        if status != 0:
            return 0
        return has_x64
    static else:
        return 0

def c_GuestExec_AeroLibFallbackStubAddress() -> uintptr:
    return ge_aerolib_fallback_stub_address()

# AeroLib fallback getters (ported; written only by the x86_64 fork/absorb path)
def c_GuestExec_AeroLibFallbackCallerPc() -> uintptr:
    return ge_aerolib_fallback_caller_pc

def c_GuestExec_AeroLibFallbackSlotVa() -> uintptr:
    return ge_aerolib_fallback_slot_va

def c_GuestExec_AeroLibFallbackCallsiteBytes() -> u64:
    return ge_aerolib_fallback_callsite_bytes

def c_GuestExec_AeroLibFallbackInvocations() -> u64:
    return ge_aerolib_fallback_invocations

def c_GuestExec_AeroLibFallbackPltVa() -> uintptr:
    return ge_aerolib_fallback_plt_va

def c_GuestExec_AeroLibFallbackPltBytes() -> u64:
    return ge_aerolib_fallback_plt_bytes

# ============================================================
# Guest memory ops + native-region table + writable-page cache (ported from
# guest_exec_runtime.c). POSIX path (mmap/mprotect/munmap) is the validated
# path on macOS/Linux; the Windows branch is a typed stub (deferred — not built
# on this host). Most libc externs are @link_name-aliased to ge_* names, but
# memcpy/memset use their canonical symbol names so compiler-generated copies
# and zeroing share the same dynamic import instead of splitting to memcpy.N.
# ============================================================
extern mmap(addr: uintptr, length: usize, prot: int, flags: int, fd: int, offset: i64) -> uintptr
@link_name(mprotect)
extern ge_mprotect(addr: uintptr, length: usize, prot: int) -> int
@link_name(munmap)
extern ge_munmap(addr: uintptr, length: usize) -> int
extern memcpy(dest: mutable void&, src: void&, n: usize) -> mutable void&
@link_name(sysconf)
extern ge_sysconf(name: int) -> i64
@link_name(sys_icache_invalidate)
extern ge_sys_icache_invalidate(start: uintptr, len: usize) -> void

def ge_memcpy(dst: void&?, src: void&?, n: usize) -> void&?:
    if dst == null or src == null:
        return dst
    can Memory.Allocate:
        _ = memcpy(dst.cast[mutable void&], src.cast[void&], n)
    return dst

const GE_NATIVE_REGION_CAP: u32 = 8192u32
const GE_WRITABLE_PAGE_CAP: u64 = 65536u64
const GE_BOUNDARY_NEAR_NULL_LIMIT: u64 = 0x10000u64
const GE_BOUNDARY_POISON_WORD: u64 = 0xBADC0DEBADC0DEADu64
const GE_BOUNDARY_GUARD_NONE: u64 = 0u64
const GE_BOUNDARY_GUARD_POISON: u64 = 1u64
const GE_BOUNDARY_GUARD_NEAR_NULL_UNMAPPED: u64 = 2u64
const GE_BOUNDARY_GUARD_NON_CANONICAL: u64 = 3u64
const GE_BOUNDARY_GUARD_UNMAPPED_EXEC: u64 = 4u64
const GE_DEBUG_TRAP_BOUNDARY_GUARD_STATUS: s32 = -90
const GE_DEBUG_TRAP_UNPUBLISHED_EXEC_STATUS: s32 = -91
const GE_DEBUG_TRAP_CALLABLE_GUARD_STATUS: s32 = -92

struct GeNativeRegion:
    base: mutable uintptr
    size: mutable u64
    prot: mutable u32
    active: mutable u32

global mutable ge_native_regions: GeNativeRegion[8192] = zeroed
global mutable ge_native_region_count: u32 = 0u32
global mutable ge_writable_pages: uintptr[65536] = zeroed
global mutable ge_writable_page_count: u32 = 0u32
global mutable ge_publish_executable_count: u64 = 0u64
global mutable ge_publish_executable_reject_count: u64 = 0u64
global mutable ge_publish_executable_last_addr: uintptr = 0.uintptr()
global mutable ge_publish_executable_last_size: u64 = 0u64
global mutable ge_publish_executable_last_prot: u32 = 0u32
global mutable ge_publish_executable_last_result: s32 = 0
global mutable ge_published_exec_bases: uintptr[2048] = zeroed
global mutable ge_published_exec_sizes: u64[2048] = zeroed
global mutable ge_published_exec_count: u32 = 0u32
global mutable ge_debug_trap_on_boundary_guard: bool = false
global mutable ge_debug_trap_on_unpublished_exec: bool = false
global mutable ge_debug_trap_on_callable_guard: bool = false
global mutable ge_debug_trap_count: u64 = 0u64
global mutable ge_debug_trap_reason: u64 = 0u64
global mutable ge_debug_trap_value: uintptr = 0.uintptr()
global mutable ge_debug_trap_sequence: u64 = 0u64
global mutable ge_debug_trace_enabled: bool = false

def ge_debug_trace_boundary(label: cstr, a: uintptr, b: uintptr, c: uintptr) -> void:
    if not ge_debug_trace_enabled:
        return
    ge_debug_trace_record(DEBUG_TRACE_KIND_BOUNDARY, label, a, b, c)

def ge_debug_trace_checkpoint(label: cstr) -> void:
    if not ge_debug_trace_enabled:
        return
    ge_debug_trace_record(DEBUG_TRACE_KIND_CHECKPOINT, label, 0.uintptr(), 0.uintptr(), 0.uintptr())

def ge_debug_trace_reset() -> void:
    if not ge_debug_trace_enabled:
        return
    debug_trace_sequence <- 0u64
    debug_trace_event_count <- 0.usize()
    debug_trace_overflowed <- false
    debug_trace_hash <- DEBUG_TRACE_HASH_INITIAL
    debug_trace_last_event <- DebugTraceEvent(0u64, 0, 0.uintptr(), 0.uintptr(), 0.uintptr(), "")

def ge_debug_trace_mix_word(word: uintptr) -> void:
    debug_trace_hash <- (debug_trace_hash ^ word.u64()) * DEBUG_TRACE_HASH_PRIME

def ge_debug_trace_record(kind: int, label: cstr, a: uintptr, b: uintptr, c: uintptr) -> void:
    if not ge_debug_trace_enabled:
        return
    debug_trace_sequence <- debug_trace_sequence + 1u64
    ge_debug_trace_mix_word(kind.uintptr())
    ge_debug_trace_mix_word(a)
    ge_debug_trace_mix_word(b)
    ge_debug_trace_mix_word(c)
    event: DebugTraceEvent = DebugTraceEvent(debug_trace_sequence, kind, a, b, c, label)
    debug_trace_last_event <- event
    if debug_trace_event_count < DEBUG_TRACE_TAPE_CAP:
        debug_trace_events[debug_trace_event_count] <- event
        debug_trace_event_count <- debug_trace_event_count + 1.usize()
    else:
        debug_trace_overflowed <- true

def ge_map_failed() -> uintptr:
    return 0xFFFFFFFFFFFFFFFFu64.uintptr()

# Reinterpret a raw guest/host address as an opaque pointer for libc calls.
def ge_addr_to_ptr(address: uintptr) -> void&?:
    p: mutable void&? = null
    trusted Unsafe.PointerCast:
        p <- address.cast[void&?]
    return p

def ge_native_prot(prot: u32) -> int:
    np: mutable int = 0
    if (prot & 1u32) != 0u32:
        np <- np | 1
    if (prot & 2u32) != 0u32:
        np <- np | 2
    if (prot & 4u32) != 0u32:
        np <- np | 4
    return np

def ge_mmap_anon_flags() -> int:
    static if PLATFORM_APPLE:
        return 0x0002 | 0x1000
    static else:
        return 0x0002 | 0x20

def ge_mmap_fixed_flags() -> int:
    static if PLATFORM_APPLE:
        return 0x0002 | 0x1000 | 0x0010
    static elif PLATFORM_LINUX:
        return 0x0002 | 0x20 | 0x100000
    static else:
        return 0x0002 | 0x20 | 0x0010

def ge_page_size() -> uintptr:
    static if PLATFORM_APPLE:
        ps: i64 = ge_sysconf(29)
        return ps.uintptr() if ps > 0i64 else 4096.uintptr()
    static elif PLATFORM_LINUX:
        ps: i64 = ge_sysconf(30)
        return ps.uintptr() if ps > 0i64 else 4096.uintptr()
    static else:
        return 4096.uintptr()

def ge_flush_instruction_cache(address: uintptr, size: u64) -> void:
    static if PLATFORM_APPLE and ARCH_ARM64:
        ge_sys_icache_invalidate(address, size.usize())
    static else:
        _ = address
        _ = size

def ge_region_contains(base: uintptr, rsize: u64, address: uintptr, size: u64) -> bool:
    if base == 0.uintptr() or rsize == 0u64:
        return false
    if address.u64() < base.u64():
        return false
    offset: u64 = address.u64() - base.u64()
    return offset <= rsize and size <= (rsize - offset)

def ge_find_native_region(address: uintptr, size: u64) -> s32:
    best: mutable s32 = -1
    best_size: mutable u64 = 0xFFFFFFFFFFFFFFFFu64
    i: mutable u32 = 0u32
    while i < ge_native_region_count and i < GE_NATIVE_REGION_CAP:
        r: GeNativeRegion = ge_native_regions[i.usize()]
        if r.active != 0u32 and ge_region_contains(r.base, r.size, address, size):
            if r.size < best_size:
                best <- i.s32()
                best_size <- r.size
        i <- i + 1u32
    return best

def ge_record_native_region(base: uintptr, size: u64, prot: u32) -> void:
    if base == 0.uintptr() or size == 0u64:
        return
    existing: s32 = ge_find_native_region(base, size)
    if existing >= 0 and existing.u32() < GE_NATIVE_REGION_CAP:
        idx: u32 = existing.u32()
        cur: GeNativeRegion = ge_native_regions[idx.usize()]
        if cur.base == base and cur.size == size:
            ge_native_regions[idx.usize()] <- GeNativeRegion(base, size, prot, 1u32)
            return
    if ge_native_region_count >= GE_NATIVE_REGION_CAP:
        return
    idx: u32 = ge_native_region_count
    if idx < GE_NATIVE_REGION_CAP:
        ge_native_regions[idx.usize()] <- GeNativeRegion(base, size, prot, 1u32)
        ge_native_region_count <- ge_native_region_count + 1u32

def ge_forget_native_region(base: uintptr, size: u64) -> void:
    i: mutable u32 = 0u32
    while i < ge_native_region_count and i < GE_NATIVE_REGION_CAP:
        cur: GeNativeRegion = ge_native_regions[i.usize()]
        if cur.active != 0u32 and cur.base == base and cur.size == size:
            ge_native_regions[i.usize()] <- GeNativeRegion(base, size, cur.prot, 0u32)
            return
        i <- i + 1u32

def ge_native_prot_at(address: uintptr, size: u64) -> u32:
    index: s32 = ge_find_native_region(address, size)
    if index >= 0 and index.u32() < GE_NATIVE_REGION_CAP:
        return ge_native_regions[index.usize()].prot
    return 0xffffffffu32

def ge_boundary_guard_reason_for_value(value: uintptr) -> u64:
    if value.u64() == GE_BOUNDARY_POISON_WORD:
        return GE_BOUNDARY_GUARD_POISON
    if value != 0.uintptr() and value.u64() < GE_BOUNDARY_NEAR_NULL_LIMIT and ge_native_prot_at(value, 8u64) == 0xffffffffu32:
        return GE_BOUNDARY_GUARD_NEAR_NULL_UNMAPPED
    return GE_BOUNDARY_GUARD_NONE

def ge_is_noncanonical_x86_address(value: uintptr) -> bool:
    raw: u64 = value.u64()
    sign: u64 = (raw >> 47u64) & 1u64
    upper: u64 = raw >> 48u64
    if sign == 0u64:
        return upper != 0u64
    return upper != 0xffffu64

def ge_callable_guard_reason_for_value(value: uintptr) -> u64:
    base_reason: u64 = ge_boundary_guard_reason_for_value(value)
    if base_reason != GE_BOUNDARY_GUARD_NONE:
        return base_reason
    if ge_is_noncanonical_x86_address(value):
        return GE_BOUNDARY_GUARD_NON_CANONICAL
    prot: u32 = ge_native_prot_at(value, 1u64)
    if prot == 0xffffffffu32 or (prot & 4u32) == 0u32:
        return GE_BOUNDARY_GUARD_UNMAPPED_EXEC
    return GE_BOUNDARY_GUARD_NONE

def ge_record_published_exec(address: uintptr, size: u64) -> void:
    if address == 0.uintptr() or size == 0u64:
        return
    i: mutable u32 = 0u32
    while i < ge_published_exec_count and i < 2048u32:
        if ge_published_exec_bases[i.usize()] == address:
            ge_published_exec_sizes[i.usize()] <- size
            return
        i <- i + 1u32
    if ge_published_exec_count < 2048u32:
        ge_published_exec_bases[ge_published_exec_count.usize()] <- address
        ge_published_exec_sizes[ge_published_exec_count.usize()] <- size
        ge_published_exec_count <- ge_published_exec_count + 1u32

def ge_is_published_exec(address: uintptr, size: u64) -> bool:
    if address == 0.uintptr() or size == 0u64:
        return false
    i: mutable u32 = 0u32
    while i < ge_published_exec_count and i < 2048u32:
        base: uintptr = ge_published_exec_bases[i.usize()]
        rsize: u64 = ge_published_exec_sizes[i.usize()]
        if ge_region_contains(base, rsize, address, size):
            return true
        i <- i + 1u32
    return false

def ge_check_entry_published(entry_addr: uintptr) -> bool:
    if not ge_debug_trap_on_unpublished_exec:
        return true
    if ge_is_published_exec(entry_addr, 1u64):
        return true
    ge_debug_trap_count <- ge_debug_trap_count + 1u64
    ge_debug_trap_reason <- GE_DEBUG_TRAP_UNPUBLISHED_EXEC_STATUS.u64()
    ge_debug_trap_value <- entry_addr
    ge_debug_trap_sequence <- ge_debug_trap_count
    ge_last_status <- GE_DEBUG_TRAP_UNPUBLISHED_EXEC_STATUS
    return false

def ge_debug_guard_callable_target(target: uintptr, sequence: u64) -> bool:
    if not ge_debug_trap_on_callable_guard:
        return true
    if ge_debug_trap_sequence != 0u64:
        return false
    reason: u64 = ge_callable_guard_reason_for_value(target)
    if reason == GE_BOUNDARY_GUARD_NONE:
        return true
    ge_debug_trap_count <- ge_debug_trap_count + 1u64
    ge_debug_trap_reason <- reason
    ge_debug_trap_value <- target
    ge_debug_trap_sequence <- sequence if sequence != 0u64 else ge_debug_trap_count
    ge_last_status <- GE_DEBUG_TRAP_CALLABLE_GUARD_STATUS
    ge_debug_trace_boundary("guest-exec-callable-guard-stop", target, reason.uintptr(), ge_debug_trap_sequence.uintptr())
    return false

def ge_read_native_word(address: uintptr) -> uintptr:
    if address == 0.uintptr():
        return 0.uintptr()
    index: s32 = ge_find_native_region(address, 8u64)
    if index < 0 or index.u32() >= GE_NATIVE_REGION_CAP:
        return 0.uintptr()
    if (ge_native_regions[index.usize()].prot & 1u32) == 0u32:
        return 0.uintptr()
    out: mutable u64 = 0u64
    _ = ge_memcpy(out.ref[void&], ge_addr_to_ptr(address), 8usize)
    return out.uintptr()

def ge_maybe_debug_trap_boundary_guard() -> void:
    if not ge_debug_trap_on_boundary_guard:
        return
    if ge_runtime_hle_boundary_guard_reason == GE_BOUNDARY_GUARD_NONE:
        return
    if ge_debug_trap_sequence != 0u64:
        return
    ge_debug_trap_count <- ge_debug_trap_count + 1u64
    ge_debug_trap_reason <- ge_runtime_hle_boundary_guard_reason
    ge_debug_trap_value <- ge_runtime_hle_boundary_guard_value
    ge_debug_trap_sequence <- ge_runtime_hle_boundary_guard_sequence
    ge_last_status <- GE_DEBUG_TRAP_BOUNDARY_GUARD_STATUS
    fr: ElisaGuestExecForkReport&? = ge_fork_report
    if fr != null:
        fr.status <- GE_DEBUG_TRAP_BOUNDARY_GUARD_STATUS
        fr.signal <- 0
    if ge_guard_active != 0:
        current_thread: uintptr = ge_pthread_self()
        if ge_guard_target_thread == 0.uintptr() or current_thread == ge_guard_target_thread:
            ge_siglongjmp(ge_jmp_buf[0usize].ref[void&], 1)
        ge_cross_thread_signal_count <- ge_cross_thread_signal_count + 1u64
        ge_cross_thread_signal_guard_thread <- ge_guard_target_thread
        ge_cross_thread_signal_fault_thread <- current_thread
        ge_cross_thread_signal_number <- GE_DEBUG_TRAP_BOUNDARY_GUARD_STATUS
        if fr != null:
            fr.cross_thread_signal_count <- ge_cross_thread_signal_count
            fr.cross_thread_signal_guard_thread <- ge_guard_target_thread
            fr.cross_thread_signal_fault_thread <- current_thread
            fr.cross_thread_signal_number <- GE_DEBUG_TRAP_BOUNDARY_GUARD_STATUS
        ge_exit_now(90)

def ge_clear_writable_page_cache() -> void:
    i: mutable usize = 0usize
    while i < 65536usize:
        ge_writable_pages[i] <- 0.uintptr()
        i <- i + 1usize
    ge_writable_page_count <- 0u32

def ge_page_cached_writable(page: uintptr) -> bool:
    slot: u64 = (page.u64() >> 12u64) % GE_WRITABLE_PAGE_CAP
    if slot < GE_WRITABLE_PAGE_CAP:
        return ge_writable_pages[slot.usize()] == page
    return false

def ge_cache_writable_page(page: uintptr) -> void:
    slot: u64 = (page.u64() >> 12u64) % GE_WRITABLE_PAGE_CAP
    if slot < GE_WRITABLE_PAGE_CAP:
        if ge_writable_pages[slot.usize()] == 0.uintptr():
            ge_writable_page_count <- ge_writable_page_count + 1u32
        ge_writable_pages[slot.usize()] <- page

def ge_make_writable_cached(address: uintptr, size: u64) -> s32:
    if address == 0.uintptr() or size == 0u64:
        return 0
    ps: uintptr = ge_page_size()
    ps64: u64 = ps.u64()
    mask: u64 = 0xFFFFFFFFFFFFFFFFu64 ^ (ps64 - 1u64)
    start: u64 = address.u64() & mask
    end: u64 = (address.u64() + size + ps64 - 1u64) & mask
    page: mutable u64 = start
    while page < end:
        if not ge_page_cached_writable(page.uintptr()):
            static if PLATFORM_WINDOWS:
                return -1
            static else:
                if ge_mprotect(page.uintptr(), ps.usize(), 7) != 0:
                    return -1
            ge_cache_writable_page(page.uintptr())
        page <- page + ps64
    return 0

def c_GuestExec_MapRegion(address: uintptr, size: u64, prot: u32) -> s32:
    if address == 0.uintptr() or size == 0u64:
        return -1
    ge_clear_writable_page_cache()
    static if PLATFORM_WINDOWS:
        return -1
    static else:
        np: int = ge_native_prot(prot)
        result: uintptr = mmap(address, size.usize(), np, ge_mmap_fixed_flags(), -1, 0i64)
        if result != ge_map_failed() and result == address:
            ge_record_native_region(address, size, prot)
            return 0
        # Reservation+commit overlap (Linux MAP_FIXED_NOREPLACE EEXIST, etc.):
        # promote the existing subrange via mprotect instead of leaving it.
        if ge_mprotect(address, size.usize(), np) == 0:
            ge_record_native_region(address, size, prot)
            return 0
        return -1

def c_GuestExec_ProtectRegion(address: uintptr, size: u64, prot: u32) -> s32:
    if address == 0.uintptr() or size == 0u64:
        return -1
    ge_clear_writable_page_cache()
    static if PLATFORM_WINDOWS:
        return -1
    static else:
        np: int = ge_native_prot(prot)
        if ge_mprotect(address, size.usize(), np) == 0:
            ge_record_native_region(address, size, prot)
            return 0
        return -1

def c_GuestExec_UnmapRegion(address: uintptr, size: u64) -> s32:
    if address == 0.uintptr() or size == 0u64:
        return -1
    static if PLATFORM_WINDOWS:
        return -1
    static else:
        if ge_munmap(address, size.usize()) == 0:
            ge_forget_native_region(address, size)
            return 0
        return -1

def c_GuestExec_AllocateRegion(size: u64, prot: u32) -> uintptr:
    if size == 0u64:
        return 0.uintptr()
    static if PLATFORM_WINDOWS:
        return 0.uintptr()
    static else:
        np: int = ge_native_prot(prot)
        hint: mutable uintptr = 0.uintptr()
        static if PLATFORM_APPLE and ARCH_X86_64:
            # The x64 game runner shrinks __PAGEZERO and reserves low memory for
            # LDT/TCB pages. With that layout mmap(NULL, ...) can hand out those
            # low pages; executable HLE thunks must live in normal host space.
            hint <- 0x600000000000.uintptr()
        result: uintptr = mmap(hint, size.usize(), np, ge_mmap_anon_flags(), -1, 0i64)
        if result == ge_map_failed():
            return 0.uintptr()
        ge_record_native_region(result, size, prot)
        return result

def c_GuestExec_WriteBytes(address: uintptr, data: void&?, size: u64) -> s32:
    if address == 0.uintptr() or (data == null and size != 0u64):
        return -1
    if size != 0u64:
        if ge_make_writable_cached(address, size) != 0:
            return -1
        _ = ge_memcpy(ge_addr_to_ptr(address), data, size.usize())
        ge_flush_instruction_cache(address, size)
    return 0

def c_GuestExec_WriteU64(address: uintptr, value: u64) -> s32:
    if address == 0.uintptr():
        return -1
    if ge_make_writable_cached(address, 8u64) != 0:
        return -1
    v: mutable u64 = value
    _ = ge_memcpy(ge_addr_to_ptr(address), v.ref[void&], 8usize)
    ge_flush_instruction_cache(address, 8u64)
    return 0

def c_GuestExec_PublishExecutableCode(address: uintptr, size: u64) -> s32:
    ge_publish_executable_last_addr <- address
    ge_publish_executable_last_size <- size
    ge_publish_executable_last_prot <- ge_native_prot_at(address, size)
    if address == 0.uintptr() or size == 0u64:
        ge_publish_executable_reject_count <- ge_publish_executable_reject_count + 1u64
        ge_publish_executable_last_result <- -1
        return -1
    if ge_publish_executable_last_prot == 0xffffffffu32 or (ge_publish_executable_last_prot & 4u32) == 0u32:
        ge_publish_executable_reject_count <- ge_publish_executable_reject_count + 1u64
        ge_publish_executable_last_result <- -2
        return -2
    ge_flush_instruction_cache(address, size)
    ge_publish_executable_count <- ge_publish_executable_count + 1u64
    ge_record_published_exec(address, size)
    ge_publish_executable_last_result <- 0
    return 0

def c_GuestExec_NativeRegionCount() -> u32:
    n: mutable u32 = 0u32
    i: mutable u32 = 0u32
    while i < ge_native_region_count and i < GE_NATIVE_REGION_CAP:
        if ge_native_regions[i.usize()].active != 0u32:
            n <- n + 1u32
        i <- i + 1u32
    return n

def c_GuestExec_AddressNativeProt(address: uintptr) -> u32:
    return ge_native_prot_at(address, 8u64)

def c_GuestExec_ReadNativeU64(address: uintptr) -> uintptr:
    return ge_read_native_word(address)

@c_abi(c)
def c_GuestExec_ReadContextU64(address: uintptr) -> uintptr:
    return ge_read_context_word(address)

def c_GuestExec_PublishExecutableCount() -> u64:
    return ge_publish_executable_count

def c_GuestExec_PublishExecutableRejectCount() -> u64:
    return ge_publish_executable_reject_count

def c_GuestExec_PublishExecutableLastAddr() -> uintptr:
    return ge_publish_executable_last_addr

def c_GuestExec_PublishExecutableLastSize() -> u64:
    return ge_publish_executable_last_size

def c_GuestExec_PublishExecutableLastProt() -> u32:
    return ge_publish_executable_last_prot

def c_GuestExec_PublishExecutableLastResult() -> s32:
    return ge_publish_executable_last_result

def c_GuestExec_PublishedExecutableCount() -> u32:
    return ge_published_exec_count

def c_GuestExec_IsExecutableCodePublished(address: uintptr, size: u64) -> s32:
    return 1 if ge_is_published_exec(address, size) else 0

def c_GuestExec_DebugTrapCount() -> u64:
    return ge_debug_trap_count

def c_GuestExec_DebugTrapReason() -> u64:
    return ge_debug_trap_reason

def c_GuestExec_DebugTrapValue() -> uintptr:
    return ge_debug_trap_value

def c_GuestExec_DebugTrapSequence() -> u64:
    return ge_debug_trap_sequence

# ============================================================
# x86_64 signal/ucontext crash-capture foundation (Stage C+D+E, part 1).
# Inert until the atomic swap wires it in; the signal handler and guards mirror
# guest_exec_runtime.c. ucontext register extraction uses raw offset reads (no
# struct modeling) — the same fields upstream shadPS4 reads via uc_mcontext->__ss.
# ============================================================
@link_name(sigaction)
extern ge_sigaction(signum: int, act: void&?, oldact: void&?) -> int
@link_name(siglongjmp)
extern ge_siglongjmp(env: void&?, val: int) -> void
@link_name(dladdr)
extern ge_dladdr(addr: void&?, info: void&?) -> int

# macOS struct sigaction (16 bytes): handler ptr, sa_mask (u32), sa_flags (int).
# Linux's is larger/different — modeled for the validated macOS path; Linux is
# a follow-up (like the Windows memory stubs).
@fixed_layout
struct GeSigaction:
    handler: mutable void&?
    mask: mutable u32
    flags: mutable int

# Dl_info: { const char* dli_fname; void* dli_fbase; const char* dli_sname; void* dli_saddr; }
@fixed_layout
struct GeDlInfo:
    dli_fname: mutable static u8&?
    dli_fbase: mutable void&?
    dli_sname: mutable static u8&?
    dli_saddr: mutable void&?

global mutable ge_guard_active: s32 = 0
global mutable ge_old_segv: GeSigaction = zeroed
global mutable ge_old_bus: GeSigaction = zeroed
global mutable ge_old_ill: GeSigaction = zeroed
global mutable ge_old_fpe: GeSigaction = zeroed
global mutable ge_old_trap: GeSigaction = zeroed
global mutable ge_old_alrm: GeSigaction = zeroed
global mutable ge_jmp_buf: u8[256] = zeroed
global mutable ge_cross_thread_signal_count: u64 = 0u64
global mutable ge_cross_thread_signal_guard_thread: uintptr = 0.uintptr()
global mutable ge_cross_thread_signal_fault_thread: uintptr = 0.uintptr()
global mutable ge_cross_thread_signal_number: s32 = 0

const GE_SIG_SEGV: int = 11
const GE_SIG_ILL: int = 4
const GE_SIG_FPE: int = 8
const GE_SIG_TRAP: int = 5
const GE_SIG_ALRM: int = 14
def ge_sig_bus() -> int:
    static if PLATFORM_APPLE:
        return 10
    static else:
        return 7
def ge_sa_siginfo() -> int:
    return 0x40

def ge_set_native_phase(phase: s32) -> void:
    ge_last_native_phase <- phase
    fr: ElisaGuestExecForkReport&? = ge_fork_report
    if fr != null:
        fr.native_phase <- phase

# Raw read of a uintptr at an arbitrary host address (signal/stack context).
def ge_read_context_word(address: uintptr) -> uintptr:
    if address == 0.uintptr():
        return 0.uintptr()
    out: mutable u64 = 0u64
    _ = ge_memcpy(out.ref[void&], ge_addr_to_ptr(address), 8usize)
    return out.uintptr()

def ge_uctx_word(uctx: void&?, offset: u64) -> uintptr:
    if uctx == null:
        return 0.uintptr()
    return ge_read_context_word(uctx.uintptr() + offset.uintptr())

def ge_extract_mctx(uctx: void&?) -> uintptr:
    static if ARCH_X86_64 and PLATFORM_APPLE:
        return ge_uctx_word(uctx, 48u64)
    static elif ARCH_X86_64 and PLATFORM_LINUX:
        return uctx.uintptr() + 40.uintptr() if uctx != null else 0.uintptr()
    static else:
        _ = uctx
        return 0.uintptr()

# x86_64 ucontext register extraction (raw offsets). macOS: uc_mcontext ptr at
# uctx+48 -> mcontext64.__ss regs. Linux: inline uc_mcontext.gregs at uctx+40.
def ge_extract_pc(uctx: void&?) -> uintptr:
    static if ARCH_X86_64 and PLATFORM_APPLE:
        mctx: uintptr = ge_uctx_word(uctx, 48u64)
        return ge_read_context_word(mctx + 144.uintptr())
    static elif ARCH_X86_64 and PLATFORM_LINUX:
        return ge_uctx_word(uctx, 40u64 + 16u64 * 8u64)
    static else:
        return 0.uintptr()

def ge_extract_sp(uctx: void&?) -> uintptr:
    static if ARCH_X86_64 and PLATFORM_APPLE:
        mctx: uintptr = ge_uctx_word(uctx, 48u64)
        return ge_read_context_word(mctx + 72.uintptr())
    static elif ARCH_X86_64 and PLATFORM_LINUX:
        return ge_uctx_word(uctx, 40u64 + 15u64 * 8u64)
    static else:
        return 0.uintptr()

def ge_extract_bp(uctx: void&?) -> uintptr:
    static if ARCH_X86_64 and PLATFORM_APPLE:
        mctx: uintptr = ge_uctx_word(uctx, 48u64)
        return ge_read_context_word(mctx + 64.uintptr())
    static elif ARCH_X86_64 and PLATFORM_LINUX:
        return ge_uctx_word(uctx, 40u64 + 10u64 * 8u64)
    static else:
        return 0.uintptr()

# reg index: 0=rdi 1=rsi 2=rax 3=rbx 4=rdx 5=rcx 6=r8 7=r9
def ge_extract_greg(uctx: void&?, reg: int) -> uintptr:
    static if ARCH_X86_64 and PLATFORM_APPLE:
        mctx: uintptr = ge_uctx_word(uctx, 48u64)
        off: mutable u64 = 0u64
        if reg == 0:
            off <- 48u64
        elif reg == 1:
            off <- 56u64
        elif reg == 2:
            off <- 16u64
        elif reg == 3:
            off <- 24u64
        elif reg == 4:
            off <- 40u64
        elif reg == 5:
            off <- 32u64
        elif reg == 6:
            off <- 80u64
        elif reg == 7:
            off <- 88u64
        else:
            return 0.uintptr()
        return ge_read_context_word(mctx + off.uintptr())
    static elif ARCH_X86_64 and PLATFORM_LINUX:
        gi: mutable u64 = 0u64
        if reg == 0:
            gi <- 8u64
        elif reg == 1:
            gi <- 9u64
        elif reg == 2:
            gi <- 13u64
        elif reg == 3:
            gi <- 11u64
        elif reg == 4:
            gi <- 12u64
        elif reg == 5:
            gi <- 14u64
        elif reg == 6:
            gi <- 0u64
        elif reg == 7:
            gi <- 1u64
        else:
            return 0.uintptr()
        return ge_uctx_word(uctx, 40u64 + gi * 8u64)
    static else:
        return 0.uintptr()

# si_addr lives at a per-OS offset inside siginfo_t (macOS 24, Linux 16).
def ge_siginfo_fault_addr(info: void&?) -> uintptr:
    if info == null:
        return 0.uintptr()
    static if PLATFORM_APPLE:
        return ge_read_context_word(info.uintptr() + 24.uintptr())
    static elif PLATFORM_LINUX:
        return ge_read_context_word(info.uintptr() + 16.uintptr())
    static else:
        return 0.uintptr()

# dladdr a code address into symbol + image name; store into the stack-context
# or pc-context globals.
def ge_resolve_pc_symbol(address: uintptr, is_stack: bool) -> void:
    sym: mutable static u8&? = ""
    img: mutable static u8&? = ""
    if address != 0.uintptr():
        info: mutable GeDlInfo = zeroed
        if ge_dladdr(ge_addr_to_ptr(address), info.ref[void&]) != 0:
            if info.dli_sname != null:
                sym <- info.dli_sname
            if info.dli_fname != null:
                img <- info.dli_fname
    if is_stack:
        ge_signal_stack_symbol0 <- sym
        ge_signal_stack_image0 <- img
    else:
        ge_signal_pc_symbol <- sym
        ge_signal_pc_image <- img

def ge_install_guards() -> void:
    sa: mutable GeSigaction = zeroed
    sa.handler <- ge_signal_handler as void&?
    sa.mask <- 0u32
    sa.flags <- ge_sa_siginfo()
    _ = ge_sigaction(GE_SIG_SEGV, sa.ref[void&], ge_old_segv.ref[void&])
    _ = ge_sigaction(ge_sig_bus(), sa.ref[void&], ge_old_bus.ref[void&])
    _ = ge_sigaction(GE_SIG_ILL, sa.ref[void&], ge_old_ill.ref[void&])
    _ = ge_sigaction(GE_SIG_FPE, sa.ref[void&], ge_old_fpe.ref[void&])
    _ = ge_sigaction(GE_SIG_TRAP, sa.ref[void&], ge_old_trap.ref[void&])
    alarm_sa: mutable GeSigaction = zeroed
    alarm_sa.handler <- ge_alarm_handler as void&?
    alarm_sa.mask <- 0u32
    alarm_sa.flags <- 0
    _ = ge_sigaction(GE_SIG_ALRM, alarm_sa.ref[void&], ge_old_alrm.ref[void&])

def ge_restore_guards() -> void:
    _ = ge_sigaction(GE_SIG_SEGV, ge_old_segv.ref[void&], null)
    _ = ge_sigaction(ge_sig_bus(), ge_old_bus.ref[void&], null)
    _ = ge_sigaction(GE_SIG_ILL, ge_old_ill.ref[void&], null)
    _ = ge_sigaction(GE_SIG_FPE, ge_old_fpe.ref[void&], null)
    _ = ge_sigaction(GE_SIG_TRAP, ge_old_trap.ref[void&], null)
    _ = ge_sigaction(GE_SIG_ALRM, ge_old_alrm.ref[void&], null)

@c_abi(c)
def ge_alarm_handler(sig: int) -> void:
    _ = sig
    ge_set_native_phase(GE_PHASE_ALARM_HANDLER_ENTERED)
    ge_timeout_fired <- 1
    ge_last_status <- -3
    ge_last_signal <- GE_SIG_ALRM.s32()
    fr: ElisaGuestExecForkReport&? = ge_fork_report
    if fr != null:
        fr.status <- -3
        fr.signal <- GE_SIG_ALRM.s32()
        fr.fault_thread <- ge_pthread_self()
        fr.guard_thread <- ge_guard_target_thread
        if fr.execution_stage < 4:
            fr.execution_stage <- 4
    if ge_guard_active != 0:
        current_thread: uintptr = ge_pthread_self()
        if ge_guard_target_thread == 0.uintptr() or current_thread == ge_guard_target_thread:
            ge_siglongjmp(ge_jmp_buf[0usize].ref[void&], 1)
        ge_cross_thread_signal_count <- ge_cross_thread_signal_count + 1u64
        ge_cross_thread_signal_guard_thread <- ge_guard_target_thread
        ge_cross_thread_signal_fault_thread <- current_thread
        ge_cross_thread_signal_number <- GE_SIG_ALRM.s32()
        if fr != null:
            fr.cross_thread_signal_count <- ge_cross_thread_signal_count
            fr.cross_thread_signal_guard_thread <- ge_guard_target_thread
            fr.cross_thread_signal_fault_thread <- current_thread
            fr.cross_thread_signal_number <- GE_SIG_ALRM.s32()
        ge_exit_now(128 + GE_SIG_ALRM)

@c_abi(c)
def ge_signal_handler(sig: int, info: void&?, uctx: void&?) -> void:
    ge_set_native_phase(GE_PHASE_SIGNAL_HANDLER_ENTERED)
    ge_last_status <- (0 - sig).s32()
    ge_last_signal <- sig.s32()
    fault_thread: uintptr = ge_pthread_self()
    ge_signal_uctx <- uctx.uintptr() if uctx != null else 0.uintptr()
    ge_signal_mctx <- ge_extract_mctx(uctx)
    ge_last_fault_address <- ge_siginfo_fault_addr(info)
    ge_signal_fault_addr_valid <- 1 if info != null else 0
    ge_signal_guest_pc <- ge_extract_pc(uctx)
    ge_signal_pc_valid <- 1 if ge_signal_guest_pc != 0.uintptr() else 0
    ge_fallback_guest_pc <- 0.uintptr()
    ge_last_pc_was_fallback <- 0
    ge_last_pc_source <- (GE_PC_SOURCE_SIGNAL_UCONTEXT if ge_signal_pc_valid != 0 else GE_PC_SOURCE_NONE)
    ge_last_guest_pc <- ge_signal_guest_pc
    ge_last_guest_sp <- ge_extract_sp(uctx)
    ge_last_guest_bp <- ge_extract_bp(uctx)
    ge_last_guest_rdi <- ge_extract_greg(uctx, 0)
    ge_last_guest_rsi <- ge_extract_greg(uctx, 1)
    ge_last_guest_rax <- ge_extract_greg(uctx, 2)
    ge_last_guest_rbx <- ge_extract_greg(uctx, 3)
    ge_last_guest_rdx <- ge_extract_greg(uctx, 4)
    ge_last_guest_rcx <- ge_extract_greg(uctx, 5)
    ge_last_guest_r8 <- ge_extract_greg(uctx, 6)
    ge_last_guest_r9 <- ge_extract_greg(uctx, 7)
    ge_signal_sp_valid <- 1 if ge_signal_mctx != 0.uintptr() else 0
    ge_signal_bp_valid <- ge_signal_sp_valid
    ge_signal_rdi_valid <- ge_signal_sp_valid
    ge_signal_rsi_valid <- ge_signal_sp_valid
    ge_signal_native_region_index <- ge_find_native_region(ge_last_guest_pc, 8u64)
    ge_pc_native_prot <- ge_native_prot_at(ge_last_guest_pc, 8u64)
    ge_fault_word0 <- ge_read_native_word(ge_last_guest_pc)
    ge_fault_word1 <- ge_read_native_word(ge_last_guest_pc + 8.uintptr())
    ge_signal_stack_word0 <- ge_read_context_word(ge_last_guest_sp)
    ge_signal_stack_word1 <- ge_read_context_word(ge_last_guest_sp + 8.uintptr())
    ge_signal_stack_word_m1 <- 0.uintptr()
    if ge_last_guest_sp.u64() >= 8u64:
        ge_signal_stack_word_m1 <- ge_read_context_word(ge_last_guest_sp - 8.uintptr())
    ge_fault_transfer_class <- 0u64
    if ge_last_guest_pc != 0.uintptr() and ge_last_guest_pc.u64() < 4096u64 and ge_pc_native_prot == 0xffffffffu32:
        ge_fault_transfer_class <- 1u64
        if ge_last_guest_pc == ge_signal_stack_word_m1:
            ge_fault_transfer_class <- 2u64
        elif ge_last_guest_pc == ge_signal_stack_word0:
            ge_fault_transfer_class <- 3u64
        elif ge_last_guest_pc == ge_signal_stack_word1:
            ge_fault_transfer_class <- 4u64
    ge_resolve_pc_symbol(ge_signal_stack_word0, true)
    ge_resolve_pc_symbol(ge_last_guest_pc, false)
    fr: ElisaGuestExecForkReport&? = ge_fork_report
    if fr != null:
        fr.status <- ge_last_status
        fr.signal <- sig.s32()
        fr.fault_thread <- fault_thread
        fr.guard_thread <- ge_guard_target_thread
        fr.fault_address <- ge_last_fault_address
        fr.guest_pc <- ge_last_guest_pc
        fr.guest_sp <- ge_last_guest_sp
        fr.guest_bp <- ge_last_guest_bp
        fr.guest_rdi <- ge_last_guest_rdi
        fr.guest_rsi <- ge_last_guest_rsi
        fr.guest_rdx <- ge_last_guest_rdx
        fr.guest_rcx <- ge_last_guest_rcx
        fr.guest_r8 <- ge_last_guest_r8
        fr.guest_r9 <- ge_last_guest_r9
        fr.guest_rax <- ge_last_guest_rax
        fr.guest_rbx <- ge_last_guest_rbx
        fr.fault_word0 <- ge_fault_word0
        fr.fault_word1 <- ge_fault_word1
        fr.signal_stack_word0 <- ge_signal_stack_word0
        fr.signal_stack_word1 <- ge_signal_stack_word1
        fr.signal_stack_word_m1 <- ge_signal_stack_word_m1
        fr.fault_transfer_class <- ge_fault_transfer_class
        fr.signal_stack_symbol0 <- ge_signal_stack_symbol0
        fr.signal_stack_image0 <- ge_signal_stack_image0
        fr.signal_pc_symbol <- ge_signal_pc_symbol
        fr.signal_pc_image <- ge_signal_pc_image
        fr.signal_guest_pc <- ge_signal_guest_pc
        fr.fallback_guest_pc <- ge_fallback_guest_pc
        fr.signal_pc_valid <- ge_signal_pc_valid
        fr.signal_sp_valid <- ge_signal_sp_valid
        fr.signal_bp_valid <- ge_signal_bp_valid
        fr.signal_rdi_valid <- ge_signal_rdi_valid
        fr.signal_rsi_valid <- ge_signal_rsi_valid
        fr.signal_uctx <- ge_signal_uctx
        fr.signal_mctx <- ge_signal_mctx
        fr.signal_fault_addr_valid <- ge_signal_fault_addr_valid
        fr.signal_native_region_index <- ge_signal_native_region_index
        fr.pc_source <- ge_last_pc_source
        fr.pc_was_fallback <- ge_last_pc_was_fallback
        fr.pc_native_prot <- ge_pc_native_prot
        if fr.execution_stage < 6:
            fr.execution_stage <- 6
    if ge_guard_active != 0:
        if ge_guard_target_thread == 0.uintptr() or fault_thread == ge_guard_target_thread:
            ge_siglongjmp(ge_jmp_buf[0usize].ref[void&], 1)
        ge_cross_thread_signal_count <- ge_cross_thread_signal_count + 1u64
        ge_cross_thread_signal_guard_thread <- ge_guard_target_thread
        ge_cross_thread_signal_fault_thread <- fault_thread
        ge_cross_thread_signal_number <- sig.s32()
        if fr != null:
            fr.cross_thread_signal_count <- ge_cross_thread_signal_count
            fr.cross_thread_signal_guard_thread <- ge_guard_target_thread
            fr.cross_thread_signal_fault_thread <- fault_thread
            fr.cross_thread_signal_number <- sig.s32()
        if sig > 0 and sig < 128:
            ge_exit_now(128 + sig)
        ge_exit_now(1)

# ---- Orchestration plumbing (atomic core, part 2a; inert until swap) ----
@link_name(sigsetjmp)
extern ge_sigsetjmp(env: void&?, savemask: int) -> int
extern pthread_self() -> void&?
@link_name(_exit)
extern ge_exit_now(code: int) -> void
@link_name(pause)
extern ge_pause() -> int
extern memset(dest: mutable void&, value: int, n: usize) -> mutable void&
extern ElisaGuestExec_CurrentStackPointerAsm() -> uintptr
extern ElisaGuestExec_EnterMainEntryAsm(params: uintptr, exit_func: uintptr) -> void
extern ElisaGuestExec_CallMainEntryAsm(entry: uintptr, params: uintptr, exit_func: uintptr) -> void
extern ElisaGuestExec_JumpMainEntryAsm(entry: uintptr, params: uintptr, exit_func: uintptr) -> void
extern ElisaGuestExec_JumpMainEntryOnStackAsm(entry: uintptr, params: uintptr, exit_func: uintptr, stack_top: uintptr) -> void
extern ElisaGuestExec_AeroLibFallbackUnknownStubAsm() -> u64

global mutable ge_fork_report_addr: uintptr = 0.uintptr()
global mutable ge_guard_target_thread: uintptr = 0.uintptr()

def ge_pthread_self() -> uintptr:
    return pthread_self().uintptr()

def ge_memset(dst: void&?, value: int, n: usize) -> void&?:
    if dst == null:
        return dst
    can Memory.Allocate:
        _ = memset(dst.cast[mutable void&], value, n)
    return dst

def ge_record_fallback_pc(pc: uintptr, source: s32) -> void:
    if pc == 0.uintptr():
        return
    ge_fallback_guest_pc <- pc
    ge_last_guest_pc <- pc
    ge_last_pc_was_fallback <- 1
    ge_last_pc_source <- source
    fr: ElisaGuestExecForkReport&? = ge_fork_report
    if fr != null:
        fr.fallback_guest_pc <- pc
        fr.guest_pc <- pc
        fr.pc_source <- source
        fr.pc_was_fallback <- 1

def ge_current_stack_pointer() -> uintptr:
    static if ARCH_X86_64 and not PLATFORM_WINDOWS:
        return ElisaGuestExec_CurrentStackPointerAsm()
    static else:
        return 0.uintptr()

def ge_map_shared_anon_flags() -> int:
    static if PLATFORM_APPLE:
        return 0x0001 | 0x1000
    static else:
        return 0x0001 | 0x20

def ge_reset_fork_report() -> void:
    if ge_fork_report != null:
        _ = ge_memset(ge_addr_to_ptr(ge_fork_report_addr), 0, 4096usize)

def ge_ensure_fork_report() -> s32:
    static if PLATFORM_WINDOWS:
        return 0
    static else:
        if ge_fork_report != null:
            ge_reset_fork_report()
            return 0
        mapped: uintptr = mmap(0.uintptr(), 4096usize, 3, ge_map_shared_anon_flags(), -1, 0i64)
        if mapped == ge_map_failed():
            ge_fork_report <- null
            ge_fork_report_addr <- 0.uintptr()
            return -1
        ge_fork_report_addr <- mapped
        trusted Unsafe.PointerCast:
            ge_fork_report <- mapped.cast[ElisaGuestExecForkReport&?]
        ge_reset_fork_report()
        return 0

@c_abi(c)
def ge_default_exit(code: int) -> void:
    _ = code
    while true:
        _ = ge_pause()

@c_abi(c)
def ge_guarded_exit(code: int) -> void:
    _ = code
    ge_last_status <- 0
    fr: ElisaGuestExecForkReport&? = ge_fork_report
    if fr != null:
        if fr.execution_stage < 4:
            fr.execution_stage <- 4

def ge_call_main_entry(params: mutable GuestEntryParams&, exit_func: uintptr) -> void:
    ef: mutable uintptr = exit_func
    if ef == 0.uintptr():
        ef <- ge_default_exit as uintptr
    ElisaGuestExec_CallMainEntryAsm(params.entry_addr, params.ref[void&].uintptr(), ef)

def ge_jump_main_entry(params: mutable GuestEntryParams&, exit_func: uintptr) -> void:
    ef: mutable uintptr = exit_func
    if ef == 0.uintptr():
        ef <- ge_default_exit as uintptr
    ge_prejump_rdi <- params.ref[void&].uintptr()
    ge_prejump_rsi <- ef
    ge_prejump_rsp <- params.ref[void&].uintptr()
    fr: ElisaGuestExecForkReport&? = ge_fork_report
    if fr != null:
        fr.prejump_rdi <- ge_prejump_rdi
        fr.prejump_rsi <- ge_prejump_rsi
        fr.prejump_rsp <- ge_prejump_rsp
    if guest_exec_main_stack_top != 0.uintptr():
        ElisaGuestExec_JumpMainEntryOnStackAsm(params.entry_addr, ge_prejump_rdi, ef, guest_exec_main_stack_top)
    ElisaGuestExec_JumpMainEntryAsm(params.entry_addr, ge_prejump_rdi, ef)

def ge_absorb_fork_report() -> void:
    fr: ElisaGuestExecForkReport&? = ge_fork_report
    if fr == null:
        return
    if fr.status == 0 and fr.signal == 0 and fr.execution_stage >= 4:
        fr.status <- -11
        if fr.guest_pc == 0.uintptr() and fr.signal_pc_valid == 0:
            ge_record_fallback_pc(fr.entry_addr, GE_PC_SOURCE_FALLBACK_PARENT_SILENT_CHILD)
    if fr.status < 0 and fr.guest_pc == 0.uintptr() and fr.signal_pc_valid == 0 and fr.entry_addr != 0.uintptr():
        ge_record_fallback_pc(fr.entry_addr, GE_PC_SOURCE_FALLBACK_PARENT_STATUS)
    if fr.status != 0:
        ge_last_status <- fr.status
    if fr.signal != 0:
        ge_last_signal <- fr.signal
    if fr.fault_address != 0.uintptr() or fr.status < 0:
        ge_last_fault_address <- fr.fault_address
    if fr.guest_pc != 0.uintptr():
        ge_last_guest_pc <- fr.guest_pc
    if fr.guest_sp != 0.uintptr():
        ge_last_guest_sp <- fr.guest_sp
    if fr.guest_bp != 0.uintptr():
        ge_last_guest_bp <- fr.guest_bp
    if fr.guest_rdi != 0.uintptr():
        ge_last_guest_rdi <- fr.guest_rdi
    if fr.guest_rsi != 0.uintptr():
        ge_last_guest_rsi <- fr.guest_rsi
    if fr.guest_rax != 0.uintptr():
        ge_last_guest_rax <- fr.guest_rax
    if fr.guest_rbx != 0.uintptr():
        ge_last_guest_rbx <- fr.guest_rbx
    if fr.guest_rdx != 0.uintptr():
        ge_last_guest_rdx <- fr.guest_rdx
    if fr.guest_rcx != 0.uintptr():
        ge_last_guest_rcx <- fr.guest_rcx
    if fr.guest_r8 != 0.uintptr():
        ge_last_guest_r8 <- fr.guest_r8
    if fr.guest_r9 != 0.uintptr():
        ge_last_guest_r9 <- fr.guest_r9
    if fr.cross_thread_signal_count != 0u64:
        ge_cross_thread_signal_count <- fr.cross_thread_signal_count
        ge_cross_thread_signal_guard_thread <- fr.cross_thread_signal_guard_thread
        ge_cross_thread_signal_fault_thread <- fr.cross_thread_signal_fault_thread
        ge_cross_thread_signal_number <- fr.cross_thread_signal_number
    if fr.expected_entry_params != 0.uintptr():
        ge_expected_entry_params <- fr.expected_entry_params
    if fr.expected_stack_word0 != 0.uintptr() or fr.expected_stack_word1 != 0.uintptr():
        ge_expected_stack_word0 <- fr.expected_stack_word0
        ge_expected_stack_word1 <- fr.expected_stack_word1
    if fr.entry_stack_word0 != 0.uintptr() or fr.entry_stack_word1 != 0.uintptr():
        ge_entry_stack_word0 <- fr.entry_stack_word0
        ge_entry_stack_word1 <- fr.entry_stack_word1
    if fr.entry_native_word0 != 0.uintptr() or fr.entry_native_word1 != 0.uintptr():
        ge_entry_native_word0 <- fr.entry_native_word0
        ge_entry_native_word1 <- fr.entry_native_word1
    if fr.entry_native_prot != 0u32:
        ge_entry_native_prot <- fr.entry_native_prot
    if fr.prejump_rdi != 0.uintptr():
        ge_prejump_rdi <- fr.prejump_rdi
    if fr.prejump_rsi != 0.uintptr():
        ge_prejump_rsi <- fr.prejump_rsi
    if fr.prejump_rsp != 0.uintptr():
        ge_prejump_rsp <- fr.prejump_rsp
    if fr.signal_pc_valid != 0:
        ge_signal_pc_valid <- 1
        ge_signal_guest_pc <- fr.signal_guest_pc
        if fr.pc_was_fallback == 0:
            ge_last_guest_pc <- ge_signal_guest_pc
    if fr.signal_sp_valid != 0:
        ge_signal_sp_valid <- fr.signal_sp_valid
    if fr.signal_bp_valid != 0:
