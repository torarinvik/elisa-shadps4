    return c_GuestExec_LastGuestRBX()

def GuestExec_ExpectedEntryParams() -> VAddr:
    return c_GuestExec_ExpectedEntryParams()

def GuestExec_ExpectedStackWord0() -> VAddr:
    return c_GuestExec_ExpectedStackWord0()

def GuestExec_ExpectedStackWord1() -> VAddr:
    return c_GuestExec_ExpectedStackWord1()

def GuestExec_EntryStackWord0() -> VAddr:
    return c_GuestExec_EntryStackWord0()

def GuestExec_EntryStackWord1() -> VAddr:
    return c_GuestExec_EntryStackWord1()

def GuestExec_FaultWord0() -> VAddr:
    return c_GuestExec_FaultWord0()

def GuestExec_FaultWord1() -> VAddr:
    return c_GuestExec_FaultWord1()

def GuestExec_SignalStackWord0() -> VAddr:
    return c_GuestExec_SignalStackWord0()

def GuestExec_SignalStackWord1() -> VAddr:
    return c_GuestExec_SignalStackWord1()

def GuestExec_RecordLoad() -> void:
    if guest_exec_execution_stage < GUEST_EXEC_STAGE_LOAD:
        guest_exec_execution_stage <- GUEST_EXEC_STAGE_LOAD

def GuestExec_RecordLink() -> void:
    if guest_exec_execution_stage < GUEST_EXEC_STAGE_LINK:
        guest_exec_execution_stage <- GUEST_EXEC_STAGE_LINK

def GuestExec_RecordFirstBoundary(reason: s32) -> void:
    if guest_exec_main_run_count == 0:
        return
    guest_exec_first_boundary_reached <- true
    if guest_exec_first_boundary_reason == GUEST_EXEC_BOUNDARY_REASON_NONE:
        guest_exec_first_boundary_reason <- reason
    guest_exec_execution_stage <- GUEST_EXEC_STAGE_FIRST_BOUNDARY
    c_GuestExec_ReportFirstBoundary(reason)

def GuestExec_AbsorbNativeBoundaryReport() -> void:
    reported_stage: s32 = c_GuestExec_ReportedExecutionStage()
    if reported_stage > guest_exec_execution_stage:
        guest_exec_execution_stage <- reported_stage
    if c_GuestExec_ReportedBoundaryReached() == 0:
        return
    guest_exec_first_boundary_reached <- true
    reported_reason: s32 = c_GuestExec_ReportedBoundaryReason()
    if guest_exec_first_boundary_reason == GUEST_EXEC_BOUNDARY_REASON_NONE and reported_reason != GUEST_EXEC_BOUNDARY_REASON_NONE:
        guest_exec_first_boundary_reason <- reported_reason
    if guest_exec_execution_stage < GUEST_EXEC_STAGE_FIRST_BOUNDARY:
        guest_exec_execution_stage <- GUEST_EXEC_STAGE_FIRST_BOUNDARY

def GuestExec_RecordLastHle(module: static u8&, symbol: static u8&) -> void:
    guest_exec_last_hle_module <- module
    guest_exec_last_hle_symbol <- symbol

def GuestExec_LastHleModule() -> static u8&?:
    return guest_exec_last_hle_module

def GuestExec_LastHleSymbol() -> static u8&?:
    return guest_exec_last_hle_symbol

def GuestExec_HasReachedFirstBoundary() -> bool:
    return guest_exec_first_boundary_reached

def GuestExec_FirstBoundaryReason() -> s32:
    if guest_exec_main_run_count == 0:
        return GUEST_EXEC_BOUNDARY_REASON_NONE
    if not GuestExec_IsSupported():
        return GUEST_EXEC_BOUNDARY_REASON_UNSUPPORTED_HOST
    if guest_exec_probe_mode:
        return GUEST_EXEC_BOUNDARY_REASON_PROBE_ONLY
    if guest_exec_first_boundary_reason != GUEST_EXEC_BOUNDARY_REASON_NONE:
        return guest_exec_first_boundary_reason
    status: mutable s32 = guest_exec_last_game_execution_status
    if status == 0:
        status <- GuestExec_LastStatus()
    if status == -3:
        return GUEST_EXEC_BOUNDARY_REASON_TIMEOUT
    if status < 0:
        return GUEST_EXEC_BOUNDARY_REASON_HOST_CRASH
    return GUEST_EXEC_BOUNDARY_REASON_EXITED_BEFORE_BOUNDARY

def GuestExec_FirstBoundaryReasonName() -> static u8&:
    return GuestExec_BoundaryReasonName(GuestExec_FirstBoundaryReason())

def GuestExec_ExecutionStage() -> s32:
    if guest_exec_execution_stage >= GUEST_EXEC_STAGE_GUARDED_ENTRY or guest_exec_first_boundary_reached:
        return guest_exec_execution_stage
    if guest_exec_main_run_count == 0:
        if guest_exec_execution_stage > GUEST_EXEC_STAGE_NONE:
            return guest_exec_execution_stage
        return GUEST_EXEC_STAGE_NONE
    if guest_exec_execution_stage > GUEST_EXEC_STAGE_NONE:
        return guest_exec_execution_stage
    return GUEST_EXEC_STAGE_HANDOFF

def GuestExec_ClassifyGameExecutionStage() -> s32:
    if guest_exec_main_run_count == 0:
        guest_exec_last_game_execution_status <- 0
        return 0
    if not GuestExec_IsSupported():
        guest_exec_last_game_execution_status <- -2
        return -2
    if guest_exec_probe_mode:
        guest_exec_last_game_execution_status <- 2
        return 2
    guest_exec_last_game_execution_status <- GuestExec_LastStatus()
    return guest_exec_last_game_execution_status

def GuestExec_ClassifyFirstBoundary() -> s32:
    if guest_exec_main_run_count == 0:
        return GUEST_EXEC_BOUNDARY_NOT_REACHED
    if not GuestExec_IsSupported():
        return GUEST_EXEC_BOUNDARY_UNSUPPORTED_HOST
    if guest_exec_probe_mode:
        return GUEST_EXEC_BOUNDARY_ARMED_PROBE_ONLY
    if guest_exec_first_boundary_reached:
        return GUEST_EXEC_BOUNDARY_FIRST_HLE_IMPORT
    status: mutable s32 = guest_exec_last_game_execution_status
    if status == 0:
        status <- GuestExec_LastStatus()
    if status == -3:
        return GUEST_EXEC_BOUNDARY_TIMEOUT
    if status == -11 and GuestExec_LastSignal() == 0:
        return GUEST_EXEC_BOUNDARY_EXITED_BEFORE_BOUNDARY
    if status < 0:
        return GUEST_EXEC_BOUNDARY_PRE_BOUNDARY_FAULT
    return GUEST_EXEC_BOUNDARY_EXITED_BEFORE_BOUNDARY

def GuestExec_EmitCusaArtifactStage() -> void:
    c_GuestExec_EmitCusaArtifactStage()

