def GuestExec_HasReachedFirstBoundary() -> bool:
    return guest_exec_first_boundary_reached

def GuestExec_FirstBoundaryReason() -> s32:
    if guest_exec_main_run_count == 0:
        return GUEST_EXEC_BOUNDARY_REASON_NONE
    if not GuestExec_IsSupported():
        return GUEST_EXEC_BOUNDARY_REASON_UNSUPPORTED_HOST
    if guest_exec_probe_mode:
        return GUEST_EXEC_BOUNDARY_REASON_PROBE_ONLY
    if guest_exec_first_boundary_reason != GUEST_EXEC_BOUNDARY_REASON_NONE:
        return guest_exec_first_boundary_reason
    status: mutable s32 = guest_exec_last_game_execution_status
    if status == 0:
        status <- GuestExec_LastStatus()
    if status == -3:
        return GUEST_EXEC_BOUNDARY_REASON_TIMEOUT
    if status < 0:
        return GUEST_EXEC_BOUNDARY_REASON_HOST_CRASH
    return GUEST_EXEC_BOUNDARY_REASON_EXITED_BEFORE_BOUNDARY

def GuestExec_FirstBoundaryReasonName() -> static u8&:
    return GuestExec_BoundaryReasonName(GuestExec_FirstBoundaryReason())

def GuestExec_ExecutionStage() -> s32:
    if guest_exec_execution_stage >= GUEST_EXEC_STAGE_GUARDED_ENTRY or guest_exec_first_boundary_reached:
        return guest_exec_execution_stage
    if guest_exec_main_run_count == 0:
        if guest_exec_execution_stage > GUEST_EXEC_STAGE_NONE:
            return guest_exec_execution_stage
        return GUEST_EXEC_STAGE_NONE
    if guest_exec_execution_stage > GUEST_EXEC_STAGE_NONE:
        return guest_exec_execution_stage
    return GUEST_EXEC_STAGE_HANDOFF

def GuestExec_ClassifyGameExecutionStage() -> s32:
    if guest_exec_main_run_count == 0:
        guest_exec_last_game_execution_status <- 0
        return 0
    if not GuestExec_IsSupported():
        guest_exec_last_game_execution_status <- -2
        return -2
    if guest_exec_probe_mode:
        guest_exec_last_game_execution_status <- 2
        return 2
    guest_exec_last_game_execution_status <- GuestExec_LastStatus()
    return guest_exec_last_game_execution_status

def GuestExec_ClassifyFirstBoundary() -> s32:
    if guest_exec_main_run_count == 0:
        return GUEST_EXEC_BOUNDARY_NOT_REACHED
    if not GuestExec_IsSupported():
        return GUEST_EXEC_BOUNDARY_UNSUPPORTED_HOST
    if guest_exec_probe_mode:
        return GUEST_EXEC_BOUNDARY_ARMED_PROBE_ONLY
    if guest_exec_first_boundary_reached:
        return GUEST_EXEC_BOUNDARY_FIRST_HLE_IMPORT
    status: mutable s32 = guest_exec_last_game_execution_status
    if status == 0:
        status <- GuestExec_LastStatus()
    if status == -3:
        return GUEST_EXEC_BOUNDARY_TIMEOUT
    if status == -11 and GuestExec_LastSignal() == 0:
        return GUEST_EXEC_BOUNDARY_EXITED_BEFORE_BOUNDARY
    if status < 0:
        return GUEST_EXEC_BOUNDARY_PRE_BOUNDARY_FAULT
    return GUEST_EXEC_BOUNDARY_EXITED_BEFORE_BOUNDARY

def GuestExec_EmitCusaArtifactStage() -> void:
    ElisaGuestExec_EmitCusaArtifactStage()

def GuestExec_EmitCusaArtifactSummary(module_count: u64, total_imports: u64, unresolved_imports: u64, relocated_imports: u64, native_hle_resolved: u64, prx_export_resolved: u64, aerolib_fallback_resolved: u64, hle_symbols: u64, entry: u64, main_entry: u64, guarded_status: s32, last_signal: s32, fault_address: u64) -> void:
