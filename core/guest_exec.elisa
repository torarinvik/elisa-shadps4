def GuestExec_CusaPutFormatted(line: mutable u8&, size: usize, written: int) -> void:
    if written > 0 and written.usize() < size:
        _ = puts(line) can Console.Write

# Print the generic HLE call ring (every guest->HLE boundary crossing, recorded
# by the linker's recorder-prefix thunks) oldest-to-newest as CUSA07399_ARTIFACT
# lines, so the last calls before a crash are visible without a debugger.
def GuestExec_DumpHleCallRingLine(line: mutable u8&, size: usize, written: int) -> void can[Unsafe.SegmentMutation, Segment.Host]:
    if written > 0 and written.usize() < size:
        line[written.usize()] <- 0x0A
        can Unsafe.SegmentMutation, Segment.Host:
            _ = ge_raw_write(1, (&line).cast[void&], (written + 1).usize())

def GuestExec_DumpHleCallRing() -> void can[Console.Format, Unsafe.SegmentMutation, Segment.Host]:
    total: u64 = Linker_HleCallRingTotal()
    count: u64 = Linker_HleCallRingCount()
    start: u64 = total - count
    line: mutable u8[256] = zeroed
    wp: int = snprintf(line[0], 256, "CUSA07399_ARTIFACT reloc_probe addr=0x%llx count=%llu value=0x%llx type=0x%x path=%u", Linker_RelocProbeAddr(), Linker_RelocProbeCount(), Linker_RelocProbeValue(), Linker_RelocProbeType(), Linker_RelocProbePath()) can Console.Format
    can Unsafe.SegmentMutation, Segment.Host:
        GuestExec_DumpHleCallRingLine(line[0], 256, wp)
    tp: int = snprintf(line[0], 256, "CUSA07399_ARTIFACT init_trampoline addr=0x%llx captured=%llu cap_calls=%llu modcount=%llu", Linker_InitTrampolineAddr(), Linker_DeferredInitCount(), Linker_CaptureDbgCalls(), Linker_CaptureModCount()) can Console.Format
    can Unsafe.SegmentMutation, Segment.Host:
        GuestExec_DumpHleCallRingLine(line[0], 256, tp)
    dbgi: mutable usize = 0
    can Unsafe.AssumeProgress:
        while dbgi < Linker_CaptureDbgCalls().usize() and dbgi < 16:
            decreases 16 - dbgi
            dl: int = snprintf(line[0], 256, "CUSA07399_ARTIFACT init_dbg idx=%llu base=0x%llx preinit_size=0x%llx init_size=0x%llx preinit_va=0x%llx", dbgi.u64(), Linker_CaptureDbgBase(dbgi.u64()), Linker_CaptureDbgVa(dbgi.u64()), Linker_CaptureDbgSize(dbgi.u64()), Linker_CaptureDbgEntry0(dbgi.u64())) can Console.Format
            can Unsafe.SegmentMutation, Segment.Host:
                GuestExec_DumpHleCallRingLine(line[0], 256, dl)
            dbgi <- dbgi + 1
    # Fallback-slot list: imports that resolved to the aerolib fallback stub
    # (i.e. Elisa could not resolve them to a real HLE/PRX export). A missing
    # libc/runtime init export here is the smoking gun for the skipped boot path.
    fb_count: u32 = Linker_FallbackSlotCount()
    fbw: int = snprintf(line[0], 256, "CUSA07399_ARTIFACT fallback_slot_count=%u", fb_count) can Console.Format
    can Unsafe.SegmentMutation, Segment.Host:
        GuestExec_DumpHleCallRingLine(line[0], 256, fbw)
    fi: mutable u32 = 0
    can Unsafe.AssumeProgress:
        while fi < fb_count and fi < 200:
            decreases 200 - fi
            fbl: int = snprintf(line[0], 256, "CUSA07399_ARTIFACT fallback_slot idx=%u va=0x%llx module=%s symbol=%s rel_type=%u", fi, Linker_FallbackSlotVaAt(fi), Linker_FallbackSlotModuleAt(fi), Linker_FallbackSlotSymbolAt(fi), Linker_FallbackSlotRelTypeAt(fi)) can Console.Format
            can Unsafe.SegmentMutation, Segment.Host:
                GuestExec_DumpHleCallRingLine(line[0], 256, fbl)
            fi <- fi + 1

    # Module-start oracle trace: which modules ran Module_Start and their
    # init-array/DT_INIT execution. Survives the guard longjmp (global buffer),
    # so it shows whether e.g. libc.prx's init actually executed before the crash.
    ms_count: u64 = Module_StartOracleTraceCount()
    msw: int = snprintf(line[0], 256, "CUSA07399_ARTIFACT modstart_count=%llu", ms_count) can Console.Format
    can Unsafe.SegmentMutation, Segment.Host:
        GuestExec_DumpHleCallRingLine(line[0], 256, msw)
    mi: mutable u64 = 0
    while mi < ms_count:
        msl: int = snprintf(line[0], 256, "CUSA07399_ARTIFACT modstart seq=%llu phase=%s module=%s label=%s entry=0x%llx count=%llu ret=%d", mi + 1, Module_StartOracleTracePhase(mi), Module_StartOracleTraceModule(mi), Module_StartOracleTraceLabel(mi), Module_StartOracleTraceEntry(mi).u64(), Module_StartOracleTraceCountField(mi), Module_StartOracleTraceRet(mi)) can Console.Format
        can Unsafe.SegmentMutation, Segment.Host:
            GuestExec_DumpHleCallRingLine(line[0], 256, msl)
        mi <- mi + 1
    written0: int = snprintf(line[0], 256, "CUSA07399_ARTIFACT hle_call_ring_total=%llu count=%llu", total, count) can Console.Format
    can Unsafe.SegmentMutation, Segment.Host:
        GuestExec_DumpHleCallRingLine(line[0], 256, written0)
    k: mutable u64 = 0
    while k < count:
        seq: u64 = start + k
        sym: static u8&? = Linker_HleCallRingSymbolAt(seq)
        target: u64 = Linker_HleCallRingTargetAt(seq)
        return_pc: u64 = Linker_HleCallRingReturnAt(seq)
        rdi: u64 = Linker_HleCallRingRdiAt(seq)
        rsi: u64 = Linker_HleCallRingRsiAt(seq)
        rdx: u64 = Linker_HleCallRingRdxAt(seq)
        if k + 16 >= count:
            GuestExec_RecordHleRingSymbol(seq, sym)
            GuestExec_RecordHleRingTarget(seq, target)
        sym_text: static u8& = sym if sym != null else "(null)"
        written: int = snprintf(line[0], 256, "CUSA07399_ARTIFACT hle_call seq=%llu symbol=%s target=0x%llx return=0x%llx rdi=0x%llx rsi=0x%llx rdx=0x%llx", seq, sym_text, target, return_pc, rdi, rsi, rdx) can Console.Format
        can Unsafe.SegmentMutation, Segment.Host:
            GuestExec_DumpHleCallRingLine(line[0], 256, written)
        k <- k + 1
    oracle_count: u64 = c_GuestExec_HleOracleTraceCount()
    written1: int = snprintf(line[0], 256, "CUSA07399_ARTIFACT hle_oracle_count=%llu total=%llu", oracle_count, ge_runtime_hle_sequence) can Console.Format
    can Unsafe.SegmentMutation, Segment.Host:
        GuestExec_DumpHleCallRingLine(line[0], 256, written1)
    oracle_start: u64 = ge_runtime_hle_sequence - oracle_count
    j: mutable u64 = 0
    while j < oracle_count:
        abs_seq: u64 = oracle_start + j + 1
        slot: u64 = ((abs_seq - 1) & 2047)
        module: static u8& = c_GuestExec_HleOracleTraceModule(slot)
        symbol: static u8& = c_GuestExec_HleOracleTraceSymbol(slot)
        return_pc: uintptr = c_GuestExec_HleOracleTraceReturn(slot)
        result: uintptr = c_GuestExec_HleOracleTraceResult(slot)
        rdi: uintptr = c_GuestExec_HleOracleTraceRdi(slot)
        rsi: uintptr = c_GuestExec_HleOracleTraceRsi(slot)
        rdx: uintptr = c_GuestExec_HleOracleTraceRdx(slot)
        written_oracle: int = snprintf(line[0], 256, "CUSA07399_ARTIFACT hle_oracle seq=%llu module=%s symbol=%s return=0x%llx result=0x%llx rdi=0x%llx rsi=0x%llx rdx=0x%llx", abs_seq, module, symbol, return_pc.u64(), result.u64(), rdi.u64(), rsi.u64(), rdx.u64()) can Console.Format
        can Unsafe.SegmentMutation, Segment.Host:
            GuestExec_DumpHleCallRingLine(line[0], 256, written_oracle)
        j <- j + 1

def ElisaGuestExec_EmitCusaArtifactStage() -> void:
    _ = puts("CUSA07399_EXEC_STAGE stage=load link=pass handoff=pass") can Console.Write

def ElisaGuestExec_EmitCusaArtifactSummary(module_count: u64, total_imports: u64, unresolved_imports: u64, relocated_imports: u64, native_hle_resolved: u64, prx_export_resolved: u64, aerolib_fallback_resolved: u64, hle_symbols: u64, entry: u64, main_entry: u64, guarded_status: s32, last_signal: s32, fault_address: u64, last_guest_pc: u64, boundary_status: s32, boundary_reason: s32, execution_stage: s32) -> void:
    can Console.Format, Console.Write:
        line: mutable u8[512] = zeroed
        written: mutable int = snprintf(line[0], 512, "CUSA07399_ARTIFACT module_count=%llu total_imports=%llu unresolved_imports=%llu relocated_imports=%llu native_hle=%llu prx_export=%llu aerolib_fallback=%llu hle_symbols=%llu", module_count, total_imports, unresolved_imports, relocated_imports, native_hle_resolved, prx_export_resolved, aerolib_fallback_resolved, hle_symbols)
        GuestExec_CusaPutFormatted(line[0], 512, written)
        written <- snprintf(line[0], 512, "CUSA07399_ARTIFACT entry=0x%llx main_entry=0x%llx guarded_status=%d last_signal=%d fault=0x%llx last_guest_pc=0x%llx", entry, main_entry, guarded_status, last_signal, fault_address, last_guest_pc)
        GuestExec_CusaPutFormatted(line[0], 512, written)
        written <- snprintf(line[0], 512, "CUSA07399_ARTIFACT execution_stage=%d boundary_status=%d boundary_reason=%d", execution_stage, boundary_status, boundary_reason)
        GuestExec_CusaPutFormatted(line[0], 512, written)
        written <- snprintf(line[0], 512, "CUSA07399_ARTIFACT failed_relocations=%llu", guest_exec_failed_relocation_count)
        GuestExec_CusaPutFormatted(line[0], 512, written)

def ElisaGuestExec_EmitCusaArtifactModule(module: static u8&?, host: static u8&?, shared: s32, relocations: u64, imports: u64, resolved: u64, native_hle: u64, prx_export: u64, aerolib_fallback: u64, malformed: u64, unresolved: u64) -> void:
    can Console.Format, Console.Write:
        line: mutable u8[512] = zeroed
        module_text: static u8& = module if module != null else ""
        host_text: static u8& = host if host != null else ""
        written: int = snprintf(line[0], 512, "CUSA07399_ARTIFACT module=%s host=%s shared=%d relocations=%llu imports=%llu resolved=%llu native_hle=%llu prx_export=%llu aerolib_fallback=%llu malformed=%llu unresolved=%llu", module_text, host_text, shared, relocations, imports, resolved, native_hle, prx_export, aerolib_fallback, malformed, unresolved)
        GuestExec_CusaPutFormatted(line[0], 512, written)

def ElisaGuestExec_EmitCusaArtifactImport(source: static u8&?, nid: static u8&?, library: static u8&?, module: static u8&?, subsystem: static u8&?, resolution: u64) -> void:
    can Console.Format, Console.Write:
        line: mutable u8[512] = zeroed
        source_text: static u8& = source if source != null else ""
        nid_text: static u8& = nid if nid != null else ""
        library_text: static u8& = library if library != null else ""
        module_text: static u8& = module if module != null else ""
        subsystem_text: static u8& = subsystem if subsystem != null else ""
        written: int = snprintf(line[0], 512, "CUSA07399_ARTIFACT fallback_import source=%s nid=%s library=%s module=%s subsystem=%s resolution=%llu", source_text, nid_text, library_text, module_text, subsystem_text, resolution)
        GuestExec_CusaPutFormatted(line[0], 512, written)

def ElisaGuestExec_EmitCusaArtifactLastHle(module: static u8&?, symbol: static u8&?) -> void:
    can Console.Format, Console.Write:
        line: mutable u8[256] = zeroed
        module_text: static u8& = module if module != null else ""
        symbol_text: static u8& = symbol if symbol != null else ""
        written: int = snprintf(line[0], 256, "CUSA07399_ARTIFACT last_hle_module=%s last_hle_symbol=%s", module_text, symbol_text)
        GuestExec_CusaPutFormatted(line[0], 256, written)

def ElisaGuestExec_EmitCusaArtifactStringKV(key: static u8&?, value: static u8&?) -> void:
    can Console.Format, Console.Write:
        line: mutable u8[256] = zeroed
        key_text: static u8& = key if key != null else "key"
        value_text: static u8& = value if value != null else ""
        written: int = snprintf(line[0], 256, "CUSA07399_ARTIFACT %s=%s", key_text, value_text)
        GuestExec_CusaPutFormatted(line[0], 256, written)

def ElisaGuestExec_EmitCusaArtifactKV(key: static u8&?, value: u64) -> void:
    can Console.Format, Console.Write:
        line: mutable u8[256] = zeroed
        key_text: static u8& = key if key != null else "key"
        written: int = snprintf(line[0], 256, "CUSA07399_ARTIFACT %s=%llu", key_text, value)
        GuestExec_CusaPutFormatted(line[0], 256, written)
