    ge_last_guest_bp <- 0.uintptr().cast[GuestFramePointer]
    ge_last_guest_rdi <- 0.uintptr()
    ge_last_guest_rsi <- 0.uintptr()
    ge_last_guest_rdx <- 0.uintptr()
    ge_last_guest_rcx <- 0.uintptr()
    ge_last_guest_r8 <- 0.uintptr()
    ge_last_guest_r9 <- 0.uintptr()
    ge_last_guest_rax <- 0.uintptr()
    ge_last_guest_rbx <- 0.uintptr()
    ge_expected_entry_params <- 0.uintptr()
    ge_expected_stack_word0 <- 0.uintptr()
    ge_expected_stack_word1 <- 0.uintptr()
    ge_entry_stack_word0 <- 0.uintptr()
    ge_entry_stack_word1 <- 0.uintptr()
    ge_entry_native_word0 <- 0.uintptr()
    ge_entry_native_word1 <- 0.uintptr()
    ge_prejump_rdi <- 0.uintptr()
    ge_prejump_rsi <- 0.uintptr()
    ge_prejump_rsp <- 0.uintptr()
    ge_signal_guest_pc <- 0.uintptr().cast[GuestPC]
    ge_fallback_guest_pc <- 0.uintptr().cast[GuestPC]
    ge_signal_pc_valid <- 0
    ge_signal_sp_valid <- 0
    ge_signal_bp_valid <- 0
    ge_signal_rdi_valid <- 0
    ge_signal_rsi_valid <- 0
    ge_signal_uctx <- 0.uintptr().cast[SignalContextPtr]
    ge_signal_mctx <- 0.uintptr().cast[MachineContextPtr]
    ge_signal_fault_addr_valid <- 0
    ge_signal_native_region_index <- -1
    ge_pc_sampler_count <- 0
    ge_pc_sampler_last_pc <- 0.uintptr().cast[GuestPC]
    ge_pc_sampler_last_sp <- 0.uintptr().cast[GuestStackPointer]
    pc_sample_i: mutable usize = 0
    while pc_sample_i < GE_PC_SAMPLE_CAP:
        ge_pc_sampler_samples[pc_sample_i] <- 0.uintptr().cast[GuestPC]
        ge_pc_sampler_sps[pc_sample_i] <- 0.uintptr().cast[GuestStackPointer]
        pc_sample_i <- pc_sample_i + 1
    ge_last_pc_source <- GE_PC_SOURCE_NONE
    ge_fault_word0 <- 0.uintptr()
    ge_fault_word1 <- 0.uintptr()
    ge_signal_stack_word0 <- 0.uintptr()
    ge_signal_stack_word1 <- 0.uintptr()
    ge_signal_stack_word_m1 <- 0.uintptr()
    ge_fault_transfer_class <- 0
    ge_signal_stack_symbol0 <- ""
    ge_signal_stack_image0 <- ""
    ge_signal_pc_symbol <- ""
    ge_signal_pc_image <- ""
    ge_entry_native_prot <- 0xffffffff
    ge_pc_native_prot <- 0xffffffff
    ge_last_pc_was_fallback <- 0
    ge_sse4a_extrq_handled_count <- 0
    ge_sse4a_insertq_handled_count <- 0
    ge_sse4a_last_pc <- 0.uintptr()
    ge_sse4a_last_word <- 0
    ge_boundary_callback_count <- 0
    ge_boundary_callback_reason <- 0
    ge_synthetic_observed_argc <- 0
    ge_synthetic_observed_argv0 <- 0.uintptr()
    ge_synthetic_observed_entry <- 0.uintptr()
    ge_synthetic_observed_params <- 0.uintptr()
    ge_synthetic_observed_exit_func <- 0.uintptr()
    ge_synthetic_observed_stack <- 0.uintptr()
    ge_aerolib_fallback_caller_pc <- 0.uintptr()
