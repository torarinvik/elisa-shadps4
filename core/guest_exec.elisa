def GuestExec_RecordHandoff(entry_addr: VAddr, argc: int, is_main_executable: bool) -> void:
    guest_exec_last_entry_addr <- entry_addr
    guest_exec_last_argc <- argc
    guest_exec_run_count <- guest_exec_run_count + 1
    if is_main_executable:
        guest_exec_last_main_entry_addr <- entry_addr
        guest_exec_main_run_count <- guest_exec_main_run_count + 1
        guest_exec_execution_stage <- GUEST_EXEC_STAGE_HANDOFF

def GuestExec_SetEntryArg(index: usize, arg: static u8&?) -> void:
    if index >= 33:
        return
    guest_exec_last_argv[index] <- arg
    if index == 0:
        guest_exec_last_argv0 <- arg

def GuestExec_ClearEntryArgs() -> void:
    i: mutable usize = 0
    while i < 33:
        guest_exec_last_argv[i] <- null
        i <- i + 1
    guest_exec_last_argv0 <- null

def GuestExec_EntryArgc() -> int:
    return guest_exec_last_argc

def GuestExec_EntryArgv() -> u8&?:
    return (&guest_exec_last_argv[0]).cast[u8&?]

def GuestExec_FillEntryParamsArgv(params: mutable GuestEntryParams&, argc: int, argv0: void&?) -> void:
    i: mutable usize = 0
    while i < 33:
        params.argv[i] <- null
        i <- i + 1
    if argv0 != null:
        params.argv[0] <- argv0.cast[static u8&?]
        return
    i <- 0
    limit: mutable usize = argc.usize()
    if limit > 33:
        limit <- 33
    while i < limit:
        params.argv[i] <- guest_exec_last_argv[i]
        i <- i + 1
    if params.argv[0] == null and guest_exec_last_argv0 != null:
        params.argv[0] <- guest_exec_last_argv0

def GuestExec_RecordLastModuleSymbol(module: static u8&, symbol: static u8&) -> void:
    guest_exec_last_module <- module
    guest_exec_last_symbol <- symbol

def GuestExec_LastModule() -> static u8&?:
    return guest_exec_last_module

def GuestExec_LastSymbol() -> static u8&?:
    return guest_exec_last_symbol

def GuestExec_RunModuleEntry(entry_addr: VAddr, argc: int, argv: void&?, is_main_executable: bool) -> void:
    if not GuestExec_IsEnabled() or entry_addr == 0.uintptr():
        return
    if argv != null:
        guest_exec_last_argv0 <- argv.cast[static u8&?]
        guest_exec_last_argv[0] <- argv.cast[static u8&?]
    GuestExec_RecordHandoff(entry_addr, argc, is_main_executable)

def GuestExec_RunMainEntry(entry_addr: VAddr, argc: int, argv: void&?) -> void:
    GuestExec_RunModuleEntry(entry_addr, argc, argv, true)

def GuestExec_RunMainEntryGuarded(entry_addr: VAddr, argc: int, argv: void&?, timeout_ms: u32) -> s32 can[Unsafe.SegmentMutation, Segment.Host, Segment.Guest]:
    if entry_addr == 0.uintptr():
        guest_exec_last_game_execution_status <- -1
        return -1
    GuestExec_RecordHandoff(entry_addr, argc, true)
    guest_exec_execution_stage <- GUEST_EXEC_STAGE_GUARDED_ENTRY
    if not GuestExec_IsSupported():
        guest_exec_last_game_execution_status <- -2
        guest_exec_first_boundary_reason <- GUEST_EXEC_BOUNDARY_REASON_UNSUPPORTED_HOST
        return -2
    params: mutable GuestEntryParams = zeroed
    params.argc <- argc.s32()
    params.padding <- 0
    params.entry_addr <- entry_addr
    GuestExec_FillEntryParamsArgv(params, argc, argv)
    status: mutable s32 = 0
    can Unsafe.SegmentMutation, Segment.Host, Segment.Guest:
        status <- c_GuestExec_RunMainEntryGuarded(params, timeout_ms)
    guest_exec_last_game_execution_status <- status
    GuestExec_AbsorbNativeBoundaryReport()
    if not guest_exec_first_boundary_reached:
        if status == -3:
            guest_exec_first_boundary_reason <- GUEST_EXEC_BOUNDARY_REASON_TIMEOUT
        elif status == -11 and GuestExec_LastSignal() == 0:
            guest_exec_first_boundary_reason <- GUEST_EXEC_BOUNDARY_REASON_EXITED_BEFORE_BOUNDARY
        elif status < 0:
            guest_exec_first_boundary_reason <- GUEST_EXEC_BOUNDARY_REASON_HOST_CRASH
            if GuestExec_LastSignal() != 0:
                guest_exec_execution_stage <- GUEST_EXEC_STAGE_CRASH_CAPTURED
        else:
            guest_exec_first_boundary_reason <- GUEST_EXEC_BOUNDARY_REASON_EXITED_BEFORE_BOUNDARY
    if guest_exec_first_boundary_reached:
        guest_exec_execution_stage <- GUEST_EXEC_STAGE_FIRST_BOUNDARY
    return status

def GuestExec_RunMainEntryGuardedInProcess(entry_addr: VAddr, argc: int, argv: void&?, timeout_ms: u32) -> s32 can[Unsafe.SegmentMutation, Unsafe.GuestSegmentInstall, Segment.Host, Segment.Guest]:
    if entry_addr == 0.uintptr():
        guest_exec_last_game_execution_status <- -1
        return -1
    GuestExec_RecordHandoff(entry_addr, argc, true)
    guest_exec_execution_stage <- GUEST_EXEC_STAGE_GUARDED_ENTRY
    if not GuestExec_IsSupported():
        guest_exec_last_game_execution_status <- -2
        guest_exec_first_boundary_reason <- GUEST_EXEC_BOUNDARY_REASON_UNSUPPORTED_HOST
        return -2
    params: mutable GuestEntryParams = zeroed
    params.argc <- argc.s32()
    params.padding <- 0
    params.entry_addr <- entry_addr
    GuestExec_FillEntryParamsArgv(params, argc, argv)
    status: mutable s32 = 0
    can Unsafe.SegmentMutation, Unsafe.GuestSegmentInstall, Segment.Host, Segment.Guest:
        status <- c_GuestExec_RunMainEntryGuardedInProcess(params, timeout_ms)
    guest_exec_last_game_execution_status <- status
    GuestExec_AbsorbNativeBoundaryReport()
    if not guest_exec_first_boundary_reached:
        if status == -3:
            guest_exec_first_boundary_reason <- GUEST_EXEC_BOUNDARY_REASON_TIMEOUT
        elif status == -11 and GuestExec_LastSignal() == 0:
            guest_exec_first_boundary_reason <- GUEST_EXEC_BOUNDARY_REASON_EXITED_BEFORE_BOUNDARY
        elif status < 0:
            guest_exec_first_boundary_reason <- GUEST_EXEC_BOUNDARY_REASON_HOST_CRASH
            if GuestExec_LastSignal() != 0:
                guest_exec_execution_stage <- GUEST_EXEC_STAGE_CRASH_CAPTURED
        else:
            guest_exec_first_boundary_reason <- GUEST_EXEC_BOUNDARY_REASON_EXITED_BEFORE_BOUNDARY
    if guest_exec_first_boundary_reached:
        guest_exec_execution_stage <- GUEST_EXEC_STAGE_FIRST_BOUNDARY
    return status

