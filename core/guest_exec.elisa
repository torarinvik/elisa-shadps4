const GUEST_EXEC_MAX_ARGS: usize = 33

extern snprintf(buf: mutable u8&?, bufsize: usize, fmt: u8&, ...) -> int effects[Console.Format]
extern puts(s: u8&) -> int effects[Console.Write]
extern popen(command: u8&, mode: u8&) -> void&?
extern pclose(stream: void&) -> int
extern fgets(s: mutable u8&, size: int, stream: void&) -> mutable u8&?

@fixed_layout
struct GuestEntryParams:
    argc: mutable s32
    padding: mutable u32
    argv: mutable static u8&?[33]
    entry_addr: mutable VAddr

# Platform-capability queries: ported from native C to pure Elisa using the
# compile-time target facts (common/arch.elisa). These resolve entirely at build
# time via `static if`, so the unselected branches are eliminated (no runtime
# checks). HostCanRunX64Subprocess uses libc process I/O FFI only for the Apple
# Silicon Rosetta probe.
def c_GuestExec_IsSupported() -> s32:
    static if PLATFORM_WINDOWS:
        return 0
    static elif ARCH_X86_64:
        return 1
    static else:
        return 0

def c_GuestExec_SupportedNativeExecution() -> s32:
    return c_GuestExec_IsSupported()

def c_GuestExec_HostArchitecture() -> static u8&?:
    static if ARCH_X86_64:
        return "x86_64"
    static elif ARCH_ARM64:
        return "arm64"
    static else:
        return "unknown"

def c_GuestExec_HostMode() -> static u8&?:
    static if PLATFORM_WINDOWS:
        return "Windows"
    static elif PLATFORM_APPLE:
        return "macOS"
    static elif PLATFORM_LINUX:
        return "Linux"
    static elif PLATFORM_FREEBSD:
        return "FreeBSD"
    static else:
        return "unknown"

def c_GuestExec_HostCanRunX64Subprocess() -> s32:
    static if ARCH_X86_64:
        return 1
    static elif PLATFORM_APPLE and ARCH_ARM64:
        line: mutable u8[64] = zeroed
        proc: void&? = popen("/usr/bin/arch -x86_64 /usr/bin/uname -m 2>/dev/null", "r")
        if proc == null:
            return 0
        has_x64: mutable s32 = 0
        read_result: mutable u8&? = fgets(line[0].ref[mutable u8&], 64, proc.cast[void&])
        if read_result != null:
            i: mutable usize = 0
            while i < 64usize:
                if line[i] == 0:
                    i <- 64usize
                elif line[i] == '\n' or line[i] == '\r':
                    line[i] <- 0
                    i <- 64usize
                else:
                    i <- i + 1
            if streq(line[0].ref[u8&].cast[static u8&], "x86_64") == 1:
                has_x64 <- 1
        status: int = pclose(proc.cast[void&])
        if status != 0:
            return 0
        return has_x64
    static else:
        return 0

