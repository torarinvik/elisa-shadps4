def c_GuestExec_EntryParamsSize() -> u64:
    return 280

def c_GuestExec_EntryParamsArgcOffset() -> u64:
    return 0

def c_GuestExec_EntryParamsArgvOffset() -> u64:
    return 8

def c_GuestExec_EntryParamsEntryAddrOffset() -> u64:
    return 272

def c_GuestExec_ProbeEntryParams(params: mutable GuestEntryParams&) -> u64:
    result: mutable u64 = 0xE100000000000000
    result <- result | (params.argc.u64() & 0xFFFF)
    if params.padding == 0xA5A5A5A5:
        result <- result | (1.u64() << 16)
    if params.argv[0].uintptr() == 0x12345678.uintptr():
        result <- result | (1.u64() << 17)
    if params.entry_addr == 0x8877665544332211.uintptr():
        result <- result | (1.u64() << 18)
    return result

