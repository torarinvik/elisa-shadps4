    ge_runtime_hle_guest_return_addr <- 0.uintptr().cast[GuestPC]
    ge_runtime_hle_guest_rsp <- 0.uintptr().cast[GuestStackPointer]
    ge_runtime_hle_guest_rbp <- 0.uintptr().cast[GuestFramePointer]
    ge_runtime_hle_guest_rdi <- 0.uintptr()
    ge_runtime_hle_guest_rsi <- 0.uintptr()
    ge_runtime_hle_guest_rdx <- 0.uintptr()
    ge_runtime_hle_guest_rcx <- 0.uintptr()
    ge_runtime_hle_guest_r8 <- 0.uintptr()
    ge_runtime_hle_guest_r9 <- 0.uintptr()
    ge_runtime_hle_guest_stack_word0 <- 0.uintptr()
    ge_runtime_hle_guest_stack_word1 <- 0.uintptr()
    ge_runtime_hle_guest_stack_word2 <- 0.uintptr()
    ge_runtime_hle_guest_stack_word3 <- 0.uintptr()
    ge_runtime_hle_guest_frame_word0 <- 0.uintptr()
    ge_runtime_hle_guest_frame_word1 <- 0.uintptr()
    ge_runtime_hle_guest_frame_word2 <- 0.uintptr()
    ge_runtime_hle_guest_frame_word3 <- 0.uintptr()
    ge_runtime_hle_caller_frame_word0 <- 0.uintptr()
    ge_runtime_hle_caller_frame_word1 <- 0.uintptr()
    ge_runtime_hle_caller_frame_word2 <- 0.uintptr()
    ge_runtime_hle_caller_frame_word3 <- 0.uintptr()
    hle_oracle_reset_i: mutable usize = 0
    while hle_oracle_reset_i < 2048:
        ge_hle_oracle_modules[hle_oracle_reset_i] <- null
        ge_hle_oracle_symbols[hle_oracle_reset_i] <- null
        ge_hle_oracle_returns[hle_oracle_reset_i] <- 0.uintptr()
        ge_hle_oracle_results[hle_oracle_reset_i] <- 0.uintptr()
        ge_hle_oracle_rdi[hle_oracle_reset_i] <- 0.uintptr()
        ge_hle_oracle_rsi[hle_oracle_reset_i] <- 0.uintptr()
        ge_hle_oracle_rdx[hle_oracle_reset_i] <- 0.uintptr()
        hle_oracle_reset_i <- hle_oracle_reset_i + 1
    ge_clear_writable_page_cache()
    ge_timeout_fired <- 0
    ge_emergency_seq <- 0
    emergency_i: mutable usize = 0
    while emergency_i < 256:
        ge_emergency_events[emergency_i] <- zeroed
        emergency_i <- emergency_i + 1
    ge_current_hle_id <- 0
    ge_current_guest_pc <- 0.uintptr()
    ge_current_return_pc <- 0.uintptr()
    ge_current_guest_sp <- 0.uintptr()
    ge_current_segment_owner <- GE_FS_OWNER_UNKNOWN

# ---- Synthetic test fixtures (@c_abi(c), address-taken; atomic core 2b) ----
@c_abi(c)
def ge_synthetic_crash(arg0: u64, arg1: u64) -> u64:
    _ = arg0
    _ = arg1
    out: mutable u64 = 0
    trusted Unsafe.PointerCast:
        r: u64& = 0.uintptr().cast[u64&]
        out <- r
    return out

@c_abi(c)
def ge_synthetic_add(arg0: u64, arg1: u64) -> u64:
    return arg0 + arg1 + 0x1234

@c_abi(c)
def ge_synthetic_spin(arg0: u64, arg1: u64) -> u64:
    sink: mutable u64 = arg0 ^ arg1
    while true:
        can Unsafe.NonProgress:
            sink <- sink + 1
    return sink

@c_abi(c)
def ge_synthetic_main_return(params: GuestEntryParams&?, exit_func: void&?) -> void:
    ge_synthetic_observed_stack <- !ge_current_stack_pointer()
    ge_synthetic_observed_params <- params.uintptr()
    ge_synthetic_observed_exit_func <- exit_func.uintptr()
    if params != null:
        ge_synthetic_observed_argc <- params.argc
        ge_synthetic_observed_argv0 <- params.argv[0].uintptr()
        ge_synthetic_observed_entry <- params.entry_addr
    if params == null or params.argc != 77:
        ge_last_status <- -4
        return
    ge_last_status <- 1

@c_abi(c)
def ge_synthetic_boundary_callback(reason: u64) -> void:
    ge_boundary_callback_count <- ge_boundary_callback_count + 1
    ge_boundary_callback_reason <- reason
    ge_last_status <- 2

@c_abi(c)
def ge_synthetic_main_call_boundary(params: GuestEntryParams&?, exit_func: void&?) -> void:
    _ = exit_func
    if params == null or params.argc != 88 or params.argv[0] == null:
        ge_last_status <- -5
        return
    static if ARCH_X86_64 and not PLATFORM_WINDOWS:
        boundary: func(u64) -> void = params.argv[0].uintptr().cast[func(u64) -> void]
        boundary(0xB000000000000042)
    static else:
        _ = params

@c_abi(c)
def ge_non_synthetic_main_report_boundary(params: GuestEntryParams&?, exit_func: void&?) -> void:
    _ = params
    _ = exit_func
    ge_report_first_boundary(1)

@c_abi(c)
def ge_synthetic_hle_boundary_probe() -> u64:
    GuestExec_RecordFirstBoundary(GUEST_EXEC_BOUNDARY_REASON_NATIVE_HLE)
    can Memory.Allocate, Unsafe.SegmentMutation, Segment.Host:
        GuestExec_RecordRuntimeHle("synthetic", "synthetic_hle_boundary_probe", 0.uintptr(), 0.uintptr(), 0.uintptr(), 0xB10C.u64().uintptr())
    return 0xB10C

def ge_is_synthetic_main_entry(entry_addr: uintptr) -> bool:
    return entry_addr == (ge_synthetic_main_return.cast[uintptr]) or entry_addr == (ge_synthetic_main_call_boundary.cast[uintptr])

# ---- AeroLib fallback stub recorder ----
# NOTE: the fully-attributing guest-reachable stub (which captures
# __builtin_return_address and tail-calls this recorder) is deferred — it needs
# an EASM function that calls back into Elisa. The plain fallback stub below
# still must be a real nonzero callable address: shadPS4 patches unresolved
# AeroLib imports to a concrete stub function, and R_X86_64_64 relocations may
# carry addends. Returning 0 here leaves tiny addend-only addresses in guest
# memory, which turns unresolved imports into bogus low pointers.
def ge_read_byte(addr: uintptr) -> u8:
    can Memory.Allocate:
        out: mutable u8 = 0
        _ = ge_memcpy((&out).cast[void&], ge_addr_to_ptr(addr), 1)
        return out

def ge_read_disp32(addr: uintptr) -> s32:
    can Memory.Allocate:
        out: mutable u32 = 0
        _ = ge_memcpy((&out).cast[void&], ge_addr_to_ptr(addr), 4)
        return out.s32()

@c_abi(c)
def ge_aerolib_fallback_record(caller_pc: uintptr) -> u64:
    can Memory.Allocate:
        fr: ElisaGuestExecForkReport&? = ge_fork_report
        if fr != null:
            fr.aerolib_fallback_invocations <- fr.aerolib_fallback_invocations + 1
            if fr.aerolib_fallback_caller_pc == 0.uintptr() and caller_pc != 0.uintptr():
                fr.aerolib_fallback_caller_pc <- caller_pc
                raw: mutable u64 = 0
                i: mutable int = 1
                while i <= 8:
                    raw <- (raw << 8) | ge_read_byte(caller_pc - i.uintptr()).u64()
                    i <- i + 1
                fr.aerolib_fallback_callsite_bytes <- raw
                slot_va: mutable uintptr = 0.uintptr()
                b6: u8 = ge_read_byte(caller_pc - 6.uintptr())
                b5: u8 = ge_read_byte(caller_pc - 5.uintptr())
                if b6 == 0xFF and b5 == 0x15:
                    disp: s32 = ge_read_disp32(caller_pc - 4.uintptr())
                    slot_va <- (caller_pc.i64() + disp.i64()).uintptr()
                elif b5 == 0xE8:
                    rel: s32 = ge_read_disp32(caller_pc - 4.uintptr())
                    plt: uintptr = (caller_pc.i64() + rel.i64()).uintptr()
                    fr.aerolib_fallback_plt_va <- plt
                    pltraw: mutable u64 = 0
                    j: mutable int = 7
                    while j >= 0:
                        pltraw <- (pltraw << 8) | ge_read_byte(plt + j.uintptr()).u64()
                        j <- j - 1
                    fr.aerolib_fallback_plt_bytes <- pltraw
                    q0: u8 = ge_read_byte(plt)
                    q1: u8 = ge_read_byte(plt + 1.uintptr())
                    if q0 == 0xFF and q1 == 0x25:
                        disp2: s32 = ge_read_disp32(plt + 2.uintptr())
                        slot_va <- (plt.i64() + 6 + disp2.i64()).uintptr()
                fr.aerolib_fallback_slot_va <- slot_va
        ge_report_first_boundary(2)
        return 0

def ge_aerolib_fallback_stub_address() -> uintptr:
    static if ARCH_X86_64:
        return ElisaGuestExec_AeroLibFallbackUnknownStubAsm.cast[uintptr]
    static else:
        return 0.uintptr()

# ---- Synthetic-fixture address getters (atomic core 2b) ----
def ge_get_synthetic_add_address() -> uintptr:
    return ge_synthetic_add.cast[uintptr]

def ge_get_synthetic_crash_address() -> uintptr:
    return ge_synthetic_crash.cast[uintptr]

def ge_get_synthetic_spin_address() -> uintptr:
    return ge_synthetic_spin.cast[uintptr]

def ge_get_synthetic_main_return_address() -> uintptr:
    return ge_synthetic_main_return.cast[uintptr]

def ge_get_synthetic_main_call_boundary_address() -> uintptr:
    return ge_synthetic_main_call_boundary.cast[uintptr]

def ge_get_synthetic_boundary_callback_address() -> uintptr:
    return ge_synthetic_boundary_callback.cast[uintptr]

def ge_get_non_synthetic_main_report_boundary_address() -> uintptr:
    return ge_non_synthetic_main_report_boundary.cast[uintptr]

def ge_get_synthetic_hle_boundary_probe_address() -> uintptr:
    return ge_synthetic_hle_boundary_probe.cast[uintptr]

# ---- Run orchestration + crash getters (atomic core, part 2c; inert) ----
@link_name(fork)
extern ge_fork() -> int
@link_name(waitpid)
extern ge_waitpid(pid: int, status: mutable int&, options: int) -> int
@link_name(kill)
extern ge_kill(pid: int, sig: int) -> int
@link_name(usleep)
extern ge_usleep(usec: u32) -> int
@link_name(setitimer)
extern ge_setitimer(which: int, value: void&?, old: void&?) -> int

@fixed_layout
struct GeTimeval:
    tv_sec: mutable i64
    tv_usec: mutable i32
    tv_pad: mutable i32
@fixed_layout
struct GeItimerval:
    interval: mutable GeTimeval
    value: mutable GeTimeval

const GE_WNOHANG: int = 1
const GE_ITIMER_REAL: int = 0
const GE_SENTINEL_MAX: u64 = 0xFFFFFFFFFFFFFFFF

def ge_wif_signaled(status: int) -> bool:
    low: int = status & 0x7f
    return low != 0 and low != 0x7f
def ge_wtermsig(status: int) -> int:
    return status & 0x7f
def ge_wif_exited(status: int) -> bool:
    return (status & 0x7f) == 0
def ge_wexitstatus(status: int) -> int:
    return (status >> 8) & 0xff
def ge_wif_stopped(status: int) -> bool:
    return (status & 0xff) == 0x7f

def ge_arm_timer(timeout_ms: u32) -> void:
    if timeout_ms != 0:
        ge_raw_breadcrumb("GE:TIMER_ARM\n", 13)
        timer: mutable GeItimerval = zeroed
        timer.value.tv_sec <- (timeout_ms / 1000).i64()
        timer.value.tv_usec <- ((timeout_ms % 1000) * 1000).i32()
        _ = ge_setitimer(GE_ITIMER_REAL, (&timer).cast[void&], null)

def ge_arm_pc_sampler_timer(timeout_ms: u32) -> void:
    if timeout_ms != 0:
        ge_raw_breadcrumb("GE:PC_SAMPLER_ARM\n", 18)
        interval_ms: mutable u32 = ge_pc_sampler_interval_ms
        if interval_ms == 0:
            interval_ms <- 5
        ge_pc_sampler_count <- 0
        ge_pc_sampler_max_samples <- timeout_ms / interval_ms
        if ge_pc_sampler_max_samples == 0:
            ge_pc_sampler_max_samples <- 1
        timer: mutable GeItimerval = zeroed
        timer.interval.tv_sec <- (interval_ms / 1000).i64()
        timer.interval.tv_usec <- ((interval_ms % 1000) * 1000).i32()
        timer.value.tv_sec <- timer.interval.tv_sec
        timer.value.tv_usec <- timer.interval.tv_usec
        _ = ge_setitimer(GE_ITIMER_REAL, (&timer).cast[void&], null)

def ge_disarm_timer() -> void:
    ge_raw_breadcrumb("GE:TIMER_DISARM\n", 16)
    timer_off: mutable GeItimerval = zeroed
    _ = ge_setitimer(GE_ITIMER_REAL, (&timer_off).cast[void&], null)

def ge_run_synthetic_function(entry_addr: uintptr, arg0: u64, arg1: u64) -> u64:
    ge_debug_trace_boundary("guest-exec-synthetic-entry", entry_addr, arg0.uintptr(), arg1.uintptr())
    if entry_addr == 0.uintptr():
        ge_last_status <- -1
        ge_debug_trace_boundary("guest-exec-synthetic-stop", entry_addr, GE_SENTINEL_MAX.uintptr(), 0.uintptr())
        return GE_SENTINEL_MAX
    static if ARCH_X86_64 and not PLATFORM_WINDOWS:
        if not ge_debug_guard_callable_target(entry_addr, 1):
            ge_debug_trace_boundary("guest-exec-synthetic-stop", entry_addr, (GE_SENTINEL_MAX - 5).uintptr(), ge_debug_trap_reason.uintptr())
            return GE_SENTINEL_MAX - 5
        if not ge_check_entry_published(entry_addr):
            ge_debug_trace_boundary("guest-exec-synthetic-stop", entry_addr, (GE_SENTINEL_MAX - 4).uintptr(), GE_DEBUG_TRAP_UNPUBLISHED_EXEC_STATUS.u64().uintptr())
            return GE_SENTINEL_MAX - 4
        ge_reset_crash_state()
        ge_install_guards()
        ge_guard_active <- 1
        ge_guard_target_thread <- !ge_pthread_self()
        if ge_sigsetjmp((&ge_jmp_buf[0]).cast[void&], 1) != 0:
            ge_guard_active <- 0
            ge_restore_guards()
            ge_debug_trace_boundary("guest-exec-synthetic-stop", entry_addr, (GE_SENTINEL_MAX - 2).uintptr(), ge_last_status.u64().uintptr())
            return GE_SENTINEL_MAX - 2
        fn: func(u64, u64) -> u64 = entry_addr.cast[func(u64, u64) -> u64]
        result: u64 = fn(arg0, arg1)
        ge_guard_active <- 0
        ge_restore_guards()
        ge_last_status <- 1
        ge_debug_trace_boundary("guest-exec-synthetic-result", entry_addr, result.uintptr(), ge_last_status.u64().uintptr())
        return result
    static else:
        _ = arg0
        _ = arg1
        ge_last_status <- -2
        ge_debug_trace_boundary("guest-exec-synthetic-stop", entry_addr, (GE_SENTINEL_MAX - 1).uintptr(), ge_last_status.u64().uintptr())
        return GE_SENTINEL_MAX - 1

def ge_run_synthetic_function_with_timeout(entry_addr: uintptr, arg0: u64, arg1: u64, timeout_ms: u32) -> u64:
    ge_debug_trace_boundary("guest-exec-synthetic-timeout-entry", entry_addr, arg0.uintptr(), arg1.uintptr())
    if entry_addr == 0.uintptr():
        ge_last_status <- -1
        ge_debug_trace_boundary("guest-exec-synthetic-timeout-stop", entry_addr, GE_SENTINEL_MAX.uintptr(), 0.uintptr())
        return GE_SENTINEL_MAX
    static if ARCH_X86_64 and not PLATFORM_WINDOWS:
        if not ge_debug_guard_callable_target(entry_addr, 1):
            ge_debug_trace_boundary("guest-exec-synthetic-timeout-stop", entry_addr, (GE_SENTINEL_MAX - 5).uintptr(), ge_debug_trap_reason.uintptr())
            return GE_SENTINEL_MAX - 5
        if not ge_check_entry_published(entry_addr):
            ge_debug_trace_boundary("guest-exec-synthetic-timeout-stop", entry_addr, (GE_SENTINEL_MAX - 4).uintptr(), GE_DEBUG_TRAP_UNPUBLISHED_EXEC_STATUS.u64().uintptr())
            return GE_SENTINEL_MAX - 4
        ge_reset_crash_state()
        ge_install_guards()
        ge_guard_active <- 1
        ge_guard_target_thread <- !ge_pthread_self()
        ge_arm_timer(timeout_ms)
        if ge_sigsetjmp((&ge_jmp_buf[0]).cast[void&], 1) != 0:
            ge_disarm_timer()
            ge_guard_active <- 0
            ge_restore_guards()
            if ge_timeout_fired != 0:
                ge_last_status <- -3
                ge_debug_trace_boundary("guest-exec-synthetic-timeout-stop", entry_addr, (GE_SENTINEL_MAX - 3).uintptr(), ge_last_status.u64().uintptr())
                return GE_SENTINEL_MAX - 3
            ge_debug_trace_boundary("guest-exec-synthetic-timeout-stop", entry_addr, (GE_SENTINEL_MAX - 2).uintptr(), ge_last_status.u64().uintptr())
            return GE_SENTINEL_MAX - 2
        fn: func(u64, u64) -> u64 = entry_addr.cast[func(u64, u64) -> u64]
        result: u64 = fn(arg0, arg1)
        ge_disarm_timer()
        ge_guard_active <- 0
        ge_restore_guards()
        ge_last_status <- 1
        ge_debug_trace_boundary("guest-exec-synthetic-timeout-result", entry_addr, result.uintptr(), ge_last_status.u64().uintptr())
        return result
    static else:
        _ = arg0
        _ = arg1
        _ = timeout_ms
        ge_last_status <- -2
        ge_debug_trace_boundary("guest-exec-synthetic-timeout-stop", entry_addr, (GE_SENTINEL_MAX - 1).uintptr(), ge_last_status.u64().uintptr())
        return GE_SENTINEL_MAX - 1

def ge_run_main_entry(params: mutable GuestEntryParams&, exit_func: void&?) -> void:
    static if ARCH_X86_64 and not PLATFORM_WINDOWS:
        ef: mutable uintptr = exit_func.uintptr()
        if ef == 0.uintptr():
            ef <- ge_default_exit.cast[uintptr]
        ElisaGuestExec_EnterMainEntryAsm((&params).cast[void&].uintptr().cast[HostPtr[GuestEntryParams]], ef.cast[ExitFunction])
    static else:
        _ = params
        _ = exit_func

def ge_prepare_main_entry_snapshot(params: mutable GuestEntryParams&) -> void:
    can Memory.Allocate:
        ge_expected_entry_params <- (&params).cast[void&].uintptr()
        ge_expected_stack_word0 <- params.argc.u32().uintptr()
        ge_expected_stack_word1 <- params.argv[0].uintptr()
        ge_entry_stack_word0 <- ge_expected_stack_word0
        ge_entry_stack_word1 <- ge_expected_stack_word1
        ge_entry_native_word0 <- ge_read_native_word(params.entry_addr)
        ge_entry_native_word1 <- ge_read_native_word(params.entry_addr + 8.uintptr())
        ge_entry_native_prot <- ge_native_prot_at(params.entry_addr, 8)
        fr: ElisaGuestExecForkReport&? = ge_fork_report
        if fr != null:
            fr.expected_entry_params <- ge_expected_entry_params
            fr.expected_stack_word0 <- ge_expected_stack_word0
            fr.expected_stack_word1 <- ge_expected_stack_word1
            fr.entry_stack_word0 <- ge_entry_stack_word0
            fr.entry_stack_word1 <- ge_entry_stack_word1
            fr.entry_native_word0 <- ge_entry_native_word0
            fr.entry_native_word1 <- ge_entry_native_word1
            fr.entry_native_prot <- ge_entry_native_prot

def ge_run_main_entry_guarded_in_process(params: mutable GuestEntryParams&, timeout_ms: u32) -> s32 can[Unsafe.SegmentMutation, Unsafe.GuestSegmentInstall, Segment.Host, Segment.Guest]:
    ge_set_native_phase(GE_PHASE_FUNCTION_ENTRY)
    if params.entry_addr == 0.uintptr():
        ge_reset_crash_state()
        ge_set_native_phase(GE_PHASE_RETURN_BAD_PARAMS)
        ge_last_status <- -1
        return -1
    static if ARCH_X86_64 and not PLATFORM_WINDOWS:
        ge_reset_crash_state()
        ge_set_native_phase(GE_PHASE_AFTER_RESET)
        can Unsafe.SegmentMutation, Segment.Host:
            ge_assert_host_fs_owner("guarded-in-process-after-reset")
        ge_prepare_main_entry_snapshot(params)
        ge_install_guards()
        ge_guard_active <- 1
        ge_guard_target_thread <- !ge_pthread_self()
        if ge_pc_sampler_enabled:
            ge_arm_pc_sampler_timer(timeout_ms)
        else:
            ge_arm_timer(timeout_ms)
        ge_set_native_phase(GE_PHASE_SYNTHETIC_BEFORE_SIGSETJMP)
        if ge_sigsetjmp((&ge_jmp_buf[0]).cast[void&], 1) != 0:
            ge_raw_breadcrumb("GE:GUARD_LONGJMP_ENTER\n", 23)
            static if PLATFORM_APPLE and ARCH_X86_64:
                can Unsafe.SegmentMutation, Segment.Host:
                    TLS_RestoreHostFsSelector()
                ge_raw_breadcrumb("GE:GUARD_LONGJMP_RESTORE\n", 25)
                can Unsafe.SegmentMutation, Segment.Host:
                    ge_assert_host_fs_owner("guarded-in-process-after-longjmp-host-restore")
                ge_raw_breadcrumb("GE:GUARD_LONGJMP_ASSERT\n", 24)
            ge_disarm_timer()
            ge_raw_breadcrumb("GE:GUARD_LONGJMP_DISARMED\n", 26)
            ge_guard_active <- 0
            ge_raw_breadcrumb("GE:GUARD_LONGJMP_INACTIVE\n", 26)
            ge_restore_guards()
            ge_raw_breadcrumb("GE:GUARD_LONGJMP_RESTORED\n", 26)
            if ge_timeout_fired != 0:
                ge_last_status <- -3
                ge_raw_breadcrumb("GE:GUARD_LONGJMP_TIMEOUT\n", 25)
            if ge_last_status == 0:
                ge_last_status <- -11
                ge_raw_breadcrumb("GE:GUARD_LONGJMP_DEFAULT\n", 25)
            if ge_debug_trace_enabled or getenv("ELISA_FORCE_TAPE_DUMP".cast[u8&]) != null:
                ge_emergency_dump_raw()
            ge_raw_breadcrumb("GE:GUARD_LONGJMP_RETURN\n", 24)
            return ge_last_status
        ge_set_native_phase(GE_PHASE_CHILD_BEFORE_MAIN_ENTRY)
        can Unsafe.SegmentMutation, Segment.Host:
            ge_assert_host_fs_owner("guarded-in-process-before-main-entry")
        # If an init trampoline was built (deferred-init mode), jump to it instead of
        # the eboot entry. The trampoline runs the dependency PRX inits (libc heap
        # bootstrap) as native guest code -- under this guard, with live HLE dispatch --
        # then jmps to the real eboot entry. This mirrors shadPS4 running PRX inits
        # before _start. last_entry_addr / params.entry_addr stay the real entry for
        # reporting; only the actual jump target is redirected.
        ge_init_trampoline: u64 = Linker_InitTrampolineAddr()
        if ge_init_trampoline != 0:
            params.entry_addr <- ge_init_trampoline.uintptr()
        static if PLATFORM_LINUX and ARCH_X86_64:
            # Install the guest TCB into the GS base before entering guest code.
            # Guest fs: accesses were rewritten to gs: by cpu_patches; mirrors shadPS4
            # InitializeTLS()->SetTcbBase(arch_prctl ARCH_SET_GS) ahead of RunMainEntry.
            can Unsafe.SegmentMutation, Unsafe.GuestSegmentInstall, Segment.Guest:
                TLS_InstallPrimaryTcbBase()
        can Unsafe.SegmentMutation, Segment.Host, Segment.Guest:
            ge_jump_main_entry(params, ge_guarded_exit.cast[uintptr])
        ge_raw_breadcrumb("GE:GUARD_AFTER_JUMP\n", 20)
        ge_disarm_timer()
        ge_raw_breadcrumb("GE:GUARD_AFTER_DISARM\n", 22)
        ge_guard_active <- 0
        ge_raw_breadcrumb("GE:GUARD_BEFORE_RESTORE\n", 24)
        ge_restore_guards()
        ge_raw_breadcrumb("GE:GUARD_AFTER_RESTORE\n", 23)
        if ge_last_status == 0:
            ge_last_status <- 1
        ge_raw_breadcrumb("GE:GUARD_RETURN\n", 16)
        return ge_last_status
    static else:
        _ = timeout_ms
        ge_reset_crash_state()
        ge_set_native_phase(GE_PHASE_UNSUPPORTED_RETURN)
        ge_last_status <- -2
        return -2

def ge_run_main_entry_guarded(params: mutable GuestEntryParams&, timeout_ms: u32) -> s32 can[Unsafe.SegmentMutation, Segment.Host, Segment.Guest]:
    ge_set_native_phase(GE_PHASE_FUNCTION_ENTRY)
    if params.entry_addr == 0.uintptr():
        ge_reset_crash_state()
        ge_set_native_phase(GE_PHASE_RETURN_BAD_PARAMS)
        ge_last_status <- -1
        return -1
    static if ARCH_X86_64 and not PLATFORM_WINDOWS:
        ge_reset_crash_state()
        ge_set_native_phase(GE_PHASE_AFTER_RESET)
        can Unsafe.SegmentMutation, Segment.Host:
            ge_assert_host_fs_owner("guarded-fork-after-reset")
        ge_last_errno <- -100
        if ge_is_synthetic_main_entry(params.entry_addr):
            ge_set_native_phase(GE_PHASE_SYNTHETIC_ENTRY)
            ge_install_guards()
            ge_guard_active <- 1
            ge_guard_target_thread <- !ge_pthread_self()
            ge_arm_timer(timeout_ms)
            ge_set_native_phase(GE_PHASE_SYNTHETIC_BEFORE_SIGSETJMP)
            if ge_sigsetjmp((&ge_jmp_buf[0]).cast[void&], 1) != 0:
                ge_disarm_timer()
                ge_guard_active <- 0
                ge_restore_guards()
                if ge_timeout_fired != 0:
                    ge_last_status <- -3
                return ge_last_status
            ge_set_native_phase(GE_PHASE_SYNTHETIC_BEFORE_MAIN_ENTRY)
            ge_call_main_entry(params, ge_guarded_exit.cast[uintptr])
            ge_disarm_timer()
            ge_guard_active <- 0
            ge_restore_guards()
            ge_last_status <- 1
            return 1
        ge_set_native_phase(GE_PHASE_BEFORE_FORK_REPORT_SETUP)
        if ge_ensure_fork_report() != 0:
            ge_set_native_phase(GE_PHASE_RETURN_FORK_REPORT_SETUP_FAILED)
            ge_last_errno <- -101
            ge_last_status <- -1
            return -1
        ge_set_native_phase(GE_PHASE_AFTER_FORK_REPORT_SETUP)
        ge_last_errno <- -102
        ge_set_native_phase(GE_PHASE_BEFORE_FORK)
        child: int = ge_fork()
        if child < 0:
            ge_set_native_phase(GE_PHASE_RETURN_FORK_FAILED)
            ge_last_errno <- -103
            ge_last_status <- -1
            return -1
        if child == 0:
            can Unsafe.SegmentMutation, Segment.Host, Segment.Guest:
                ge_run_child_main_entry(params)
        ge_set_native_phase(GE_PHASE_PARENT_BRANCH_ENTERED)
        waited_ms: mutable u32 = 0
        status: mutable int = 0
        while true:
            can Unsafe.AssumeProgress:
                result: int = ge_waitpid(child, (&status).cast[mutable int&], GE_WNOHANG)
                if result == child:
                    ge_set_native_phase(GE_PHASE_PARENT_WAITPID_CHILD)
                    ge_last_errno <- -104
                    if ge_wif_signaled(status):
                        ge_set_native_phase(GE_PHASE_PARENT_WIFSIGNALED)
                        sig: int = ge_wtermsig(status)
                        fr: ElisaGuestExecForkReport&? = ge_fork_report
                        if fr != null:
                            if fr.status == 0:
                                fr.status <- (0 - sig).s32()
                            if fr.signal == 0:
                                fr.signal <- sig.s32()
                        ge_absorb_fork_report()
                        if ge_last_status == 0:
                            ge_last_status <- (0 - sig).s32()
                        if ge_last_signal == 0:
                            ge_last_signal <- sig.s32()
                        return ge_last_status
                    if ge_wif_exited(status):
                        ge_set_native_phase(GE_PHASE_PARENT_WIFEXITED)
                        code: int = ge_wexitstatus(status)
                        fr2: ElisaGuestExecForkReport&? = ge_fork_report
                        if fr2 != null:
                            if fr2.status == 0:
                                fr2.status <- (-11 if code == 0 else ((0 - (code - 128)) if code >= 128 else (0 - code))).s32()
                            if code >= 128 and fr2.signal == 0:
                                fr2.signal <- (code - 128).s32()
                        ge_absorb_fork_report()
                        if ge_last_status == 0:
                            ge_last_status <- (-11 if code == 0 else (0 - code)).s32()
                        return ge_last_status
                    if ge_wif_stopped(status):
                        ge_set_native_phase(GE_PHASE_PARENT_WAIT_STATUS_OTHER)
                        continue
                    ge_set_native_phase(GE_PHASE_PARENT_WAIT_STATUS_OTHER)
                    ge_last_errno <- status.s32()
                    ge_absorb_fork_report()
                    if ge_last_status == 0:
                        ge_last_status <- -1
                    return ge_last_status
                if result < 0:
                    ge_set_native_phase(GE_PHASE_PARENT_WAITPID_ERROR)
                    ge_last_errno <- -105
                    ge_absorb_fork_report()
                    if ge_last_status == 0:
                        ge_last_status <- -1
                    return ge_last_status
                if timeout_ms != 0 and waited_ms >= timeout_ms:
                    ge_set_native_phase(GE_PHASE_PARENT_TIMEOUT)
                    ge_timeout_fired <- 1
                    ge_last_status <- -3
                    ge_last_signal <- GE_SIG_ALRM.s32()
                    fr3: ElisaGuestExecForkReport&? = ge_fork_report
                    if fr3 != null:
                        fr3.status <- -3
                        fr3.signal <- GE_SIG_ALRM.s32()
                        fr3.native_phase <- GE_PHASE_PARENT_TIMEOUT
                    # Ask the child to take a catchable signal first. Its handler
                    # snapshots RIP/RSP/registers into the shared ForkReport before
                    # the parent falls back to SIGKILL, turning timeout hangs into a
                    # concrete guest PC instead of a blind kill.
                    _ = ge_kill(child, GE_SIG_TRAP)
                    snapshot_wait_ms: mutable u32 = 0
                    while snapshot_wait_ms < 50:
                        snapshot_result: int = ge_waitpid(child, (&status).cast[mutable int&], GE_WNOHANG)
                        if snapshot_result == child or snapshot_result < 0:
                            break
                        _ = ge_usleep(1000)
                        snapshot_wait_ms <- snapshot_wait_ms + 1
                    ge_absorb_fork_report()
                    ge_last_status <- -3
                    if ge_last_signal == 0:
                        ge_last_signal <- GE_SIG_ALRM.s32()
                    if snapshot_wait_ms >= 50:
                        _ = ge_kill(child, 9)
                    reap_wait_ms: mutable u32 = 0
                    while reap_wait_ms < 250:
                        reap_result: int = ge_waitpid(child, (&status).cast[mutable int&], GE_WNOHANG)
                        if reap_result == child or reap_result < 0:
                            break
                        _ = ge_usleep(1000)
                        reap_wait_ms <- reap_wait_ms + 1
                    ge_absorb_fork_report()
                    ge_last_status <- -3
                    if ge_last_signal == 0:
                        ge_last_signal <- GE_SIG_ALRM.s32()
                    return -3
                _ = ge_usleep(1000)
                waited_ms <- waited_ms + 1
        return ge_last_status
    static else:
        _ = timeout_ms
        ge_reset_crash_state()
        ge_set_native_phase(GE_PHASE_UNSUPPORTED_RETURN)
        ge_last_status <- -2
        return -2

