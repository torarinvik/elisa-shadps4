global mutable guest_exec_enabled: bool = false
global mutable guest_exec_probe_mode: bool = false
global mutable guest_exec_last_map_result: s32 = 0
global mutable guest_exec_last_entry_addr: VAddr = 0.uintptr()
global mutable guest_exec_last_argc: int = 0
global mutable guest_exec_last_argv0: static u8&? = null
global mutable guest_exec_last_argv: static u8&?[33] = zeroed
global mutable guest_exec_run_count: usize = 0
global mutable guest_exec_failed_relocation_count: u64 = 0
global mutable guest_exec_last_main_entry_addr: VAddr = 0.uintptr()
global mutable guest_exec_main_run_count: usize = 0
global mutable guest_exec_last_game_execution_status: s32 = 0
global mutable guest_exec_last_module: static u8&? = null
global mutable guest_exec_last_symbol: static u8&? = null
global mutable guest_exec_last_hle_module: static u8&? = null
global mutable guest_exec_last_hle_symbol: static u8&? = null
global mutable guest_exec_first_boundary_reached: bool = false
global mutable guest_exec_first_boundary_reason: s32 = 0
global mutable guest_exec_execution_stage: s32 = 0
global mutable guest_exec_main_stack_top: VAddr = 0.uintptr()

const GUEST_EXEC_STAGE_NONE: s32 = 0
const GUEST_EXEC_STAGE_LOAD: s32 = 1
const GUEST_EXEC_STAGE_LINK: s32 = 2
const GUEST_EXEC_STAGE_HANDOFF: s32 = 3
const GUEST_EXEC_STAGE_GUARDED_ENTRY: s32 = 4
const GUEST_EXEC_STAGE_FIRST_BOUNDARY: s32 = 5
const GUEST_EXEC_STAGE_CRASH_CAPTURED: s32 = 6

const GUEST_EXEC_BOUNDARY_NOT_REACHED: s32 = 0
const GUEST_EXEC_BOUNDARY_FIRST_HLE_IMPORT: s32 = 1
const GUEST_EXEC_BOUNDARY_ARMED_PROBE_ONLY: s32 = 2
const GUEST_EXEC_BOUNDARY_UNSUPPORTED_HOST: s32 = -2
const GUEST_EXEC_BOUNDARY_TIMEOUT: s32 = -3
const GUEST_EXEC_BOUNDARY_PRE_BOUNDARY_FAULT: s32 = -10
const GUEST_EXEC_BOUNDARY_EXITED_BEFORE_BOUNDARY: s32 = -11

const GUEST_EXEC_BOUNDARY_REASON_NONE: s32 = 0
const GUEST_EXEC_BOUNDARY_REASON_NATIVE_HLE: s32 = 1
const GUEST_EXEC_BOUNDARY_REASON_AEROLIB_FALLBACK: s32 = 2
const GUEST_EXEC_BOUNDARY_REASON_UNSUPPORTED_SYSCALL: s32 = 3
const GUEST_EXEC_BOUNDARY_REASON_HOST_CRASH: s32 = 4
const GUEST_EXEC_BOUNDARY_REASON_TIMEOUT: s32 = 5
const GUEST_EXEC_BOUNDARY_REASON_EXITED_BEFORE_BOUNDARY: s32 = 6
# 7 means the host cannot safely execute guest code on this platform/ABI.
const GUEST_EXEC_BOUNDARY_REASON_UNSUPPORTED_HOST: s32 = 7
# 8 means execution was intentionally limited to probe-only mode.
const GUEST_EXEC_BOUNDARY_REASON_PROBE_ONLY: s32 = 8

def GuestExec_BoundaryReasonName(reason: s32) -> static u8&:
    if reason == GUEST_EXEC_BOUNDARY_REASON_NATIVE_HLE:
        return "native-hle"
    if reason == GUEST_EXEC_BOUNDARY_REASON_AEROLIB_FALLBACK:
        return "aerolib-fallback"
    if reason == GUEST_EXEC_BOUNDARY_REASON_UNSUPPORTED_SYSCALL:
        return "unsupported-syscall"
    if reason == GUEST_EXEC_BOUNDARY_REASON_HOST_CRASH:
        return "host-crash"
    if reason == GUEST_EXEC_BOUNDARY_REASON_TIMEOUT:
        return "timeout"
    if reason == GUEST_EXEC_BOUNDARY_REASON_EXITED_BEFORE_BOUNDARY:
        return "exited-before-boundary"
    if reason == GUEST_EXEC_BOUNDARY_REASON_UNSUPPORTED_HOST:
        return "unsupported-host"
    if reason == GUEST_EXEC_BOUNDARY_REASON_PROBE_ONLY:
        return "probe-only"
    return "none"

def GuestExec_IsSupported() -> bool:
    return c_GuestExec_IsSupported() == 1

def GuestExec_ResetState() -> void:
    ge_debug_trace_reset()
    ge_debug_trace_checkpoint("guest-exec-reset")
    guest_exec_enabled <- false
    guest_exec_probe_mode <- false
    guest_exec_last_map_result <- 0
    guest_exec_last_entry_addr <- 0.uintptr()
    guest_exec_last_argc <- 0
    guest_exec_last_argv0 <- null
    argv_i: mutable usize = 0
    while argv_i < 33:
        guest_exec_last_argv[argv_i] <- null
        argv_i <- argv_i + 1
    guest_exec_run_count <- 0
    guest_exec_last_main_entry_addr <- 0.uintptr()
    guest_exec_main_run_count <- 0
    guest_exec_last_game_execution_status <- 0
    guest_exec_last_module <- null
    guest_exec_last_symbol <- null
    guest_exec_last_hle_module <- null
    guest_exec_last_hle_symbol <- null
    guest_exec_first_boundary_reached <- false
    guest_exec_first_boundary_reason <- GUEST_EXEC_BOUNDARY_REASON_NONE
    guest_exec_execution_stage <- GUEST_EXEC_STAGE_NONE
    guest_exec_main_stack_top <- 0.uintptr()
    ge_publish_executable_count <- 0
    ge_publish_executable_reject_count <- 0
    ge_publish_executable_last_addr <- 0.uintptr().cast[PublishedExecutableAddr]
    ge_publish_executable_last_size <- 0
    ge_publish_executable_last_prot <- 0
    ge_publish_executable_last_result <- 0
    ge_published_exec_count <- 0
    i: mutable u32 = 0
    while i < 2048:
        ge_published_exec_bases[i.usize()] <- 0.uintptr().cast[PublishedExecutableAddr]
        ge_published_exec_sizes[i.usize()] <- 0
        i <- i + 1
    ge_debug_trap_on_boundary_guard <- false
    ge_debug_trap_on_unpublished_exec <- false
    ge_debug_trap_on_callable_guard <- false
    ge_debug_trap_count <- 0
    ge_debug_trap_reason <- GE_BOUNDARY_GUARD_NONE
    ge_debug_trap_value <- 0.uintptr()
    ge_debug_trap_sequence <- 0
    ge_oracle_first_boundary_emitted <- 0
    ge_debug_trap_return_addr <- 0.uintptr()
    ge_debug_trap_arg0 <- 0.uintptr()
    ge_debug_trap_arg1 <- 0.uintptr()
    ge_debug_trap_arg2 <- 0.uintptr()
    ge_debug_trap_pointer_size <- 0
    ge_debug_trap_nearest_mapping_base <- 0.uintptr()
    ge_debug_trap_nearest_mapping_end <- 0.uintptr()
    ge_debug_trap_nearest_mapping_prot <- 0
    ge_debug_trap_tcb_base <- 0.uintptr()
    ge_debug_trap_tcb_self <- 0.uintptr()
    ge_debug_trap_install_fs0 <- 0.uintptr()
    ge_fs_state_mismatch_count <- 0
    ge_fs_state_observation_count <- 0
    ge_fs_state_last_site <- ""
    ge_fs_state_last_expect_guest <- false
    ge_fs_state_last_expected <- 0.uintptr()
    ge_fs_state_last_actual <- 0.uintptr()
    ge_fs_state_last_expected_owner <- GE_FS_OWNER_UNKNOWN
    ge_fs_state_last_actual_owner <- GE_FS_OWNER_UNKNOWN
    ge_fs_state_last_guest_selector <- 0.uintptr()
    ge_fs_state_last_host_selector <- 0.uintptr()
    ge_fs_state_last_tcb_base <- 0.uintptr()
    ge_fs_state_last_fs0 <- 0.uintptr()
    ge_fs_state_last_hle_return_addr <- 0.uintptr()
    ge_fs_state_last_hle_module <- ""
    ge_fs_state_last_hle_symbol <- ""
    ge_fs_state_shadow_owner <- GE_FS_OWNER_HOST
    ge_fs_state_shadow_mismatch_count <- 0
    ge_fs_state_shadow_transition_count <- 0
    ge_fs_state_shadow_last_site <- ""
    ge_hle_thunk_contract_count <- 0
    ge_hle_thunk_contract_last_thunk <- 0.uintptr()
    ge_hle_thunk_contract_last_target <- 0.uintptr()
    ge_hle_thunk_contract_last_size <- 0
    ge_hle_thunk_contract_last_host_selector <- 0.uintptr()
    hle_thunk_i: mutable u64 = 0
    while hle_thunk_i < GE_HLE_THUNK_CONTRACT_CAP:
        ge_hle_thunk_contract_addrs[hle_thunk_i.usize()] <- 0.uintptr()
        ge_hle_thunk_contract_targets[hle_thunk_i.usize()] <- 0.uintptr()
        ge_hle_thunk_contract_sizes[hle_thunk_i.usize()] <- 0
        hle_thunk_i <- hle_thunk_i + 1
    c_GuestExec_ResetCrashState()

def GuestExec_Enable(enabled: bool) -> void:
    guest_exec_enabled <- enabled

def GuestExec_SetProbeMode(enabled: bool) -> void:
    guest_exec_probe_mode <- enabled

def GuestExec_SetMainStackTop(stack_top: VAddr) -> void:
    guest_exec_main_stack_top <- stack_top

def GuestExec_MainStackTop() -> VAddr:
    return guest_exec_main_stack_top

def GuestExec_IsEnabled() -> bool:
    return guest_exec_enabled and (guest_exec_probe_mode or GuestExec_IsSupported())

def GuestExec_IsProbeMode() -> bool:
    return guest_exec_probe_mode

def GuestExec_SupportedNativeExecution() -> bool:
    return c_GuestExec_SupportedNativeExecution() == 1

def GuestExec_HostCanRunX64Subprocess() -> bool:
    return c_GuestExec_HostCanRunX64Subprocess() == 1

def GuestExec_SpawnX64Subprocess(path: u8&?, argv: static u8&?&?) -> s32:
    ensure result >= -1
    raw_status: s32 = c_GuestExec_SpawnX64Subprocess(path, argv)
    if raw_status < -1:
        return -1
    return raw_status

def GuestExec_AeroLibFallbackStubAddress() -> uintptr:
    return c_GuestExec_AeroLibFallbackStubAddress()

def GuestExec_AeroLibFallbackCallerPc() -> u64:
    return c_GuestExec_AeroLibFallbackCallerPc().u64()

def GuestExec_AeroLibFallbackSlotVa() -> u64:
    return c_GuestExec_AeroLibFallbackSlotVa().u64()

def GuestExec_AeroLibFallbackCallsiteBytes() -> u64:
    return c_GuestExec_AeroLibFallbackCallsiteBytes()

def GuestExec_AeroLibFallbackInvocations() -> u64:
    return c_GuestExec_AeroLibFallbackInvocations()

def GuestExec_AeroLibFallbackPltVa() -> u64:
    return c_GuestExec_AeroLibFallbackPltVa().u64()

def GuestExec_AeroLibFallbackPltBytes() -> u64:
    return c_GuestExec_AeroLibFallbackPltBytes()

def GuestExec_IsProbeOnly() -> bool:
    return guest_exec_probe_mode or not GuestExec_IsSupported()

def GuestExec_HostArchitecture() -> static u8&?:
    return c_GuestExec_HostArchitecture()

def GuestExec_HostMode() -> static u8&?:
    return c_GuestExec_HostMode()

def GuestExec_MapRegion(address: VAddr, size: u64, prot: u32) -> bool:
    if not GuestExec_IsEnabled():
        return false
    if not GuestExec_IsSupported():
        guest_exec_last_map_result <- -2
        return false
    result: s32 = c_GuestExec_MapRegion(address, size, prot)
    guest_exec_last_map_result <- result
    return result == 0

def GuestExec_ProtectRegion(address: VAddr, size: u64, prot: u32) -> bool:
    if not GuestExec_IsEnabled():
        return false
    if not GuestExec_IsSupported():
        guest_exec_last_map_result <- -2
        return false
    result: s32 = c_GuestExec_ProtectRegion(address, size, prot)
    guest_exec_last_map_result <- result
    return result == 0

def GuestExec_ClearWritablePageCache() -> void:
    ge_clear_writable_page_cache()

def GuestExec_UnmapRegion(address: VAddr, size: u64) -> bool:
    if not GuestExec_IsEnabled():
        return false
    if not GuestExec_IsSupported():
        guest_exec_last_map_result <- -2
        return false
    result: s32 = c_GuestExec_UnmapRegion(address, size)
    guest_exec_last_map_result <- result
    return result == 0

def GuestExec_AllocateRegion(size: u64, prot: u32) -> VAddr:
    if not GuestExec_IsEnabled():
        return 0.uintptr()
    if not GuestExec_IsSupported():
        return 0.uintptr()
    return c_GuestExec_AllocateRegion(size, prot)

def GuestExec_WriteBytes(address: VAddr, data: void&?, size: u64) -> bool:
    can Memory.Allocate:
        if not GuestExec_IsEnabled():
            return false
        if not GuestExec_IsSupported():
            return false
        return c_GuestExec_WriteBytes(address, data, size) == 0

def GuestExec_WriteU64(address: VAddr, value: u64) -> bool:
    can Memory.Allocate:
        if not GuestExec_IsEnabled():
            return false
        if not GuestExec_IsSupported():
            return false
        return c_GuestExec_WriteU64(address, value) == 0

def GuestExec_PublishExecutableCode(address: VAddr, size: u64) -> bool can[Unsafe.ExecutableCodePublish]:
    if not GuestExec_IsEnabled():
        return false
    if not GuestExec_IsSupported():
        return false
    can Unsafe.ExecutableCodePublish:
        return c_GuestExec_PublishExecutableCode(address, size) == 0

