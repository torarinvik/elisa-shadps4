# ============================================================
# Pure-Elisa guest-runtime state (ported from guest_exec_runtime.c).
# Shared crash/boundary state plus the cross-process ForkReport struct. The
# x86_64 signal/fork machinery (which writes most of this) is ported in later
# chunks; on non-x86_64 hosts those paths are inert and this state stays at its
# dormant defaults, matching the C behavior.
# ============================================================

# PC source codes
const GE_PC_SOURCE_NONE: s32 = 0
const GE_PC_SOURCE_SIGNAL_UCONTEXT: s32 = 1
const GE_PC_SOURCE_FALLBACK_CHILD_SIGLONGJMP: s32 = 2
