# Oracle slice: emit the consolidated first-HLE-boundary facts exactly once so a
# shadPS4-parity diff can stop at the first divergence (wrong / unmapped /
# unpublished continuation). One-shot so the tape isn't flooded on later boundaries.
global mutable ge_oracle_first_boundary_emitted: s32 = 0
global mutable ge_runtime_hle_recorder_stack_word0: uintptr = 0.uintptr()
global mutable ge_runtime_hle_recorder_stack_word1: uintptr = 0.uintptr()
global mutable ge_runtime_hle_guest_return_addr: GuestPC = 0.uintptr().cast[GuestPC]
global mutable ge_runtime_hle_guest_rsp: GuestStackPointer = 0.uintptr().cast[GuestStackPointer]
global mutable ge_runtime_hle_guest_rbp: GuestFramePointer = 0.uintptr().cast[GuestFramePointer]
global mutable ge_runtime_hle_guest_rdi: uintptr = 0.uintptr()
global mutable ge_runtime_hle_guest_rsi: uintptr = 0.uintptr()
global mutable ge_runtime_hle_guest_rdx: uintptr = 0.uintptr()
global mutable ge_runtime_hle_guest_rcx: uintptr = 0.uintptr()
global mutable ge_runtime_hle_guest_r8: uintptr = 0.uintptr()
global mutable ge_runtime_hle_guest_r9: uintptr = 0.uintptr()
