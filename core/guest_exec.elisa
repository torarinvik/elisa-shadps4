    ge_runtime_hle_first_bad_arg0_return_addr <- 0.uintptr()
    ge_runtime_hle_first_bad_arg0_rsi <- 0.uintptr()
    ge_runtime_hle_first_bad_arg0_rdx <- 0.uintptr()
    ge_runtime_hle_first_tiny_unmapped_arg_sequence <- 0
    ge_runtime_hle_first_tiny_unmapped_arg_index <- 0
    ge_runtime_hle_first_tiny_unmapped_arg_module <- ""
    ge_runtime_hle_first_tiny_unmapped_arg_symbol <- ""
    ge_runtime_hle_first_tiny_unmapped_arg_value <- 0.uintptr()
    ge_runtime_hle_first_tiny_unmapped_arg_return_addr <- 0.uintptr()
    ge_runtime_hle_boundary_guard_sequence <- 0
    ge_runtime_hle_boundary_guard_index <- 0
    ge_runtime_hle_boundary_guard_reason <- GE_BOUNDARY_GUARD_NONE
    ge_runtime_hle_boundary_guard_module <- ""
    ge_runtime_hle_boundary_guard_symbol <- ""
