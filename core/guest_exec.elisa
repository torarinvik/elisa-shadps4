@fixed_layout
@abi_layout(size, 280, align, 8, field, argc, 0, field, argv, 8, field, entry_addr, 272)
struct GuestEntryParams:
    argc: mutable s32
    padding: mutable u32
    argv: mutable static u8&?[33]
    entry_addr: mutable VAddr

# Platform-capability queries: ported from native C to pure Elisa using the
# compile-time target facts (common/arch.elisa). These resolve entirely at build
# time via `static if`, so the unselected branches are eliminated (no runtime
# checks). HostCanRunX64Subprocess uses libc process I/O FFI only for the Apple
# Silicon Rosetta probe.
# Runtime confirmation that this process can ACTUALLY execute native x86_64 guest
# code. The compile-time ARCH_X86_64 fact is necessary but not sufficient: the test
# harness can interpret an x86_64-target build on an Apple Silicon host, where
# ARCH_X86_64 is statically true yet jumping to guest x86_64 code traps (the arm64
# interpreter cannot run x86_64 machine code). Distinguish the genuinely-runnable
# cases — a real Intel binary, or an x86_64 binary under Rosetta — from the arm64
# interpreter via two in-process sysctls: native exec works UNLESS we are on Apple
# Silicon hardware (hw.optional.arm64==1) running natively (proc_translated==0).
global mutable ge_native_x64_runnable_cache: s32 = -1

def ge_sysctl_flag(name: u8&) -> s32:
    value: mutable s32 = 0
    length: mutable usize = 4
    rc: int = sysctlbyname(name, (&value).cast[void&?], &length, null, 0)
    if rc != 0:
        return 0
    return value

def ge_host_native_x64_runnable() -> s32:
    ensure result == 0 or result == 1
    if ge_native_x64_runnable_cache == 0:
        return 0
    if ge_native_x64_runnable_cache == 1:
        return 1
    apple_silicon_hw: s32 = ge_sysctl_flag("hw.optional.arm64")
    translated: s32 = ge_sysctl_flag("sysctl.proc_translated")
    if apple_silicon_hw == 1 and translated == 0:
        # Apple Silicon hardware, running natively (not under Rosetta): this build is
        # the arm64 interpreter masquerading as an x86_64 target — guest exec traps.
        can Global:
            ge_native_x64_runnable_cache <- 0
        return 0
    can Global:
        ge_native_x64_runnable_cache <- 1
    return 1

def c_GuestExec_IsSupported() -> s32:
    static if PLATFORM_WINDOWS:
        return 0
    static elif ARCH_X86_64:
        static if PLATFORM_APPLE:
            return ge_host_native_x64_runnable()
        static else:
            return 1
    static else:
        return 0

def c_GuestExec_SupportedNativeExecution() -> s32:
    return c_GuestExec_IsSupported()

def c_GuestExec_HostArchitecture() -> static u8&?:
    static if ARCH_X86_64:
        return "x86_64"
    static elif ARCH_ARM64:
        return "arm64"
    static else:
        return "unknown"

def c_GuestExec_HostMode() -> static u8&?:
    static if PLATFORM_WINDOWS:
        return "Windows"
    static elif PLATFORM_APPLE:
        return "macOS"
    static elif PLATFORM_LINUX:
        return "Linux"
    static elif PLATFORM_FREEBSD:
        return "FreeBSD"
    static else:
        return "unknown"

def c_GuestExec_HostCanRunX64Subprocess() -> s32:
    ensure result == 0 or result == 1
    static if ARCH_X86_64:
        return 1
    static elif PLATFORM_APPLE and ARCH_ARM64:
        line: mutable u8[64] = zeroed
        proc: void&? = popen("/usr/bin/arch -x86_64 /usr/bin/uname -m 2>/dev/null", "r")
        if proc == null:
            return 0
        has_x64: mutable s32 = 0
        read_result: mutable u8&? = fgets(line[0], 64, proc)
        if read_result != null:
            i: mutable usize = 0
            while i < 64:
                if line[i] == 0:
                    i <- 64
                elif line[i] == '\n' or line[i] == '\r':
                    line[i] <- 0
                    i <- 64
                else:
                    i <- i + 1
            if streq((&line[0]).cast[static u8&], "x86_64") == 1:
                has_x64 <- 1
        status: int = pclose(proc)
        if status != 0:
            return 0
        if has_x64 == 1:
            return 1
        return 0
    static else:
        return 0

# Trusted boundary: this is the Apple subprocess handoff used when an arm64 host
# cannot execute guest x86_64 code in-process. The production C++ lane uses
# posix_spawn with an x86_64 architecture preference and an owned NUL-terminated
# argv vector; this Elisa port keeps the same observable contract via a real
# fork + execv of /usr/bin/arch -x86_64 <path> [args...], blocking-waiting the
# child and returning its WEXITSTATUS so genuine guest x86_64 code runs under
# Rosetta on an arm64 host. Null-path and Rosetta-unavailable guards preserved.
@link_name(execv)
extern ge_execv(path: static u8&, argv: static u8&?&) -> int
@link_name(fork)
extern ge_spawn_fork() -> int
@link_name(waitpid)
extern ge_spawn_waitpid(pid: int, status: mutable int&, options: int) -> int

def ge_spawn_x64_subprocess(path: u8&?, argv: static u8&?&?) -> s32:
    ensure result >= -1
    if path == null:
        return -1
    if c_GuestExec_HostCanRunX64Subprocess() != 1:
        return -1
    # Build argv: ["/usr/bin/arch", "-x86_64", path, <user argv[1..]...>, NULL].
    # User argv[0] is the guest program name and is replaced by `path`, matching
    # execv conventions; remaining user args are forwarded verbatim.
    spawn_argv: mutable static u8&?[64] = zeroed
    spawn_argv[0] <- "/usr/bin/arch"
    spawn_argv[1] <- "-x86_64"
    spawn_argv[2] <- path.cast[static u8&?]
    n: mutable usize = 3
    if argv != null:
        ua: static u8&?& = argv
        ui: mutable usize = 1
        can Unsafe.AssumeProgress:
            while ui < 60:
                decreases 60 - ui
                entry: static u8&? = ua[ui]
                if entry == null:
                    ui <- 60
                else:
                    spawn_argv[n] <- entry
                    n <- n + 1
                    ui <- ui + 1
    spawn_argv[n] <- null
    child: int = ge_spawn_fork()
    if child < 0:
        return -1
    if child == 0:
        # Child: exec /usr/bin/arch under x86_64. On failure, exit 127.
        ge_execv("/usr/bin/arch", (&spawn_argv[0]).cast[static u8&?&])
        ge_exit_now(127)
        return -1
    status: mutable int = 0
    waited: int = ge_spawn_waitpid(child, (&status).cast[mutable int&], 0)
    if waited != child:
        return -1
    if ge_wif_exited(status):
        code: int = ge_wexitstatus(status) & 0xff
        out: s32 = code.s32()
        if out < 0:
            return -1
        return out
    if ge_wif_signaled(status):
        sig: int = (128 + (ge_wtermsig(status) & 0x7f))
        sout: s32 = sig.s32()
        if sout < 0:
            return -1
        return sout
    return -1

def c_GuestExec_SpawnX64Subprocess(path: u8&?, argv: static u8&?&?) -> s32:
    return ge_spawn_x64_subprocess(path, argv)

def c_GuestExec_AeroLibFallbackStubAddress() -> uintptr:
