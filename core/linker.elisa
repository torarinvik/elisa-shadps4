# Diagnostic: order-dependent fingerprint of every symbol relocation's
# resolution outcome (symbol index + relocation type + whether it fell to the
# fallback stub), accumulated during relocation. Two runs with identical inputs
# must produce identical fingerprints; a difference localises nondeterminism to
# the resolution path.
global mutable linker_resolution_fp: u64 = 0
global mutable linker_resolution_relocs: u64 = 0
global mutable linker_seq_fp: u64 = 0
global mutable linker_name_fp: u64 = 0
global mutable linker_dbg_first_name: static u8&? = null
global mutable linker_dbg_first_index: u32 = 0
global mutable linker_name_setfp: u64 = 0
global mutable linker_name_count: u64 = 0

def Linker_DbgFirstName() -> static u8&:
    if linker_dbg_first_name == null:
        return ""
    return linker_dbg_first_name
def Linker_DbgFirstIndex() -> u32:
    return linker_dbg_first_index
def Linker_NameSetFingerprint() -> u64:
    return linker_name_setfp
def Linker_NameCount() -> u64:
    return linker_name_count

def Linker_ResetResolutionFingerprint() -> void:
    linker_resolution_fp <- 0xcbf29ce484222325
    linker_seq_fp <- 0xcbf29ce484222325
    linker_name_fp <- 0xcbf29ce484222325
    linker_resolution_relocs <- 0
    linker_dbg_first_name <- null
    linker_dbg_first_index <- 0
    linker_name_setfp <- 0
    linker_name_count <- 0

def Linker_ResolutionFingerprintValue() -> u64:
    return linker_resolution_fp

def Linker_SeqFingerprintValue() -> u64:
    return linker_seq_fp

def Linker_NameFingerprintValue() -> u64:
    return linker_name_fp

def Linker_ResolutionRelocCount() -> u64:
    return linker_resolution_relocs

def Linker_MixResolution(symbol_index: u32, is_stub: bool, rel_type: u32, name: static u8&) -> void:
    stub_bit: u64 = 1 if is_stub else 0
    # Sequence fingerprint: relocation identity only (must be stable).
    seq: u64 = symbol_index.u64() ^ (rel_type.u64() << 24)
    linker_seq_fp <- (linker_seq_fp ^ seq) * 0x100000001b3
    # Name fingerprint: the resolved symbol name bytes (must be stable if the
    # symbol/string tables are read deterministically).
    n: mutable usize = 0
    nl: usize = static_strlen(name)
    per_name: mutable u64 = 0xcbf29ce484222325
    while n < nl:
        linker_name_fp <- (linker_name_fp ^ name[n].u64()) * 0x100000001b3
        per_name <- (per_name ^ name[n].u64()) * 0x100000001b3
        n <- n + 1
    linker_name_fp <- linker_name_fp ^ 0xff
    if nl > 0:
        # Order-independent: combine (symbol_index, content-hash) so a stable set
        # of (index -> name) yields a stable value regardless of visit order.
        linker_name_setfp <- linker_name_setfp + (per_name ^ (symbol_index.u64() * 0x9e3779b97f4a7c15))
        linker_name_count <- linker_name_count + 1
    if nl > 0 and linker_dbg_first_name == null:
        linker_dbg_first_name <- name
        linker_dbg_first_index <- symbol_index
    # Resolution fingerprint: includes the stub/resolved outcome.
    linker_resolution_fp <- (linker_resolution_fp ^ (seq ^ (stub_bit << 40))) * 0x100000001b3
    linker_resolution_relocs <- linker_resolution_relocs + 1

# Count of registered HLE symbols whose callable_address is zero. A nonzero,
# run-to-run-varying count would reveal an uninitialized-scalar (address) read.
def Linker_HleZeroAddrCount(self: Linker&) -> u64:
    count: mutable u64 = 0
    i: mutable usize = 0
    while i < self.hle_symbols.symbols.count:
        if self.hle_symbols.symbols[i].callable_address == 0:
            count <- count + 1
        i <- i + 1
    return count

def Linker_FallbackTableFingerprint() -> u64:
    # Order-independent fingerprint of the fallback slot table: sum of a per-slot
    # FNV-style mix of (slot_va, symbol_index). Used to compare the unresolved
    # set across relocation passes / process runs.
    acc: mutable u64 = 0
    count: u32 = Linker_FallbackSlotCount()
    i: mutable u32 = 0
    while i < count:
        mix: u64 = (Linker_FallbackSlotVaAt(i) ^ (Linker_FallbackSlotSymbolIndexAt(i).u64() * 0x9e3779b97f4a7c15)) * 0x100000001b3
        acc <- acc + mix
        i <- i + 1
    return acc

def Linker_RuntimeLifecycleNoop() -> int:
    return 0

def Linker_AeroLibFallbackStub() -> u64:
    GuestExec_RecordFirstBoundary(GUEST_EXEC_BOUNDARY_REASON_AEROLIB_FALLBACK)
    return 0

def Linker_FileExists(path: static u8&) -> bool:
    file: mutable IOFile = IOFile()
    opened: bool = file.Open(path, FileAccessMode.Read) == 0
    file.Close()
    return opened

def Linker_ResolveGuestModulePath(self: Linker&, guest_path: static u8&) -> static u8&:
    len: usize = static_strlen(guest_path)
    if len == 0:
        return ""
    root: mutable static u8& = ""
    if self.app0_host_root != null:
        root <- self.app0_host_root
    can Memory.Allocate, Abort.Panic:
        if len >= 5 and guest_path[0] == '/'.u8() and guest_path[1] == 'a'.u8() and guest_path[2] == 'p'.u8() and guest_path[3] == 'p'.u8() and guest_path[4] == '0'.u8():
            if len == 5:
                return root
            if guest_path[5] == '/'.u8():
                suffix: static u8& = Linker_Substr(guest_path, 6, len - 6)
                return Linker_PathJoin(root, suffix)
        if guest_path[0] != '/'.u8() and not Linker_StringContainsSlash(guest_path):
            return Linker_PathJoin(root, guest_path)
    return guest_path

def Linker_StaticTlsSize(self: Linker&) -> usize:
    return self.static_tls_size

def Linker_DependencyGuestPath(name: static u8&) -> static u8&:
    if static_strlen(name) == 0:
        return ""
    if Linker_StringContainsSlash(name):
        return name
    can Memory.Allocate, Abort.Panic:
        if Linker_StringHasSuffix(name, ".prx") or Linker_StringHasSuffix(name, ".sprx"):
            return Linker_PathJoin("/app0/sce_module", name)
        return Linker_PathJoin("/app0/sce_module", Linker_Concat2(name, ".prx"))

def Linker_LoadGuestDependency(self: mutable Linker&, dependency_name: static u8&) -> s32 can[Unsafe.SegmentMutation, Unsafe.GuestSegmentInstall, Segment.Guest, Segment.Host, Memory.Allocate, Abort.Panic]:
    # One effect-grant block wraps the whole body: all six effects are already in the
    # signature, and keeping every local in a single scope avoids `can:`-block scoping
    # dropping `guest_path`/`mod_ref`/`idx` (and preserves the null-narrowing of mod_ref).
    can Unsafe.SegmentMutation, Unsafe.GuestSegmentInstall, Segment.Guest, Segment.Host, Memory.Allocate, Abort.Panic:
        guest_path: static u8& = Linker_DependencyGuestPath(dependency_name)
        if static_strlen(guest_path) == 0:
            return -1
        host_path: static u8& = Linker_ResolveGuestModulePath((&self).cast[Linker&], guest_path)
        if static_strlen(host_path) == 0:
            return -1
        existing: mutable u32 = Linker_FindByFileOrHost((&self).cast[Linker&], guest_path)
        if existing != 0xFFFFFFFF.u32():
            return existing.s32()
        existing <- Linker_FindByFileOrHost((&self).cast[Linker&], host_path)
        if existing != 0xFFFFFFFF.u32():
            return existing.s32()
        if not Linker_FileExists(host_path):
            return -1
        idx: s32 = Linker_LoadModuleFromHost((&self).cast[mutable Linker&], guest_path, host_path, true)
        if idx < 0:
            return idx
        mod_ref: mutable Module&? = Linker_GetModule((&self).cast[mutable Linker&], idx)
        if mod_ref == null:
            return -1
        Linker_RelocateAnyImports((&self).cast[mutable Linker&], mod_ref)
        if mod_ref.tls.image_size != 0:
            Linker_AdvanceGenerationCounter((&self).cast[mutable Linker&])
        # In deferred-start mode the dependency inits are NOT run here. Capture their
        # init-array function-pointer VALUES from the MemoryManager backing right now --
        # the exact point (post per-module relocation, pre-darray-realloc) where the
        # original Module_Start reads them successfully (0x...600 etc.). They are gone
        # from every layer by execution time, so this transient window is the only place
        # to read them. Run later via the init trampoline. Otherwise start now (shadPS4
        # parity: LoadAndStartModule passes the module's proc param to Start).
        if not linker_defer_dependency_start:
            _ = Module_Start(mod_ref, 0, null, Module_GetProcParam(mod_ref).cast[void&?])
        else:
            Linker_CaptureInitValuesNow(mod_ref, mod_ref.dynamic_info.preinit_array_virtual_addr, mod_ref.dynamic_info.preinit_array_size)
            Linker_CaptureInitValuesNow(mod_ref, mod_ref.dynamic_info.init_array_virtual_addr, mod_ref.dynamic_info.init_array_size)
        return idx

def Linker_PreloadLibkernelGameModules(self: mutable Linker&) -> void can[Unsafe.SegmentMutation, Unsafe.GuestSegmentInstall, Segment.Guest, Segment.Host]:
    # shadPS4's sceSysmodulePreloadModuleForLibkernel loads these app-local
    # modules before the guest entry runs. Do this before the eager dependency
    # closure so the module table order matches the executable oracle.
    can Unsafe.SegmentMutation, Unsafe.GuestSegmentInstall, Segment.Guest, Segment.Host, Memory.Allocate, Abort.Panic:
        _ = Linker_LoadGuestDependency((&self).cast[mutable Linker&], "libSceFios2")
        _ = Linker_LoadGuestDependency((&self).cast[mutable Linker&], "libc")

def Linker_LoadDependencyClosure(self: mutable Linker&) -> void can[Unsafe.SegmentMutation, Unsafe.GuestSegmentInstall, Segment.Guest, Segment.Host]:
    initial_count: usize = self.modules.count
    ge_emergency_mark(GE_EV_DEP_CLOSURE_BEGIN, initial_count.uintptr(), self.modules.count.uintptr(), 0.uintptr(), 0.uintptr())
    index: mutable usize = 0
    while index < self.modules.count:
        dep_count: usize = self.modules[index].dynamic_info.import_modules.count
        ge_emergency_mark(GE_EV_DEP_CLOSURE_MODULE_BEGIN, index.uintptr(), dep_count.uintptr(), self.modules.count.uintptr(), self.modules[index].base_virtual_addr)
        dep_index: mutable usize = 0
        while dep_index < dep_count:
            dep_name: static u8& = self.modules[index].dynamic_info.import_modules[dep_index].name
            ge_emergency_mark(GE_EV_DEP_CLOSURE_DEP_BEGIN, index.uintptr(), dep_index.uintptr(), dep_count.uintptr(), self.modules.count.uintptr())
            dep_result: mutable s32 = 0
            can Unsafe.SegmentMutation, Unsafe.GuestSegmentInstall, Segment.Guest, Segment.Host, Memory.Allocate, Abort.Panic:
                dep_result <- Linker_LoadGuestDependency((&self).cast[mutable Linker&], dep_name)
            ge_emergency_mark(GE_EV_DEP_CLOSURE_DEP_END, index.uintptr(), dep_index.uintptr(), dep_result.u64().uintptr(), self.modules.count.uintptr())
            dep_index <- dep_index + 1
        ge_emergency_mark(GE_EV_DEP_CLOSURE_MODULE_END, index.uintptr(), dep_count.uintptr(), self.modules.count.uintptr(), self.modules[index].base_virtual_addr)
        index <- index + 1
    if self.modules.count != initial_count:
        self.relocated_all_imports <- false
    ge_emergency_mark(GE_EV_DEP_CLOSURE_END, initial_count.uintptr(), self.modules.count.uintptr(), 0.uintptr(), 0.uintptr())

# Marker kind for a machine-code emit that would write past the end of a thunk
# buffer. Raw u32 kind (GE_EV_* live in guest_exec.elisa); the payload carries the
# offending offset, the write width, and the buffer length so a fault is
# self-describing. Distinct from the relocation/HLE markers above.
const LINKER_EV_THUNK_EMIT_OOB: u32 = 0x544B4F42  # 'TKOB'

# Bounds-checked little-endian immediate writers for the HLE thunk generators.
# `len` is the length of the destination buffer; the write is refused (and a
# self-describing emergency marker is raised) unless the whole `width`-byte field
# fits, i.e. `offset + width <= len`. The `offset > len` pre-check makes the
# `len - offset` usize subtraction wrap-free, and `len - offset >= width` then
# proves every indexed store below is in range. Returns true iff the field was
# fully written; callers MUST abort thunk creation on false so a wrong offset can
# never corrupt adjacent storage nor leave a half-formed thunk. On the success
# path the emitted bytes are byte-identical to a direct indexed store.
def Linker_WriteU16LE(out: mutable u8&, len: usize, offset: usize, value: u16) -> bool:
    if offset > len or (len - offset) < 2:
        ge_emergency_mark(LINKER_EV_THUNK_EMIT_OOB, offset.uintptr(), 2.uintptr(), len.uintptr(), value.u64().uintptr())
        return false
    out[offset] <- (value & 0xff).u8()
    out[offset + 1] <- ((value >> 8) & 0xff).u8()
    return true

def Linker_WriteU64LE(out: mutable u8&, len: usize, offset: usize, value: u64) -> bool:
    if offset > len or (len - offset) < 8:
        ge_emergency_mark(LINKER_EV_THUNK_EMIT_OOB, offset.uintptr(), 8.uintptr(), len.uintptr(), value.uintptr())
        return false
    i: mutable usize = 0
    while i < 8:
        shift: u64 = (i.u64() * 8)
        out[offset + i] <- ((value >> shift) & 0xff).u8()
        i <- i + 1
    return true

def Linker_UseNativeHleBoundaryThunk() -> bool:
    static if PLATFORM_APPLE and ARCH_X86_64:
        if getenv("ELISA_GUEST_EXEC_NO_HLE_BOUNDARY_THUNK".cast[u8&]) != null:
            return false
        return getenv("ELISA_GUEST_EXEC_NO_FORK".cast[u8&]) != null or getenv("ELISA_GUEST_EXEC_BOUNDARY_THUNK".cast[u8&]) != null
    static else:
        return false

def Linker_NativeHleBoundaryThunkCount() -> u64:
    return linker_native_hle_thunk_count.u64()

def Linker_NativeHleBoundaryThunkEnabled() -> bool:
    return Linker_UseNativeHleBoundaryThunk()

def Linker_FindNativeHleBoundaryThunkBase(address: u64) -> u64:
    i: mutable usize = 0
    while i < linker_native_hle_thunk_count and i < LINKER_NATIVE_HLE_THUNK_CAP:
        decreases LINKER_NATIVE_HLE_THUNK_CAP - i
        base: u64 = linker_native_hle_thunk_addrs[i]
        if address >= base and address < base + 4096:
            return base
        i <- i + 1
    return 0

def Linker_FindNativeHleBoundaryThunkTarget(address: u64) -> u64:
    i: mutable usize = 0
    while i < linker_native_hle_thunk_count and i < LINKER_NATIVE_HLE_THUNK_CAP:
        decreases LINKER_NATIVE_HLE_THUNK_CAP - i
        base: u64 = linker_native_hle_thunk_addrs[i]
        if address >= base and address < base + 4096:
            return linker_native_hle_thunk_targets[i]
        i <- i + 1
    return 0

def Linker_NativeHleFunctionRelocationCount() -> u64:
    return linker_native_hle_function_relocation_count

def Linker_NativeHleDataRelocationCount() -> u64:
    return linker_native_hle_data_relocation_count

def Linker_NativeHleUnthunkedFunctionCount() -> u64:
    return linker_native_hle_unthunked_function_count

def Linker_NativeHleUnthunkedFunctionFirstTarget() -> u64:
    return linker_native_hle_unthunked_function_first_target

def Linker_NativeHleFunctionAddendCount() -> u64:
    return linker_native_hle_function_addend_count

def Linker_NativeHleFunctionMaxAddend() -> u64:
    return linker_native_hle_function_max_addend

def Linker_NativeHleDataThunkPointerCount() -> u64:
    return linker_native_hle_data_thunk_pointer_count

def Linker_NativeHleDataThunkPointerFirstValue() -> u64:
    return linker_native_hle_data_thunk_pointer_first_value

def Linker_NativeHleDataThunkPointerFirstName() -> static u8&?:
    return linker_native_hle_data_thunk_pointer_first_name

def Linker_NoteNativeHleDataRelocationValue(value: u64, symbol_name: static u8&?) -> void:
    if value == 0:
        return
    if Linker_FindNativeHleBoundaryThunkBase(value) == 0:
        return
    if linker_native_hle_data_thunk_pointer_count == 0:
        linker_native_hle_data_thunk_pointer_first_value <- value
        linker_native_hle_data_thunk_pointer_first_name <- symbol_name
    linker_native_hle_data_thunk_pointer_count <- linker_native_hle_data_thunk_pointer_count + 1

# Record a pointer-bearing relocation whose final written value is a near-NULL
# bogus pointer. Call AFTER computing the value, only for pointer relocations
# (RELATIVE / 64 / GLOB_DAT / JUMP_SLOT) -- never for DTPMOD64.
def Linker_NoteRelocatedPointerValue(value: u64, rel_virtual_addr: u64, rel_type: u32, symbol_name: static u8&?, module_name: static u8&?) -> void:
    if value == 0 or value >= LINKER_TINY_POINTER_THRESHOLD:
        return
    if linker_tiny_pointer_slot_count == 0:
        linker_tiny_pointer_first_value <- value
        linker_tiny_pointer_first_offset <- rel_virtual_addr
        linker_tiny_pointer_first_type <- rel_type
        linker_tiny_pointer_first_name <- symbol_name
        linker_tiny_pointer_first_module <- module_name
    linker_tiny_pointer_slot_count <- linker_tiny_pointer_slot_count + 1

def Linker_TinyPointerSlotCount() -> u64:
    return linker_tiny_pointer_slot_count

def Linker_TinyPointerFirstValue() -> u64:
    return linker_tiny_pointer_first_value

def Linker_TinyPointerFirstOffset() -> u64:
    return linker_tiny_pointer_first_offset

def Linker_TinyPointerFirstType() -> u32:
    return linker_tiny_pointer_first_type

def Linker_TinyPointerFirstName() -> static u8&?:
    return linker_tiny_pointer_first_name

def Linker_TinyPointerFirstModule() -> static u8&?:
    return linker_tiny_pointer_first_module

def Linker_TlsGetAddrCalls() -> u64:
    return linker_tls_get_addr_calls

def Linker_TlsLastModuleIndex() -> u64:
    return linker_tls_last_module_index

