def Linker_HleSymbolsStringChecksum(self: Linker&) -> u64:
    # FNV-1a over every HLE symbol's name + nid strings (NOT callable_address,
    # which is ASLR-randomized). Detects use-after-free corruption of the HLE
    # resolver table independent of address-space layout.
    hash: mutable u64 = 0xcbf29ce484222325u64
    i: mutable usize = 0
    while i < self.hle_symbols.symbols.count:
        sym: SymbolRecord = self.hle_symbols.symbols[i]
        # Scan name + nid through bounds-safe views (the cstr coercion measures
        # each string once; view indexing is proven in range).
        name_c: cstr = sym.name
        name_view: sview = name_c[0:name_c.len]
        n: mutable usize = 0
        while n < name_view.len.usize():
            hash <- (hash ^ name_view[n].u64()) * 0x100000001b3u64
            n <- n + 1
        nid_c: cstr = sym.nid_name
        nid_view: sview = nid_c[0:nid_c.len]
        m: mutable usize = 0
        while m < nid_view.len.usize():
            hash <- (hash ^ nid_view[m].u64()) * 0x100000001b3u64
            m <- m + 1
        hash <- hash ^ 0xffu64
        i <- i + 1
    return hash

def Linker_GetInstance() -> mutable Linker&:
    return linker_singleton.ref[mutable Linker&]

def Linker_Reset() -> void:
    Memory_Reset()
    GuestExec_ResetState()
    TLS_ResetForTests()
    Module_ResetMetadataArena()
    Module_StartOracleReset()
    linker_hle_tiny_callable_count <- 0
    linker_hle_tiny_callable_first_value <- 0
    linker_hle_tiny_callable_first_name <- null
    linker_hle_tiny_callable_first_nid <- null
    linker_application_heap_api <- 0.uintptr()
    linker_singleton <- Linker_New()

def Linker_GetHLESymbols(self: mutable Linker&) -> mutable SymbolsResolver&:
    return self.hle_symbols.ref[mutable SymbolsResolver&]

def SymbolsResolver_AddSymbol(self: mutable SymbolsResolver&, nid: static u8&, name: static u8&, virtual_address: u64) -> void:
    SymbolsResolver_AddBoundSymbol(self, nid, name, virtual_address, virtual_address)

def SymbolsResolver_AddBoundSymbol(self: mutable SymbolsResolver&, nid: static u8&, name: static u8&, virtual_address: u64, callable_address: u64) -> void:
    SymbolsResolver_AddBoundSymbolForLibrary(self, nid, name, "", 0u16, "", IMPORT_SYMBOL_TYPE_UNKNOWN, virtual_address, callable_address)

def SymbolsResolver_AddBoundSymbolForLibrary(self: mutable SymbolsResolver&, nid: static u8&, name: static u8&, library: static u8&, library_version: u16, module: static u8&, symbol_type: u8, virtual_address: u64, callable_address: u64) -> void:
    Linker_NoteHleCallableRegistration(nid, name, symbol_type, callable_address)
    # The HLE symbol table outlives this call, so its backing storage must be
    # allocated from the persistent metadata arena. Using a transient local
    # arena here freed the darray backing on return, leaving the resolver table
    # in use-after-free memory and making import resolution nondeterministic.
    owner: mutable Arena& = module_metadata_arena.ref[mutable Arena&]
    in owner:
        self.symbols.push(SymbolRecord(nid, name, library, library_version, module, symbol_type, virtual_address, callable_address))

def Linker_NoteHleCallableRegistration(nid: static u8&, name: static u8&, symbol_type: u8, callable_address: u64) -> void:
    if symbol_type != IMPORT_SYMBOL_TYPE_FUNCTION and symbol_type != IMPORT_SYMBOL_TYPE_UNKNOWN:
        return
    if callable_address >= LINKER_TINY_POINTER_THRESHOLD:
        return
    if linker_hle_tiny_callable_count == 0u64:
        linker_hle_tiny_callable_first_value <- callable_address
        linker_hle_tiny_callable_first_name <- name
        linker_hle_tiny_callable_first_nid <- nid
    linker_hle_tiny_callable_count <- linker_hle_tiny_callable_count + 1u64

def Linker_HleTinyCallableCount() -> u64:
    return linker_hle_tiny_callable_count

def Linker_HleTinyCallableFirstValue() -> u64:
    return linker_hle_tiny_callable_first_value

def Linker_HleTinyCallableFirstName() -> static u8&?:
    return linker_hle_tiny_callable_first_name

def Linker_HleTinyCallableFirstNid() -> static u8&?:
    return linker_hle_tiny_callable_first_nid

def Linker_SetHeapAPI(func: void&?) -> void:
    if func == null:
        linker_application_heap_api <- 0.uintptr()
        return
    linker_application_heap_api <- func.uintptr()

def Linker_GetHeapAPI() -> uintptr:
    return linker_application_heap_api

def Linker_BootstrapApplicationHeapApi() -> void can[Unsafe.SegmentMutation, Unsafe.GuestSegmentInstall, Segment.Guest, Segment.Host]:
    if linker_application_heap_bootstrap_done:
        return
    linker_application_heap_bootstrap_done <- true
    heap_api: uintptr = Linker_GetHeapAPI()
    if heap_api == 0.uintptr():
        return
    malloc_fn_addr: uintptr = GuestExec_ReadNativeU64(heap_api)
    linker_application_heap_bootstrap_malloc <- malloc_fn_addr
    if malloc_fn_addr == 0.uintptr():
        ge_emergency_mark(GE_EV_HLE_KNOWN_TARGET, 0x48454152.uintptr(), heap_api, 0.uintptr(), 0.uintptr())
        return
    linker_application_heap_bootstrap_attempts <- linker_application_heap_bootstrap_attempts + 1u64
    ge_emergency_mark(GE_EV_HLE_KNOWN_TARGET, 0x48454152.uintptr(), heap_api, malloc_fn_addr, 0xb0.uintptr())
    static if PLATFORM_APPLE and ARCH_X86_64:
        guest_selector: GuestFsSelector = TLS_PrepareTcbBase((!TLS_PrimaryTcbBase()).cast[void&?])
        host_selector: HostFsSelector = TLS_CaptureHostFsSelector()
        if !guest_selector == 0u32:
            ge_emergency_mark(GE_EV_HLE_KNOWN_TARGET, 0x48454153.uintptr(), heap_api, malloc_fn_addr, 0.uintptr())
            return
        result: mutable void&? = null
        can Unsafe.SegmentMutation, Segment.Host, Segment.Guest:
            result <- TLS_CallGuestThreadEntryWithPreparedSegment(malloc_fn_addr.cast[void&?], 0xb0.uintptr().cast[void&?], guest_selector, host_selector)
        linker_application_heap_bootstrap_result <- result.uintptr()
        ge_emergency_mark(GE_EV_HLE_KNOWN_TARGET, 0x48454154.uintptr(), malloc_fn_addr, result.uintptr(), 0xb0.uintptr())
    static else:
        ge_emergency_mark(GE_EV_HLE_KNOWN_TARGET, 0x48454155.uintptr(), heap_api, malloc_fn_addr, 0.uintptr())

def SymbolsResolver_Count(self: SymbolsResolver&) -> usize:
    return self.symbols.count

def SymbolsResolver_FindByNid(self: SymbolsResolver&, nid: static u8&) -> s32:
    for i in 0..<self.symbols.count:
        if streq(self.symbols[i].name, nid) == 1:
            return i.s32()
    return -1

def SymbolsResolver_FindHleSymbol(self: SymbolsResolver&, nid: static u8&, library: static u8&, library_version: u16, module: static u8&, symbol_type: u8) -> s32:
    for i in 0..<self.symbols.count:
        sym: SymbolRecord = self.symbols[i]
        if streq(sym.nid_name, nid) != 1 and not Linker_NameMatchesNid(sym.name, nid):
            continue
        if static_strlen(sym.library) == 0 or static_strlen(sym.module) == 0:
            continue
        if streq(sym.library, library) != 1:
            continue
        if sym.library_version != library_version:
            continue
        if streq(sym.module, module) != 1:
            continue
        if symbol_type != IMPORT_SYMBOL_TYPE_UNKNOWN and sym.symbol_type != IMPORT_SYMBOL_TYPE_UNKNOWN and sym.symbol_type != symbol_type:
            continue
        return i.s32()
    return -1

def SymbolsResolver_FindHleSymbolByNidOnly(self: SymbolsResolver&, nid: static u8&) -> s32:
    return SymbolsResolver_FindHleSymbolByNidOnlyTyped(self, nid, IMPORT_SYMBOL_TYPE_UNKNOWN)

def SymbolsResolver_FindHleSymbolByNidOnlyTyped(self: SymbolsResolver&, nid: static u8&, symbol_type: u8) -> s32:
    for i in 0..<self.symbols.count:
        sym: SymbolRecord = self.symbols[i]
        if Linker_NameMatchesNid(sym.name, nid) or streq(sym.nid_name, nid) == 1:
            if symbol_type != IMPORT_SYMBOL_TYPE_UNKNOWN and sym.symbol_type != IMPORT_SYMBOL_TYPE_UNKNOWN and sym.symbol_type != symbol_type:
                continue
            return i.s32()
    return -1

def Linker_GetProcParam(self: Linker&) -> VAddr:
    if self.modules.count == 0:
        return 0.uintptr()
    return self.modules[0].proc_param_virtual_addr

def Linker_GetCompiledSdkVersion(self: Linker&) -> u32:
    if self.modules.count == 0:
        return ORBIS_SDK_FW_50.u32()
    module: Module = self.modules[0]
    proc_param: VAddr = module.proc_param_virtual_addr
    if proc_param == 0.uintptr():
        return ORBIS_SDK_FW_50.u32()
    sdk_version: u64 = Module_ReadImageU64(module, proc_param.u64() + 16u64)
    if sdk_version == 0u64:
        return ORBIS_SDK_FW_50.u32()
    return sdk_version.u32()

def Linker_GetFlexibleMemorySize(self: Linker&) -> u64:
    if self.modules.count == 0:
        return ORBIS_KERNEL_FLEXIBLE_MEMORY_SIZE
    module: Module = self.modules[0]
    proc_param: VAddr = module.proc_param_virtual_addr
    if proc_param == 0.uintptr():
        return ORBIS_KERNEL_FLEXIBLE_MEMORY_SIZE
    memory: mutable MemoryManager& = Memory_Instance()
    proc_param_size: u64 = MemoryManager_ReadU64(memory, proc_param)
    if proc_param_size < 72u64:
        return ORBIS_KERNEL_FLEXIBLE_MEMORY_SIZE
    mem_param: u64 = MemoryManager_ReadU64(memory, proc_param + 64.uintptr())
    if mem_param == 0u64:
        return ORBIS_KERNEL_FLEXIBLE_MEMORY_SIZE
    mem_param_addr: VAddr = mem_param.uintptr()
    mem_param_size: u64 = MemoryManager_ReadU64(memory, mem_param_addr)
    if mem_param_size < 24u64:
        return ORBIS_KERNEL_FLEXIBLE_MEMORY_SIZE
    flexible_size_ptr: u64 = MemoryManager_ReadU64(memory, mem_param_addr + 16.uintptr())
    if flexible_size_ptr == 0u64:
        return ORBIS_KERNEL_FLEXIBLE_MEMORY_SIZE
    requested: u64 = MemoryManager_ReadU64(memory, flexible_size_ptr.uintptr())
    if requested == 0u64:
        return ORBIS_KERNEL_FLEXIBLE_MEMORY_SIZE
    return requested + ORBIS_KERNEL_FLEXIBLE_MEMORY_BASE

def Linker_ReadMemParamFlag(memory: MemoryManager&, ptr: u64) -> bool:
    if ptr == 0u64:
        return false
    return MemoryManager_ReadU8(memory, ptr.uintptr()) != 0u8

def Linker_GetUseExtendedMemory1(self: Linker&) -> bool:
    if Linker_GetCompiledSdkVersion(self) >= ORBIS_SDK_FW_50.u32():
        return true
    if self.modules.count == 0:
        return true
    module: Module = self.modules[0]
    proc_param: VAddr = module.proc_param_virtual_addr
    if proc_param == 0.uintptr():
        return true
    memory: mutable MemoryManager& = Memory_Instance()
    proc_param_size: u64 = MemoryManager_ReadU64(memory, proc_param)
    if proc_param_size < 72u64:
        return false
    mem_param: u64 = MemoryManager_ReadU64(memory, proc_param + 64.uintptr())
    if mem_param == 0u64:
        return false
    mem_param_addr: VAddr = mem_param.uintptr()
    mem_param_size: u64 = MemoryManager_ReadU64(memory, mem_param_addr)
    if mem_param_size < 32u64:
        return false
    extended_memory_1: u64 = MemoryManager_ReadU64(memory, mem_param_addr + 24.uintptr())
    return Linker_ReadMemParamFlag(memory, extended_memory_1)

def Linker_GetUseExtendedMemory2(self: Linker&) -> bool:
    if Linker_GetCompiledSdkVersion(self) >= ORBIS_SDK_FW_50.u32():
        return true
    if self.modules.count == 0:
        return true
    module: Module = self.modules[0]
    proc_param: VAddr = module.proc_param_virtual_addr
    if proc_param == 0.uintptr():
        return true
    memory: mutable MemoryManager& = Memory_Instance()
    proc_param_size: u64 = MemoryManager_ReadU64(memory, proc_param)
    if proc_param_size < 72u64:
        return false
    mem_param: u64 = MemoryManager_ReadU64(memory, proc_param + 64.uintptr())
    if mem_param == 0u64:
        return false
    mem_param_addr: VAddr = mem_param.uintptr()
    mem_param_size: u64 = MemoryManager_ReadU64(memory, mem_param_addr)
    if mem_param_size < 48u64:
        return false
    extended_memory_2: u64 = MemoryManager_ReadU64(memory, mem_param_addr + 40.uintptr())
    return Linker_ReadMemParamFlag(memory, extended_memory_2)

def Linker_GetModule(self: mutable Linker&, index: s32) -> mutable Module&?:
    if index < 0 or index >= self.modules.count.int():
        return null
    return self.modules[index.usize()].ref[mutable Module&]

def Linker_FindByName(self: Linker&, name: static u8&) -> u32:
    for i in 0..<self.modules.count:
        if streq(self.modules[i].file, name) == 1:
            return i.u32()
    return 0xFFFFFFFF.u32()

def Linker_FindByFileOrHost(self: Linker&, name: static u8&) -> u32:
    for i in 0..<self.modules.count:
        if streq(self.modules[i].file, name) == 1 or streq(self.modules[i].host_file, name) == 1:
            return i.u32()
    return 0xFFFFFFFF.u32()

def Linker_MaxTlsIndex(self: Linker&) -> u32:
    return self.max_tls_index

def Linker_GenerationCounter(self: Linker&) -> u32:
    return self.dtv_generation_counter

def Linker_EnableNativeGuestExecution(self: mutable Linker&, enabled: bool) -> void:
    self.native_guest_exec_requested <- enabled
    GuestExec_Enable(enabled)

def Linker_SetApp0HostRoot(self: mutable Linker&, root: static u8&) -> void:
    self.app0_host_root <- root

# Build the result in the persistent metadata arena (stable addresses, no
# per-call heap churn) and return a pointer to its NUL-terminated bytes. The
# buffer is explicitly terminated below; the unbounded-string lint flags this
# conservatively (it cannot prove the terminator) and is a warning here.
# input taken as cstr (sliceable) so the substring is a bounds-safe view that is
# deep-copied into the persistent metadata arena (no unchecked indexing).
def Linker_Substr(input: cstr, start: usize, len: usize) -> static u8&:
    seg: sview = input[start:start + len]
    out: mutable dstr = []
    can Memory.Allocate, Abort.Panic:
        trusted Unsafe.MutableGlobal:
            owner: mutable Arena& = module_metadata_arena.ref[mutable Arena&]
            in owner:
                out <- clone[dstr](seg)
                out.push(0)
    trusted Unsafe.PointerCast, Unsafe.UncheckedIndex:
        return out[0].ref[static u8&]

def Linker_Concat2(lhs: cstr, rhs: cstr) -> static u8&:
    lhs_view: sview = lhs[0:lhs.len]
    rhs_view: sview = rhs[0:rhs.len]
    out: mutable dstr = []
    can Memory.Allocate, Abort.Panic:
        trusted Unsafe.MutableGlobal:
            owner: mutable Arena& = module_metadata_arena.ref[mutable Arena&]
            in owner:
                out <- clone[dstr](lhs_view)
                j: mutable usize = 0
                while j < rhs_view.len.usize():
                    out.push(rhs_view[j])
                    j <- j + 1
                out.push(0)
    trusted Unsafe.PointerCast, Unsafe.UncheckedIndex:
        return out[0].ref[static u8&]

def Linker_PathJoin(lhs: cstr, rhs: cstr) -> static u8&:
    if static_strlen(lhs) == 0:
        return rhs
    if static_strlen(rhs) == 0:
        return lhs
    if Linker_StringHasSuffix(lhs, "/"):
        return Linker_Concat2(lhs, rhs)
    return Linker_Concat2(Linker_Concat2(lhs, "/"), rhs)

def Linker_StringContainsSlash(input: cstr) -> bool:
    view: sview = input[0:input.len]
    i: mutable usize = 0
    while i < view.len.usize():
        if view[i] == '/'.u8():
            return true
        i <- i + 1
    return false

def Linker_StringHasSuffix(input: cstr, suffix: cstr) -> bool:
    input_len: usize = static_strlen(input)
    suffix_len: usize = static_strlen(suffix)
    if suffix_len > input_len:
        return false
    start: usize = input_len - suffix_len
    return sview_eq(input[start:input_len], suffix[0:suffix_len])

def Linker_StringHasPrefix(input: cstr, prefix: cstr) -> bool:
    input_len: usize = static_strlen(input)
    prefix_len: usize = static_strlen(prefix)
    if prefix_len > input_len:
        return false
    return sview_eq(input[0:prefix_len], prefix[0:prefix_len])

def Linker_NameMatchesNid(name: static u8&, nid_or_symbol: static u8&) -> bool:
    if streq(name, nid_or_symbol) == 1:
        return true
    name_len: usize = static_strlen(name)
    if name_len == 0:
        return false
    i: mutable usize = 0
    while i < name_len:
        if nid_or_symbol[i] == 0 or nid_or_symbol[i] == '#'.u8() or name[i] != nid_or_symbol[i]:
            return false
        i <- i + 1
    return nid_or_symbol[i] == 0 or nid_or_symbol[i] == '#'.u8()

# Patch-time table mapping each fallback-patched GOT slot virtual address to the
# import symbol name it was meant to resolve. Used to attribute the runtime
# AeroLib fallback boundary (whose slot VA the native stub recovers) back to a
# concrete unimplemented import. The table lives in the native runtime so the
# relocation hot path does not need an arena/Memory effect scope to record into
# it.
# Ported from native/guest_exec_runtime.c to pure Elisa. The table is plain
# parent-side bookkeeping (populated during relocation, queried after a guarded
# run); it never touches the fork-report shared memory, signals, or mmap, so it
# carries no allocation/effect requirement — fixed global arrays keep the
# relocation hot path arena-free, exactly as the native version intended.
const FALLBACK_SLOT_CAP: u32 = 8192u32

global mutable g_fallback_slot_addrs: u64[8192] = zeroed
global mutable g_fallback_slot_names: static u8&?[8192] = zeroed
global mutable g_fallback_slot_modules: static u8&?[8192] = zeroed
global mutable g_fallback_slot_symbol_indices: u32[8192] = zeroed
global mutable g_fallback_slot_rel_types: u32[8192] = zeroed
global mutable g_fallback_slot_count: u32 = 0u32

def _fallback_slot_is_empty(s: static u8&?) -> bool:
    return s == null or static_strlen(s) == 0usize

def _fallback_find_index(slot_va: u64) -> s32:
    if slot_va == 0u64:
        return -1
    i: mutable u32 = 0u32
    while i < g_fallback_slot_count and i < FALLBACK_SLOT_CAP:
        if g_fallback_slot_addrs[i.usize()] == slot_va:
            return i.s32()
        i <- i + 1u32
    return -1

def c_GuestExec_RecordFallbackSlot(slot_va: u64, name: static u8&, symbol_index: u32, rel_type: u32, module_name: static u8&) -> void:
    if slot_va == 0u64:
        return
    # De-duplicate: relocation passes can run more than once. Prefer a
    # non-empty symbol name / valid index if a later pass supplies one.
    existing: s32 = _fallback_find_index(slot_va)
    if existing >= 0:
        idx: u32 = existing.u32()
        if idx < FALLBACK_SLOT_CAP:
            if _fallback_slot_is_empty(g_fallback_slot_names[idx.usize()]) and not _fallback_slot_is_empty(name):
                g_fallback_slot_names[idx.usize()] <- name
            if g_fallback_slot_symbol_indices[idx.usize()] == 0u32 and symbol_index != 0u32:
                g_fallback_slot_symbol_indices[idx.usize()] <- symbol_index
            if g_fallback_slot_rel_types[idx.usize()] == 0u32 and rel_type != 0u32:
                g_fallback_slot_rel_types[idx.usize()] <- rel_type
            if _fallback_slot_is_empty(g_fallback_slot_modules[idx.usize()]) and not _fallback_slot_is_empty(module_name):
                g_fallback_slot_modules[idx.usize()] <- module_name
        return
    if g_fallback_slot_count >= FALLBACK_SLOT_CAP:
        return
    idx: u32 = g_fallback_slot_count
    if idx < FALLBACK_SLOT_CAP:
        g_fallback_slot_addrs[idx.usize()] <- slot_va
        g_fallback_slot_names[idx.usize()] <- name
        g_fallback_slot_modules[idx.usize()] <- module_name
        g_fallback_slot_symbol_indices[idx.usize()] <- symbol_index
        g_fallback_slot_rel_types[idx.usize()] <- rel_type
        g_fallback_slot_count <- g_fallback_slot_count + 1u32

def c_GuestExec_ResetFallbackSlots() -> void:
    g_fallback_slot_count <- 0u32

def c_GuestExec_FindFallbackSymbolBySlot(slot_va: u64) -> static u8&?:
    index: s32 = _fallback_find_index(slot_va)
    if index >= 0 and index.u32() < FALLBACK_SLOT_CAP:
        return g_fallback_slot_names[index.usize()]
    return null

def c_GuestExec_FindFallbackModuleBySlot(slot_va: u64) -> static u8&?:
    index: s32 = _fallback_find_index(slot_va)
    if index >= 0 and index.u32() < FALLBACK_SLOT_CAP:
        return g_fallback_slot_modules[index.usize()]
    return null

def c_GuestExec_FindFallbackSymbolIndexBySlot(slot_va: u64) -> u32:
    index: s32 = _fallback_find_index(slot_va)
    if index >= 0 and index.u32() < FALLBACK_SLOT_CAP:
        return g_fallback_slot_symbol_indices[index.usize()]
    return 0u32

def c_GuestExec_FindFallbackRelTypeBySlot(slot_va: u64) -> u32:
    index: s32 = _fallback_find_index(slot_va)
    if index >= 0 and index.u32() < FALLBACK_SLOT_CAP:
        return g_fallback_slot_rel_types[index.usize()]
    return 0u32

def c_GuestExec_FindFallbackSlotIndexBySlot(slot_va: u64) -> s32:
    return _fallback_find_index(slot_va)

def c_GuestExec_FallbackSlotCount() -> u32:
    return g_fallback_slot_count

def c_GuestExec_FallbackSlotVaAt(index: u32) -> u64:
    if index < g_fallback_slot_count and index < FALLBACK_SLOT_CAP:
        return g_fallback_slot_addrs[index.usize()]
    return 0u64

def c_GuestExec_FallbackSlotSymbolAt(index: u32) -> static u8&?:
    if index < g_fallback_slot_count and index < FALLBACK_SLOT_CAP:
        return g_fallback_slot_names[index.usize()]
    return null

def c_GuestExec_FallbackSlotModuleAt(index: u32) -> static u8&?:
    if index < g_fallback_slot_count and index < FALLBACK_SLOT_CAP:
        return g_fallback_slot_modules[index.usize()]
    return null

def c_GuestExec_FallbackSlotSymbolIndexAt(index: u32) -> u32:
    if index < g_fallback_slot_count and index < FALLBACK_SLOT_CAP:
        return g_fallback_slot_symbol_indices[index.usize()]
    return 0u32

def c_GuestExec_FallbackSlotRelTypeAt(index: u32) -> u32:
    if index < g_fallback_slot_count and index < FALLBACK_SLOT_CAP:
        return g_fallback_slot_rel_types[index.usize()]
    return 0u32

def Linker_RecordFallbackSlot(slot_va: u64, symbol_name: static u8&, symbol_index: u32, rel_type: u32, module_name: static u8&) -> void:
    c_GuestExec_RecordFallbackSlot(slot_va, symbol_name, symbol_index, rel_type, module_name)

def Linker_ResetFallbackSlots() -> void:
    c_GuestExec_ResetFallbackSlots()

def Linker_FindFallbackSymbolBySlot(slot_va: u64) -> static u8&:
    result: static u8&? = c_GuestExec_FindFallbackSymbolBySlot(slot_va)
    if result == null:
        return ""
    return result

def Linker_FindFallbackModuleBySlot(slot_va: u64) -> static u8&:
    result: static u8&? = c_GuestExec_FindFallbackModuleBySlot(slot_va)
    if result == null:
        return ""
    return result

def Linker_FindFallbackSymbolIndexBySlot(slot_va: u64) -> u32:
    return c_GuestExec_FindFallbackSymbolIndexBySlot(slot_va)

def Linker_FindFallbackRelTypeBySlot(slot_va: u64) -> u32:
    return c_GuestExec_FindFallbackRelTypeBySlot(slot_va)

def Linker_FindFallbackSlotIndexBySlot(slot_va: u64) -> s32:
    return c_GuestExec_FindFallbackSlotIndexBySlot(slot_va)

def Linker_FallbackSlotCount() -> u32:
    return c_GuestExec_FallbackSlotCount()

def Linker_FallbackSlotVaAt(index: u32) -> u64:
    return c_GuestExec_FallbackSlotVaAt(index)

def Linker_FallbackSlotSymbolAt(index: u32) -> static u8&:
    result: static u8&? = c_GuestExec_FallbackSlotSymbolAt(index)
    if result == null:
        return ""
    return result

def Linker_FallbackSlotModuleAt(index: u32) -> static u8&:
    result: static u8&? = c_GuestExec_FallbackSlotModuleAt(index)
    if result == null:
        return ""
    return result

def Linker_FallbackSlotSymbolIndexAt(index: u32) -> u32:
    return c_GuestExec_FallbackSlotSymbolIndexAt(index)

def Linker_FallbackSlotRelTypeAt(index: u32) -> u32:
    return c_GuestExec_FallbackSlotRelTypeAt(index)

# Diagnostic: order-dependent fingerprint of every symbol relocation's
# resolution outcome (symbol index + relocation type + whether it fell to the
# fallback stub), accumulated during relocation. Two runs with identical inputs
# must produce identical fingerprints; a difference localises nondeterminism to
# the resolution path.
global mutable linker_resolution_fp: u64 = 0
global mutable linker_resolution_relocs: u64 = 0
global mutable linker_seq_fp: u64 = 0
global mutable linker_name_fp: u64 = 0
global mutable linker_dbg_first_name: static u8&? = null
global mutable linker_dbg_first_index: u32 = 0
global mutable linker_name_setfp: u64 = 0
global mutable linker_name_count: u64 = 0

def Linker_DbgFirstName() -> static u8&:
    if linker_dbg_first_name == null:
        return ""
    return linker_dbg_first_name
def Linker_DbgFirstIndex() -> u32:
    return linker_dbg_first_index
def Linker_NameSetFingerprint() -> u64:
    return linker_name_setfp
def Linker_NameCount() -> u64:
    return linker_name_count

def Linker_ResetResolutionFingerprint() -> void:
    linker_resolution_fp <- 0xcbf29ce484222325u64
    linker_seq_fp <- 0xcbf29ce484222325u64
    linker_name_fp <- 0xcbf29ce484222325u64
    linker_resolution_relocs <- 0
    linker_dbg_first_name <- null
    linker_dbg_first_index <- 0
    linker_name_setfp <- 0
    linker_name_count <- 0

def Linker_ResolutionFingerprintValue() -> u64:
    return linker_resolution_fp

def Linker_SeqFingerprintValue() -> u64:
    return linker_seq_fp

def Linker_NameFingerprintValue() -> u64:
    return linker_name_fp

def Linker_ResolutionRelocCount() -> u64:
    return linker_resolution_relocs

def Linker_MixResolution(symbol_index: u32, is_stub: bool, rel_type: u32, name: static u8&) -> void:
    stub_bit: u64 = 1u64 if is_stub else 0u64
    # Sequence fingerprint: relocation identity only (must be stable).
    seq: u64 = symbol_index.u64() ^ (rel_type.u64() << 24u64)
    linker_seq_fp <- (linker_seq_fp ^ seq) * 0x100000001b3u64
    # Name fingerprint: the resolved symbol name bytes (must be stable if the
    # symbol/string tables are read deterministically).
    n: mutable usize = 0
    nl: usize = static_strlen(name)
    per_name: mutable u64 = 0xcbf29ce484222325u64
    while n < nl:
        linker_name_fp <- (linker_name_fp ^ name[n].u64()) * 0x100000001b3u64
        per_name <- (per_name ^ name[n].u64()) * 0x100000001b3u64
        n <- n + 1
    linker_name_fp <- linker_name_fp ^ 0xffu64
    if nl > 0:
        # Order-independent: combine (symbol_index, content-hash) so a stable set
        # of (index -> name) yields a stable value regardless of visit order.
        linker_name_setfp <- linker_name_setfp + (per_name ^ (symbol_index.u64() * 0x9e3779b97f4a7c15u64))
        linker_name_count <- linker_name_count + 1
    if nl > 0 and linker_dbg_first_name == null:
        linker_dbg_first_name <- name
        linker_dbg_first_index <- symbol_index
    # Resolution fingerprint: includes the stub/resolved outcome.
    linker_resolution_fp <- (linker_resolution_fp ^ (seq ^ (stub_bit << 40u64))) * 0x100000001b3u64
    linker_resolution_relocs <- linker_resolution_relocs + 1

# Count of registered HLE symbols whose callable_address is zero. A nonzero,
# run-to-run-varying count would reveal an uninitialized-scalar (address) read.
def Linker_HleZeroAddrCount(self: Linker&) -> u64:
    count: mutable u64 = 0
    i: mutable usize = 0
    while i < self.hle_symbols.symbols.count:
        if self.hle_symbols.symbols[i].callable_address == 0:
            count <- count + 1
        i <- i + 1
    return count

def Linker_FallbackTableFingerprint() -> u64:
    # Order-independent fingerprint of the fallback slot table: sum of a per-slot
    # FNV-style mix of (slot_va, symbol_index). Used to compare the unresolved
    # set across relocation passes / process runs.
    acc: mutable u64 = 0
    count: u32 = Linker_FallbackSlotCount()
    i: mutable u32 = 0
    while i < count:
        mix: u64 = (Linker_FallbackSlotVaAt(i) ^ (Linker_FallbackSlotSymbolIndexAt(i).u64() * 0x9e3779b97f4a7c15u64)) * 0x100000001b3u64
        acc <- acc + mix
        i <- i + 1
    return acc

def Linker_RuntimeLifecycleNoop() -> int:
    return 0

def Linker_AeroLibFallbackStub() -> u64:
    GuestExec_RecordFirstBoundary(GUEST_EXEC_BOUNDARY_REASON_AEROLIB_FALLBACK)
    return 0

def Linker_FileExists(path: static u8&) -> bool:
    file: mutable IOFile = IOFile_new()
    opened: bool = IOFile_Open(file.ref[mutable IOFile&], path, FileAccessMode.Read) == 0
    IOFile_Close(file.ref[mutable IOFile&])
    return opened

def Linker_ResolveGuestModulePath(self: Linker&, guest_path: static u8&) -> static u8&:
    len: usize = static_strlen(guest_path)
    if len == 0:
        return ""
    root: mutable static u8& = ""
    if self.app0_host_root != null:
        root <- self.app0_host_root
    if len >= 5 and guest_path[0] == '/'.u8() and guest_path[1] == 'a'.u8() and guest_path[2] == 'p'.u8() and guest_path[3] == 'p'.u8() and guest_path[4] == '0'.u8():
        if len == 5:
            return root
        if guest_path[5] == '/'.u8():
            suffix: static u8& = Linker_Substr(guest_path, 6, len - 6)
            return Linker_PathJoin(root, suffix)
    if guest_path[0] != '/'.u8() and not Linker_StringContainsSlash(guest_path):
        return Linker_PathJoin(root, guest_path)
    return guest_path

def Linker_StaticTlsSize(self: Linker&) -> usize:
    return self.static_tls_size

def Linker_DependencyGuestPath(name: static u8&) -> static u8&:
    if static_strlen(name) == 0:
        return ""
    if Linker_StringContainsSlash(name):
        return name
    if Linker_StringHasSuffix(name, ".prx") or Linker_StringHasSuffix(name, ".sprx"):
        return Linker_PathJoin("/app0/sce_module", name)
    return Linker_PathJoin("/app0/sce_module", Linker_Concat2(name, ".prx"))

def Linker_LoadGuestDependency(self: mutable Linker&, dependency_name: static u8&) -> s32 can[Unsafe.SegmentMutation, Unsafe.GuestSegmentInstall, Segment.Guest, Segment.Host]:
    guest_path: static u8& = Linker_DependencyGuestPath(dependency_name)
    if static_strlen(guest_path) == 0:
        return -1
    host_path: static u8& = Linker_ResolveGuestModulePath(self.ref[Linker&], guest_path)
    if static_strlen(host_path) == 0:
        return -1
    existing: mutable u32 = Linker_FindByFileOrHost(self.ref[Linker&], guest_path)
    if existing != 0xFFFFFFFF.u32():
        return existing.s32()
    existing <- Linker_FindByFileOrHost(self.ref[Linker&], host_path)
    if existing != 0xFFFFFFFF.u32():
        return existing.s32()
    if not Linker_FileExists(host_path):
        return -1
    idx: s32 = Linker_LoadModuleFromHost(self.ref[mutable Linker&], guest_path, host_path, true)
    if idx < 0:
        return idx
    mod_ref: mutable Module&? = Linker_GetModule(self.ref[mutable Linker&], idx)
    if mod_ref == null:
        return -1
    Linker_RelocateAnyImports(self.ref[mutable Linker&], mod_ref)
    if mod_ref.tls.image_size != 0:
        Linker_AdvanceGenerationCounter(self.ref[mutable Linker&])
    can Unsafe.SegmentMutation, Unsafe.GuestSegmentInstall, Segment.Guest, Segment.Host:
        _ = Module_Start(mod_ref, 0, null, null)
    return idx

def Linker_PreloadLibkernelGameModules(self: mutable Linker&) -> void can[Unsafe.SegmentMutation, Unsafe.GuestSegmentInstall, Segment.Guest, Segment.Host]:
    # shadPS4's sceSysmodulePreloadModuleForLibkernel loads these app-local
    # modules before the guest entry runs. Do this before the eager dependency
    # closure so the module table order matches the executable oracle.
    can Unsafe.SegmentMutation, Unsafe.GuestSegmentInstall, Segment.Guest, Segment.Host:
        _ = Linker_LoadGuestDependency(self.ref[mutable Linker&], "libSceFios2")
        _ = Linker_LoadGuestDependency(self.ref[mutable Linker&], "libc")

def Linker_LoadDependencyClosure(self: mutable Linker&) -> void can[Unsafe.SegmentMutation, Unsafe.GuestSegmentInstall, Segment.Guest, Segment.Host]:
    initial_count: usize = self.modules.count
    ge_emergency_mark(GE_EV_DEP_CLOSURE_BEGIN, initial_count.uintptr(), self.modules.count.uintptr(), 0.uintptr(), 0.uintptr())
    index: mutable usize = 0
    while index < self.modules.count:
        dep_count: usize = self.modules[index].dynamic_info.import_modules.count
        ge_emergency_mark(GE_EV_DEP_CLOSURE_MODULE_BEGIN, index.uintptr(), dep_count.uintptr(), self.modules.count.uintptr(), self.modules[index].base_virtual_addr)
        dep_index: mutable usize = 0
        while dep_index < dep_count:
            dep_name: static u8& = self.modules[index].dynamic_info.import_modules[dep_index].name
            ge_emergency_mark(GE_EV_DEP_CLOSURE_DEP_BEGIN, index.uintptr(), dep_index.uintptr(), dep_count.uintptr(), self.modules.count.uintptr())
            dep_result: mutable s32 = 0
            can Unsafe.SegmentMutation, Unsafe.GuestSegmentInstall, Segment.Guest, Segment.Host:
                dep_result <- Linker_LoadGuestDependency(self.ref[mutable Linker&], dep_name)
            ge_emergency_mark(GE_EV_DEP_CLOSURE_DEP_END, index.uintptr(), dep_index.uintptr(), dep_result.u64().uintptr(), self.modules.count.uintptr())
            dep_index <- dep_index + 1
        ge_emergency_mark(GE_EV_DEP_CLOSURE_MODULE_END, index.uintptr(), dep_count.uintptr(), self.modules.count.uintptr(), self.modules[index].base_virtual_addr)
        index <- index + 1
    if self.modules.count != initial_count:
        self.relocated_all_imports <- false
    ge_emergency_mark(GE_EV_DEP_CLOSURE_END, initial_count.uintptr(), self.modules.count.uintptr(), 0.uintptr(), 0.uintptr())

def Linker_WriteU16LE(out: mutable u8&, offset: usize, value: u16) -> void:
    out[offset] <- (value & 0xffu16).u8()
    out[offset + 1usize] <- ((value >> 8u16) & 0xffu16).u8()

def Linker_WriteU64LE(out: mutable u8&, offset: usize, value: u64) -> void:
    i: mutable usize = 0
    while i < 8usize:
        shift: u64 = (i.u64() * 8u64)
        out[offset + i] <- ((value >> shift) & 0xffu64).u8()
        i <- i + 1usize

def Linker_UseNativeHleBoundaryThunk() -> bool:
    static if PLATFORM_APPLE and ARCH_X86_64:
        if getenv("ELISA_GUEST_EXEC_NO_HLE_BOUNDARY_THUNK".cast[u8&]) != null:
            return false
        return getenv("ELISA_GUEST_EXEC_NO_FORK".cast[u8&]) != null or getenv("ELISA_GUEST_EXEC_BOUNDARY_THUNK".cast[u8&]) != null
    static else:
        return false

def Linker_NativeHleBoundaryThunkCount() -> u64:
    return linker_native_hle_thunk_count.u64()

def Linker_NativeHleBoundaryThunkEnabled() -> bool:
    return Linker_UseNativeHleBoundaryThunk()

def Linker_FindNativeHleBoundaryThunkBase(address: u64) -> u64:
    i: mutable usize = 0usize
    while i < linker_native_hle_thunk_count and i < LINKER_NATIVE_HLE_THUNK_CAP:
        base: u64 = linker_native_hle_thunk_addrs[i]
        if address >= base and address < base + 4096u64:
            return base
        i <- i + 1usize
    return 0u64

def Linker_FindNativeHleBoundaryThunkTarget(address: u64) -> u64:
    i: mutable usize = 0usize
    while i < linker_native_hle_thunk_count and i < LINKER_NATIVE_HLE_THUNK_CAP:
        base: u64 = linker_native_hle_thunk_addrs[i]
        if address >= base and address < base + 4096u64:
            return linker_native_hle_thunk_targets[i]
        i <- i + 1usize
    return 0u64

def Linker_NativeHleFunctionRelocationCount() -> u64:
    return linker_native_hle_function_relocation_count

def Linker_NativeHleDataRelocationCount() -> u64:
    return linker_native_hle_data_relocation_count

def Linker_NativeHleUnthunkedFunctionCount() -> u64:
    return linker_native_hle_unthunked_function_count

def Linker_NativeHleUnthunkedFunctionFirstTarget() -> u64:
    return linker_native_hle_unthunked_function_first_target

def Linker_NativeHleFunctionAddendCount() -> u64:
    return linker_native_hle_function_addend_count

def Linker_NativeHleFunctionMaxAddend() -> u64:
    return linker_native_hle_function_max_addend

def Linker_NativeHleDataThunkPointerCount() -> u64:
    return linker_native_hle_data_thunk_pointer_count

def Linker_NativeHleDataThunkPointerFirstValue() -> u64:
    return linker_native_hle_data_thunk_pointer_first_value

def Linker_NativeHleDataThunkPointerFirstName() -> static u8&?:
    return linker_native_hle_data_thunk_pointer_first_name

def Linker_NoteNativeHleDataRelocationValue(value: u64, symbol_name: static u8&?) -> void:
    if value == 0u64:
        return
    if Linker_FindNativeHleBoundaryThunkBase(value) == 0u64:
        return
    if linker_native_hle_data_thunk_pointer_count == 0u64:
        linker_native_hle_data_thunk_pointer_first_value <- value
        linker_native_hle_data_thunk_pointer_first_name <- symbol_name
    linker_native_hle_data_thunk_pointer_count <- linker_native_hle_data_thunk_pointer_count + 1u64

# Record a pointer-bearing relocation whose final written value is a near-NULL
# bogus pointer. Call AFTER computing the value, only for pointer relocations
# (RELATIVE / 64 / GLOB_DAT / JUMP_SLOT) -- never for DTPMOD64.
def Linker_NoteRelocatedPointerValue(value: u64, rel_virtual_addr: u64, rel_type: u32, symbol_name: static u8&?, module_name: static u8&?) -> void:
    if value == 0u64 or value >= LINKER_TINY_POINTER_THRESHOLD:
        return
    if linker_tiny_pointer_slot_count == 0u64:
        linker_tiny_pointer_first_value <- value
        linker_tiny_pointer_first_offset <- rel_virtual_addr
        linker_tiny_pointer_first_type <- rel_type
        linker_tiny_pointer_first_name <- symbol_name
        linker_tiny_pointer_first_module <- module_name
    linker_tiny_pointer_slot_count <- linker_tiny_pointer_slot_count + 1u64

def Linker_TinyPointerSlotCount() -> u64:
    return linker_tiny_pointer_slot_count

def Linker_TinyPointerFirstValue() -> u64:
    return linker_tiny_pointer_first_value

def Linker_TinyPointerFirstOffset() -> u64:
    return linker_tiny_pointer_first_offset

def Linker_TinyPointerFirstType() -> u32:
    return linker_tiny_pointer_first_type

def Linker_TinyPointerFirstName() -> static u8&?:
    return linker_tiny_pointer_first_name

def Linker_TinyPointerFirstModule() -> static u8&?:
    return linker_tiny_pointer_first_module

def Linker_TlsGetAddrCalls() -> u64:
    return linker_tls_get_addr_calls

def Linker_TlsLastModuleIndex() -> u64:
    return linker_tls_last_module_index

def Linker_TlsLastOffset() -> u64:
    return linker_tls_last_offset

def Linker_TlsLastDtvBase() -> u64:
    return linker_tls_last_dtv_base.u64()

def Linker_TlsLastBlockPointer() -> u64:
    return linker_tls_last_block_pointer.u64()

def Linker_TlsLastResult() -> u64:
    return linker_tls_last_result.u64()

def Linker_TlsModule0Calls() -> u64:
    return linker_tls_module0_calls

def Linker_TlsNullDtvCalls() -> u64:
    return linker_tls_null_dtv_calls

def Linker_TlsPrimaryBase() -> u64:
    return linker_tls_primary_base.u64()

def Linker_TlsPrimarySize() -> u64:
    return linker_tls_primary_size

def Linker_TlsPrimaryTcb() -> u64:
    return linker_tls_primary_tcb.u64()

def Linker_TlsPrimaryDtvBase() -> u64:
    return linker_tls_primary_dtv_base.u64()

def Linker_TlsPrimaryDtvSize() -> u64:
    return linker_tls_primary_dtv_size

def Linker_IsQualifiedImportSymbol(raw_symbol: static u8&) -> bool:
    parsed_nid: mutable static u8& = ""
    parsed_library: mutable static u8& = ""
    parsed_module: mutable static u8& = ""
    if not Module_ParseImportSymbol(raw_symbol, parsed_nid.ref[mutable static u8&], parsed_library.ref[mutable static u8&], parsed_module.ref[mutable static u8&]):
        return false
    return static_strlen(parsed_library) > 0 and static_strlen(parsed_module) > 0

def Linker_WriteRelocationU64(module: mutable Module&, memory: mutable MemoryManager&, addr: u64, value: u64) -> bool:
    image_ok: bool = Module_WriteImageU64(module.ref[mutable Module&], addr, value)
    memory_ok: mutable bool = false
    if linker_defer_native_relocation_writes and GuestExec_IsEnabled() and GuestExec_IsSupported():
        memory_ok <- MemoryManager_WriteU64BackingOnly(memory, addr.uintptr(), value)
    else:
        memory_ok <- MemoryManager_WriteU64(memory, addr.uintptr(), value)
    return image_ok or memory_ok

def Linker_WriteRelativeRelocationFast(module: mutable Module&, memory: mutable MemoryManager&, addr: u64, value: u64, cached_backing_index: mutable s32&) -> bool:
    image_ok: mutable bool = false
    image_offset: mutable usize = 0usize
    if Module_ImageOffsetForVirtualAddress(module, addr, image_offset.ref[mutable usize&]):
        for i in 0..<8:
            module.image[image_offset + i] <- ((value >> (i.u64() * 8)) & 0xff).u8()
        image_ok <- true

    backing_index: mutable s32 = cached_backing_index
    backing_ok: mutable bool = false
    if backing_index >= 0 and backing_index.usize() < memory.mapped_bytes.count:
        cached: MappedMemoryBytes = memory.mapped_bytes[backing_index.usize()]
        if addr.uintptr() >= cached.base:
            cached_offset: u64 = (addr.uintptr() - cached.base).u64()
            if cached_offset <= cached.size and 8u64 <= (cached.size - cached_offset):
                backing_ok <- true
    if not backing_ok:
        backing_index <- MemoryManager_FindBackingIndex(memory, addr.uintptr(), 8u64)
        if backing_index >= 0:
            cached_backing_index <- backing_index
            backing_ok <- true
    if backing_ok:
        base_offset: usize = (addr.uintptr() - memory.mapped_bytes[backing_index.usize()].base).usize()
        for i in 0..<8:
            memory.mapped_bytes[backing_index.usize()].bytes[base_offset + i] <- ((value >> (i.u64() * 8)) & 0xff).u8()
    return image_ok or backing_ok

def Linker_ModuleRelocationBit(module: Module&, bit_index: usize) -> bool:
    byte_index: usize = bit_index / 8usize
    if byte_index >= module.applied_relocation_bits.count:
        return false
    mask: u8 = (1u8 << (bit_index % 8usize).u8())
    return (module.applied_relocation_bits[byte_index] & mask) != 0u8

def Linker_EnsureModuleRelocationBit(module: mutable Module&, bit_index: usize) -> void:
    byte_index: usize = bit_index / 8usize
    can Memory.Allocate:
        trusted Unsafe.MutableGlobal:
            owner: mutable Arena& = module_metadata_arena.ref[mutable Arena&]
            in owner:
                while module.applied_relocation_bits.count <= byte_index:
                    module.applied_relocation_bits.push(0u8)

def Linker_SetModuleRelocationBit(module: mutable Module&, bit_index: usize) -> void:
    Linker_EnsureModuleRelocationBit(module.ref[mutable Module&], bit_index)
    byte_index: usize = bit_index / 8usize
    mask: u8 = (1u8 << (bit_index % 8usize).u8())
    module.applied_relocation_bits[byte_index] <- module.applied_relocation_bits[byte_index] | mask

def Linker_RecordFailedRelocationType(self: mutable Linker&, rel_type: u32) -> void:
    if rel_type == R_X86_64_64:
        self.failed_relocation_type1_count <- self.failed_relocation_type1_count + 1
    elif rel_type == R_X86_64_GLOB_DAT:
        self.failed_relocation_glob_dat_count <- self.failed_relocation_glob_dat_count + 1
    elif rel_type == R_X86_64_JUMP_SLOT:
        self.failed_relocation_jump_slot_count <- self.failed_relocation_jump_slot_count + 1
    elif rel_type == R_X86_64_RELATIVE:
        self.failed_relocation_relative_count <- self.failed_relocation_relative_count + 1
    elif rel_type == R_X86_64_DTPMOD64:
        self.failed_relocation_dtpmod64_count <- self.failed_relocation_dtpmod64_count + 1
    else:
        self.failed_relocation_other_count <- self.failed_relocation_other_count + 1

def Linker_RecordFailedRelocationDetail(self: mutable Linker&, stage: u32, kind: u8, value: u64) -> void:
    self.last_failed_relocation_stage <- stage
    self.last_failed_relocation_kind <- kind
    self.last_failed_relocation_value <- value

def Linker_ShouldThunkNativeHleRelocation(rel_type: u32, symbol_found: bool, symbol: elf_symbol) -> bool:
    if not symbol_found:
        return rel_type == R_X86_64_JUMP_SLOT
    typ: u8 = ElfSymbol_GetType(symbol)
    return typ == STT_FUN or (typ == STT_NOTYPE and rel_type == R_X86_64_JUMP_SLOT)

def Linker_CreateNativeHleBoundaryThunk(target: u64, symbol_name: static u8&?) -> u64:
    if target == 0u64:
        return 0u64
    if not Linker_UseNativeHleBoundaryThunk():
        return target
    sym_ptr: u64 = Linker_SymbolNamePtr(symbol_name)
    cache_index: mutable usize = 0usize
    while cache_index < linker_native_hle_thunk_count and cache_index < LINKER_NATIVE_HLE_THUNK_CAP:
        if linker_native_hle_thunk_targets[cache_index] == target and linker_native_hle_thunk_symbol_ptrs[cache_index] == sym_ptr:
            return linker_native_hle_thunk_addrs[cache_index]
        cache_index <- cache_index + 1usize
    static if PLATFORM_APPLE and ARCH_X86_64:
        host_selector: HostFsSelector = TLS_CaptureHostFsSelector()
        full: mutable u8[174] = zeroed
        # Capture the guest return address before touching the thunk stack.
        # At thunk entry, (%rsp) is the return PC pushed by the guest call.
        # movq (%rsp), %r11
        full[0] <- 0x4Cu8
        full[1] <- 0x8Bu8
        full[2] <- 0x1Cu8
        full[3] <- 0x24u8
        # movabs $ge_runtime_hle_guest_return_addr, %r10; movq %r11, (%r10)
        full[4] <- 0x49u8
        full[5] <- 0xBAu8
        Linker_WriteU64LE(full[0].ref[mutable u8&], 6usize, ge_runtime_hle_guest_return_addr.ref[void&].uintptr().u64())
        full[14] <- 0x4Du8
        full[15] <- 0x89u8
        full[16] <- 0x1Au8
        # movabs $ge_runtime_hle_guest_rsp, %r10; movq %rsp, (%r10)
        full[17] <- 0x49u8
        full[18] <- 0xBAu8
        Linker_WriteU64LE(full[0].ref[mutable u8&], 19usize, ge_runtime_hle_guest_rsp.ref[void&].uintptr().u64())
        full[27] <- 0x49u8
        full[28] <- 0x89u8
        full[29] <- 0x22u8
        # movabs $ge_runtime_hle_guest_rbp, %r10; movq %rbp, (%r10)
        full[30] <- 0x49u8
        full[31] <- 0xBAu8
        Linker_WriteU64LE(full[0].ref[mutable u8&], 32usize, ge_runtime_hle_guest_rbp.ref[void&].uintptr().u64())
        full[40] <- 0x49u8
        full[41] <- 0x89u8
        full[42] <- 0x2Au8
        # movabs $ge_runtime_hle_guest_rdi, %r10; movq %rdi, (%r10)
        full[43] <- 0x49u8
        full[44] <- 0xBAu8
        Linker_WriteU64LE(full[0].ref[mutable u8&], 45usize, ge_runtime_hle_guest_rdi.ref[void&].uintptr().u64())
        full[53] <- 0x49u8
        full[54] <- 0x89u8
        full[55] <- 0x3Au8
        # Capture the rest of the SysV argument register set. This lets the
        # artifact distinguish "real mutex call with a bad pointer" from
        # "wrong callee / corrupted call frame" without a debugger.
        full[56] <- 0x49u8
        full[57] <- 0xBAu8
        Linker_WriteU64LE(full[0].ref[mutable u8&], 58usize, ge_runtime_hle_guest_rsi.ref[void&].uintptr().u64())
        full[66] <- 0x49u8
        full[67] <- 0x89u8
        full[68] <- 0x32u8
        full[69] <- 0x49u8
        full[70] <- 0xBAu8
        Linker_WriteU64LE(full[0].ref[mutable u8&], 71usize, ge_runtime_hle_guest_rdx.ref[void&].uintptr().u64())
        full[79] <- 0x49u8
        full[80] <- 0x89u8
        full[81] <- 0x12u8
        full[82] <- 0x49u8
        full[83] <- 0xBAu8
        Linker_WriteU64LE(full[0].ref[mutable u8&], 84usize, ge_runtime_hle_guest_rcx.ref[void&].uintptr().u64())
        full[92] <- 0x49u8
        full[93] <- 0x89u8
        full[94] <- 0x0Au8
        full[95] <- 0x49u8
        full[96] <- 0xBAu8
        Linker_WriteU64LE(full[0].ref[mutable u8&], 97usize, ge_runtime_hle_guest_r8.ref[void&].uintptr().u64())
        full[105] <- 0x4Du8
        full[106] <- 0x89u8
        full[107] <- 0x02u8
        full[108] <- 0x49u8
        full[109] <- 0xBAu8
        Linker_WriteU64LE(full[0].ref[mutable u8&], 110usize, ge_runtime_hle_guest_r9.ref[void&].uintptr().u64())
        full[118] <- 0x4Du8
        full[119] <- 0x89u8
        full[120] <- 0x0Au8
        # Save the live guest selector. Every guest thread has its own %fs, so
        # restoring a baked main-thread selector corrupts worker-thread TLS.
        # push %r10 also fixes the nested SysV call alignment.
        full[121] <- 0x66u8
        full[122] <- 0x41u8
        full[123] <- 0x8Cu8
        full[124] <- 0xE2u8
        full[125] <- 0x41u8
        full[126] <- 0x52u8
        # movw $host_selector, %r10w; movw %r10w, %fs
        full[127] <- 0x66u8
        full[128] <- 0x41u8
        full[129] <- 0xBAu8
        Linker_WriteU16LE(full[0].ref[mutable u8&], 130usize, (!host_selector).u16())
        full[132] <- 0x66u8
        full[133] <- 0x41u8
        full[134] <- 0x8Eu8
        full[135] <- 0xE2u8
        # movabs $target, %r11; call *%r11
        full[136] <- 0x49u8
        full[137] <- 0xBBu8
        Linker_WriteU64LE(full[0].ref[mutable u8&], 138usize, target)
        full[146] <- 0x41u8
        full[147] <- 0xFFu8
        full[148] <- 0xD3u8
        # Restore the original guest return slot before returning. Host HLE
        # bodies run on the guest stack; preserving the call continuation here
        # prevents host prologues/epilogues from accidentally skipping guest code.
        full[149] <- 0x49u8
        full[150] <- 0xBBu8
        Linker_WriteU64LE(full[0].ref[mutable u8&], 151usize, ge_runtime_hle_guest_return_addr.ref[void&].uintptr().u64())
        full[159] <- 0x4Du8
        full[160] <- 0x8Bu8
        full[161] <- 0x1Bu8
        full[162] <- 0x4Cu8
        full[163] <- 0x89u8
        full[164] <- 0x5Cu8
        full[165] <- 0x24u8
        full[166] <- 0x08u8
        # pop saved selector into %r10; movw %r10w, %fs; ret
        full[167] <- 0x41u8
        full[168] <- 0x5Au8
        full[169] <- 0x66u8
        full[170] <- 0x41u8
        full[171] <- 0x8Eu8
        full[172] <- 0xE2u8
        full[173] <- 0xC3u8
        thunk: VAddr = GuestExec_AllocateRegion(4096u64, 5u32)
        if thunk == 0.uintptr():
            return target
        trusted Unsafe.MachineCodeBuilder:
            if not GuestExec_WriteBytes(thunk, full[0].ref[void&], 174u64):
                return target
        trusted Unsafe.ExecutableCodePublish:
            if not GuestExec_PublishExecutableCode(thunk, 174u64):
                return target
        GuestExec_RecordHleBoundaryThunkContract(thunk, target.uintptr(), 174u64, host_selector)
        # Wrap the real thunk in a recorder prefix that logs the symbol-name pointer
        # of this call into linker_hle_call_ring, then jmps through. The GOT ends up
        # pointing at the prefix; the prefix preserves %rsp and all SysV arg regs
        # (it only clobbers %r10/%r11, which the real thunk reloads immediately) so
        # the boundary contract is unaffected.
        entry_addr: u64 = Linker_CreateHleRecorderPrefix(thunk.u64(), sym_ptr, target)
        final_addr: u64 = entry_addr if entry_addr != 0u64 else thunk.u64()
        if linker_native_hle_thunk_count < LINKER_NATIVE_HLE_THUNK_CAP:
            linker_native_hle_thunk_targets[linker_native_hle_thunk_count] <- target
            linker_native_hle_thunk_addrs[linker_native_hle_thunk_count] <- final_addr
            linker_native_hle_thunk_symbol_ptrs[linker_native_hle_thunk_count] <- sym_ptr
            linker_native_hle_thunk_count <- linker_native_hle_thunk_count + 1usize
        return final_addr
    static else:
        return target

def Linker_SymbolNamePtr(symbol_name: static u8&?) -> u64:
    if symbol_name == null:
        return 0u64
    name: static u8& = symbol_name
    return name.ref[void&].uintptr().u64()

# Build a small recorder prefix stub that logs `sym_ptr` into linker_hle_call_ring
# (masked by 1023) and then jmps to `real_thunk`. It preserves %rsp (push/pop %rax
# is balanced) and every SysV argument register, clobbering only %r10/%r11 which the
# real boundary thunk reloads on entry. Returns the stub address, or 0 on failure.
def Linker_CreateHleRecorderPrefix(real_thunk: u64, sym_ptr: u64, target: u64) -> u64:
    static if PLATFORM_APPLE and ARCH_X86_64:
        stub: mutable u8[159] = zeroed
        idx_addr: u64 = linker_hle_call_ring_index.ref[void&].uintptr().u64()
        ring_addr: u64 = linker_hle_call_ring[0].ref[void&].uintptr().u64()
        target_ring_addr: u64 = linker_hle_call_target_ring[0].ref[void&].uintptr().u64()
        return_ring_addr: u64 = linker_hle_call_return_ring[0].ref[void&].uintptr().u64()
        rdi_ring_addr: u64 = linker_hle_call_rdi_ring[0].ref[void&].uintptr().u64()
        rsi_ring_addr: u64 = linker_hle_call_rsi_ring[0].ref[void&].uintptr().u64()
        rdx_ring_addr: u64 = linker_hle_call_rdx_ring[0].ref[void&].uintptr().u64()
        # push %rax
        stub[0] <- 0x50u8
        # movabs $&index, %r10 ; mov (%r10), %rax
        stub[1] <- 0x49u8
        stub[2] <- 0xBAu8
        Linker_WriteU64LE(stub[0].ref[mutable u8&], 3usize, idx_addr)
        stub[11] <- 0x49u8
        stub[12] <- 0x8Bu8
        stub[13] <- 0x02u8
        # and $0x3ff, %rax
        stub[14] <- 0x48u8
        stub[15] <- 0x25u8
        stub[16] <- 0xFFu8
        stub[17] <- 0x03u8
        stub[18] <- 0x00u8
        stub[19] <- 0x00u8
        # movabs $&ring, %r11
        stub[20] <- 0x49u8
        stub[21] <- 0xBBu8
        Linker_WriteU64LE(stub[0].ref[mutable u8&], 22usize, ring_addr)
        # movabs $sym_ptr, %r10
        stub[30] <- 0x49u8
        stub[31] <- 0xBAu8
        Linker_WriteU64LE(stub[0].ref[mutable u8&], 32usize, sym_ptr)
        # mov %r10, (%r11,%rax,8)
        stub[40] <- 0x4Du8
        stub[41] <- 0x89u8
        stub[42] <- 0x14u8
        stub[43] <- 0xC3u8
        # movabs $&target_ring, %r11
        stub[44] <- 0x49u8
        stub[45] <- 0xBBu8
        Linker_WriteU64LE(stub[0].ref[mutable u8&], 46usize, target_ring_addr)
        # movabs $target, %r10
        stub[54] <- 0x49u8
        stub[55] <- 0xBAu8
        Linker_WriteU64LE(stub[0].ref[mutable u8&], 56usize, target)
        # mov %r10, (%r11,%rax,8)
        stub[64] <- 0x4Du8
        stub[65] <- 0x89u8
        stub[66] <- 0x14u8
        stub[67] <- 0xC3u8
        # movabs $&return_ring, %r11
        stub[68] <- 0x49u8
        stub[69] <- 0xBBu8
        Linker_WriteU64LE(stub[0].ref[mutable u8&], 70usize, return_ring_addr)
        # mov 8(%rsp), %r10 -- return PC below the saved %rax
        stub[78] <- 0x4Cu8
        stub[79] <- 0x8Bu8
        stub[80] <- 0x54u8
        stub[81] <- 0x24u8
        stub[82] <- 0x08u8
        # mov %r10, (%r11,%rax,8)
        stub[83] <- 0x4Du8
        stub[84] <- 0x89u8
        stub[85] <- 0x14u8
        stub[86] <- 0xC3u8
        # Store the first three SysV argument registers alongside the generic
        # call record. These are the fields the shadPS4 boot oracle compares at
        # each HLE boundary, and recording them in the prefix avoids patching
        # every individual HLE.
        # movabs $&rdi_ring, %r11 ; mov %rdi, (%r11,%rax,8)
        stub[87] <- 0x49u8
        stub[88] <- 0xBBu8
        Linker_WriteU64LE(stub[0].ref[mutable u8&], 89usize, rdi_ring_addr)
        stub[97] <- 0x49u8
        stub[98] <- 0x89u8
        stub[99] <- 0x3Cu8
        stub[100] <- 0xC3u8
        # movabs $&rsi_ring, %r11 ; mov %rsi, (%r11,%rax,8)
        stub[101] <- 0x49u8
        stub[102] <- 0xBBu8
        Linker_WriteU64LE(stub[0].ref[mutable u8&], 103usize, rsi_ring_addr)
        stub[111] <- 0x49u8
        stub[112] <- 0x89u8
        stub[113] <- 0x34u8
        stub[114] <- 0xC3u8
        # movabs $&rdx_ring, %r11 ; mov %rdx, (%r11,%rax,8)
        stub[115] <- 0x49u8
        stub[116] <- 0xBBu8
        Linker_WriteU64LE(stub[0].ref[mutable u8&], 117usize, rdx_ring_addr)
        stub[125] <- 0x49u8
        stub[126] <- 0x89u8
        stub[127] <- 0x14u8
        stub[128] <- 0xC3u8
        # inc %rax
        stub[129] <- 0x48u8
        stub[130] <- 0xFFu8
        stub[131] <- 0xC0u8
        # movabs $&index, %r11 ; mov %rax, (%r11)
        stub[132] <- 0x49u8
        stub[133] <- 0xBBu8
        Linker_WriteU64LE(stub[0].ref[mutable u8&], 134usize, idx_addr)
        stub[142] <- 0x49u8
        stub[143] <- 0x89u8
        stub[144] <- 0x03u8
        # pop %rax
        stub[145] <- 0x58u8
        # movabs $real_thunk, %r11 ; jmp *%r11
        stub[146] <- 0x49u8
        stub[147] <- 0xBBu8
        Linker_WriteU64LE(stub[0].ref[mutable u8&], 148usize, real_thunk)
        stub[156] <- 0x41u8
        stub[157] <- 0xFFu8
        stub[158] <- 0xE3u8
        prefix: VAddr = GuestExec_AllocateRegion(4096u64, 5u32)
        if prefix == 0.uintptr():
            return 0u64
        trusted Unsafe.MachineCodeBuilder:
            if not GuestExec_WriteBytes(prefix, stub[0].ref[void&], 159u64):
                return 0u64
        trusted Unsafe.ExecutableCodePublish:
            if not GuestExec_PublishExecutableCode(prefix, 159u64):
                return 0u64
        return prefix.u64()
    static else:
        return 0u64

# Accessors over the HLE call ring (oldest retained call .. newest). The dump
# helper lives in guest_exec.elisa where the text/output primitives are declared.
def Linker_HleCallRingTotal() -> u64:
    return linker_hle_call_ring_index

def Linker_HleCallRingCount() -> u64:
    total: u64 = linker_hle_call_ring_index
    return total if total < LINKER_HLE_CALL_RING_CAP.u64() else LINKER_HLE_CALL_RING_CAP.u64()

def Linker_HleCallRingSymbolAt(seq: u64) -> static u8&?:
    slot: usize = (seq & (LINKER_HLE_CALL_RING_CAP.u64() - 1u64)).usize()
    ptr: u64 = linker_hle_call_ring[slot]
    if ptr == 0u64:
        return null
    return ptr.uintptr().cast[void&].cast[static u8&]

def Linker_HleCallRingTargetAt(seq: u64) -> u64:
    slot: usize = (seq & (LINKER_HLE_CALL_RING_CAP.u64() - 1u64)).usize()
    return linker_hle_call_target_ring[slot]

def Linker_HleCallRingReturnAt(seq: u64) -> u64:
    slot: usize = (seq & (LINKER_HLE_CALL_RING_CAP.u64() - 1u64)).usize()
    return linker_hle_call_return_ring[slot]

def Linker_HleCallRingRdiAt(seq: u64) -> u64:
    slot: usize = (seq & (LINKER_HLE_CALL_RING_CAP.u64() - 1u64)).usize()
    return linker_hle_call_rdi_ring[slot]

def Linker_HleCallRingRsiAt(seq: u64) -> u64:
    slot: usize = (seq & (LINKER_HLE_CALL_RING_CAP.u64() - 1u64)).usize()
    return linker_hle_call_rsi_ring[slot]

def Linker_HleCallRingRdxAt(seq: u64) -> u64:
    slot: usize = (seq & (LINKER_HLE_CALL_RING_CAP.u64() - 1u64)).usize()
    return linker_hle_call_rdx_ring[slot]

def Linker_RelocateAnyImports(self: mutable Linker&, module: mutable Module&) -> void:
    ge_emergency_mark(GE_EV_RELOC_MODULE_BEGIN, module.base_virtual_addr, module.import_symbols.count.uintptr(), module.dynamic_info.rela_table_total_size.uintptr(), module.dynamic_info.jmp_relocation_total_size.uintptr())
    for i in 0..<module.import_symbols.count:
        self.last_total_import_count <- self.last_total_import_count + 1
        resolved_addr: mutable u64 = 0
        resolved_kind: mutable u8 = IMPORT_RESOLUTION_UNRESOLVED
        import_symbol: ImportSymbolRecord = module.import_symbols[i]
        ge_emergency_mark(GE_EV_RELOC_MODULE_IMPORT_BEGIN, module.base_virtual_addr, i.uintptr(), import_symbol.nid.uintptr(), import_symbol.raw_symbol.uintptr())
        qualified_raw: bool = Linker_IsQualifiedImportSymbol(import_symbol.raw_symbol)
        resolved: mutable bool = false
        if qualified_raw:
            resolved <- Linker_Resolve(self.ref[mutable Linker&], import_symbol.raw_symbol, module, import_symbol.symbol_type, resolved_addr.ref[mutable u64&], resolved_kind.ref[mutable u8&])
            if not resolved:
                resolved <- Linker_Resolve(self.ref[mutable Linker&], import_symbol.nid, module, import_symbol.symbol_type, resolved_addr.ref[mutable u64&], resolved_kind.ref[mutable u8&])
        else:
            resolved <- Linker_Resolve(self.ref[mutable Linker&], import_symbol.nid, module, import_symbol.symbol_type, resolved_addr.ref[mutable u64&], resolved_kind.ref[mutable u8&])
            if not resolved:
                resolved <- Linker_Resolve(self.ref[mutable Linker&], import_symbol.raw_symbol, module, import_symbol.symbol_type, resolved_addr.ref[mutable u64&], resolved_kind.ref[mutable u8&])
        module.import_symbols[i].resolved <- resolved
        module.import_symbols[i].resolved_virtual_addr <- resolved_addr
        module.import_symbols[i].resolution_kind <- resolved_kind
        if resolved:
            self.last_relocated_import_count <- self.last_relocated_import_count + 1
            if resolved_kind == IMPORT_RESOLUTION_NATIVE_HLE:
                self.last_native_hle_resolved_count <- self.last_native_hle_resolved_count + 1
            elif resolved_kind == IMPORT_RESOLUTION_PRX_EXPORT:
                self.last_prx_export_resolved_count <- self.last_prx_export_resolved_count + 1
            elif resolved_kind == IMPORT_RESOLUTION_AEROLIB_FALLBACK:
                self.last_aerolib_fallback_resolved_count <- self.last_aerolib_fallback_resolved_count + 1
        else:
            if resolved_kind == IMPORT_RESOLUTION_MALFORMED:
                self.last_malformed_import_count <- self.last_malformed_import_count + 1
            else:
                self.last_unresolved_import_count <- self.last_unresolved_import_count + 1
        ge_emergency_mark(GE_EV_RELOC_MODULE_IMPORT_END, module.base_virtual_addr, i.uintptr(), resolved_addr.uintptr(), resolved_kind.u64().uintptr())
    ge_emergency_mark(GE_EV_RELOC_MODULE_IMPORTS_DONE, module.base_virtual_addr, module.import_symbols.count.uintptr(), self.last_relocated_import_count.u64().uintptr(), self.last_unresolved_import_count.u64().uintptr())
    Linker_ApplyModuleRelocations(self.ref[mutable Linker&], module.ref[mutable Module&])
    ge_emergency_mark(GE_EV_RELOC_MODULE_END, module.base_virtual_addr, module.import_symbols.count.uintptr(), module.applied_relocation_count.uintptr(), module.patched_import_relocation_count.uintptr())

def Linker_ApplyRelocationEntry(self: mutable Linker&, module: mutable Module&, rel: elf_relocation) -> bool:
    linker_last_relocation_retryable <- false
    rel_type: u32 = (rel.rel_info & 0xffffffff.u64()).u32()
    symbol_index: u32 = (rel.rel_info >> 32.u64()).u32()
    rel_virtual_addr: u64 = module.base_virtual_addr.u64() + rel.rel_offset
    memory: mutable MemoryManager& = Memory_Instance()
    if rel_type == R_X86_64_RELATIVE:
        value: u64 = module.base_virtual_addr.u64() + rel.rel_addend.u64()
        Linker_NoteRelocatedPointerValue(value, rel_virtual_addr, rel_type, null, module.name)
        if Linker_WriteRelocationU64(module.ref[mutable Module&], memory, rel_virtual_addr, value):
            module.applied_relocation_count <- module.applied_relocation_count + 1
            return true
        Linker_RecordFailedRelocationDetail(self.ref[mutable Linker&], 1u32, IMPORT_RESOLUTION_UNRESOLVED, value)
        return false
    if rel_type == R_X86_64_64 or rel_type == R_X86_64_GLOB_DAT or rel_type == R_X86_64_JUMP_SLOT:
        addend: mutable i64 = rel.rel_addend
        if rel_type == R_X86_64_GLOB_DAT or rel_type == R_X86_64_JUMP_SLOT:
            addend <- 0
        symbol: mutable elf_symbol = zeroed
        symbol_found: bool = Module_GetSymbolByIndex(module, symbol_index, symbol.ref[mutable elf_symbol&])
        if symbol_found:
            symbol_bind: u8 = ElfSymbol_GetBind(symbol)
            if symbol_bind == STB_LOCAL or ((symbol_bind == STB_GLOBAL or symbol_bind == STB_WEAK) and symbol.st_shndx != ELF_SHN_UNDEF and symbol.st_value != 0):
                value: u64 = module.base_virtual_addr.u64() + symbol.st_value + addend.u64()
                Linker_NoteRelocatedPointerValue(value, rel_virtual_addr, rel_type, Module_GetSymbolNameByIndex(module.ref[mutable Module&], symbol_index), module.name)
                if Linker_WriteRelocationU64(module.ref[mutable Module&], memory, rel_virtual_addr, value):
                    module.applied_relocation_count <- module.applied_relocation_count + 1
                    return true
                Linker_RecordFailedRelocationDetail(self.ref[mutable Linker&], 2u32, IMPORT_RESOLUTION_PRX_EXPORT, value)
                return false
        symbol_name: static u8& = Module_GetSymbolNameByIndex(module.ref[mutable Module&], symbol_index)
        resolved_addr: mutable u64 = 0
        rel_kind: mutable u8 = IMPORT_RESOLUTION_UNRESOLVED
        expected_symbol_type: mutable u8 = IMPORT_SYMBOL_TYPE_UNKNOWN
        if rel_type == R_X86_64_JUMP_SLOT:
            expected_symbol_type <- IMPORT_SYMBOL_TYPE_FUNCTION
        resolved: mutable bool = Linker_Resolve(self.ref[mutable Linker&], symbol_name, module, expected_symbol_type, resolved_addr.ref[mutable u64&], rel_kind.ref[mutable u8&])
        if not resolved:
            import_index: s32 = Module_FindImportByName(module, symbol_name)
            if import_index >= 0 and module.import_symbols[import_index.usize()].resolved:
                resolved_addr <- module.import_symbols[import_index.usize()].resolved_virtual_addr
                rel_kind <- module.import_symbols[import_index.usize()].resolution_kind
                resolved <- true
        if not resolved and (rel_type == R_X86_64_JUMP_SLOT or rel_type == R_X86_64_GLOB_DAT or rel_type == R_X86_64_64):
            # Unresolved slot relocation: patch with the native fallback stub to
            # prevent a NULL/garbage pointer being left in the slot. shadPS4
            # handles R_X86_64_64/GLOB_DAT/JUMP_SLOT uniformly -- Resolve() returns
            # a non-zero stub so all three are written (linker.cpp Relocate). We
            # previously left unresolved R_X86_64_64 slots unpatched (value 0),
            # producing failed relocations and stale image bytes the guest could
            # read/call. The native stub also records the guest call site so the
            # first boundary can be attributed to a specific unimplemented import.
            resolved_addr <- GuestExec_AeroLibFallbackStubAddress().u64()
            resolved <- true
            linker_last_relocation_retryable <- true
        Linker_MixResolution(symbol_index, resolved_addr == GuestExec_AeroLibFallbackStubAddress().u64(), rel_type, symbol_name)
        if resolved:
            # Record every slot that ends up holding the fallback stub, no matter
            # which resolution path produced it (Linker_Resolve's built-in final
            # fallback also returns the stub address), so the runtime fallback
            # boundary can be attributed back to this relocation's symbol.
            if resolved_addr == GuestExec_AeroLibFallbackStubAddress().u64():
                Linker_RecordFallbackSlot(rel_virtual_addr, symbol_name, symbol_index, rel_type, module.name)
                linker_last_relocation_retryable <- true
            if rel_kind == IMPORT_RESOLUTION_NATIVE_HLE:
                should_thunk_native_hle: bool = Linker_ShouldThunkNativeHleRelocation(rel_type, symbol_found, symbol)
                if should_thunk_native_hle:
                    linker_native_hle_function_relocation_count <- linker_native_hle_function_relocation_count + 1
                    if addend != 0:
                        linker_native_hle_function_addend_count <- linker_native_hle_function_addend_count + 1
                        abs_addend: u64 = addend.u64() if addend >= 0 else (0i64 - addend).u64()
                        if abs_addend > linker_native_hle_function_max_addend:
                            linker_native_hle_function_max_addend <- abs_addend
                    raw_native_hle_addr: u64 = resolved_addr
                    resolved_addr <- Linker_CreateNativeHleBoundaryThunk(resolved_addr, symbol_name)
                    if Linker_UseNativeHleBoundaryThunk() and raw_native_hle_addr != 0u64 and resolved_addr == raw_native_hle_addr:
                        if linker_native_hle_unthunked_function_count == 0u64:
                            linker_native_hle_unthunked_function_first_target <- raw_native_hle_addr
                        linker_native_hle_unthunked_function_count <- linker_native_hle_unthunked_function_count + 1
                else:
                    linker_native_hle_data_relocation_count <- linker_native_hle_data_relocation_count + 1
                    Linker_NoteNativeHleDataRelocationValue(resolved_addr, symbol_name)
            value: u64 = resolved_addr + addend.u64()
            Linker_NoteRelocatedPointerValue(value, rel_virtual_addr, rel_type, symbol_name, module.name)
            if Linker_WriteRelocationU64(module.ref[mutable Module&], memory, rel_virtual_addr, value):
                module.applied_relocation_count <- module.applied_relocation_count + 1
                module.patched_import_relocation_count <- module.patched_import_relocation_count + 1
                return true
            Linker_RecordFailedRelocationDetail(self.ref[mutable Linker&], 4u32, rel_kind, value)
            return false
        Linker_RecordFailedRelocationDetail(self.ref[mutable Linker&], 3u32, rel_kind, resolved_addr)
        return false
    if rel_type == R_X86_64_DTPMOD64:
        if Linker_WriteRelocationU64(module.ref[mutable Module&], memory, rel_virtual_addr, module.tls.modid.u64()):
            module.applied_relocation_count <- module.applied_relocation_count + 1
            return true
        Linker_RecordFailedRelocationDetail(self.ref[mutable Linker&], 5u32, IMPORT_RESOLUTION_UNRESOLVED, module.tls.modid.u64())
    return false

def Linker_ApplyRelocationTable(self: mutable Linker&, module: mutable Module&, table_offset: u64, table_size: u64, entry_size: u64, bit_base_index: usize) -> void:
    if table_offset == 0 or table_size == 0 or entry_size == 0:
        return
    count: usize = (table_size / entry_size).usize()
    if count != 0usize:
        Linker_EnsureModuleRelocationBit(module.ref[mutable Module&], bit_base_index + count - 1usize)
    ge_emergency_mark(GE_EV_RELOC_TABLE_BEGIN, module.base_virtual_addr, table_offset.uintptr(), count.uintptr(), entry_size.uintptr())
    memory: mutable MemoryManager& = Memory_Instance()
    cached_relative_backing_index: mutable s32 = -1
    for i in 0..<count:
        offset: u64 = table_offset + (i.u64() * entry_size)
        bit_index: usize = bit_base_index + i
        if Linker_ModuleRelocationBit(module, bit_index):
            continue
        record_entry: bool = (i.u64() & 0xfffu64) == 0u64
        if record_entry:
            ge_emergency_mark(GE_EV_RELOC_TABLE_ENTRY_BEGIN, module.base_virtual_addr, i.uintptr(), offset.uintptr(), count.uintptr())
        if offset + size_of(elf_relocation).u64() <= module.dynamic_data.count.u64():
            rel: elf_relocation = Module_ReadRelocationAt(module, offset.usize())
            rel_type_for_fast_path: u32 = (rel.rel_info & 0xffffffff.u64()).u32()
            applied: mutable bool = false
            if rel_type_for_fast_path == R_X86_64_RELATIVE and linker_defer_native_relocation_writes:
                rel_virtual_addr: u64 = module.base_virtual_addr.u64() + rel.rel_offset
                value: u64 = module.base_virtual_addr.u64() + rel.rel_addend.u64()
                if Linker_WriteRelativeRelocationFast(module.ref[mutable Module&], memory, rel_virtual_addr, value, cached_relative_backing_index.ref[mutable s32&]):
                    module.applied_relocation_count <- module.applied_relocation_count + 1
                    applied <- true
                    linker_last_relocation_retryable <- false
            else:
                applied <- Linker_ApplyRelocationEntry(self.ref[mutable Linker&], module.ref[mutable Module&], rel)
            if applied and not linker_last_relocation_retryable:
                Linker_SetModuleRelocationBit(module.ref[mutable Module&], bit_index)
            if record_entry or not applied:
                ge_emergency_mark(GE_EV_RELOC_TABLE_ENTRY_END, module.base_virtual_addr, i.uintptr(), (rel.rel_info & 0xffffffff.u64()).uintptr(), rel.rel_offset.uintptr())
            if not applied:
                rel_type: u32 = (rel.rel_info & 0xffffffff.u64()).u32()
                self.last_failed_relocation_count <- self.last_failed_relocation_count + 1
                Linker_RecordFailedRelocationType(self.ref[mutable Linker&], rel_type)
                self.last_failed_relocation_type <- rel_type
                self.last_failed_relocation_symbol <- (rel.rel_info >> 32.u64()).u32()
                self.last_failed_relocation_offset <- rel.rel_offset
                self.last_failed_relocation_module <- module.name
                self.last_failed_relocation_name <- Module_GetSymbolNameByIndex(module.ref[mutable Module&], self.last_failed_relocation_symbol)
        else:
            ge_emergency_mark(GE_EV_RELOC_TABLE_ENTRY_END, module.base_virtual_addr, i.uintptr(), 0xffffffff.u64().uintptr(), offset.uintptr())
    ge_emergency_mark(GE_EV_RELOC_TABLE_END, module.base_virtual_addr, table_offset.uintptr(), count.uintptr(), module.applied_relocation_count.uintptr())

def Linker_ApplyModuleRelocations(self: mutable Linker&, module: mutable Module&) -> void:
    entry_size: u64 = Module_GetRelaEntrySize(module)
    rela_count: usize = Module_GetRelaRelocationCount(module)
    Linker_ApplyRelocationTable(self.ref[mutable Linker&], module.ref[mutable Module&], module.dynamic_info.rela_table_offset, module.dynamic_info.rela_table_total_size, entry_size, 0usize)
    Linker_ApplyRelocationTable(self.ref[mutable Linker&], module.ref[mutable Module&], module.dynamic_info.jmp_relocation_offset, module.dynamic_info.jmp_relocation_total_size, entry_size, rela_count)

def Linker_RelocateAllImports(self: mutable Linker&) -> void:
    self.last_total_import_count <- 0
    self.last_relocated_import_count <- 0
    self.last_unresolved_import_count <- 0
    self.last_native_hle_resolved_count <- 0
    self.last_prx_export_resolved_count <- 0
    self.last_aerolib_fallback_resolved_count <- 0
    self.last_malformed_import_count <- 0
    self.last_failed_relocation_count <- 0
    self.last_failed_relocation_type <- 0u32
    self.last_failed_relocation_symbol <- 0u32
    self.last_failed_relocation_offset <- 0u64
    self.last_failed_relocation_module <- null
    self.last_failed_relocation_name <- null
    self.last_failed_relocation_stage <- 0u32
    self.last_failed_relocation_kind <- IMPORT_RESOLUTION_UNRESOLVED
    self.last_failed_relocation_value <- 0u64
    self.failed_relocation_type1_count <- 0
    self.failed_relocation_glob_dat_count <- 0
    self.failed_relocation_jump_slot_count <- 0
    self.failed_relocation_relative_count <- 0
    self.failed_relocation_dtpmod64_count <- 0
    self.failed_relocation_other_count <- 0
    linker_native_hle_thunk_count <- 0usize
    linker_native_hle_function_relocation_count <- 0
    linker_native_hle_data_relocation_count <- 0
    linker_native_hle_unthunked_function_count <- 0
    linker_native_hle_unthunked_function_first_target <- 0
    linker_native_hle_function_addend_count <- 0
    linker_native_hle_function_max_addend <- 0
    linker_native_hle_data_thunk_pointer_count <- 0
    linker_native_hle_data_thunk_pointer_first_value <- 0
    linker_native_hle_data_thunk_pointer_first_name <- null
    linker_tiny_pointer_slot_count <- 0
    linker_tiny_pointer_first_value <- 0
    linker_tiny_pointer_first_offset <- 0
    linker_tiny_pointer_first_type <- 0u32
    linker_tiny_pointer_first_name <- null
    linker_tiny_pointer_first_module <- null
    Linker_ResetFallbackSlots()
    Linker_ResetResolutionFingerprint()
    for i in 0..<self.modules.count:
        Linker_RelocateAnyImports(self.ref[mutable Linker&], self.modules[i].ref[mutable Module&])
    self.relocated_all_imports <- true

def Linker_RecountImportResolution(self: mutable Linker&) -> void:
    self.last_total_import_count <- 0
    self.last_relocated_import_count <- 0
    self.last_unresolved_import_count <- 0
    self.last_native_hle_resolved_count <- 0
    self.last_prx_export_resolved_count <- 0
    self.last_aerolib_fallback_resolved_count <- 0
    self.last_malformed_import_count <- 0
    for module_index in 0..<self.modules.count:
        module_ref: mutable Module& = self.modules[module_index].ref[mutable Module&]
        for import_index in 0..<module_ref.import_symbols.count:
            import_ref: mutable ImportSymbolRecord& = module_ref.import_symbols[import_index].ref[mutable ImportSymbolRecord&]
            self.last_total_import_count <- self.last_total_import_count + 1
            if import_ref.resolved:
                self.last_relocated_import_count <- self.last_relocated_import_count + 1
                if import_ref.resolution_kind == IMPORT_RESOLUTION_NATIVE_HLE:
                    self.last_native_hle_resolved_count <- self.last_native_hle_resolved_count + 1
                elif import_ref.resolution_kind == IMPORT_RESOLUTION_PRX_EXPORT:
                    self.last_prx_export_resolved_count <- self.last_prx_export_resolved_count + 1
                elif import_ref.resolution_kind == IMPORT_RESOLUTION_AEROLIB_FALLBACK:
                    self.last_aerolib_fallback_resolved_count <- self.last_aerolib_fallback_resolved_count + 1
            else:
                if import_ref.resolution_kind == IMPORT_RESOLUTION_MALFORMED:
                    self.last_malformed_import_count <- self.last_malformed_import_count + 1
                else:
                    self.last_unresolved_import_count <- self.last_unresolved_import_count + 1

def Linker_AdvanceGenerationCounter(self: mutable Linker&) -> void:
    self.dtv_generation_counter <- self.dtv_generation_counter + 1

def Linker_TlsGetAddr(self: Linker&, module_index: u64, offset: u64) -> GuestVAddr[void]:
    GuestExec_RecordFirstBoundary(GUEST_EXEC_BOUNDARY_REASON_NATIVE_HLE)
    linker_tls_get_addr_calls <- linker_tls_get_addr_calls + 1u64
    linker_tls_last_module_index <- module_index
    linker_tls_last_offset <- offset
    linker_tls_last_dtv_base <- 0.uintptr()
    linker_tls_last_block_pointer <- 0.uintptr()
    ge_debug_trace_boundary("tls-get-addr-input", module_index.uintptr(), offset.uintptr(), 0.uintptr())
    if module_index == 0u64:
        # A TLS access with module id 0 means its DTPMOD64 relocation never
        # landed (the GOT pair still holds its link-time 0). shadPS4 always has
        # module_index >= 1. Returning the bare offset here hands the guest a
        # near-NULL bogus pointer (e.g. offset 0x1f4) -- the exact 0x1f4-class
        # bug. Surface it and return NULL so downstream null-checks catch it
        # instead of letting a tiny pointer flow into a mutex/TLS slot.
        linker_tls_module0_calls <- linker_tls_module0_calls + 1u64
        linker_tls_last_result <- 0.uintptr()
        ge_debug_trace_boundary("tls-get-addr-module0", module_index.uintptr(), offset.uintptr(), 0.uintptr())
        return 0.uintptr().cast[GuestVAddr[void]]
    # Faithful path (shadPS4 Linker::TlsGetAddr): the per-thread TLS block lives
    # in the DTV, NOT in the module's shared static init image. Read
    # tcb_dtv[module_index + 1].pointer + offset.
    tcb: mutable Tcb& = GetTcbBase()
    dtv_base: uintptr = !tcb.tcb_dtv
    linker_tls_last_dtv_base <- dtv_base
    if dtv_base != 0.uintptr():
        trusted Unsafe.PointerCast:
            dtv: mutable DtvEntry& = dtv_base.cast[mutable DtvEntry&]
            num_dtvs: usize = dtv[1usize].counter
            if module_index + 1u64 < (num_dtvs.u64() + 2u64):
                block: uintptr = !dtv[(module_index + 1u64).usize()].pointer
                linker_tls_last_block_pointer <- block
                if block != 0.uintptr():
                    result: uintptr = block + offset.uintptr()
                    linker_tls_last_result <- result
                    ge_debug_trace_boundary("tls-get-addr-dtv-result", result, block, offset.uintptr())
                    return result.cast[GuestVAddr[void]]
    else:
        linker_tls_null_dtv_calls <- linker_tls_null_dtv_calls + 1u64
    # Fallback (no installed DTV, e.g. dormant on the arm64 host): module-relative.
    module_slot: u64 = module_index - 1u64
    if module_slot >= self.modules.count.u64():
        linker_tls_last_result <- offset.uintptr()
        ge_debug_trace_boundary("tls-get-addr-module-miss", offset.uintptr(), module_index.uintptr(), self.modules.count.uintptr())
        return offset.uintptr().cast[GuestVAddr[void]]
    module: Module = self.modules[module_slot.usize()]
    fallback_res: mutable uintptr = module.base_virtual_addr + offset.uintptr()
    if module.tls.image_virtual_addr != 0.uintptr():
        fallback_res <- module.tls.image_virtual_addr + offset.uintptr()
    linker_tls_last_result <- fallback_res
    ge_debug_trace_boundary("tls-get-addr-fallback-result", fallback_res, module.base_virtual_addr, offset.uintptr())
    return fallback_res.cast[GuestVAddr[void]]

def Linker_AllocateTlsForThread(self: mutable Linker&, is_primary: bool) -> uintptr:
    # NOTE (C++ deviation, deliberate): shadPS4 maps the PRIMARY thread's TLS+TCB
    # from flexible (guest) memory (linker.cpp AllocateTlsForThread). We cannot:
    # in our architecture guest VAs are not directly host-writable (native
    # backing is synced separately), but the TCB/DTV build below writes to the
    # block as a host pointer. So we host-malloc the block; the %fs:0 -> LdtPage
    # .tcb indirection already lets the TCB live at any (even >4GB) host address.
    _ = is_primary
    tls_aligned_size: usize = Module_AlignUp(self.static_tls_size.u64(), 0x20u64).usize()
    total_tls_size: usize = tls_aligned_size + 0x40usize
    raw: mutable heap void&? = malloc(total_tls_size)
    if raw == null:
        InitializeTLS()
        fallback: mutable Tcb& = GetTcbBase()
        fallback_addr: uintptr = fallback.ref[mutable Tcb&].cast[uintptr]
        linker_tls_primary_base <- fallback_addr
        linker_tls_primary_size <- 0x40u64
        linker_tls_primary_tcb <- fallback_addr
        linker_tls_primary_dtv_base <- 0.uintptr()
        linker_tls_primary_dtv_size <- 0u64
        if !fallback.tcb_self == 0.uintptr():
            fallback.tcb_self <- fallback.ref[mutable Tcb&].cast[uintptr].cast[SegmentSelfPointer]
        if !fallback.tcb_thread == 0.uintptr():
            fallback.tcb_thread <- Linker_CurrentThreadObject().cast[GuestThreadObjectPointer]
        TLS_SetPrimaryTcbBase(fallback.ref[mutable Tcb&].cast[uintptr].cast[SegmentSelfPointer])
        return fallback.ref[mutable Tcb&].cast[uintptr]
    base: uintptr = raw.cast[uintptr]
    trusted Unsafe.PointerCast:
        bytes: mutable u8& = raw.cast[mutable u8&]
        i: mutable usize = 0
        while i < total_tls_size:
            bytes[i] <- 0u8
            i <- i + 1
        dtv_count: usize = self.max_tls_index.usize() + 2usize
        dtv_raw: mutable heap void&? = malloc(dtv_count * size_of(DtvEntry))
        if dtv_raw == null:
            return 0.uintptr()
        linker_tls_primary_base <- base
        linker_tls_primary_size <- total_tls_size.u64()
        linker_tls_primary_dtv_base <- dtv_raw.cast[uintptr]
        linker_tls_primary_dtv_size <- (dtv_count * size_of(DtvEntry)).u64()
        dtv_bytes: mutable u8& = dtv_raw.cast[mutable u8&]
        d: mutable usize = 0
        while d < dtv_count * size_of(DtvEntry):
            dtv_bytes[d] <- 0u8
            d <- d + 1
        tcb_addr: uintptr = base + tls_aligned_size.uintptr()
        linker_tls_primary_tcb <- tcb_addr
        tcb: mutable Tcb& = tcb_addr.cast[mutable Tcb&]
        dtv: mutable DtvEntry& = dtv_raw.cast[mutable DtvEntry&]
        tcb.tcb_self <- tcb_addr.cast[SegmentSelfPointer]
        tcb.tcb_dtv <- dtv_raw.cast[uintptr].cast[GuestDtvPointer]
        tcb.tcb_thread <- Linker_CurrentThreadObject().cast[GuestThreadObjectPointer]
        tcb.tcb_fiber <- 0.uintptr().cast[GuestFiberPointer]
        dtv[0usize].counter <- self.dtv_generation_counter.usize()
        dtv[1usize].counter <- self.max_tls_index.usize()
        if self.modules.count > 0:
            module: Module = self.modules[0]
            if module.tls.image_size != 0 and module.tls.modid.u64() + 1u64 < dtv_count.u64():
                dest_addr: uintptr = base + (tls_aligned_size - module.tls.offset.usize()).uintptr()
                src_addr: uintptr = module.tls.image_virtual_addr
                if src_addr != 0.uintptr():
                    src: u8& = src_addr.cast[u8&]
                    dest: mutable u8& = dest_addr.cast[mutable u8&]
                    c: mutable usize = 0
                    while c < module.tls.init_image_size.usize():
                        dest[c] <- src[c]
                        c <- c + 1
                dtv[module.tls.modid.usize() + 1usize].pointer <- dest_addr.cast[GuestTlsBlockPointer]
        TLS_SetPrimaryTcbBase(tcb_addr.cast[SegmentSelfPointer])
        TLS_RegisterPrimaryTemplate(base.cast[GuestTlsTemplatePointer], total_tls_size, dtv_raw.cast[uintptr].cast[GuestDtvPointer], dtv_count)
        return tcb_addr

def Linker_FreeTlsForNonPrimaryThread(self: mutable Linker&, pointer: void&?) -> void:
    _ = self
    _ = pointer

def Linker_LoadModule(self: mutable Linker&, elf_name: static u8&, is_dynamic: bool) -> s32:
    return Linker_LoadModuleFromHost(self.ref[mutable Linker&], elf_name, elf_name, is_dynamic)

def Linker_NextModuleBase(self: Linker&) -> VAddr:
    base: mutable u64 = MODULE_LOAD_BASE
    i: mutable usize = 0
    while i < self.modules.count:
        module_end: u64 = self.modules[i].base_virtual_addr.u64() + self.modules[i].aligned_base_size + MODULE_TRAMPOLINE_SIZE
        if module_end > base:
            base <- module_end
        i <- i + 1
    return Module_AlignUp(base, MODULE_BLOCK_ALIGN).uintptr()

def Linker_LoadModuleFromHost(self: mutable Linker&, guest_name: static u8&, host_name: static u8&, is_dynamic: bool) -> s32:
    base: mutable VAddr = Linker_NextModuleBase(self)
    module_name: static u8& = guest_name
    module: Module = Module_New(guest_name, module_name, base, is_dynamic)
    Module_SetHostFile(module.ref[mutable Module&], host_name)
    memory: mutable MemoryManager& = Memory_Instance()
    Module_LoadModuleToMemory(module.ref[mutable Module&], memory, self.max_tls_index.ref[mutable u32&])
    if not module.is_valid:
        return -1
    if not is_dynamic:
        self.num_static_modules <- self.num_static_modules + 1
    # The module table is persistent linker state; allocate its backing from the
    # persistent metadata arena rather than a transient local arena.
    owner: mutable Arena& = module_metadata_arena.ref[mutable Arena&]
    in owner:
        self.modules.push(module)
    return (self.modules.count - 1).s32()

def Linker_LoadAndStartModule(self: mutable Linker&, path: static u8&, args: u64, argp: void&?, p_res: mutable int&?) -> s32 can[Unsafe.SegmentMutation, Unsafe.GuestSegmentInstall, Segment.Guest, Segment.Host]:
    existing: u32 = Linker_FindByFileOrHost(self.ref[Linker&], path)
    if existing != 0xFFFFFFFF.u32():
        self.last_started_module_index <- existing.s32()
        self.last_start_result <- 0
        mod_existing: mutable Module&? = Linker_GetModule(self.ref[mutable Linker&], existing.s32())
        if mod_existing != null:
            self.last_entry_addr <- Module_GetEntryAddress(mod_existing, 0.uintptr())
        if p_res != null:
            p_res <- 0
        return existing.s32()
    idx: s32 = Linker_LoadModule(self.ref[mutable Linker&], path, true)
    if idx < 0:
        if p_res != null:
            p_res <- idx
        return idx
    mod_ref: mutable Module&? = Linker_GetModule(self.ref[mutable Linker&], idx)
    if mod_ref == null:
        if p_res != null:
            p_res <- -1
        self.last_started_module_index <- -1
        self.last_start_result <- -1
        self.last_entry_addr <- 0.uintptr()
        return -1
    Linker_RelocateAnyImports(self.ref[mutable Linker&], mod_ref)
    if mod_ref.tls.image_size != 0:
        Linker_AdvanceGenerationCounter(self.ref[mutable Linker&])
    self.last_entry_addr <- Module_GetEntryAddress(mod_ref, 0.uintptr())
    start_result: mutable s32 = 0
    can Unsafe.SegmentMutation, Unsafe.GuestSegmentInstall, Segment.Guest, Segment.Host:
        start_result <- Module_Start(mod_ref, args, argp, null)
    # Starting a PRX can make new exports available to modules loaded earlier,
    # but walking every module's relocation table here repeatedly re-scans the
    # eboot's 400k+ RELA entries during dependency startup. The final
    # Linker_Execute relocation pass still retries process-wide imports before
    # main enters guest code; keep this per-module path scoped to the module we
    # just loaded.
    self.relocated_all_imports <- false
    self.last_started_module_index <- idx
    self.last_start_result <- start_result
    Linker_RecountImportResolution(self.ref[mutable Linker&])
    if p_res != null:
        p_res <- start_result
    return idx

def Linker_LoadAndStartGuestModule(self: mutable Linker&, guest_path: static u8&, args: u64, argp: void&?, p_res: mutable int&?) -> s32 can[Unsafe.SegmentMutation, Unsafe.GuestSegmentInstall, Segment.Guest, Segment.Host]:
    host_path: static u8& = Linker_ResolveGuestModulePath(self.ref[Linker&], guest_path)
    if static_strlen(host_path) == 0:
        return -1
    self.last_loaded_dynamic_host_path <- host_path
    existing: mutable u32 = Linker_FindByFileOrHost(self.ref[Linker&], guest_path)
    if existing == 0xFFFFFFFF.u32():
        existing <- Linker_FindByFileOrHost(self.ref[Linker&], host_path)
    if existing != 0xFFFFFFFF.u32():
        self.last_started_module_index <- existing.s32()
        self.last_start_result <- 0
        mod_existing: mutable Module&? = Linker_GetModule(self.ref[mutable Linker&], existing.s32())
        if mod_existing != null:
            self.last_entry_addr <- Module_GetEntryAddress(mod_existing, 0.uintptr())
        if p_res != null:
            p_res <- 0
        return existing.s32()
    idx: s32 = Linker_LoadModuleFromHost(self.ref[mutable Linker&], guest_path, host_path, true)
    if idx < 0:
        if p_res != null:
            p_res <- idx
        return idx
    mod_ref: mutable Module&? = Linker_GetModule(self.ref[mutable Linker&], idx)
    if mod_ref == null:
        if p_res != null:
            p_res <- -1
        self.last_started_module_index <- -1
        self.last_start_result <- -1
        self.last_entry_addr <- 0.uintptr()
        return -1
    Linker_RelocateAnyImports(self.ref[mutable Linker&], mod_ref)
    if mod_ref.tls.image_size != 0:
        Linker_AdvanceGenerationCounter(self.ref[mutable Linker&])
    self.last_entry_addr <- Module_GetEntryAddress(mod_ref, 0.uintptr())
    start_result: mutable s32 = 0
    can Unsafe.SegmentMutation, Unsafe.GuestSegmentInstall, Segment.Guest, Segment.Host:
        start_result <- Module_Start(mod_ref, args, argp, null)
    # Defer process-wide retry relocation until the final Execute pass. Doing
    # it after every dynamic module start preserves correctness poorly for the
    # current two-layer runtime because it repeatedly scans the main eboot RELA
    # table, while the new module itself was already relocated before start.
    self.relocated_all_imports <- false
    self.last_started_module_index <- idx
    self.last_start_result <- start_result
    Linker_RecountImportResolution(self.ref[mutable Linker&])
    if p_res != null:
        p_res <- start_result
    return idx

def Linker_FindByAddress(self: mutable Linker&, address: VAddr) -> mutable Module&?:
    for i in 0..<self.modules.count:
        mod: Module = self.modules[i]
        if mod.base_virtual_addr <= address and address < mod.base_virtual_addr + mod.aligned_base_size.uintptr():
            return self.modules[i].ref[mutable Module&]
    return null

def Linker_Relocate(self: mutable Linker&, module: mutable Module&) -> void:
    Linker_RelocateAnyImports(self.ref[mutable Linker&], module.ref[mutable Module&])

def Linker_Resolve(self: mutable Linker&, name: static u8&, module: mutable Module&, expected_symbol_type: u8, out_virtual_address: mutable u64&, out_resolution_kind: mutable u8&) -> bool:
    out_virtual_address <- 0
    out_resolution_kind <- IMPORT_RESOLUTION_UNRESOLVED
    GuestExec_RecordLastModuleSymbol(module.name, name)
    if static_strlen(name) == 0:
        out_resolution_kind <- IMPORT_RESOLUTION_MALFORMED
        return false
    if streq(name, "module_start") == 1 or streq(name, "module_stop") == 1 or streq(name, "compilerrt_abort_impl") == 1 or Linker_StringHasPrefix(name, "Need_"):
        out_virtual_address <- Linker_RuntimeLifecycleNoop.uintptr().u64()
        out_resolution_kind <- IMPORT_RESOLUTION_NATIVE_HLE
        GuestExec_RecordLastHle(module.name, name)
        return true
    parsed_nid: mutable static u8& = ""
    parsed_library_id: mutable static u8& = ""
    parsed_module_id: mutable static u8& = ""
    parsed: bool = Module_ParseImportSymbol(name, parsed_nid.ref[mutable static u8&], parsed_library_id.ref[mutable static u8&], parsed_module_id.ref[mutable static u8&])
    symbol_type: mutable u8 = expected_symbol_type
    lookup_nid: mutable static u8& = name
    if parsed:
        lookup_nid <- parsed_nid
    if parsed and static_strlen(parsed_library_id) > 0 and static_strlen(parsed_module_id) > 0:
        library_index: s32 = Module_FindImportLibraryIndex(module, parsed_library_id)
        module_index: s32 = Module_FindImportModuleIndex(module, parsed_module_id)
        if library_index >= 0 and module_index >= 0:
            library_value: LibraryInfo = Module_LibraryByCombinedIndex(module, library_index)
            module_value: ModuleInfo = Module_InfoByCombinedIndex(module, module_index)
            for import_index in 0..<module.import_symbols.count:
                imp: ImportSymbolRecord = module.import_symbols[import_index]
                if streq(imp.raw_symbol, name) == 1 or (streq(imp.nid, parsed_nid) == 1 and streq(imp.library, parsed_library_id) == 1 and streq(imp.module, parsed_module_id) == 1):
                    symbol_type <- imp.symbol_type
            found_index: s32 = SymbolsResolver_FindHleSymbol(self.hle_symbols, parsed_nid, library_value.name, Module_DynamicLibraryVersion(library_value.value), module_value.name, symbol_type)
            if found_index >= 0:
                sym: SymbolRecord = self.hle_symbols.symbols[found_index.usize()]
                out_virtual_address <- sym.callable_address
                out_resolution_kind <- IMPORT_RESOLUTION_NATIVE_HLE
                GuestExec_RecordLastHle(module.name, sym.name)
                return true
            for candidate_index in 0..<self.modules.count:
                if Module_FindDefinedQualifiedSymbolAddress(self.modules[candidate_index].ref[Module&], parsed_nid, library_value.name, Module_DynamicLibraryVersion(library_value.value), module_value.name, symbol_type, out_virtual_address.ref[mutable u64&]):
                    out_resolution_kind <- IMPORT_RESOLUTION_PRX_EXPORT
                    return true
    for module_index in 0..<self.modules.count:
        if Module_FindDefinedSymbolAddress(self.modules[module_index].ref[mutable Module&], lookup_nid, out_virtual_address.ref[mutable u64&]):
            out_resolution_kind <- IMPORT_RESOLUTION_PRX_EXPORT
            return true
    fallback_index: s32 = SymbolsResolver_FindHleSymbolByNidOnlyTyped(self.hle_symbols, lookup_nid, symbol_type)
    if fallback_index >= 0:
        sym: SymbolRecord = self.hle_symbols.symbols[fallback_index.usize()]
        out_virtual_address <- sym.callable_address
        out_resolution_kind <- IMPORT_RESOLUTION_NATIVE_HLE
        GuestExec_RecordLastHle(module.name, sym.name)
        return true
    if lookup_nid != name:
        for module_index in 0..<self.modules.count:
            if Module_FindDefinedSymbolAddress(self.modules[module_index].ref[mutable Module&], name, out_virtual_address.ref[mutable u64&]):
                out_resolution_kind <- IMPORT_RESOLUTION_PRX_EXPORT
                return true
    out_virtual_address <- GuestExec_AeroLibFallbackStubAddress().u64()
    out_resolution_kind <- IMPORT_RESOLUTION_AEROLIB_FALLBACK
    return true

def Linker_Execute(self: mutable Linker&, args: darray[static u8&]) -> s32 can[Unsafe.SegmentMutation, Unsafe.GuestSegmentInstall, Segment.Guest, Segment.Host]:
    self.last_execute_argc <- args.count
    if self.modules.count == 0:
        self.last_started_module_index <- -1
        self.last_start_result <- -1
        self.last_entry_addr <- 0.uintptr()
        return -1
    self.static_tls_size <- self.modules[0].tls.image_size.usize()
    self.modules[0].tls.offset <- self.modules[0].tls.image_size
    memory: mutable MemoryManager& = Memory_Instance()
    flexible_size: u64 = Linker_GetFlexibleMemorySize(self)
    use_extended_mem1: bool = Linker_GetUseExtendedMemory1(self)
    use_extended_mem2: bool = Linker_GetUseExtendedMemory2(self)
    ge_emergency_mark(GE_EV_EXEC_MEMORY_SETUP_BEGIN, self.modules.count.uintptr(), self.static_tls_size.uintptr(), flexible_size.uintptr(), (1u64 if use_extended_mem2 else 0u64).uintptr())
    MemoryManager_SetupMemoryRegions(memory, flexible_size, use_extended_mem1, use_extended_mem2)
    ge_emergency_mark(GE_EV_EXEC_MEMORY_SETUP_END, self.modules.count.uintptr(), self.static_tls_size.uintptr(), flexible_size.uintptr(), MemoryManager_GetTotalDirectSize(memory).uintptr())
    Linker_EnsureMainGuestStack(memory)
    can Unsafe.SegmentMutation, Unsafe.GuestSegmentInstall, Segment.Guest, Segment.Host:
        Linker_PreloadLibkernelGameModules(self.ref[mutable Linker&])
        Linker_LoadDependencyClosure(self.ref[mutable Linker&])
    ge_emergency_mark(GE_EV_EXEC_AFTER_DEP_CLOSURE, self.modules.count.uintptr(), (1u64 if self.relocated_all_imports else 0u64).uintptr(), 0.uintptr(), 0.uintptr())
    GuestExec_RecordLoad()
    if not self.relocated_all_imports:
        ge_emergency_mark(GE_EV_EXEC_RELOC_ALL_BEGIN, self.modules.count.uintptr(), self.last_relocated_import_count.u64().uintptr(), 0.uintptr(), 0.uintptr())
        linker_defer_native_relocation_writes <- true
        Linker_RelocateAllImports(self.ref[mutable Linker&])
        linker_defer_native_relocation_writes <- false
        ge_emergency_mark(GE_EV_EXEC_RELOC_ALL_END, self.modules.count.uintptr(), self.last_relocated_import_count.u64().uintptr(), 0.uintptr(), 0.uintptr())
    GuestExec_RecordLink()
    GuestExec_SetFailedRelocationCount(self.last_failed_relocation_count.u64())
    ge_emergency_mark(GE_EV_EXEC_TLS_ALLOC_BEGIN, self.modules.count.uintptr(), self.static_tls_size.uintptr(), 0.uintptr(), 0.uintptr())
    tls_addr: VAddr = Linker_AllocateTlsForThread(self.ref[mutable Linker&], true)
    ge_emergency_mark(GE_EV_EXEC_TLS_ALLOC_END, tls_addr, self.modules.count.uintptr(), self.static_tls_size.uintptr(), 0.uintptr())
    Linker_EnsureMainGuestStack(memory)
    index: mutable s32 = 0
    mod_ref: mutable Module&? = Linker_GetModule(self.ref[mutable Linker&], index)
    if mod_ref == null:
        self.last_started_module_index <- -1
        self.last_start_result <- -1
        self.last_entry_addr <- 0.uintptr()
        return -1
    self.last_entry_addr <- Module_GetEntryAddress(mod_ref, 0.uintptr())
    mod_ref.last_start_entry_addr <- self.last_entry_addr
    mod_ref.last_start_preinit_count <- 0
    mod_ref.last_start_init_count <- 0
    result: s32 = 0
    if GuestExec_IsEnabled():
        ge_emergency_mark(GE_EV_MAIN_ENTRY_SYNC_BEGIN, self.last_entry_addr, args.count.uintptr(), 0.uintptr(), 0.uintptr())
        if not MemoryManager_SyncNativeBackingToGuestExec(memory):
            self.last_started_module_index <- index
            self.last_start_result <- -2
            return -2
        ge_emergency_mark(GE_EV_MAIN_ENTRY_SYNC_END, self.last_entry_addr, args.count.uintptr(), 0.uintptr(), 0.uintptr())
        argv0: mutable void&? = null
        GuestExec_ClearEntryArgs()
        arg_index: mutable usize = 0usize
        while arg_index < args.count and arg_index < 33usize:
            GuestExec_SetEntryArg(arg_index, args[arg_index])
            arg_index <- arg_index + 1usize
        if args.count > 0:
            argv0 <- args[0].cast[void&?]
        ge_emergency_mark(GE_EV_MAIN_ENTRY_PREPARE_BEGIN, self.last_entry_addr, args.count.uintptr(), argv0.uintptr(), 0.uintptr())
        prep_status: mutable s32 = 0
        can Unsafe.SegmentMutation, Segment.Host:
            prep_status <- Linker_PrepareMainThreadBeforeEntry()
        ge_emergency_mark(GE_EV_MAIN_ENTRY_PREPARE_END, self.last_entry_addr, prep_status.u64().uintptr(), argv0.uintptr(), 0.uintptr())
        ge_emergency_mark(GE_EV_MAIN_ENTRY_JUMP_BEGIN, self.last_entry_addr, args.count.uintptr(), argv0.uintptr(), 0.uintptr())
        GuestExec_RunMainEntry(self.last_entry_addr, args.count.int(), argv0)
        ge_emergency_mark(GE_EV_MAIN_ENTRY_JUMP_RETURNED, self.last_entry_addr, args.count.uintptr(), argv0.uintptr(), 0.uintptr())
    Linker_RelocateAllImports(self.ref[mutable Linker&])
    self.last_started_module_index <- index
    self.last_start_result <- result
    Linker_RecountImportResolution(self.ref[mutable Linker&])
    return result

def Linker_DebugDump(self: Linker&) -> darray[static u8&]:
    out: mutable darray[static u8&] = []
    owner: mutable Arena& = module_metadata_arena.ref[mutable Arena&]
    in owner:
        for i in 0..<self.modules.count:
            out.push(self.modules[i].name)
    return out
