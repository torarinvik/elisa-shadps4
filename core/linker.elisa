def Linker_IsQualifiedImportSymbol(raw_symbol: static u8&) -> bool can[Memory.Allocate, Abort.Panic]:
    parsed_nid: mutable static u8& = ""
    parsed_library: mutable static u8& = ""
    parsed_module: mutable static u8& = ""
    can Memory.Allocate, Abort.Panic:
        if not Module_ParseImportSymbol(raw_symbol, (&parsed_nid).cast[mutable static u8&], (&parsed_library).cast[mutable static u8&], (&parsed_module).cast[mutable static u8&]):
            return false
    return static_strlen(parsed_library) > 0 and static_strlen(parsed_module) > 0

def Linker_RelocProbeNote(addr: u64, value: u64, rel_type: u32, path: u32) -> void:
    if linker_reloc_probe_addr == 0:
        return
    if addr >= linker_reloc_probe_addr and addr < (linker_reloc_probe_addr + 8):
        linker_reloc_probe_count <- linker_reloc_probe_count + 1
        linker_reloc_probe_value <- value
        linker_reloc_probe_type <- rel_type
        linker_reloc_probe_path <- path

def Linker_RelocProbeCount() -> u64:
    return linker_reloc_probe_count

def Linker_RelocProbeValue() -> u64:
    return linker_reloc_probe_value

def Linker_RelocProbeType() -> u32:
    return linker_reloc_probe_type

def Linker_RelocProbePath() -> u32:
    return linker_reloc_probe_path

def Linker_RelocProbeAddr() -> u64:
    return linker_reloc_probe_addr

# A relocation write that lands in neither the module image nor guest memory. The
# payload carries the target guest address so a handler is self-describing. This is
# the linker's own error set (distinct from the loader's LoaderError), caught — not
# propagated — at the relocation-apply layer, which records and continues.
error RelocError:
    WriteUnlanded(addr: u64)

def Linker_WriteRelocationU64(module: mutable Module&, memory: mutable MemoryManager&, addr: u64, value: u64) -> void error[RelocError] can[Memory.Allocate]:
    Linker_RelocProbeNote(addr, value, 0xFFFFFFFF, 1)
    image_ok: bool = Module_WriteImageU64((&module).cast[mutable Module&], addr, value)
    memory_ok: mutable bool = false
    if linker_defer_native_relocation_writes and GuestExec_IsEnabled() and GuestExec_IsSupported():
        memory_ok <- MemoryManager_WriteU64BackingOnly(memory, addr.uintptr(), value)
    else:
        can Memory.Allocate:
            memory_ok <- MemoryManager_WriteU64(memory, addr.uintptr(), value)
    if image_ok or memory_ok:
        return
    raise RelocError.WriteUnlanded(addr)

def Linker_WriteRelativeRelocationFast(module: mutable Module&, memory: mutable MemoryManager&, addr: u64, value: u64, cached_backing_index: mutable s32&) -> bool:
    Linker_RelocProbeNote(addr, value, 8, 2)  # 8 = R_X86_64_RELATIVE
    image_ok: mutable bool = false
    image_offset: mutable usize = 0
    if Module_ImageOffsetForVirtualAddress(module, addr, image_offset):
        for i in 0..<8:
            module.image[image_offset + i] <- ((value >> (i.u64() * 8)) & 0xff).u8()
        image_ok <- true

    backing_index: mutable s32 = cached_backing_index
    backing_ok: mutable bool = false
    if backing_index >= 0 and backing_index.usize() < memory.mapped_bytes.count:
        cached: MappedMemoryBytes = memory.mapped_bytes[backing_index.usize()]
        if addr.uintptr() >= cached.base:
            cached_offset: u64 = (addr.uintptr() - cached.base).u64()
            if cached_offset <= cached.size and 8 <= (cached.size - cached_offset):
                backing_ok <- true
    if not backing_ok:
        backing_index <- MemoryManager_FindBackingIndex(memory, addr.uintptr(), 8)
        if backing_index >= 0:
            cached_backing_index <- backing_index
            backing_ok <- true
    if backing_ok:
        base_offset: usize = (addr.uintptr() - memory.mapped_bytes[backing_index.usize()].base).usize()
        for i in 0..<8:
            memory.mapped_bytes[backing_index.usize()].bytes[base_offset + i] <- ((value >> (i.u64() * 8)) & 0xff).u8()
    return image_ok or backing_ok

def Linker_ModuleRelocationBit(module: Module&, bit_index: usize) -> bool:
    byte_index: usize = bit_index / 8
    if byte_index >= module.applied_relocation_bits.count:
        return false
    mask: u8 = (1 << (bit_index % 8).u8())
    return (module.applied_relocation_bits[byte_index] & mask) != 0

def Linker_EnsureModuleRelocationBit(module: mutable Module&, bit_index: usize) -> void:
    byte_index: usize = bit_index / 8
    can Memory.Allocate:
        can Unsafe.MutableGlobal:
            in perm:
                while module.applied_relocation_bits.count <= byte_index:
                    decreases byte_index - module.applied_relocation_bits.count
                    module.applied_relocation_bits.push(0)

def Linker_SetModuleRelocationBit(module: mutable Module&, bit_index: usize) -> void can[Memory.Allocate]:
    can Memory.Allocate:
        Linker_EnsureModuleRelocationBit((&module).cast[mutable Module&], bit_index)
    byte_index: usize = bit_index / 8
    mask: u8 = (1 << (bit_index % 8).u8())
    module.applied_relocation_bits[byte_index] <- module.applied_relocation_bits[byte_index] | mask

def Linker_RecordFailedRelocationType(self: mutable Linker&, rel_type: u32) -> void:
    if rel_type == R_X86_64_64:
        self.failed_relocation_type1_count <- self.failed_relocation_type1_count + 1
    elif rel_type == R_X86_64_GLOB_DAT:
        self.failed_relocation_glob_dat_count <- self.failed_relocation_glob_dat_count + 1
    elif rel_type == R_X86_64_JUMP_SLOT:
        self.failed_relocation_jump_slot_count <- self.failed_relocation_jump_slot_count + 1
    elif rel_type == R_X86_64_RELATIVE:
        self.failed_relocation_relative_count <- self.failed_relocation_relative_count + 1
    elif rel_type == R_X86_64_DTPMOD64:
        self.failed_relocation_dtpmod64_count <- self.failed_relocation_dtpmod64_count + 1
    else:
        self.failed_relocation_other_count <- self.failed_relocation_other_count + 1

def Linker_RecordFailedRelocationDetail(self: mutable Linker&, stage: u32, kind: u8, value: u64) -> void:
    self.last_failed_relocation_stage <- stage
    self.last_failed_relocation_kind <- kind
    self.last_failed_relocation_value <- value

def Linker_ShouldThunkNativeHleRelocation(rel_type: u32, symbol_found: bool, symbol: elf_symbol) -> bool:
    if not symbol_found:
        return rel_type == R_X86_64_JUMP_SLOT
    typ: u8 = ElfSymbol_GetType(symbol)
    return typ == STT_FUN or (typ == STT_NOTYPE and rel_type == R_X86_64_JUMP_SLOT)

def Linker_CreateNativeHleBoundaryThunk(target: u64, symbol_name: static u8&?) -> u64:
    if target == 0:
        return 0
    if not Linker_UseNativeHleBoundaryThunk():
        return target
    sym_ptr: u64 = Linker_SymbolNamePtr(symbol_name)
    cache_index: mutable usize = 0
    while cache_index < linker_native_hle_thunk_count and cache_index < LINKER_NATIVE_HLE_THUNK_CAP:
        decreases LINKER_NATIVE_HLE_THUNK_CAP - cache_index
        if linker_native_hle_thunk_targets[cache_index] == target and linker_native_hle_thunk_symbol_ptrs[cache_index] == sym_ptr:
            return linker_native_hle_thunk_addrs[cache_index]
        cache_index <- cache_index + 1
    static if PLATFORM_APPLE and ARCH_X86_64:
        host_selector: HostFsSelector = TLS_CaptureHostFsSelector()
        # gap-3 (UPDATE 9): prefer the live host %gs selector captured at runtime over the
        # hardcoded 0x6F. The thunk is built on a host thread (module init, before any guest
        # %gs swap), so %gs still holds the host selector here. Only override when the
        # captured value is non-zero, so a future platform that returns 0 falls back safely.
        if linker_restore_host_gs:
            captured_gs: u16 = TLS_CaptureHostGsSelector()
            if captured_gs != 0:
                linker_host_gs_selector <- captured_gs
        # gap-3 (UPDATE 8): optionally also force the host %gs selector before the HLE
        # body runs, so a host malloc/CRT reached from an HLE reads host pthread TLS
        # (%gs:0x68) instead of a guest/clobbered base. 8 extra bytes:
        #   movw $host_gs_selector, %r10w ; movw %r10w, %gs
        # inserted right after the %fs restore, before `movabs $target,%r11`. The guest
        # never uses %gs, so no guest-%gs save/restore is needed. When the flag is off
        # the emitted thunk is byte-identical to the original 174-byte layout.
        # movw $imm16,%r10w (66 41 BA + imm16 = 5 bytes) + movw %r10w,%gs (66 41 8E EA = 4) = 9
        gs_extra: u64 = 9 if linker_restore_host_gs else 0
        thunk_size: u64 = 174 + gs_extra
        full: mutable u8[183] = zeroed
        # Accumulates the result of every bounds-checked immediate emit below. If a
        # hardcoded offset ever stops fitting `full` (e.g. after a layout/size edit)
        # the checked writer refuses the store and flips this false; we then bail via
        # the same `return target` failure path used for allocation/publish errors,
        # so a bad offset can never corrupt stack/heap past `full` nor ship a
        # half-formed thunk. On the success path it stays true and the emitted bytes
        # are byte-identical to the previous direct-store codegen.
        emit_ok: mutable bool = true
        # Capture the guest return address before touching the thunk stack.
        # At thunk entry, (%rsp) is the return PC pushed by the guest call.
        # movq (%rsp), %r11
        full[0] <- 0x4C
        full[1] <- 0x8B
        full[2] <- 0x1C
        full[3] <- 0x24
        # movabs $ge_runtime_hle_guest_return_addr, %r10; movq %r11, (%r10)
        full[4] <- 0x49
        full[5] <- 0xBA
        emit_ok <- emit_ok and Linker_WriteU64LE((&full[0]).cast[mutable u8&], 183, 6, (&ge_runtime_hle_guest_return_addr).cast[void&].uintptr().u64())
        full[14] <- 0x4D
        full[15] <- 0x89
        full[16] <- 0x1A
        # movabs $ge_runtime_hle_guest_rsp, %r10; movq %rsp, (%r10)
        full[17] <- 0x49
        full[18] <- 0xBA
        emit_ok <- emit_ok and Linker_WriteU64LE((&full[0]).cast[mutable u8&], 183, 19, (&ge_runtime_hle_guest_rsp).cast[void&].uintptr().u64())
        full[27] <- 0x49
        full[28] <- 0x89
        full[29] <- 0x22
        # movabs $ge_runtime_hle_guest_rbp, %r10; movq %rbp, (%r10)
        full[30] <- 0x49
        full[31] <- 0xBA
        emit_ok <- emit_ok and Linker_WriteU64LE((&full[0]).cast[mutable u8&], 183, 32, (&ge_runtime_hle_guest_rbp).cast[void&].uintptr().u64())
        full[40] <- 0x49
        full[41] <- 0x89
        full[42] <- 0x2A
        # movabs $ge_runtime_hle_guest_rdi, %r10; movq %rdi, (%r10)
        full[43] <- 0x49
        full[44] <- 0xBA
        emit_ok <- emit_ok and Linker_WriteU64LE((&full[0]).cast[mutable u8&], 183, 45, (&ge_runtime_hle_guest_rdi).cast[void&].uintptr().u64())
        full[53] <- 0x49
        full[54] <- 0x89
        full[55] <- 0x3A
        # Capture the rest of the SysV argument register set. This lets the
        # artifact distinguish "real mutex call with a bad pointer" from
        # "wrong callee / corrupted call frame" without a debugger.
        full[56] <- 0x49
        full[57] <- 0xBA
        emit_ok <- emit_ok and Linker_WriteU64LE((&full[0]).cast[mutable u8&], 183, 58, (&ge_runtime_hle_guest_rsi).cast[void&].uintptr().u64())
        full[66] <- 0x49
        full[67] <- 0x89
        full[68] <- 0x32
        full[69] <- 0x49
        full[70] <- 0xBA
        emit_ok <- emit_ok and Linker_WriteU64LE((&full[0]).cast[mutable u8&], 183, 71, (&ge_runtime_hle_guest_rdx).cast[void&].uintptr().u64())
        full[79] <- 0x49
        full[80] <- 0x89
        full[81] <- 0x12
        full[82] <- 0x49
        full[83] <- 0xBA
        emit_ok <- emit_ok and Linker_WriteU64LE((&full[0]).cast[mutable u8&], 183, 84, (&ge_runtime_hle_guest_rcx).cast[void&].uintptr().u64())
        full[92] <- 0x49
        full[93] <- 0x89
        full[94] <- 0x0A
        full[95] <- 0x49
        full[96] <- 0xBA
        emit_ok <- emit_ok and Linker_WriteU64LE((&full[0]).cast[mutable u8&], 183, 97, (&ge_runtime_hle_guest_r8).cast[void&].uintptr().u64())
        full[105] <- 0x4D
        full[106] <- 0x89
        full[107] <- 0x02
        full[108] <- 0x49
        full[109] <- 0xBA
        emit_ok <- emit_ok and Linker_WriteU64LE((&full[0]).cast[mutable u8&], 183, 110, (&ge_runtime_hle_guest_r9).cast[void&].uintptr().u64())
        full[118] <- 0x4D
        full[119] <- 0x89
        full[120] <- 0x0A
        # Save the live guest selector. Every guest thread has its own %fs, so
        # restoring a baked main-thread selector corrupts worker-thread TLS.
        # push %r10 also fixes the nested SysV call alignment.
        full[121] <- 0x66
        full[122] <- 0x41
        full[123] <- 0x8C
        full[124] <- 0xE2
        full[125] <- 0x41
        full[126] <- 0x52
        # movw $host_selector, %r10w; movw %r10w, %fs
        full[127] <- 0x66
        full[128] <- 0x41
        full[129] <- 0xBA
        emit_ok <- emit_ok and Linker_WriteU16LE((&full[0]).cast[mutable u8&], 183, 130, (!host_selector).u16())
        full[132] <- 0x66
        full[133] <- 0x41
        full[134] <- 0x8E
        full[135] <- 0xE2
        # gap-3 (UPDATE 8): optional host-%gs restore. movw $sel,%r10w ; movw %r10w,%gs.
        # 0x8E /r with ModRM.reg=5 selects %gs (vs 0xE2 = %fs which is reg=4).
        if linker_restore_host_gs:
            full[136] <- 0x66
            full[137] <- 0x41
            full[138] <- 0xBA
            emit_ok <- emit_ok and Linker_WriteU16LE((&full[0]).cast[mutable u8&], 183, 139, linker_host_gs_selector)
            full[141] <- 0x66
            full[142] <- 0x41
            full[143] <- 0x8E
            full[144] <- 0xEA
        t: usize = (136 + gs_extra).usize()
        # movabs $target, %r11; call *%r11
        full[t] <- 0x49
        full[t + 1] <- 0xBB
        emit_ok <- emit_ok and Linker_WriteU64LE((&full[0]).cast[mutable u8&], 183, (t + 2).u64(), target)
        full[t + 10] <- 0x41
        full[t + 11] <- 0xFF
        full[t + 12] <- 0xD3
        # Restore the original guest return slot before returning. Host HLE
        # bodies run on the guest stack; preserving the call continuation here
        # prevents host prologues/epilogues from accidentally skipping guest code.
        full[t + 13] <- 0x49
        full[t + 14] <- 0xBB
        emit_ok <- emit_ok and Linker_WriteU64LE((&full[0]).cast[mutable u8&], 183, (t + 15).u64(), (&ge_runtime_hle_guest_return_addr).cast[void&].uintptr().u64())
        full[t + 23] <- 0x4D
        full[t + 24] <- 0x8B
        full[t + 25] <- 0x1B
        full[t + 26] <- 0x4C
        full[t + 27] <- 0x89
        full[t + 28] <- 0x5C
        full[t + 29] <- 0x24
        full[t + 30] <- 0x08
        # pop saved selector into %r10; movw %r10w, %fs; ret
        full[t + 31] <- 0x41
        full[t + 32] <- 0x5A
        full[t + 33] <- 0x66
        full[t + 34] <- 0x41
        full[t + 35] <- 0x8E
        full[t + 36] <- 0xE2
        full[t + 37] <- 0xC3
        # If any immediate emit was refused as out-of-range, the buffer is not a
        # valid thunk -- bail through the same failure path as an allocation error
        # rather than publish corrupt machine code.
        if not emit_ok:
            return target
        thunk: VAddr = GuestExec_AllocateRegion(4096, 5)
        if thunk == 0.uintptr():
            return target
        can Unsafe.MachineCodeBuilder:
            if not GuestExec_WriteBytes(thunk, (&full[0]).cast[void&], thunk_size):
                return target
        can Unsafe.ExecutableCodePublish:
            if not GuestExec_PublishExecutableCode(thunk, thunk_size):
                return target
        GuestExec_RecordHleBoundaryThunkContract(thunk, target.uintptr(), thunk_size, host_selector)
        # Wrap the real thunk in a recorder prefix that logs the symbol-name pointer
        # of this call into linker_hle_call_ring, then jmps through. The GOT ends up
        # pointing at the prefix; the prefix preserves %rsp and all SysV arg regs
        # (it only clobbers %r10/%r11, which the real thunk reloads immediately) so
        # the boundary contract is unaffected.
        entry_addr: u64 = Linker_CreateHleRecorderPrefix(thunk.u64(), sym_ptr, target)
        final_addr: u64 = entry_addr if entry_addr != 0 else thunk.u64()
        if linker_native_hle_thunk_count < LINKER_NATIVE_HLE_THUNK_CAP:
            linker_native_hle_thunk_targets[linker_native_hle_thunk_count] <- target
            linker_native_hle_thunk_addrs[linker_native_hle_thunk_count] <- final_addr
            linker_native_hle_thunk_symbol_ptrs[linker_native_hle_thunk_count] <- sym_ptr
            linker_native_hle_thunk_count <- linker_native_hle_thunk_count + 1
        return final_addr
    static else:
        return target

def Linker_SymbolNamePtr(symbol_name: static u8&?) -> u64:
    if symbol_name == null:
        return 0
    name: static u8& = symbol_name
    return (&name).cast[void&].uintptr().u64()

# Build a small recorder prefix stub that logs `sym_ptr` into linker_hle_call_ring
# (masked by 1023) and then jmps to `real_thunk`. It preserves %rsp (push/pop %rax
# is balanced) and every SysV argument register, clobbering only %r10/%r11 which the
# real boundary thunk reloads on entry. Returns the stub address, or 0 on failure.
def Linker_CreateHleRecorderPrefix(real_thunk: u64, sym_ptr: u64, target: u64) -> u64:
    static if PLATFORM_APPLE and ARCH_X86_64:
        stub: mutable u8[159] = zeroed
        # See Linker_CreateNativeHleBoundaryThunk: every bounds-checked immedate emit
        # ANDs into emit_ok; a refused store flips it false and we bail via the
        # existing `return 0` failure path before publishing, so a wrong offset can
        # never overrun `stub`. Success-path bytes are byte-identical to before.
        emit_ok: mutable bool = true
        idx_addr: u64 = (&linker_hle_call_ring_index).cast[void&].uintptr().u64()
        ring_addr: u64 = (&linker_hle_call_ring[0]).cast[void&].uintptr().u64()
        target_ring_addr: u64 = (&linker_hle_call_target_ring[0]).cast[void&].uintptr().u64()
        return_ring_addr: u64 = (&linker_hle_call_return_ring[0]).cast[void&].uintptr().u64()
        rdi_ring_addr: u64 = (&linker_hle_call_rdi_ring[0]).cast[void&].uintptr().u64()
        rsi_ring_addr: u64 = (&linker_hle_call_rsi_ring[0]).cast[void&].uintptr().u64()
        rdx_ring_addr: u64 = (&linker_hle_call_rdx_ring[0]).cast[void&].uintptr().u64()
        # push %rax
        stub[0] <- 0x50
        # movabs $&index, %r10 ; mov (%r10), %rax
        stub[1] <- 0x49
        stub[2] <- 0xBA
        emit_ok <- emit_ok and Linker_WriteU64LE((&stub[0]).cast[mutable u8&], 159, 3, idx_addr)
        stub[11] <- 0x49
        stub[12] <- 0x8B
        stub[13] <- 0x02
        # and $0x3ff, %rax
        stub[14] <- 0x48
        stub[15] <- 0x25
        stub[16] <- 0xFF
        stub[17] <- 0x03
        stub[18] <- 0x00
        stub[19] <- 0x00
        # movabs $&ring, %r11
        stub[20] <- 0x49
        stub[21] <- 0xBB
        emit_ok <- emit_ok and Linker_WriteU64LE((&stub[0]).cast[mutable u8&], 159, 22, ring_addr)
        # movabs $sym_ptr, %r10
        stub[30] <- 0x49
        stub[31] <- 0xBA
        emit_ok <- emit_ok and Linker_WriteU64LE((&stub[0]).cast[mutable u8&], 159, 32, sym_ptr)
        # mov %r10, (%r11,%rax,8)
        stub[40] <- 0x4D
        stub[41] <- 0x89
        stub[42] <- 0x14
        stub[43] <- 0xC3
        # movabs $&target_ring, %r11
        stub[44] <- 0x49
        stub[45] <- 0xBB
        emit_ok <- emit_ok and Linker_WriteU64LE((&stub[0]).cast[mutable u8&], 159, 46, target_ring_addr)
        # movabs $target, %r10
        stub[54] <- 0x49
        stub[55] <- 0xBA
        emit_ok <- emit_ok and Linker_WriteU64LE((&stub[0]).cast[mutable u8&], 159, 56, target)
        # mov %r10, (%r11,%rax,8)
        stub[64] <- 0x4D
        stub[65] <- 0x89
        stub[66] <- 0x14
        stub[67] <- 0xC3
        # movabs $&return_ring, %r11
        stub[68] <- 0x49
        stub[69] <- 0xBB
        emit_ok <- emit_ok and Linker_WriteU64LE((&stub[0]).cast[mutable u8&], 159, 70, return_ring_addr)
        # mov 8(%rsp), %r10 -- return PC below the saved %rax
        stub[78] <- 0x4C
        stub[79] <- 0x8B
        stub[80] <- 0x54
        stub[81] <- 0x24
        stub[82] <- 0x08
        # mov %r10, (%r11,%rax,8)
        stub[83] <- 0x4D
        stub[84] <- 0x89
        stub[85] <- 0x14
        stub[86] <- 0xC3
        # Store the first three SysV argument registers alongside the generic
        # call record. These are the fields the shadPS4 boot oracle compares at
        # each HLE boundary, and recording them in the prefix avoids patching
        # every individual HLE.
        # movabs $&rdi_ring, %r11 ; mov %rdi, (%r11,%rax,8)
        stub[87] <- 0x49
        stub[88] <- 0xBB
        emit_ok <- emit_ok and Linker_WriteU64LE((&stub[0]).cast[mutable u8&], 159, 89, rdi_ring_addr)
        stub[97] <- 0x49
        stub[98] <- 0x89
        stub[99] <- 0x3C
        stub[100] <- 0xC3
        # movabs $&rsi_ring, %r11 ; mov %rsi, (%r11,%rax,8)
        stub[101] <- 0x49
        stub[102] <- 0xBB
        emit_ok <- emit_ok and Linker_WriteU64LE((&stub[0]).cast[mutable u8&], 159, 103, rsi_ring_addr)
        stub[111] <- 0x49
        stub[112] <- 0x89
        stub[113] <- 0x34
        stub[114] <- 0xC3
        # movabs $&rdx_ring, %r11 ; mov %rdx, (%r11,%rax,8)
        stub[115] <- 0x49
        stub[116] <- 0xBB
        emit_ok <- emit_ok and Linker_WriteU64LE((&stub[0]).cast[mutable u8&], 159, 117, rdx_ring_addr)
        stub[125] <- 0x49
        stub[126] <- 0x89
        stub[127] <- 0x14
        stub[128] <- 0xC3
        # inc %rax
        stub[129] <- 0x48
        stub[130] <- 0xFF
        stub[131] <- 0xC0
        # movabs $&index, %r11 ; mov %rax, (%r11)
        stub[132] <- 0x49
        stub[133] <- 0xBB
        emit_ok <- emit_ok and Linker_WriteU64LE((&stub[0]).cast[mutable u8&], 159, 134, idx_addr)
        stub[142] <- 0x49
        stub[143] <- 0x89
        stub[144] <- 0x03
        # pop %rax
        stub[145] <- 0x58
        # movabs $real_thunk, %r11 ; jmp *%r11
        stub[146] <- 0x49
        stub[147] <- 0xBB
        emit_ok <- emit_ok and Linker_WriteU64LE((&stub[0]).cast[mutable u8&], 159, 148, real_thunk)
        stub[156] <- 0x41
        stub[157] <- 0xFF
        stub[158] <- 0xE3
        # Refuse to publish a stub whose immediate emits did not all land in range.
        if not emit_ok:
            return 0
        prefix: VAddr = GuestExec_AllocateRegion(4096, 5)
        if prefix == 0.uintptr():
            return 0
        can Unsafe.MachineCodeBuilder:
            if not GuestExec_WriteBytes(prefix, (&stub[0]).cast[void&], 159):
                return 0
        can Unsafe.ExecutableCodePublish:
            if not GuestExec_PublishExecutableCode(prefix, 159):
                return 0
        return prefix.u64()
    static else:
        return 0

# Accessors over the HLE call ring (oldest retained call .. newest). The dump
# helper lives in guest_exec.elisa where the text/output primitives are declared.
def Linker_HleCallRingTotal() -> u64:
    return linker_hle_call_ring_index

def Linker_HleCallRingCount() -> u64:
    total: u64 = linker_hle_call_ring_index
    return total if total < LINKER_HLE_CALL_RING_CAP.u64() else LINKER_HLE_CALL_RING_CAP.u64()

def Linker_HleCallRingSymbolAt(seq: u64) -> static u8&?:
    slot: usize = (seq & (LINKER_HLE_CALL_RING_CAP.u64() - 1)).usize()
    ptr: u64 = linker_hle_call_ring[slot]
    if ptr == 0:
        return null
    return ptr.uintptr().cast[void&].cast[static u8&]

def Linker_HleCallRingTargetAt(seq: u64) -> u64:
    slot: usize = (seq & (LINKER_HLE_CALL_RING_CAP.u64() - 1)).usize()
    return linker_hle_call_target_ring[slot]

def Linker_HleCallRingReturnAt(seq: u64) -> u64:
    slot: usize = (seq & (LINKER_HLE_CALL_RING_CAP.u64() - 1)).usize()
    return linker_hle_call_return_ring[slot]

def Linker_HleCallRingRdiAt(seq: u64) -> u64:
    slot: usize = (seq & (LINKER_HLE_CALL_RING_CAP.u64() - 1)).usize()
    return linker_hle_call_rdi_ring[slot]

def Linker_HleCallRingRsiAt(seq: u64) -> u64:
    slot: usize = (seq & (LINKER_HLE_CALL_RING_CAP.u64() - 1)).usize()
    return linker_hle_call_rsi_ring[slot]

def Linker_HleCallRingRdxAt(seq: u64) -> u64:
    slot: usize = (seq & (LINKER_HLE_CALL_RING_CAP.u64() - 1)).usize()
    return linker_hle_call_rdx_ring[slot]

def Linker_RelocateAnyImports(self: mutable Linker&, module: mutable Module&) -> void can[Memory.Allocate, Abort.Panic]:
    ge_emergency_mark(GE_EV_RELOC_MODULE_BEGIN, module.base_virtual_addr, module.import_symbols.count.uintptr(), module.dynamic_info.rela_table_total_size.uintptr(), module.dynamic_info.jmp_relocation_total_size.uintptr())
    for i in 0..<module.import_symbols.count:
        self.last_total_import_count <- self.last_total_import_count + 1
        resolved_addr: mutable u64 = 0
        resolved_kind: mutable u8 = IMPORT_RESOLUTION_UNRESOLVED
        import_symbol: ImportSymbolRecord = module.import_symbols[i]
        ge_emergency_mark(GE_EV_RELOC_MODULE_IMPORT_BEGIN, module.base_virtual_addr, i.uintptr(), import_symbol.nid.uintptr(), import_symbol.raw_symbol.uintptr())
        qualified_raw: mutable bool = false
        resolved: mutable bool = false
        can Memory.Allocate, Abort.Panic:
            qualified_raw <- Linker_IsQualifiedImportSymbol(import_symbol.raw_symbol)
            if qualified_raw:
                resolved <- Linker_Resolve((&self).cast[mutable Linker&], import_symbol.raw_symbol, module, import_symbol.symbol_type, resolved_addr, resolved_kind)
                if not resolved:
                    resolved <- Linker_Resolve((&self).cast[mutable Linker&], import_symbol.nid, module, import_symbol.symbol_type, resolved_addr, resolved_kind)
            else:
                resolved <- Linker_Resolve((&self).cast[mutable Linker&], import_symbol.nid, module, import_symbol.symbol_type, resolved_addr, resolved_kind)
                if not resolved:
                    resolved <- Linker_Resolve((&self).cast[mutable Linker&], import_symbol.raw_symbol, module, import_symbol.symbol_type, resolved_addr, resolved_kind)
        module.import_symbols[i].resolved <- resolved
        module.import_symbols[i].resolved_virtual_addr <- resolved_addr
        module.import_symbols[i].resolution_kind <- resolved_kind
        if resolved:
            self.last_relocated_import_count <- self.last_relocated_import_count + 1
            if resolved_kind == IMPORT_RESOLUTION_NATIVE_HLE:
                self.last_native_hle_resolved_count <- self.last_native_hle_resolved_count + 1
            elif resolved_kind == IMPORT_RESOLUTION_PRX_EXPORT:
                self.last_prx_export_resolved_count <- self.last_prx_export_resolved_count + 1
            elif resolved_kind == IMPORT_RESOLUTION_AEROLIB_FALLBACK:
                self.last_aerolib_fallback_resolved_count <- self.last_aerolib_fallback_resolved_count + 1
        else:
            if resolved_kind == IMPORT_RESOLUTION_MALFORMED:
                self.last_malformed_import_count <- self.last_malformed_import_count + 1
            else:
                self.last_unresolved_import_count <- self.last_unresolved_import_count + 1
        ge_emergency_mark(GE_EV_RELOC_MODULE_IMPORT_END, module.base_virtual_addr, i.uintptr(), resolved_addr.uintptr(), resolved_kind.u64().uintptr())
    ge_emergency_mark(GE_EV_RELOC_MODULE_IMPORTS_DONE, module.base_virtual_addr, module.import_symbols.count.uintptr(), self.last_relocated_import_count.u64().uintptr(), self.last_unresolved_import_count.u64().uintptr())
    can Memory.Allocate, Abort.Panic:
        Linker_ApplyModuleRelocations((&self).cast[mutable Linker&], (&module).cast[mutable Module&])
    ge_emergency_mark(GE_EV_RELOC_MODULE_END, module.base_virtual_addr, module.import_symbols.count.uintptr(), module.applied_relocation_count.uintptr(), module.patched_import_relocation_count.uintptr())

def Linker_ApplyRelocationEntry(self: mutable Linker&, module: mutable Module&, rel: elf_relocation) -> bool can[Memory.Allocate, Abort.Panic]:
    linker_last_relocation_retryable <- false
    rel_type: u32 = (rel.rel_info & 0xffffffff.u64()).u32()
    symbol_index: u32 = (rel.rel_info >> 32.u64()).u32()
    rel_virtual_addr: u64 = module.base_virtual_addr.u64() + rel.rel_offset
    memory: mutable MemoryManager& = Memory_Instance()
    if rel_type == R_X86_64_RELATIVE:
        value: u64 = module.base_virtual_addr.u64() + rel.rel_addend.u64()
        Linker_NoteRelocatedPointerValue(value, rel_virtual_addr, rel_type, null, module.name)
        can Memory.Allocate:
            catch Linker_WriteRelocationU64((&module).cast[mutable Module&], memory, rel_virtual_addr, value):
                n:
                    module.applied_relocation_count <- module.applied_relocation_count + 1
                    return true
                error e:
                    true
        Linker_RecordFailedRelocationDetail((&self).cast[mutable Linker&], 1, IMPORT_RESOLUTION_UNRESOLVED, value)
        return false
    if rel_type == R_X86_64_64 or rel_type == R_X86_64_GLOB_DAT or rel_type == R_X86_64_JUMP_SLOT:
        addend: mutable i64 = rel.rel_addend
        if rel_type == R_X86_64_GLOB_DAT or rel_type == R_X86_64_JUMP_SLOT:
            addend <- 0
        symbol: mutable elf_symbol = zeroed
        symbol_found: bool = Module_GetSymbolByIndex(module, symbol_index, symbol)
        if symbol_found:
            symbol_bind: u8 = ElfSymbol_GetBind(symbol)
            if symbol_bind == STB_LOCAL or ((symbol_bind == STB_GLOBAL or symbol_bind == STB_WEAK) and symbol.st_shndx != ELF_SHN_UNDEF and symbol.st_value != 0):
                value: u64 = module.base_virtual_addr.u64() + symbol.st_value + addend.u64()
                symbol_name_val: mutable static u8& = ""
                can Memory.Allocate, Abort.Panic:
                    symbol_name_val <- Module_GetSymbolNameByIndex((&module).cast[mutable Module&], symbol_index)
                Linker_NoteRelocatedPointerValue(value, rel_virtual_addr, rel_type, symbol_name_val, module.name)
                can Memory.Allocate:
                    catch Linker_WriteRelocationU64((&module).cast[mutable Module&], memory, rel_virtual_addr, value):
                        n:
                            module.applied_relocation_count <- module.applied_relocation_count + 1
                            return true
                        error e:
                            true
                Linker_RecordFailedRelocationDetail((&self).cast[mutable Linker&], 2, IMPORT_RESOLUTION_PRX_EXPORT, value)
                return false
        symbol_name: mutable static u8& = ""
        can Memory.Allocate, Abort.Panic:
            symbol_name <- Module_GetSymbolNameByIndex((&module).cast[mutable Module&], symbol_index)
        resolved_addr: mutable u64 = 0
        rel_kind: mutable u8 = IMPORT_RESOLUTION_UNRESOLVED
        expected_symbol_type: mutable u8 = IMPORT_SYMBOL_TYPE_UNKNOWN
        if rel_type == R_X86_64_JUMP_SLOT:
            expected_symbol_type <- IMPORT_SYMBOL_TYPE_FUNCTION
        resolved: mutable bool = false
        can Memory.Allocate, Abort.Panic:
            resolved <- Linker_Resolve((&self).cast[mutable Linker&], symbol_name, module, expected_symbol_type, resolved_addr, rel_kind)
        if not resolved:
            import_index: s32 = Module_FindImportByName(module, symbol_name)
            if import_index >= 0 and module.import_symbols[import_index.usize()].resolved:
                resolved_addr <- module.import_symbols[import_index.usize()].resolved_virtual_addr
                rel_kind <- module.import_symbols[import_index.usize()].resolution_kind
                resolved <- true
        if not resolved and (rel_type == R_X86_64_JUMP_SLOT or rel_type == R_X86_64_GLOB_DAT or rel_type == R_X86_64_64):
            # Unresolved slot relocation: patch with the native fallback stub to
            # prevent a NULL/garbage pointer being left in the slot. shadPS4
            # handles R_X86_64_64/GLOB_DAT/JUMP_SLOT uniformly -- Resolve() returns
            # a non-zero stub so all three are written (linker.cpp Relocate). We
            # previously left unresolved R_X86_64_64 slots unpatched (value 0),
            # producing failed relocations and stale image bytes the guest could
            # read/call. The native stub also records the guest call site so the
            # first boundary can be attributed to a specific unimplemented import.
            resolved_addr <- GuestExec_AeroLibFallbackStubAddress().u64()
            resolved <- true
            linker_last_relocation_retryable <- true
        Linker_MixResolution(symbol_index, resolved_addr == GuestExec_AeroLibFallbackStubAddress().u64(), rel_type, symbol_name)
        if resolved:
            # Record every slot that ends up holding the fallback stub, no matter
            # which resolution path produced it (Linker_Resolve's built-in final
            # fallback also returns the stub address), so the runtime fallback
            # boundary can be attributed back to this relocation's symbol.
            if resolved_addr == GuestExec_AeroLibFallbackStubAddress().u64():
                Linker_RecordFallbackSlot(rel_virtual_addr, symbol_name, symbol_index, rel_type, module.name)
                linker_last_relocation_retryable <- true
            if rel_kind == IMPORT_RESOLUTION_NATIVE_HLE:
                should_thunk_native_hle: bool = Linker_ShouldThunkNativeHleRelocation(rel_type, symbol_found, symbol)
                if should_thunk_native_hle:
                    linker_native_hle_function_relocation_count <- linker_native_hle_function_relocation_count + 1
                    if addend != 0:
                        linker_native_hle_function_addend_count <- linker_native_hle_function_addend_count + 1
                        abs_addend: u64 = addend.u64() if addend >= 0 else (0 - addend).u64()
                        if abs_addend > linker_native_hle_function_max_addend:
                            linker_native_hle_function_max_addend <- abs_addend
                    raw_native_hle_addr: u64 = resolved_addr
                    resolved_addr <- Linker_CreateNativeHleBoundaryThunk(resolved_addr, symbol_name)
                    if Linker_UseNativeHleBoundaryThunk() and raw_native_hle_addr != 0 and resolved_addr == raw_native_hle_addr:
                        if linker_native_hle_unthunked_function_count == 0:
                            linker_native_hle_unthunked_function_first_target <- raw_native_hle_addr
                        linker_native_hle_unthunked_function_count <- linker_native_hle_unthunked_function_count + 1
                else:
                    linker_native_hle_data_relocation_count <- linker_native_hle_data_relocation_count + 1
                    Linker_NoteNativeHleDataRelocationValue(resolved_addr, symbol_name)
            value: u64 = resolved_addr + addend.u64()
            Linker_NoteRelocatedPointerValue(value, rel_virtual_addr, rel_type, symbol_name, module.name)
            can Memory.Allocate:
                catch Linker_WriteRelocationU64((&module).cast[mutable Module&], memory, rel_virtual_addr, value):
                    n:
                        module.applied_relocation_count <- module.applied_relocation_count + 1
                        module.patched_import_relocation_count <- module.patched_import_relocation_count + 1
                        return true
                    error e:
                        true
            Linker_RecordFailedRelocationDetail((&self).cast[mutable Linker&], 4, rel_kind, value)
            return false
        Linker_RecordFailedRelocationDetail((&self).cast[mutable Linker&], 3, rel_kind, resolved_addr)
        return false
    if rel_type == R_X86_64_DTPMOD64:
        can Memory.Allocate:
            catch Linker_WriteRelocationU64((&module).cast[mutable Module&], memory, rel_virtual_addr, module.tls.modid.u64()):
                n:
                    module.applied_relocation_count <- module.applied_relocation_count + 1
                    return true
                error e:
                    true
        Linker_RecordFailedRelocationDetail((&self).cast[mutable Linker&], 5, IMPORT_RESOLUTION_UNRESOLVED, module.tls.modid.u64())
    return false

def Linker_ApplyRelocationTable(self: mutable Linker&, module: mutable Module&, table_offset: u64, table_size: u64, entry_size: u64, bit_base_index: usize) -> void can[Memory.Allocate, Abort.Panic]:
    if table_offset == 0 or table_size == 0 or entry_size == 0:
        return
    count: usize = (table_size / entry_size).usize()
    if count != 0:
        can Memory.Allocate:
            Linker_EnsureModuleRelocationBit((&module).cast[mutable Module&], bit_base_index + count - 1)
    ge_emergency_mark(GE_EV_RELOC_TABLE_BEGIN, module.base_virtual_addr, table_offset.uintptr(), count.uintptr(), entry_size.uintptr())
    memory: mutable MemoryManager& = Memory_Instance()
    cached_relative_backing_index: mutable s32 = -1
    for i in 0..<count:
        offset: u64 = table_offset + (i.u64() * entry_size)
        bit_index: usize = bit_base_index + i
        if Linker_ModuleRelocationBit(module, bit_index):
            continue
        record_entry: bool = (i.u64() & 0xfff) == 0
        if record_entry:
            ge_emergency_mark(GE_EV_RELOC_TABLE_ENTRY_BEGIN, module.base_virtual_addr, i.uintptr(), offset.uintptr(), count.uintptr())
        if offset + size_of(elf_relocation).u64() <= module.dynamic_data.count.u64():
            rel: elf_relocation = Module_ReadRelocationAt(module, offset.usize())
            rel_type_for_fast_path: u32 = (rel.rel_info & 0xffffffff.u64()).u32()
            applied: mutable bool = false
            if rel_type_for_fast_path == R_X86_64_RELATIVE and linker_defer_native_relocation_writes:
                rel_virtual_addr: u64 = module.base_virtual_addr.u64() + rel.rel_offset
                value: u64 = module.base_virtual_addr.u64() + rel.rel_addend.u64()
                if Linker_WriteRelativeRelocationFast((&module).cast[mutable Module&], memory, rel_virtual_addr, value, cached_relative_backing_index):
                    module.applied_relocation_count <- module.applied_relocation_count + 1
                    applied <- true
                    linker_last_relocation_retryable <- false
            else:
                can Memory.Allocate, Abort.Panic:
                    applied <- Linker_ApplyRelocationEntry((&self).cast[mutable Linker&], (&module).cast[mutable Module&], rel)
            if applied and not linker_last_relocation_retryable:
                can Memory.Allocate:
                    Linker_SetModuleRelocationBit((&module).cast[mutable Module&], bit_index)
            if record_entry or not applied:
                ge_emergency_mark(GE_EV_RELOC_TABLE_ENTRY_END, module.base_virtual_addr, i.uintptr(), (rel.rel_info & 0xffffffff.u64()).uintptr(), rel.rel_offset.uintptr())
            if not applied:
                rel_type: u32 = (rel.rel_info & 0xffffffff.u64()).u32()
                self.last_failed_relocation_count <- self.last_failed_relocation_count + 1
                Linker_RecordFailedRelocationType((&self).cast[mutable Linker&], rel_type)
                self.last_failed_relocation_type <- rel_type
                self.last_failed_relocation_symbol <- (rel.rel_info >> 32.u64()).u32()
                self.last_failed_relocation_offset <- rel.rel_offset
                self.last_failed_relocation_module <- module.name
                can Memory.Allocate, Abort.Panic:
                    self.last_failed_relocation_name <- Module_GetSymbolNameByIndex((&module).cast[mutable Module&], self.last_failed_relocation_symbol)
        else:
            ge_emergency_mark(GE_EV_RELOC_TABLE_ENTRY_END, module.base_virtual_addr, i.uintptr(), 0xffffffff.u64().uintptr(), offset.uintptr())
    ge_emergency_mark(GE_EV_RELOC_TABLE_END, module.base_virtual_addr, table_offset.uintptr(), count.uintptr(), module.applied_relocation_count.uintptr())

def Linker_ApplyModuleRelocations(self: mutable Linker&, module: mutable Module&) -> void can[Memory.Allocate, Abort.Panic]:
    entry_size: u64 = Module_GetRelaEntrySize(module)
    rela_count: usize = Module_GetRelaRelocationCount(module)
    can Memory.Allocate, Abort.Panic:
        MemoryManager_BeginBulkWriteWindow()
        Linker_ApplyRelocationTable((&self).cast[mutable Linker&], (&module).cast[mutable Module&], module.dynamic_info.rela_table_offset, module.dynamic_info.rela_table_total_size, entry_size, 0)
        Linker_ApplyRelocationTable((&self).cast[mutable Linker&], (&module).cast[mutable Module&], module.dynamic_info.jmp_relocation_offset, module.dynamic_info.jmp_relocation_total_size, entry_size, rela_count)
        MemoryManager_EndBulkWriteWindow(Memory_Instance())

def Linker_RelocateAllImports(self: mutable Linker&) -> void can[Memory.Allocate, Abort.Panic]:
    self.last_total_import_count <- 0
    self.last_relocated_import_count <- 0
    self.last_unresolved_import_count <- 0
    self.last_native_hle_resolved_count <- 0
    self.last_prx_export_resolved_count <- 0
    self.last_aerolib_fallback_resolved_count <- 0
    self.last_malformed_import_count <- 0
    self.last_failed_relocation_count <- 0
    self.last_failed_relocation_type <- 0
    self.last_failed_relocation_symbol <- 0
    self.last_failed_relocation_offset <- 0
    self.last_failed_relocation_module <- null
    self.last_failed_relocation_name <- null
    self.last_failed_relocation_stage <- 0
    self.last_failed_relocation_kind <- IMPORT_RESOLUTION_UNRESOLVED
    self.last_failed_relocation_value <- 0
    self.failed_relocation_type1_count <- 0
    self.failed_relocation_glob_dat_count <- 0
    self.failed_relocation_jump_slot_count <- 0
    self.failed_relocation_relative_count <- 0
    self.failed_relocation_dtpmod64_count <- 0
    self.failed_relocation_other_count <- 0
    linker_native_hle_thunk_count <- 0
    linker_native_hle_function_relocation_count <- 0
    linker_native_hle_data_relocation_count <- 0
    linker_native_hle_unthunked_function_count <- 0
    linker_native_hle_unthunked_function_first_target <- 0
    linker_native_hle_function_addend_count <- 0
    linker_native_hle_function_max_addend <- 0
    linker_native_hle_data_thunk_pointer_count <- 0
    linker_native_hle_data_thunk_pointer_first_value <- 0
    linker_native_hle_data_thunk_pointer_first_name <- null
    linker_tiny_pointer_slot_count <- 0
    linker_tiny_pointer_first_value <- 0
    linker_tiny_pointer_first_offset <- 0
    linker_tiny_pointer_first_type <- 0
    linker_tiny_pointer_first_name <- null
    linker_tiny_pointer_first_module <- null
    Linker_ResetFallbackSlots()
    Linker_ResetResolutionFingerprint()
    can Memory.Allocate, Abort.Panic:
        MemoryManager_BeginBulkWriteWindow()
        for i in 0..<self.modules.count:
            Linker_RelocateAnyImports((&self).cast[mutable Linker&], self.modules[i])
        MemoryManager_EndBulkWriteWindow(Memory_Instance())
    self.relocated_all_imports <- true

def Linker_RecountImportResolution(self: mutable Linker&) -> void:
    self.last_total_import_count <- 0
    self.last_relocated_import_count <- 0
    self.last_unresolved_import_count <- 0
    self.last_native_hle_resolved_count <- 0
    self.last_prx_export_resolved_count <- 0
    self.last_aerolib_fallback_resolved_count <- 0
    self.last_malformed_import_count <- 0
    for module_index in 0..<self.modules.count:
        module_ref: mutable Module& = &self.modules[module_index]
        for import_index in 0..<module_ref.import_symbols.count:
            import_ref: mutable ImportSymbolRecord& = &module_ref.import_symbols[import_index]
            self.last_total_import_count <- self.last_total_import_count + 1
            if import_ref.resolved:
                self.last_relocated_import_count <- self.last_relocated_import_count + 1
                if import_ref.resolution_kind == IMPORT_RESOLUTION_NATIVE_HLE:
                    self.last_native_hle_resolved_count <- self.last_native_hle_resolved_count + 1
                elif import_ref.resolution_kind == IMPORT_RESOLUTION_PRX_EXPORT:
                    self.last_prx_export_resolved_count <- self.last_prx_export_resolved_count + 1
                elif import_ref.resolution_kind == IMPORT_RESOLUTION_AEROLIB_FALLBACK:
                    self.last_aerolib_fallback_resolved_count <- self.last_aerolib_fallback_resolved_count + 1
            else:
                if import_ref.resolution_kind == IMPORT_RESOLUTION_MALFORMED:
                    self.last_malformed_import_count <- self.last_malformed_import_count + 1
                else:
                    self.last_unresolved_import_count <- self.last_unresolved_import_count + 1

def Linker_AdvanceGenerationCounter(self: mutable Linker&) -> void:
    self.dtv_generation_counter <- self.dtv_generation_counter + 1

def Linker_TlsGetAddr(self: Linker&, module_index: u64, offset: u64) -> GuestVAddr[void]:
    GuestExec_RecordFirstBoundary(GUEST_EXEC_BOUNDARY_REASON_NATIVE_HLE)
    linker_tls_get_addr_calls <- linker_tls_get_addr_calls + 1
    linker_tls_last_module_index <- module_index
    linker_tls_last_offset <- offset
    linker_tls_last_dtv_base <- 0.uintptr()
    linker_tls_last_block_pointer <- 0.uintptr()
    ge_debug_trace_boundary("tls-get-addr-input", module_index.uintptr(), offset.uintptr(), 0.uintptr())
    if module_index == 0:
        # A TLS access with module id 0 means its DTPMOD64 relocation never
        # landed (the GOT pair still holds its link-time 0). shadPS4 always has
        # module_index >= 1. Returning the bare offset here hands the guest a
        # near-NULL bogus pointer (e.g. offset 0x1f4) -- the exact 0x1f4-class
        # bug. Surface it and return NULL so downstream null-checks catch it
        # instead of letting a tiny pointer flow into a mutex/TLS slot.
        linker_tls_module0_calls <- linker_tls_module0_calls + 1
        linker_tls_last_result <- 0.uintptr()
        ge_debug_trace_boundary("tls-get-addr-module0", module_index.uintptr(), offset.uintptr(), 0.uintptr())
        return 0.uintptr().cast[GuestVAddr[void]]
    # Faithful path (shadPS4 Linker::TlsGetAddr): the per-thread TLS block lives
    # in the DTV, NOT in the module's shared static init image. Read
    # tcb_dtv[module_index + 1].pointer + offset.
    tcb: mutable Tcb& = GetTcbBase()
    dtv_base: uintptr = !tcb.tcb_dtv
    linker_tls_last_dtv_base <- dtv_base
    if dtv_base != 0.uintptr():
        can Unsafe.PointerCast:
            dtv: mutable DtvEntry& = dtv_base.cast[mutable DtvEntry&]
            num_dtvs: usize = dtv[1].counter
            if module_index + 1 < (num_dtvs.u64() + 2):
                block: uintptr = !dtv[(module_index + 1).usize()].pointer
                linker_tls_last_block_pointer <- block
                if block != 0.uintptr():
                    result: uintptr = block + offset.uintptr()
                    linker_tls_last_result <- result
                    ge_debug_trace_boundary("tls-get-addr-dtv-result", result, block, offset.uintptr())
                    return result.cast[GuestVAddr[void]]
    else:
        linker_tls_null_dtv_calls <- linker_tls_null_dtv_calls + 1
    # Fallback (no installed DTV, e.g. dormant on the arm64 host): module-relative.
    module_slot: u64 = module_index - 1
    if module_slot >= self.modules.count.u64():
        linker_tls_last_result <- offset.uintptr()
        ge_debug_trace_boundary("tls-get-addr-module-miss", offset.uintptr(), module_index.uintptr(), self.modules.count.uintptr())
        return offset.uintptr().cast[GuestVAddr[void]]
    module: Module = self.modules[module_slot.usize()]
    fallback_res: mutable uintptr = module.base_virtual_addr + offset.uintptr()
    if module.tls.image_virtual_addr != 0.uintptr():
        fallback_res <- module.tls.image_virtual_addr + offset.uintptr()
    linker_tls_last_result <- fallback_res
    ge_debug_trace_boundary("tls-get-addr-fallback-result", fallback_res, module.base_virtual_addr, offset.uintptr())
    return fallback_res.cast[GuestVAddr[void]]

def Linker_AllocateTlsForThread(self: mutable Linker&, is_primary: bool) -> uintptr:
    # NOTE (C++ deviation, deliberate): shadPS4 maps the PRIMARY thread's TLS+TCB
    # from flexible (guest) memory (linker.cpp AllocateTlsForThread). We cannot:
    # in our architecture guest VAs are not directly host-writable (native
    # backing is synced separately), but the TCB/DTV build below writes to the
    # block as a host pointer. So we host-malloc the block; the %fs:0 -> LdtPage
    # .tcb indirection already lets the TCB live at any (even >4GB) host address.
    _ = is_primary
    # L1: static_tls_size is a u32, so widening to u64 yields a value <= 2^32-1 and
    # +0x20 cannot wrap; make the bound explicit so the AlignUp precondition holds.
    tls_size_u64: mutable u64 = self.static_tls_size.u64()
    if tls_size_u64 > 0xFFFFFFFFFFFFFFFF - 0x20:
        tls_size_u64 <- 0xFFFFFFFFFFFFFFFF - 0x20
    tls_aligned_size: usize = Module_AlignUp(tls_size_u64, 0x20).usize()
    total_tls_size: usize = tls_aligned_size + 0x40
    raw: mutable heap void&? = malloc(total_tls_size)
    if raw == null:
        InitializeTLS()
        fallback: mutable Tcb& = GetTcbBase()
        fallback_addr: uintptr = (&fallback).cast[mutable Tcb&].cast[uintptr]
        linker_tls_primary_base <- fallback_addr
        linker_tls_primary_size <- 0x40
        linker_tls_primary_tcb <- fallback_addr
        linker_tls_primary_dtv_base <- 0.uintptr()
        linker_tls_primary_dtv_size <- 0
        if !fallback.tcb_self == 0.uintptr():
            fallback.tcb_self <- (&fallback).cast[mutable Tcb&].cast[uintptr].cast[SegmentSelfPointer]
        if !fallback.tcb_thread == 0.uintptr():
            fallback.tcb_thread <- Linker_CurrentThreadObject().cast[GuestThreadObjectPointer]
        TLS_SetPrimaryTcbBase((&fallback).cast[mutable Tcb&].cast[uintptr].cast[SegmentSelfPointer])
        return (&fallback).cast[mutable Tcb&].cast[uintptr]
    base: uintptr = raw.cast[uintptr]
    can Unsafe.PointerCast:
        bytes: mutable u8& = raw.cast[mutable u8&]
        i: mutable usize = 0
        while i < total_tls_size:
            bytes[i] <- 0
            i <- i + 1
        dtv_count: usize = self.max_tls_index.usize() + 2
        dtv_raw: mutable heap void&? = malloc(dtv_count * size_of(DtvEntry))
        if dtv_raw == null:
            return 0.uintptr()
        linker_tls_primary_base <- base
        linker_tls_primary_size <- total_tls_size.u64()
        linker_tls_primary_dtv_base <- dtv_raw.cast[uintptr]
        linker_tls_primary_dtv_size <- (dtv_count * size_of(DtvEntry)).u64()
        dtv_bytes: mutable u8& = dtv_raw.cast[mutable u8&]
        d: mutable usize = 0
        while d < dtv_count * size_of(DtvEntry):
            dtv_bytes[d] <- 0
            d <- d + 1
        tcb_addr: uintptr = base + tls_aligned_size.uintptr()
        linker_tls_primary_tcb <- tcb_addr
        tcb: mutable Tcb& = tcb_addr.cast[mutable Tcb&]
        dtv: mutable DtvEntry& = dtv_raw.cast[mutable DtvEntry&]
        tcb.tcb_self <- tcb_addr.cast[SegmentSelfPointer]
        tcb.tcb_dtv <- dtv_raw.cast[uintptr].cast[GuestDtvPointer]
        tcb.tcb_thread <- Linker_CurrentThreadObject().cast[GuestThreadObjectPointer]
        tcb.tcb_fiber <- 0.uintptr().cast[GuestFiberPointer]
        dtv[0].counter <- self.dtv_generation_counter.usize()
        dtv[1].counter <- self.max_tls_index.usize()
        if self.modules.count > 0:
            module: Module = self.modules[0]
            if module.tls.image_size != 0 and module.tls.modid.u64() + 1 < dtv_count.u64():
                dest_addr: uintptr = base + (tls_aligned_size - module.tls.offset.usize()).uintptr()
                src_addr: uintptr = module.tls.image_virtual_addr
                if src_addr != 0.uintptr():
                    src: u8& = src_addr.cast[u8&]
                    dest: mutable u8& = dest_addr.cast[mutable u8&]
                    c: mutable usize = 0
                    while c < module.tls.init_image_size.usize():
                        dest[c] <- src[c]
                        c <- c + 1
                dtv[module.tls.modid.usize() + 1].pointer <- dest_addr.cast[GuestTlsBlockPointer]
        TLS_SetPrimaryTcbBase(tcb_addr.cast[SegmentSelfPointer])
        TLS_RegisterPrimaryTemplate(base.cast[GuestTlsTemplatePointer], total_tls_size, dtv_raw.cast[uintptr].cast[GuestDtvPointer], dtv_count)
        return tcb_addr

def Linker_FreeTlsForNonPrimaryThread(self: mutable Linker&, pointer: void&?) -> void:
    _ = self
    _ = pointer

def Linker_LoadModule(self: mutable Linker&, elf_name: static u8&, is_dynamic: bool) -> s32 can[Memory.Allocate, Abort.Panic]:
    can Memory.Allocate, Abort.Panic:
        return Linker_LoadModuleFromHost((&self).cast[mutable Linker&], elf_name, elf_name, is_dynamic)

def Linker_NextModuleBase(self: Linker&) -> VAddr:
    base: mutable u64 = MODULE_LOAD_BASE
    i: mutable usize = 0
    while i < self.modules.count:
        # L2: the running module_end accumulation can itself overflow u64; skip any
        # module whose end would wrap so the AlignUp argument stays bounded.
        m_base: u64 = self.modules[i].base_virtual_addr.u64()
        m_size: u64 = self.modules[i].aligned_base_size
        if Module_U64AddNoOverflow(m_base, m_size) and Module_U64AddNoOverflow(m_base + m_size, MODULE_TRAMPOLINE_SIZE):
            module_end: u64 = m_base + m_size + MODULE_TRAMPOLINE_SIZE
            if module_end > base:
                base <- module_end
        i <- i + 1
    # The AlignUp argument (base) must leave room for MODULE_BLOCK_ALIGN; bases are
    # well below u64-max in practice, but cap defensively so the round-up is sound.
    if base > 0xFFFFFFFFFFFFFFFF - MODULE_BLOCK_ALIGN:
        base <- 0xFFFFFFFFFFFFFFFF - MODULE_BLOCK_ALIGN
    return Module_AlignUp(base, MODULE_BLOCK_ALIGN).uintptr()

def Linker_LoadModuleFromHost(self: mutable Linker&, guest_name: static u8&, host_name: static u8&, is_dynamic: bool) -> s32 can[Memory.Allocate, Abort.Panic]:
    base: mutable VAddr = Linker_NextModuleBase(self)
    module_name: static u8& = guest_name
    module: Module = Module_New(guest_name, module_name, base, is_dynamic)
    Module_SetHostFile((&module).cast[mutable Module&], host_name)
    memory: mutable MemoryManager& = Memory_Instance()
    can Memory.Allocate, Abort.Panic:
        # The module's growable image/dynamic segments outlive the load → program-lifetime `perm`.
        # This single `in perm:` at the origin threads through the whole load chain (region inference),
        # replacing the per-hop `in perm:` scopes the loader used to scatter through module.elisa.
        in perm:
            Module_LoadModuleToMemory((&module).cast[mutable Module&], memory, self.max_tls_index)
    if not module.is_valid:
        return -1
    if not is_dynamic:
        self.num_static_modules <- self.num_static_modules + 1
    # The module table is persistent linker state; allocate its backing from the
    # persistent metadata arena rather than a transient local arena.
    in perm:
        self.modules.push(module)
    return (self.modules.count - 1).s32()

def Linker_LoadAndStartModule(self: mutable Linker&, path: static u8&, args: u64, argp: void&?, p_res: mutable int&?) -> s32 can[Unsafe.SegmentMutation, Unsafe.GuestSegmentInstall, Segment.Guest, Segment.Host, Memory.Allocate, Abort.Panic]:
    existing: u32 = Linker_FindByFileOrHost((&self).cast[Linker&], path)
    if existing != 0xFFFFFFFF.u32():
        self.last_started_module_index <- existing.s32()
        self.last_start_result <- 0
        mod_existing: mutable Module&? = Linker_GetModule((&self).cast[mutable Linker&], existing.s32())
        if mod_existing != null:
            self.last_entry_addr <- Module_GetEntryAddress(mod_existing, 0.uintptr())
        if p_res != null:
            p_res <- 0
        return existing.s32()
    idx: mutable s32 = 0
    can Memory.Allocate, Abort.Panic:
        idx <- Linker_LoadModule((&self).cast[mutable Linker&], path, true)
    if idx < 0:
        if p_res != null:
            p_res <- idx
        return idx
    mod_ref: mutable Module&? = Linker_GetModule((&self).cast[mutable Linker&], idx)
    if mod_ref == null:
        if p_res != null:
            p_res <- -1
        self.last_started_module_index <- -1
        self.last_start_result <- -1
        self.last_entry_addr <- 0.uintptr()
        return -1
    can Memory.Allocate, Abort.Panic:
        Linker_RelocateAnyImports((&self).cast[mutable Linker&], mod_ref)
    if mod_ref.tls.image_size != 0:
        Linker_AdvanceGenerationCounter((&self).cast[mutable Linker&])
    self.last_entry_addr <- Module_GetEntryAddress(mod_ref, 0.uintptr())
    start_result: mutable s32 = 0
    can Unsafe.SegmentMutation, Unsafe.GuestSegmentInstall, Segment.Guest, Segment.Host, Memory.Allocate:
        start_result <- Module_Start(mod_ref, args, argp, Module_GetProcParam(mod_ref).cast[void&?])
    # Starting a PRX can make new exports available to modules loaded earlier,
    # but walking every module's relocation table here repeatedly re-scans the
    # eboot's 400k+ RELA entries during dependency startup. The final
    # Linker_Execute relocation pass still retries process-wide imports before
    # main enters guest code; keep this per-module path scoped to the module we
    # just loaded.
    self.relocated_all_imports <- false
    self.last_started_module_index <- idx
    self.last_start_result <- start_result
    Linker_RecountImportResolution((&self).cast[mutable Linker&])
    if p_res != null:
        p_res <- start_result
    return idx

def Linker_LoadAndStartGuestModule(self: mutable Linker&, guest_path: static u8&, args: u64, argp: void&?, p_res: mutable int&?) -> s32 can[Unsafe.SegmentMutation, Unsafe.GuestSegmentInstall, Segment.Guest, Segment.Host, Memory.Allocate, Abort.Panic]:
    host_path: mutable static u8& = ""
    can Memory.Allocate, Abort.Panic:
        host_path <- Linker_ResolveGuestModulePath((&self).cast[Linker&], guest_path)
    if static_strlen(host_path) == 0:
        return -1
    self.last_loaded_dynamic_host_path <- host_path
    existing: mutable u32 = Linker_FindByFileOrHost((&self).cast[Linker&], guest_path)
    if existing == 0xFFFFFFFF.u32():
        existing <- Linker_FindByFileOrHost((&self).cast[Linker&], host_path)
    if existing != 0xFFFFFFFF.u32():
        self.last_started_module_index <- existing.s32()
        self.last_start_result <- 0
        mod_existing: mutable Module&? = Linker_GetModule((&self).cast[mutable Linker&], existing.s32())
        if mod_existing != null:
            self.last_entry_addr <- Module_GetEntryAddress(mod_existing, 0.uintptr())
        if p_res != null:
            p_res <- 0
        return existing.s32()
    idx: mutable s32 = 0
    can Memory.Allocate, Abort.Panic:
        idx <- Linker_LoadModuleFromHost((&self).cast[mutable Linker&], guest_path, host_path, true)
    if idx < 0:
        if p_res != null:
            p_res <- idx
        return idx
    mod_ref: mutable Module&? = Linker_GetModule((&self).cast[mutable Linker&], idx)
    if mod_ref == null:
        if p_res != null:
            p_res <- -1
        self.last_started_module_index <- -1
        self.last_start_result <- -1
        self.last_entry_addr <- 0.uintptr()
        return -1
    can Memory.Allocate, Abort.Panic:
        Linker_RelocateAnyImports((&self).cast[mutable Linker&], mod_ref)
    if mod_ref.tls.image_size != 0:
        Linker_AdvanceGenerationCounter((&self).cast[mutable Linker&])
    self.last_entry_addr <- Module_GetEntryAddress(mod_ref, 0.uintptr())
    start_result: mutable s32 = 0
    can Unsafe.SegmentMutation, Unsafe.GuestSegmentInstall, Segment.Guest, Segment.Host, Memory.Allocate:
        start_result <- Module_Start(mod_ref, args, argp, Module_GetProcParam(mod_ref).cast[void&?])
    # Defer process-wide retry relocation until the final Execute pass. Doing
    # it after every dynamic module start preserves correctness poorly for the
    # current two-layer runtime because it repeatedly scans the main eboot RELA
    # table, while the new module itself was already relocated before start.
    self.relocated_all_imports <- false
    self.last_started_module_index <- idx
    self.last_start_result <- start_result
    Linker_RecountImportResolution((&self).cast[mutable Linker&])
    if p_res != null:
        p_res <- start_result
    return idx

def Linker_FindByAddress(self: mutable Linker&, address: VAddr) -> mutable Module&?:
    for i in 0..<self.modules.count:
        mod: Module = self.modules[i]
        if mod.base_virtual_addr <= address and address < mod.base_virtual_addr + mod.aligned_base_size.uintptr():
            return &self.modules[i]
    return null

def Linker_Relocate(self: mutable Linker&, module: mutable Module&) -> void:
    can Memory.Allocate, Abort.Panic:
        Linker_RelocateAnyImports((&self).cast[mutable Linker&], (&module).cast[mutable Module&])

def Linker_Resolve(self: mutable Linker&, name: static u8&, module: mutable Module&, expected_symbol_type: u8, out_virtual_address: mutable u64&, out_resolution_kind: mutable u8&) -> bool can[Memory.Allocate, Abort.Panic]:
    out_virtual_address <- 0
    out_resolution_kind <- IMPORT_RESOLUTION_UNRESOLVED
    GuestExec_RecordLastModuleSymbol(module.name, name)
    if static_strlen(name) == 0:
        out_resolution_kind <- IMPORT_RESOLUTION_MALFORMED
        return false
    if streq(name, "module_start") == 1 or streq(name, "module_stop") == 1 or streq(name, "compilerrt_abort_impl") == 1 or Linker_StringHasPrefix(name, "Need_"):
        out_virtual_address <- Linker_RuntimeLifecycleNoop.uintptr().u64()
        out_resolution_kind <- IMPORT_RESOLUTION_NATIVE_HLE
        GuestExec_RecordLastHle(module.name, name)
        return true
    parsed_nid: mutable static u8& = ""
    parsed_library_id: mutable static u8& = ""
    parsed_module_id: mutable static u8& = ""
    parsed: mutable bool = false
    can Memory.Allocate, Abort.Panic:
        parsed <- Module_ParseImportSymbol(name, (&parsed_nid).cast[mutable static u8&], (&parsed_library_id).cast[mutable static u8&], (&parsed_module_id).cast[mutable static u8&])
    symbol_type: mutable u8 = expected_symbol_type
    lookup_nid: mutable static u8& = name
    if parsed:
        lookup_nid <- parsed_nid
    if parsed and static_strlen(parsed_library_id) > 0 and static_strlen(parsed_module_id) > 0:
        library_index: s32 = Module_FindImportLibraryIndex(module, parsed_library_id)
        module_index: s32 = Module_FindImportModuleIndex(module, parsed_module_id)
        if library_index >= 0 and module_index >= 0:
            library_value: LibraryInfo = Module_LibraryByCombinedIndex(module, library_index)
            module_value: ModuleInfo = Module_InfoByCombinedIndex(module, module_index)
            for import_index in 0..<module.import_symbols.count:
                imp: ImportSymbolRecord = module.import_symbols[import_index]
                if streq(imp.raw_symbol, name) == 1 or (streq(imp.nid, parsed_nid) == 1 and streq(imp.library, parsed_library_id) == 1 and streq(imp.module, parsed_module_id) == 1):
                    symbol_type <- imp.symbol_type
            found_index: s32 = SymbolsResolver_FindHleSymbol(self.hle_symbols, parsed_nid, library_value.name, Module_DynamicLibraryVersion(library_value.value), module_value.name, symbol_type)
            if found_index >= 0:
                sym: SymbolRecord = self.hle_symbols.symbols[found_index.usize()]
                out_virtual_address <- sym.callable_address
                out_resolution_kind <- IMPORT_RESOLUTION_NATIVE_HLE
                GuestExec_RecordLastHle(module.name, sym.name)
                return true
            can Memory.Allocate, Abort.Panic:
                for candidate_index in 0..<self.modules.count:
                    if Module_FindDefinedQualifiedSymbolAddress(self.modules[candidate_index], parsed_nid, library_value.name, Module_DynamicLibraryVersion(library_value.value), module_value.name, symbol_type, out_virtual_address):
                        out_resolution_kind <- IMPORT_RESOLUTION_PRX_EXPORT
                        return true
    can Memory.Allocate, Abort.Panic:
        for mutable module_value in self.modules:
            if Module_FindDefinedSymbolAddress(module_value, lookup_nid, out_virtual_address):
                out_resolution_kind <- IMPORT_RESOLUTION_PRX_EXPORT
                return true
    fallback_index: s32 = SymbolsResolver_FindHleSymbolByNidOnlyTyped(self.hle_symbols, lookup_nid, symbol_type)
    if fallback_index >= 0:
        sym: SymbolRecord = self.hle_symbols.symbols[fallback_index.usize()]
        out_virtual_address <- sym.callable_address
        out_resolution_kind <- IMPORT_RESOLUTION_NATIVE_HLE
        GuestExec_RecordLastHle(module.name, sym.name)
        return true
    # lookup_nid and name are raw C-strings; `!=` compared pointers, not content
    # (re-running the name lookup whenever parsed_nid had a distinct address even
    # if equal in content). Compare by content via streq (==1 means equal).
    if streq(lookup_nid, name) != 1:
        can Memory.Allocate, Abort.Panic:
            for mutable module_value in self.modules:
                if Module_FindDefinedSymbolAddress(module_value, name, out_virtual_address):
                    out_resolution_kind <- IMPORT_RESOLUTION_PRX_EXPORT
                    return true
    out_virtual_address <- GuestExec_AeroLibFallbackStubAddress().u64()
    out_resolution_kind <- IMPORT_RESOLUTION_AEROLIB_FALLBACK
    return true

def Linker_Execute(self: mutable Linker&, args: darray[static u8&]) -> s32 can[Unsafe.SegmentMutation, Unsafe.GuestSegmentInstall, Segment.Guest, Segment.Host, Memory.Allocate, Abort.Panic]:
    self.last_execute_argc <- args.count
    if self.modules.count == 0:
        self.last_started_module_index <- -1
        self.last_start_result <- -1
        self.last_entry_addr <- 0.uintptr()
        return -1
    self.static_tls_size <- self.modules[0].tls.image_size.usize()
    self.modules[0].tls.offset <- self.modules[0].tls.image_size
    memory: mutable MemoryManager& = Memory_Instance()
    flexible_size: mutable u64 = 0
    use_extended_mem1: mutable bool = false
    use_extended_mem2: mutable bool = false
    can Memory.Allocate:
        flexible_size <- Linker_GetFlexibleMemorySize(self)
        use_extended_mem1 <- Linker_GetUseExtendedMemory1(self)
        use_extended_mem2 <- Linker_GetUseExtendedMemory2(self)
    ge_emergency_mark(GE_EV_EXEC_MEMORY_SETUP_BEGIN, self.modules.count.uintptr(), self.static_tls_size.uintptr(), flexible_size.uintptr(), (1 if use_extended_mem2 else 0).uintptr())
    MemoryManager_SetupMemoryRegions(memory, flexible_size, use_extended_mem1, use_extended_mem2)
    ge_emergency_mark(GE_EV_EXEC_MEMORY_SETUP_END, self.modules.count.uintptr(), self.static_tls_size.uintptr(), flexible_size.uintptr(), MemoryManager_GetTotalDirectSize(memory).uintptr())
    Linker_EnsureMainGuestStack(memory)
    # Defer dependency module inits until after the native backing is synced
    # (below), so their PREINIT/init runs against a fully relocated + synced GOT and
    # the libc heap bootstrap (GetProcParam / RtldSetApplicationHeapAPI / DirectMemory)
    # dispatches before the eboot entry. Opt-in while the guarded-context host-struct
    # corruption (see docs) is resolved; default keeps the original preload-start.
    if getenv("ELISA_RESTORE_HOST_GS".cast[u8&]) != null:
        linker_restore_host_gs <- true
    if getenv("ELISA_DEFER_PRX_INIT".cast[u8&]) != null:
        linker_defer_dependency_start <- true
        linker_deferred_init_count <- 0
        linker_init_array_n <- 0
        linker_cap_dbg_calls <- 0
        linker_cap_dbg_modcount <- 0
    can Unsafe.SegmentMutation, Unsafe.GuestSegmentInstall, Segment.Guest, Segment.Host, Memory.Allocate, Abort.Panic:
        Linker_PreloadLibkernelGameModules((&self).cast[mutable Linker&])
        Linker_LoadDependencyClosure((&self).cast[mutable Linker&])
    ge_emergency_mark(GE_EV_EXEC_AFTER_DEP_CLOSURE, self.modules.count.uintptr(), (1 if self.relocated_all_imports else 0).uintptr(), 0.uintptr(), 0.uintptr())
    GuestExec_RecordLoad()
    if not self.relocated_all_imports:
        ge_emergency_mark(GE_EV_EXEC_RELOC_ALL_BEGIN, self.modules.count.uintptr(), self.last_relocated_import_count.u64().uintptr(), 0.uintptr(), 0.uintptr())
        # Single-view: write relocations straight to the native MAP_FIXED mapping (no
        # deferred backing-only batching). ge_make_writable_cached keeps repeated
        # same-page writes cheap, and native is now the single source of truth, so the
        # backing/native divergence that hid relocated values is gone.
        can Memory.Allocate, Abort.Panic:
            Linker_RelocateAllImports((&self).cast[mutable Linker&])
        ge_emergency_mark(GE_EV_EXEC_RELOC_ALL_END, self.modules.count.uintptr(), self.last_relocated_import_count.u64().uintptr(), 0.uintptr(), 0.uintptr())
    GuestExec_RecordLink()
    GuestExec_SetFailedRelocationCount(self.last_failed_relocation_count.u64())
    ge_emergency_mark(GE_EV_EXEC_TLS_ALLOC_BEGIN, self.modules.count.uintptr(), self.static_tls_size.uintptr(), 0.uintptr(), 0.uintptr())
    tls_addr: VAddr = Linker_AllocateTlsForThread((&self).cast[mutable Linker&], true)
    ge_emergency_mark(GE_EV_EXEC_TLS_ALLOC_END, tls_addr, self.modules.count.uintptr(), self.static_tls_size.uintptr(), 0.uintptr())
    Linker_EnsureMainGuestStack(memory)
    index: mutable s32 = 0
    mod_ref: mutable Module&? = Linker_GetModule((&self).cast[mutable Linker&], index)
    if mod_ref == null:
        self.last_started_module_index <- -1
        self.last_start_result <- -1
        self.last_entry_addr <- 0.uintptr()
        return -1
    self.last_entry_addr <- Module_GetEntryAddress(mod_ref, 0.uintptr())
    mod_ref.last_start_entry_addr <- self.last_entry_addr
    mod_ref.last_start_preinit_count <- 0
    mod_ref.last_start_init_count <- 0
    result: s32 = 0
    if GuestExec_IsEnabled():
        ge_emergency_mark(GE_EV_MAIN_ENTRY_SYNC_BEGIN, self.last_entry_addr, args.count.uintptr(), 0.uintptr(), 0.uintptr())
        sync_result: mutable bool = false
        can Memory.Allocate:
            sync_result <- MemoryManager_SyncNativeBackingToGuestExec(memory)
        if not sync_result:
            self.last_started_module_index <- index
            self.last_start_result <- -2
            return -2
        ge_emergency_mark(GE_EV_MAIN_ENTRY_SYNC_END, self.last_entry_addr, args.count.uintptr(), 0.uintptr(), 0.uintptr())
        # Build the init trampoline from the init function pointers captured during
        # load (Linker_CaptureInitValuesNow). The guarded executor jumps here so the
        # PRX inits (libc heap bootstrap) run as native guest code with live HLE
        # dispatch before the eboot entry, matching shadPS4. last_entry_addr stays the
        # real eboot entry for reporting.
        if linker_defer_dependency_start and linker_deferred_init_count > 0:
            _ = Linker_BuildInitTrampoline(self.last_entry_addr.u64())
        ge_emergency_mark(GE_EV_MODULE_START_BEGIN, linker_init_trampoline_addr.uintptr(), linker_deferred_init_count.uintptr(), self.last_entry_addr, 0xDEF0.uintptr())
        argv0: mutable void&? = null
        GuestExec_ClearEntryArgs()
        arg_index: mutable usize = 0
        while arg_index < args.count and arg_index < 33:
            decreases 33 - arg_index
            GuestExec_SetEntryArg(arg_index, args[arg_index])
            arg_index <- arg_index + 1
        if args.count > 0:
            argv0 <- args[0].cast[void&?]
        ge_emergency_mark(GE_EV_MAIN_ENTRY_PREPARE_BEGIN, self.last_entry_addr, args.count.uintptr(), argv0.uintptr(), 0.uintptr())
        prep_status: mutable s32 = 0
        can Unsafe.SegmentMutation, Segment.Host, Memory.Allocate:
            prep_status <- Linker_PrepareMainThreadBeforeEntry()
        ge_emergency_mark(GE_EV_MAIN_ENTRY_PREPARE_END, self.last_entry_addr, prep_status.u64().uintptr(), argv0.uintptr(), 0.uintptr())
        ge_emergency_mark(GE_EV_MAIN_ENTRY_JUMP_BEGIN, self.last_entry_addr, args.count.uintptr(), argv0.uintptr(), 0.uintptr())
        GuestExec_RunMainEntry(self.last_entry_addr, args.count.int(), argv0)
        ge_emergency_mark(GE_EV_MAIN_ENTRY_JUMP_RETURNED, self.last_entry_addr, args.count.uintptr(), argv0.uintptr(), 0.uintptr())
    can Memory.Allocate, Abort.Panic:
        Linker_RelocateAllImports((&self).cast[mutable Linker&])
    self.last_started_module_index <- index
    self.last_start_result <- result
    Linker_RecountImportResolution((&self).cast[mutable Linker&])
    return result

def Linker_DebugDump(self: Linker&) -> darray[static u8&]:
    out: mutable darray[static u8&] = []
    in perm:
        for i in 0..<self.modules.count:
            out.push(self.modules[i].name)
    return out

def Linker_DeferredInitCount() -> u64:
    return linker_deferred_init_count.u64()

def Linker_CaptureDbgCalls() -> u64:
    return linker_cap_dbg_calls.u64()

def Linker_CaptureModCount() -> u64:
    return linker_cap_dbg_modcount

def Linker_CaptureDbgBase(i: u64) -> u64:
    return linker_cap_dbg_base[i.usize()] if i.usize() < 16 else 0

def Linker_CaptureDbgVa(i: u64) -> u64:
    return linker_cap_dbg_va[i.usize()] if i.usize() < 16 else 0

def Linker_CaptureDbgSize(i: u64) -> u64:
    return linker_cap_dbg_size[i.usize()] if i.usize() < 16 else 0

def Linker_CaptureDbgEntry0(i: u64) -> u64:
    return linker_cap_dbg_entry0[i.usize()] if i.usize() < 16 else 0
