global mutable linker_tls_get_addr_calls: u64 = 0
global mutable linker_tls_last_module_index: u64 = 0
global mutable linker_tls_last_offset: u64 = 0
global mutable linker_tls_last_dtv_base: uintptr = 0.uintptr()
global mutable linker_tls_last_block_pointer: uintptr = 0.uintptr()
global mutable linker_tls_last_result: uintptr = 0.uintptr()
global mutable linker_tls_module0_calls: u64 = 0
global mutable linker_tls_null_dtv_calls: u64 = 0
global mutable linker_tls_primary_base: uintptr = 0.uintptr()
global mutable linker_tls_primary_size: u64 = 0
global mutable linker_tls_primary_tcb: uintptr = 0.uintptr()
global mutable linker_tls_primary_dtv_base: uintptr = 0.uintptr()
global mutable linker_tls_primary_dtv_size: u64 = 0

