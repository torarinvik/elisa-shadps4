extern getenv(name: u8&) -> u8&?
extern pthread_self() -> void&?

extern sceSysmodulePreloadModuleForLibkernel() -> int
extern sceKernelAllocateDirectMemory(searchStart: i64, searchEnd: i64, len: u64, alignment: u64, memoryType: int, physAddrOut: void&?) -> int
extern sceKernelAllocateMainDirectMemory(len: u64, alignment: u64, memoryType: int, physAddrOut: void&?) -> int

# shadPS4 sets tcb->tcb_thread = thread (the current Pthread object), see
# core/libraries/kernel/threads/tcb.cpp:58. A guest that reads %fs:tcb_thread
# and round-trips it back into our HLE pthread layer must therefore see the
# current host thread handle, NOT the TCB self-address. Mirror that here.
def Linker_CurrentThreadObject() -> uintptr:
    return pthread_self().uintptr()

def Linker_PrepareMainThreadBeforeEntry() -> s32 can[Unsafe.SegmentMutation, Segment.Host]:
    # Mirror shadPS4's pre-entry game-thread setup: libkernel sysmodule preload,
    # then a small SceGnmDriver direct-memory reservation that some titles expect
    # to exist before their crt0 reaches user code.
    preload: int = sceSysmodulePreloadModuleForLibkernel()
    if preload != 0:
        return preload.s32()
    phys_addr: mutable i64 = 0
    alloc: mutable int = 0
    can Unsafe.SegmentMutation, Segment.Host, Memory.Allocate:
        alloc <- sceKernelAllocateDirectMemory(0xc0000000, 0xc0010000, 0x10000, 0x10000, 3, (&phys_addr).cast[void&?])
    if alloc != 0:
        return alloc.s32()
    mapped_addr: mutable VAddr = 0.uintptr()
    return MemoryManager_MapMemory(Memory_Instance(), mapped_addr, 0xfe0000000.uintptr(), 0x10000, 0x13, MemoryMapFlags_NoFlags, VMAType_Direct, "SceGnmDriver", false, phys_addr.uintptr(), 0x10000)

def Linker_EnsureMainGuestStack(memory: mutable MemoryManager&) -> void:
    if not GuestExec_IsEnabled() or not GuestExec_IsSupported():
        return
    if GuestExec_MainStackTop() != 0.uintptr():
        return
    # shadPS4 starts guest module initializers and main on a PS4 thread stack.
    # Prepare it before dependency module starts so their DT_INIT code does not
    # run on the host stack.
    guest_stack_guard: VAddr = 0x7EFCB0000.uintptr()
    guest_stack_base: VAddr = guest_stack_guard + 0x4000.uintptr()
    guest_stack_size: u64 = 0x120000
    guard_out: mutable VAddr = 0.uintptr()
    stack_out: mutable VAddr = 0.uintptr()
    guard_status: s32 = MemoryManager_MapMemory(memory, guard_out, guest_stack_guard, 0x4000, MemoryProt_NoAccess, MemoryMapFlags_Fixed, VMAType_Reserved, "main-thread-guard", false, 0.uintptr(), 0x4000)
    stack_status: s32 = MemoryManager_MapMemory(memory, stack_out, guest_stack_base, guest_stack_size, MemoryProt_CpuReadWrite, MemoryMapFlags_Fixed, VMAType_Stack, "main-thread-stack", false, 0.uintptr(), 0x4000)
    if guard_status == 0 and stack_status == 0:
        GuestExec_SetMainStackTop(stack_out + guest_stack_size.uintptr())

const LINKER_NATIVE_HLE_THUNK_CAP: usize = 2048

global mutable linker_native_hle_thunk_targets: u64[2048] = zeroed
global mutable linker_native_hle_thunk_addrs: u64[2048] = zeroed
global mutable linker_native_hle_thunk_symbol_ptrs: u64[2048] = zeroed
global mutable linker_native_hle_thunk_count: usize = 0
# Generic HLE call ring: a per-thunk recorder prefix stub writes the symbol-name
# C-string pointer of every guest->HLE call into this ring (masked by 1023), then
# jmps through to the real boundary thunk. This captures EVERY boundary crossing
# without manually instrumenting each HLE function, so the last few calls before a
# crash can be read back from the tail of the ring. See GuestExec_DumpHleCallRing.
const LINKER_HLE_CALL_RING_CAP: usize = 1024
global mutable linker_hle_call_ring: u64[1024] = zeroed
global mutable linker_hle_call_target_ring: u64[1024] = zeroed
global mutable linker_hle_call_return_ring: u64[1024] = zeroed
global mutable linker_hle_call_rdi_ring: u64[1024] = zeroed
global mutable linker_hle_call_rsi_ring: u64[1024] = zeroed
global mutable linker_hle_call_rdx_ring: u64[1024] = zeroed
global mutable linker_hle_call_ring_index: u64 = 0
# Relocation probe: record any relocation write whose target falls in the 8-byte
# window at linker_reloc_probe_addr (default 0x802d85190, the null-global crash
# site). Distinguishes "global is a relocation target" (and whether the write
# applied) from "global is code-initialized" without a debugger.
global mutable linker_reloc_probe_addr: u64 = 0x802d85190
global mutable linker_reloc_probe_count: u64 = 0
global mutable linker_reloc_probe_value: u64 = 0
global mutable linker_reloc_probe_type: u32 = 0
global mutable linker_reloc_probe_path: u32 = 0  # 1=WriteRelocationU64, 2=WriteRelativeRelocationFast
global mutable linker_native_hle_function_relocation_count: u64 = 0
global mutable linker_native_hle_data_relocation_count: u64 = 0
global mutable linker_native_hle_unthunked_function_count: u64 = 0
global mutable linker_native_hle_unthunked_function_first_target: u64 = 0
global mutable linker_native_hle_function_addend_count: u64 = 0
global mutable linker_native_hle_function_max_addend: u64 = 0
global mutable linker_native_hle_data_thunk_pointer_count: u64 = 0
global mutable linker_native_hle_data_thunk_pointer_first_value: u64 = 0
global mutable linker_native_hle_data_thunk_pointer_first_name: static u8&? = null

# Link-time tiny-pointer sweep: any pointer-bearing relocation whose final
# written value is nonzero but lands in the unmapped low range (< 0x10000) is a
# near-NULL bogus pointer the guest may later call/deref (the 0x1f4-class bug).
# Flagging it here names the offending symbol/slot at link time instead of
# leaving it to crash anonymously at runtime. TLS module-id writes (DTPMOD64,
# value == modid) are legitimately small and are deliberately NOT swept.
const LINKER_TINY_POINTER_THRESHOLD: u64 = 0x10000
global mutable linker_tiny_pointer_slot_count: u64 = 0
global mutable linker_tiny_pointer_first_value: u64 = 0
global mutable linker_tiny_pointer_first_offset: u64 = 0
global mutable linker_tiny_pointer_first_type: u32 = 0
global mutable linker_tiny_pointer_first_name: static u8&? = null
global mutable linker_tiny_pointer_first_module: static u8&? = null
global mutable linker_defer_native_relocation_writes: bool = false
# When true, Linker_LoadGuestDependency loads + relocates a dependency module but
# does NOT run its Module_Start (init arrays / module_start). Boot uses this so the
# PRX inits run only AFTER the native backing is synced to guest-exec (otherwise a
# PRX's PREINIT executes against a stale, unsynced GOT — its HLE calls like
# GetProcParam never dispatch, the libc heap bootstrap silently no-ops, and a
# once-guard inside the PRX prevents a later retry). shadPS4 runs these inits after
# relocation, before RunMainEntry; this mirrors that ordering.
global mutable linker_defer_dependency_start: bool = false
# gap-3 (UPDATE 8): on macOS the HOST TLS register is %gs, not %fs. The HLE boundary
# thunk restores host %fs before calling the HLE body but never restores host %gs, so
# a host malloc/CRT reached from an HLE (e.g. libc PREINIT's internal_malloc during the
# deferred-init bootstrap) dereferences %gs:0x68 with a clobbered base and faults at
# fault_addr=0x68. When set (env ELISA_RESTORE_HOST_GS), the boundary thunk also forces
# the host %gs selector before `call *%r11`. Gated so the default 174-byte thunk is
# byte-identical (default tree stays green). macOS userland %gs selector = 0x6F.
global mutable linker_restore_host_gs: bool = false
global mutable linker_host_gs_selector: u16 = 0x6F
global mutable linker_last_relocation_retryable: bool = false
global mutable linker_hle_tiny_callable_count: u64 = 0
global mutable linker_hle_tiny_callable_first_value: u64 = 0
global mutable linker_hle_tiny_callable_first_name: static u8&? = null
global mutable linker_hle_tiny_callable_first_nid: static u8&? = null
global mutable linker_application_heap_api: uintptr = 0.uintptr()
global mutable linker_application_heap_bootstrap_malloc: uintptr = 0.uintptr()
global mutable linker_application_heap_bootstrap_result: uintptr = 0.uintptr()
global mutable linker_application_heap_bootstrap_attempts: u64 = 0
global mutable linker_application_heap_bootstrap_done: bool = false

# TLS-base provenance: record __tls_get_addr inputs and the resolved per-thread
