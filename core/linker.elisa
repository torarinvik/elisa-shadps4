def Linker_HleSymbolsStringChecksum(self: Linker&) -> u64:
    # FNV-1a over every HLE symbol's name + nid strings (NOT callable_address,
    # which is ASLR-randomized). Detects use-after-free corruption of the HLE
    # resolver table independent of address-space layout.
    hash: mutable u64 = 0xcbf29ce484222325
    i: mutable usize = 0
    while i < self.hle_symbols.symbols.count:
        sym: SymbolRecord = self.hle_symbols.symbols[i]
        # Scan name + nid through bounds-safe views (the cstr coercion measures
        # each string once; view indexing is proven in range).
        name_c: cstr = sym.name
        name_view: sview = name_c[0:name_c.len]
        n: mutable usize = 0
        while n < name_view.len.usize():
            hash <- (hash ^ name_view[n].u64()) * 0x100000001b3
            n <- n + 1
        nid_c: cstr = sym.nid_name
        nid_view: sview = nid_c[0:nid_c.len]
        m: mutable usize = 0
        while m < nid_view.len.usize():
            hash <- (hash ^ nid_view[m].u64()) * 0x100000001b3
            m <- m + 1
        hash <- hash ^ 0xff
        i <- i + 1
    return hash

def Linker_GetInstance() -> mutable Linker&:
    return &linker_singleton

global mutable linker_deferred_starts_done: bool = false
# Captured guest init-array function pointers for the dependency PRXs, collected
# during load (while the host Module structs are alive) and replayed under the
# guarded executor. The Module metadata arena is recycled after load, so the
# guarded executor must NOT read Module structs directly (they read back as host
# string garbage); it replays from these stable primitives instead.
const LINKER_DEFERRED_INIT_CAP: usize = 1024
global mutable linker_deferred_init_fns: u64[1024] = zeroed
global mutable linker_deferred_init_count: usize = 0
# Two-stage capture: stage 1 (Linker_RecordInitArrays, post-closure) records each
# dependency's init-array ADDRESS + entry count from the still-valid module structs.
# Stage 2 (Linker_ResolveInitFnsFromNative, post-sync) reads the relocated entries
# from NATIVE memory (the only layer that has them post-sync) into the fn list.
# This bridges the layer mismatch: struct metadata is valid only pre-sync; the
# relocated init-array contents are valid only post-sync (native).
const LINKER_INIT_ARRAY_CAP: usize = 64
global mutable linker_init_array_addr: u64[64] = zeroed
global mutable linker_init_array_count: u64[64] = zeroed
global mutable linker_init_array_n: usize = 0
# Capture diagnostics (first 16 Linker_CaptureInitArrayFns calls): records what the
# capture observed so the count=0 cause can be read back at the deferred-start point.
global mutable linker_cap_dbg_calls: usize = 0
global mutable linker_cap_dbg_modcount: u64 = 0
global mutable linker_cap_dbg_base: u64[16] = zeroed
global mutable linker_cap_dbg_va: u64[16] = zeroed
global mutable linker_cap_dbg_size: u64[16] = zeroed
global mutable linker_cap_dbg_entry0: u64[16] = zeroed

# Capture one init/preinit array's relocated function-pointer VALUES from the
# MemoryManager backing into the deferred-init list. Called from LoadGuestDependency
# right after the module's relocation -- the transient window where the values are
# present (same point the original Module_Start reads them). `self` is the live
# (narrowed) module reference, used exactly as Module_Start uses it.
def Linker_CaptureInitValuesNow(self: Module&, array_va: u64, array_size: u64) -> void:
    if array_va == 0 or array_size < 8 or array_size > 0x10000:
        return
    base: u64 = self.base_virtual_addr.u64() + array_va
    count: u64 = array_size / 8
    memory: mutable MemoryManager& = Memory_Instance()
    can Memory.Allocate:
        if linker_cap_dbg_calls < 16:
            linker_cap_dbg_base[linker_cap_dbg_calls] <- base
            linker_cap_dbg_va[linker_cap_dbg_calls] <- array_va
            linker_cap_dbg_size[linker_cap_dbg_calls] <- array_size
            linker_cap_dbg_entry0[linker_cap_dbg_calls] <- MemoryManager_ReadU64(memory, base.uintptr()).u64()
            linker_cap_dbg_calls <- linker_cap_dbg_calls + 1
        i: mutable u64 = 0
        while i < count and i < 2048 and linker_deferred_init_count < LINKER_DEFERRED_INIT_CAP:
            decreases 2048 - i
            entry: u64 = MemoryManager_ReadU64(memory, (base + (i * 8)).uintptr()).u64()
            if entry != 0 and entry != 0xffffffffffffffff:
                linker_deferred_init_fns[linker_deferred_init_count] <- entry
                linker_deferred_init_count <- linker_deferred_init_count + 1
            i <- i + 1

# Record one module's preinit_array + init_array ADDRESS + entry count (not the
# contents). Reads only module-struct metadata (valid pre-sync).

# Stage 1 (post-closure, pre-sync): record each dependency module's init-array
# addresses from the still-valid module structs, in dependency order. Iterates the
# module table directly (valid refs), NOT LoadGuestDependency (dangling on realloc).

# Stage 2 (post-sync): read the relocated init-array entries from NATIVE memory
# (the layer the guest executes against, which now has the relocated pointers) into
# the deferred-init fn list, using the addresses recorded in stage 1. No struct reads.

global mutable linker_init_trampoline_addr: u64 = 0

def Linker_InitTrampolineAddr() -> u64:
    return linker_init_trampoline_addr

# Build a guest-side machine-code trampoline that calls each captured init function
# in order, then jmps to real_entry. The guarded executor jumps to this trampoline
# instead of the eboot entry, so the PRX inits (libc PREINIT heap bootstrap:
# GetProcParam / RtldSetApplicationHeapAPI / DirectMemory) run as NATIVE guest code
# with live HLE dispatch and the signal guard active -- exactly as shadPS4 runs PRX
# inits before _start -- then control falls through to the eboot entry. Returns the
# trampoline guest address (also stored in linker_init_trampoline_addr), or 0.
def Linker_BuildInitTrampoline(real_entry: u64) -> u64:
    linker_init_trampoline_addr <- 0
    static if PLATFORM_APPLE and ARCH_X86_64:
        if real_entry == 0:
            return 0
        n: usize = linker_deferred_init_count
        total: usize = 24 + (12 * n)
        if total > 4096:
            return 0
        buf: mutable u8[4096] = zeroed
        # Guest entry ABI (easm JumpMainEntryOnStackWithFsAsm): rdi=EntryParams ptr,
        # rsi=exit_func, rsp%16==8, EntryParams words on stack. Preserve rdi/rsi and
        # keep rsp balanced so the real entry sees the same state after the inits.
        # push rdi (57); push rsi (56)  -> saves args, rsp%16: 8->0->8
        buf[0] <- 0x57
        buf[1] <- 0x56
        # sub rsp,8 (48 83 EC 08) -> rsp%16: 8->0 so each `call` lands callee at %16==8
        buf[2] <- 0x48
        buf[3] <- 0x83
        buf[4] <- 0xEC
        buf[5] <- 0x08
        pos: mutable usize = 6
        k: mutable usize = 0
        while k < n:
            fn: u64 = linker_deferred_init_fns[k]
            buf[pos] <- 0x48           # movabs rax, imm64
            buf[pos + 1] <- 0xB8
            Linker_WriteU64LE((&buf[0]).cast[mutable u8&], pos + 2, fn)
            buf[pos + 10] <- 0xFF # call rax
            buf[pos + 11] <- 0xD0
            pos <- pos + 12
            k <- k + 1
        # add rsp,8 (48 83 C4 08); pop rsi (5E); pop rdi (5F) -> restore args + rsp%16==8
        buf[pos] <- 0x48
        buf[pos + 1] <- 0x83
        buf[pos + 2] <- 0xC4
        buf[pos + 3] <- 0x08
        buf[pos + 4] <- 0x5E
        buf[pos + 5] <- 0x5F
        pos <- pos + 6
        # movabs rax, real_entry ; jmp rax
        buf[pos] <- 0x48
        buf[pos + 1] <- 0xB8
        Linker_WriteU64LE((&buf[0]).cast[mutable u8&], pos + 2, real_entry)
        buf[pos + 10] <- 0xFF
        buf[pos + 11] <- 0xE0
        pos <- pos + 12
        tramp: VAddr = GuestExec_AllocateRegion(4096, 5)
        if tramp == 0.uintptr():
            return 0
        can Unsafe.MachineCodeBuilder:
            if not GuestExec_WriteBytes(tramp, (&buf[0]).cast[void&], pos.u64()):
                return 0
        can Unsafe.ExecutableCodePublish:
            if not GuestExec_PublishExecutableCode(tramp, pos.u64()):
                return 0
        linker_init_trampoline_addr <- tramp.u64()
        return tramp.u64()
    static else:
        _ = real_entry
        return 0

def Linker_Reset() -> void:
    linker_deferred_starts_done <- false
    linker_defer_dependency_start <- false
    linker_deferred_init_count <- 0
    linker_init_array_n <- 0
    linker_init_trampoline_addr <- 0
    Memory_Reset()
    GuestExec_ResetState()
    TLS_ResetForTests()
    Module_StartOracleReset()
    linker_hle_tiny_callable_count <- 0
    linker_hle_tiny_callable_first_value <- 0
    linker_hle_tiny_callable_first_name <- null
    linker_hle_tiny_callable_first_nid <- null
    linker_application_heap_api <- 0.uintptr()
    linker_singleton <- Linker_New()

def Linker_GetHLESymbols(self: mutable Linker&) -> mutable SymbolsResolver&:
    return &self.hle_symbols

def SymbolsResolver_AddSymbol(self: mutable SymbolsResolver&, nid: static u8&, name: static u8&, virtual_address: u64) -> void:
    SymbolsResolver_AddBoundSymbol(self, nid, name, virtual_address, virtual_address)

def SymbolsResolver_AddBoundSymbol(self: mutable SymbolsResolver&, nid: static u8&, name: static u8&, virtual_address: u64, callable_address: u64) -> void:
    SymbolsResolver_AddBoundSymbolForLibrary(self, nid, name, "", 0, "", IMPORT_SYMBOL_TYPE_UNKNOWN, virtual_address, callable_address)

def SymbolsResolver_AddBoundSymbolForLibrary(self: mutable SymbolsResolver&, nid: static u8&, name: static u8&, library: static u8&, library_version: u16, module: static u8&, symbol_type: u8, virtual_address: u64, callable_address: u64) -> void:
    Linker_NoteHleCallableRegistration(nid, name, symbol_type, callable_address)
    # The HLE symbol table outlives this call, so its backing storage must be
    # allocated from the persistent metadata arena. Using a transient local
    # arena here freed the darray backing on return, leaving the resolver table
    # in use-after-free memory and making import resolution nondeterministic.
    in perm:
        self.symbols.push(SymbolRecord(nid, name, library, library_version, module, symbol_type, virtual_address, callable_address))

def Linker_NoteHleCallableRegistration(nid: static u8&, name: static u8&, symbol_type: u8, callable_address: u64) -> void:
    if symbol_type != IMPORT_SYMBOL_TYPE_FUNCTION and symbol_type != IMPORT_SYMBOL_TYPE_UNKNOWN:
        return
    if callable_address >= LINKER_TINY_POINTER_THRESHOLD:
        return
    if linker_hle_tiny_callable_count == 0:
        linker_hle_tiny_callable_first_value <- callable_address
        linker_hle_tiny_callable_first_name <- name
        linker_hle_tiny_callable_first_nid <- nid
    linker_hle_tiny_callable_count <- linker_hle_tiny_callable_count + 1

def Linker_HleTinyCallableCount() -> u64:
    return linker_hle_tiny_callable_count

def Linker_HleTinyCallableFirstValue() -> u64:
    return linker_hle_tiny_callable_first_value

def Linker_HleTinyCallableFirstName() -> static u8&?:
    return linker_hle_tiny_callable_first_name

def Linker_HleTinyCallableFirstNid() -> static u8&?:
    return linker_hle_tiny_callable_first_nid

def Linker_SetHeapAPI(func: void&?) -> void:
    if func == null:
        linker_application_heap_api <- 0.uintptr()
        return
    linker_application_heap_api <- func.uintptr()

def Linker_GetHeapAPI() -> uintptr:
    return linker_application_heap_api

def Linker_BootstrapApplicationHeapApi() -> void can[Unsafe.SegmentMutation, Unsafe.GuestSegmentInstall, Segment.Guest, Segment.Host, Memory.Allocate]:
    if linker_application_heap_bootstrap_done:
        return
    linker_application_heap_bootstrap_done <- true
    heap_api: uintptr = Linker_GetHeapAPI()
    if heap_api == 0.uintptr():
        return
    malloc_fn_addr: mutable uintptr = 0.uintptr()
    can Memory.Allocate:
        malloc_fn_addr <- GuestExec_ReadNativeU64(heap_api)
    linker_application_heap_bootstrap_malloc <- malloc_fn_addr
    if malloc_fn_addr == 0.uintptr():
        ge_emergency_mark(GE_EV_HLE_KNOWN_TARGET, 0x48454152.uintptr(), heap_api, 0.uintptr(), 0.uintptr())
        return
    linker_application_heap_bootstrap_attempts <- linker_application_heap_bootstrap_attempts + 1
    ge_emergency_mark(GE_EV_HLE_KNOWN_TARGET, 0x48454152.uintptr(), heap_api, malloc_fn_addr, 0xb0.uintptr())
    static if PLATFORM_APPLE and ARCH_X86_64:
        guest_selector: GuestFsSelector = TLS_PrepareTcbBase((!TLS_PrimaryTcbBase()).cast[void&?])
        host_selector: HostFsSelector = TLS_CaptureHostFsSelector()
        if !guest_selector == 0:
            ge_emergency_mark(GE_EV_HLE_KNOWN_TARGET, 0x48454153.uintptr(), heap_api, malloc_fn_addr, 0.uintptr())
            return
        result: mutable void&? = null
        can Unsafe.SegmentMutation, Segment.Host, Segment.Guest:
            result <- TLS_CallGuestThreadEntryWithPreparedSegment(malloc_fn_addr.cast[void&?], 0xb0.uintptr().cast[void&?], guest_selector, host_selector)
        linker_application_heap_bootstrap_result <- result.uintptr()
        ge_emergency_mark(GE_EV_HLE_KNOWN_TARGET, 0x48454154.uintptr(), malloc_fn_addr, result.uintptr(), 0xb0.uintptr())
    static else:
        ge_emergency_mark(GE_EV_HLE_KNOWN_TARGET, 0x48454155.uintptr(), heap_api, malloc_fn_addr, 0.uintptr())

def SymbolsResolver_Count(self: SymbolsResolver&) -> usize:
    return self.symbols.count

def SymbolsResolver_FindByNid(self: SymbolsResolver&, nid: static u8&) -> s32:
    for i in 0..<self.symbols.count:
        if streq(self.symbols[i].name, nid) == 1:
            return i.s32()
    return -1

def SymbolsResolver_FindHleSymbol(self: SymbolsResolver&, nid: static u8&, library: static u8&, library_version: u16, module: static u8&, symbol_type: u8) -> s32:
    for i in 0..<self.symbols.count:
        sym: SymbolRecord = self.symbols[i]
        if streq(sym.nid_name, nid) != 1 and not Linker_NameMatchesNid(sym.name, nid):
            continue
        if static_strlen(sym.library) == 0 or static_strlen(sym.module) == 0:
            continue
        if streq(sym.library, library) != 1:
            continue
        if sym.library_version != library_version:
            continue
        if streq(sym.module, module) != 1:
            continue
        if symbol_type != IMPORT_SYMBOL_TYPE_UNKNOWN and sym.symbol_type != IMPORT_SYMBOL_TYPE_UNKNOWN and sym.symbol_type != symbol_type:
            continue
        return i.s32()
    return -1

def SymbolsResolver_FindHleSymbolByNidOnly(self: SymbolsResolver&, nid: static u8&) -> s32:
    return SymbolsResolver_FindHleSymbolByNidOnlyTyped(self, nid, IMPORT_SYMBOL_TYPE_UNKNOWN)

def SymbolsResolver_FindHleSymbolByNidOnlyTyped(self: SymbolsResolver&, nid: static u8&, symbol_type: u8) -> s32:
    for i in 0..<self.symbols.count:
        sym: SymbolRecord = self.symbols[i]
        if Linker_NameMatchesNid(sym.name, nid) or streq(sym.nid_name, nid) == 1:
            if symbol_type != IMPORT_SYMBOL_TYPE_UNKNOWN and sym.symbol_type != IMPORT_SYMBOL_TYPE_UNKNOWN and sym.symbol_type != symbol_type:
                continue
            return i.s32()
    return -1

def Linker_GetProcParam(self: Linker&) -> VAddr:
    if self.modules.count == 0:
        return 0.uintptr()
    return self.modules[0].proc_param_virtual_addr

# --- Typed proc_param / mem_param overlay (over-read hardening) ---------------
#
# The guest `OrbisProcParam` and `OrbisKernelMemParam` structures live in guest
# memory and were historically read with raw `base + offset` arithmetic, which
# over-read past short/truncated structs and crashed. The descriptors below name
# every field offset/width the linker touches, and the accessors fold in the
# `size`-field bounds guards that the call sites used to do inline (proc_param
# `size >= 72`, mem_param `size >= 24/32/48`). Each accessor verifies that the
# declared `size` field covers `offset + width` before reading; on an under-size
# struct it returns the same defensive sentinel (0) the old code fell back to, so
# behavior is byte-for-byte identical to the previous inline guards.
#
# Field offsets (bytes), confirmed against the OrbisProcParam / OrbisKernelMemParam
# struct layouts declared above:
#   OrbisProcParam:      size@0:u64   sdk_version@16:u64   mem_param@64:uintptr
#   OrbisKernelMemParam: size@0:u64   flexible_memory_size@16:uintptr
#                        extended_memory_1@24:uintptr   extended_memory_2@40:uintptr
const ORBIS_PROC_PARAM_OFF_SIZE: u64 = 0
const ORBIS_PROC_PARAM_OFF_SDK_VERSION: u64 = 16
const ORBIS_PROC_PARAM_OFF_MEM_PARAM: u64 = 64
# mem_param pointer lives at +64; reading it requires size >= 64 + 8 = 72.
const ORBIS_PROC_PARAM_MIN_SIZE_MEM_PARAM: u64 = 72

const ORBIS_MEM_PARAM_OFF_SIZE: u64 = 0
const ORBIS_MEM_PARAM_OFF_FLEXIBLE_MEMORY_SIZE: u64 = 16
const ORBIS_MEM_PARAM_OFF_EXTENDED_MEMORY_1: u64 = 24
const ORBIS_MEM_PARAM_OFF_EXTENDED_MEMORY_2: u64 = 40
# Each uintptr/u64 field is 8 bytes wide; the min-size guard is offset + 8.
const ORBIS_MEM_PARAM_MIN_SIZE_FLEXIBLE: u64 = 24
const ORBIS_MEM_PARAM_MIN_SIZE_EXTENDED_1: u64 = 32
const ORBIS_MEM_PARAM_MIN_SIZE_EXTENDED_2: u64 = 48

# Read the proc_param `size` field (offset 0). The declared size bounds every
# other field access below.
def Linker_ProcParamSize(memory: mutable MemoryManager&, proc_param: VAddr) -> u64:
    can Memory.Allocate:
        return MemoryManager_ReadU64(memory, proc_param + ORBIS_PROC_PARAM_OFF_SIZE.uintptr())

# Read proc_param.sdk_version (offset 16, u64) through the module image reader.
# The original call site read this field with no size guard (it only treated a
# zero result as "absent"), so this accessor mirrors that: no size argument, no
# bounds check beyond the named offset.
def Linker_ProcParamSdkVersion(module: Module, proc_param: VAddr) -> u64:
    return Module_ReadImageU64(module, proc_param.u64() + ORBIS_PROC_PARAM_OFF_SDK_VERSION)

# Read proc_param.mem_param pointer (offset 64). Returns 0 unless the declared
# size covers the pointer (size >= 72), matching the old `< 72` guard.
def Linker_ProcParamMemParam(memory: mutable MemoryManager&, proc_param: VAddr, proc_param_size: u64) -> u64:
    if proc_param_size < ORBIS_PROC_PARAM_MIN_SIZE_MEM_PARAM:
        return 0
    can Memory.Allocate:
        return MemoryManager_ReadU64(memory, proc_param + ORBIS_PROC_PARAM_OFF_MEM_PARAM.uintptr())

# Read the mem_param `size` field (offset 0).
def Linker_MemParamSize(memory: mutable MemoryManager&, mem_param: VAddr) -> u64:
    can Memory.Allocate:
        return MemoryManager_ReadU64(memory, mem_param + ORBIS_MEM_PARAM_OFF_SIZE.uintptr())

# Read mem_param.flexible_memory_size pointer (offset 16). Returns 0 unless the
# declared size covers the field (size >= 24), matching the old `< 24` guard.
def Linker_MemParamFlexibleSizePtr(memory: mutable MemoryManager&, mem_param: VAddr, mem_param_size: u64) -> u64:
    if mem_param_size < ORBIS_MEM_PARAM_MIN_SIZE_FLEXIBLE:
        return 0
    can Memory.Allocate:
        return MemoryManager_ReadU64(memory, mem_param + ORBIS_MEM_PARAM_OFF_FLEXIBLE_MEMORY_SIZE.uintptr())

# Read mem_param.extended_memory_1 pointer (offset 24). Returns 0 unless the
# declared size covers the field (size >= 32), matching the old `< 32` guard.
def Linker_MemParamExtendedMemory1Ptr(memory: mutable MemoryManager&, mem_param: VAddr, mem_param_size: u64) -> u64:
    if mem_param_size < ORBIS_MEM_PARAM_MIN_SIZE_EXTENDED_1:
        return 0
    can Memory.Allocate:
        return MemoryManager_ReadU64(memory, mem_param + ORBIS_MEM_PARAM_OFF_EXTENDED_MEMORY_1.uintptr())

# Read mem_param.extended_memory_2 pointer (offset 40). Returns 0 unless the
# declared size covers the field (size >= 48), matching the old `< 48` guard.
def Linker_MemParamExtendedMemory2Ptr(memory: mutable MemoryManager&, mem_param: VAddr, mem_param_size: u64) -> u64:
    if mem_param_size < ORBIS_MEM_PARAM_MIN_SIZE_EXTENDED_2:
        return 0
    can Memory.Allocate:
        return MemoryManager_ReadU64(memory, mem_param + ORBIS_MEM_PARAM_OFF_EXTENDED_MEMORY_2.uintptr())

def Linker_GetCompiledSdkVersion(self: Linker&) -> u32:
    if self.modules.count == 0:
        return ORBIS_SDK_FW_50.u32()
    module: Module = self.modules[0]
    proc_param: VAddr = module.proc_param_virtual_addr
    if proc_param == 0.uintptr():
        return ORBIS_SDK_FW_50.u32()
    sdk_version: u64 = Linker_ProcParamSdkVersion(module, proc_param)
    if sdk_version == 0:
        return ORBIS_SDK_FW_50.u32()
    return sdk_version.u32()

def Linker_GetFlexibleMemorySize(self: Linker&) -> u64:
    if self.modules.count == 0:
        return ORBIS_KERNEL_FLEXIBLE_MEMORY_SIZE
    module: Module = self.modules[0]
    proc_param: VAddr = module.proc_param_virtual_addr
    if proc_param == 0.uintptr():
        return ORBIS_KERNEL_FLEXIBLE_MEMORY_SIZE
    memory: mutable MemoryManager& = Memory_Instance()
    can Memory.Allocate:
        proc_param_size: u64 = Linker_ProcParamSize(memory, proc_param)
        # mem_param pointer at +64 requires proc_param size >= 72.
        mem_param: u64 = Linker_ProcParamMemParam(memory, proc_param, proc_param_size)
        if mem_param == 0:
            return ORBIS_KERNEL_FLEXIBLE_MEMORY_SIZE
        mem_param_addr: VAddr = mem_param.uintptr()
        mem_param_size: u64 = Linker_MemParamSize(memory, mem_param_addr)
        # flexible_memory_size pointer at +16 requires mem_param size >= 24.
        flexible_size_ptr: u64 = Linker_MemParamFlexibleSizePtr(memory, mem_param_addr, mem_param_size)
        if flexible_size_ptr == 0:
            return ORBIS_KERNEL_FLEXIBLE_MEMORY_SIZE
        requested: u64 = MemoryManager_ReadU64(memory, flexible_size_ptr.uintptr())
        if requested == 0:
            return ORBIS_KERNEL_FLEXIBLE_MEMORY_SIZE
        return requested + ORBIS_KERNEL_FLEXIBLE_MEMORY_BASE

def Linker_ReadMemParamFlag(memory: MemoryManager&, ptr: u64) -> bool:
    if ptr == 0:
        return false
    can Memory.Allocate:
        return MemoryManager_ReadU8(memory, ptr.uintptr()) != 0

def Linker_GetUseExtendedMemory1(self: Linker&) -> bool:
    if Linker_GetCompiledSdkVersion(self) >= ORBIS_SDK_FW_50.u32():
        return true
    if self.modules.count == 0:
        return true
    module: Module = self.modules[0]
    proc_param: VAddr = module.proc_param_virtual_addr
    if proc_param == 0.uintptr():
        return true
    memory: mutable MemoryManager& = Memory_Instance()
    can Memory.Allocate:
        proc_param_size: u64 = Linker_ProcParamSize(memory, proc_param)
        # mem_param pointer at +64 requires proc_param size >= 72.
        mem_param: u64 = Linker_ProcParamMemParam(memory, proc_param, proc_param_size)
        if mem_param == 0:
            return false
        mem_param_addr: VAddr = mem_param.uintptr()
        mem_param_size: u64 = Linker_MemParamSize(memory, mem_param_addr)
        # extended_memory_1 pointer at +24 requires mem_param size >= 32; an
        # under-size struct yields a null pointer, and Linker_ReadMemParamFlag
        # maps null -> false, matching the old `< 32 -> return false` guard.
        extended_memory_1: u64 = Linker_MemParamExtendedMemory1Ptr(memory, mem_param_addr, mem_param_size)
        return Linker_ReadMemParamFlag(memory, extended_memory_1)

def Linker_GetUseExtendedMemory2(self: Linker&) -> bool:
    if Linker_GetCompiledSdkVersion(self) >= ORBIS_SDK_FW_50.u32():
        return true
    if self.modules.count == 0:
        return true
    module: Module = self.modules[0]
    proc_param: VAddr = module.proc_param_virtual_addr
    if proc_param == 0.uintptr():
        return true
    memory: mutable MemoryManager& = Memory_Instance()
    can Memory.Allocate:
        proc_param_size: u64 = Linker_ProcParamSize(memory, proc_param)
        # mem_param pointer at +64 requires proc_param size >= 72.
        mem_param: u64 = Linker_ProcParamMemParam(memory, proc_param, proc_param_size)
        if mem_param == 0:
            return false
        mem_param_addr: VAddr = mem_param.uintptr()
        mem_param_size: u64 = Linker_MemParamSize(memory, mem_param_addr)
        # extended_memory_2 pointer at +40 requires mem_param size >= 48; an
        # under-size struct yields a null pointer, and Linker_ReadMemParamFlag
        # maps null -> false, matching the old `< 48 -> return false` guard.
        extended_memory_2: u64 = Linker_MemParamExtendedMemory2Ptr(memory, mem_param_addr, mem_param_size)
        return Linker_ReadMemParamFlag(memory, extended_memory_2)

def Linker_GetModule(self: mutable Linker&, index: s32) -> mutable Module&?:
    if index < 0 or index >= self.modules.count.int():
        return null
    return &self.modules[index.usize()]

def Linker_FindByName(self: Linker&, name: static u8&) -> u32:
    for i in 0..<self.modules.count:
        if streq(self.modules[i].file, name) == 1:
            return i.u32()
    return 0xFFFFFFFF.u32()

def Linker_FindByFileOrHost(self: Linker&, name: static u8&) -> u32:
    for i in 0..<self.modules.count:
        if streq(self.modules[i].file, name) == 1 or streq(self.modules[i].host_file, name) == 1:
            return i.u32()
    return 0xFFFFFFFF.u32()

def Linker_MaxTlsIndex(self: Linker&) -> u32:
    return self.max_tls_index

def Linker_GenerationCounter(self: Linker&) -> u32:
    return self.dtv_generation_counter

def Linker_EnableNativeGuestExecution(self: mutable Linker&, enabled: bool) -> void:
    self.native_guest_exec_requested <- enabled
    GuestExec_Enable(enabled)

def Linker_SetApp0HostRoot(self: mutable Linker&, root: static u8&) -> void:
    self.app0_host_root <- root

# Build the result in the persistent metadata arena (stable addresses, no
# per-call heap churn) and return a pointer to its NUL-terminated bytes. The
# buffer is explicitly terminated below; the unbounded-string lint flags this
# conservatively (it cannot prove the terminator) and is a warning here.
# input taken as cstr (sliceable) so the substring is a bounds-safe view that is
# deep-copied into the persistent metadata arena (no unchecked indexing).
def Linker_Substr(input: cstr, start: usize, len: usize) -> static u8&:
    seg: sview = input[start:start + len]
    out: mutable dstr = []
    can Memory.Allocate, Abort.Panic:
        can Unsafe.MutableGlobal:
            out <- clone[dstr](seg)
            out.push(0)
    can Unsafe.PointerCast, Unsafe.UncheckedIndex:
        return (&out[0]).cast[static u8&]

def Linker_Concat2(lhs: cstr, rhs: cstr) -> static u8&:
    lhs_view: sview = lhs[0:lhs.len]
    rhs_view: sview = rhs[0:rhs.len]
    out: mutable dstr = []
    can Memory.Allocate, Abort.Panic:
        can Unsafe.MutableGlobal:
            out <- clone[dstr](lhs_view)
            j: mutable usize = 0
            while j < rhs_view.len.usize():
                out.push(rhs_view[j])
                j <- j + 1
            out.push(0)
    can Unsafe.PointerCast, Unsafe.UncheckedIndex:
        return (&out[0]).cast[static u8&]

def Linker_PathJoin(lhs: cstr, rhs: cstr) -> static u8&:
    if static_strlen(lhs) == 0:
        return rhs
    if static_strlen(rhs) == 0:
        return lhs
    can Memory.Allocate, Abort.Panic:
        if Linker_StringHasSuffix(lhs, "/"):
            return Linker_Concat2(lhs, rhs)
        return Linker_Concat2(Linker_Concat2(lhs, "/"), rhs)

def Linker_StringContainsSlash(input: cstr) -> bool:
    view: sview = input[0:input.len]
    i: mutable usize = 0
    while i < view.len.usize():
        if view[i] == '/'.u8():
            return true
        i <- i + 1
    return false

def Linker_StringHasSuffix(input: cstr, suffix: cstr) -> bool:
    input_len: usize = static_strlen(input)
    suffix_len: usize = static_strlen(suffix)
    if suffix_len > input_len:
        return false
    start: usize = input_len - suffix_len
    return sview_eq(input[start:input_len], suffix[0:suffix_len])

def Linker_StringHasPrefix(input: cstr, prefix: cstr) -> bool:
    input_len: usize = static_strlen(input)
    prefix_len: usize = static_strlen(prefix)
    if prefix_len > input_len:
        return false
    return sview_eq(input[0:prefix_len], prefix[0:prefix_len])

def Linker_NameMatchesNid(name: static u8&, nid_or_symbol: static u8&) -> bool:
    if streq(name, nid_or_symbol) == 1:
        return true
    name_len: usize = static_strlen(name)
    if name_len == 0:
        return false
    i: mutable usize = 0
    while i < name_len:
        if nid_or_symbol[i] == 0 or nid_or_symbol[i] == '#'.u8() or name[i] != nid_or_symbol[i]:
            return false
        i <- i + 1
    return nid_or_symbol[i] == 0 or nid_or_symbol[i] == '#'.u8()

# Patch-time table mapping each fallback-patched GOT slot virtual address to the
# import symbol name it was meant to resolve. Used to attribute the runtime
# AeroLib fallback boundary (whose slot VA the native stub recovers) back to a
# concrete unimplemented import. The table lives in the native runtime so the
# relocation hot path does not need an arena/Memory effect scope to record into
# it.
# Ported from native/guest_exec_runtime.c to pure Elisa. The table is plain
# parent-side bookkeeping (populated during relocation, queried after a guarded
# run); it never touches the fork-report shared memory, signals, or mmap, so it
# carries no allocation/effect requirement — fixed global arrays keep the
# relocation hot path arena-free, exactly as the native version intended.
const FALLBACK_SLOT_CAP: u32 = 8192

global mutable g_fallback_slot_addrs: u64[8192] = zeroed
global mutable g_fallback_slot_names: static u8&?[8192] = zeroed
global mutable g_fallback_slot_modules: static u8&?[8192] = zeroed
global mutable g_fallback_slot_symbol_indices: u32[8192] = zeroed
global mutable g_fallback_slot_rel_types: u32[8192] = zeroed
global mutable g_fallback_slot_count: u32 = 0

def _fallback_slot_is_empty(s: static u8&?) -> bool:
    return s == null or static_strlen(s) == 0

def _fallback_find_index(slot_va: u64) -> s32:
    if slot_va == 0:
        return -1
    i: mutable u32 = 0
    while i < g_fallback_slot_count and i < FALLBACK_SLOT_CAP:
        decreases FALLBACK_SLOT_CAP - i
        if g_fallback_slot_addrs[i.usize()] == slot_va:
            return i.s32()
        i <- i + 1
    return -1

def c_GuestExec_RecordFallbackSlot(slot_va: u64, name: static u8&, symbol_index: u32, rel_type: u32, module_name: static u8&) -> void:
    if slot_va == 0:
        return
    # De-duplicate: relocation passes can run more than once. Prefer a
    # non-empty symbol name / valid index if a later pass supplies one.
    existing: s32 = _fallback_find_index(slot_va)
    if existing >= 0:
        idx: u32 = existing.u32()
        if idx < FALLBACK_SLOT_CAP:
            if _fallback_slot_is_empty(g_fallback_slot_names[idx.usize()]) and not _fallback_slot_is_empty(name):
                g_fallback_slot_names[idx.usize()] <- name
            if g_fallback_slot_symbol_indices[idx.usize()] == 0 and symbol_index != 0:
                g_fallback_slot_symbol_indices[idx.usize()] <- symbol_index
            if g_fallback_slot_rel_types[idx.usize()] == 0 and rel_type != 0:
                g_fallback_slot_rel_types[idx.usize()] <- rel_type
            if _fallback_slot_is_empty(g_fallback_slot_modules[idx.usize()]) and not _fallback_slot_is_empty(module_name):
                g_fallback_slot_modules[idx.usize()] <- module_name
        return
    if g_fallback_slot_count >= FALLBACK_SLOT_CAP:
        return
    idx: u32 = g_fallback_slot_count
    if idx < FALLBACK_SLOT_CAP:
        g_fallback_slot_addrs[idx.usize()] <- slot_va
        g_fallback_slot_names[idx.usize()] <- name
        g_fallback_slot_modules[idx.usize()] <- module_name
        g_fallback_slot_symbol_indices[idx.usize()] <- symbol_index
        g_fallback_slot_rel_types[idx.usize()] <- rel_type
        g_fallback_slot_count <- g_fallback_slot_count + 1

def c_GuestExec_ResetFallbackSlots() -> void:
    g_fallback_slot_count <- 0

def c_GuestExec_FindFallbackSymbolBySlot(slot_va: u64) -> static u8&?:
    index: s32 = _fallback_find_index(slot_va)
    if index >= 0 and index.u32() < FALLBACK_SLOT_CAP:
        return g_fallback_slot_names[index.usize()]
    return null

def c_GuestExec_FindFallbackModuleBySlot(slot_va: u64) -> static u8&?:
    index: s32 = _fallback_find_index(slot_va)
    if index >= 0 and index.u32() < FALLBACK_SLOT_CAP:
        return g_fallback_slot_modules[index.usize()]
    return null

def c_GuestExec_FindFallbackSymbolIndexBySlot(slot_va: u64) -> u32:
    index: s32 = _fallback_find_index(slot_va)
    if index >= 0 and index.u32() < FALLBACK_SLOT_CAP:
        return g_fallback_slot_symbol_indices[index.usize()]
    return 0

def c_GuestExec_FindFallbackRelTypeBySlot(slot_va: u64) -> u32:
    index: s32 = _fallback_find_index(slot_va)
    if index >= 0 and index.u32() < FALLBACK_SLOT_CAP:
        return g_fallback_slot_rel_types[index.usize()]
    return 0

def c_GuestExec_FindFallbackSlotIndexBySlot(slot_va: u64) -> s32:
    return _fallback_find_index(slot_va)

def c_GuestExec_FallbackSlotCount() -> u32:
    return g_fallback_slot_count

def c_GuestExec_FallbackSlotVaAt(index: u32) -> u64:
    if index < g_fallback_slot_count and index < FALLBACK_SLOT_CAP:
        return g_fallback_slot_addrs[index.usize()]
    return 0

def c_GuestExec_FallbackSlotSymbolAt(index: u32) -> static u8&?:
    if index < g_fallback_slot_count and index < FALLBACK_SLOT_CAP:
        return g_fallback_slot_names[index.usize()]
    return null

def c_GuestExec_FallbackSlotModuleAt(index: u32) -> static u8&?:
    if index < g_fallback_slot_count and index < FALLBACK_SLOT_CAP:
        return g_fallback_slot_modules[index.usize()]
    return null

def c_GuestExec_FallbackSlotSymbolIndexAt(index: u32) -> u32:
    if index < g_fallback_slot_count and index < FALLBACK_SLOT_CAP:
        return g_fallback_slot_symbol_indices[index.usize()]
    return 0

def c_GuestExec_FallbackSlotRelTypeAt(index: u32) -> u32:
    if index < g_fallback_slot_count and index < FALLBACK_SLOT_CAP:
        return g_fallback_slot_rel_types[index.usize()]
    return 0

