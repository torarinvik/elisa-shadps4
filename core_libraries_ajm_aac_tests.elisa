include "../compiler/runtime/elisacore_std/elisacore_runtime.elisa"
include "./core/libraries/ajm/ajm_aac.elisa"
include "./core/libraries/ajm/ajm_at9.elisa"

@test
def ajm_aac_mapping_and_validation_helpers() -> void:
    can Abort.Panic:
        assert AjmAac_TransportTypeFromConfigType(0) == AjmAacTransportType_Invalid
        assert AjmAac_TransportTypeFromConfigType(ConfigType_ADTS) == AjmAacTransportType_Adts
        assert AjmAac_TransportTypeFromConfigType(ConfigType_RAW) == AjmAacTransportType_Raw

        assert AjmAac_ChannelConfigFromChannels(0) == 2
        assert AjmAac_ChannelConfigFromChannels(2) == 2
        assert AjmAac_ChannelConfigFromChannels(7) == 11
        assert AjmAac_ChannelConfigFromChannels(8) == 12
        assert AjmAac_ChannelConfigFromChannels(9) == AjmAacChannelConfig_Invalid

        assert AjmAac_IsValidSamplingFreqType(0)
        assert AjmAac_IsValidSamplingFreqType((AjmAacFreqCount - 1).u32())
        assert not AjmAac_IsValidSamplingFreqType(AjmAacFreqCount.u32())

        # Upstream C++ stub: sceAjmDecAt9ParseConfigData returns ORBIS_OK unconditionally.
        assert sceAjmDecAt9ParseConfigData() == ORBIS_OK
