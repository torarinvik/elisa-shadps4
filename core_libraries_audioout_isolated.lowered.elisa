        state: heap PackedStoreState& = state_bits.cast[heap PackedStoreState&]
        state.side_words <- side_words
        return state_bits

def ctx_packed_store_alloc_fixed_tagged_result(a: mutable Arena&, state_bits: mutable void&, tag: u32) -> PackedStoreAllocResult:
    can Memory.Allocate, Abort.Panic:
        result: PackedStoreAllocResult = ctx_packed_store_alloc_fixed_result(a, state_bits)
        state: PackedStoreState& = state_bits.cast[PackedStoreState&]
        needed_rows: mutable usize = (state.tags.count + 1)
        if (needed_rows < state.handles.count):
            needed_rows <- state.handles.count
        packed_store_ensure_metadata_capacity(a, state, needed_rows)
        in a:
            state.tags.push(tag)
        return result

def ctx_packed_store_alloc_fixed_tagged_index_result(a: mutable Arena&, state_bits: mutable void&, tag: u32) -> PackedStoreIndexAllocResult:
    can Memory.Allocate, Abort.Panic:
        result: PackedStoreAllocResult = ctx_packed_store_alloc_fixed_tagged_result(a, state_bits, tag)
        state: PackedStoreState& = state_bits.cast[PackedStoreState&]
        assert((state.indices.items != null))
        assert((state.indices.count > 0))
        indices: u32& = state.indices.items
        return PackedStoreIndexAllocResult(result.row, indices[(state.indices.count - 1)])

def ctx_packed_store_record_side_words(a: mutable Arena&, words: void&, state_bits: mutable void&):
    can Memory.Allocate, Abort.Panic:
        assert((state_bits != null))
        state: PackedStoreState& = state_bits.cast[PackedStoreState&]
        packed_store_append_side_words(a, state, words)

def ctx_packed_store_read_side_word(state_bits: mutable void&, index: u32, word_offset: usize) -> uintptr:
    can Abort.Panic:
        assert((state_bits != null))
