const SDL_INIT_AUDIO: u32 = 0x00000010u32

global mutable audio_sdl_ready: bool = false

global mutable audio_openal_probe: void&? = null

global mutable audioout_sdl_device_ids: u32[25] = zeroed

global mutable audioin_sdl_device_ids: u32[7] = zeroed

global mutable audioout_openal_source_ids: u32[25] = zeroed

global mutable audioout_openal_buf_ids: u32[150] = zeroed

global mutable audioout_openal_next_buf: s32[25] = zeroed

const AL_FORMAT_MONO16: s32 = 0x1101

const AL_FORMAT_STEREO16: s32 = 0x1103

const AL_FORMAT_MONO_FLOAT32: s32 = 0x10010

const AL_FORMAT_STEREO_FLOAT32: s32 = 0x10011

const AL_BUFFERS_PROCESSED: s32 = 0x1016

const AL_BUFFERS_QUEUED: s32 = 0x1015

const AL_SOURCE_STATE: s32 = 0x1010

const AL_PLAYING: s32 = 0x1012

const AL_GAIN: s32 = 0x100A

def AudioFFI_InitSDL() -> s32:
    if audio_sdl_ready:
        return ORBIS_OK
    rc: s32 = SDL_Init(SDL_INIT_AUDIO)
    if (rc != 0):
        return ORBIS_AUDIO_OUT_ERROR_NOT_OPENED
    audio_sdl_ready <- true
    return ORBIS_OK

def AudioFFI_QuitSDL() -> void:
    if audio_sdl_ready:
        SDL_Quit()
        audio_sdl_ready <- false

def AudioFFI_IsSDLReady() -> bool:
    return audio_sdl_ready

def AudioFFI_ProbeOpenAL() -> bool:
    if (audio_openal_probe != null):
        return true
    dev: void&? = alcOpenDevice(null)
    if (dev == null):
        return false
    audio_openal_probe <- dev
    return true

def AudioFFI_CloseOpenALProbe() -> void:
    if (audio_openal_probe != null):
        _ = alcCloseDevice(audio_openal_probe as void&)
        audio_openal_probe <- null

def AudioFFI_AudioOutSDLOpen(port_id: s32) -> bool:
    if ((port_id < 0) or (port_id >= ORBIS_AUDIO_OUT_NUM_PORTS)):
        return false
    if (AudioFFI_InitSDL() != ORBIS_OK):
        return false
    dev: u32 = SDL_OpenAudioDevice(0u32, null)
    if (dev == 0u32):
        return false
    if (SDL_ResumeAudioDevice(dev) != 0):
        SDL_CloseAudioDevice(dev)
        return false
    audioout_sdl_device_ids[port_id] <- dev
    return true

def AudioFFI_AudioOutSDLClose(port_id: s32) -> void:
    if ((port_id < 0) or (port_id >= ORBIS_AUDIO_OUT_NUM_PORTS)):
        return
    dev: u32 = audioout_sdl_device_ids[port_id]
    if (dev != 0u32):
        _ = SDL_PauseAudioDevice(dev)
        SDL_CloseAudioDevice(dev)
        audioout_sdl_device_ids[port_id] <- 0u32

def AudioFFI_AudioOutSDLQueue(port_id: s32, data: void&, len: u32) -> s32:
    if ((port_id < 0) or (port_id >= ORBIS_AUDIO_OUT_NUM_PORTS)):
        return (-1)
    dev: u32 = audioout_sdl_device_ids[port_id]
    if (dev == 0u32):
        return (-1)
    return SDL_QueueAudio(dev, data, len)

def AudioFFI_AudioInSDLOpen(port_id: s32) -> bool:
    if ((port_id < 0) or (port_id >= ORBIS_AUDIO_IN_NUM_PORTS)):
        return false
    if (AudioFFI_InitSDL() != ORBIS_OK):
        return false
    dev: u32 = SDL_OpenAudioDevice(0xFFFFFFFFu32, null)
    if (dev == 0u32):
        return false
    if (SDL_ResumeAudioDevice(dev) != 0):
        SDL_CloseAudioDevice(dev)
        return false
    audioin_sdl_device_ids[port_id] <- dev
    return true

def AudioFFI_AudioInSDLClose(port_id: s32) -> void:
    if ((port_id < 0) or (port_id >= ORBIS_AUDIO_IN_NUM_PORTS)):
        return
    dev: u32 = audioin_sdl_device_ids[port_id]
    if (dev != 0u32):
        _ = SDL_PauseAudioDevice(dev)
        SDL_CloseAudioDevice(dev)
        audioin_sdl_device_ids[port_id] <- 0u32

def AudioFFI_AudioInSDLRead(port_id: s32, out_data: mutable void&, len: u32) -> u32:
    if ((port_id < 0) or (port_id >= ORBIS_AUDIO_IN_NUM_PORTS)):
        return 0u32
    dev: u32 = audioin_sdl_device_ids[port_id]
    if (dev == 0u32):
        return 0u32
    return SDL_DequeueAudio(dev, out_data, len)

struct AudioOutNidEntry:
    nid: static u8&
    lib_name: static u8&
    export_lib: static u8&
    symbol_name: static u8&

const AUDIOOUT_NIDS_COUNT: usize = 69

def AudioOut_NidEntryAt(index: usize) -> AudioOutNidEntry:
    if (index == 0usize):
        return AudioOutNidEntry("cx2dYFbzIAg", "libSceAudioOutDeviceService", "libSceAudioOut", "sceAudioOutDeviceIdOpen")
    if (index == 1usize):
        return AudioOutNidEntry("Iz9X7ISldhs", "libSceAudioOut", "libSceAudioOut", "sceAudioOutA3dControl")
    if (index == 2usize):
        return AudioOutNidEntry("9RVIoocOVAo", "libSceAudioOut", "libSceAudioOut", "sceAudioOutA3dExit")
    if (index == 3usize):
        return AudioOutNidEntry("n7KgxE8rOuE", "libSceAudioOut", "libSceAudioOut", "sceAudioOutA3dInit")
    if (index == 4usize):
        return AudioOutNidEntry("WBAO6-n0-4M", "libSceAudioOut", "libSceAudioOut", "sceAudioOutAttachToApplicationByPid")
    if (index == 5usize):
        return AudioOutNidEntry("O3FM2WXIJaI", "libSceAudioOut", "libSceAudioOut", "sceAudioOutChangeAppModuleState")
    if (index == 6usize):
        return AudioOutNidEntry("s1--uE9mBFw", "libSceAudioOut", "libSceAudioOut", "sceAudioOutClose")
    if (index == 7usize):
        return AudioOutNidEntry("ol4LbeTG8mc", "libSceAudioOut", "libSceAudioOut", "sceAudioOutDetachFromApplicationByPid")
    if (index == 8usize):
        return AudioOutNidEntry("r1V9IFEE+Ts", "libSceAudioOut", "libSceAudioOut", "sceAudioOutExConfigureOutputMode")
    if (index == 9usize):
        return AudioOutNidEntry("wZakRQsWGos", "libSceAudioOut", "libSceAudioOut", "sceAudioOutExGetSystemInfo")
    if (index == 10usize):
