def SDLAudioOut_Open(port: void&?) -> void&?:
    if (port == null):
        return null
    if (AudioFFI_InitSDL() != ORBIS_OK):
        return null
    return port

def OpenALAudioOut_Open(port: void&?) -> void&?:
    if (port == null):
        return null
    if (not AudioFFI_ProbeOpenAL()):
        return null
    return port

def OpenALManager_Init() -> s32:
    if (not AudioFFI_ProbeOpenAL()):
        return ORBIS_AUDIO_OUT_ERROR_NOT_OPENED
    return ORBIS_OK

def OpenALManager_Shutdown() -> void:
    AudioFFI_CloseOpenALProbe()

