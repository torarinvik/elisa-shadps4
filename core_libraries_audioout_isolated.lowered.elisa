def audioout_get_port_id(handle: s32) -> s32:
    pid: s32 = (handle & 0xff)
    if ((pid < 0) or (pid >= ORBIS_AUDIO_OUT_NUM_PORTS)):
        return ORBIS_AUDIO_OUT_ERROR_INVALID_PORT
    if (((handle & 0x3f000000)) != AUDIOOUT_HANDLE_TAG):
        return ORBIS_AUDIO_OUT_ERROR_INVALID_PORT
    return pid

def audioout_get_port_type_from_handle(handle: s32) -> s32:
    return (((handle >> 16)) & 0xff)

def audioout_valid_runtime_port_type(pt: s32) -> bool:
    return (((((((pt >= 0) and (pt <= 4))) or (pt == 14)) or (pt == 126)) or (pt == 127)))

def audioout_valid_open_port_type(pt: s32) -> bool:
    return ((((((pt >= 0) and (pt <= 4))) or (pt == 126)) or (pt == 127)))

def audioout_alloc_port_in_range(start: s32, end: s32) -> s32:
    i: mutable s32 = start
    while (i <= end):
        if (not audioout_open_mask[i]):
            return i
        i <- (i + 1)
    return (-1)

def audioout_alloc_port_for_type(pt: s32) -> s32:
    if (pt == 0):
        return audioout_alloc_port_in_range(0, 7)
    if (pt == 1):
        return audioout_alloc_port_in_range(8, 8)
    if (pt == 2):
        return audioout_alloc_port_in_range(9, 12)
    if (pt == 3):
        return audioout_alloc_port_in_range(13, 16)
    if (pt == 4):
        return audioout_alloc_port_in_range(17, 20)
    if (pt == 126):
        return audioout_alloc_port_in_range(22, 22)
    if (pt == 127):
        return audioout_alloc_port_in_range(23, 23)
    return (-1)

# @port core/libraries/audio/audioout.cpp::sceAudioOutInit sha256=64a665d73db28510 oracle@a3773841
def sceAudioOutInit() -> s32:
    if audioout_inited:
        return ORBIS_AUDIO_OUT_ERROR_ALREADY_INIT
    audioout_inited <- true
    return ORBIS_OK

def sceAudioOutSelectBackendOpenAL(enable: bool) -> s32:
    if enable:
        rc: s32 = OpenALManager_Init()
        if (rc < 0):
            return rc
    else:
        OpenALManager_Shutdown()
    audioout_backend_mode_openal <- enable
    return ORBIS_OK

def sceAudioOutSetOutputParamLayout64(is_64bit: bool) -> s32:
    if is_64bit:
        audioout_param_stride_bytes <- 16usize
        audioout_param_ptr_offset_bytes <- 8usize
        audioout_param_ptr_width_bytes <- 8usize
    else:
        audioout_param_stride_bytes <- 8usize
        audioout_param_ptr_offset_bytes <- 4usize
        audioout_param_ptr_width_bytes <- 4usize
    return ORBIS_OK

# @port core/libraries/audio/audioout.cpp::sceAudioOutOpen sha256=cef1d4ea573d522a oracle@a3773841
def sceAudioOutOpen(user_id: s32, port_type: s32, index: s32, length: u32, sample_rate: u32, param_type: u32) -> s32:
    _ = user_id
    _ = index
    if (not audioout_inited):
        return ORBIS_AUDIO_OUT_ERROR_NOT_INIT
    if (((length == 0u32) or (length > 2048u32)) or (((length & 0xffu32)) != 0u32)):
        return ORBIS_AUDIO_OUT_ERROR_INVALID_SIZE
    if (sample_rate != 48000u32):
        return ORBIS_AUDIO_OUT_ERROR_INVALID_SAMPLE_FREQ
    if (not audioout_valid_open_port_type(port_type)):
        return ORBIS_AUDIO_OUT_ERROR_INVALID_PORT_TYPE
    param_raw: u32 = param_type
    if ((port_type != 3) and (((param_raw & 0x00020000u32)) != 0u32)):
        return ORBIS_AUDIO_OUT_ERROR_INVALID_FORMAT
    if ((port_type != 0) and (((param_raw & 0x70000000u32)) != 0u32)):
        return ORBIS_AUDIO_OUT_ERROR_INVALID_FORMAT
    attrs: u32 = (((param_raw >> 16u32)) & 0x0fu32)
    if (attrs > 2u32):
        return ORBIS_AUDIO_OUT_ERROR_INVALID_FORMAT
    data_format: u32 = (param_type & 0xffu32)
    if (data_format > 7u32):
        return ORBIS_AUDIO_OUT_ERROR_INVALID_FORMAT
    frame_bytes: mutable u32 = 0u32
    if (data_format == 0u32):
        frame_bytes <- 2u32
    if (data_format == 1u32):
        frame_bytes <- 4u32
    if (data_format == 2u32):
        frame_bytes <- 16u32
    if (data_format == 3u32):
        frame_bytes <- 4u32
    if (data_format == 4u32):
        frame_bytes <- 8u32
    if (data_format == 5u32):
        frame_bytes <- 32u32
    if (data_format == 6u32):
        frame_bytes <- 16u32
    if (data_format == 7u32):
        frame_bytes <- 32u32
    pid: s32 = audioout_alloc_port_for_type(port_type)
    if (pid < 0):
        return ORBIS_AUDIO_OUT_ERROR_PORT_FULL
    backend_ok: mutable bool = false
    if audioout_backend_mode_openal:
        backend_ok <- ((OpenALAudioOut_Open(1 as void&?) != null) and audioout_openal_init_port(pid))
    else:
        backend_ok <- ((SDLAudioOut_Open(1 as void&?) != null) and AudioFFI_AudioOutSDLOpen(pid))
    if (not backend_ok):
        return ORBIS_AUDIO_OUT_ERROR_TRANS_EVENT
    audioout_open_mask[pid] <- true
    audioout_backend_open[pid] <- true
    audioout_backend_is_openal[pid] <- audioout_backend_mode_openal
    audioout_type[pid] <- port_type
    audioout_frames[pid] <- length
    audioout_data_format[pid] <- data_format
    audioout_frame_bytes[pid] <- frame_bytes
    audioout_last_time[pid] <- 0u64
    vbase: mutable s32 = (pid * 8)
    vi: mutable s32 = 0
    while (vi < 8):
        audioout_volume[(vbase + vi)] <- ORBIS_AUDIO_OUT_VOLUME_0DB
        vi <- (vi + 1)
    return ((AUDIOOUT_HANDLE_TAG | ((((port_type & 0xff)) << 16))) | pid)

# @port core/libraries/audio/audioout.cpp::sceAudioOutClose sha256=cc602756e4a26161 oracle@a3773841
def sceAudioOutClose(handle: s32) -> s32:
    if (not audioout_inited):
        return ORBIS_AUDIO_OUT_ERROR_NOT_INIT
    pid: s32 = audioout_get_port_id(handle)
    if (pid < 0):
        return pid
    pt: s32 = audioout_get_port_type_from_handle(handle)
    if ((pt >= 5) and (pt <= 13)):
        return ORBIS_AUDIO_OUT_ERROR_INVALID_PORT_TYPE
    if (not audioout_valid_runtime_port_type(pt)):
        return ORBIS_AUDIO_OUT_ERROR_INVALID_PORT_TYPE
    if (not audioout_open_mask[pid]):
        return ORBIS_AUDIO_OUT_ERROR_NOT_OPENED
    audioout_open_mask[pid] <- false
    audioout_backend_open[pid] <- false
    if audioout_backend_is_openal[pid]:
        audioout_openal_close_port(pid)
    else:
        AudioFFI_AudioOutSDLClose(pid)
    audioout_last_time[pid] <- 0u64
    audioout_data_format[pid] <- 0u32
    audioout_frame_bytes[pid] <- 0u32
    audioout_backend_is_openal[pid] <- false
    return ORBIS_OK

# @port core/libraries/audio/audioout.cpp::sceAudioOutGetLastOutputTime sha256=c60a3db58d365935 oracle@a3773841
def sceAudioOutGetLastOutputTime(handle: s32, output_time: mutable u64&?) -> s32:
    if (not audioout_inited):
        return ORBIS_AUDIO_OUT_ERROR_NOT_INIT
    pid: s32 = audioout_get_port_id(handle)
    if (pid < 0):
        return pid
    if (output_time == null):
        return ORBIS_AUDIO_OUT_ERROR_INVALID_POINTER
    if (not audioout_open_mask[pid]):
        return ORBIS_AUDIO_OUT_ERROR_NOT_OPENED
    output_time[0] <- audioout_last_time[pid]
    return ORBIS_OK

# @port core/libraries/audio/audioout.cpp::sceAudioOutGetPortState sha256=93bbe91d91b6ef36 oracle@a3773841
def sceAudioOutGetPortState(handle: s32, state: void&?) -> s32:
    if (not audioout_inited):
        return ORBIS_AUDIO_OUT_ERROR_NOT_INIT
    pid: s32 = audioout_get_port_id(handle)
    if (pid < 0):
        return pid
    if (state == null):
        return ORBIS_AUDIO_OUT_ERROR_INVALID_POINTER
    if (not audioout_open_mask[pid]):
        return ORBIS_AUDIO_OUT_ERROR_NOT_OPENED
    st: mutable u8& = state as mutable u8&
    _ = memset(st as mutable void&, 0, 32usize)
    pt: s32 = audioout_type[pid]
    fmt: u32 = audioout_data_format[pid]
    output: mutable u16 = 0u16
    channel: mutable u8 = 0u8
    volume: mutable s16 = (-1i16)
    ch_count: mutable u8 = 1u8
    if ((fmt == 1u32) or (fmt == 4u32)):
        ch_count <- 2u8
    if ((((fmt == 2u32) or (fmt == 5u32)) or (fmt == 6u32)) or (fmt == 7u32)):
        ch_count <- 8u8
    if (((pt == 0) or (pt == 1)) or (pt == 126)):
        output <- 0x01u16
        if (ch_count > 2u8):
            channel <- 2u8
        else:
            channel <- ch_count
    if ((pt == 2) or (pt == 3)):
        output <- 0x40u16
        channel <- 1u8
    if (pt == 4):
        output <- 0x04u16
        channel <- 1u8
        volume <- 127i16
    if (pt == 127):
        output <- 0x80u16
        channel <- 0u8
    _ = memcpy(((st + 0usize)) as mutable void&, (output as u16&) as void&, 2usize)
    _ = memcpy(((st + 2usize)) as mutable void&, (channel as u8&) as void&, 1usize)
    _ = memcpy(((st + 4usize)) as mutable void&, (volume as s16&) as void&, 2usize)
    return ORBIS_OK

# @port core/libraries/audio/audioout.cpp::sceAudioOutOutput sha256=7cf782cd92671bf3 oracle@a3773841
def sceAudioOutOutput(handle: s32, ptr: mutable u8&?) -> s32:
    if (not audioout_inited):
        return ORBIS_AUDIO_OUT_ERROR_NOT_INIT
    pid: s32 = audioout_get_port_id(handle)
    if (pid < 0):
        return pid
    pt: s32 = audioout_get_port_type_from_handle(handle)
    if ((pt >= 5) and (pt <= 13)):
        return ORBIS_AUDIO_OUT_ERROR_INVALID_PORT_TYPE
    if (not audioout_valid_runtime_port_type(pt)):
        return ORBIS_AUDIO_OUT_ERROR_INVALID_PORT_TYPE
    if (not audioout_open_mask[pid]):
        return ORBIS_AUDIO_OUT_ERROR_NOT_OPENED
    if (ptr == null):
        return 0
    bytes_len: u32 = (audioout_frames[pid] * audioout_frame_bytes[pid])
    if audioout_backend_is_openal[pid]:
        fmt: s32 = audioout_openal_select_format(pid)
        if (fmt == 0):
            return ORBIS_AUDIO_OUT_ERROR_INVALID_FORMAT
        prep_ptr: void& = ptr as void&
        prep_size: mutable s32 = bytes_len as s32
        queue_ptr: void& = audioout_openal_prepare_data(pid, prep_ptr, fmt, prep_size)
        if (not audioout_openal_queue(pid, queue_ptr, prep_size, 48000, fmt)):
            return ORBIS_AUDIO_OUT_ERROR_TRANS_EVENT
    else:
        if (AudioFFI_AudioOutSDLQueue(pid, ptr as void&, bytes_len) != 0):
            return ORBIS_AUDIO_OUT_ERROR_TRANS_EVENT
    audioout_last_time[pid] <- (audioout_last_time[pid] + 1u64)
    ch: mutable s32 = 1
    fmt: u32 = audioout_data_format[pid]
    if ((fmt == 1u32) or (fmt == 4u32)):
        ch <- 2
    if ((((fmt == 2u32) or (fmt == 5u32)) or (fmt == 6u32)) or (fmt == 7u32)):
        ch <- 8
    ret_frames: u32 = audioout_frames[pid]
    return ((ret_frames as s32) * ch)

# @port core/libraries/audio/audioout.cpp::sceAudioOutOutputs sha256=d411dadf45cb72f2 oracle@a3773841
def sceAudioOutOutputs(param: void&?, num: u32) -> s32:
    if (not audioout_inited):
        return ORBIS_AUDIO_OUT_ERROR_NOT_INIT
    if ((num == 0u32) or (num > ORBIS_AUDIO_OUT_NUM_PORTS)):
        return ORBIS_AUDIO_OUT_ERROR_PORT_FULL
    if (param == null):
        return ORBIS_AUDIO_OUT_ERROR_INVALID_POINTER
    if (not audioout_decode_output_params_default(param, num)):
        return ORBIS_AUDIO_OUT_ERROR_INVALID_POINTER
    return sceAudioOutOutputsEx(audioout_decode_handles_buf[0], audioout_decode_ptrs_buf[0], num)

def sceAudioOutOutputsEx(handles: s32&, buffers: void&?, num: u32) -> s32:
    if (not audioout_inited):
        return ORBIS_AUDIO_OUT_ERROR_NOT_INIT
    if ((num == 0u32) or (num > ORBIS_AUDIO_OUT_NUM_PORTS)):
        return ORBIS_AUDIO_OUT_ERROR_PORT_FULL
    if (handles == null):
        return ORBIS_AUDIO_OUT_ERROR_INVALID_POINTER
    num_s32: s32 = num.s32()
    i: mutable s32 = 0
    while (i < num_s32):
        h: s32 = handles[i]
        pid: s32 = audioout_get_port_id(h)
        if (pid < 0):
            return pid
        pt: s32 = audioout_get_port_type_from_handle(h)
        if ((pt >= 5) and (pt <= 13)):
            return ORBIS_AUDIO_OUT_ERROR_INVALID_PORT_TYPE
        if (not audioout_valid_runtime_port_type(pt)):
            return ORBIS_AUDIO_OUT_ERROR_INVALID_PORT_TYPE
        j: mutable s32 = 0
        while (j < i):
            if (h == handles[j]):
                return ORBIS_AUDIO_OUT_ERROR_INVALID_PORT
            j <- (j + 1)
        if (not audioout_open_mask[pid]):
            return ORBIS_AUDIO_OUT_ERROR_NOT_OPENED
        i <- (i + 1)
    frames: u32 = audioout_frames[audioout_get_port_id(handles[0])]
    i <- 0
    while (i < num_s32):
        h2: s32 = handles[i]
        pid2: s32 = audioout_get_port_id(h2)
        if (audioout_frames[pid2] != frames):
            return ORBIS_AUDIO_OUT_ERROR_INVALID_SIZE
        if (buffers != null):
            ptrs: void&?& = buffers as void&?&
            out_ptr: void&? = ptrs[i]
            if (out_ptr != null):
                out_rc: s32 = sceAudioOutOutput(h2, out_ptr as mutable u8&?)
                if (out_rc < 0):
                    return out_rc
            else:
                _ = sceAudioOutOutput(h2, null)
        i <- (i + 1)
    frames_s32: s32 = frames as s32
    return frames_s32

def audioout_decode_output_params_default(param: void&?, num: u32) -> bool:
    if (param == null):
        return false
    if ((num == 0u32) or (num > ORBIS_AUDIO_OUT_NUM_PORTS)):
        return false
    stride: usize = audioout_param_stride_bytes
    base: u8& = param as u8&
    num_s32: s32 = num.s32()
    i: mutable s32 = 0
    while (i < num_s32):
        off: usize = ((i as usize) * stride)
        src_h: void& = ((base + off)) as void&
        handle_slot: mutable s32 = 0
        _ = memcpy(handle_slot as mutable void&, src_h, 4usize)
        audioout_decode_handles_buf[i as usize] <- handle_slot
        ptr_off: usize = (off + audioout_param_ptr_offset_bytes)
        src_p: void& = ((base + ptr_off)) as void&
        ptr_word: mutable u64 = 0u64
        _ = memcpy(ptr_word as mutable void&, src_p, audioout_param_ptr_width_bytes)
        audioout_decode_ptrs_buf[i as usize] <- ptr_word.cast[void&?]
        i <- (i + 1)
    return true

# @port core/libraries/audio/audioout.cpp::sceAudioOutSetVolume sha256=785a4d4efedcd829 oracle@a3773841
def sceAudioOutSetVolume(handle: s32, flag: s32, vol: mutable s32&?) -> s32:
    if (not audioout_inited):
        return ORBIS_AUDIO_OUT_ERROR_NOT_INIT
    pid: s32 = audioout_get_port_id(handle)
    if (pid < 0):
        return pid
    pt: s32 = audioout_get_port_type_from_handle(handle)
    if ((pt >= 5) and (pt <= 13)):
        return ORBIS_AUDIO_OUT_ERROR_INVALID_PORT_TYPE
    if (not audioout_valid_runtime_port_type(pt)):
        return ORBIS_AUDIO_OUT_ERROR_INVALID_PORT_TYPE
    if (vol == null):
        return ORBIS_AUDIO_OUT_ERROR_INVALID_POINTER
    if (vol[0] > ORBIS_AUDIO_OUT_VOLUME_0DB):
        return ORBIS_AUDIO_OUT_ERROR_INVALID_VOLUME
    if (not audioout_open_mask[pid]):
        return ORBIS_AUDIO_OUT_ERROR_NOT_OPENED
    base: s32 = (pid * 8)
    v: s32 = vol[0]
    uflag: u32 = flag.u32()
    if (((uflag & ORBIS_AUDIO_VOLUME_FLAG_L_CH)) != 0u32):
        audioout_volume[(base + 0)] <- v
    if (((uflag & ORBIS_AUDIO_VOLUME_FLAG_R_CH)) != 0u32):
        audioout_volume[(base + 1)] <- v
    if (((uflag & ORBIS_AUDIO_VOLUME_FLAG_C_CH)) != 0u32):
        audioout_volume[(base + 2usize)] <- v
    if (((uflag & ORBIS_AUDIO_VOLUME_FLAG_LFE_CH)) != 0u32):
        audioout_volume[(base + 3usize)] <- v
    if (((uflag & ORBIS_AUDIO_VOLUME_FLAG_LS_CH)) != 0u32):
        audioout_volume[(base + 4usize)] <- v
    if (((uflag & ORBIS_AUDIO_VOLUME_FLAG_RS_CH)) != 0u32):
        audioout_volume[(base + 5usize)] <- v
    if (((uflag & ORBIS_AUDIO_VOLUME_FLAG_LE_CH)) != 0u32):
        audioout_volume[(base + 6usize)] <- v
    if (((uflag & ORBIS_AUDIO_VOLUME_FLAG_RE_CH)) != 0u32):
        audioout_volume[(base + 7usize)] <- v
    return ORBIS_OK

# @port core/libraries/audio/audioout.cpp::sceAudioOutSetMixLevelPadSpk sha256=fb84ad267fcc7302 oracle@a3773841
def sceAudioOutSetMixLevelPadSpk(handle: s32, mixLevel: s32) -> s32:
    if (not audioout_inited):
        return ORBIS_AUDIO_OUT_ERROR_NOT_INIT
    pid: s32 = audioout_get_port_id(handle)
    if (pid < 0):
        return pid
    if (audioout_get_port_type_from_handle(handle) != 4):
        return ORBIS_AUDIO_OUT_ERROR_INVALID_PORT_TYPE
    if (mixLevel > ORBIS_AUDIO_OUT_VOLUME_0DB):
        return ORBIS_AUDIO_OUT_ERROR_INVALID_MIXLEVEL
    if (not audioout_open_mask[pid]):
        return ORBIS_AUDIO_OUT_ERROR_NOT_OPENED
    audioout_mixlevel_padspk[pid] <- mixLevel
    return ORBIS_OK

