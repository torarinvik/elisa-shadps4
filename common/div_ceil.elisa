def DivCeil(number: usize, divisor: usize) -> usize:
    return 0 if divisor == 0 else (number + divisor - 1) / divisor

def DivCeilLog2(value: usize, alignment_log2: usize) -> usize:
    alignment: usize = 1 << alignment_log2
    return DivCeil(value, alignment)

