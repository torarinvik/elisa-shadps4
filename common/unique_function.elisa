struct UniqueFunction:
    callable: mutable void&?

extern unique_function_call(callable: void&) -> void
extern unique_function_destroy(callable: void&) -> void

def UniqueFunction_new(callable: void&?) -> UniqueFunction:
    return UniqueFunction(callable)

def UniqueFunction_call(self: UniqueFunction&) -> void:
    if self.callable != null:
        unique_function_call(self.callable.cast[void&])

def UniqueFunction_reset(self: mutable UniqueFunction&) -> void:
    if self.callable != null:
        unique_function_destroy(self.callable.cast[void&])
        self.callable <- null

