type s8 = i8
type s16 = i16
type s32 = i32
type s64 = i64
type VAddr = uintptr
type PAddr = uintptr

struct u128:
    lo: mutable u64
    hi: mutable u64

def KB(x: u64) -> u64:
    return x * 1024

def MB(x: u64) -> u64:
    return x * 1024 * 1024

def GB(x: u64) -> u64:
    return x * 1024 * 1024 * 1024

