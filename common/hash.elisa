def HashCombine64(seed: u64, hash: u64) -> u64:
    return seed ^ (hash + 0x9e3779b97f4a7c15 + (seed << 6) + (seed >> 2))

def HashCombine32(seed: u32, hash: u32) -> u32:
    return seed ^ (hash + 0x9e3779b9.u32() + (seed << 6) + (seed >> 2))

