struct VaList:
    gp_offset: mutable u32
    fp_offset: mutable u32
    overflow_arg_area: mutable void&?
    reg_save_area: mutable void&?

struct VaRegSave:
    gp: mutable u64[6]
    fp: mutable u8[128]

struct VaCtx:
    list: mutable VaList
    save: mutable VaRegSave

extern va_arg_read(ctx: mutable VaCtx&, size: usize, align: usize, out: mutable void&) -> void

def VaCtx_new() -> VaCtx:
    return zeroed

def VaCtx_arg[T](ctx: mutable VaCtx&, out: mutable T&) -> void:
    va_arg_read(ctx, size_of(T), align_of(T), out.cast[mutable void&])

