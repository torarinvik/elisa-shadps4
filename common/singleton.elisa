struct Singleton[T]:
    instance: mutable heap T&?

def Singleton_new[T]() -> Singleton[T]:
    return Singleton[T](null)

def Singleton_Instance[T](self: mutable Singleton[T]&, fallback: heap T&) -> heap T&:
    if self.instance == null:
        self.instance <- fallback
    return self.instance.cast[heap T&]

