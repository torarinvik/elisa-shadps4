# Standalone streq()/sview_eq() for translation units that need C-string and
# string-view equality WITHOUT pulling in the full Elisacore std runtime. The
# runtime also defines these (runtime.elisa), so this file must NOT be combined
# with the runtime umbrella in the same program. It exists specifically for the
# PS4 kernel/emulator/loader tests, which cannot include the runtime umbrella:
# the runtime's libc bindings (exit, pthread_detach, ...) collide with the PS4
# kernel HLE's own definitions of those symbols. Such tests include this file
# (plus common/types.elisa for static_strlen/sview) instead.
include "./types.elisa"

def streq(lhs: u8&?, rhs: u8&?) -> int:
    left: u8& = lhs if lhs != null else ""
    right: u8& = rhs if rhs != null else ""
    left_len: usize = static_strlen(left)
    right_len: usize = static_strlen(right)
    if left_len != right_len:
        return 0
    # Bytes compared up to the shared length; raw C strings carry no length in
    # their type so the indexing is vouched against the measured lengths.
    trusted Unsafe.UncheckedIndex:
        i: mutable usize = 0
        while i < left_len:
            if left[i] != right[i]:
                return 0
            i <- i + 1
    return 1

# Bounds-safe equality of two string views.
def sview_eq(a: sview, b: sview) -> bool:
    if a.len != b.len:
        return false
    trusted Unsafe.UncheckedIndex:
        i: mutable usize = 0
        while i < a.len.usize():
            if a[i] != b[i]:
                return false
            i <- i + 1
    return true

# Standalone string_slice_eq() mirroring the runtime's signature, for the
# emulator/loader translation units that include this lightweight string TU
# instead of the full Elisacore std runtime. Compares value[start..end) against
# the NUL-terminated `other`. Returns 1 on equality, 0 otherwise.
def string_slice_eq(value: u8&?, start: i64, end: i64, other: u8&?) -> int:
    src: u8& = value if value != null else ""
    rhs: u8& = other if other != null else ""
    len: usize = static_strlen(src)

    lo: mutable usize = 0
    hi: mutable usize = len

    if start > 0:
        lo <- start.usize()
        if lo > len:
            lo <- len

    if end >= 0:
        hi <- end.usize()
        if hi > len:
            hi <- len

    if hi < lo:
        hi <- lo

    slice_len: usize = hi - lo
    rhs_len: usize = static_strlen(rhs)

    if slice_len != rhs_len:
        return 0

    trusted Unsafe.UncheckedIndex:
        i: mutable usize = 0
        while i < slice_len:
            if src[lo + i] != rhs[i]:
                return 0
            i <- i + 1
    return 1
