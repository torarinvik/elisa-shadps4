struct UTF:
    value: mutable static u8&

extern format_enum(value: u64) -> static u8&
extern format_utf(value: static u8&) -> static u8&

def Formatter_enum(value: u64) -> static u8&:
    return format_enum(value)

def UTF_new(value: static u8&) -> UTF:
    return UTF(value)

def Formatter_utf(value: UTF&) -> static u8&:
    return format_utf(value.value)

