enum ConfigMode:
    Default
    Global
    Clean

struct GameInstallDir:
    path: mutable static u8&
    enabled: mutable bool

global mutable config_mode: ConfigMode = ConfigMode.Default
global mutable config_values: dict[static u8&, static u8&]
global mutable settings_install_dirs: darray[GameInstallDir] = []
global mutable install_dirs_enabled: darray[bool] = []
global mutable settings_addon_install_dir: static u8& = ""
global mutable save_data_path: static u8& = ""

extern config_load_toml(path: static u8&, is_game_specific: bool) -> void
extern config_save_toml(path: static u8&, is_game_specific: bool) -> void
extern config_get_string(key: static u8&, fallback: static u8&) -> static u8&
extern config_get_bool(key: static u8&, fallback: bool) -> bool
extern config_get_int(key: static u8&, fallback: int) -> int
extern config_get_u32(key: static u8&, fallback: u32) -> u32
extern config_get_f64(key: static u8&, fallback: f64) -> f64
extern config_set_string(key: static u8&, value: static u8&, is_game_specific: bool) -> void
extern config_set_bool(key: static u8&, value: bool, is_game_specific: bool) -> void
extern config_set_int(key: static u8&, value: int, is_game_specific: bool) -> void
extern config_set_u32(key: static u8&, value: u32, is_game_specific: bool) -> void
extern config_set_f64(key: static u8&, value: f64, is_game_specific: bool) -> void

def setConfigMode(mode: ConfigMode) -> void:
    config_mode <- mode

def load(path: static u8&, is_game_specific: bool = false) -> void:
    config_load_toml(path, is_game_specific)

def save(path: static u8&, is_game_specific: bool = false) -> void:
    config_save_toml(path, is_game_specific)

def resetGameSpecificValue(entry: static u8&) -> void:
    config_set_string(entry, "", true)

