def AlignUp(value: usize, size: usize) -> usize:
    # Rounds up to a multiple of size: never moves backwards, and the result is a
    # true multiple (size==0 is the identity, guarded against modulo-by-zero).
    ensure result >= value
    ensure size == 0 or (result % size) == 0
    return value if size == 0 else ((value + size - 1) / size) * size

def AlignDown(value: usize, size: usize) -> usize:
    # Rounds down to a multiple of size: never moves forwards, and the result is a
    # true multiple (size==0 is the identity, guarded against modulo-by-zero).
    ensure result <= value
    ensure size == 0 or (result % size) == 0
    return value if size == 0 else (value / size) * size

def IsAligned(value: usize, alignment: usize) -> bool:
    if alignment == 0:
        return value == 0
    return (value & (alignment - 1)) == 0

def Is16KBAligned(value: usize) -> bool:
    return IsAligned(value, 16 * 1024)

def Is64KBAligned(value: usize) -> bool:
    return IsAligned(value, 64 * 1024)

def Is2MBAligned(value: usize) -> bool:
    return IsAligned(value, 2 * 1024 * 1024)
