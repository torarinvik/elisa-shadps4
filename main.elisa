include "./common/types.elisa"
include "./launch_cli.elisa"
include "./launch_pipeline.elisa"

def Main_Run(args: darray[static u8&]) -> int:
    parsed: ParseResult = Parse(args)
    if parsed.should_exit:
        return parsed.exit_code
    executable_name: static u8& = ""
    if args.count > 0:
        executable_name <- args[0]
    return RunParsedLaunch(executable_name, parsed.state)
