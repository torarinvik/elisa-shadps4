include "./shader_recompiler/recompiler_backend.elisa"
include "../compiler/runtime/elisacore_std/elisacore_runtime.elisa"

@test
def recompiler_bridge_rejects_missing_arguments() -> void:
    can Abort.Panic:
        out_program: mutable void&? = null
        rc: int = ShaderRecompiler_TranslateProgramViaFfi(null, 0usize, null, null, null, null, out_program)
        assert rc == ELISA_RECOMPILER_BRIDGE_INVALID_ARGS
        assert out_program == null

@test
def recompiler_bridge_valid_arguments_are_currently_unverified_gate() -> void:
    can Abort.Panic:
        code_words: mutable u32[1] = [0xdeadbeefu32]
        pools: mutable u64 = 1u64
        info: mutable u64 = 2u64
        runtime_info: mutable u64 = 3u64
        profile: mutable u64 = 4u64
        out_program: mutable void&? = null
        rc: int = ShaderRecompiler_TranslateProgramViaFfi(
            code_words[0].ref[u32&],
            1usize,
            pools.ref[mutable u64&].cast[mutable void&?],
            info.ref[mutable u64&].cast[mutable void&?],
            runtime_info.ref[mutable u64&].cast[mutable void&?],
            profile.ref[mutable u64&].cast[void&?],
            out_program
        )
        assert rc == ELISA_RECOMPILER_BRIDGE_EXCEPTION
        assert out_program == null

@test
def recompiler_bridge_free_allows_null() -> void:
    ShaderRecompiler_FreeProgramViaFfi(null)
