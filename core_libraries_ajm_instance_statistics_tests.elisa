include "../compiler/runtime/elisacore_std/elisacore_runtime.elisa"
include "./core/libraries/ajm/ajm_instance_statistics.elisa"

@test
def ajm_instance_statistics_execute_job_contract() -> void:
    can Abort.Panic:
        engine: mutable AjmSidebandStatisticsEngine = zeroed
        per_codec: mutable AjmSidebandStatisticsEnginePerCodec = zeroed
        mem: mutable AjmSidebandStatisticsMemory = zeroed

        AjmInstanceStatistics_ExecuteJob(3u32, engine.ref[mutable AjmSidebandStatisticsEngine&], per_codec.ref[mutable AjmSidebandStatisticsEnginePerCodec&], mem.ref[mutable AjmSidebandStatisticsMemory&])

        assert engine.usage_batch == 0.05
        assert engine.usage_interval[0] == 0.01
        assert engine.usage_interval[1] == 0.01
        assert engine.usage_interval[2] == 0.01

        assert per_codec.codec_count == 1u8
        assert per_codec.codec_id[0] == AjmCodecType_At9Dec.u8()
        assert per_codec.codec_percentage[0] == 0.01

        assert mem.instance_free == 0x400000u32
        assert mem.buffer_free == 0x400000u32
        assert mem.batch_size == 0x4200u32
        assert mem.input_size == 0x2000u32
        assert mem.output_size == 0x2000u32
        assert mem.small_size == 0x400u32
