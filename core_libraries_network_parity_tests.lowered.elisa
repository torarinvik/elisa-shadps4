def fail(message: cstr):
    can Abort.Panic:
        panic(message)

def assert_true(condition: bool):
    can Abort.Panic:
        if (not condition):
            panic("assert_true failed")

def assert_false(condition: bool):
    can Abort.Panic:
        if condition:
            panic("assert_false failed")

def assert_eq[T](actual: T, expected: T):
    can Abort.Panic:
        if (actual != expected):
            panic("assert_eq failed")

def assert_ne[T](actual: T, expected: T):
    can Abort.Panic:
        if (actual == expected):
            panic("assert_ne failed")

def id_invalid[T]() -> id[T]:
    return 0.u32() as id[T]

def id_valid[T](value: id[T]) -> bool:
    return ((!value) != 0)

def assert_id_valid[T](value: id[T]):
    assert_true(id_valid[T](value)) can Abort.Panic

def assert_id_invalid[T](value: id[T]):
    assert_false(id_valid[T](value)) can Abort.Panic

const ARENA_BACKEND_LIBC_MALLOC = 0

const ARENA_BACKEND_LINUX_MMAP = 1

const ARENA_BACKEND_WIN32_VIRTUALALLOC = 2

const ARENA_BACKEND_WASM_HEAPBASE = 3

const ARENA_BACKEND: int = ARENA_BACKEND_LIBC_MALLOC

const ARENA_REGION_DEFAULT_CAPACITY: usize = (8 * 1024)

const ARENA_WASM_PAGE_SIZE: usize = (64 * 1024)

error RuntimeError:
    OutOfMemory

struct Region:
    next: mutable heap Region&?
    count: mutable usize
    capacity: mutable usize
    owner_tag: mutable uintptr
    owner_next: mutable heap Region&?
    global_index: mutable usize
    data: tail uintptr

struct Arena:
    begin: mutable heap Region&?
    end: mutable heap Region&?
    end_index: mutable usize

struct ArenaMark:
    region: heap Region&?
    count: usize

static if (ARENA_BACKEND == ARENA_BACKEND_LIBC_MALLOC):
    extern malloc(size: usize) -> mutable heap void&? can[Memory.Allocate]
    extern free(ptr: heap void&) can[Memory.Release]
static elif (ARENA_BACKEND == ARENA_BACKEND_LINUX_MMAP):
    const PROT_READ = 0x1
    const PROT_WRITE = 0x2
    const MAP_PRIVATE = 0x02
    const MAP_ANONYMOUS = 0x20
    extern mmap(addr: heap void&?, length: usize, prot: int, flags: int, fd: int, offset: isize) -> mutable heap void&?
    extern munmap(addr: heap void&, length: usize) -> int
    extern MAP_FAILED() -> mutable heap void&?
static elif (ARENA_BACKEND == ARENA_BACKEND_WIN32_VIRTUALALLOC):
    const MEM_COMMIT = 0x1000
    const MEM_RESERVE = 0x2000
    const MEM_RELEASE = 0x8000
    const PAGE_READWRITE = 0x04
    extern GetCurrentProcess() -> void&
    extern VirtualAllocEx(process: void&, address: mutable heap void&?, size: usize, alloc_type: int, protect: int) -> mutable heap void&?
    extern VirtualFreeEx(process: void&, address: heap void&, size: usize, free_type: int) -> bool
static elif (ARENA_BACKEND == ARENA_BACKEND_WASM_HEAPBASE):
    extern __heap_base: heap u8&
    extern wasm_memory_size(index: int) -> int
    extern wasm_memory_grow(index: int, pages: usize) -> int
    global mutable bump_pointer: heap u8& = __heap_base

def assert(condition: bool):
    can Abort.Panic:
        if (not condition):
            panic("assert failed")

def max(a: usize, b: usize) -> usize:
    return (a if (a > b) else b)

def inv_handle(ptr: heap void&?) -> bool:
    return (ptr == null)

@internal
def arena_region_from_raw(raw: heap void&) -> mutable heap Region&:
    trusted Unsafe.PointerCast:
        return raw.cast[mutable heap Region&]

@internal
def arena_heap_void_from_region(r: heap Region&) -> heap void&:
    trusted Unsafe.PointerCast:
        return r.cast[heap void&]

@internal
def arena_heap_u8_from_region_data(r: heap Region&) -> mutable heap u8&:
    trusted Unsafe.PointerCast, Unsafe.PointerArithmetic:
        return ((r.cast[heap u8&] + size_of(Region))).cast[mutable heap u8&]

@internal
def arena_heap_void_from_data_base(data_base: heap u8&, offset_bytes: usize) -> mutable heap void&:
    trusted Unsafe.PointerCast, Unsafe.PointerArithmetic:
        return ((data_base + offset_bytes)).cast[mutable heap void&]

@internal
def arena_heap_void_from_mutable(ptr: mutable void&) -> mutable heap void&:
    trusted Unsafe.PointerCast:
        return ptr.cast[mutable heap void&]

@internal
def arena_heap_u8_from_void(ptr: heap void&) -> mutable heap u8&:
    trusted Unsafe.PointerCast:
        return ptr.cast[mutable heap u8&]

@internal
def arena_heap_void_from_u8(ptr: heap u8&) -> heap void&:
    trusted Unsafe.PointerCast:
        return ptr.cast[heap void&]

@internal
def arena_u8_from_void(ptr: void&) -> u8&:
    trusted Unsafe.PointerCast:
        return ptr.cast[u8&]

@internal
def arena_mutable_u8_from_void(ptr: mutable void&) -> mutable u8&:
    trusted Unsafe.PointerCast:
        return ptr.cast[mutable u8&]

@internal
def arena_heap_u8_from_alloc(ptr: heap void&) -> mutable heap u8&:
    trusted Unsafe.PointerCast:
        return ptr.cast[mutable heap u8&]

@internal
def arena_void_from_mutable_u8(ptr: mutable heap u8&) -> mutable void&:
    trusted Unsafe.PointerCast:
        return ptr.cast[mutable void&]

@internal
def arena_void_from_u8(ptr: u8&) -> void&:
    trusted Unsafe.PointerCast:
        return ptr.cast[void&]

@internal
def arena_nullable_u8_from_heap(ptr: heap u8&) -> u8&?:
    trusted Unsafe.PointerCast:
        return ptr.cast[u8&?]

def sfree[T](ptr: heap T&) -> heap T!:
    trusted Unsafe.PointerCast, Unsafe.RawExtern:
        free(ptr.cast[heap void&]) can Memory.Release
    return null

def new_region_with_owner(capacity: usize, owner_tag: uintptr) -> mutable heap Region&:
    can Memory.Allocate, Abort.Panic:
        size_bytes: usize = (size_of(Region) + (size_of(uintptr) * capacity))
        static if (ARENA_BACKEND == ARENA_BACKEND_LIBC_MALLOC):
            raw: mutable heap void&? = null
            trusted Unsafe.RawExtern:
                raw <- malloc(size_bytes)
            assert((raw != null))
            r: heap Region& = arena_region_from_raw(raw)
        static elif (ARENA_BACKEND == ARENA_BACKEND_LINUX_MMAP):
            raw: heap void&? = mmap(null, size_bytes, (PROT_READ | PROT_WRITE), (MAP_ANONYMOUS | MAP_PRIVATE), (-1), 0)
            assert((raw != MAP_FAILED()))
            r: heap Region& = arena_region_from_raw(raw)
        static elif (ARENA_BACKEND == ARENA_BACKEND_WIN32_VIRTUALALLOC):
            raw: heap void&? = VirtualAllocEx(GetCurrentProcess(), null, size_bytes, (MEM_COMMIT | MEM_RESERVE), PAGE_READWRITE)
            assert((not inv_handle(raw)))
            r: heap Region& = arena_region_from_raw(raw)
        static elif (ARENA_BACKEND == ARENA_BACKEND_WASM_HEAPBASE):
            r: heap Region& = arena_region_from_raw(arena_heap_void_from_u8(bump_pointer))
            current_memory_size: mutable usize = 0
            trusted Unsafe.RawExtern:
                current_memory_size <- (ARENA_WASM_PAGE_SIZE * wasm_memory_size(0).usize())
            desired_memory_size: usize = (bump_pointer.usize() + size_bytes)
            if (desired_memory_size > current_memory_size):
                delta_bytes: usize = (desired_memory_size - current_memory_size)
                delta_pages: usize = (((delta_bytes + ((ARENA_WASM_PAGE_SIZE - 1)))) / ARENA_WASM_PAGE_SIZE)
                grow_result: mutable int = (-1)
                trusted Unsafe.RawExtern:
                    grow_result <- wasm_memory_grow(0, delta_pages)
                assert((grow_result >= 0))
            bump_pointer <- (bump_pointer + size_bytes)
        static else:
            static error("Unknown arena backend")
        r.next <- null
        r.count <- 0
        r.capacity <- capacity
        r.owner_tag <- owner_tag
        r.owner_next <- null
        r.global_index <- 0
        return r

def new_region(capacity: usize) -> mutable heap Region&:
    return new_region_with_owner(capacity, 0.uintptr()) can Memory.Allocate, Abort.Panic

def free_region(r: heap Region&):
    can Memory.Release, Abort.Panic:
        static if (ARENA_BACKEND == ARENA_BACKEND_LIBC_MALLOC):
            trusted Unsafe.RawExtern:
                free(arena_heap_void_from_region(r))
        static elif (ARENA_BACKEND == ARENA_BACKEND_LINUX_MMAP):
            size_bytes: usize = (size_of(Region) + (size_of(uintptr) * r.capacity))
            ret: int = munmap(arena_heap_void_from_region(r), size_bytes)
            assert((ret == 0))
        static elif (ARENA_BACKEND == ARENA_BACKEND_WIN32_VIRTUALALLOC):
            ok: bool = VirtualFreeEx(GetCurrentProcess(), arena_heap_void_from_region(r), 0, MEM_RELEASE)
            assert(ok)
        static elif (ARENA_BACKEND == ARENA_BACKEND_WASM_HEAPBASE):
            pass

def arena_alloc(a: mutable Arena&, size_bytes: usize) -> mutable heap void&:
    can Memory.Allocate, Abort.Panic:
        size: usize = ((((size_bytes + size_of(uintptr)) - 1)) / size_of(uintptr))
        if (a.end == null):
            assert((a.begin == null))
            capacity: mutable usize = ARENA_REGION_DEFAULT_CAPACITY
            if (capacity < size):
                capacity <- size
            a.end as & <- new_region(capacity)
            a.begin <- a.end
            a.end_index <- 0
            a.end.global_index <- 0
        assert((a.end != null))
        trusted Unsafe.AssumeProgress:
            while ((((a.end.owner_tag != 0.uintptr()) or ((a.end.count + size) > a.end.capacity))) and (a.end.next != null)):
                a.end <- a.end.next
                a.end_index <- (a.end_index + 1)
        if ((a.end.owner_tag != 0.uintptr()) or ((a.end.count + size) > a.end.capacity)):
            assert((a.end.next == null))
            capacity: mutable usize = ARENA_REGION_DEFAULT_CAPACITY
            if (capacity < size):
                capacity <- size
            a.end.next as & <- new_region(capacity)
            a.end <- a.end.next
            a.end_index <- (a.end_index + 1)
            a.end.global_index <- a.end_index
        data_base: heap u8& = arena_heap_u8_from_region_data(a.end)
        offset_bytes: usize = (a.end.count * size_of(uintptr))
        result: heap void& = arena_heap_void_from_data_base(data_base, offset_bytes)
        a.end.count <- (a.end.count + size)
        return result

def arena_realloc(a: mutable Arena&, oldptr: mutable void&, oldsz: usize, newsz: usize) -> mutable heap void&:
    can Memory.Allocate, Abort.Panic:
        if (newsz <= oldsz):
            return arena_heap_void_from_mutable(oldptr)
        newptr: heap void& = arena_alloc(a, newsz)
        newptr_bytes: heap u8& = arena_heap_u8_from_void(newptr)
        oldptr_bytes: u8& = arena_u8_from_void(oldptr)
        trusted Unsafe.UncheckedIndex:
            for i in 0 ..< oldsz:
                newptr_bytes[i] <- oldptr_bytes[i]
        return newptr

def arena_strlen(s: u8&) -> usize:
    n: mutable usize = 0
    trusted Unsafe.UncheckedIndex:
        trusted Unsafe.AssumeProgress:
            while (s[n] != 0):
                n <- (n + 1)
    return n

def arena_memcpy(dest: mutable void&, src: void&, n: usize) -> mutable void&:
    d: mutable u8& = arena_mutable_u8_from_void(dest)
    s: u8& = arena_u8_from_void(src)
    trusted Unsafe.UncheckedIndex:
        for i in 0 ..< n:
            d[i] <- s[i]
    return dest

def arena_memeq(lhs: void&, rhs: void&, n: usize) -> bool:
    left: u8& = arena_u8_from_void(lhs)
    right: u8& = arena_u8_from_void(rhs)
    trusted Unsafe.UncheckedIndex:
        for i in 0 ..< n:
            if (left[i] != right[i]):
                return false
    return true

def arena_strdup(a: mutable Arena&, cstr: u8&) -> mutable heap u8&:
    n: usize = arena_strlen(cstr)
    dup: mutable heap u8& = arena_heap_u8_from_alloc(arena_alloc(a, (n + 1))) can Memory.Allocate, Abort.Panic
    arena_memcpy(arena_void_from_mutable_u8(dup), arena_void_from_u8(cstr), n)
    trusted Unsafe.UncheckedIndex:
        dup[n] <- 0
    return dup

def arena_memdup(a: mutable Arena&, data: void&, size: usize) -> mutable heap void&:
    dup: mutable heap void& = arena_alloc(a, size) can Memory.Allocate, Abort.Panic
    _ = arena_memcpy(dup, data, size)
    return dup

def arena_snapshot(a: Arena&) -> ArenaMark:
    if (a.end == null):
        assert((a.begin == null))
        return ArenaMark(null, 0)
    return ArenaMark(a.end, a.end.count)

def arena_reset(a: mutable Arena&):
    r: mutable heap Region&? = a.begin
    trusted Unsafe.AssumeProgress:
        while (r != null):
            r.count <- 0
            r <- r.next
    a.end <- a.begin
    a.end_index <- 0

def arena_rewind(a: mutable Arena&, m: ArenaMark):
    if (m.region == null):
        arena_reset(a)
        return
    region: heap Region& = m.region
    region.count <- m.count
    r: mutable heap Region&? = region.next
    trusted Unsafe.AssumeProgress:
        while (r != null):
            r.count <- 0
            r <- r.next
    a.end as & <- region
    region_index: mutable usize = 0
    current: mutable heap Region&? = a.begin
    trusted Unsafe.AssumeProgress:
        while ((current != null) and (current != region)):
            current <- current.next
            region_index <- (region_index + 1)
    assert((current != null))
    a.end_index <- region_index

def arena_free(a: mutable Arena&):
    can Memory.Release, Abort.Panic:
        r: mutable heap Region&? = a.begin
        trusted Unsafe.AssumeProgress:
            while (r != null):
                r0: mutable heap Region& = r
                r <- r.next
                free_region(r0)
        a.begin as ! <- null
        a.end as ! <- null
        a.end_index <- 0

def arena_trim(a: mutable Arena&):
    can Memory.Release, Abort.Panic:
        if (a.end == null):
            return
        r: mutable heap Region&? = a.end.next
        trusted Unsafe.AssumeProgress:
            while (r != null):
                r0: mutable heap Region& = r
                r <- r.next
                free_region(r0)
        a.end.next as ! <- null

extern va_list

extern va_copy(args: va_list) -> va_list

extern va_end(args: va_list)

extern vsnprintf(buffer: u8&?, buffer_size: usize, format: u8&, args: va_list) -> int

def arena_vsprintf(a: mutable Arena&, format: u8&, args: va_list) -> mutable heap u8&:
    can Memory.Allocate, Console.Format, Abort.Panic:
        args_copy: mutable va_list = args
        n: mutable int = (-1)
        trusted Unsafe.RawExtern:
            args_copy <- va_copy(args)
            n <- vsnprintf(null, 0, format, args_copy)
            va_end(args_copy)
        assert((n >= 0))
        result: heap u8& = arena_heap_u8_from_alloc(arena_alloc(a, (n.usize() + 1)))
        trusted Unsafe.RawExtern:
            _ = vsnprintf(arena_nullable_u8_from_heap(result), (n.usize() + 1), format, args)
        return result

const ARENA_DEQUE_INIT_CAP: usize = 16

struct Deque[T]:
    items: mutable T&?
    head: mutable usize
    count: mutable usize
    capacity: mutable usize

@internal
def deque_items_from_alloc[T](ptr: heap void&) -> mutable T&:
    trusted Unsafe.PointerCast:
        return ptr.cast[mutable T&]

@internal
def deque_mutable_void_from_items[T](items: mutable T&) -> mutable void&:
    trusted Unsafe.PointerCast:
        return items.cast[mutable void&]

@internal
def deque_void_from_items[T](items: T&) -> void&:
    trusted Unsafe.PointerCast:
        return items.cast[void&]

@internal
def deque_void_from_items_at[T](items: T&, index: usize) -> void&:
    trusted Unsafe.PointerCast, Unsafe.PointerArithmetic:
        return ((items + index)).cast[void&]

@internal
def deque_mutable_void_from_items_at[T](items: mutable T&, index: usize) -> mutable void&:
    trusted Unsafe.PointerCast, Unsafe.PointerArithmetic:
        return ((items + index)).cast[mutable void&]

def arena_deque_init[T]() -> Deque[T]:
    out: mutable Deque[T] = zeroed
    return out

def arena_deque_init_buffer[T](buffer: T&, capacity: usize) -> Deque[T]:
    out: mutable Deque[T] = zeroed
    out.items as & <- buffer
    out.head <- 0
    out.count <- 0
    out.capacity <- capacity
    return out

def arena_deque_with_capacity[T](a: mutable Arena&, capacity: usize) -> Deque[T]:
    can Memory.Allocate, Abort.Panic:
        if (capacity == 0):
            out0: mutable Deque[T] = zeroed
            return out0
        out: mutable Deque[T] = zeroed
        out.items as & <- deque_items_from_alloc[T](arena_alloc(a, (capacity * size_of(T))))
        out.head <- 0
        out.count <- 0
        out.capacity <- capacity
        return out

def arena_deque_len[T](d: Deque[T]&) -> usize:
    return d.count

def arena_deque_capacity[T](d: Deque[T]&) -> usize:
    return d.capacity

def arena_deque_is_empty[T](d: Deque[T]&) -> bool:
    return (d.count == 0)

def arena_deque_clear[T](d: mutable Deque[T]&):
    d.head <- 0
    d.count <- 0

def arena_deque_buffer_index[T](d: Deque[T]&, logical_index: usize) -> usize:
    can Abort.Panic:
        assert((d.capacity > 0))
        assert((logical_index < d.capacity))
        head_len: usize = (d.capacity - d.head)
        return (((d.head + logical_index)) if (logical_index < head_len) else (logical_index - head_len))

def arena_deque_copy_linearized[T](d: Deque[T]&, dst: mutable T&):
    if (d.count == 0):
        return
    assert((d.items != null))
    if (d.head <= (d.capacity - d.count)):
        arena_memcpy(deque_mutable_void_from_items[T](dst), deque_void_from_items_at[T](d.items, d.head), (d.count * size_of(T)))
        return
    head_count: usize = (d.capacity - d.head)
    tail_count: usize = (d.count - head_count)
    arena_memcpy(deque_mutable_void_from_items[T](dst), deque_void_from_items_at[T](d.items, d.head), (head_count * size_of(T)))
    arena_memcpy(deque_mutable_void_from_items_at[T](dst, head_count), deque_void_from_items[T](d.items), (tail_count * size_of(T)))

def arena_deque_reserve[T](a: mutable Arena&, d: mutable Deque[T]&, needed: usize) -> mutable Deque[T]&:
    can Memory.Allocate, Abort.Panic:
        if (needed <= d.capacity):
            return d
        new_capacity: mutable usize = d.capacity
        if (new_capacity == 0):
            new_capacity <- ARENA_DEQUE_INIT_CAP
        trusted Unsafe.AssumeProgress:
            while (needed > new_capacity):
                new_capacity <- (new_capacity * 2)
        new_items: mutable T& = deque_items_from_alloc[T](arena_alloc(a, (new_capacity * size_of(T))))
        arena_deque_copy_linearized(d, new_items)
        d.items as & <- new_items
        d.head <- 0
        d.capacity <- new_capacity
        return d

def arena_deque_ensure_unused[T](a: mutable Arena&, d: mutable Deque[T]&, additional: usize) -> mutable Deque[T]&:
    can Memory.Allocate, Abort.Panic:
        needed: usize = (d.count + additional)
        assert((needed >= d.count))
        return arena_deque_reserve(a, d, needed)

def arena_deque_push_front_assume_capacity[T](d: mutable Deque[T]&, item: T):
    can Abort.Panic:
        assert((d.items != null))
        assert((d.count < d.capacity))
        if (d.head == 0):
            d.head <- d.capacity
        d.head <- (d.head - 1)
        d.items[d.head] <- item
        d.count <- (d.count + 1)

def arena_deque_push_back_assume_capacity[T](d: mutable Deque[T]&, item: T):
    can Abort.Panic:
        assert((d.items != null))
        assert((d.count < d.capacity))
        physical_index: usize = arena_deque_buffer_index(d, d.count)
        d.items[physical_index] <- item
        d.count <- (d.count + 1)

def arena_deque_push_front_bounded[T](d: mutable Deque[T]&, item: T) -> bool:
    can Abort.Panic:
        if (d.count >= d.capacity):
            return false
        arena_deque_push_front_assume_capacity(d, item)
        return true

def arena_deque_push_back_bounded[T](d: mutable Deque[T]&, item: T) -> bool:
    can Abort.Panic:
        if (d.count >= d.capacity):
            return false
        arena_deque_push_back_assume_capacity(d, item)
        return true

def arena_deque_push_front[T](a: mutable Arena&, d: mutable Deque[T]&, item: T) -> mutable Deque[T]&:
    can Memory.Allocate, Abort.Panic:
        _ = arena_deque_ensure_unused(a, d, 1)
        arena_deque_push_front_assume_capacity(d, item)
        return d

def arena_deque_push_back[T](a: mutable Arena&, d: mutable Deque[T]&, item: T) -> mutable Deque[T]&:
    can Memory.Allocate, Abort.Panic:
        _ = arena_deque_ensure_unused(a, d, 1)
        arena_deque_push_back_assume_capacity(d, item)
        return d

def arena_deque_front[T](d: Deque[T]&) -> T&?:
    return (null if ((d.count == 0) or (d.items == null)) else &d.items[d.head])

def arena_deque_back[T](d: Deque[T]&) -> T&?:
    can Abort.Panic:
        if ((d.count == 0) or (d.items == null)):
            return null
        physical_index: usize = arena_deque_buffer_index(d, (d.count - 1))
        return &d.items[physical_index]

def arena_deque_at[T](d: Deque[T]&, index: usize) -> T&:
    can Abort.Panic:
        assert((index < d.count))
        assert((d.items != null))
        physical_index: usize = arena_deque_buffer_index(d, index)
        return &d.items[physical_index]

def arena_deque_pop_front[T](d: mutable Deque[T]&, out: mutable T&) -> bool:
    can Abort.Panic:
        if ((d.count == 0) or (d.items == null)):
            return false
        out[0] <- d.items[d.head]
        if (d.count == 1):
            d.count <- 0
            d.head <- 0
            return true
        d.head <- arena_deque_buffer_index(d, 1)
        d.count <- (d.count - 1)
        return true

def arena_deque_pop_back[T](d: mutable Deque[T]&, out: mutable T&) -> bool:
    can Abort.Panic:
        if ((d.count == 0) or (d.items == null)):
            return false
        physical_index: usize = arena_deque_buffer_index(d, (d.count - 1))
        out[0] <- d.items[physical_index]
        d.count <- (d.count - 1)
        if (d.count == 0):
            d.head <- 0
        return true

const ARENA_DA_INIT_CAP: usize = 256

const DICT_INIT_CAP: usize = 8

struct DynArray[T]:
    items: mutable T&?
    count: mutable usize
    capacity: mutable usize

struct DynArrayView:
    data: mutable void&?
    len: mutable usize
    elem_size: mutable usize

struct DictBucket[K, T]:
    key: mutable K
    value: mutable T

struct DynDict[K, T]:
    items: mutable DictBucket[K, T]&?
    count: mutable usize
    used: mutable usize
    capacity: mutable usize
    arena: mutable Arena&?

struct DictProbeResult:
    index: mutable usize
    found: mutable bool

extern SymbolTableSlot

type SymbolTableId = id[SymbolTableSlot]

def __cast__(value: u32) -> SymbolTableId:
    return value.cast[SymbolTableId]

global SYMBOL_TABLE_INVALID_ID: SymbolTableId = 0.u32().SymbolTableId()

struct SymbolEntry[K, T]:
    key: mutable K
    value: mutable T

struct IndexMapEntry[K, T]:
    key: mutable K
    value: mutable T

struct IndexMap[K, T]:
    owner: mutable Arena&?
    entries: mutable darray[IndexMapEntry[K, T]]
    by_key: mutable dict[K, usize]

struct SymbolTable[K, T]:
    items: mutable IndexMap[K, T]

struct InlineVec[T, N: usize]:
    owner: mutable Arena&?
    inline_items: mutable T[N]
    overflow: mutable darray[T]
    len: mutable usize
    is_spilled: mutable bool

struct DArrayBuilder[T]:
    owner: mutable Arena&?
    items: mutable darray[T]

struct Flags[T]:
    bits: mutable u64

struct IndexMapNamespace:
    _unused: u8

struct SymbolTableNamespace:
    _unused: u8

struct InlineVecNamespace:
    _unused: u8

struct DArrayBuilderNamespace:
    _unused: u8

struct FlagsNamespace:
    _unused: u8

global indexmap: IndexMapNamespace = IndexMapNamespace(0)

global symtab: SymbolTableNamespace = SymbolTableNamespace(0)

global inlinevec: InlineVecNamespace = InlineVecNamespace(0)

global arraybuilder: DArrayBuilderNamespace = DArrayBuilderNamespace(0)

global flags: FlagsNamespace = FlagsNamespace(0)

@internal
def collections_items_from_alloc[T](ptr: heap void&) -> mutable T&:
    trusted Unsafe.PointerCast:
        return ptr.cast[mutable T&]

@internal
def collections_void_from_items[T](items: T&) -> void&:
    trusted Unsafe.PointerCast:
        return items.cast[void&]

@internal
def collections_mutable_void_from_items[T](items: mutable T&) -> mutable void&:
    trusted Unsafe.PointerCast:
        return items.cast[mutable void&]

@internal
def collections_void_from_items_at[T](items: T&, index: usize) -> void&:
    trusted Unsafe.PointerCast, Unsafe.PointerArithmetic:
        return ((items + index)).cast[void&]

@internal
def collections_mutable_void_from_items_at[T](items: mutable T&, index: usize) -> mutable void&:
    trusted Unsafe.PointerCast, Unsafe.PointerArithmetic:
        return ((items + index)).cast[mutable void&]

@internal
def collections_void_from_data_at(data: void&, offset: usize) -> void&:
    trusted Unsafe.PointerCast, Unsafe.PointerArithmetic:
        return ((data.cast[u8&] + offset)).cast[void&]

@internal
def collections_items_from_data_at[T](data: void&, offset: usize) -> T&:
    trusted Unsafe.PointerCast, Unsafe.PointerArithmetic:
        return ((data.cast[u8&] + offset)).cast[T&]

@internal
def collections_items_from_data[T](data: void&) -> T&:
    trusted Unsafe.PointerCast:
        return data.cast[T&]

@internal
def collections_mutable_items_from_data[T](data: mutable void&) -> mutable T&:
    trusted Unsafe.PointerCast:
        return data.cast[mutable T&]

def arena_da_reserve[T](a: mutable Arena&, da: mutable darray[T, shape_in]&, needed: usize) -> mutable darray[T, shape_out]&:
    can Memory.Allocate, Abort.Panic:
        if (needed <= da.capacity):
            return da
        new_capacity: mutable usize = da.capacity
        if (new_capacity == 0):
            new_capacity <- ARENA_DA_INIT_CAP
        trusted Unsafe.AssumeProgress:
            while (needed > new_capacity):
                new_capacity <- (new_capacity * 2)
        old_size: usize = (da.capacity * size_of(T))
        new_size: usize = (new_capacity * size_of(T))
        if (da.items == null):
            da.items as & <- collections_items_from_alloc[T](arena_alloc(a, new_size))
        else:
            resized: heap void& = arena_realloc(a, collections_mutable_void_from_items[T](da.items), old_size, new_size)
            da.items as & <- collections_items_from_alloc[T](resized)
        da.capacity <- new_capacity
        return da

def arena_da_view[T](da: darray[T, shape_in]&, start: usize, end: usize) -> view[T]:
    elem_size: usize = size_of(T)
    if ((da.items == null) or (da.count == 0)):
        return DynArrayView(null, 0, elem_size)
    lo: mutable usize = (start if (start < da.count) else da.count)
    hi: mutable usize = (end if (end < da.count) else da.count)
    if (hi < lo):
        hi <- lo
    if (hi == lo):
        return DynArrayView(null, 0, elem_size)
    return DynArrayView(collections_void_from_items_at[T](da.items, lo), (hi - lo), elem_size)

def arena_da_view_len[T](view: view[T]) -> usize:
    return view.len

def arena_da_view_slice[T](view: view[T], start: usize, end: usize) -> view[T]:
    if ((view.data == null) or (view.len == 0)):
        return DynArrayView(null, 0, view.elem_size)
    lo: mutable usize = (start if (start < view.len) else view.len)
    hi: mutable usize = (end if (end < view.len) else view.len)
    if (hi < lo):
        hi <- lo
    if (hi == lo):
        return DynArrayView(null, 0, view.elem_size)
    offset: usize = (lo * view.elem_size)
    return DynArrayView(collections_void_from_data_at(view.data, offset), (hi - lo), view.elem_size)

def arena_da_view_prefix[T](view: view[T], end: usize) -> view[T]:
    return arena_da_view_slice(view, 0, end)

def arena_da_view_suffix[T](view: view[T], start: usize) -> view[T]:
    return arena_da_view_slice(view, start, view.len)

def arena_da_view_get[T](view: view[T], index: usize) -> T:
    assert((index < view.len))
    assert((view.data != null))
    offset: usize = (index * view.elem_size)
    base: T& = collections_items_from_data_at[T](view.data, offset)
    return base[0]

def arena_da_fill[T](dst: view[T], value: T):
    if (dst.len == 0):
        return
    assert((dst.data != null))
    out: mutable T& = collections_mutable_items_from_data[T](dst.data)
    for i in 0 ..< dst.len:
        out[i] <- value

def arena_da_copy_exact[T](dst: view[T], src: view[T]):
    assert((dst.len == src.len))
    if (dst.len == 0):
        return
    assert((dst.data != null))
    assert((src.data != null))
    out: mutable T& = collections_mutable_items_from_data[T](dst.data)
    src_items: T& = collections_items_from_data[T](src.data)
    for i in 0 ..< dst.len:
        out[i] <- src_items[i]

def arena_da_eq_exact[T](left: view[T], right: view[T]) -> bool:
    assert((left.len == right.len))
    assert((left.elem_size == right.elem_size))
    if (left.len == 0):
        return true
    assert((left.data != null))
    assert((right.data != null))
    byte_count: usize = (left.len * left.elem_size)
    return arena_memeq(left.data, right.data, byte_count)

def arena_da_from_view[T](a: mutable Arena&, view: view[T]) -> darray[T, shape_out]:
    can Memory.Allocate, Abort.Panic:
        if (view.len == 0):
            return zeroed
        items: mutable T& = collections_items_from_alloc[T](arena_alloc(a, (view.len * size_of(T))))
        assert((view.data != null))
        arena_memcpy(collections_mutable_void_from_items[T](items), view.data, (view.len * view.elem_size))
        out: mutable darray[T, shape_out] = zeroed
        out.items as & <- items
        out.count <- view.len
        out.capacity <- view.len
        return out

def darray_view[T](da: darray[T]) -> view[T]:
    elem_size: usize = size_of(T)
    if ((da.items == null) or (da.count == 0)):
        return DynArrayView(null, 0, elem_size)
    return DynArrayView(collections_void_from_items[T](da.items), da.count, elem_size)

@ufcs_only
def view[T](da: darray[T]) -> view[T]:
    return darray_view[T](da)

@ufcs_only
def where[S, T](source: S, predicate: func(T) -> bool) -> FilteredView[S, T]:
    return FilteredView[S, T](source, predicate)

def darray_builder[T](owner: mutable Arena&) -> DArrayBuilder[T]:
    result: mutable DArrayBuilder[T] = zeroed
    result.owner as & <- owner
    return result

def new[T](api: DArrayBuilderNamespace, owner: mutable Arena&) -> DArrayBuilder[T]:
    _ = api
    return darray_builder[T](owner)

@ufcs_only
def builder[T](owner: mutable Arena&) -> DArrayBuilder[T]:
    return darray_builder[T](owner)

def darray_builder_count[T](builder: DArrayBuilder[T]&) -> usize:
    return builder.items.count

@ufcs_only
def count[T](builder: DArrayBuilder[T]&) -> usize:
    return darray_builder_count[T](builder)

def darray_builder_is_empty[T](builder: DArrayBuilder[T]&) -> bool:
    return (builder.items.count == 0)

@ufcs_only
def is_empty[T](builder: DArrayBuilder[T]&) -> bool:
    return darray_builder_is_empty[T](builder)

def darray_builder_get[T](builder: DArrayBuilder[T]&, index: usize) -> T:
    assert((index < builder.items.count))
    return builder.items[index]

@ufcs_only
def get[T](builder: DArrayBuilder[T]&, index: usize) -> T:
    return darray_builder_get[T](builder, index)

def darray_builder_reserve[T](builder: mutable DArrayBuilder[T]&, capacity: usize):
    can Memory.Allocate, Abort.Panic:
        assert((builder.owner != null))
        owner: mutable Arena& = builder.owner
        in owner:
            _ = builder.items.reserve(capacity)

@ufcs_only
def reserve[T](builder: mutable DArrayBuilder[T]&, capacity: usize):
    darray_builder_reserve[T](builder, capacity) can Memory.Allocate, Abort.Panic

def darray_builder_push[T](builder: mutable DArrayBuilder[T]&, item: T):
    can Memory.Allocate, Abort.Panic:
        assert((builder.owner != null))
        owner: mutable Arena& = builder.owner
        in owner:
            builder.items.push(item)

@ufcs_only
def push[T](builder: mutable DArrayBuilder[T]&, item: T):
    darray_builder_push[T](builder, item) can Memory.Allocate, Abort.Panic

def darray_builder_view[T](builder: DArrayBuilder[T]&) -> view[T]:
    elem_size: usize = size_of(T)
    if ((builder.items.items == null) or (builder.items.count == 0)):
        return DynArrayView(null, 0, elem_size)
    return DynArrayView(collections_void_from_items[T](builder.items.items), builder.items.count, elem_size)

@ufcs_only
def view[T](builder: DArrayBuilder[T]&) -> view[T]:
    return darray_builder_view[T](builder)

def darray_builder_finish[T](builder: DArrayBuilder[T]&) -> darray[T]:
    return builder.items

@ufcs_only
def finish[T](builder: DArrayBuilder[T]&) -> darray[T]:
    return darray_builder_finish[T](builder)

def darray_builder_clear[T](builder: mutable DArrayBuilder[T]&):
    builder.items.count <- 0

@ufcs_only
def clear[T](builder: mutable DArrayBuilder[T]&):
    darray_builder_clear[T](builder)

def inline_vec[T, N: usize](owner: mutable Arena&) -> InlineVec[T, N]:
    out: mutable InlineVec[T, N] = zeroed
    out.owner as & <- owner
    return out

def new[T, N: usize](api: InlineVecNamespace, owner: mutable Arena&) -> InlineVec[T, N]:
    _ = api
    return inline_vec[T, N](owner)

def inline_vec_count[T, N: usize](vec: InlineVec[T, N]&) -> usize:
    return vec.len

@ufcs_only
def count[T, N: usize](vec: InlineVec[T, N]&) -> usize:
    return inline_vec_count[T, N](vec)

def inline_vec_is_empty[T, N: usize](vec: InlineVec[T, N]&) -> bool:
    return (vec.len == 0)

@ufcs_only
def is_empty[T, N: usize](vec: InlineVec[T, N]&) -> bool:
    return inline_vec_is_empty[T, N](vec)

def inline_vec_spilled[T, N: usize](vec: InlineVec[T, N]&) -> bool:
    return vec.is_spilled

@ufcs_only
def spilled[T, N: usize](vec: InlineVec[T, N]&) -> bool:
    return inline_vec_spilled[T, N](vec)

def inline_vec_get[T, N: usize](vec: InlineVec[T, N]&, index: usize) -> T:
    assert((index < vec.len))
    if vec.is_spilled:
        trusted Unsafe.UncheckedIndex:
            return vec.overflow[index]
    trusted Unsafe.UncheckedIndex:
        return vec.inline_items[index]

@ufcs_only
def get[T, N: usize](vec: InlineVec[T, N]&, index: usize) -> T:
    return inline_vec_get[T, N](vec, index)

def inline_vec_set[T, N: usize](vec: mutable InlineVec[T, N]&, index: usize, item: T):
    assert((index < vec.len))
    if vec.is_spilled:
        trusted Unsafe.UncheckedIndex:
            vec.overflow[index] <- item
    else:
        trusted Unsafe.UncheckedIndex:
            vec.inline_items[index] <- item

@ufcs_only
def set[T, N: usize](vec: mutable InlineVec[T, N]&, index: usize, item: T):
    inline_vec_set[T, N](vec, index, item)

def inline_vec_spill[T, N: usize](vec: mutable InlineVec[T, N]&):
    can Memory.Allocate, Abort.Panic:
        if vec.is_spilled:
            return
        assert((vec.owner != null))
        owner: mutable Arena& = vec.owner
        in owner:
            _ = vec.overflow.reserve((N * 2))
            for index in 0 ..< vec.len:
                trusted Unsafe.UncheckedIndex:
                    vec.overflow.push(vec.inline_items[index])
        vec.is_spilled <- true

def inline_vec_push[T, N: usize](vec: mutable InlineVec[T, N]&, item: T):
    can Memory.Allocate, Abort.Panic:
        if vec.is_spilled:
            assert((vec.owner != null))
            owner: mutable Arena& = vec.owner
            in owner:
                vec.overflow.push(item)
            vec.len <- (vec.len + 1)
            return
        if (vec.len < N):
            trusted Unsafe.UncheckedIndex:
                vec.inline_items[vec.len] <- item
            vec.len <- (vec.len + 1)
            return
        inline_vec_spill[T, N](vec)
        assert((vec.owner != null))
        owner: mutable Arena& = vec.owner
        in owner:
            vec.overflow.push(item)
        vec.len <- (vec.len + 1)

@ufcs_only
def push[T, N: usize](vec: mutable InlineVec[T, N]&, item: T):
    inline_vec_push[T, N](vec, item) can Memory.Allocate, Abort.Panic

def inline_vec_pop[T, N: usize](vec: mutable InlineVec[T, N]&) -> T:
    assert((vec.len > 0))
    vec.len <- (vec.len - 1)
    if vec.is_spilled:
        vec.overflow.count <- vec.len
        trusted Unsafe.UncheckedIndex:
            return vec.overflow[vec.len]
    trusted Unsafe.UncheckedIndex:
        return vec.inline_items[vec.len]

@ufcs_only
def pop[T, N: usize](vec: mutable InlineVec[T, N]&) -> T:
    return inline_vec_pop[T, N](vec)

def inline_vec_last[T, N: usize](vec: InlineVec[T, N]&) -> T:
    assert((vec.len > 0))
    return inline_vec_get[T, N](vec, (vec.len - 1))

@ufcs_only
def last[T, N: usize](vec: InlineVec[T, N]&) -> T:
    return inline_vec_last[T, N](vec)

def inline_vec_view[T, N: usize](vec: InlineVec[T, N]&) -> view[T]:
    elem_size: usize = size_of(T)
    if (vec.len == 0):
        return DynArrayView(null, 0, elem_size)
    if vec.is_spilled:
        assert((vec.overflow.items != null))
        return DynArrayView(collections_void_from_items[T](vec.overflow.items), vec.len, elem_size)
    trusted Unsafe.UncheckedIndex:
        return DynArrayView(collections_void_from_items[T](vec.inline_items[0].cast[T&]), vec.len, elem_size)

@ufcs_only
def view[T, N: usize](vec: InlineVec[T, N]&) -> view[T]:
    return inline_vec_view[T, N](vec)

def inline_vec_clear[T, N: usize](vec: mutable InlineVec[T, N]&):
    if vec.is_spilled:
        vec.overflow.count <- 0
    vec.len <- 0
    vec.is_spilled <- false

@ufcs_only
def clear[T, N: usize](vec: mutable InlineVec[T, N]&):
    inline_vec_clear[T, N](vec)

def flags_new[T](api: FlagsNamespace) -> Flags[T]:
    _ = api
    result: Flags[T] = zeroed
    return result

def new[T](api: FlagsNamespace) -> Flags[T]:
    return flags_new[T](api)

def flags_empty[T]() -> Flags[T]:
    result: Flags[T] = zeroed
    return result

def flags_from_bits[T](bits: u64) -> Flags[T]:
    result: mutable Flags[T] = zeroed
    result.bits <- bits
    return result

def flags_bits[T](items: Flags[T]&) -> u64:
    return items.bits

def bits[T](items: Flags[T]&) -> u64:
    return flags_bits[T](items)

def flags_mask[T](value: T) -> u64:
    index: u64 = value.u64()
    assert((index < 64))
    return (1.u64() << index.u32())

def flags_has[T](items: Flags[T]&, value: T) -> bool:
    return (((items.bits & flags_mask[T](value))) != 0)

def has[T](items: Flags[T]&, value: T) -> bool:
    return flags_has[T](items, value)

def flags_add[T](items: mutable Flags[T]&, value: T):
    items.bits <- (items.bits | flags_mask[T](value))

def add[T](items: mutable Flags[T]&, value: T):
    flags_add[T](items, value)

def flags_remove[T](items: mutable Flags[T]&, value: T):
    items.bits <- (items.bits & (~flags_mask[T](value)))

def remove[T](items: mutable Flags[T]&, value: T):
    flags_remove[T](items, value)

def flags_set[T](items: mutable Flags[T]&, value: T, enabled: bool):
    if enabled:
        items.add(value)
    else:
        items.remove(value)

def flags_clear[T](items: mutable Flags[T]&):
    items.bits <- 0

def flags_any[T](items: Flags[T]&) -> bool:
    return (items.bits != 0)

def flags_union[T](left: Flags[T]&, right: Flags[T]&) -> Flags[T]:
    return flags_from_bits[T]((left.bits | right.bits))

def flags_intersection[T](left: Flags[T]&, right: Flags[T]&) -> Flags[T]:
    return flags_from_bits[T]((left.bits & right.bits))

def flags_difference[T](left: Flags[T]&, right: Flags[T]&) -> Flags[T]:
    return flags_from_bits[T]((left.bits & (~right.bits)))

def arena_da_append[T](a: mutable Arena&, da: mutable darray[T, shape_in]&, item: T) -> mutable darray[T, shape_out]&:
    can Memory.Allocate, Abort.Panic:
        in a:
            _ = da.reserve((da.count + 1))
        assert((da.items != null))
        da.items[da.count] <- item
        da.count <- (da.count + 1)
        return da

def darray_pop[T](da: mutable darray[T]&) -> T:
    can Abort.Panic:
        assert((da.count > 0))
        da.count <- (da.count - 1)
        return da[da.count]

@ufcs_only
def pop[T](da: mutable darray[T]&) -> T:
    return darray_pop[T](da) can Abort.Panic

def darray_remove_at[T](da: mutable darray[T]&, index: usize) -> T:
    can Abort.Panic:
        assert((index < da.count))
        removed: T = da[index]
        next: mutable usize = (index + 1)
        trusted Unsafe.AssumeProgress:
            while (next < da.count):
                da[(next - 1)] <- da[next]
                next <- (next + 1)
        da.count <- (da.count - 1)
        return removed

@ufcs_only
def remove_at[T](da: mutable darray[T]&, index: usize) -> T:
    return darray_remove_at[T](da, index) can Abort.Panic

def arena_da_append_many[T](a: mutable Arena&, da: mutable darray[T, shape_in]&, new_items: T&, new_items_count: usize) -> mutable darray[T, shape_out]&:
    can Memory.Allocate, Abort.Panic:
        needed: usize = (da.count + new_items_count)
        if (needed > da.capacity):
            new_capacity: mutable usize = da.capacity
            if (new_capacity == 0):
                new_capacity <- ARENA_DA_INIT_CAP
            trusted Unsafe.AssumeProgress:
                while (needed > new_capacity):
                    new_capacity <- (new_capacity * 2)
            old_size: usize = (da.capacity * size_of(T))
            new_size: usize = (new_capacity * size_of(T))
            if (da.items == null):
                da.items as & <- collections_items_from_alloc[T](arena_alloc(a, new_size))
            else:
                resized: heap void& = arena_realloc(a, collections_mutable_void_from_items[T](da.items), old_size, new_size)
                da.items as & <- collections_items_from_alloc[T](resized)
            da.capacity <- new_capacity
        assert((da.items != null))
        arena_memcpy(collections_mutable_void_from_items_at[T](da.items, da.count), collections_void_from_items[T](new_items), (new_items_count * size_of(T)))
        da.count <- (da.count + new_items_count)
        return da

def arena_sb_append_buf(a: mutable Arena&, sb: mutable darray[u8, shape_in]&, buf: u8&, n: usize) -> mutable darray[u8, shape_out]&:
    return arena_da_append_many(a, sb, buf, n) can Memory.Allocate, Abort.Panic

def arena_sb_append_cstr(a: mutable Arena&, sb: mutable darray[u8, shape_in]&, cstr: u8&) -> mutable darray[u8, shape_out]&:
    n: usize = arena_strlen(cstr)
    return arena_da_append_many(a, sb, cstr, n) can Memory.Allocate, Abort.Panic

def arena_sb_append_null(a: mutable Arena&, sb: mutable darray[u8, shape_in]&) -> mutable darray[u8, shape_out]&:
    can Memory.Allocate, Abort.Panic:
        in a:
            return sb.extend([0.u8()])

def arena_dict_next_capacity(min_capacity: usize) -> usize:
    if (min_capacity == 0):
        return 0
    cap: mutable usize = DICT_INIT_CAP
    trusted Unsafe.AssumeProgress:
        while (cap < min_capacity):
            cap <- (cap * 2)
    return cap

def arena_dict_find_index[K, T](m: dict[K, T]&, key: K) -> DictProbeResult:
    if ((m.count == 0) or (m.items == null)):
        return DictProbeResult(0, false)
    assert((m.items != null))
    items: DictBucket[K, T]& = m.items
    for index in 0 ..< m.count:
        if (items[index].key == key):
            return DictProbeResult(index, true)
    return DictProbeResult(m.count, false)

def arena_dict_zero_buckets[K, T](items: mutable DictBucket[K, T]&, capacity: usize):
    view: view[DictBucket[K, T]] = DynArrayView(collections_void_from_items[DictBucket[K, T]](items), capacity, size_of(DictBucket[K, T]))
    arena_da_fill(view, zeroed)

def arena_dict_new[K, T](a: mutable Arena&, initial_capacity: usize) -> dict[K, T]:
    can Memory.Allocate, Abort.Panic:
        out: mutable dict[K, T] = zeroed
        out.arena as & <- a
        capacity: usize = arena_dict_next_capacity(initial_capacity)
        if (capacity == 0):
            return out
        items: mutable DictBucket[K, T]& = collections_items_from_alloc[DictBucket[K, T]](arena_alloc(a, (capacity * size_of(DictBucket[K, T]))))
        arena_dict_zero_buckets(items, capacity)
        out.items as & <- items
        out.capacity <- capacity
        return out

def arena_dict_reserve[K, T](a: mutable Arena&, m: mutable dict[K, T]&, min_capacity: usize) -> void error[RuntimeError]:
    can Memory.Allocate, Abort.Panic:
        target_capacity: usize = arena_dict_next_capacity(min_capacity)
        if (target_capacity == 0):
            return
        if (target_capacity <= m.capacity):
            return
        owner: mutable Arena& = (m.arena if (m.arena != null) else a)
        new_items: mutable DictBucket[K, T]& = collections_items_from_alloc[DictBucket[K, T]](arena_alloc(owner, (target_capacity * size_of(DictBucket[K, T]))))
        arena_dict_zero_buckets(new_items, target_capacity)
        if ((m.items != null) and (m.count > 0)):
            assert((m.items != null))
            old_items: mutable DictBucket[K, T]& = m.items
            for i in 0 ..< m.count:
                new_items[i] <- old_items[i]
        m.items as & <- new_items
        m.used <- m.count
        m.capacity <- target_capacity
        m.arena as & <- owner
        return

def arena_dict_get[K, T](m: dict[K, T]&, key: K) -> mutable T&?:
    if ((m.count == 0) or (m.items == null)):
        return null
    probe: DictProbeResult = arena_dict_find_index(m, key)
    if (not probe.found):
        return null
    assert((m.items != null))
    items: mutable DictBucket[K, T]& = m.items
    return &items[probe.index].value

def arena_dict_put[K, T](a: mutable Arena&, m: mutable dict[K, T]&, key: K, value: T) -> mutable T&? error[RuntimeError]:
    can Memory.Allocate, Abort.Panic:
        owner: mutable Arena& = (m.arena if (m.arena != null) else a)
        if (m.arena == null):
            m.arena as & <- owner
        probe: DictProbeResult = arena_dict_find_index(m, key)
        if probe.found:
            assert((m.items != null))
            items: mutable DictBucket[K, T]& = m.items
            items[probe.index].value <- value
            return &items[probe.index].value
        if ((m.capacity == 0) or (m.count == m.capacity)):
            target_capacity: mutable usize = (DICT_INIT_CAP if (m.capacity == 0) else (m.capacity * 2))
            if (target_capacity < (m.count + 1)):
                target_capacity <- (m.count + 1)
            try arena_dict_reserve(owner, m, target_capacity)
        assert((m.items != null))
        assert((m.capacity > 0))
        items: mutable DictBucket[K, T]& = m.items
        insert_index: usize = m.count
        items[insert_index].key <- key
        items[insert_index].value <- value
        m.count <- (insert_index + 1)
        m.used <- m.count
        return &items[insert_index].value

def arena_dict_get_or_insert[K, T](a: mutable Arena&, m: mutable dict[K, T]&, key: K, value: T) -> mutable T&? error[RuntimeError]:
    can Memory.Allocate, Abort.Panic:
        existing: mutable T&? = arena_dict_get(m, key)
        if (existing != null):
            return existing
        return try arena_dict_put(a, m, key, value)

def arena_dict_contains[K, T](m: dict[K, T]&, key: K) -> bool:
    return (arena_dict_get(m, key) != null)

def arena_dict_remove[K, T](m: mutable dict[K, T]&, key: K) -> bool:
    if ((m.count == 0) or (m.items == null)):
        return false
    probe: DictProbeResult = arena_dict_find_index(m, key)
    if (not probe.found):
        return false
    assert((m.items != null))
    items: mutable DictBucket[K, T]& = m.items
    last_index: usize = (m.count - 1)
    if (probe.index != last_index):
        items[probe.index] <- items[last_index]
    items[last_index] <- zeroed
    m.count <- last_index
    m.used <- m.count
    return true

def arena_dict_clear[K, T](m: mutable dict[K, T]&):
    if ((m.items == null) or (m.capacity == 0)):
        m.count <- 0
        m.used <- 0
        return
    assert((m.items != null))
    items: DictBucket[K, T]& = m.items
    arena_dict_zero_buckets(items, m.capacity)
    m.count <- 0
    m.used <- 0

def arena_dict_new__i64(a: mutable Arena&, initial_capacity: usize) -> dict[cstr[key_shape], i64]:
    return arena_dict_new[cstr[key_shape], i64](a, initial_capacity) can Memory.Allocate, Abort.Panic

def arena_dict_reserve__i64(a: mutable Arena&, m: mutable dict[cstr[key_shape], i64]&, min_capacity: usize) -> void error[RuntimeError]:
    (try arena_dict_reserve[cstr[key_shape], i64](a, m, min_capacity)) can Memory.Allocate, Abort.Panic

def arena_dict_get__i64(m: dict[cstr[key_shape], i64]&, key: cstr[key_shape]) -> mutable i64&?:
    return arena_dict_get[cstr[key_shape], i64](m, key)

def arena_dict_put__i64(a: mutable Arena&, m: mutable dict[cstr[key_shape], i64]&, key: cstr[key_shape], value: i64) -> mutable i64&? error[RuntimeError]:
    return (try arena_dict_put[cstr[key_shape], i64](a, m, key, value)) can Memory.Allocate, Abort.Panic

def arena_dict_get_or_insert__i64(a: mutable Arena&, m: mutable dict[cstr[key_shape], i64]&, key: cstr[key_shape], value: i64) -> mutable i64&? error[RuntimeError]:
    return (try arena_dict_get_or_insert[cstr[key_shape], i64](a, m, key, value)) can Memory.Allocate, Abort.Panic

def arena_dict_contains__i64(m: dict[cstr[key_shape], i64]&, key: cstr[key_shape]) -> bool:
    return arena_dict_contains[cstr[key_shape], i64](m, key)

def arena_dict_remove__i64(m: mutable dict[cstr[key_shape], i64]&, key: cstr[key_shape]) -> bool:
    return arena_dict_remove[cstr[key_shape], i64](m, key)

def arena_dict_clear__i64(m: mutable dict[cstr[key_shape], i64]&):
    arena_dict_clear[cstr[key_shape], i64](m)

def index_map[K, T](owner: mutable Arena&, initial_capacity: usize) -> IndexMap[K, T]:
    can Memory.Allocate, Abort.Panic:
        map: mutable IndexMap[K, T] = zeroed
        map.owner as & <- owner
        map.by_key <- arena_dict_new[K, usize](owner, initial_capacity)
        in owner:
            _ = map.entries.reserve(initial_capacity)
        return map

def index_map_new[K, T](owner: mutable Arena&) -> IndexMap[K, T]:
    return index_map[K, T](owner, 32) can Memory.Allocate, Abort.Panic

def new[K, T](api: IndexMapNamespace, owner: mutable Arena&) -> IndexMap[K, T]:
    can Memory.Allocate, Abort.Panic:
        _ = api
        return index_map_new[K, T](owner)

def index_map_with_capacity[K, T](owner: mutable Arena&, initial_capacity: usize) -> IndexMap[K, T]:
    return index_map[K, T](owner, initial_capacity) can Memory.Allocate, Abort.Panic

def with_capacity[K, T](api: IndexMapNamespace, owner: mutable Arena&, initial_capacity: usize) -> IndexMap[K, T]:
    can Memory.Allocate, Abort.Panic:
        _ = api
        return index_map_with_capacity[K, T](owner, initial_capacity)

def index_map_count[K, T](map: IndexMap[K, T]&) -> usize:
    return map.entries.count

def count[K, T](map: IndexMap[K, T]&) -> usize:
    return index_map_count[K, T](map)

def index_map_valid_index[K, T](map: IndexMap[K, T]&, index: usize) -> bool:
    return (index < map.entries.count)

def index_map_find_index[K, T](map: IndexMap[K, T]&, key: K) -> usize?:
    found: mutable usize&? = arena_dict_get[K, usize](map.by_key, key)
    if (found == null):
        return null
    trusted Unsafe.UncheckedIndex:
        return found[0]

def index_map_contains[K, T](map: IndexMap[K, T]&, key: K) -> bool:
    return (index_map_find_index[K, T](map, key) != null)

def index_map_entry[K, T](map: IndexMap[K, T]&, index: usize) -> IndexMapEntry[K, T]:
    assert((index < map.entries.count))
    return map.entries[index]

def index_map_value[K, T](map: IndexMap[K, T]&, index: usize) -> T:
    return index_map_entry[K, T](map, index).value

def index_map_entries[K, T](map: IndexMap[K, T]&) -> view[IndexMapEntry[K, T]]:
    return map.entries.view()

@ufcs_only
def entry[K, T](map: IndexMap[K, T]&, index: usize) -> IndexMapEntry[K, T]:
    return index_map_entry[K, T](map, index)

@ufcs_only
def value[K, T](map: IndexMap[K, T]&, index: usize) -> T:
    return index_map_value[K, T](map, index)

@ufcs_only
def entry_view[K, T](map: IndexMap[K, T]&) -> view[IndexMapEntry[K, T]]:
    return index_map_entries[K, T](map)

def index_map_put[K, T](map: mutable IndexMap[K, T]&, key: K, value: T) -> usize:
    can Memory.Allocate, Abort.Panic:
        match index_map_find_index[K, T](map, key):
            null:
                pass
            existing_index:
                assert((existing_index < map.entries.count))
                map.entries[existing_index].value <- value
                return existing_index
        assert((map.owner != null))
        owner: mutable Arena& = map.owner
        index: usize = map.entries.count
        in owner:
            map.entries.push(IndexMapEntry[K, T]{key, value})
        _ = try arena_dict_put[K, usize](owner, map.by_key, key, index) else null
        return index

def put[K, T](map: mutable IndexMap[K, T]&, key: K, value: T) -> usize:
    return index_map_put[K, T](map, key, value) can Memory.Allocate, Abort.Panic

def index_map_set[K, T](map: mutable IndexMap[K, T]&, key: K, value: T) -> usize:
    return index_map_put[K, T](map, key, value) can Memory.Allocate, Abort.Panic

def set[K, T](map: mutable IndexMap[K, T]&, key: K, value: T) -> usize:
    return index_map_set[K, T](map, key, value) can Memory.Allocate, Abort.Panic

def index_map_get[K, T](map: IndexMap[K, T]&, key: K) -> T?:
    index: usize = index_map_find_index[K, T](map, key) else return null
    value: T = index_map_value[K, T](map, index)
    return value

def get[K, T](map: IndexMap[K, T]&, key: K) -> T?:
    return index_map_get[K, T](map, key)

def index_map_has[K, T](map: IndexMap[K, T]&, key: K) -> bool:
    return index_map_contains[K, T](map, key)

def has[K, T](map: IndexMap[K, T]&, key: K) -> bool:
    return index_map_has[K, T](map, key)

def update_at[K, T](map: mutable IndexMap[K, T]&, index: usize, value: T) -> bool:
    if (not index_map_valid_index[K, T](map, index)):
        return false
    assert((index < map.entries.count))
    map.entries[index].value <- value
    return true

def clear[K, T](map: mutable IndexMap[K, T]&):
    map.entries.count <- 0
    arena_dict_clear[K, usize](map.by_key)

def symbol_table_index(symbol_id: SymbolTableId) -> usize:
    assert((symbol_id != SYMBOL_TABLE_INVALID_ID))
    return (((!symbol_id)).usize() - 1)

def symbol_table_id_from_index(index: usize) -> SymbolTableId:
    return ((index + 1)).u32().SymbolTableId()

def symbol_table[K, T](owner: mutable Arena&, initial_capacity: usize) -> SymbolTable[K, T]:
    can Memory.Allocate, Abort.Panic:
        table: mutable SymbolTable[K, T] = zeroed
        table.items <- index_map[K, T](owner, initial_capacity)
        return table

def new[K, T](api: SymbolTableNamespace, owner: mutable Arena&) -> SymbolTable[K, T]:
    can Memory.Allocate, Abort.Panic:
        _ = api
        return symbol_table[K, T](owner, 32)

def with_capacity[K, T](api: SymbolTableNamespace, owner: mutable Arena&, initial_capacity: usize) -> SymbolTable[K, T]:
    can Memory.Allocate, Abort.Panic:
        _ = api
        return symbol_table[K, T](owner, initial_capacity)

def symbol_table_count[K, T](table: SymbolTable[K, T]&) -> usize:
    return index_map_count[K, T](table.items)

def count[K, T](table: SymbolTable[K, T]&) -> usize:
    return symbol_table_count[K, T](table)

def symbol_table_valid_id[K, T](table: SymbolTable[K, T]&, symbol_id: SymbolTableId) -> bool:
    if (symbol_id == SYMBOL_TABLE_INVALID_ID):
        return false
    return index_map_valid_index[K, T](table.items, symbol_table_index(symbol_id))

def symbol_table_find_id[K, T](table: SymbolTable[K, T]&, key: K) -> SymbolTableId:
    index: usize = index_map_find_index[K, T](table.items, key) else return SYMBOL_TABLE_INVALID_ID
    return symbol_table_id_from_index(index)

def symbol_table_contains[K, T](table: SymbolTable[K, T]&, key: K) -> bool:
    return (symbol_table_find_id[K, T](table, key) != SYMBOL_TABLE_INVALID_ID)

def has[K, T](table: SymbolTable[K, T]&, key: K) -> bool:
    return symbol_table_contains[K, T](table, key)

def symbol_table_entry[K, T](table: SymbolTable[K, T]&, symbol_id: SymbolTableId) -> SymbolEntry[K, T]:
    assert(symbol_table_valid_id[K, T](table, symbol_id))
    entry: IndexMapEntry[K, T] = index_map_entry[K, T](table.items, symbol_table_index(symbol_id))
    return SymbolEntry[K, T]{key: entry.key, value: entry.value}

def symbol_table_value[K, T](table: SymbolTable[K, T]&, symbol_id: SymbolTableId) -> T:
    return symbol_table_entry[K, T](table, symbol_id).value

def symbol_table_entries[K, T](table: SymbolTable[K, T]&) -> view[IndexMapEntry[K, T]]:
    return index_map_entries[K, T](table.items)

@ufcs_only
def entry[K, T](table: SymbolTable[K, T]&, symbol_id: SymbolTableId) -> SymbolEntry[K, T]:
    return symbol_table_entry[K, T](table, symbol_id)

@ufcs_only
def value[K, T](table: SymbolTable[K, T]&, symbol_id: SymbolTableId) -> T:
    return symbol_table_value[K, T](table, symbol_id)

@ufcs_only
def entry_view[K, T](table: SymbolTable[K, T]&) -> view[IndexMapEntry[K, T]]:
    return symbol_table_entries[K, T](table)

def symbol_table_put[K, T](table: mutable SymbolTable[K, T]&, key: K, value: T) -> SymbolTableId:
    can Memory.Allocate, Abort.Panic:
        index: usize = index_map_put[K, T](table.items, key, value)
        return symbol_table_id_from_index(index)

def declare[K, T](table: mutable SymbolTable[K, T]&, key: K, value: T) -> SymbolTableId:
    return symbol_table_put[K, T](table, key, value) can Memory.Allocate, Abort.Panic

def lookup_id[K, T](table: SymbolTable[K, T]&, key: K) -> SymbolTableId:
    return symbol_table_find_id[K, T](table, key)

def get[K, T](table: SymbolTable[K, T]&, symbol_id: SymbolTableId) -> T:
    return symbol_table_value[K, T](table, symbol_id)

def lookup[K, T](table: SymbolTable[K, T]&, key: K) -> T?:
    symbol_id: SymbolTableId = symbol_table_find_id[K, T](table, key)
    if (symbol_id == SYMBOL_TABLE_INVALID_ID):
        return null
    value: T = symbol_table_value[K, T](table, symbol_id)
    return value

def symbol_table_replace[K, T](table: mutable SymbolTable[K, T]&, symbol_id: SymbolTableId, value: T) -> bool:
    if (not symbol_table_valid_id[K, T](table, symbol_id)):
        return false
    return update_at[K, T](table.items, symbol_table_index(symbol_id), value)

def update[K, T](table: mutable SymbolTable[K, T]&, symbol_id: SymbolTableId, value: T) -> bool:
    return symbol_table_replace[K, T](table, symbol_id, value)

def symbol_table_clear[K, T](table: mutable SymbolTable[K, T]&):
    clear[K, T](table.items)

struct FixedBufferAllocator:
    data: mutable u8&?
    capacity: mutable usize
    end_index: mutable usize

struct FixedBufferMark:
    end_index: usize

struct MemoryPoolFreeNode:
    next: mutable heap MemoryPoolFreeNode&?

struct MemoryPool[T]:
    arena: mutable Arena
    free_list: mutable heap MemoryPoolFreeNode&?

def fixed_buffer_allocator_init(buffer: u8&, size: usize) -> FixedBufferAllocator:
    return FixedBufferAllocator(buffer, size, 0)

def fixed_buffer_align_forward(value: usize, alignment: usize) -> usize:
    if (alignment <= 1):
        return value
    remainder: usize = (value % alignment)
    return (value if (remainder == 0) else (value + ((alignment - remainder))))

def fixed_buffer_owns_ptr(a: FixedBufferAllocator&, ptr: void&) -> bool:
    if (a.data == null):
        return false
    trusted Unsafe.PointerCast:
        base: uintptr = a.data.cast[u8&].uintptr()
        raw: uintptr = ptr.cast[u8&].uintptr()
        limit: uintptr = (base + a.capacity.uintptr())
        return ((raw >= base) and (raw < limit))

def fixed_buffer_owns_range(a: FixedBufferAllocator&, ptr: void&, size_bytes: usize) -> bool:
    if (a.data == null):
        return false
    trusted Unsafe.PointerCast:
        base: uintptr = a.data.cast[u8&].uintptr()
        raw: uintptr = ptr.cast[u8&].uintptr()
        limit: uintptr = (base + a.capacity.uintptr())
        end_raw: uintptr = (raw + size_bytes.uintptr())
        return ((raw >= base) and (end_raw <= limit))

def fixed_buffer_is_last_allocation(a: FixedBufferAllocator&, ptr: void&, size_bytes: usize) -> bool:
    if (a.data == null):
        return false
    trusted Unsafe.PointerCast:
        base: uintptr = a.data.cast[u8&].uintptr()
        raw: uintptr = ptr.cast[u8&].uintptr()
        end_raw: uintptr = (raw + size_bytes.uintptr())
        return (end_raw == (base + a.end_index.uintptr()))

def fixed_buffer_snapshot(a: FixedBufferAllocator&) -> FixedBufferMark:
    return FixedBufferMark(a.end_index)

def fixed_buffer_rewind(a: mutable FixedBufferAllocator&, mark: FixedBufferMark):
    can Abort.Panic:
        assert((mark.end_index <= a.capacity))
        a.end_index <- mark.end_index

def fixed_buffer_reset(a: mutable FixedBufferAllocator&):
    a.end_index <- 0

def fixed_buffer_alloc_align(a: mutable FixedBufferAllocator&, size_bytes: usize, alignment: usize) -> mutable void&?:
    if (a.data == null):
        return null
    trusted Unsafe.PointerCast, Unsafe.PointerArithmetic:
        base: u8& = a.data.cast[u8&]
        adjusted_addr: usize = fixed_buffer_align_forward(((base + a.end_index)).uintptr().usize(), alignment)
        adjusted_index: usize = ((adjusted_addr.uintptr() - base.uintptr())).usize()
        if (adjusted_index > a.capacity):
            return null
        if (size_bytes > (a.capacity - adjusted_index)):
            return null
        result: void& = ((base + adjusted_index)).cast[void&]
        a.end_index <- (adjusted_index + size_bytes)
        return result

def fixed_buffer_alloc(a: mutable FixedBufferAllocator&, size_bytes: usize) -> mutable void&?:
    return fixed_buffer_alloc_align(a, size_bytes, size_of(uintptr))

def fixed_buffer_alloc_align_or_panic(a: mutable FixedBufferAllocator&, size_bytes: usize, alignment: usize) -> mutable void&:
    can Abort.Panic:
        raw: void&? = fixed_buffer_alloc_align(a, size_bytes, alignment)
        assert((raw != null))
        trusted Unsafe.PointerCast:
            return raw.cast[void&]

def fixed_buffer_alloc_or_panic(a: mutable FixedBufferAllocator&, size_bytes: usize) -> mutable void&:
    can Abort.Panic:
        raw: void&? = fixed_buffer_alloc(a, size_bytes)
        assert((raw != null))
        trusted Unsafe.PointerCast:
            return raw.cast[void&]

def fixed_buffer_resize(a: mutable FixedBufferAllocator&, ptr: void&, old_size: usize, new_size: usize) -> bool:
    if (not fixed_buffer_owns_range(a, ptr, old_size)):
        return false
    if (not fixed_buffer_is_last_allocation(a, ptr, old_size)):
        return (new_size <= old_size)
    if (a.data == null):
        return false
    if (new_size <= old_size):
        a.end_index <- (a.end_index - ((old_size - new_size)))
        return true
    trusted Unsafe.PointerCast:
        base: uintptr = a.data.cast[u8&].uintptr()
        start_index: usize = ((ptr.cast[u8&].uintptr() - base)).usize()
        if ((start_index + new_size) > a.capacity):
            return false
        a.end_index <- (start_index + new_size)
        return true

def fixed_buffer_release(a: mutable FixedBufferAllocator&, ptr: void&, size_bytes: usize):
    if fixed_buffer_is_last_allocation(a, ptr, size_bytes):
        a.end_index <- (a.end_index - size_bytes)

def memory_pool_init[T]() -> MemoryPool[T]:
    return zeroed

def memory_pool_init_capacity[T](count: usize) -> MemoryPool[T]:
    out: mutable MemoryPool[T] = zeroed
    memory_pool_add_capacity(out.cast[MemoryPool[T]&], count) can Memory.Allocate, Abort.Panic
    return out

def memory_pool_add_capacity[T](pool: mutable MemoryPool[T]&, count: usize):
    can Memory.Allocate, Abort.Panic:
        item_size: mutable usize = size_of(T)
        if (item_size < size_of(MemoryPoolFreeNode)):
            item_size <- size_of(MemoryPoolFreeNode)
        for i in 0 ..< count:
            raw: heap void& = arena_alloc(pool.arena.cast[Arena&], item_size)
            trusted Unsafe.PointerCast:
                node: heap MemoryPoolFreeNode& = raw.cast[heap MemoryPoolFreeNode&]
                node.next <- pool.free_list
                pool.free_list as & <- node

def memory_pool_create[T](pool: mutable MemoryPool[T]&) -> mutable heap T&:
    can Memory.Allocate, Abort.Panic:
        if (pool.free_list != null):
            node: heap MemoryPoolFreeNode& = pool.free_list
            pool.free_list <- node.next
            trusted Unsafe.PointerCast:
                item: heap T& = node.cast[heap T&]
                item[0] <- zeroed
                return item
        item_size: mutable usize = size_of(T)
        if (item_size < size_of(MemoryPoolFreeNode)):
            item_size <- size_of(MemoryPoolFreeNode)
        raw: heap void& = arena_alloc(pool.arena.cast[Arena&], item_size)
        trusted Unsafe.PointerCast:
            item: heap T& = raw.cast[heap T&]
            item[0] <- zeroed
            return item

def memory_pool_destroy[T](pool: mutable MemoryPool[T]&, ptr: mutable heap T&):
    ptr[0] <- zeroed
    trusted Unsafe.PointerCast:
        node: heap MemoryPoolFreeNode& = ptr.cast[heap MemoryPoolFreeNode&]
        node.next <- pool.free_list
        pool.free_list as & <- node

def memory_pool_reset[T](pool: mutable MemoryPool[T]&):
    arena_reset(pool.arena.cast[Arena&])
    pool.free_list <- null

def memory_pool_deinit[T](pool: mutable MemoryPool[T]&):
    arena_free(pool.arena.cast[Arena&]) can Memory.Release, Abort.Panic
    pool.arena <- zeroed
    pool.free_list <- null

const PACKED_STORE_MIN_ROWS_PER_REGION: usize = 64

@inline(always)
def packed_store_region_data(r: heap Region&) -> heap u8&:
    return ((r.cast[heap u8&] + size_of(Region))).cast[heap u8&]

def packed_store_region_table(state: mutable PackedStoreState&) -> mutable darray[heap Region&?]&:
    return state.regions.cast[darray[heap Region&?]&]

def packed_store_index_table(state: mutable PackedStoreState&) -> mutable darray[u32]&:
    return state.indices.cast[darray[u32]&]

def packed_store_variant_slot_table(state: mutable PackedStoreState&) -> mutable darray[u32]&:
    return state.variant_slots.cast[darray[u32]&]

def packed_store_prefix_column_table(state: mutable PackedStoreState&) -> mutable darray[uintptr]&:
    return state.prefix_columns.cast[darray[uintptr]&]

def packed_store_side_column_table(state: mutable PackedStoreState&) -> mutable darray[uintptr]&:
    return state.side_columns.cast[darray[uintptr]&]

def packed_store_ensure_metadata_capacity(a: mutable Arena&, state: mutable PackedStoreState&, needed_rows: usize):
    can Memory.Allocate, Abort.Panic:
        handles: mutable darray[uintptr]& = packed_store_handle_table(state)
        indices: mutable darray[u32]& = packed_store_index_table(state)
        tags: mutable darray[u32]& = packed_store_tag_table(state)
        variant_slots: mutable darray[u32]& = packed_store_variant_slot_table(state)
        in a:
            _ = handles.reserve(needed_rows)
            _ = indices.reserve(needed_rows)
            _ = tags.reserve(needed_rows)
            _ = variant_slots.reserve(needed_rows)
        packed_store_ensure_prefix_columns(a, state, needed_rows)
        packed_store_ensure_side_columns(a, state, needed_rows)

def packed_store_append_index(a: mutable Arena&, state: mutable PackedStoreState&, index: u32):
    can Memory.Allocate, Abort.Panic:
        indices: mutable darray[u32]& = packed_store_index_table(state)
        in a:
            indices.push(index)

def packed_store_append_variant_slot(a: mutable Arena&, state: mutable PackedStoreState&, slot: u32):
    can Memory.Allocate, Abort.Panic:
        variant_slots: mutable darray[u32]& = packed_store_variant_slot_table(state)
        in a:
            variant_slots.push(slot)

def packed_store_ensure_prefix_columns(a: mutable Arena&, state: mutable PackedStoreState&, needed_rows: usize):
    can Memory.Allocate, Abort.Panic:
        if (state.prefix_words == 0):
            return
        columns: mutable darray[uintptr]& = packed_store_prefix_column_table(state)
        in a:
            for column_index in columns.count ..< state.prefix_words:
                columns.push(0.uintptr())
        if (state.prefix_column_capacity >= needed_rows):
            return
        new_capacity: mutable usize = (ARENA_DA_INIT_CAP if (state.prefix_column_capacity == 0) else (state.prefix_column_capacity * 2))
        trusted Unsafe.AssumeProgress:
            while (new_capacity < needed_rows):
                new_capacity <- (new_capacity * 2)
        old_size: usize = (state.prefix_column_capacity * size_of(uintptr))
        new_size: usize = (new_capacity * size_of(uintptr))
        assert((columns.items != null))
        column_ptrs: uintptr& = columns.items
        for i in 0 ..< state.prefix_words:
            if (column_ptrs[i] == 0.uintptr()):
                column_ptrs[i] <- arena_alloc(a, new_size).cast[heap uintptr&].cast[heap u8&].uintptr()
            else:
                current_ptr: heap uintptr& = column_ptrs[i].cast[heap u8&].cast[heap uintptr&]
                column_ptrs[i] <- arena_realloc(a, current_ptr.cast[mutable void&], old_size, new_size).cast[heap uintptr&].cast[heap u8&].uintptr()
        state.prefix_column_capacity <- new_capacity

def packed_store_ensure_side_columns(a: mutable Arena&, state: mutable PackedStoreState&, needed_rows: usize):
    can Memory.Allocate, Abort.Panic:
        if (state.side_words == 0):
            return
        columns: mutable darray[uintptr]& = packed_store_side_column_table(state)
        in a:
            for column_index in columns.count ..< state.side_words:
                columns.push(0.uintptr())
        if (state.side_column_capacity >= needed_rows):
            return
        new_capacity: mutable usize = (ARENA_DA_INIT_CAP if (state.side_column_capacity == 0) else (state.side_column_capacity * 2))
        trusted Unsafe.AssumeProgress:
            while (new_capacity < needed_rows):
                new_capacity <- (new_capacity * 2)
        old_size: usize = (state.side_column_capacity * size_of(uintptr))
        new_size: usize = (new_capacity * size_of(uintptr))
        assert((columns.items != null))
        column_ptrs: uintptr& = columns.items
        for i in 0 ..< state.side_words:
            if (column_ptrs[i] == 0.uintptr()):
                column_ptrs[i] <- arena_alloc(a, new_size).cast[heap uintptr&].cast[heap u8&].uintptr()
            else:
                current_ptr: heap uintptr& = column_ptrs[i].cast[heap u8&].cast[heap uintptr&]
                column_ptrs[i] <- arena_realloc(a, current_ptr.cast[mutable void&], old_size, new_size).cast[heap uintptr&].cast[heap u8&].uintptr()
        state.side_column_capacity <- new_capacity

def packed_store_register_region(a: mutable Arena&, state: mutable PackedStoreState&, r: heap Region&?, global_index: usize):
    can Memory.Allocate, Abort.Panic:
        assert((r != null))
        regions: mutable darray[heap Region&?]& = packed_store_region_table(state)
        in a:
            for region_slot in regions.count ..< ((global_index + 1)):
                regions.push(null)
        assert((regions.items != null))
        regions.items[global_index] <- r

@inline(always)
def packed_store_lookup_region(state: mutable PackedStoreState&, global_index: usize) -> heap Region&?:
    if (state.regions.items == null):
        return null
    return (null if (global_index >= state.regions.count) else state.regions.items[global_index])

def ctx_packed_store_state_new(a: mutable Arena&, row_bytes: usize) -> mutable heap void&:
    can Memory.Allocate, Abort.Panic:
        state: heap PackedStoreState& = arena_alloc(a, size_of(PackedStoreState)).cast[heap PackedStoreState&]
        row_words: usize = ((((row_bytes + size_of(uintptr)) - 1)) / size_of(uintptr))
        preferred_region_capacity: mutable usize = ARENA_REGION_DEFAULT_CAPACITY
        hinted_capacity: usize = (row_words * PACKED_STORE_MIN_ROWS_PER_REGION)
        if (preferred_region_capacity < hinted_capacity):
            preferred_region_capacity <- hinted_capacity
        if (preferred_region_capacity < row_words):
            preferred_region_capacity <- row_words
        state.head_region <- null
        state.alloc_region <- null
        state.alloc_region_index <- 0
        state.decode_region <- null
        state.decode_region_index <- 0
        state.tail_region <- null
        state.regions <- zeroed
        state.handles <- zeroed
        state.indices <- zeroed
        state.tags <- zeroed
        state.variant_slots <- zeroed
        state.variant_rows <- zeroed
        state.prefix_words <- row_words
        state.prefix_columns <- zeroed
        state.prefix_column_capacity <- 0
        state.side_words <- 0
        state.side_columns <- zeroed
        state.side_column_capacity <- 0
        state.row_words <- row_words
        state.preferred_region_capacity <- preferred_region_capacity
        return state.cast[heap void&]

def ctx_packed_store_alloc_result_slow(a: mutable Arena&, size: usize, owner_tag: uintptr, state: mutable PackedStoreState&):
    can Memory.Allocate, Abort.Panic:
        if (state.alloc_region == null):
            capacity: mutable usize = state.preferred_region_capacity
            if (capacity < size):
                capacity <- size
            if (a.end == null):
                assert((a.begin == null))
                a.end as & <- new_region_with_owner(capacity, owner_tag)
                a.begin <- a.end
                a.end_index <- 0
                a.end.global_index <- 0
            else:
                a.end.next as & <- new_region_with_owner(capacity, owner_tag)
                a.end <- a.end.next
                a.end_index <- (a.end_index + 1)
                a.end.global_index <- a.end_index
            state.head_region <- a.end
            state.alloc_region <- a.end
            state.alloc_region_index <- a.end_index
            state.tail_region <- a.end
            packed_store_register_region(a, state, a.end, a.end_index)
            return
        assert((state.alloc_region != null))
        assert((state.tail_region != null))
        cursor: mutable heap Region&? = state.alloc_region.owner_next
        found_region: mutable heap Region&? = null
        found_region_index: mutable usize = 0
        trusted Unsafe.AssumeProgress:
            while (cursor != null):
                if ((cursor.count + size) <= cursor.capacity):
                    found_region <- cursor
                    found_region_index <- cursor.global_index
                    cursor <- null
                else:
                    cursor <- cursor.owner_next
        if (found_region != null):
            state.alloc_region <- found_region
            state.alloc_region_index <- found_region_index
            return
        capacity: mutable usize = state.preferred_region_capacity
        grown_capacity: usize = (state.alloc_region.capacity * 2)
        if (capacity < grown_capacity):
            capacity <- grown_capacity
        if (capacity < size):
            capacity <- size
        assert((a.end != null))
        a.end.next as & <- new_region_with_owner(capacity, owner_tag)
        a.end <- a.end.next
        a.end_index <- (a.end_index + 1)
        a.end.global_index <- a.end_index
        state.tail_region.owner_next as & <- a.end
        state.tail_region <- a.end
        state.alloc_region <- a.end
        state.alloc_region_index <- a.end_index
        packed_store_register_region(a, state, a.end, a.end_index)

