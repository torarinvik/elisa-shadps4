# @port core/libraries/network/net.cpp::sceNetBind sha256=13212432feb28b54 oracle@a3773841
def sceNetBind(s: i64, addr: u8&?, addrlen: int) -> int:
    err: int = sceNet_RequireInit()
    if (err != ORBIS_OK):
        return err
    idx: int = sceNet_FindSocket(s)
    if (idx < 0):
        sceNet_SetErr(ORBIS_NET_ERROR_ENOTSOCK)
        return ORBIS_NET_ERROR_ENOTSOCK
    result: int = c_bind(s.int(), addr, addrlen.u32())
    return sceNet_FfiIntResult(result, ORBIS_NET_ERROR_EINVAL)

