# @port core/libraries/network/netctl.cpp::sceNetCtlGetInfo sha256=0ed37dcc3ce1d566 oracle@a3773841
def sceNetCtlGetInfo(code: int, info: mutable OrbisNetCtlInfo&?) -> int:
    if (info == null):
        return ORBIS_NET_CTL_ERROR_INVALID_ADDR
    payload: mutable array[u8, 256] = zeroed
    result: int = c_netctl_get_info(code, payload[0].cast[mutable u8&])
    if (result == ORBIS_OK):
        _NetCtl_CopyInfoPayload(code, info, payload[0].cast[mutable u8&])
    return result

