# @port core/libraries/network/net.cpp::sceNetHtonl sha256=05574622bc2a0d86 oracle@a3773841
def sceNetHtonl(host32: u32) -> u32:
    b0: u32 = (((host32 & 0xff)) << 24)
    b1: u32 = (((host32 & 0xff00)) << 8)
    b2: u32 = (((host32 >> 8)) & 0xff00)
    b3: u32 = (((host32 >> 24)) & 0xff)
    return (((b0 | b1) | b2) | b3)

# @port core/libraries/network/net.cpp::sceNetHtonll sha256=00a5048523d79dd5 oracle@a3773841
def sceNetHtonll(host64: u64) -> u64:
    lo: u64 = sceNetHtonl(((host64 & 0xffffffff)).u32()).u64()
    hi: u64 = sceNetHtonl(((host64 >> 32)).u32()).u64()
    return (((lo << 32)) | hi)

# @port core/libraries/network/net.cpp::sceNetHtons sha256=339907b87a2ba7e9 oracle@a3773841
def sceNetHtons(host16: u16) -> u16:
    return (((((host16 & 0xff)) << 8)) | ((((host16 >> 8)) & 0xff)))

