struct NetParityEpollEvent:
    events: mutable u32
    pad: mutable u32
    ident: mutable u64
    data_u64: mutable u64

@test
def net_get_mac_address_bridge_parity_contracts() -> void:
    can Abort.Panic:
        assert((sceNetGetMacAddress(null, 0) == ORBIS_NET_EINVAL))
        mac: mutable array[u8, 6] = zeroed
        assert((sceNetGetMacAddress(mac[0].cast[mutable u8&], 0) == ORBIS_OK))

@test
def net_inet_bridge_parity_contracts() -> void:
    can Abort.Panic:
        src4: mutable array[u8, 4] = zeroed
        src4[0] <- 127
        src4[3] <- 1
        text4: mutable array[u8, 16] = zeroed
        assert((sceNetInetNtop(ORBIS_NET_AF_INET, src4[0].cast[mutable u8&], text4[0].cast[mutable u8&], 16) != null))
        tiny: mutable array[u8, 1] = zeroed
        assert((sceNetInetNtop(ORBIS_NET_AF_INET, src4[0].cast[mutable u8&], tiny[0].cast[mutable u8&], 1) == null))
        assert((c_net_errno() == ORBIS_NET_ENOSPC))
        assert((sceNetInetNtop(9999, src4[0].cast[mutable u8&], text4[0].cast[mutable u8&], 16) == null))
        assert((c_net_errno() == ORBIS_NET_EAFNOSUPPORT))
        parsed4: mutable array[u8, 4] = zeroed
        assert((sceNetInetPton(ORBIS_NET_AF_INET, "127.0.0.1", parsed4[0].cast[mutable u8&]) == 1))
        assert((parsed4[0] == 127))
        assert((parsed4[3] == 1))

@test
def netctl_info_state_bridge_parity_contracts() -> void:
    can Abort.Panic:
        prev_connected: int = c_is_connected_to_network()
        info: mutable OrbisNetCtlInfo = zeroed
        c_set_connected_to_network(0)
        assert((sceNetCtlGetInfo(ORBIS_NET_CTL_INFO_DEVICE, info.cast[mutable OrbisNetCtlInfo&]) == ORBIS_NET_CTL_ERROR_NOT_CONNECTED))
        c_set_connected_to_network(1)
        state: mutable int = 0
        assert((sceNetCtlGetState(state.cast[mutable int&]) == ORBIS_OK))
        assert((state == ORBIS_NET_CTL_STATE_IPOBTAINED))
        assert((sceNetCtlGetInfo(ORBIS_NET_CTL_INFO_DEVICE, info.cast[mutable OrbisNetCtlInfo&]) == ORBIS_OK))
        assert((info.device == ORBIS_NET_CTL_DEVICE_WIRED.u32()))
        assert((sceNetCtlGetInfo(ORBIS_NET_CTL_INFO_MTU, info.cast[mutable OrbisNetCtlInfo&]) == ORBIS_OK))
        assert((info.mtu == 1500))
        assert((sceNetCtlGetInfo(ORBIS_NET_CTL_INFO_PRIMARY_DNS, info.cast[mutable OrbisNetCtlInfo&]) == ORBIS_OK))
        assert((info.primary_dns[0] == '1'.u8()))
        c_set_connected_to_network(prev_connected)

@test
def net_resolver_bridge_parity_contracts() -> void:
    can Abort.Panic:
        assert((sceNetInit() == ORBIS_OK))
        status: mutable int = 0
        assert((sceNetResolverGetError(12345, status.cast[mutable int&]) == ORBIS_NET_ERROR_EBADF))
        assert((sceNetResolverGetError(12345, null) == ORBIS_NET_ERROR_EINVAL))
        rid: int = sceNetResolverCreate(null, 1, 0)
        assert((rid > 0))
        assert((sceNetResolverGetError(rid.i64(), status.cast[mutable int&]) == ORBIS_OK))
        addr: mutable u32 = 0
        assert((sceNetResolverStartNtoa(rid.i64(), "localhost", addr.cast[mutable u32&].cast[mutable u8&], 0, 0, 0) == ORBIS_OK))
        assert((sceNetResolverDestroy(rid.i64()) == ORBIS_OK))
        assert((sceNetResolverDestroy(rid.i64()) == ORBIS_NET_ERROR_EBADF))

@test
def net_epoll_bridge_parity_contracts() -> void:
    can Abort.Panic:
        assert((sceNetInit() == ORBIS_OK))
        assert((sceNetEpollDestroy(9999) == ORBIS_NET_ERROR_EBADF))
        assert((sceNetEpollWait(9999, null, 1, 0) == ORBIS_NET_ERROR_EBADF))
        ep: int = sceNetEpollCreate("elisa-epoll", 0)
        assert((ep > 0))
        sock: i64 = sceNetSocket("ep-sock", ORBIS_NET_AF_INET, ORBIS_NET_SOCK_STREAM.int(), 0)
        assert((sock > 0))
        event_storage: mutable array[u8, 32] = zeroed
        event_ptr: mutable u8& = event_storage[0].cast[mutable u8&]
        assert((sceNetEpollControl(ep.i64(), 1, sock, event_ptr) == ORBIS_OK))
        assert((sceNetEpollControl(ep.i64(), 1, sock, event_ptr) == ORBIS_NET_ERROR_EEXIST))
        assert((sceNetEpollControl(ep.i64(), 99, sock, event_ptr) == ORBIS_NET_ERROR_EINVAL))
        assert((sceNetEpollControl(ep.i64(), 3, sock, null) == ORBIS_OK))
        assert((sceNetEpollControl(ep.i64(), 3, sock, null) == ORBIS_NET_ERROR_EBADF))
        assert((sceNetSocketClose(sock) == ORBIS_OK))
        assert((sceNetEpollDestroy(ep.i64()) == ORBIS_OK))

@test
def net_resolver_async_epoll_bridge_contracts() -> void:
    can Abort.Panic:
        assert((sceNetInit() == ORBIS_OK))
        rid: int = sceNetResolverCreate("resolver-async", 1, 0)
        assert((rid > 0))
        assert((sceNetResolverStartNtoa(987654, "localhost", null, 0, 0, ORBIS_NET_RESOLVER_ASYNC) == ORBIS_NET_ERROR_EBADF))
        ep: int = sceNetEpollCreate("resolver-epoll", 0)
        assert((ep > 0))
        event_storage: mutable array[u8, 32] = zeroed
        event_ptr: mutable u8& = event_storage[0].cast[mutable u8&]
        assert((sceNetEpollControl(ep.i64(), 1, rid.i64(), event_ptr) == ORBIS_OK))
        addr: mutable u32 = 0
        first_async: int = sceNetResolverStartNtoa(rid.i64(), "localhost", addr.cast[mutable u32&].cast[mutable u8&], 0, 0, ORBIS_NET_RESOLVER_ASYNC)
        assert((first_async == ORBIS_OK))
        second_async: int = sceNetResolverStartNtoa(rid.i64(), "localhost", addr.cast[mutable u32&].cast[mutable u8&], 0, 0, ORBIS_NET_RESOLVER_ASYNC)
        assert((second_async == ORBIS_NET_ERROR_RESOLVER_EBUSY))
        wait_storage: mutable array[u8, 32] = zeroed
        wait_ptr: mutable u8& = wait_storage[0].cast[mutable u8&]
        wait_ret: int = sceNetEpollWait(ep.i64(), wait_ptr, 1, 0)
        assert((wait_ret >= 0))
        assert((wait_ret <= 1))
        if (wait_ret == 1):
            ev: mutable NetParityEpollEvent& = wait_ptr.cast[mutable NetParityEpollEvent&]
            assert((ev.ident == rid.u64()))
            assert((ev.events == ORBIS_NET_EPOLLDESCID))
        status: mutable int = 0
        assert((sceNetResolverGetError(rid.i64(), status.cast[mutable int&]) == ORBIS_OK))
        bad_addr: mutable u32 = 0
        bad_lookup: int = sceNetResolverStartNtoa(rid.i64(), "definitely-not-a-real-hostname.invalid", bad_addr.cast[mutable u32&].cast[mutable u8&], 0, 0, 0)
        assert((bad_lookup != ORBIS_OK))
        assert((sceNetEpollControl(ep.i64(), 3, rid.i64(), null) == ORBIS_OK))
        assert((sceNetEpollDestroy(ep.i64()) == ORBIS_OK))
        assert((sceNetResolverDestroy(rid.i64()) == ORBIS_OK))

@test
def net_resolver_offline_enodns_contracts() -> void:
    can Abort.Panic:
        assert((sceNetInit() == ORBIS_OK))
        prev_connected: int = c_is_connected_to_network()
        c_set_connected_to_network(0)
        rid: int = sceNetResolverCreate("resolver-offline", 1, 0)
        assert((rid > 0))
        addr: mutable u32 = 0
        sync_result: int = sceNetResolverStartNtoa(rid.i64(), "localhost", addr.cast[mutable u32&].cast[mutable u8&], 0, 0, 0)
        assert((sync_result == ORBIS_NET_ERROR_RESOLVER_ENODNS))
        async_result: int = sceNetResolverStartNtoa(rid.i64(), "localhost", addr.cast[mutable u32&].cast[mutable u8&], 0, 0, ORBIS_NET_RESOLVER_ASYNC)
        assert(((async_result == ORBIS_NET_ERROR_RESOLVER_ENODNS) or (async_result == ORBIS_OK)))
        status: mutable int = 0
        assert((sceNetResolverGetError(rid.i64(), status.cast[mutable int&]) == ORBIS_OK))
        if (async_result == ORBIS_NET_ERROR_RESOLVER_ENODNS):
            assert((status == ORBIS_NET_ERROR_RESOLVER_ENODNS))
        assert((sceNetResolverDestroy(rid.i64()) == ORBIS_OK))
        c_set_connected_to_network(prev_connected)

def main() -> int:
    assert((sceNetInit() == ORBIS_OK))
    if (sceNetGetMacAddress(null, 0) != ORBIS_NET_EINVAL):
        return 16
    mac: mutable array[u8, 6] = zeroed
    if (sceNetGetMacAddress(mac[0].cast[mutable u8&], 0) != ORBIS_OK):
        return 17
    src4: mutable array[u8, 4] = zeroed
    src4[0] <- 127
    src4[3] <- 1
    text4: mutable array[u8, 16] = zeroed
    if (sceNetInetNtop(ORBIS_NET_AF_INET, src4[0].cast[mutable u8&], text4[0].cast[mutable u8&], 16) == null):
        return 18
    tiny: mutable array[u8, 1] = zeroed
    if (sceNetInetNtop(ORBIS_NET_AF_INET, src4[0].cast[mutable u8&], tiny[0].cast[mutable u8&], 1) != null):
        return 19
    if (c_net_errno() != ORBIS_NET_ENOSPC):
        return 20
    parsed4: mutable array[u8, 4] = zeroed
    if (sceNetInetPton(ORBIS_NET_AF_INET, "127.0.0.1", parsed4[0].cast[mutable u8&]) != 1):
        return 21
    info: mutable OrbisNetCtlInfo = zeroed
    prev_netctl_connected: int = c_is_connected_to_network()
    c_set_connected_to_network(0)
    if (sceNetCtlGetInfo(ORBIS_NET_CTL_INFO_DEVICE, info.cast[mutable OrbisNetCtlInfo&]) != ORBIS_NET_CTL_ERROR_NOT_CONNECTED):
        c_set_connected_to_network(prev_netctl_connected)
        return 22
    c_set_connected_to_network(1)
    state_check: mutable int = 0
    if (sceNetCtlGetState(state_check.cast[mutable int&]) != ORBIS_OK):
        c_set_connected_to_network(prev_netctl_connected)
        return 23
    if (state_check != ORBIS_NET_CTL_STATE_IPOBTAINED):
        c_set_connected_to_network(prev_netctl_connected)
        return 24
    if (sceNetCtlGetInfo(ORBIS_NET_CTL_INFO_MTU, info.cast[mutable OrbisNetCtlInfo&]) != ORBIS_OK):
        c_set_connected_to_network(prev_netctl_connected)
        return 25
    if (info.mtu != 1500):
        c_set_connected_to_network(prev_netctl_connected)
        return 26
    c_set_connected_to_network(prev_netctl_connected)
    status: mutable int = 0
    if (sceNetResolverGetError(12345, status.cast[mutable int&]) != ORBIS_NET_ERROR_EBADF):
        return 1
    if (sceNetResolverGetError(12345, null) != ORBIS_NET_ERROR_EINVAL):
        return 2
    rid: int = sceNetResolverCreate("main-resolver", 1, 0)
    if (rid <= 0):
        return 3
    addr: mutable u32 = 0
    if (sceNetResolverStartNtoa(rid.i64(), "localhost", addr.cast[mutable u32&].cast[mutable u8&], 0, 0, 0) != ORBIS_OK):
        return 4
    ep: int = sceNetEpollCreate("main-epoll", 0)
    if (ep <= 0):
        return 5
    event_storage: mutable array[u8, 32] = zeroed
    event_ptr: mutable u8& = event_storage[0].cast[mutable u8&]
    if (sceNetEpollControl(ep.i64(), 1, rid.i64(), event_ptr) != ORBIS_OK):
        return 6
    if (sceNetEpollControl(ep.i64(), 99, rid.i64(), event_ptr) != ORBIS_NET_ERROR_EINVAL):
        return 7
    if (sceNetResolverStartNtoa(rid.i64(), "localhost", addr.cast[mutable u32&].cast[mutable u8&], 0, 0, ORBIS_NET_RESOLVER_ASYNC) != ORBIS_OK):
        return 8
    if (sceNetResolverStartNtoa(rid.i64(), "localhost", addr.cast[mutable u32&].cast[mutable u8&], 0, 0, ORBIS_NET_RESOLVER_ASYNC) != ORBIS_NET_ERROR_RESOLVER_EBUSY):
        return 9
    wait_storage: mutable array[u8, 32] = zeroed
    wait_ptr: mutable u8& = wait_storage[0].cast[mutable u8&]
    wait_ret: int = sceNetEpollWait(ep.i64(), wait_ptr, 1, 0)
    if ((wait_ret < 0) or (wait_ret > 1)):
        return 10
    if (wait_ret == 1):
        ev: mutable NetParityEpollEvent& = wait_ptr.cast[mutable NetParityEpollEvent&]
        if (ev.ident != rid.u64()):
            return 11
    prev_connected: int = c_is_connected_to_network()
    c_set_connected_to_network(0)
    offline_ret: int = sceNetResolverStartNtoa(rid.i64(), "localhost", addr.cast[mutable u32&].cast[mutable u8&], 0, 0, 0)
    c_set_connected_to_network(prev_connected)
    if (offline_ret != ORBIS_NET_ERROR_RESOLVER_ENODNS):
        return 12
    if (sceNetEpollControl(ep.i64(), 3, rid.i64(), null) != ORBIS_OK):
        return 13
    if (sceNetEpollDestroy(ep.i64()) != ORBIS_OK):
        return 14
    if (sceNetResolverDestroy(rid.i64()) != ORBIS_OK):
        return 15
    return 0
