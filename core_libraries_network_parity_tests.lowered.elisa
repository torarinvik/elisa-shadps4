# @port core/libraries/network/net.cpp::sceNetConnect sha256=6d7676b62de9e673 oracle@a3773841
def sceNetConnect(s: i64, addr: u8&?, addrlen: int) -> int:
    err: int = sceNet_RequireInit()
    if (err != ORBIS_OK):
        return err
    if (addr == null):
        sceNet_SetErr(ORBIS_NET_ERROR_EINVAL)
        return ORBIS_NET_ERROR_EINVAL
    idx: int = sceNet_FindSocket(s)
    if (idx < 0):
        sceNet_SetErr(ORBIS_NET_ERROR_ENOTSOCK)
        return ORBIS_NET_ERROR_ENOTSOCK
    result: int = c_connect(s.int(), addr, addrlen.u32())
    if (result < 0):
        return sceNet_FfiIntResult(result, ORBIS_NET_ERROR_ECONNREFUSED)
    slot: mutable OrbisNetSocketState& = g_net_sockets[idx.usize()].cast[mutable OrbisNetSocketState&]
    slot.connected <- true
    slot.listening <- false
    sceNet_SetErr(ORBIS_OK)
    return ORBIS_OK

