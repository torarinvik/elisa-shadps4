# @port core/libraries/network/net.cpp::sceNetShutdown sha256=ed1b48198fea992a oracle@a3773841
def sceNetShutdown(s: i64, how: int) -> int:
    err: int = sceNet_RequireInit()
    if (err != ORBIS_OK):
        return err
    idx: int = sceNet_FindSocket(s)
    if (idx < 0):
        sceNet_SetErr(ORBIS_NET_ERROR_ENOTSOCK)
        return ORBIS_NET_ERROR_ENOTSOCK
    result: int = c_shutdown(s.int(), how)
    if (result < 0):
        return sceNet_FfiIntResult(result, ORBIS_NET_ERROR_ENOTCONN)
    slot: mutable OrbisNetSocketState& = g_net_sockets[idx.usize()].cast[mutable OrbisNetSocketState&]
    slot.shutdown_state <- how
    sceNet_SetErr(ORBIS_OK)
    return ORBIS_OK

# @port core/libraries/network/net.cpp::sceNetSocket sha256=9142cad74bfb4638 oracle@a3773841
def sceNetSocket(name: u8&?, family: int, type: int, protocol: int) -> i64:
    err: int = sceNet_RequireInit()
    if (err != ORBIS_OK):
        return ORBIS_NET_ERROR_ENOTINIT
    native_fd: int = c_socketex(name, family, type, protocol)
    if (native_fd < 0):
        sceNet_SetErr(ORBIS_NET_ERROR_EPROTONOSUPPORT)
        return ORBIS_NET_ERROR_EPROTONOSUPPORT
    i: usize = 0
    while (i < ORBIS_NET_MAX_SOCKETS):
        slot: mutable OrbisNetSocketState& = g_net_sockets[i].cast[mutable OrbisNetSocketState&]
        if (not slot.in_use):
            slot.in_use <- true
            slot.handle <- native_fd.i64()
            slot.connected <- false
            slot.listening <- false
            slot.shutdown_state <- 0
            _ = name
            sceNet_SetErr(ORBIS_OK)
            return slot.handle.int()
        i += 1
    _ = c_close(native_fd)
    sceNet_SetErr(ORBIS_NET_ERROR_ENFILE)
    return (-1)

# @port core/libraries/network/net.cpp::sceNetSocketAbort sha256=5d38062a531a457f oracle@a3773841
def sceNetSocketAbort(s: i64, flags: int) -> int:
    err: int = sceNet_RequireInit()
    if (err != ORBIS_OK):
        return err
    idx: int = sceNet_FindSocket(s)
    if (idx < 0):
        sceNet_SetErr(ORBIS_NET_ERROR_ENOTSOCK)
        return ORBIS_NET_ERROR_ENOTSOCK
    result: int = c_netabort(s.int(), flags)
    return sceNet_FfiIntResult(result, ORBIS_NET_ERROR_EBADF)

# @port core/libraries/network/net.cpp::sceNetSocketClose sha256=71d4e0195758eb9b oracle@a3773841
def sceNetSocketClose(s: i64) -> int:
    if (not g_net_initialized):
        return ORBIS_NET_ERROR_ENOTINIT
    idx: int = sceNet_FindSocket(s)
    if (idx < 0):
        return ORBIS_NET_ERROR_ENOTSOCK
    result: int = c_close(s.int())
    if (result < 0):
        return sceNet_FfiIntResult(result, ORBIS_NET_ERROR_EBADF)
    slot: mutable OrbisNetSocketState& = g_net_sockets[idx.usize()].cast[mutable OrbisNetSocketState&]
    slot <- zeroed
    g_net_last_error <- ORBIS_OK
    return ORBIS_OK

