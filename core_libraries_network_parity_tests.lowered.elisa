        in a:
            state.tags.push(tag)

def ctx_packed_store_read_tag(a: mutable Arena&, handle: uintptr, state_bits: mutable void&) -> u32:
    assert((handle != 0.uintptr()))
    if ((handle & 1.uintptr()) != 0.uintptr()):
        return ((handle >> 49.uintptr())).u32()
    region_index: usize = ((handle >> 32.uintptr())).usize()
    offset_words_plus_one: usize = ((((handle & 0xffffffff.u64().uintptr())) >> 1.uintptr())).usize()
    assert((offset_words_plus_one > 0))
    if (state_bits != null):
        state: PackedStoreState& = state_bits.cast[PackedStoreState&]
        if ((state.alloc_region != null) and (state.alloc_region_index == region_index)):
            offset_words: usize = (offset_words_plus_one - 1)
            assert((offset_words < state.alloc_region.capacity))
            data_base: heap u8& = packed_store_region_data(state.alloc_region)
            row_tag: u32& = ((data_base + (offset_words * size_of(uintptr)))).cast[u32&]
            return row_tag[0]
        if ((state.decode_region != null) and (state.decode_region_index == region_index)):
            offset_words: usize = (offset_words_plus_one - 1)
            assert((offset_words < state.decode_region.capacity))
            data_base: heap u8& = packed_store_region_data(state.decode_region)
            row_tag: u32& = ((data_base + (offset_words * size_of(uintptr)))).cast[u32&]
            return row_tag[0]
        indexed_region: heap Region&? = packed_store_lookup_region(state, region_index)
        if (indexed_region != null):
            offset_words: usize = (offset_words_plus_one - 1)
            assert((offset_words < indexed_region.capacity))
            state.decode_region <- indexed_region
            state.decode_region_index <- region_index
            data_base: heap u8& = packed_store_region_data(indexed_region)
            row_tag: u32& = ((data_base + (offset_words * size_of(uintptr)))).cast[u32&]
            return row_tag[0]
    r: mutable heap Region&? = a.begin
    i: mutable usize = 0
    if (state_bits != null):
        state: PackedStoreState& = state_bits.cast[PackedStoreState&]
        owner_cursor: mutable heap Region&? = null
        owner_cursor_index: mutable usize = 0
        if ((state.head_region != null) and (state.head_region.global_index <= region_index)):
            owner_cursor <- state.head_region
            owner_cursor_index <- state.head_region.global_index
            r <- state.head_region
            i <- state.head_region.global_index
        if ((state.alloc_region != null) and (state.alloc_region_index <= region_index)):
            if ((owner_cursor == null) or (state.alloc_region_index > owner_cursor_index)):
                owner_cursor <- state.alloc_region
                owner_cursor_index <- state.alloc_region_index
            if ((r == null) or (state.alloc_region_index > i)):
                r <- state.alloc_region
                i <- state.alloc_region_index
        if ((state.decode_region != null) and (state.decode_region_index <= region_index)):
            if ((owner_cursor == null) or (state.decode_region_index > owner_cursor_index)):
                owner_cursor <- state.decode_region
                owner_cursor_index <- state.decode_region_index
            if ((r == null) or (state.decode_region_index > i)):
                r <- state.decode_region
                i <- state.decode_region_index
        if (owner_cursor != null):
            trusted Unsafe.AssumeProgress:
                while ((owner_cursor != null) and (owner_cursor.global_index < region_index)):
                    owner_cursor <- owner_cursor.owner_next
            if ((owner_cursor != null) and (owner_cursor.global_index == region_index)):
                offset_words: usize = (offset_words_plus_one - 1)
                assert((offset_words < owner_cursor.capacity))
                state.decode_region <- owner_cursor
                state.decode_region_index <- region_index
                data_base: heap u8& = packed_store_region_data(owner_cursor)
                row_tag: u32& = ((data_base + (offset_words * size_of(uintptr)))).cast[u32&]
                return row_tag[0]
    trusted Unsafe.AssumeProgress:
        while ((i < region_index) and (r != null)):
            r <- r.next
            i <- (i + 1)
    assert((r != null))
    offset_words: usize = (offset_words_plus_one - 1)
    assert((offset_words < r.capacity))
    if (state_bits != null):
        state: PackedStoreState& = state_bits.cast[PackedStoreState&]
        state.decode_region <- r
        state.decode_region_index <- region_index
    data_base: heap u8& = packed_store_region_data(r)
    row_tag: u32& = ((data_base + (offset_words * size_of(uintptr)))).cast[u32&]
    return row_tag[0]

def ctx_packed_store_read_index_tag(state_bits: mutable void&, index: u32) -> u32:
    assert((state_bits != null))
    state: PackedStoreState& = state_bits.cast[PackedStoreState&]
    index_usize: usize = index.usize()
    assert((index_usize < state.tags.count))
    assert((state.tags.items != null))
    tags: u32& = state.tags.items
    return tags[index_usize]

def ctx_packed_store_read_word(a: mutable Arena&, handle: uintptr, state_bits: mutable void&, word_offset: usize) -> uintptr:
    can Abort.Panic:
        assert((handle != 0.uintptr()))
        if ((handle & 1.uintptr()) != 0.uintptr()):
            panic("packed store read_word cannot read inline word handles")
        region_index: usize = ((handle >> 32.uintptr())).usize()
        offset_words_plus_one: usize = ((((handle & 0xffffffff.u64().uintptr())) >> 1.uintptr())).usize()
        assert((offset_words_plus_one > 0))
        if (state_bits != null):
            state: PackedStoreState& = state_bits.cast[PackedStoreState&]
            if ((state.alloc_region != null) and (state.alloc_region_index == region_index)):
                offset_words: usize = (offset_words_plus_one - 1)
                assert(((offset_words + word_offset) < state.alloc_region.capacity))
                data_base: heap u8& = packed_store_region_data(state.alloc_region)
                row_words: uintptr& = ((data_base + (offset_words * size_of(uintptr)))).cast[uintptr&]
                return row_words[word_offset]
            if ((state.decode_region != null) and (state.decode_region_index == region_index)):
                offset_words: usize = (offset_words_plus_one - 1)
                assert(((offset_words + word_offset) < state.decode_region.capacity))
                data_base: heap u8& = packed_store_region_data(state.decode_region)
                row_words: uintptr& = ((data_base + (offset_words * size_of(uintptr)))).cast[uintptr&]
                return row_words[word_offset]
            indexed_region: heap Region&? = packed_store_lookup_region(state, region_index)
            if (indexed_region != null):
                offset_words: usize = (offset_words_plus_one - 1)
                assert(((offset_words + word_offset) < indexed_region.capacity))
                state.decode_region <- indexed_region
                state.decode_region_index <- region_index
                data_base: heap u8& = packed_store_region_data(indexed_region)
                row_words: uintptr& = ((data_base + (offset_words * size_of(uintptr)))).cast[uintptr&]
                return row_words[word_offset]
        r: mutable heap Region&? = a.begin
        i: mutable usize = 0
        if (state_bits != null):
            state: PackedStoreState& = state_bits.cast[PackedStoreState&]
            owner_cursor: mutable heap Region&? = null
            owner_cursor_index: mutable usize = 0
            if ((state.head_region != null) and (state.head_region.global_index <= region_index)):
                owner_cursor <- state.head_region
                owner_cursor_index <- state.head_region.global_index
                r <- state.head_region
                i <- state.head_region.global_index
            if ((state.alloc_region != null) and (state.alloc_region_index <= region_index)):
                if ((owner_cursor == null) or (state.alloc_region_index > owner_cursor_index)):
                    owner_cursor <- state.alloc_region
                    owner_cursor_index <- state.alloc_region_index
                if ((r == null) or (state.alloc_region_index > i)):
                    r <- state.alloc_region
                    i <- state.alloc_region_index
            if ((state.decode_region != null) and (state.decode_region_index <= region_index)):
                if ((owner_cursor == null) or (state.decode_region_index > owner_cursor_index)):
                    owner_cursor <- state.decode_region
                    owner_cursor_index <- state.decode_region_index
                if ((r == null) or (state.decode_region_index > i)):
                    r <- state.decode_region
                    i <- state.decode_region_index
            if (owner_cursor != null):
                trusted Unsafe.AssumeProgress:
                    while ((owner_cursor != null) and (owner_cursor.global_index < region_index)):
                        owner_cursor <- owner_cursor.owner_next
                if ((owner_cursor != null) and (owner_cursor.global_index == region_index)):
                    offset_words: usize = (offset_words_plus_one - 1)
                    assert(((offset_words + word_offset) < owner_cursor.capacity))
                    state.decode_region <- owner_cursor
                    state.decode_region_index <- region_index
                    data_base: heap u8& = packed_store_region_data(owner_cursor)
                    row_words: uintptr& = ((data_base + (offset_words * size_of(uintptr)))).cast[uintptr&]
                    return row_words[word_offset]
        trusted Unsafe.AssumeProgress:
            while ((i < region_index) and (r != null)):
                r <- r.next
                i <- (i + 1)
        assert((r != null))
        offset_words: usize = (offset_words_plus_one - 1)
        assert(((offset_words + word_offset) < r.capacity))
        if (state_bits != null):
            state: PackedStoreState& = state_bits.cast[PackedStoreState&]
            state.decode_region <- r
            state.decode_region_index <- region_index
        data_base: heap u8& = packed_store_region_data(r)
        row_words: uintptr& = ((data_base + (offset_words * size_of(uintptr)))).cast[uintptr&]
        return row_words[word_offset]

@inline(always)
def ctx_packed_store_read_index_word(a: mutable Arena&, index: u32, state_bits: mutable void&, word_offset: usize) -> uintptr:
    can Abort.Panic:
        assert((state_bits != null))
        state: PackedStoreState& = state_bits.cast[PackedStoreState&]
        index_usize: usize = index.usize()
        assert((index_usize < state.handles.count))
        if (word_offset < state.prefix_words):
            assert((state.prefix_columns.items != null))
            columns: uintptr& = state.prefix_columns.items
            assert((word_offset < state.prefix_columns.count))
            assert((columns[word_offset] != 0.uintptr()))
            column: uintptr& = columns[word_offset].cast[heap u8&].cast[uintptr&]
            return column[index_usize]
        assert((state.handles.items != null))
        handles: uintptr& = state.handles.items
        return ctx_packed_store_read_word(a, handles[index_usize], state_bits, word_offset)

def packed_store_variant_rows_table(state: mutable PackedStoreState&) -> mutable darray[PackedStoreVariantRows]&:
    return state.variant_rows.cast[darray[PackedStoreVariantRows]&]

def packed_store_find_variant_rows(state: mutable PackedStoreState&, tag: u32) -> mutable PackedStoreVariantRows&?:
    variants: darray[PackedStoreVariantRows]& = packed_store_variant_rows_table(state)
    if (variants.items == null):
        return null
    for i in 0 ..< variants.count:
        if (variants.items[i].tag == tag):
            return &variants.items[i]
    return null

def packed_store_get_or_create_variant_rows(a: mutable Arena&, state: mutable PackedStoreState&, tag: u32) -> mutable PackedStoreVariantRows&:
    can Memory.Allocate, Abort.Panic:
        found: PackedStoreVariantRows&? = packed_store_find_variant_rows(state, tag)
        if (found != null):
            return found
        variants: mutable darray[PackedStoreVariantRows]& = packed_store_variant_rows_table(state)
        created: mutable PackedStoreVariantRows = zeroed
        created.tag <- tag
        in a:
            variants.push(created)
        assert((variants.items != null))
        return &variants.items[(variants.count - 1)]

def packed_store_append_variant_row(a: mutable Arena&, state: mutable PackedStoreState&, tag: u32, row: void&) -> u32:
    can Memory.Allocate, Abort.Panic:
        variant_rows: PackedStoreVariantRows& = packed_store_get_or_create_variant_rows(a, state, tag)
        rows: mutable darray[uintptr]& = variant_rows.rows.cast[mutable darray[uintptr]&]
        slot: u32 = rows.count.u32()
        in a:
            rows.push(row.cast[u8&].uintptr())
        return slot

def packed_store_variant_row_ptr(state: mutable PackedStoreState&, tag: u32, slot: u32) -> mutable void&:
    can Abort.Panic:
        variant_rows: PackedStoreVariantRows&? = packed_store_find_variant_rows(state, tag)
        assert((variant_rows != null))
        rows: darray[uintptr]& = variant_rows.rows.cast[darray[uintptr]&]
        slot_index: usize = slot.usize()
        assert((rows.items != null))
        assert((slot_index < rows.count))
        row_ptrs: uintptr& = rows.items
        return row_ptrs[slot_index].cast[heap u8&].cast[mutable void&]

def ctx_packed_store_reserve(a: mutable Arena&, needed_rows: usize, state_bits: mutable void&):
    can Memory.Allocate, Abort.Panic:
        assert((state_bits != null))
        state: PackedStoreState& = state_bits.cast[PackedStoreState&]
        if (needed_rows <= state.handles.capacity):
            return
        packed_store_ensure_metadata_capacity(a, state, needed_rows)

def ctx_packed_store_row_ptr_at(state_bits: mutable void&, index: usize) -> mutable void&:
    handle: uintptr = ctx_packed_store_word_handle_at(state_bits, index)
    assert((handle != 0.uintptr()))
    return handle.cast[u8&].cast[mutable void&]

def ctx_packed_store_record_row_ptr(a: mutable Arena&, row: void&, state_bits: mutable void&):
    can Memory.Allocate, Abort.Panic:
        assert((state_bits != null))
        packed_store_append_handle(a, state_bits.cast[PackedStoreState&], row.cast[u8&].uintptr())

def ctx_packed_store_state_new_variant_sparse(a: mutable Arena&, row_bytes: usize) -> mutable heap void&:
    can Memory.Allocate, Abort.Panic:
        state: heap PackedStoreState& = arena_alloc(a, size_of(PackedStoreState)).cast[heap PackedStoreState&]
        row_words: usize = ((((row_bytes + size_of(uintptr)) - 1)) / size_of(uintptr))
        preferred_region_capacity: mutable usize = ARENA_REGION_DEFAULT_CAPACITY
        hinted_capacity: usize = (row_words * PACKED_STORE_MIN_ROWS_PER_REGION)
        if (preferred_region_capacity < hinted_capacity):
            preferred_region_capacity <- hinted_capacity
        if (preferred_region_capacity < row_words):
            preferred_region_capacity <- row_words
        state.head_region <- null
        state.alloc_region <- null
        state.alloc_region_index <- 0
        state.decode_region <- null
        state.decode_region_index <- 0
        state.tail_region <- null
        state.regions <- zeroed
        state.handles <- zeroed
        state.indices <- zeroed
        state.tags <- zeroed
        state.variant_slots <- zeroed
        state.variant_rows <- zeroed
        state.prefix_words <- 0
        state.prefix_columns <- zeroed
        state.prefix_column_capacity <- 0
        state.side_words <- 0
        state.side_columns <- zeroed
        state.side_column_capacity <- 0
        state.row_words <- row_words
        state.preferred_region_capacity <- preferred_region_capacity
        return state.cast[heap void&]

def ctx_packed_store_state_new_variant_sparse_with_side_words(a: mutable Arena&, row_bytes: usize, side_words: usize) -> mutable heap void&:
    can Memory.Allocate, Abort.Panic:
        state_bits: heap void& = ctx_packed_store_state_new_variant_sparse(a, row_bytes)
        state: heap PackedStoreState& = state_bits.cast[heap PackedStoreState&]
        state.side_words <- side_words
        return state_bits

def ctx_packed_store_alloc_tagged_variant_sparse_result(a: mutable Arena&, size_bytes: usize, state_bits: mutable void&, tag: u32) -> PackedStoreIndexAllocResult:
    can Memory.Allocate, Abort.Panic:
        assert((state_bits != null))
        state: PackedStoreState& = state_bits.cast[PackedStoreState&]
        row_words: mutable usize = ((((size_bytes + size_of(uintptr)) - 1)) / size_of(uintptr))
        if (row_words == 0):
            row_words <- 1
        if (row_words > state.row_words):
            state.row_words <- row_words
        row_size_bytes: usize = (row_words * size_of(uintptr))
        row: heap void& = arena_alloc(a, row_size_bytes)
        global_index: u32 = state.handles.count.u32()
        needed_rows: usize = (state.handles.count + 1)
        packed_store_ensure_metadata_capacity(a, state, needed_rows)
        slot: u32 = packed_store_append_variant_row(a, state, tag, row.cast[void&])
        in a:
            state.handles.push(row.cast[u8&].uintptr())
            state.indices.push(global_index)
            state.tags.push(tag)
            state.variant_slots.push(slot)
        return PackedStoreIndexAllocResult(row, global_index)

def ctx_packed_store_alloc_fixed_tagged_variant_sparse_result(a: mutable Arena&, state_bits: mutable void&, tag: u32) -> PackedStoreIndexAllocResult:
    can Memory.Allocate, Abort.Panic:
        assert((state_bits != null))
        state: PackedStoreState& = state_bits.cast[PackedStoreState&]
        return ctx_packed_store_alloc_tagged_variant_sparse_result(a, (state.row_words * size_of(uintptr)), state_bits, tag)

def ctx_packed_store_encode_variant_sparse(ptr: void&, state_bits: mutable void&) -> u32:
    can Abort.Panic:
        assert((state_bits != null))
        state: PackedStoreState& = state_bits.cast[PackedStoreState&]
        raw: uintptr = ptr.cast[u8&].uintptr()
        assert((state.handles.items != null))
        handles: uintptr& = state.handles.items
        for i, handle in state.handles.enumerate():
            if (handle == raw):
                return i.u32()
        panic("variant-sparse packed store encode missing row pointer")

def ctx_packed_store_decode_variant_sparse(index: u32, state_bits: mutable void&) -> mutable void&:
    can Abort.Panic:
        assert((state_bits != null))
        state: PackedStoreState& = state_bits.cast[PackedStoreState&]
        index_usize: usize = index.usize()
        assert((index_usize < state.handles.count))
        assert((state.handles.items != null))
        handles: uintptr& = state.handles.items
        return handles[index_usize].cast[heap u8&].cast[mutable void&]

def ctx_packed_store_read_variant_sparse_tag(state_bits: mutable void&, index: u32) -> u32:
    assert((state_bits != null))
    state: PackedStoreState& = state_bits.cast[PackedStoreState&]
    index_usize: usize = index.usize()
    assert((index_usize < state.tags.count))
    assert((state.tags.items != null))
    tags: u32& = state.tags.items
    return tags[index_usize]

def ctx_packed_store_read_variant_sparse_word(index: u32, state_bits: mutable void&, word_offset: usize) -> uintptr:
    can Abort.Panic:
        assert((state_bits != null))
        state: PackedStoreState& = state_bits.cast[PackedStoreState&]
        index_usize: usize = index.usize()
        assert((index_usize < state.tags.count))
        assert((state.tags.items != null))
        assert((state.variant_slots.items != null))
        tags: u32& = state.tags.items
        slots: u32& = state.variant_slots.items
        row_words: uintptr& = packed_store_variant_row_ptr(state, tags[index_usize], slots[index_usize]).cast[uintptr&]
        return row_words[word_offset]

extern strlen(s: u8&) -> usize

extern strcmp(lhs: u8&, rhs: u8&) -> int

extern memcpy(dest: mutable void&, src: void&, n: usize) -> mutable void&

extern memmove(dest: mutable void&, src: void&, n: usize) -> mutable void&

extern memcmp(lhs: void&, rhs: void&, n: usize) -> int

extern memset(dest: mutable void&, val: int, n: usize) -> mutable void&

extern snprintf(buf: mutable u8&?, bufsize: usize, fmt: u8&, ...) -> int can[Console.Format]

extern puts(s: u8&) -> int can[Console.Write]

extern fprintf(stream: void&, fmt: u8&, ...) -> int can[Console]

extern exit(code: int) can[Abort.Exit]

extern stderr: void&

const CTX_SMALL_STRING_CACHE_BUCKETS: usize = 1024

const CTX_STRING_LEN_CACHE_BUCKETS: usize = 4096

const CTX_ENABLE_SMALL_STRING_CACHE_EXPERIMENT: bool = false

global mutable perm_arena: Arena = Arena(null, null, 0)

global mutable scratch_arena: Arena = Arena(null, null, 0)

struct SmallStringCacheEntry:
    next: mutable heap SmallStringCacheEntry&?
    len: mutable usize
    text: mutable tail u8

struct StringLenCacheEntry:
    next: mutable heap StringLenCacheEntry&?
    ptr: mutable u8&
    len: mutable usize

struct StringBuilder:
    len: mutable i64
    cap: mutable i64
    data: mutable heap u8&?

struct StringView:
    data: mutable u8&
    len: mutable i64

struct ProgressBudget:
    remaining_steps: mutable i64
    max_depth: mutable i64
    current_depth: mutable i64
    cancelled: mutable bool

global mutable small_string_cache: heap SmallStringCacheEntry&?[CTX_SMALL_STRING_CACHE_BUCKETS] = zeroed

global mutable string_len_cache: heap StringLenCacheEntry&?[CTX_STRING_LEN_CACHE_BUCKETS] = zeroed

def progress_budget_steps(steps: i64) -> ProgressBudget:
    budget: ProgressBudget = zeroed
    budget.remaining_steps <- steps
    budget.max_depth <- 0
    budget.current_depth <- 0
    budget.cancelled <- false
    return budget

def progress_budget_steps_and_depth(steps: i64, max_depth: i64) -> ProgressBudget:
    budget: ProgressBudget = progress_budget_steps(steps)
    budget.max_depth <- max_depth
    return budget

def progress_cancel(budget: mutable ProgressBudget&):
    budget.cancelled <- true

def progress_check_cancel(budget: mutable ProgressBudget&):
    can Progress.CheckCancel, Abort.Panic:
        if budget.cancelled:
            panic("progress budget cancelled")

def progress_tick(budget: mutable ProgressBudget&):
    can Progress.Tick, Progress.CheckCancel, Abort.Panic:
        progress_check_cancel(budget)
        if (budget.remaining_steps <= 0):
            panic("progress budget exhausted")
        budget.remaining_steps <- (budget.remaining_steps - 1)

def progress_enter_recursion(budget: mutable ProgressBudget&):
    can Progress.EnterRecursion, Progress.CheckCancel, Abort.Panic:
        progress_check_cancel(budget)
        if ((budget.max_depth > 0) and (budget.current_depth >= budget.max_depth)):
            panic("progress recursion depth exhausted")
        budget.current_depth <- (budget.current_depth + 1)

def progress_leave_recursion(budget: mutable ProgressBudget&):
    can Progress.LeaveRecursion:
        if (budget.current_depth > 0):
            budget.current_depth <- (budget.current_depth - 1)

def alloc_perm(size: i64) -> mutable heap void&:
    resolved: usize = (size.usize() if (size > 0) else 1)
    return arena_alloc(perm_arena.cast[Arena&], resolved) can Memory.Allocate, Abort.Panic

def alloc_scratch(size: i64) -> mutable heap void&:
    resolved: usize = (size.usize() if (size > 0) else 1)
    return arena_alloc(scratch_arena.cast[Arena&], resolved) can Memory.Allocate, Abort.Panic

def reset_scratch():
    arena_reset(scratch_arena.cast[Arena&])

def string_len_bucket(ptr: u8&) -> usize:
    bits: mutable uintptr = ptr.uintptr()
    bits ^= ((bits >> 33))
    bits *= 0xff51afd7ed558ccd.uintptr()
    bits ^= ((bits >> 33))
    return ((bits & ((CTX_STRING_LEN_CACHE_BUCKETS - 1)).uintptr())).usize()

def register_perm_string_len(ptr: u8&?, len: usize):
    can Memory.Allocate, Abort.Panic:
        if ((ptr == null) or (len == 0)):
            return
        bucket: usize = string_len_bucket(ptr.cast[u8&])
        entry: mutable heap StringLenCacheEntry&? = string_len_cache[bucket]
        trusted Unsafe.AssumeProgress:
            while (entry != null):
                if (entry.ptr == ptr.cast[u8&]):
                    entry.len <- len
                    return
                entry <- entry.next
        new_entry: heap StringLenCacheEntry& = alloc_perm(size_of(StringLenCacheEntry).i64()).cast[heap StringLenCacheEntry&]
        new_entry.next <- string_len_cache[bucket]
        new_entry.ptr <- ptr.cast[u8&]
        new_entry.len <- len
        string_len_cache[bucket] <- new_entry

def lookup_cached_string_len(ptr: u8&?, len_out: mutable usize&) -> int:
    if (ptr == null):
        return 0
    bucket: usize = string_len_bucket(ptr.cast[u8&])
    prev: mutable heap StringLenCacheEntry&? = null
    entry: mutable heap StringLenCacheEntry&? = string_len_cache[bucket]
    trusted Unsafe.AssumeProgress:
        while (entry != null):
            if (entry.ptr == ptr.cast[u8&]):
                if (prev != null):
                    prev.next <- entry.next
                    entry.next <- string_len_cache[bucket]
                    string_len_cache[bucket] <- entry
                len_out <- entry.len
                return 1
            prev <- entry
            entry <- entry.next
    return 0

def runtime_strlen(value: u8&?) -> usize:
    src: u8& = (value if (value != null) else "")
    if (src[0] == 0):
        return 0
    return strlen(src)

def intern_small_string(src: u8&, len: usize) -> heap u8&:
    can Memory.Allocate, Abort.Panic:
        out: heap u8& = alloc_perm(((len + 1)).i64()).cast[heap u8&]
        if (len > 0):
            memcpy(out.cast[mutable void&], src.cast[void&], len)
        out[len] <- 0
        register_perm_string_len(out.cast[u8&], len)
        return out

def int_to_string_into(arena: mutable Arena&, value: i64) -> heap u8&:
    can Memory.Allocate, Console.Format, Abort.Panic:
        len: int = snprintf(null, 0, "%lld", value)
        if ((len > 0) and (len <= 8)):
            text: u8[9]
            snprintf(text[0].cast[u8&], (len.usize() + 1), "%lld", value)
            return intern_small_string(text[0].cast[u8&], len.usize())
        out: heap u8& = arena_alloc(arena, (len.usize() + 1)).cast[heap u8&]
        snprintf(out.cast[u8&?], (len.usize() + 1), "%lld", value)
        if (arena == perm_arena.cast[Arena&]):
            register_perm_string_len(out.cast[u8&], len.usize())
        return out

def bool_to_string_into(arena: Arena&, value: int) -> u8&:
    _ = arena
    return ("True" if (value != 0) else "False")

def char_to_string_into(arena: Arena&, value: i64) -> heap u8&:
    can Memory.Allocate, Abort.Panic:
        _ = arena
        text: u8[2]
        text[0] <- value.u8()
        text[1] <- 0
        return intern_small_string(text[0].cast[u8&], 1)

def string_builder_next_cap(min_cap: i64) -> i64:
    cap: mutable i64 = 16
    trusted Unsafe.AssumeProgress:
        while (cap < min_cap):
            cap *= 2
    return cap

def string_builder_new(initial: u8&?) -> mutable heap StringBuilder&:
    can Memory.Allocate, Abort.Panic:
        src: u8& = (initial if (initial != null) else "")
        len: usize = runtime_strlen(src)
        builder: heap StringBuilder& = alloc_perm(size_of(StringBuilder).i64()).cast[heap StringBuilder&]
        builder.len <- len.i64()
        builder.cap <- string_builder_next_cap((len.i64() + 1))
        builder.data <- alloc_perm(builder.cap).cast[heap u8&]
        if (len > 0):
            memcpy(builder.data.cast[mutable void&], src.cast[void&], len)
        builder.data[len] <- 0
        return builder

def string_builder_append(builder: mutable heap StringBuilder&?, suffix: u8&?) -> mutable heap StringBuilder&:
    can Memory.Allocate, Abort.Panic:
        src: u8& = (suffix if (suffix != null) else "")
        suffix_len: usize = runtime_strlen(src)
        if (builder == null):
            return string_builder_new(src)
        if (suffix_len == 0):
            return builder
        b: heap StringBuilder& = builder
        needed: i64 = ((b.len + suffix_len.i64()) + 1)
        if (needed > b.cap):
            new_cap: i64 = string_builder_next_cap(needed)
            new_data: heap u8& = alloc_perm(new_cap).cast[heap u8&]
            if (b.len > 0):
                assert((b.data != null))
                memcpy(new_data.cast[mutable void&], b.data.cast[void&], b.len.usize())
            b.data <- new_data
            b.cap <- new_cap
        assert((b.data != null))
        memmove(((b.data + b.len.usize())).cast[mutable void&], src.cast[void&], suffix_len)
        b.len += suffix_len.i64()
        b.data[b.len.usize()] <- 0
        return b

def string_builder_finish(builder: heap StringBuilder&?) -> heap u8&:
    can Memory.Allocate, Abort.Panic:
        if (builder == null):
            return intern_small_string("", 0)
        b: heap StringBuilder& = builder
        if (b.len <= 0):
            return intern_small_string("", 0)
        assert((b.data != null))
        if (b.len <= 8):
            return intern_small_string(b.data.cast[u8&], b.len.usize())
        register_perm_string_len(b.data.cast[u8&], b.len.usize())
        return b.data

struct Thread[T, S]:
    handle: mutable uintptr
    state: mutable void&?

struct Task[T, S]:
    handle: mutable uintptr
    state: mutable void&?

struct ThreadPool:
    handle: mutable void&?

struct TaskGroup:
    handle: mutable void&?
    cleanup: mutable void&?

struct Mutex:
    handle: mutable void&?

struct MutexGuard[S]:
    handle: mutable void&?

struct CondVar:
    handle: mutable void&?

struct atomic[T]:
    value: mutable T

struct ConcurrencyBox[T]:
    value: mutable T

struct ConcurrencyWorkStart1:
    fn_bits: mutable uintptr
    arg_bits: mutable void&
    result_bits: mutable void&
    refs: mutable atomic[i64]

struct ConcurrencyTaskGroupNode:
    next: mutable heap ConcurrencyTaskGroupNode&?
    state_bits: mutable void&

struct ConcurrencyRawTaskNode:
    next: mutable heap ConcurrencyRawTaskNode&?
    handle: mutable uintptr

struct ConcurrencyPoolState:
    worker_count: mutable usize

enum MemoryOrder:
    Relaxed
    Acquire
    Release
    AcqRel
    SeqCst

extern pthread_create(thread: mutable uintptr&, attr: void&?, start_routine: void&, arg: void&?) -> int can[Thread.Spawn]

extern pthread_join(thread: uintptr, retval: mutable void&?) -> int can[Thread.Join]

extern pthread_detach(thread: uintptr) -> int can[Thread.Detach]

extern pthread_mutex_lock(mutex: void&) -> int can[Sync.Lock]

extern pthread_mutex_unlock(mutex: void&) -> int can[Sync.Unlock]

extern pthread_cond_wait(cond: void&, mutex: void&) -> int can[Sync.Wait]

extern pthread_cond_signal(cond: void&) -> int can[Sync.Notify]

extern pthread_cond_broadcast(cond: void&) -> int can[Sync.Notify]

extern mutex_lock(mu: mutable Mutex&) -> MutexGuard[Held] can[Sync.Lock]

extern mutex_unlock(g: MutexGuard[Held]) -> void can[Sync.Unlock]

extern cond_wait(cv: mutable CondVar&, g: MutexGuard[Held]) -> MutexGuard[Held] can[Sync.Wait]

extern notify_one(cv: mutable CondVar&) -> void can[Sync.Notify]

extern notify_all(cv: mutable CondVar&) -> void can[Sync.Notify]

def ctx_concurrency_alloc(size: usize) -> mutable heap void&:
    can Memory.Allocate, Abort.Panic:
        raw: heap void&? = malloc(size)
        if (raw == null):
            panic("concurrency allocation failed")
        ptr: heap void& = raw.cast[heap void&]
        return ptr

def ctx_concurrency_box_new[T](value: T) -> mutable heap ConcurrencyBox[T]&:
    raw: heap void& = ctx_concurrency_alloc(size_of(ConcurrencyBox[T])) can Memory.Allocate, Abort.Panic
    box: heap ConcurrencyBox[T]& = raw.cast[heap ConcurrencyBox[T]&]
    box.value <- value
    return box

def ctx_concurrency_join_handle(handle: uintptr):
    can Thread.Join, Abort.Panic:
        status: int = pthread_join(handle, null)
        if (status != 0):
            panic("pthread_join failed")

def spawn_raw(entry: void&, arg: void&?) -> Thread[void&?, Joinable]:
    can Thread.Spawn, Abort.Panic:
        out: Thread[void&?, Joinable] = zeroed
        status: int = pthread_create(out.handle.cast[mutable uintptr&], null, entry, arg)
        if (status != 0):
            panic("pthread_create failed")
        out.state <- arg
        return move out

def join_raw(thread: Thread[void&?, Joinable]) -> void&?:
    can Thread.Join, Abort.Panic:
        handle: uintptr = thread.handle
        state_bits: void&? = thread.state
        _ = move thread
        ctx_concurrency_join_handle(handle)
        return state_bits

def detach_raw(thread: Thread[void&?, Joinable]):
    can Thread.Detach, Abort.Panic:
        handle: uintptr = thread.handle
        _ = move thread
        status: int = pthread_detach(handle)
        if (status != 0):
            panic("pthread_detach failed")

def pool_new(threads: usize) -> ThreadPool:
    can Pool.Create, Memory.Allocate, Abort.Panic:
        raw: heap void& = ctx_concurrency_alloc(size_of(ConcurrencyPoolState))
        state: heap ConcurrencyPoolState& = raw.cast[heap ConcurrencyPoolState&]
        state.worker_count <- threads
        out: ThreadPool = zeroed
        out.handle <- state.cast[void&]
        return move out

def pool_shutdown(pool: mutable ThreadPool&):
    can Pool.Shutdown, Memory.Release:
        if (pool.handle != null):
            free(pool.handle.cast[heap void&])
            pool.handle <- null

def pool_submit_raw(pool: mutable ThreadPool&, entry: void&, arg: void&?) -> Task[void&?, Pending]:
    can Pool.Submit, Thread.Spawn, Abort.Panic:
        _ = pool
        thread: Thread[void&?, Joinable] = spawn_raw(entry, arg)
        out: Task[void&?, Pending] = zeroed
        out.handle <- thread.handle
        out.state <- thread.state
        _ = move thread
        return move out

def pool_await_raw(task: Task[void&?, Pending]) -> void&?:
    can Pool.Await, Thread.Join, Abort.Panic:
        handle: uintptr = task.handle
        state_bits: void&? = task.state
        _ = move task
        ctx_concurrency_join_handle(handle)
        return state_bits

def task_group_new_raw() -> TaskGroup:
    out: TaskGroup = zeroed
    return move out

def task_group_add_raw(group: mutable TaskGroup&, task: Task[void&?, Pending]):
    can Memory.Allocate, Abort.Panic:
        handle: uintptr = task.handle
        _ = move task
        raw: heap void& = ctx_concurrency_alloc(size_of(ConcurrencyRawTaskNode))
        node: heap ConcurrencyRawTaskNode& = raw.cast[heap ConcurrencyRawTaskNode&]
        node.handle <- handle
        if (group.handle == null):
            node.next <- null
        else:
            node.next <- group.handle.cast[heap ConcurrencyRawTaskNode&]
        group.handle <- node.cast[void&]

def task_group_wait_all_raw(group: mutable TaskGroup&):
    can Pool.WaitAll, Thread.Join, Memory.Release, Abort.Panic:
        current: mutable heap ConcurrencyRawTaskNode&? = group.handle.cast[heap ConcurrencyRawTaskNode&?]
        group.handle <- null
        trusted Unsafe.AssumeProgress:
            while (current != null):
                next: mutable heap ConcurrencyRawTaskNode&? = current.next
                ctx_concurrency_join_handle(current.handle)
                free(current.cast[heap void&])
                current <- next

def ctx_concurrency_ref_release(slot: mutable atomic[i64]&) -> i64:
    trusted Unsafe.AssumeProgress:
        while true:
            current: i64 = load(slot, MemoryOrder.Acquire) can Atomics.Load
            next: i64 = (current - 1)
            if compare_exchange(slot, current, next, MemoryOrder.AcqRel, MemoryOrder.Acquire) can Atomics.CompareExchange:
                return next
    return 0

def ctx_concurrency_work1_release(state_bits: mutable void&?):
    can Memory.Release, Atomics.Load, Atomics.CompareExchange:
        if (state_bits == null):
            return
        live_bits: void& = state_bits.cast[void&]
        state: heap ConcurrencyWorkStart1& = live_bits.cast[heap ConcurrencyWorkStart1&]
        remaining: i64 = ctx_concurrency_ref_release(state.casts.cast[atomic[i64]&])
        if (remaining == 0):
            free(state.arg_bits.cast[heap void&])
            free(state.result_bits.cast[heap void&])
            free(state.cast[heap void&])

def ctx_concurrency_work1_new[A, R, permission P](fn: func(A) -> R can[P], arg: A) -> mutable heap ConcurrencyWorkStart1&:
    can Memory.Allocate, Abort.Panic:
        arg_box: heap ConcurrencyBox[A]& = ctx_concurrency_box_new(arg)
        result_seed: R = zeroed
        result_box: heap ConcurrencyBox[R]& = ctx_concurrency_box_new(result_seed)
        raw: heap void& = ctx_concurrency_alloc(size_of(ConcurrencyWorkStart1))
        state: heap ConcurrencyWorkStart1& = raw.cast[heap ConcurrencyWorkStart1&]
        state.fn_bits <- fn as uintptr
        state.arg_bits <- arg_box.cast[void&]
        state.result_bits <- result_box.cast[void&]
        state.casts.value <- 2
        return state

def ctx_concurrency_work1_entry[A, R, permission P](state_bits: mutable void&) -> void&:
    can P, Memory.Release, Atomics.Load, Atomics.CompareExchange:
        state: heap ConcurrencyWorkStart1& = state_bits.cast[heap ConcurrencyWorkStart1&]
        fn: func(A) -> R can[P] = state.fn_bits.cast[func(A) -> R can[P]]
        arg_box: heap ConcurrencyBox[A]& = state.arg_bits.cast[heap ConcurrencyBox[A]&]
        result_box: heap ConcurrencyBox[R]& = state.result_bits.cast[heap ConcurrencyBox[R]&]
        result_box.value <- fn(arg_box.value)
        ctx_concurrency_work1_release(state.cast[mutable void&])
        return state.cast[void&]

def ctx_concurrency_work1_take_result[R](state_bits: void&?) -> R:
    can Memory.Release, Abort.Panic, Atomics.Load, Atomics.CompareExchange:
        if (state_bits == null):
            panic("concurrency work returned no state")
        live_bits: void& = state_bits.cast[void&]
        state: heap ConcurrencyWorkStart1& = live_bits.cast[heap ConcurrencyWorkStart1&]
        result_box: heap ConcurrencyBox[R]& = state.result_bits.cast[heap ConcurrencyBox[R]&]
        result: R = result_box.value
        ctx_concurrency_work1_release(state.cast[mutable void&])
        return result

def ctx_thread_from_raw[R, S](raw: Thread[void&?, S]) -> Thread[R, S]:
    out: Thread[R, S] = zeroed
    out.handle <- raw.handle
    out.state <- raw.state
    return move out

def ctx_thread_to_raw[R, S](thread: Thread[R, S]) -> Thread[void&?, S]:
    out: Thread[void&?, S] = zeroed
    out.handle <- thread.handle
    out.state <- thread.state
    return move out

def ctx_task_from_raw[R, S](raw: Task[void&?, S]) -> Task[R, S]:
    out: Task[R, S] = zeroed
    out.handle <- raw.handle
    out.state <- raw.state
    return move out

def ctx_task_to_raw[R, S](task: Task[R, S]) -> Task[void&?, S]:
    out: Task[void&?, S] = zeroed
    out.handle <- task.handle
    out.state <- task.state
    return move out

def task_group_new() -> TaskGroup:
    group: TaskGroup = task_group_new_raw()
    group.cleanup <- null
    return move group

def ctx_task_group_push_state(group: mutable TaskGroup&, state_bits: void&?):
    can Memory.Allocate, Abort.Panic:
        if (state_bits == null):
            return
        raw: heap void& = ctx_concurrency_alloc(size_of(ConcurrencyTaskGroupNode))
        node: heap ConcurrencyTaskGroupNode& = raw.cast[heap ConcurrencyTaskGroupNode&]
        if (group.cleanup == null):
            node.next <- null
        else:
            node.next <- group.cleanup.cast[heap ConcurrencyTaskGroupNode&]
        node.state_bits <- state_bits.cast[void&]
        group.cleanup <- node.cast[void&]

def ctx_task_group_release_all(group: mutable TaskGroup&):
    can Memory.Release, Atomics.Load, Atomics.CompareExchange:
        if (group.cleanup == null):
            return
        current: mutable heap ConcurrencyTaskGroupNode&? = group.cleanup.cast[heap ConcurrencyTaskGroupNode&?]
        group.cleanup <- null
        trusted Unsafe.AssumeProgress:
            while (current != null):
                next: mutable heap ConcurrencyTaskGroupNode&? = current.next
                ctx_concurrency_work1_release(current.state_bits.cast[mutable void&])
                free(current.cast[heap void&])
                current <- next

def spawn1[A, R, permission P](fn: func(A) -> R can[P], arg: A) -> Thread[R, Joinable]:
    can Thread.Spawn, Memory.Allocate, Abort.Panic:
        from_raw: func(Thread[void&?, Joinable]) -> Thread[R, Joinable] = ctx_thread_from_raw[R, Joinable]
        state: heap ConcurrencyWorkStart1& = ctx_concurrency_work1_new(fn, arg)
        raw: Thread[void&?, Joinable] = spawn_raw(ctx_concurrency_work1_entry[A, R].cast[void&], state.cast[void&])
        raw.state <- state.cast[void&]
        return from_raw(move raw)

def join[R](thread: Thread[R, Joinable]) -> R:
    can Thread.Join, Memory.Release, Abort.Panic, Atomics.Load, Atomics.CompareExchange:
        take_result: func(void&?) -> R can[Memory.Release, Abort.Panic, Atomics.Load, Atomics.CompareExchange] = ctx_concurrency_work1_take_result[R]
        state_bits: void&? = thread.state
        raw: Thread[void&?, Joinable] = ctx_thread_to_raw(move thread)
        _ = join_raw(move raw)
        result: R = take_result(state_bits)
        return result

def detach[R](thread: Thread[R, Joinable]):
    can Thread.Detach, Memory.Release, Abort.Panic, Atomics.Load, Atomics.CompareExchange:
        state_bits: void&? = thread.state
        raw: Thread[void&?, Joinable] = ctx_thread_to_raw(move thread)
        detach_raw(move raw)
        ctx_concurrency_work1_release(state_bits)

def pool_submit1[A, R, permission P](pool: mutable ThreadPool&, fn: func(A) -> R can[P], arg: A) -> Task[R, Pending]:
    can Pool.Submit, Thread.Spawn, Memory.Allocate, Abort.Panic:
        from_raw: func(Task[void&?, Pending]) -> Task[R, Pending] = ctx_task_from_raw[R, Pending]
        state: heap ConcurrencyWorkStart1& = ctx_concurrency_work1_new(fn, arg)
        raw: Task[void&?, Pending] = pool_submit_raw(pool, ctx_concurrency_work1_entry[A, R].cast[void&], state.cast[void&])
        raw.state <- state.cast[void&]
        return from_raw(move raw)

def pool_await[R](task: Task[R, Pending]) -> R:
    can Pool.Await, Thread.Join, Memory.Release, Abort.Panic, Atomics.Load, Atomics.CompareExchange:
        take_result: func(void&?) -> R can[Memory.Release, Abort.Panic, Atomics.Load, Atomics.CompareExchange] = ctx_concurrency_work1_take_result[R]
        state_bits: void&? = task.state
        raw: Task[void&?, Pending] = ctx_task_to_raw(move task)
        _ = pool_await_raw(move raw)
        result: R = take_result(state_bits)
        return result

def task_group_add[R](group: mutable TaskGroup&, task: Task[R, Pending]):
    can Memory.Allocate, Abort.Panic:
        state_bits: void&? = task.state
        raw: Task[void&?, Pending] = ctx_task_to_raw(move task)
        task_group_add_raw(group, move raw)
        ctx_task_group_push_state(group, state_bits)

def task_group_wait_all(group: mutable TaskGroup&):
    can Pool.WaitAll, Thread.Join, Memory.Release, Abort.Panic, Atomics.Load, Atomics.CompareExchange:
        task_group_wait_all_raw(group)
        ctx_task_group_release_all(group)

def load[T](slot: atomic[T]&, order: MemoryOrder) -> T:
    can Atomics.Load:
        _ = order
        return slot.value

def store[T](slot: mutable atomic[T]&, value: T, order: MemoryOrder):
    can Atomics.Store:
        _ = order
        slot.value <- value

def exchange[T](slot: mutable atomic[T]&, value: T, order: MemoryOrder) -> T:
    can Atomics.Exchange:
        _ = order
        old_value: T = slot.value
        slot.value <- value
        return old_value

def compare_exchange[T](slot: mutable atomic[T]&, expected: T, desired: T, success: MemoryOrder, failure: MemoryOrder) -> bool:
    can Atomics.CompareExchange:
        _ = success
        _ = failure
        if (slot.value == expected):
            slot.value <- desired
            return true
        return false

def fetch_add(slot: mutable atomic[i64]&, value: i64, order: MemoryOrder) -> i64:
    can Atomics.Rmw:
        _ = order
        old_value: i64 = slot.value
        slot.value <- (old_value + value)
        return old_value

def fetch_sub(slot: mutable atomic[i64]&, value: i64, order: MemoryOrder) -> i64:
    can Atomics.Rmw:
        _ = order
        old_value: i64 = slot.value
        slot.value <- (old_value - value)
        return old_value

def fetch_or(slot: mutable atomic[i64]&, value: i64, order: MemoryOrder) -> i64:
    can Atomics.Rmw:
        _ = order
        old_value: i64 = slot.value
        slot.value <- (old_value | value)
        return old_value

def fetch_and(slot: mutable atomic[i64]&, value: i64, order: MemoryOrder) -> i64:
    can Atomics.Rmw:
        _ = order
        old_value: i64 = slot.value
        slot.value <- (old_value & value)
        return old_value

def fetch_xor(slot: mutable atomic[i64]&, value: i64, order: MemoryOrder) -> i64:
    can Atomics.Rmw:
        _ = order
        old_value: i64 = slot.value
        slot.value <- (old_value ^ value)
        return old_value

def fence(order: MemoryOrder):
    _ = order can Atomics.Fence

def concat2(lhs: u8&?, rhs: u8&?) -> u8&:
    can Memory.Allocate, Abort.Panic:
        left: u8& = (lhs.cast[u8&] if (lhs != null) else "")
        right: u8& = (rhs.cast[u8&] if (rhs != null) else "")
        left_len: usize = runtime_strlen(left)
        right_len: usize = runtime_strlen(right)
        if (left_len == 0):
            return right
        if (right_len == 0):
            return left
        if ((left_len + right_len) <= 8):
            text: u8[9]
            memcpy(text[0].cast[mutable void&], left.cast[void&], left_len)
            memcpy(((&text[0] + left_len)).cast[mutable void&], right.cast[void&], right_len)
            text[(left_len + right_len)] <- 0
            return intern_small_string(text[0].cast[u8&], (left_len + right_len)).cast[u8&]
        out: u8& = alloc_perm((((left_len + right_len) + 1)).i64()).cast[u8&]
        memcpy(out.cast[mutable void&], left.cast[void&], left_len)
        memcpy(((out + left_len)).cast[mutable void&], right.cast[void&], right_len)
        out[(left_len + right_len)] <- 0
        register_perm_string_len(out, (left_len + right_len))
        return out

def concat2_scratch(lhs: u8&?, rhs: u8&?) -> u8&:
    can Memory.Allocate, Abort.Panic:
        left: u8& = (lhs.cast[u8&] if (lhs != null) else "")
        right: u8& = (rhs.cast[u8&] if (rhs != null) else "")
        left_len: usize = runtime_strlen(left)
        right_len: usize = runtime_strlen(right)
        if (left_len == 0):
            return right
        if (right_len == 0):
            return left
        if ((left_len + right_len) <= 8):
            text: u8[9]
            memcpy(text[0].cast[mutable void&], left.cast[void&], left_len)
            memcpy(((&text[0] + left_len)).cast[mutable void&], right.cast[void&], right_len)
            text[(left_len + right_len)] <- 0
            return intern_small_string(text[0].cast[u8&], (left_len + right_len)).cast[u8&]
        out: u8& = alloc_scratch((((left_len + right_len) + 1)).i64()).cast[u8&]
        memcpy(out.cast[mutable void&], left.cast[void&], left_len)
        memcpy(((out + left_len)).cast[mutable void&], right.cast[void&], right_len)
        out[(left_len + right_len)] <- 0
        return out

def string_index(value: u8&?, index: i64) -> i64:
    src: u8& = (value if (value != null) else "")
    len: usize = runtime_strlen(src)
    return (0 if ((index < 0) or (index.usize() >= len)) else src[index.usize()].i64())

def string_slice_eq(value: u8&?, start: i64, end: i64, other: u8&?) -> int:
    src: u8& = (value if (value != null) else "")
    rhs: u8& = (other if (other != null) else "")
    len: usize = runtime_strlen(src)
    lo: mutable usize = 0
    hi: mutable usize = len
    if (start > 0):
        lo <- start.usize()
        if (lo > len):
            lo <- len
    if (end >= 0):
        hi <- end.usize()
        if (hi > len):
            hi <- len
    if (hi < lo):
        hi <- lo
    slice_len: usize = (hi - lo)
    rhs_len: usize = runtime_strlen(rhs)
    if (slice_len != rhs_len):
        return 0
    if ((slice_len == 0) or ((src + lo) == rhs)):
        return 1
    return (1 if (memcmp(((src + lo)).cast[void&], rhs.cast[void&], slice_len) == 0) else 0)

def string_slices_eq(lhs: u8&?, lhs_start: i64, lhs_end: i64, rhs: u8&?, rhs_start: i64, rhs_end: i64) -> int:
    left: u8& = (lhs if (lhs != null) else "")
    right: u8& = (rhs if (rhs != null) else "")
    left_len: usize = runtime_strlen(left)
    right_len: usize = runtime_strlen(right)
    left_lo: mutable usize = 0
    left_hi: mutable usize = left_len
    right_lo: mutable usize = 0
    right_hi: mutable usize = right_len
    if (lhs_start > 0):
        left_lo <- lhs_start.usize()
        if (left_lo > left_len):
            left_lo <- left_len
    if (lhs_end >= 0):
        left_hi <- lhs_end.usize()
        if (left_hi > left_len):
            left_hi <- left_len
    if (left_hi < left_lo):
        left_hi <- left_lo
    if (rhs_start > 0):
        right_lo <- rhs_start.usize()
        if (right_lo > right_len):
            right_lo <- right_len
    if (rhs_end >= 0):
        right_hi <- rhs_end.usize()
        if (right_hi > right_len):
            right_hi <- right_len
    if (right_hi < right_lo):
        right_hi <- right_lo
    left_slice_len: usize = (left_hi - left_lo)
    right_slice_len: usize = (right_hi - right_lo)
    if (left_slice_len != right_slice_len):
        return 0
    if ((left_slice_len == 0) or ((left + left_lo) == (right + right_lo))):
        return 1
    return (1 if (memcmp(((left + left_lo)).cast[void&], ((right + right_lo)).cast[void&], left_slice_len) == 0) else 0)

def string_slice(value: u8&?, start: i64, end: i64) -> u8&:
    can Memory.Allocate, Abort.Panic:
        src: u8& = (value if (value != null) else "")
        len: usize = runtime_strlen(src)
        lo: mutable usize = 0
        hi: mutable usize = len
        if (start > 0):
            lo <- start.usize()
            if (lo > len):
                lo <- len
        if (end >= 0):
            hi <- end.usize()
            if (hi > len):
                hi <- len
        if (hi < lo):
            hi <- lo
        if ((lo == 0) and (hi == len)):
            return src
        out_len: usize = (hi - lo)
        if (out_len == 0):
            return ""
        if (out_len <= 8):
            return intern_small_string((src + lo), out_len).cast[u8&]
        out: u8& = alloc_perm(((out_len + 1)).i64()).cast[u8&]
        memcpy(out.cast[mutable void&], ((src + lo)).cast[void&], out_len)
        out[out_len] <- 0
        register_perm_string_len(out, out_len)
        return out

def sview(value: u8&?, start: i64, end: i64) -> sview:
    src: u8& = (value if (value != null) else "")
    len: usize = runtime_strlen(src)
    lo: mutable usize = 0
    hi: mutable usize = len
    if (start > 0):
        lo <- start.usize()
        if (lo > len):
            lo <- len
    if (end >= 0):
        hi <- end.usize()
        if (hi > len):
            hi <- len
    if (hi < lo):
        hi <- lo
    return StringView((src + lo), ((hi - lo)).i64())

def string_view_len(view: sview) -> i64:
    return view.len

def string_view_slice(view: sview, start: i64, end: i64) -> sview:
    lo: mutable i64 = (start if (start > 0) else 0)
    hi: mutable i64 = (end if (end >= 0) else view.len)
    if (lo > view.len):
        lo <- view.len
    if (hi > view.len):
        hi <- view.len
    if (hi < lo):
        hi <- lo
    return StringView((view.data + lo.usize()), (hi - lo))

def string_view_prefix(view: sview, end: i64) -> sview:
    return string_view_slice(view, 0, end)

def string_view_suffix(view: sview, start: i64) -> sview:
    return string_view_slice(view, start, view.len)

def string_view_index(view: sview, index: i64) -> i64:
    if ((index < 0) or (index >= view.len)):
        return 0
    return view.data[index.usize()].i64()

def string_view_eq(view: sview, other: u8&?) -> int:
    rhs: u8& = (other if (other != null) else "")
    rhs_len: usize = runtime_strlen(rhs)
    if ((view.len < 0) or (view.len.usize() != rhs_len)):
        return 0
    if ((view.len == 0) or (view.data == rhs)):
        return 1
    return (1 if (memcmp(view.data.cast[void&], rhs.cast[void&], view.len.usize()) == 0) else 0)

def string_views_eq(lhs: sview, rhs: sview) -> int:
    if (lhs.len != rhs.len):
        return 0
    if ((lhs.len == 0) or (lhs.data == rhs.data)):
        return 1
    return (1 if (memcmp(lhs.data.cast[void&], rhs.data.cast[void&], lhs.len.usize()) == 0) else 0)

def string_view_copy(view: sview) -> heap u8&:
    can Memory.Allocate, Abort.Panic:
        if (view.len <= 0):
            return intern_small_string("", 0)
        if (view.len <= 8):
            return intern_small_string(view.data, view.len.usize())
        out: heap u8& = alloc_perm(((view.len + 1)).usize()).cast[heap u8&]
        memcpy(out.cast[mutable void&], view.data.cast[void&], view.len.usize())
        out[view.len.usize()] <- 0
        register_perm_string_len(out.cast[u8&], view.len.usize())
        return out

