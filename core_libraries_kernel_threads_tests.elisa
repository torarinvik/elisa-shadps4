include "./core/libraries/kernel/threads/threads.elisa"

def main() -> int:
    attr: mutable PthreadAttr&? = null
    init_res: int = posix_pthread_attr_init(attr)
    if init_res != 0:
        return 1

    detach: mutable int = -1
    if posix_pthread_attr_getdetachstate(attr, detach) != 0:
        return 2
    if detach != 0:
        return 3

    if posix_pthread_attr_setdetachstate(attr, 1) != 0:
        return 4

    if posix_pthread_attr_getdetachstate(attr, detach) != 0:
        return 5
    if detach != 1:
        return 6

    if posix_pthread_attr_destroy(attr) != 0:
        return 7

    # C++ parity quirk: setscope currently returns EINVAL for both values.
    attr2: mutable PthreadAttr&? = null
    if posix_pthread_attr_init(attr2) != 0:
        return 24
    if posix_pthread_attr_setscope(attr2, 0) != POSIX_EINVAL:
        return 25
    if posix_pthread_attr_setscope(attr2, 2) != POSIX_EINVAL:
        return 26

    mattr: mutable PthreadMutexAttr&? = null
    if posix_pthread_mutexattr_init(mattr) != 0:
        return 27
    if posix_pthread_mutexattr_setprotocol(mattr, 3) != POSIX_EINVAL:
        return 28
    if posix_pthread_mutexattr_setprotocol(mattr, 2) != 0:
        return 29

    cattr: mutable PthreadCondAttr&? = null
    if posix_pthread_condattr_init(cattr) != 0:
        return 30
    if posix_pthread_condattr_setclock(cattr, 3) != POSIX_EINVAL:
        return 31
    if posix_pthread_condattr_setclock(cattr, 4) != 0:
        return 32

    sem_id: mutable int = -1
    sem_create: int = sceKernelCreateSema(sem_id, "t", 0u32, 1, 2, null)
    if sem_create != ORBIS_OK:
        return 8
    if sceKernelPollSema(sem_id, 1) != ORBIS_OK:
        return 9
    if sceKernelPollSema(sem_id, 1) != ORBIS_KERNEL_ERROR_EBUSY:
        return 10
    if sceKernelSignalSema(sem_id, 1) != ORBIS_OK:
        return 11
    if sceKernelDeleteSema(sem_id) != ORBIS_OK:
        return 12

    key: mutable int = -1
    if posix_pthread_key_create(key, null) != 0:
        return 13
    if posix_pthread_setspecific(key, 0x1234 as void&?) != 0:
        return 14
    got: void&? = posix_pthread_getspecific(key)
    if got == null:
        return 15
    if posix_pthread_key_delete(key) != 0:
        return 16

    ev: mutable int = -1
    if sceKernelCreateEventFlag(ev, "ev", 0u32, 0u64, null) != ORBIS_OK:
        return 17
    if sceKernelSetEventFlag(ev, 0x2u64) != ORBIS_OK:
        return 18
    out_pat: mutable u64 = 0u64
    if sceKernelPollEventFlag(ev, 0x2u64, 0x02u32, out_pat) != ORBIS_OK:
        return 19
    if sceKernelDeleteEventFlag(ev) != ORBIS_OK:
        return 20

    if sceKernelInstallExceptionHandler(30, null) != ORBIS_OK:
        return 21
    if sceKernelRaiseException(null, 30) != ORBIS_OK:
        return 22
    if sceKernelRemoveExceptionHandler(30) != ORBIS_OK:
        return 23

    return 0
