include "./vk_common.elisa"

global mutable g_shader_compiler_initialized: bool = false

def ToEshShaderStage(stage: u32) -> u32:
    return stage

def InitializeCompiler() -> bool:
    if g_shader_compiler_initialized:
        return true
    g_shader_compiler_initialized <- true
    return true

def ShaderUtil_HashString(code: static u8&) -> u64:
    hash: mutable u64 = 1469598103934665603u64
    i: mutable usize = 0usize
    while code[i] != 0u8:
        hash <- hash ^ code[i].u64()
        hash <- hash * 1099511628211u64
        i <- i + 1usize
    return hash

def Compile(code: static u8&, stage: u32, device: u64,
            defines: darray[static u8&] = []) -> u64:
    _ = device
    _ = defines
    if not InitializeCompiler():
        return 0u64
    _ = ToEshShaderStage(stage)
    handle: u64 = Vk_AllocHandle()
    Vk_SetObjectName(handle, code)
    return handle

def CompileSPV(code: darray[u32], device: u64) -> u64:
    _ = code
    _ = device
    return Vk_AllocHandle()
