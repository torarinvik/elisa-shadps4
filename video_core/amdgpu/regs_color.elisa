# Color buffer register structs.

include "./pixel_format.elisa"

const NUM_COLOR_BUFFERS: u32 = 8

# BlendFactor
const BlendFactor_Zero:                 u32 = 0
const BlendFactor_One:                  u32 = 1
const BlendFactor_SrcColor:             u32 = 2
const BlendFactor_OneMinusSrcColor:     u32 = 3
const BlendFactor_SrcAlpha:             u32 = 4
const BlendFactor_OneMinusSrcAlpha:     u32 = 5
const BlendFactor_DstAlpha:             u32 = 6
const BlendFactor_OneMinusDstAlpha:     u32 = 7
const BlendFactor_DstColor:             u32 = 8
const BlendFactor_OneMinusDstColor:     u32 = 9
const BlendFactor_SrcAlphaSaturate:     u32 = 10
const BlendFactor_ConstantColor:        u32 = 13
const BlendFactor_OneMinusConstantColor: u32 = 14
const BlendFactor_Src1Color:            u32 = 15
const BlendFactor_InvSrc1Color:         u32 = 16
const BlendFactor_Src1Alpha:            u32 = 17
const BlendFactor_InvSrc1Alpha:         u32 = 18
const BlendFactor_ConstantAlpha:        u32 = 19
const BlendFactor_OneMinusConstantAlpha: u32 = 20

# BlendFunc
const BlendFunc_Add:             u32 = 0
const BlendFunc_Subtract:        u32 = 1
const BlendFunc_Min:             u32 = 2
const BlendFunc_Max:             u32 = 3
const BlendFunc_ReverseSubtract: u32 = 4

# BlendControl field accessors (packed u32)
def BlendControl_ColorSrcFactor(raw: u32) -> u32:
    return raw & 0x1F

def BlendControl_ColorFunc(raw: u32) -> u32:
    return (raw >> 5) & 0x7

def BlendControl_ColorDstFactor(raw: u32) -> u32:
    return (raw >> 8) & 0x1F

def BlendControl_AlphaSrcFactor(raw: u32) -> u32:
    return (raw >> 16) & 0x1F

def BlendControl_AlphaFunc(raw: u32) -> u32:
    return (raw >> 21) & 0x7

def BlendControl_AlphaDstFactor(raw: u32) -> u32:
    return (raw >> 24) & 0x1F

def BlendControl_SeparateAlphaBlend(raw: u32) -> bool:
    return ((raw >> 29) & 1) != 0

def BlendControl_Enable(raw: u32) -> bool:
    return ((raw >> 30) & 1) != 0

def BlendControl_DisableRop3(raw: u32) -> bool:
    return ((raw >> 31) & 1) != 0

# ColorControl — OperationMode
const ColorControlMode_Disable:           u32 = 0
const ColorControlMode_Normal:            u32 = 1
const ColorControlMode_EliminateFastClear: u32 = 2
const ColorControlMode_Resolve:           u32 = 3
const ColorControlMode_Err:               u32 = 4
const ColorControlMode_FmaskDecompress:   u32 = 5

def ColorControl_Mode(raw: u32) -> u32:
    return (raw >> 4) & 0x7

def ColorControl_DegammaEnable(raw: u32) -> bool:
    return ((raw >> 3) & 1) != 0

def ColorControl_Rop3(raw: u32) -> u32:
    return (raw >> 16) & 0xFF

# ColorBufferMask
def ColorBufferMask_GetMask(raw: u32, buf_id: u32) -> u32:
    return (raw >> (buf_id * 4)) & 0xF

def ColorBufferMask_SetMask(raw: mutable u32, buf_id: u32, mask: u32) -> void:
    raw <- (raw & ~(0xF << (buf_id * 4))) | (mask << (buf_id * 4))

# ColorBuffer — EndianSwap
const EndianSwap_None:     u32 = 0
const EndianSwap_Swap8In16: u32 = 1
const EndianSwap_Swap8In32: u32 = 2
const EndianSwap_Swap8In64: u32 = 3

# SwapMode
const SwapMode_Standard:        u32 = 0
const SwapMode_Alternate:       u32 = 1
const SwapMode_StandardReverse: u32 = 2
const SwapMode_AlternateReverse: u32 = 3

# ColorBuffer info field accessors (info is packed u32)
def ColorBuffer_Endian(info: u32) -> u32:
    return info & 0x3

def ColorBuffer_Format(info: u32) -> u32:
    return (info >> 2) & 0x1F

def ColorBuffer_LinearGeneral(info: u32) -> bool:
    return ((info >> 7) & 1) != 0

def ColorBuffer_NumberType(info: u32) -> u32:
    return (info >> 8) & 0x7

def ColorBuffer_CompSwap(info: u32) -> u32:
    return (info >> 11) & 0x3

def ColorBuffer_DccEnable(info: u32) -> bool:
    return ((info >> 28) & 1) != 0

def ColorBuffer_AltTileMode(info: u32) -> bool:
    return ((info >> 31) & 1) != 0

# ColorBuffer attrib field accessors
def ColorBuffer_TileModeIndex(attrib: u32) -> u32:
    return attrib & 0x1F

def ColorBuffer_NumSamplesLog2(attrib: u32) -> u32:
    return (attrib >> 12) & 0x7

def ColorBuffer_NumFragmentsLog2(attrib: u32) -> u32:
    return (attrib >> 15) & 0x3

def ColorBuffer_ForceDstAlpha1(attrib: u32) -> bool:
    return ((attrib >> 17) & 1) != 0

# ColorBuffer pitch/slice helpers
def ColorBuffer_Pitch(pitch_tile_max: u32) -> u32:
    return (pitch_tile_max + 1) << 3

def ColorBuffer_Height(slice_tile_max: u32, pitch_tile_max: u32) -> u32:
    pitch: u32 = ColorBuffer_Pitch(pitch_tile_max)
    return (slice_tile_max + 1) * 64 / pitch

def ColorBuffer_Address(base_address: u32, info: u32, slice_start: u32) -> u64:
    linear_contrib: u32 = (slice_start & 0xFF) if ColorBuffer_LinearGeneral(info) else 0
    return (base_address.u64() << 8) | linear_contrib.u64()

def ColorBuffer_CmaskAddress(cmask_base_address: u32) -> u64:
    return cmask_base_address.u64() << 8

def ColorBuffer_FmaskAddress(fmask_base_address: u32) -> u64:
    return fmask_base_address.u64() << 8

def ColorBuffer_NumSamples(attrib: u32) -> u32:
    return 1 << ColorBuffer_NumFragmentsLog2(attrib)

def ColorBuffer_BaseSlice(info: u32, slice_start: u32) -> u32:
    if ColorBuffer_LinearGeneral(info):
        return 0
    return slice_start

def ColorBuffer_NonEmpty(base_address: u32, info: u32) -> bool:
    return base_address != 0 and ColorBuffer_Format(info) != 0

def ColorBuffer_GetTileMode(info: u32, attrib: u32) -> u32:
    if ColorBuffer_LinearGeneral(info):
        return 31  # TileMode_DisplayLinearGeneral
    return ColorBuffer_TileModeIndex(attrib)

def ColorBuffer_GetFixedNumberFormat(info: u32) -> u32:
    nfmt: u32 = ColorBuffer_NumberType(info)
    if nfmt == 6:  # NumberFormat_SnormNz -> Srgb
        return 9
    return nfmt

def ColorBuffer_GetDataFmt(info: u32) -> u32:
    return RemapDataFormat(ColorBuffer_Format(info))

def ColorBuffer_GetNumberFmt(info: u32) -> u32:
    return RemapNumberFormat(ColorBuffer_GetFixedNumberFormat(info), ColorBuffer_Format(info))

def ColorBuffer_GetNumberConversion(info: u32) -> u32:
    return MapNumberConversion(ColorBuffer_GetFixedNumberFormat(info), ColorBuffer_Format(info))

# Swizzle table lookup — delegates to C shim (table is static data on C++ side)
extern color_buffer_swizzle(info_raw: u32) -> u32 can[Unsafe.RawExtern]
