# C shims for tiling table lookups (lookup tables live on C++ side)
extern tiling_get_array_mode(tile_mode: u32) -> u32 effects[Unsafe.RawExtern]
extern tiling_get_micro_tile_mode(tile_mode: u32) -> u32 effects[Unsafe.RawExtern]
extern tiling_get_pipe_config(tile_mode: u32) -> u32 effects[Unsafe.RawExtern]
extern tiling_get_alt_pipe_config(tile_mode: u32) -> u32 effects[Unsafe.RawExtern]
extern tiling_get_sample_split(tile_mode: u32) -> u32 effects[Unsafe.RawExtern]
extern tiling_get_tile_split_hw(tile_mode: u32) -> u32 effects[Unsafe.RawExtern]
extern tiling_get_bank_width(macro_tile_mode: u32) -> u32 effects[Unsafe.RawExtern]
extern tiling_get_bank_height(macro_tile_mode: u32) -> u32 effects[Unsafe.RawExtern]
extern tiling_get_num_banks(macro_tile_mode: u32) -> u32 effects[Unsafe.RawExtern]
extern tiling_get_macrotile_aspect(macro_tile_mode: u32) -> u32 effects[Unsafe.RawExtern]
extern tiling_get_alt_bank_height(macro_tile_mode: u32) -> u32 effects[Unsafe.RawExtern]
extern tiling_get_alt_num_banks(macro_tile_mode: u32) -> u32 effects[Unsafe.RawExtern]
extern tiling_get_alt_macrotile_aspect(macro_tile_mode: u32) -> u32 effects[Unsafe.RawExtern]
extern tiling_is_macro_tiled(array_mode: u32) -> bool effects[Unsafe.RawExtern]
extern tiling_is_prt(array_mode: u32) -> bool effects[Unsafe.RawExtern]
extern tiling_get_micro_tile_thickness(array_mode: u32) -> u32 effects[Unsafe.RawExtern]
extern tiling_get_pipe_count(pipe_cfg: u32) -> u32 effects[Unsafe.RawExtern]
extern tiling_calculate_tile_split(tile_mode: u32, array_mode: u32, micro_tile_mode: u32, bpp: u32) -> u32 effects[Unsafe.RawExtern]
extern tiling_calculate_macrotile_mode(tile_mode: u32, bpp: u32, num_samples: u32) -> u32 effects[Unsafe.RawExtern]
extern tiling_name_of(tile_mode: u32) -> static u8&? effects[Unsafe.RawExtern]
