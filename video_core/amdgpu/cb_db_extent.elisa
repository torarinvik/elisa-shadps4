# CbDbExtent — packed u16 width/height in a u32.

def CbDbExtent_Width(raw: u32) -> u32:
    return raw & 0xFFFF

def CbDbExtent_Height(raw: u32) -> u32:
    return (raw >> 16) & 0xFFFF

def CbDbExtent_Pack(width: u32, height: u32) -> u32:
    return (width & 0xFFFF) | ((height & 0xFFFF) << 16)

def CbDbExtent_Valid(raw: u32) -> bool:
    return raw != 0
