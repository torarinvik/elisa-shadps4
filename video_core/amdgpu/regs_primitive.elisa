# Primitive/rasterizer/viewport register structs.

const NUM_VIEWPORTS:  u32 = 16u32
const NUM_CLIP_PLANES: u32 = 6u32

# ClipSpace
const ClipSpace_MinusWToW: u32 = 0u32
const ClipSpace_ZeroToW:   u32 = 1u32

# PrimKillCond
const PrimKillCond_AllVtx: u32 = 0u32
const PrimKillCond_AnyVtx: u32 = 1u32

# ClipperControl field accessors
def ClipperControl_UserClipPlaneEnable(raw: u32) -> u32:
    return raw & 0x3Fu32

def ClipperControl_ClipDisable(raw: u32) -> bool:
    return ((raw >> 16u32) & 1u32) != 0u32

def ClipperControl_ClipSpace(raw: u32) -> u32:
    return (raw >> 19u32) & 0x1u32

def ClipperControl_VtxKillOr(raw: u32) -> u32:
    return (raw >> 21u32) & 0x1u32

def ClipperControl_ZclipNearDisable(raw: u32) -> bool:
    return ((raw >> 26u32) & 1u32) != 0u32

def ClipperControl_ZclipFarDisable(raw: u32) -> bool:
    return ((raw >> 27u32) & 1u32) != 0u32

def ClipperControl_ZclipEnable(raw: u32) -> bool:
    near_dis: bool = ClipperControl_ZclipNearDisable(raw)
    far_dis: bool = ClipperControl_ZclipFarDisable(raw)
    if near_dis != far_dis:
        return false
    return !near_dis

# PolygonMode
const PolygonMode_Point: u32 = 0u32
const PolygonMode_Line:  u32 = 1u32
const PolygonMode_Fill:  u32 = 2u32

# ProvokingVtxLast
const ProvokingVtxLast_First: u32 = 0u32
const ProvokingVtxLast_Last:  u32 = 1u32

# CullMode
const CullMode_None:         u32 = 0u32
const CullMode_Front:        u32 = 1u32
const CullMode_Back:         u32 = 2u32
const CullMode_FrontAndBack: u32 = 3u32

# FrontFace
const FrontFace_CounterClockwise: u32 = 0u32
const FrontFace_Clockwise:        u32 = 1u32

# PolygonControl field accessors
def PolygonControl_CullFront(raw: u32) -> bool:
    return (raw & 1u32) != 0u32

def PolygonControl_CullBack(raw: u32) -> bool:
    return ((raw >> 1u32) & 1u32) != 0u32

def PolygonControl_FrontFace(raw: u32) -> u32:
    return (raw >> 2u32) & 0x1u32

def PolygonControl_EnablePolygonMode(raw: u32) -> u32:
    return (raw >> 3u32) & 0x3u32

def PolygonControl_PolygonModeFront(raw: u32) -> u32:
    return (raw >> 5u32) & 0x7u32

def PolygonControl_PolygonModeBack(raw: u32) -> u32:
    return (raw >> 8u32) & 0x7u32

def PolygonControl_EnablePolygonOffsetFront(raw: u32) -> bool:
    return ((raw >> 11u32) & 1u32) != 0u32

def PolygonControl_EnablePolygonOffsetBack(raw: u32) -> bool:
    return ((raw >> 12u32) & 1u32) != 0u32

def PolygonControl_EnablePolygonOffsetPara(raw: u32) -> bool:
    return ((raw >> 13u32) & 1u32) != 0u32

def PolygonControl_ProvokingVtxLast(raw: u32) -> u32:
    return (raw >> 19u32) & 0x1u32

def PolygonControl_PolyMode(raw: u32) -> u32:
    if PolygonControl_EnablePolygonMode(raw) != 0u32:
        return PolygonControl_PolygonModeFront(raw)
    return PolygonMode_Fill

def PolygonControl_CullingMode(raw: u32) -> u32:
    cf: u32 = if PolygonControl_CullFront(raw): 1u32 else: 0u32
    cb: u32 = if PolygonControl_CullBack(raw): 2u32 else: 0u32
    return cf | cb

def PolygonControl_NeedsBias(raw: u32) -> bool:
    return PolygonControl_EnablePolygonOffsetBack(raw) or PolygonControl_EnablePolygonOffsetFront(raw) or PolygonControl_EnablePolygonOffsetPara(raw)

# VsOutputControl
def VsOutputControl_ClipDistanceEnable(raw: u32) -> u32:
    return raw & 0xFFu32

def VsOutputControl_CullDistanceEnable(raw: u32) -> u32:
    return (raw >> 8u32) & 0xFFu32

def VsOutputControl_IsClipDistEnabled(raw: u32, index: u32) -> bool:
    return ((VsOutputControl_ClipDistanceEnable(raw) >> index) & 1u32) != 0u32

def VsOutputControl_IsCullDistEnabled(raw: u32, index: u32) -> bool:
    return ((VsOutputControl_CullDistanceEnable(raw) >> index) & 1u32) != 0u32

def VsOutputControl_UseVtxPointSize(raw: u32) -> bool:
    return ((raw >> 16u32) & 1u32) != 0u32

def VsOutputControl_UseVtxViewportIdx(raw: u32) -> bool:
    return ((raw >> 19u32) & 1u32) != 0u32

def VsOutputControl_VsOutMiscEnable(raw: u32) -> bool:
    return ((raw >> 21u32) & 1u32) != 0u32

def VsOutputControl_VsOutCcdist0Enable(raw: u32) -> bool:
    return ((raw >> 22u32) & 1u32) != 0u32

def VsOutputControl_VsOutCcdist1Enable(raw: u32) -> bool:
    return ((raw >> 23u32) & 1u32) != 0u32

# LineControl
def LineControl_Width(width_fixed_point: u32) -> f32:
    return width_fixed_point.f32() / 8.0f32

# ModeControl
def ModeControl_MsaaEnable(raw: u32) -> bool:
    return (raw & 1u32) != 0u32

def ModeControl_VportScissorEnable(raw: u32) -> bool:
    return ((raw >> 1u32) & 1u32) != 0u32

# Scissor (packed as two u32: {top_left_x: s16, top_left_y: s16}, {bottom_right_x: s16, bottom_right_y: s16})
def Scissor_TopLeftX(w0: u32) -> i32:
    return (w0 & 0xFFFFu32).i16().i32()

def Scissor_TopLeftY(w0: u32) -> i32:
    return ((w0 >> 16u32) & 0xFFFFu32).i16().i32()

def Scissor_BottomRightX(w1: u32) -> i32:
    return (w1 & 0xFFFFu32).i16().i32()

def Scissor_BottomRightY(w1: u32) -> i32:
    return ((w1 >> 16u32) & 0xFFFFu32).i16().i32()

def Scissor_GetWidth(w0: u32, w1: u32) -> u32:
    left: i32 = if Scissor_TopLeftX(w0) > 0: Scissor_TopLeftX(w0) else: 0
    right: i32 = if Scissor_BottomRightX(w1) > 0: Scissor_BottomRightX(w1) else: 0
    if right > left:
        return (right - left).u32()
    return 0u32

def Scissor_GetHeight(w0: u32, w1: u32) -> u32:
    top: i32 = if Scissor_TopLeftY(w0) > 0: Scissor_TopLeftY(w0) else: 0
    bottom: i32 = if Scissor_BottomRightY(w1) > 0: Scissor_BottomRightY(w1) else: 0
    if bottom > top:
        return (bottom - top).u32()
    return 0u32

# ViewportScissor
def ViewportScissor_TopLeftX(w0: u32) -> u32:
    return w0 & 0x7FFFu32

def ViewportScissor_TopLeftY(w0: u32) -> u32:
    return (w0 >> 15u32) & 0x7FFFu32

def ViewportScissor_BottomRightX(w1: u32) -> u32:
    return w1 & 0x7FFFu32

def ViewportScissor_BottomRightY(w1: u32) -> u32:
    return (w1 >> 15u32) & 0x7FFFu32

def ViewportScissor_GetWidth(w0: u32, w1: u32) -> u32:
    r: u32 = ViewportScissor_BottomRightX(w1)
    l: u32 = ViewportScissor_TopLeftX(w0)
    if r > l:
        return r - l
    return 0u32

def ViewportScissor_GetHeight(w0: u32, w1: u32) -> u32:
    b: u32 = ViewportScissor_BottomRightY(w1)
    t: u32 = ViewportScissor_TopLeftY(w0)
    if b > t:
        return b - t
    return 0u32

# WindowOffset
def WindowOffset_X(raw: u32) -> i32:
    return (raw & 0xFFFFu32).i16().i32()

def WindowOffset_Y(raw: u32) -> i32:
    return ((raw >> 16u32) & 0xFFFFu32).i16().i32()

# AaConfig
def AaConfig_NumSamples(raw: u32) -> u32:
    return 1u32 << (raw & 0x7u32)

# GsMode
const GsScenario_Off:       u32 = 0u32
const GsScenario_ScenarioA: u32 = 1u32
const GsScenario_ScenarioB: u32 = 2u32
const GsScenario_ScenarioG: u32 = 3u32
const GsScenario_ScenarioC: u32 = 4u32

def GsMode_Mode(raw: u32) -> u32:
    return raw & 0x7u32

def GsMode_ComputeMode(raw: u32) -> bool:
    return ((raw >> 14u32) & 1u32) != 0u32

def GsOnchip_EsVertsPerSubgroup(raw: u32) -> u32:
    return raw & 0x7FFu32

def GsOnchip_GsPrimsPerSubgroup(raw: u32) -> u32:
    return (raw >> 11u32) & 0x7FFu32
