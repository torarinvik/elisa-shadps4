# Data/image format enumerations and format utility functions.

# DataFormat — Table 8.13 Sea Islands ISA
const DataFormat_FormatInvalid:          u32 = 0u32
const DataFormat_Format8:                u32 = 1u32
const DataFormat_Format16:               u32 = 2u32
const DataFormat_Format8_8:              u32 = 3u32
const DataFormat_Format32:               u32 = 4u32
const DataFormat_Format16_16:            u32 = 5u32
const DataFormat_Format10_11_11:         u32 = 6u32
const DataFormat_Format11_11_10:         u32 = 7u32
const DataFormat_Format10_10_10_2:       u32 = 8u32
const DataFormat_Format2_10_10_10:       u32 = 9u32
const DataFormat_Format8_8_8_8:          u32 = 10u32
const DataFormat_Format32_32:            u32 = 11u32
const DataFormat_Format16_16_16_16:      u32 = 12u32
const DataFormat_Format32_32_32:         u32 = 13u32
const DataFormat_Format32_32_32_32:      u32 = 14u32
const DataFormat_Format5_6_5:            u32 = 16u32
const DataFormat_Format1_5_5_5:          u32 = 17u32
const DataFormat_Format5_5_5_1:          u32 = 18u32
const DataFormat_Format4_4_4_4:          u32 = 19u32
const DataFormat_Format8_24:             u32 = 20u32
const DataFormat_Format24_8:             u32 = 21u32
const DataFormat_FormatX24_8_32:         u32 = 22u32
const DataFormat_FormatGB_GR:            u32 = 32u32
const DataFormat_FormatBG_RG:            u32 = 33u32
const DataFormat_Format5_9_9_9:          u32 = 34u32
const DataFormat_FormatBc1:              u32 = 35u32
const DataFormat_FormatBc2:              u32 = 36u32
const DataFormat_FormatBc3:              u32 = 37u32
const DataFormat_FormatBc4:              u32 = 38u32
const DataFormat_FormatBc5:              u32 = 39u32
const DataFormat_FormatBc6:              u32 = 40u32
const DataFormat_FormatBc7:              u32 = 41u32
const DataFormat_FormatFmask8_1:         u32 = 47u32
const DataFormat_FormatFmask8_2:         u32 = 48u32
const DataFormat_FormatFmask8_4:         u32 = 49u32
const DataFormat_FormatFmask16_1:        u32 = 50u32
const DataFormat_FormatFmask16_2:        u32 = 51u32
const DataFormat_FormatFmask32_2:        u32 = 52u32
const DataFormat_FormatFmask32_4:        u32 = 53u32
const DataFormat_FormatFmask32_8:        u32 = 54u32
const DataFormat_FormatFmask64_4:        u32 = 55u32
const DataFormat_FormatFmask64_8:        u32 = 56u32
const DataFormat_Format4_4:              u32 = 57u32
const DataFormat_Format6_5_5:            u32 = 58u32
const DataFormat_Format1:                u32 = 59u32
const DataFormat_Format1_Reversed:       u32 = 60u32
const DataFormat_Format32_As_8:          u32 = 61u32
const DataFormat_Format32_As_8_8:        u32 = 62u32
const DataFormat_Format32_As_32_32_32_32: u32 = 63u32

# NumberFormat
const NumberFormat_Unorm:    u32 = 0u32
const NumberFormat_Snorm:    u32 = 1u32
const NumberFormat_Uscaled:  u32 = 2u32
const NumberFormat_Sscaled:  u32 = 3u32
const NumberFormat_Uint:     u32 = 4u32
const NumberFormat_Sint:     u32 = 5u32
const NumberFormat_SnormNz:  u32 = 6u32
const NumberFormat_Float:    u32 = 7u32
const NumberFormat_Srgb:     u32 = 9u32
const NumberFormat_Ubnorm:   u32 = 10u32
const NumberFormat_UbnormNz: u32 = 11u32
const NumberFormat_Ubint:    u32 = 12u32
const NumberFormat_Ubscaled: u32 = 13u32

# NumberClass
const NumberClass_Float: u32 = 0u32
const NumberClass_Sint:  u32 = 1u32
const NumberClass_Uint:  u32 = 2u32

# CompSwizzle
const CompSwizzle_Zero:  u32 = 0u32
const CompSwizzle_One:   u32 = 1u32
const CompSwizzle_Red:   u32 = 4u32
const CompSwizzle_Green: u32 = 5u32
const CompSwizzle_Blue:  u32 = 6u32
const CompSwizzle_Alpha: u32 = 7u32

# NumberConversion
const NumberConversion_None:            u32 = 0u32
const NumberConversion_UintToUscaled:   u32 = 1u32
const NumberConversion_SintToSscaled:   u32 = 2u32
const NumberConversion_UnormToUbnorm:   u32 = 3u32
const NumberConversion_Sint8ToSnormNz:  u32 = 4u32
const NumberConversion_Sint16ToSnormNz: u32 = 5u32
const NumberConversion_Uint32ToUnorm:   u32 = 6u32
const NumberConversion_SrgbToNorm:      u32 = 7u32

# CompMapping — pack r/g/b/a as u8[4] into a u32 (r=bits[0:7], g=bits[8:15], b=bits[16:23], a=bits[24:31])
const IdentityMapping_R: u32 = CompSwizzle_Red
const IdentityMapping_G: u32 = CompSwizzle_Green
const IdentityMapping_B: u32 = CompSwizzle_Blue
const IdentityMapping_A: u32 = CompSwizzle_Alpha

def CompMapping_Pack(r: u32, g: u32, b: u32, a: u32) -> u32:
    return r | (g << 8u32) | (b << 16u32) | (a << 24u32)

def CompMapping_R(m: u32) -> u32:
    return m & 0xFFu32

def CompMapping_G(m: u32) -> u32:
    return (m >> 8u32) & 0xFFu32

def CompMapping_B(m: u32) -> u32:
    return (m >> 16u32) & 0xFFu32

def CompMapping_A(m: u32) -> u32:
    return (m >> 24u32) & 0xFFu32

def CompMapping_Identity() -> u32:
    return CompMapping_Pack(CompSwizzle_Red, CompSwizzle_Green, CompSwizzle_Blue, CompSwizzle_Alpha)

def CompMapping_Eq(a: u32, b: u32) -> bool:
    return a == b

# Map a single swizzle component given a source channel component index and swizzle enum
def CompSwizzle_Map(swizzle: u32, comp: u32) -> u32:
    if swizzle >= CompSwizzle_Red:
        return swizzle - CompSwizzle_Red
    return comp

def RemapDataFormat(fmt: u32) -> u32:
    if fmt == DataFormat_Format11_11_10:
        return DataFormat_Format10_11_11
    if fmt == DataFormat_Format10_10_10_2:
        return DataFormat_Format2_10_10_10
    if fmt == DataFormat_Format5_5_5_1:
        return DataFormat_Format1_5_5_5
    return fmt

def RemapNumberFormat(fmt: u32, data_fmt: u32) -> u32:
    if fmt == NumberFormat_Unorm:
        if data_fmt == DataFormat_Format32 or data_fmt == DataFormat_Format32_32 or
           data_fmt == DataFormat_Format32_32_32 or data_fmt == DataFormat_Format32_32_32_32:
            return NumberFormat_Uint
        return fmt
    if fmt == NumberFormat_Srgb:
        if data_fmt == DataFormat_FormatBc6:
            return NumberFormat_Unorm
        return fmt
    if fmt == NumberFormat_Uscaled:
        return NumberFormat_Uint
    if fmt == NumberFormat_Sscaled or fmt == NumberFormat_SnormNz:
        return NumberFormat_Sint
    if fmt == NumberFormat_Ubnorm:
        return NumberFormat_Unorm
    if fmt == NumberFormat_Float:
        if data_fmt == DataFormat_Format8:
            return NumberFormat_Uint
        return fmt
    return fmt

def RemapSwizzle(fmt: u32, swizzle: u32) -> u32:
    r: u32 = CompMapping_R(swizzle)
    g: u32 = CompMapping_G(swizzle)
    b: u32 = CompMapping_B(swizzle)
    a: u32 = CompMapping_A(swizzle)
    if fmt == DataFormat_Format1_5_5_5 or fmt == DataFormat_Format11_11_10:
        return CompMapping_Pack(b, g, r, a)
    if fmt == DataFormat_Format10_10_10_2:
        return CompMapping_Pack(a, b, g, r)
    if fmt == DataFormat_Format4_4_4_4:
        return CompMapping_Pack(g, b, a, r)
    if fmt == DataFormat_Format5_6_5:
        return CompMapping_Pack(b, g, r, a)
    return swizzle

def MapNumberConversion(num_fmt: u32, data_fmt: u32) -> u32:
    if num_fmt == NumberFormat_Unorm:
        if data_fmt == DataFormat_Format32 or data_fmt == DataFormat_Format32_32 or
           data_fmt == DataFormat_Format32_32_32 or data_fmt == DataFormat_Format32_32_32_32:
            return NumberConversion_Uint32ToUnorm
        return NumberConversion_None
    if num_fmt == NumberFormat_Srgb:
        if data_fmt == DataFormat_FormatBc6:
            return NumberConversion_SrgbToNorm
        return NumberConversion_None
    if num_fmt == NumberFormat_Uscaled:
        return NumberConversion_UintToUscaled
    if num_fmt == NumberFormat_Sscaled:
        return NumberConversion_SintToSscaled
    if num_fmt == NumberFormat_Ubnorm:
        return NumberConversion_UnormToUbnorm
    if num_fmt == NumberFormat_SnormNz:
        if data_fmt == DataFormat_Format8 or data_fmt == DataFormat_Format8_8 or
           data_fmt == DataFormat_Format8_8_8_8:
            return NumberConversion_Sint8ToSnormNz
        if data_fmt == DataFormat_Format16 or data_fmt == DataFormat_Format16_16 or
           data_fmt == DataFormat_Format16_16_16_16:
            return NumberConversion_Sint16ToSnormNz
        return NumberConversion_None
    return NumberConversion_None

def GetNumberClass(nfmt: u32) -> u32:
    if nfmt == NumberFormat_Sint:
        return NumberClass_Sint
    if nfmt == NumberFormat_Uint:
        return NumberClass_Uint
    return NumberClass_Float

def IsInteger(nfmt: u32) -> bool:
    return nfmt == NumberFormat_Sint or nfmt == NumberFormat_Uint

def IsBlockCoded(fmt: u32) -> bool:
    return fmt >= DataFormat_FormatBc1 and fmt <= DataFormat_FormatBc7

def IsFmask(fmt: u32) -> bool:
    return fmt >= DataFormat_FormatFmask8_1 and fmt <= DataFormat_FormatFmask64_8

# C shims for string lookup and component count (implemented on C++ side)
extern pixel_format_name_of_data_fmt(fmt: u32) -> static u8&? effects[Unsafe.RawExtern]
extern pixel_format_name_of_num_fmt(fmt: u32) -> static u8&? effects[Unsafe.RawExtern]
extern pixel_format_num_components(fmt: u32) -> u32 effects[Unsafe.RawExtern]
extern pixel_format_num_bits_per_block(fmt: u32) -> u32 effects[Unsafe.RawExtern]
extern pixel_format_num_bits_per_element(fmt: u32) -> u32 effects[Unsafe.RawExtern]
