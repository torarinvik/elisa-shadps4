# Main Regs union constants and helpers.

include "./regs_color.elisa"
include "./regs_depth.elisa"
include "./regs_primitive.elisa"
include "./regs_shader.elisa"
include "./regs_texture.elisa"
include "./regs_vertex.elisa"

const Regs_NumRegs:               u32 = 0xD000
const Regs_UconfigRegWordOffset:  u32 = 0xC000
const Regs_ContextRegWordOffset:  u32 = 0xA000
const Regs_ConfigRegWordOffset:   u32 = 0x2000
const Regs_ShRegWordOffset:       u32 = 0x2C00

# IsClipDisabled — checks clipper_control clip_disable bit OR RectList primitive
def Regs_IsClipDisabled(clipper_control_raw: u32, primitive_type: u32) -> bool:
    return ClipperControl_ClipDisable(clipper_control_raw) or primitive_type == PrimitiveType_RectList

# ProgramForStage — returns register word offset for each shader stage index
def Regs_ProgramForStage(stage: u32) -> u32:
    # ps=0, vs=1, gs=2, es=3, hs=4, ls=5
    # These are relative word indices into reg_array — implementation depends on layout
    if stage == 0:
        return 0   # ps_program offset
    if stage == 1:
        return 1   # vs_program offset
    if stage == 2:
        return 2   # gs_program offset
    if stage == 3:
        return 3   # es_program offset
    if stage == 4:
        return 4   # hs_program offset
    if stage == 5:
        return 5   # ls_program offset
    return 0xFFFFFFFF  # invalid

# SetDefaults — delegates to C shim (initializes reg_array from compile-time table)
extern regs_set_defaults(reg_array_ptr: u64) -> void can[Unsafe.RawExtern]
