include "../amdgpu/regs_texture.elisa"

const ClampMode_Wrap: u32 = 0u32
const ClampMode_Mirror: u32 = 1u32
const ClampMode_ClampBorder: u32 = 6u32
const ClampMode_MirrorOnceBorder: u32 = 7u32

const Filter_Point: u32 = 0u32
const Filter_Bilinear: u32 = 1u32
const Filter_AnisoPoint: u32 = 2u32
const Filter_AnisoLinear: u32 = 3u32

const MipFilter_None: u32 = 0u32
const MipFilter_Point: u32 = 1u32
const MipFilter_Linear: u32 = 2u32

const BorderColor_TransparentBlack: u32 = 0u32
const BorderColor_OpaqueBlack: u32 = 1u32
const BorderColor_White: u32 = 2u32

const DepthCompare_Never: u32 = 0u32
const DepthCompare_Less: u32 = 1u32
const DepthCompare_Equal: u32 = 2u32
const DepthCompare_LessEqual: u32 = 3u32
const DepthCompare_Greater: u32 = 4u32
const DepthCompare_NotEqual: u32 = 5u32
const DepthCompare_GreaterEqual: u32 = 6u32
const DepthCompare_Always: u32 = 7u32

const VK_SAMPLER_ADDRESS_REPEAT: u32 = 0u32
const VK_SAMPLER_ADDRESS_MIRRORED_REPEAT: u32 = 1u32
const VK_SAMPLER_ADDRESS_CLAMP_TO_EDGE: u32 = 2u32
const VK_SAMPLER_ADDRESS_CLAMP_TO_BORDER: u32 = 3u32

const VK_FILTER_NEAREST: u32 = 0u32
const VK_FILTER_LINEAR: u32 = 1u32

const VK_SAMPLER_MIPMAP_MODE_NEAREST: u32 = 0u32
const VK_SAMPLER_MIPMAP_MODE_LINEAR: u32 = 1u32

const VK_COMPARE_OP_NEVER: u32 = 0u32
const VK_COMPARE_OP_LESS: u32 = 1u32
const VK_COMPARE_OP_EQUAL: u32 = 2u32
const VK_COMPARE_OP_LESS_OR_EQUAL: u32 = 3u32
const VK_COMPARE_OP_GREATER: u32 = 4u32
const VK_COMPARE_OP_NOT_EQUAL: u32 = 5u32
const VK_COMPARE_OP_GREATER_OR_EQUAL: u32 = 6u32
const VK_COMPARE_OP_ALWAYS: u32 = 7u32

const VK_BORDER_COLOR_FLOAT_TRANSPARENT_BLACK: u32 = 0u32
const VK_BORDER_COLOR_FLOAT_OPAQUE_BLACK: u32 = 1u32
const VK_BORDER_COLOR_FLOAT_OPAQUE_WHITE: u32 = 2u32
const VK_BORDER_COLOR_FLOAT_CUSTOM: u32 = 3u32

struct SamplerCustomBorderColor:
    r: mutable f32
    g: mutable f32
    b: mutable f32
    a: mutable f32

def SamplerCustomBorderColor_default() -> SamplerCustomBorderColor:
    return SamplerCustomBorderColor(0.0, 0.0, 0.0, 1.0)

struct SamplerDesc:
    raw0: mutable u64
    raw1: mutable u64

def SamplerDesc_new(raw0: u64, raw1: u64) -> SamplerDesc:
    return SamplerDesc(raw0, raw1)

struct Sampler:
    handle: mutable u64
    address_u: mutable u32
    address_v: mutable u32
    address_w: mutable u32
    min_filter: mutable u32
    mag_filter: mutable u32
    mip_filter: mutable u32
    compare_op: mutable u32
    anisotropy_enable: mutable bool
    max_anisotropy: mutable f32
    border_color: mutable u32
    border_color_ptr: mutable u64
    custom_border_color: mutable SamplerCustomBorderColor
    lod_bias: mutable f32
    min_lod: mutable f32
    max_lod: mutable f32
    valid: mutable bool

def Sampler_Default() -> Sampler:
    return Sampler(
        0u64,
        VK_SAMPLER_ADDRESS_REPEAT,
        VK_SAMPLER_ADDRESS_REPEAT,
        VK_SAMPLER_ADDRESS_REPEAT,
        VK_FILTER_NEAREST,
        VK_FILTER_NEAREST,
        VK_SAMPLER_MIPMAP_MODE_NEAREST,
        VK_COMPARE_OP_ALWAYS,
        false,
        1.0,
        VK_BORDER_COLOR_FLOAT_OPAQUE_BLACK,
        0u64,
        SamplerCustomBorderColor_default(),
        0.0,
        0.0,
        15.0,
        false
    )

def Sampler_NonEmpty(raw0: u64, raw1: u64) -> bool:
    return raw0 != 0u64 or raw1 != 0u64

def Sampler_ClampX(raw0: u64) -> u32:
    return (raw0 & 0x7u64).u32()

def Sampler_ClampY(raw0: u64) -> u32:
    return ((raw0 >> 3u64) & 0x7u64).u32()

def Sampler_ClampZ(raw0: u64) -> u32:
    return ((raw0 >> 6u64) & 0x7u64).u32()

def Sampler_MaxAniso(raw0: u64) -> u32:
    return ((raw0 >> 9u64) & 0x7u64).u32()

def Sampler_DepthCompareFunc(raw0: u64) -> u32:
    return ((raw0 >> 12u64) & 0x7u64).u32()

def Sampler_MinLod(raw0: u64) -> u32:
    return ((raw0 >> 15u64) & 0xfffu64).u32()

def Sampler_MaxLod(raw0: u64) -> u32:
    return ((raw0 >> 27u64) & 0xfffu64).u32()

def Sampler_LodBias(raw1: u64) -> u32:
    return (raw1 & 0x3fffu64).u32()

def Sampler_XyMagFilter(raw1: u64) -> u32:
    return ((raw1 >> 20u64) & 0x3u64).u32()

def Sampler_XyMinFilter(raw1: u64) -> u32:
    return ((raw1 >> 22u64) & 0x3u64).u32()

def Sampler_MipFilter(raw1: u64) -> u32:
    return ((raw1 >> 24u64) & 0x3u64).u32()

def Sampler_BorderColorType(raw1: u64) -> u32:
    return ((raw1 >> 26u64) & 0x3u64).u32()

def Sampler_BorderColorPtr(raw1: u64) -> u32:
    return ((raw1 >> 32u64) & 0xfffu64).u32()

def Sampler_MinLodFloat(raw0: u64) -> f32:
    return Sampler_MinLod(raw0).i64().f32() / 256.0

def Sampler_MaxLodFloat(raw0: u64) -> f32:
    return Sampler_MaxLod(raw0).i64().f32() / 256.0

def Sampler_MaxAnisoFloat(raw0: u64) -> f32:
    ratio: u32 = Sampler_MaxAniso(raw0)
    if ratio == 0u32:
        return 1.0
    if ratio == 1u32:
        return 2.0
    if ratio == 2u32:
        return 4.0
    if ratio == 3u32:
        return 8.0
    return 16.0

def IsAnisoFilter(filter: u32) -> bool:
    return filter == Filter_AnisoPoint or filter == Filter_AnisoLinear

def Sampler_AddressMode(clamp: u32) -> u32:
    if clamp == ClampMode_Wrap:
        return VK_SAMPLER_ADDRESS_REPEAT
    if clamp == ClampMode_Mirror:
        return VK_SAMPLER_ADDRESS_MIRRORED_REPEAT
    if clamp == ClampMode_ClampBorder or clamp == ClampMode_MirrorOnceBorder:
        return VK_SAMPLER_ADDRESS_CLAMP_TO_BORDER
    return VK_SAMPLER_ADDRESS_CLAMP_TO_EDGE

def Sampler_Filter(filter: u32) -> u32:
    if filter == Filter_Bilinear or filter == Filter_AnisoLinear:
        return VK_FILTER_LINEAR
    return VK_FILTER_NEAREST

def Sampler_MipmapMode(filter: u32) -> u32:
    if filter == MipFilter_Linear:
        return VK_SAMPLER_MIPMAP_MODE_LINEAR
    return VK_SAMPLER_MIPMAP_MODE_NEAREST

def Sampler_CompareOp(compare: u32) -> u32:
    if compare == DepthCompare_Never:
        return VK_COMPARE_OP_NEVER
    if compare == DepthCompare_Less:
        return VK_COMPARE_OP_LESS
    if compare == DepthCompare_Equal:
        return VK_COMPARE_OP_EQUAL
    if compare == DepthCompare_LessEqual:
        return VK_COMPARE_OP_LESS_OR_EQUAL
    if compare == DepthCompare_Greater:
        return VK_COMPARE_OP_GREATER
    if compare == DepthCompare_NotEqual:
        return VK_COMPARE_OP_NOT_EQUAL
    if compare == DepthCompare_GreaterEqual:
        return VK_COMPARE_OP_GREATER_OR_EQUAL
    return VK_COMPARE_OP_ALWAYS

def Sampler_BorderColor(border: u32) -> u32:
    if border == BorderColor_TransparentBlack:
        return VK_BORDER_COLOR_FLOAT_TRANSPARENT_BLACK
    if border == BorderColor_OpaqueBlack:
        return VK_BORDER_COLOR_FLOAT_OPAQUE_BLACK
    if border == BorderColor_White:
        return VK_BORDER_COLOR_FLOAT_OPAQUE_WHITE
    return VK_BORDER_COLOR_FLOAT_CUSTOM

def Sampler_New(desc: SamplerDesc, border_color_base: u64, custom_border_supported: bool, next_handle: u64) -> Sampler:
    out: mutable Sampler = Sampler_Default()
    if not Sampler_NonEmpty(desc.raw0, desc.raw1):
        return out

    out.address_u <- Sampler_AddressMode(Sampler_ClampX(desc.raw0))
    out.address_v <- Sampler_AddressMode(Sampler_ClampY(desc.raw0))
    out.address_w <- Sampler_AddressMode(Sampler_ClampZ(desc.raw0))
    out.min_filter <- Sampler_Filter(Sampler_XyMinFilter(desc.raw1))
    out.mag_filter <- Sampler_Filter(Sampler_XyMagFilter(desc.raw1))
    out.mip_filter <- Sampler_MipmapMode(Sampler_MipFilter(desc.raw1))
    out.compare_op <- Sampler_CompareOp(Sampler_DepthCompareFunc(desc.raw0))
    out.max_anisotropy <- Sampler_MaxAnisoFloat(desc.raw0)
    out.anisotropy_enable <- IsAnisoFilter(Sampler_XyMagFilter(desc.raw1)) or IsAnisoFilter(Sampler_XyMinFilter(desc.raw1))
    out.lod_bias <- Sampler_LodBias(desc.raw1).i64().f32() / 256.0
    out.min_lod <- Sampler_MinLodFloat(desc.raw0)
    out.max_lod <- Sampler_MaxLodFloat(desc.raw0)
    out.border_color <- Sampler_BorderColor(Sampler_BorderColorType(desc.raw1))
    out.border_color_ptr <- BorderColorBuffer_Address(border_color_base) + Sampler_BorderColorPtr(desc.raw1).u64() * 16u64
    if out.border_color == VK_BORDER_COLOR_FLOAT_CUSTOM and not custom_border_supported:
        out.border_color <- VK_BORDER_COLOR_FLOAT_OPAQUE_BLACK
    if out.border_color == VK_BORDER_COLOR_FLOAT_CUSTOM:
        out.custom_border_color <- SamplerCustomBorderColor(0.0, 0.0, 0.0, 0.0)
    out.handle <- next_handle
    out.valid <- true
    return out

def Sampler_Destroy(self: mutable Sampler&) -> void:
    self.valid <- false
    self.handle <- 0u64

def Sampler_Handle(self: Sampler) -> u64:
    return self.handle
