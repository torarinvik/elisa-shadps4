const VIDEO_CORE_HOST_SHADERS_FSR_SOURCE_PATH: static u8& = "fsr.comp"
const VIDEO_CORE_HOST_SHADERS_FSR_FFX_A_PATH: static u8& = "fsr/ffx_a.h"
const VIDEO_CORE_HOST_SHADERS_FSR_FFX_FSR1_PATH: static u8& = "fsr/ffx_fsr1.h"
const VIDEO_CORE_HOST_SHADERS_FSR_GENERATED_SYMBOL: static u8& = "FSR_COMP"

const VIDEO_CORE_HOST_SHADERS_FSR_SOURCE_BYTES: usize = 3249
const VIDEO_CORE_HOST_SHADERS_FSR_SOURCE_LINES: usize = 90
const VIDEO_CORE_HOST_SHADERS_FSR_SOURCE_BYTE_SUM: u32 = 0x0003f2be

const VIDEO_CORE_HOST_SHADERS_FSR_FFX_A_BYTES: usize = 181935
const VIDEO_CORE_HOST_SHADERS_FSR_FFX_A_LINES: usize = 2657
const VIDEO_CORE_HOST_SHADERS_FSR_FFX_A_BYTE_SUM: u32 = 0x00b28066

const VIDEO_CORE_HOST_SHADERS_FSR_FFX_FSR1_BYTES: usize = 60330
const VIDEO_CORE_HOST_SHADERS_FSR_FFX_FSR1_LINES: usize = 1200
const VIDEO_CORE_HOST_SHADERS_FSR_FFX_FSR1_BYTE_SUM: u32 = 0x003fdd3d

const VIDEO_CORE_HOST_SHADERS_FSR_EXPANDED_BYTES: usize = 245467
const VIDEO_CORE_HOST_SHADERS_FSR_EXPANDED_LINES: usize = 3947
const VIDEO_CORE_HOST_SHADERS_FSR_EXPANDED_BYTE_SUM: u32 = 0x00f64048

struct HostShaderFsrAssetInfo:
    path: static u8&
    generated_symbol: static u8&
    source_bytes: usize
    source_lines: usize
    byte_sum: u32

def HostShaderFsr_SourceInfo() -> HostShaderFsrAssetInfo:
    return HostShaderFsrAssetInfo(
        VIDEO_CORE_HOST_SHADERS_FSR_SOURCE_PATH,
        VIDEO_CORE_HOST_SHADERS_FSR_GENERATED_SYMBOL,
        VIDEO_CORE_HOST_SHADERS_FSR_SOURCE_BYTES,
        VIDEO_CORE_HOST_SHADERS_FSR_SOURCE_LINES,
        VIDEO_CORE_HOST_SHADERS_FSR_SOURCE_BYTE_SUM
    )

def HostShaderFsr_FfxAInfo() -> HostShaderFsrAssetInfo:
    return HostShaderFsrAssetInfo(
        VIDEO_CORE_HOST_SHADERS_FSR_FFX_A_PATH,
        "FFX_A_H",
        VIDEO_CORE_HOST_SHADERS_FSR_FFX_A_BYTES,
        VIDEO_CORE_HOST_SHADERS_FSR_FFX_A_LINES,
        VIDEO_CORE_HOST_SHADERS_FSR_FFX_A_BYTE_SUM
    )

def HostShaderFsr_FfxFsr1Info() -> HostShaderFsrAssetInfo:
    return HostShaderFsrAssetInfo(
        VIDEO_CORE_HOST_SHADERS_FSR_FFX_FSR1_PATH,
        "FFX_FSR1_H",
        VIDEO_CORE_HOST_SHADERS_FSR_FFX_FSR1_BYTES,
        VIDEO_CORE_HOST_SHADERS_FSR_FFX_FSR1_LINES,
        VIDEO_CORE_HOST_SHADERS_FSR_FFX_FSR1_BYTE_SUM
    )

def HostShaderFsr_ExpandedBytes() -> usize:
    return VIDEO_CORE_HOST_SHADERS_FSR_EXPANDED_BYTES

def HostShaderFsr_ExpandedLines() -> usize:
    return VIDEO_CORE_HOST_SHADERS_FSR_EXPANDED_LINES

def HostShaderFsr_ExpandedByteSum() -> u32:
    return VIDEO_CORE_HOST_SHADERS_FSR_EXPANDED_BYTE_SUM

def HostShaderFsr_IsFsrInclude(path: static u8&) -> bool:
    if streq(path, VIDEO_CORE_HOST_SHADERS_FSR_FFX_A_PATH) == 1:
        return true
    if streq(path, VIDEO_CORE_HOST_SHADERS_FSR_FFX_FSR1_PATH) == 1:
        return true
    return false

def HostShaderFsr_ResolveInclude(path: static u8&) -> static u8&:
    if streq(path, VIDEO_CORE_HOST_SHADERS_FSR_FFX_A_PATH) == 1:
        return VIDEO_CORE_HOST_SHADERS_FSR_FFX_A_PATH
    if streq(path, VIDEO_CORE_HOST_SHADERS_FSR_FFX_FSR1_PATH) == 1:
        return VIDEO_CORE_HOST_SHADERS_FSR_FFX_FSR1_PATH
    return ""

def HostShaderFsr_GeneratedHeaderName(path: static u8&) -> static u8&:
    if streq(path, VIDEO_CORE_HOST_SHADERS_FSR_SOURCE_PATH) == 1:
        return VIDEO_CORE_HOST_SHADERS_FSR_GENERATED_SYMBOL
    if streq(path, VIDEO_CORE_HOST_SHADERS_FSR_FFX_A_PATH) == 1:
        return "FFX_A_H"
    if streq(path, VIDEO_CORE_HOST_SHADERS_FSR_FFX_FSR1_PATH) == 1:
        return "FFX_FSR1_H"
    return ""
