include "./region_definitions.elisa"
include "./region_manager.elisa"

const MEMORY_TRACKER_MAX_CPU_PAGE_BITS: u64 = 40
const MEMORY_TRACKER_NUM_HIGH_PAGES: u64 = 1 << (MEMORY_TRACKER_MAX_CPU_PAGE_BITS - TRACKER_HIGHER_PAGE_BITS)

struct MemoryTrackerRegionEntry:
    page_index: mutable u64
    manager: mutable RegionManager

struct MemoryTracker:
    owner: mutable Arena&?
    top_tier: mutable darray[MemoryTrackerRegionEntry]

def MemoryTracker_New(owner: mutable Arena&) -> MemoryTracker:
    out: mutable MemoryTracker = zeroed
    out.owner as & <- owner
    return out

def MemoryTracker_FindRegionIndex(self: MemoryTracker&, page_index: u64) -> i64:
    i: mutable usize = 0
    while i < self.top_tier.count:
        if self.top_tier[i].page_index == page_index:
            return i.i64()
        i <- i + 1
    return -1

def MemoryTracker_FindRegion(self: mutable MemoryTracker&, page_index: u64) -> mutable RegionManager&?:
    idx: i64 = MemoryTracker_FindRegionIndex((&self).cast[MemoryTracker&], page_index)
    if idx < 0:
        return null
    return &self.top_tier[idx.usize()].manager

def MemoryTracker_CreateRegion(self: mutable MemoryTracker&, page_index: u64) -> mutable RegionManager&?:
    can Memory.Allocate, Abort.Panic:
        existing: mutable RegionManager&? = MemoryTracker_FindRegion(self, page_index)
        if existing != null:
            return existing
        if page_index >= MEMORY_TRACKER_NUM_HIGH_PAGES:
            return null
        assert self.owner != null
        owner: mutable Arena& = self.owner
        base_cpu_addr: u64 = page_index << TRACKER_HIGHER_PAGE_BITS
        manager: RegionManager = RegionManager_New(base_cpu_addr)
        in owner:
            self.top_tier.push(MemoryTrackerRegionEntry(page_index, manager))
        return &self.top_tier[self.top_tier.count - 1].manager

def MemoryTracker_IsRangeValid(cpu_addr: u64, size: u64) -> bool:
    if size == 0:
        return false
    max_space: u64 = 1 << MEMORY_TRACKER_MAX_CPU_PAGE_BITS
    if cpu_addr >= max_space:
        return false
    if size > max_space - cpu_addr:
        return false
    return true

def MemoryTracker_ClampSize(cpu_addr: u64, size: u64) -> u64:
    max_space: u64 = 1 << MEMORY_TRACKER_MAX_CPU_PAGE_BITS
    if cpu_addr >= max_space:
        return 0
    if size > max_space - cpu_addr:
        return max_space - cpu_addr
    return size

def MemoryTracker_IsRegionCpuModified(self: mutable MemoryTracker&, query_cpu_addr: u64, query_size: u64) -> bool:
    if query_size == 0:
        return false
    size: u64 = MemoryTracker_ClampSize(query_cpu_addr, query_size)
    if size == 0:
        return false
    remaining_size: mutable u64 = size
    page_index: mutable u64 = query_cpu_addr >> TRACKER_HIGHER_PAGE_BITS
    page_offset: mutable u64 = query_cpu_addr & TRACKER_HIGHER_PAGE_MASK
    while remaining_size > 0:
        copy_amount: mutable u64 = TRACKER_HIGHER_PAGE_SIZE - page_offset
        if copy_amount > remaining_size:
            copy_amount <- remaining_size
        manager: mutable RegionManager&? = MemoryTracker_FindRegion(self, page_index)
        if manager != null and RegionManager_IsRegionModified((&manager).cast[RegionManager&], REGION_TYPE_CPU, page_offset, copy_amount):
            return true
        page_index <- page_index + 1
        page_offset <- 0
        remaining_size <- remaining_size - copy_amount
    return false

def MemoryTracker_IsRegionGpuModified(self: mutable MemoryTracker&, query_cpu_addr: u64, query_size: u64) -> bool:
    if query_size == 0:
        return false
    size: u64 = MemoryTracker_ClampSize(query_cpu_addr, query_size)
    if size == 0:
        return false
    remaining_size: mutable u64 = size
    page_index: mutable u64 = query_cpu_addr >> TRACKER_HIGHER_PAGE_BITS
    page_offset: mutable u64 = query_cpu_addr & TRACKER_HIGHER_PAGE_MASK
    while remaining_size > 0:
        copy_amount: mutable u64 = TRACKER_HIGHER_PAGE_SIZE - page_offset
        if copy_amount > remaining_size:
            copy_amount <- remaining_size
        manager: mutable RegionManager&? = MemoryTracker_FindRegion(self, page_index)
        if manager != null and RegionManager_IsRegionModified((&manager).cast[RegionManager&], REGION_TYPE_GPU, page_offset, copy_amount):
            return true
        page_index <- page_index + 1
        page_offset <- 0
        remaining_size <- remaining_size - copy_amount
    return false

def MemoryTracker_MarkRegionAsCpuModified(self: mutable MemoryTracker&, dirty_cpu_addr: u64, query_size: u64) -> void:
    can Memory.Allocate, Abort.Panic:
        size: u64 = MemoryTracker_ClampSize(dirty_cpu_addr, query_size)
        if size == 0:
            return
        remaining_size: mutable u64 = size
        page_index: mutable u64 = dirty_cpu_addr >> TRACKER_HIGHER_PAGE_BITS
        page_offset: mutable u64 = dirty_cpu_addr & TRACKER_HIGHER_PAGE_MASK
        while remaining_size > 0:
            copy_amount: mutable u64 = TRACKER_HIGHER_PAGE_SIZE - page_offset
            if copy_amount > remaining_size:
                copy_amount <- remaining_size
            manager: mutable RegionManager&? = MemoryTracker_CreateRegion(self, page_index)
            if manager != null:
                RegionManager_ChangeRegionState(manager, REGION_TYPE_CPU, true, manager.cpu_addr + page_offset, copy_amount)
            page_index <- page_index + 1
            page_offset <- 0
            remaining_size <- remaining_size - copy_amount

def MemoryTracker_UnmarkRegionAsGpuModified(self: mutable MemoryTracker&, dirty_cpu_addr: u64, query_size: u64) -> void:
    size: u64 = MemoryTracker_ClampSize(dirty_cpu_addr, query_size)
    if size == 0:
        return
    remaining_size: mutable u64 = size
    page_index: mutable u64 = dirty_cpu_addr >> TRACKER_HIGHER_PAGE_BITS
    page_offset: mutable u64 = dirty_cpu_addr & TRACKER_HIGHER_PAGE_MASK
    while remaining_size > 0:
        copy_amount: mutable u64 = TRACKER_HIGHER_PAGE_SIZE - page_offset
        if copy_amount > remaining_size:
            copy_amount <- remaining_size
        manager: mutable RegionManager&? = MemoryTracker_FindRegion(self, page_index)
        if manager != null:
            RegionManager_ChangeRegionState(manager, REGION_TYPE_GPU, false, manager.cpu_addr + page_offset, copy_amount)
        page_index <- page_index + 1
        page_offset <- 0
        remaining_size <- remaining_size - copy_amount
