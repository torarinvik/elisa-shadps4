const TRACKER_PAGE_BITS: u64 = 12u64
const TRACKER_BYTES_PER_PAGE: u64 = 1u64 << TRACKER_PAGE_BITS

const TRACKER_HIGHER_PAGE_BITS: u64 = 22u64
const TRACKER_HIGHER_PAGE_SIZE: u64 = 1u64 << TRACKER_HIGHER_PAGE_BITS
const TRACKER_HIGHER_PAGE_MASK: u64 = TRACKER_HIGHER_PAGE_SIZE - 1u64
const NUM_PAGES_PER_REGION: u64 = TRACKER_HIGHER_PAGE_SIZE / TRACKER_BYTES_PER_PAGE

const REGION_TYPE_CPU: u32 = 0u32
const REGION_TYPE_GPU: u32 = 1u32

const REGION_BITS_WORD_BITS: u64 = 64u64
const REGION_BITS_WORD_COUNT: u64 = NUM_PAGES_PER_REGION / REGION_BITS_WORD_BITS

struct RegionBits:
    words: mutable u64[16]

def RegionBits_Clear(bits: mutable RegionBits&) -> void:
    i: mutable u64 = 0u64
    while i < REGION_BITS_WORD_COUNT:
        bits.words[i.usize()] <- 0u64
        i <- i + 1u64

def RegionBits_Fill(bits: mutable RegionBits&) -> void:
    i: mutable u64 = 0u64
    while i < REGION_BITS_WORD_COUNT:
        bits.words[i.usize()] <- 0xffffffffffffffffu64
        i <- i + 1u64

def RegionBits_IsSet(bits: RegionBits&, index: u64) -> bool:
    if index >= NUM_PAGES_PER_REGION:
        return false
    word_index: u64 = index / REGION_BITS_WORD_BITS
    bit_index: u64 = index % REGION_BITS_WORD_BITS
    return ((bits.words[word_index.usize()] >> bit_index) & 1u64) == 1u64

def RegionBits_Set(bits: mutable RegionBits&, index: u64) -> void:
    if index >= NUM_PAGES_PER_REGION:
        return
    word_index: u64 = index / REGION_BITS_WORD_BITS
    bit_index: u64 = index % REGION_BITS_WORD_BITS
    bits.words[word_index.usize()] <- bits.words[word_index.usize()] | (1u64 << bit_index)

def RegionBits_Unset(bits: mutable RegionBits&, index: u64) -> void:
    if index >= NUM_PAGES_PER_REGION:
        return
    word_index: u64 = index / REGION_BITS_WORD_BITS
    bit_index: u64 = index % REGION_BITS_WORD_BITS
    bits.words[word_index.usize()] <- bits.words[word_index.usize()] & ~(1u64 << bit_index)

def RegionBits_SetRange(bits: mutable RegionBits&, start_page: u64, end_page: u64) -> void:
    if end_page <= start_page:
        return
    page: mutable u64 = start_page
    while page < end_page and page < NUM_PAGES_PER_REGION:
        RegionBits_Set(bits, page)
        page <- page + 1u64

def RegionBits_UnsetRange(bits: mutable RegionBits&, start_page: u64, end_page: u64) -> void:
    if end_page <= start_page:
        return
    page: mutable u64 = start_page
    while page < end_page and page < NUM_PAGES_PER_REGION:
        RegionBits_Unset(bits, page)
        page <- page + 1u64

def RegionBits_Any(bits: RegionBits&) -> bool:
    i: mutable u64 = 0u64
    while i < REGION_BITS_WORD_COUNT:
        if bits.words[i.usize()] != 0u64:
            return true
        i <- i + 1u64
    return false

def RegionBits_None(bits: RegionBits&) -> bool:
    return not RegionBits_Any(bits)

def RegionBits_CopyRange(bits: RegionBits&, start_page: u64, end_page: u64) -> RegionBits:
    out: mutable RegionBits = zeroed
    RegionBits_Clear(out.ref[mutable RegionBits&])
    if end_page <= start_page:
        return out
    page: mutable u64 = start_page
    while page < end_page and page < NUM_PAGES_PER_REGION:
        if RegionBits_IsSet(bits, page):
            RegionBits_Set(out.ref[mutable RegionBits&], page)
        page <- page + 1u64
    return out
