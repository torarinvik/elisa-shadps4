include "../compiler/runtime/elisacore_std/elisacore_runtime.elisa"
include "./core/libraries/web_browser_dialog/webbrowserdialog.elisa"

def web_browser_dialog_reset_for_tests() -> void:
    g_isInitialized <- false
    g_isUsed <- false
    g_web_browser_dialog_status <- ORBIS_COMMON_DIALOG_STATUS_NONE

@test
def web_browser_dialog_cpp_parity_lifecycle() -> void:
    can Abort.Panic:
        web_browser_dialog_reset_for_tests()

        assert sceWebBrowserDialogInitialize() == ORBIS_COMMON_DIALOG_ERROR_NOT_SYSTEM_INITIALIZED
        assert sceWebBrowserDialogOpen() == ORBIS_COMMON_DIALOG_ERROR_INVALID_STATE
        assert sceWebBrowserDialogClose() == ORBIS_COMMON_DIALOG_ERROR_NOT_RUNNING
        assert sceWebBrowserDialogTerminate() == ORBIS_COMMON_DIALOG_ERROR_NOT_INITIALIZED

        g_isInitialized <- true
        assert sceWebBrowserDialogInitialize() == ORBIS_OK
        assert sceWebBrowserDialogGetStatus() == ORBIS_COMMON_DIALOG_STATUS_INITIALIZED
        assert g_isUsed == true

        assert sceWebBrowserDialogInitialize() == ORBIS_COMMON_DIALOG_ERROR_ALREADY_INITIALIZED

        assert sceWebBrowserDialogOpen() == ORBIS_OK
        assert sceWebBrowserDialogGetStatus() == ORBIS_COMMON_DIALOG_STATUS_RUNNING
        assert sceWebBrowserDialogClose() == ORBIS_OK
        assert sceWebBrowserDialogGetStatus() == ORBIS_COMMON_DIALOG_STATUS_RUNNING

        assert sceWebBrowserDialogUpdateStatus() == ORBIS_COMMON_DIALOG_STATUS_FINISHED
        assert sceWebBrowserDialogGetStatus() == ORBIS_COMMON_DIALOG_STATUS_FINISHED

        assert sceWebBrowserDialogOpen() == ORBIS_OK
        assert sceWebBrowserDialogGetStatus() == ORBIS_COMMON_DIALOG_STATUS_RUNNING
        assert sceWebBrowserDialogTerminate() == ORBIS_OK
        assert sceWebBrowserDialogGetStatus() == ORBIS_COMMON_DIALOG_STATUS_NONE
        assert g_isUsed == false

@test
def web_browser_dialog_cpp_parity_busy_and_stubs() -> void:
    can Abort.Panic:
        web_browser_dialog_reset_for_tests()
        g_isInitialized <- true
        g_isUsed <- true
        assert sceWebBrowserDialogInitialize() == ORBIS_COMMON_DIALOG_ERROR_BUSY

        assert sceWebBrowserDialogGetEvent() == ORBIS_OK
        assert sceWebBrowserDialogGetResult() == ORBIS_OK
        assert sceWebBrowserDialogNavigate() == ORBIS_OK
        assert sceWebBrowserDialogOpenForPredeterminedContent() == ORBIS_OK
        assert sceWebBrowserDialogResetCookie() == ORBIS_OK
        assert sceWebBrowserDialogSetCookie() == ORBIS_OK
        assert sceWebBrowserDialogSetZoom() == ORBIS_OK
        assert Func_F2BE042771625F8C() == ORBIS_OK
