include "../compiler/runtime/elisacore_std/elisacore_runtime.elisa"
include "./core/libraries/signin_dialog/signin_dialog.elisa"

@test
def signin_dialog_stub_contracts() -> void:
    can Abort.Panic:
        assert sceSigninDialogInitialize() == ORBIS_OK
        assert sceSigninDialogOpen() == ORBIS_OK
        assert sceSigninDialogGetStatus() == SIGNIN_DIALOG_STATUS_FINISHED
        assert sceSigninDialogUpdateStatus() == SIGNIN_DIALOG_STATUS_FINISHED
        assert sceSigninDialogGetResult() == ORBIS_OK
        assert sceSigninDialogClose() == ORBIS_OK
        assert sceSigninDialogTerminate() == ORBIS_OK
