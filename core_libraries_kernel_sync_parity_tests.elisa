include "./core_libraries_kernel_sync_integration.elisa"

@test
def timed_mutex_basic() -> void:
    can Abort.Panic:
        mtx: mutable TimedMutex = TimedMutex_new()
        assert TimedMutex_try_lock(mtx.ref[mutable TimedMutex&])
        assert not TimedMutex_try_lock(mtx.ref[mutable TimedMutex&])
        TimedMutex_unlock(mtx.ref[mutable TimedMutex&])
        assert TimedMutex_try_lock_for(mtx.ref[mutable TimedMutex&], 1000000)
        TimedMutex_unlock(mtx.ref[mutable TimedMutex&])
        TimedMutex_lock(mtx.ref[mutable TimedMutex&])
        assert not TimedMutex_try_lock_until(mtx.ref[mutable TimedMutex&], 123456789)

@test
def semaphore_basic() -> void:
    can Abort.Panic:
        sem: mutable Semaphore = Semaphore_new(1, 3)
        assert Semaphore_try_acquire(sem.ref[mutable Semaphore&])
        assert not Semaphore_try_acquire(sem.ref[mutable Semaphore&])

        Semaphore_release(sem.ref[mutable Semaphore&])
        Semaphore_acquire(sem.ref[mutable Semaphore&])
        assert sem.count == 0

        Semaphore_release(sem.ref[mutable Semaphore&])
        Semaphore_release(sem.ref[mutable Semaphore&])
        Semaphore_release(sem.ref[mutable Semaphore&])
        Semaphore_release(sem.ref[mutable Semaphore&])
        assert sem.count == 3

@test
def binary_and_counting_aliases() -> void:
    can Abort.Panic:
        b: mutable BinarySemaphore = BinarySemaphore_new(0)
        assert not Semaphore_try_acquire(b.ref[mutable Semaphore&])
        Semaphore_release(b.ref[mutable Semaphore&])
        Semaphore_release(b.ref[mutable Semaphore&])
        assert b.count == 1

        c: mutable CountingSemaphore = CountingSemaphore_new(2)
        assert c.max_count == ORBIS_KERNEL_SEM_VALUE_MAX
        assert Semaphore_try_acquire_for(c.ref[mutable Semaphore&], 1)
        assert Semaphore_try_acquire_until(c.ref[mutable Semaphore&], 1)
        assert not Semaphore_try_acquire(c.ref[mutable Semaphore&])
