include "../compiler/runtime/elisacore_std/elisacore_runtime.elisa"
include "./video_core/host_shaders/fsr/fsr.elisa"

@test
def host_shader_fsr_manifest_matches_cpp_generation_inputs() -> void:
    can Abort.Panic:
        source: HostShaderFsrAssetInfo = HostShaderFsr_SourceInfo()
        assert streq(source.path, "fsr.comp") == 1
        assert streq(source.generated_symbol, "FSR_COMP") == 1
        assert source.source_bytes == 3249
        assert source.source_lines == 90
        assert source.byte_sum == 0x0003f2be

        ffx_a: HostShaderFsrAssetInfo = HostShaderFsr_FfxAInfo()
        assert streq(ffx_a.path, "fsr/ffx_a.h") == 1
        assert streq(ffx_a.generated_symbol, "FFX_A_H") == 1
        assert ffx_a.source_bytes == 181935
        assert ffx_a.source_lines == 2657
        assert ffx_a.byte_sum == 0x00b28066

        ffx_fsr1: HostShaderFsrAssetInfo = HostShaderFsr_FfxFsr1Info()
        assert streq(ffx_fsr1.path, "fsr/ffx_fsr1.h") == 1
        assert streq(ffx_fsr1.generated_symbol, "FFX_FSR1_H") == 1
        assert ffx_fsr1.source_bytes == 60330
        assert ffx_fsr1.source_lines == 1200
        assert ffx_fsr1.byte_sum == 0x003fdd3d

@test
def host_shader_fsr_include_resolution_matches_cmake_generator() -> void:
    can Abort.Panic:
        assert HostShaderFsr_IsFsrInclude("fsr/ffx_a.h")
        assert HostShaderFsr_IsFsrInclude("fsr/ffx_fsr1.h")
        assert not HostShaderFsr_IsFsrInclude("missing.h")
        assert streq(HostShaderFsr_ResolveInclude("fsr/ffx_a.h"), "fsr/ffx_a.h") == 1
        assert streq(HostShaderFsr_ResolveInclude("fsr/ffx_fsr1.h"), "fsr/ffx_fsr1.h") == 1
        assert streq(HostShaderFsr_ResolveInclude("missing.h"), "") == 1
        assert streq(HostShaderFsr_GeneratedHeaderName("fsr.comp"), "FSR_COMP") == 1
        assert streq(HostShaderFsr_GeneratedHeaderName("fsr/ffx_a.h"), "FFX_A_H") == 1
        assert streq(HostShaderFsr_GeneratedHeaderName("fsr/ffx_fsr1.h"), "FFX_FSR1_H") == 1

@test
def host_shader_fsr_expanded_shape_matches_recursive_include_output() -> void:
    can Abort.Panic:
        assert HostShaderFsr_ExpandedBytes() == 245467
        assert HostShaderFsr_ExpandedLines() == 3947
        assert HostShaderFsr_ExpandedByteSum() == 0x00f64048
