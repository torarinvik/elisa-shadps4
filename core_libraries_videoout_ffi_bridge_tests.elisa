include "../compiler/runtime/elisacore_std/elisacore_runtime.elisa"
include "./core/libraries/videoout/videoout.elisa"
include "./core/libraries/videoout/videoout_error.elisa"

@test
def videoout_ffi_bridge_error_contracts() -> void:
    can Abort.Panic:
        flip_status_buf: mutable array[u8, 128] = zeroed
        mode_buf: mutable array[u8, 64] = zeroed
        color_buf: mutable array[u8, 64] = zeroed

        assert sceVideoOutGetFlipStatus(0, null) == ORBIS_VIDEO_OUT_ERROR_INVALID_ADDRESS
        assert sceVideoOutGetFlipStatus(0, flip_status_buf[0].ref[mutable u8&].cast[void&?]) == ORBIS_VIDEO_OUT_ERROR_INVALID_HANDLE

        assert sceVideoOutOpen(0, 0, 1, null) == ORBIS_VIDEO_OUT_ERROR_INVALID_VALUE

        assert sceVideoOutGetEventId(null) == ORBIS_VIDEO_OUT_ERROR_INVALID_ADDRESS
        assert sceVideoOutGetEventData(null, null) == ORBIS_VIDEO_OUT_ERROR_INVALID_ADDRESS
        assert sceVideoOutGetEventCount(null) == ORBIS_VIDEO_OUT_ERROR_INVALID_ADDRESS

        assert sceVideoOutColorSettingsSetGamma(color_buf[0].ref[mutable u8&].cast[void&?], 0.05) == ORBIS_VIDEO_OUT_ERROR_INVALID_VALUE
        assert sceVideoOutColorSettingsSetGamma(color_buf[0].ref[mutable u8&].cast[void&?], 1.0) == ORBIS_OK

        sceVideoOutSetBufferAttribute(null, 0, 0, 0, 0, 0, 0)
        sceVideoOutModeSetAny_(mode_buf[0].ref[mutable u8&].cast[void&?], 64)

@test
def videoout_ffi_bridge_remaining_exports() -> void:
    can Abort.Panic:
        res_buf: mutable array[u8, 128] = zeroed
        cap_buf: mutable array[u8, 128] = zeroed
        attr_buf: mutable array[u8, 128] = zeroed
        label_addr: mutable i64 = 0

        assert sceVideoOutAddFlipEvent(-1, 0, null) == ORBIS_VIDEO_OUT_ERROR_INVALID_HANDLE
        assert sceVideoOutAddVblankEvent(-1, 0, null) == ORBIS_VIDEO_OUT_ERROR_INVALID_HANDLE
        assert sceVideoOutSetFlipRate(-1, 0) == ORBIS_VIDEO_OUT_ERROR_INVALID_HANDLE
        assert sceVideoOutSubmitFlip(-1, 0, 0, 0) == ORBIS_VIDEO_OUT_ERROR_INVALID_HANDLE
        assert sceVideoOutRegisterBuffers(-1, 0, null, 0, null) == ORBIS_VIDEO_OUT_ERROR_INVALID_ADDRESS

        assert sceVideoOutGetResolutionStatus(-1, null) == ORBIS_VIDEO_OUT_ERROR_INVALID_HANDLE
        assert sceVideoOutIsFlipPending(-1) == ORBIS_VIDEO_OUT_ERROR_INVALID_HANDLE
        assert sceVideoOutUnregisterBuffers(-1, 0) == ORBIS_VIDEO_OUT_ERROR_INVALID_HANDLE
        assert sceVideoOutClose(-1) == ORBIS_VIDEO_OUT_ERROR_INVALID_HANDLE

        assert sceVideoOutGetBufferLabelAddress(-1, null) == ORBIS_VIDEO_OUT_ERROR_INVALID_ADDRESS
        assert sceVideoOutGetBufferLabelAddress(-1, label_addr.ref[mutable i64&].cast[void&?]) == ORBIS_VIDEO_OUT_ERROR_INVALID_HANDLE

        assert sceVideoOutGetVblankStatus(-1, null) == ORBIS_VIDEO_OUT_ERROR_INVALID_ADDRESS
        assert sceVideoOutGetVblankStatus(-1, res_buf[0].ref[mutable u8&].cast[void&?]) == ORBIS_VIDEO_OUT_ERROR_INVALID_HANDLE

        assert sceVideoOutGetDeviceCapabilityInfo(-1, cap_buf[0].ref[mutable u8&].cast[void&?]) == ORBIS_OK
        assert sceVideoOutWaitVblank(-1) == ORBIS_VIDEO_OUT_ERROR_INVALID_HANDLE

        assert sceVideoOutAdjustColor(-1, null) == ORBIS_VIDEO_OUT_ERROR_INVALID_ADDRESS
        assert sceVideoOutAdjustColor(-1, res_buf[0].ref[mutable u8&].cast[void&?]) == ORBIS_VIDEO_OUT_ERROR_INVALID_HANDLE

        assert sceVideoOutDeleteFlipEvent(-1, 0) == ORBIS_VIDEO_OUT_ERROR_INVALID_HANDLE
        assert sceVideoOutDeleteVblankEvent(-1, 0) == ORBIS_VIDEO_OUT_ERROR_INVALID_HANDLE

        assert sceVideoOutConfigureOutputMode_(-1, 0, null, null, 0, 0) == ORBIS_VIDEO_OUT_ERROR_INVALID_HANDLE
        assert sceVideoOutSubmitChangeBufferAttribute(-1, 0, attr_buf[0].ref[mutable u8&].cast[void&?]) == ORBIS_VIDEO_OUT_ERROR_INVALID_HANDLE

@test
def videoout_native_lifecycle_vblank_and_labels() -> void:
    can Abort.Panic:
        _ = sceVideoOutClose(1)

        handle: int = sceVideoOutOpen(0, 0, 0, null)
        assert handle == 1
        assert sceVideoOutSetFlipRate(handle.i64(), 0) == ORBIS_OK

        attr: mutable VideoOutBufferAttribute = zeroed
        sceVideoOutSetBufferAttribute(attr.ref[mutable VideoOutBufferAttribute&].cast[void&?], 0x80000000, 0, 0, 64, 64, 64)

        frame_buffer: mutable array[u8, 256] = zeroed
        addresses: mutable array[u64, 1] = zeroed
        addresses[0] <- frame_buffer[0].ref[mutable u8&].cast[u64]

        group_index: int = sceVideoOutRegisterBuffers(
            handle.i64(),
            0,
            addresses[0].ref[mutable u64&].cast[void&?],
            1,
            attr.ref[mutable VideoOutBufferAttribute&].cast[void&?]
        )
        assert group_index == 0

        assert sceVideoOutSubmitFlip(handle.i64(), 0, 1, 0x1234) == ORBIS_OK
        assert g_videoout_artifact_opened_emitted
        assert g_videoout_artifact_buffers_registered_emitted
        assert g_videoout_artifact_first_flip_emitted
        assert sceVideoOutIsFlipPending(handle.i64()) >= 1
        assert sceVideoOutWaitVblank(handle.i64()) == ORBIS_OK
        assert sceVideoOutIsFlipPending(handle.i64()) == 0
        assert g_videoout_artifact_flip_completed_emitted
        assert g_videoout_artifact_first_frame_candidate_emitted
        assert g_videoout_buffer_labels[0] == 1u64

        flip_status: mutable FlipStatus = zeroed
        assert sceVideoOutGetFlipStatus(handle.i64(), flip_status.ref[mutable FlipStatus&].cast[void&?]) == ORBIS_OK
        assert flip_status.count >= 1u64
        assert flip_status.current_buffer == 0

        vblank_status: mutable SceVideoOutVblankStatus = zeroed
        assert sceVideoOutGetVblankStatus(handle.i64(), vblank_status.ref[mutable SceVideoOutVblankStatus&].cast[void&?]) == ORBIS_OK
        assert vblank_status.count >= 1u64

        label_addr: mutable i64 = 0
        assert sceVideoOutGetBufferLabelAddress(handle.i64(), label_addr.ref[mutable i64&].cast[void&?]) == 16
        assert label_addr != 0
        labels: mutable u64& = label_addr.cast[mutable u64&]
        assert labels[0] == 1u64

        changed_attr: mutable VideoOutBufferAttribute = zeroed
        sceVideoOutSetBufferAttribute(changed_attr.ref[mutable VideoOutBufferAttribute&].cast[void&?], 0x80000000, 0, 0, 64, 64, 128)
        assert sceVideoOutSubmitChangeBufferAttribute(handle.i64(), group_index.i64(), changed_attr.ref[mutable VideoOutBufferAttribute&].cast[void&?]) == ORBIS_OK

        assert sceVideoOutUnregisterBuffers(handle.i64(), group_index.i64()) == ORBIS_OK
        assert sceVideoOutClose(handle.i64()) == ORBIS_OK

@test
def videoout_native_queue_full_contract() -> void:
    can Abort.Panic:
        _ = sceVideoOutClose(1)

        handle: int = sceVideoOutOpen(0, 0, 0, null)
        assert handle == 1

        attr: mutable VideoOutBufferAttribute = zeroed
        sceVideoOutSetBufferAttribute(attr.ref[mutable VideoOutBufferAttribute&].cast[void&?], 0x80000000, 0, 0, 64, 64, 64)

        frame_buffer: mutable array[u8, 256] = zeroed
        addresses: mutable array[u64, 1] = zeroed
        addresses[0] <- frame_buffer[0].ref[mutable u8&].cast[u64]

        assert sceVideoOutRegisterBuffers(
            handle.i64(),
            0,
            addresses[0].ref[mutable u64&].cast[void&?],
            1,
            attr.ref[mutable VideoOutBufferAttribute&].cast[void&?]
        ) == 0

        i: mutable int = 0
        while i < 17:
            assert sceVideoOutSubmitFlip(handle.i64(), 0, 1, i.i64()) == ORBIS_OK
            i <- i + 1
        assert sceVideoOutSubmitFlip(handle.i64(), 0, 1, 99) == ORBIS_VIDEO_OUT_ERROR_FLIP_QUEUE_FULL

        assert sceVideoOutClose(handle.i64()) == ORBIS_OK
