@test
def devtools_gcn_opcode_names_match_cpp_switch() -> void:
    can Abort.Panic:
        assert Devtools_Gcn_GetOpCodeName(IT_NOP) == "IT_NOP"
        assert Devtools_Gcn_GetOpCodeName(IT_DRAW_INDEX_2) == "IT_DRAW_INDEX_2"
        assert Devtools_Gcn_GetOpCodeName(IT_DMA_DATA__CI__VI) == "IT_DMA_DATA"
        assert Devtools_Gcn_GetOpCodeName(0xFF) == "<STUB (TMP)>"
        assert Devtools_Gcn_GetOpCodeName(0xDEAD) == "<UNK>"

@test
def devtools_gcn_register_names_match_cpp_switches() -> void:
    can Abort.Panic:
        assert Devtools_Gcn_GetShaderRegName(mmSPI_SHADER_PGM_LO_VS) == "mmSPI_SHADER_PGM_LO_VS"
        assert Devtools_Gcn_GetShaderRegName(mmCOMPUTE_USER_DATA_15) == "mmCOMPUTE_USER_DATA_15"
        assert Devtools_Gcn_GetShaderRegName(0xDEAD) == "<UNK>"
        assert Devtools_Gcn_GetContextRegName(mmDB_SHADER_CONTROL) == "mmDB_SHADER_CONTROL"
        assert Devtools_Gcn_GetContextRegName(mmPA_SU_POLY_OFFSET_CLAMP) == "mmPA_SU_POLY_OFFSET_CLAMP"
        assert Devtools_Gcn_GetContextRegName(0xDEAD) == "<UNK>"

@test
def devtools_widget_draw_call_classification_matches_cpp_switch() -> void:
    can Abort.Panic:
        header: Devtools_Widget_PM4Header = Devtools_Widget_PM4HeaderFromU32(0xc0010000)
        assert header.type == 3
        assert header.count == 1
        assert Devtools_Widget_PM4HeaderToU32(header) == 0xc0010000
        assert Devtools_Widget_IsDrawCall(PM4ItOpcode_DrawIndex2)
        assert Devtools_Widget_IsDrawCall(PM4ItOpcode_DrawIndexOffset2)
        assert Devtools_Widget_IsDrawCall(PM4ItOpcode_DrawIndexAuto)
        assert Devtools_Widget_IsDrawCall(PM4ItOpcode_DrawIndirect)
        assert Devtools_Widget_IsDrawCall(PM4ItOpcode_DrawIndexIndirect)
        assert Devtools_Widget_IsDrawCall(PM4ItOpcode_DispatchDirect)
        assert Devtools_Widget_IsDrawCall(PM4ItOpcode_DispatchIndirect)
        assert not Devtools_Widget_IsDrawCall(PM4ItOpcode_Nop)

@test
def devtools_options_parse_and_serialize_config_lines() -> void:
    can Abort.Panic, Memory.Allocate:
        Devtools_LoadOptionsConfig("disassembler_cli_isa=my-isa {src}")
        Devtools_LoadOptionsConfig("disassembler_cli_spv=my-spv {src}")
        Devtools_LoadOptionsConfig("frame_dump_render_on_collapse=1")
        options: DevtoolsOptions = Devtools_GetOptions()
        assert string_slice_eq(options.disassembler_cli_isa, 0, runtime_strlen("my-isa {src}"), "my-isa {src}") == 1
        assert string_slice_eq(options.disassembler_cli_spv, 0, runtime_strlen("my-spv {src}"), "my-spv {src}") == 1
        assert options.frame_dump_render_on_collapse
        serialized: static u8& = Devtools_SerializeOptionsConfig()
        assert Devtools_StringStartsWith(serialized, "disassembler_cli_isa=my-isa {src}\n")

@test
def devtools_widget_memory_and_frame_helpers_match_cpp_defaults() -> void:
    can Abort.Panic:
        editor: mutable Devtools_Widget_MemoryEditor = Devtools_Widget_MemoryEditor_New()
        assert editor.Open
        assert editor.Cols == 16
        assert editor.OptShowAscii
        assert Devtools_Widget_MemoryEditor_CalcAddrDigits(editor, 0x1000, 0) == 3
        Devtools_Widget_MemoryEditor_GotoAddrAndHighlight(editor, 4, 7)
        assert editor.GotoAddr == 4
        assert editor.HighlightMax == 7

        graph: mutable Devtools_Widget_FrameGraph = Devtools_Widget_FrameGraph_New()
        Devtools_Widget_FrameGraph_AddFrame(graph, 1025, 0.016)
        assert Devtools_Widget_FrameGraph_GetFrame(graph, 1).num == 1025
        Devtools_Widget_FrameGraph_UpdateStats(graph, 20.0)
        assert graph.frameRate == 50.0

@test
def devtools_widget_text_and_shader_helpers_keep_editor_state() -> void:
    can Abort.Panic, Memory.Allocate:
        editor: mutable Devtools_Widget_TextEditor = Devtools_Widget_TextEditor_New()
        Devtools_Widget_TextEditor_SetText(editor, "a\nb")
        assert Devtools_Widget_TextEditor_GetTotalLines(editor) == 2
        Devtools_Widget_TextEditor_InsertText(editor, "\nc")
        assert Devtools_Widget_TextEditor_GetTotalLines(editor) == 3
        Devtools_Widget_TextEditor_SelectAll(editor)
        assert Devtools_Widget_TextEditor_HasSelection(editor)

        selection: mutable Devtools_Widget_ShaderSelection = Devtools_Widget_ShaderSelection_New(7)
        Devtools_Widget_ShaderSelection_ReloadShader(selection, "OpCapability Shader", "void main() {}")
        assert selection.index == 7
        assert selection.open
        assert streq(selection.isa_editor.language_name, "SPIR-V") == 1

@test
def devtools_widget_module_and_cmd_config_helpers_are_elisa_owned() -> void:
    can Abort.Panic, Memory.Allocate:
        assert streq(Devtools_Widget_NormalizePrxName("libSceFoo"), "libSceFoo.prx") == 1
        assert Devtools_Widget_IsSystemModulePath("/sys/libSceFoo.prx", "/sys")
        before: usize = Devtools_Widget_ModuleCount()
        Devtools_Widget_AddModuleName("libSceFoo", false)
        assert Devtools_Widget_ModuleCount() == before + 1
        assert Devtools_Widget_ModuleAt(before).is_sys_module

        Devtools_Widget_CmdList_LoadConfig("cmd_list_group_batches=0")
        Devtools_Widget_CmdList_LoadConfig("cmd_list_show_markers=1")
        assert not Devtools_Widget_CmdListGroupBatches
        assert Devtools_Widget_CmdListShowMarkers
        serialized: static u8& = Devtools_Widget_CmdList_SerializeConfig()
        assert Devtools_StringStartsWith(serialized, "cmd_list_group_batches=0\n")

        viewer: mutable Devtools_Widget_CmdListViewer = Devtools_Widget_CmdList_New(0x1000.uintptr(), "test")
        batch: Devtools_Widget_BatchInfo = Devtools_Widget_BatchInfo(1, "marker", 0, 4, 0x1000, PM4ItOpcode_DrawIndex2, false)
        Devtools_Widget_CmdList_AddBatch(viewer, batch)
        assert viewer.events.count == 1
