include "../compiler/runtime/elisacore_std/elisacore_runtime.elisa"
include "./core/libraries/error_codes.elisa"
include "./core/libraries/hmd/hmd_error.elisa"
include "./core/libraries/hmd/hmd.elisa"
include "./core/libraries/hmd/hmd_setup_dialog.elisa"

def hmd_make_init_param(reserved0: void&?) -> OrbisHmdInitializeParam:
    out: mutable OrbisHmdInitializeParam = zeroed
    out.reserved0 <- reserved0
    return out

@test
def hmd_open_close_lifecycle() -> void:
    can Abort.Panic:
        init_param: OrbisHmdInitializeParam = hmd_make_init_param(null)
        assert sceHmdInitialize(init_param.ref[OrbisHmdInitializeParam&]) == ORBIS_OK
        handle: s32 = sceHmdOpen(1, 0, 0, null)
        assert handle > 0
        assert sceHmdClose(handle) == ORBIS_OK
        assert sceHmdTerminate() == ORBIS_OK

@test
def hmd_validation_paths() -> void:
    can Abort.Panic:
        assert sceHmdOpen(1, 0, 0, null) == ORBIS_HMD_ERROR_NOT_INITIALIZED
        init_param: OrbisHmdInitializeParam = hmd_make_init_param(null)
        assert sceHmdInitialize(init_param.ref[OrbisHmdInitializeParam&]) == ORBIS_OK
        assert sceHmdInitialize(init_param.ref[OrbisHmdInitializeParam&]) == ORBIS_HMD_ERROR_ALREADY_INITIALIZED
        assert sceHmdOpen(-1, 0, 0, null) == ORBIS_HMD_ERROR_PARAMETER_INVALID
        assert sceHmdOpen(255, 0, 0, null) == ORBIS_HMD_ERROR_PARAMETER_INVALID
        assert sceHmdTerminate() == ORBIS_OK

@test
def hmd_device_info_defaults() -> void:
    can Abort.Panic:
        init_param: OrbisHmdInitializeParam = hmd_make_init_param(null)
        assert sceHmdInitialize(init_param.ref[OrbisHmdInitializeParam&]) == ORBIS_OK
        info: mutable OrbisHmdDeviceInformation = zeroed
        assert sceHmdGetDeviceInformation(info.ref[mutable OrbisHmdDeviceInformation&]) == ORBIS_OK
        assert info.status == ORBIS_HMD_DEVICE_STATUS_NOT_DETECTED
        assert sceHmdTerminate() == ORBIS_OK

@test
def hmd_nid_tables_match_cpp_counts() -> void:
    can Abort.Panic:
        assert HMD_NIDS_COUNT == 137usize
        assert HMD_DISTORTION_NIDS_COUNT == 16usize
        assert HMD_REPROJECTION_NIDS_COUNT == 35usize

        h_first: HmdNidEntry = Hmd_NidEntryAt(0usize)
        h_last: HmdNidEntry = Hmd_NidEntryAt(136usize)
        assert h_first.nid == "6biw1XHTSqQ"
        assert h_first.symbol_name == "sceHmdClose"
        assert h_last.nid == "-y4OUwFf4jE"
        assert h_last.symbol_name == "Func_FF2E0E53015FE231"

        d_first: HmdDistortionNidEntry = HmdDistortion_NidEntryAt(0usize)
        d_last: HmdDistortionNidEntry = HmdDistortion_NidEntryAt(15usize)
        assert d_first.nid == "gEokC+OGI8g"
        assert d_last.nid == "thTykLZ-tZs"

        r_first: HmdReprojectionNidEntry = HmdReprojection_NidEntryAt(0usize)
        r_last: HmdReprojectionNidEntry = HmdReprojection_NidEntryAt(34usize)
        assert r_first.nid == "8gH1aLgty5I"
        assert r_last.nid == "uab6BzXsfkk"

@test
def hmd_setup_dialog_stub_behavior() -> void:
    can Abort.Panic:
        assert sceHmdSetupDialogInitialize() == ORBIS_OK
        result: mutable OrbisHmdSetupDialogResult = zeroed
        assert sceHmdSetupDialogGetResult(result.ref[mutable OrbisHmdSetupDialogResult&]) == ORBIS_OK
        assert result.result == ORBIS_COMMON_DIALOG_RESULT_USER_CANCELED
        assert sceHmdSetupDialogGetStatus() == ORBIS_COMMON_DIALOG_STATUS_FINISHED
        assert sceHmdSetupDialogUpdateStatus() == ORBIS_COMMON_DIALOG_STATUS_FINISHED
        assert sceHmdSetupDialogClose() == ORBIS_OK
        assert sceHmdSetupDialogTerminate() == ORBIS_OK

@test
def hmd_setup_dialog_nids_match_cpp_counts() -> void:
    can Abort.Panic:
        assert HMD_SETUP_DIALOG_NIDS_COUNT == 7usize
        first: HmdSetupDialogNidEntry = HmdSetupDialog_NidEntryAt(0usize)
        last: HmdSetupDialogNidEntry = HmdSetupDialog_NidEntryAt(6usize)
        assert first.nid == "nmHzU4Gh0xs"
        assert first.symbol_name == "sceHmdSetupDialogClose"
        assert last.nid == "Ud7j3+RDIBg"
        assert last.symbol_name == "sceHmdSetupDialogUpdateStatus"
