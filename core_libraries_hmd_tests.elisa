include "../compiler/runtime/elisacore_std/elisacore_runtime.elisa"
include "./core/libraries/error_codes.elisa"
include "./core/libraries/hmd/hmd_error.elisa"
include "./core/libraries/hmd/hmd.elisa"

def hmd_make_init_param(reserved0: void&?) -> OrbisHmdInitializeParam:
    out: mutable OrbisHmdInitializeParam = zeroed
    out.reserved0 <- reserved0
    return out

@test
def hmd_open_close_lifecycle() -> void:
    can Abort.Panic:
        init_param: OrbisHmdInitializeParam = hmd_make_init_param(null)
        assert sceHmdInitialize(init_param.ref[OrbisHmdInitializeParam&]) == ORBIS_OK
        handle: s32 = sceHmdOpen(1, 0, 0, null)
        assert handle > 0
        assert sceHmdClose(handle) == ORBIS_OK
        assert sceHmdTerminate() == ORBIS_OK

@test
def hmd_validation_paths() -> void:
    can Abort.Panic:
        assert sceHmdOpen(1, 0, 0, null) == ORBIS_HMD_ERROR_NOT_INITIALIZED
        init_param: OrbisHmdInitializeParam = hmd_make_init_param(null)
        assert sceHmdInitialize(init_param.ref[OrbisHmdInitializeParam&]) == ORBIS_OK
        assert sceHmdInitialize(init_param.ref[OrbisHmdInitializeParam&]) == ORBIS_HMD_ERROR_ALREADY_INITIALIZED
        assert sceHmdOpen(-1, 0, 0, null) == ORBIS_HMD_ERROR_PARAMETER_INVALID
        assert sceHmdOpen(255, 0, 0, null) == ORBIS_HMD_ERROR_PARAMETER_INVALID
        assert sceHmdTerminate() == ORBIS_OK

@test
def hmd_device_info_defaults() -> void:
    can Abort.Panic:
        init_param: OrbisHmdInitializeParam = hmd_make_init_param(null)
        assert sceHmdInitialize(init_param.ref[OrbisHmdInitializeParam&]) == ORBIS_OK
        info: mutable OrbisHmdDeviceInformation = zeroed
        assert sceHmdGetDeviceInformation(info.ref[mutable OrbisHmdDeviceInformation&]) == ORBIS_OK
        assert info.status == ORBIS_HMD_DEVICE_STATUS_NOT_DETECTED
        assert sceHmdTerminate() == ORBIS_OK
