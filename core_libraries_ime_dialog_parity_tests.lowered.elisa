const ORBIS_COMMON_DIALOG_STATUS_INITIALIZED: u32 = 1

const ORBIS_COMMON_DIALOG_STATUS_RUNNING: u32 = 2

const ORBIS_COMMON_DIALOG_STATUS_FINISHED: u32 = 3

const ORBIS_COMMON_DIALOG_RESULT_OK: u32 = 0

