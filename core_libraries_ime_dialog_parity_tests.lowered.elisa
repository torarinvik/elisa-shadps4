    p: mutable OrbisImeDialogParam& = param_1.cast[mutable OrbisImeDialogParam&]
    ext: mutable OrbisImeParamExtended&? = null
    if (param_2 != null):
        ext <- param_2.cast[mutable OrbisImeParamExtended&]
    return sceImeDialogInit(p.ref[mutable OrbisImeDialogParam&], ext)

