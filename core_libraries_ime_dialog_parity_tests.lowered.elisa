        posForm.type_ <- ORBIS_IME_PANEL_TYPE_HIDE
        posForm.posx <- 0.0
        posForm.posy <- 0.0
        posForm.horizontal_alignment <- 0u32
        posForm.vertical_alignment <- 0u32
        posForm.width <- 0u32
        posForm.height <- 0u32
    return ORBIS_OK

# @port core/libraries/ime/ime.cpp::sceImeGetPanelSize sha256=20db223b149a4cd1 oracle@a3773841
def sceImeGetPanelSize(param: OrbisImeParam&?, width: mutable u32&?, height: mutable u32&?) -> int:
    if (((param == null) or (width == null)) or (height == null)):
        return ORBIS_IME_ERROR_INVALID_ADDRESS
    if (param.type_ > ORBIS_IME_TYPE_NUMBER):
        return ORBIS_IME_ERROR_INVALID_TYPE
    option: u32 = param.option
    if ime_has_invalid_option(option):
        return ORBIS_IME_ERROR_INVALID_OPTION
    sdk: u32 = ime_get_compiled_sdk_version()
    if (param.type_ == ORBIS_IME_TYPE_NUMBER):
        width[0] <- 0x172u32
        height[0] <- ((0x192u32 if (sdk > 0x016fffffu32) else 0x170u32))
    else:
        if ((param.type_ == ORBIS_IME_TYPE_BASIC_LATIN) or (((option & 0xc0000004u32)) == 4u32)):
            width[0] <- 0x319u32
            height[0] <- ((0x198u32 if (sdk > 0x016fffffu32) else 0x170u32))
        else:
            width[0] <- 0x319u32
            height[0] <- 0x198u32
    if (((option & ORBIS_IME_OPTION_USE_OVER_2K_COORDINATES)) != 0u32):
        width[0] <- (width[0] << 1u32)
        height[0] <- (height[0] << 1u32)
    return ORBIS_OK

# @port core/libraries/ime/ime.cpp::sceImeKeyboardClose sha256=acfb7159f1a6ed57 oracle@a3773841
def sceImeKeyboardClose(userId: int) -> int:
    if (not g_keyboard_open):
        return ORBIS_IME_ERROR_NOT_OPENED
    if (userId == ORBIS_IME_USER_SERVICE_USER_ID_INVALID):
        return ORBIS_IME_ERROR_INVALID_USER_ID
    g_keyboard_open <- false
    g_keyboard_handler <- null
    return ORBIS_OK

# @port core/libraries/ime/ime.cpp::sceImeKeyboardGetInfo sha256=bd5d44d0a2aafc43 oracle@a3773841
def sceImeKeyboardGetInfo(resourceId: u32, info: mutable OrbisImeKeyboardInfo&?) -> int:
    _ = resourceId
    if (info != null):
        info.user_id <- 0
        info.device <- 0u32
        info.type_ <- 0u32
        info.repeat_delay <- 0u32
        info.repeat_rate <- 0u32
        info.status <- 0u32
        i: mutable int = 0
        while (i < 12):
            info.reserved[i] <- 0
            i <- (i + 1)
    return ORBIS_OK

# @port core/libraries/ime/ime.cpp::sceImeKeyboardGetResourceId sha256=c4aeb0b98a732306 oracle@a3773841
def sceImeKeyboardGetResourceId(userId: int, resourceIdArray: mutable OrbisImeKeyboardResourceIdArray&?) -> int:
    if (resourceIdArray == null):
        return ORBIS_IME_ERROR_INVALID_ADDRESS
    if (userId == ORBIS_IME_USER_SERVICE_USER_ID_INVALID):
        return ORBIS_IME_ERROR_INVALID_USER_ID
    resourceIdArray.user_id <- userId
    ime_zero_u32_5(resourceIdArray.resource_id)
    if (not g_keyboard_open):
        return ORBIS_IME_ERROR_NOT_OPENED
    return ORBIS_IME_ERROR_CONNECTION_FAILED

# @port core/libraries/ime/ime.cpp::sceImeKeyboardOpen sha256=b6f775d159d765fc oracle@a3773841
def sceImeKeyboardOpen(userId: int, param: OrbisImeKeyboardParam&?) -> int:
    if (param == null):
        return ORBIS_IME_ERROR_INVALID_ADDRESS
    if (param.handler == null):
        return ORBIS_IME_ERROR_INVALID_HANDLER
    if (((param.option & (~ORBIS_IME_KEYBOARD_OPTION_MASK))) != 0u32):
        return ORBIS_IME_ERROR_INVALID_OPTION
    if (userId == ORBIS_IME_USER_SERVICE_USER_ID_INVALID):
        return ORBIS_IME_ERROR_INVALID_USER_ID
    if (not ime_all_zero_i8_4(param.reserved1)):
        return ORBIS_IME_ERROR_INVALID_RESERVED
    if (not ime_all_zero_i8_8(param.reserved2)):
        return ORBIS_IME_ERROR_INVALID_RESERVED
    if g_keyboard_open:
        return ORBIS_IME_ERROR_BUSY
    g_keyboard_open <- true
    g_keyboard_handler <- param.handler
    return ORBIS_OK

