extern mutex_destroy(mu: mutable Mutex&) -> void effects[Memory.Release]

extern ctx_mutex_lock(mutex: void&) -> int effects[Sync.Lock]

extern ctx_mutex_unlock(mutex: void&) -> int effects[Sync.Unlock]

extern condvar_init(out: mutable CondVar&) -> void effects[Memory.Allocate]

extern condvar_destroy(cv: mutable CondVar&) -> void effects[Memory.Release]

extern ctx_cond_wait(cond: void&, mutex: void&) -> int effects[Sync.Wait]

