    can Console, Abort.Exit:
        actual_msg: u8& = (msg if (msg != null) else "<null>")
        puts("ctx_llvm_codegen_fatal:")
        puts(actual_msg)
        exit(1)

struct ByteBuffer:
    data: mutable heap u8&?
    len: mutable usize
    capacity: mutable usize

struct HeapByteBuffer:
    data: mutable heap u8&?
    len: mutable usize
    capacity: mutable usize

struct CxxU32MapEntry[T]:
    key: mutable u32
    value: mutable T

struct CxxU32Map[T]:
    entries: mutable darray[CxxU32MapEntry[T]]

def cxx_min_usize(a: usize, b: usize) -> usize:
    return (a if (a < b) else b)

def cxx_clamp_f32(value: f32, lo: f32, hi: f32) -> f32:
    if (value < lo):
        return lo
    if (value > hi):
        return hi
    return value

def cxx_memset(dest: mutable void&, value: u8, n: usize) -> mutable void&:
    bytes: mutable u8& = arena_mutable_u8_from_void(dest)
    trusted Unsafe.UncheckedIndex:
        for i in 0 ..< n:
            bytes[i] <- value
    return dest

def cxx_zero_memory(dest: mutable void&, n: usize) -> mutable void&:
    return cxx_memset(dest, 0.u8(), n)

def cxx_byte_buffer_empty() -> ByteBuffer:
    out: ByteBuffer = zeroed
    return out

def cxx_byte_buffer_alloc(a: mutable Arena&, size: usize) -> ByteBuffer:
    can Memory.Allocate, Abort.Panic:
        out: mutable ByteBuffer = zeroed
        if (size == 0):
            return out
        raw: mutable heap u8& = arena_heap_u8_from_alloc(arena_alloc(a, size))
        _ = cxx_zero_memory(arena_void_from_mutable_u8(raw), size)
        out.data as & <- raw
        out.len <- size
        out.capacity <- size
        return out

def cxx_byte_buffer_from(a: mutable Arena&, src: void&, size: usize) -> ByteBuffer:
    can Memory.Allocate, Abort.Panic:
        out: ByteBuffer = cxx_byte_buffer_alloc(a, size)
        if (size == 0):
            return out
        assert((out.data != null))
        _ = arena_memcpy(arena_void_from_mutable_u8(out.data), src, size)
        return out

def cxx_byte_buffer_resize_zeroed(a: mutable Arena&, buffer: mutable ByteBuffer&, size: usize):
    can Memory.Allocate, Abort.Panic:
        if (size <= buffer.capacity):
            return
        old_data: mutable heap u8&? = buffer.data
        old_len: usize = buffer.len
        raw: mutable heap u8& = arena_heap_u8_from_alloc(arena_alloc(a, size))
        _ = cxx_zero_memory(arena_void_from_mutable_u8(raw), size)
        if ((old_data != null) and (old_len > 0)):
            _ = arena_memcpy(arena_void_from_mutable_u8(raw), arena_void_from_u8(old_data), old_len)
        buffer.data as & <- raw
        buffer.capacity <- size
        buffer.len <- size

def cxx_byte_buffer_clear(buffer: mutable ByteBuffer&):
    buffer.len <- 0

def cxx_byte_buffer_view(buffer: ByteBuffer&) -> dview[u8]:
    return (DynArrayView(null, 0, size_of(u8)) if ((buffer.data == null) or (buffer.len == 0)) else DynArrayView(arena_void_from_u8(buffer.data), buffer.len, size_of(u8)))

def cxx_heap_byte_buffer_alloc(size: usize) -> HeapByteBuffer:
    can Memory.Allocate, Abort.Panic:
        out: mutable HeapByteBuffer = zeroed
        if (size == 0):
            return out
        raw_void: mutable heap void&? = null
        trusted Unsafe.RawExtern:
            raw_void <- malloc(size)
        assert((raw_void != null))
        raw: mutable heap u8& = arena_heap_u8_from_alloc(raw_void)
        _ = cxx_zero_memory(arena_void_from_mutable_u8(raw), size)
        out.data as & <- raw
        out.len <- size
        out.capacity <- size
        return out

def cxx_heap_byte_buffer_from(src: void&, size: usize) -> HeapByteBuffer:
    can Memory.Allocate, Abort.Panic:
        out: HeapByteBuffer = cxx_heap_byte_buffer_alloc(size)
        if (size == 0):
            return out
        assert((out.data != null))
        _ = arena_memcpy(arena_void_from_mutable_u8(out.data), src, size)
        return out

def cxx_heap_byte_buffer_free(buffer: mutable HeapByteBuffer&):
    can Memory.Release:
        if (buffer.data == null):
            return
        trusted Unsafe.RawExtern:
            free(buffer.data.cast[heap void&])
        buffer.data as ! <- null
        buffer.len <- 0
        buffer.capacity <- 0

def cxx_read_value[T](ptr: void&?) -> T:
    can Abort.Panic:
        assert((ptr != null))
        trusted Unsafe.PointerCast:
            value: T& = ptr.cast[T&]
            return value[0]

def cxx_write_value[T](ptr: mutable void&?, value: T):
    can Abort.Panic:
        assert((ptr != null))
        trusted Unsafe.PointerCast:
            out: mutable T& = ptr.cast[mutable T&]
            out[0] <- value

def cxx_copy_value_to[T](ptr: mutable void&?, value: T):
    cxx_write_value[T](ptr, value) can Abort.Panic

def cxx_read_array_at[T](ptr: void&?, index: usize) -> T:
    can Abort.Panic:
        assert((ptr != null))
        trusted Unsafe.PointerCast, Unsafe.PointerArithmetic:
            items: T& = ptr.cast[T&]
            return items[index]

def cxx_array_ref_at[T](ptr: mutable void&?, index: usize) -> mutable T&:
    can Abort.Panic:
        assert((ptr != null))
        trusted Unsafe.PointerCast, Unsafe.PointerArithmetic:
            items: mutable T& = ptr.cast[mutable T&]
            return &items[index]

def cxx_vector_new[T](a: mutable Arena&, initial_capacity: usize) -> darray[T]:
    can Memory.Allocate, Abort.Panic:
        out: mutable darray[T] = zeroed
        in a:
            _ = out.reserve(initial_capacity)
        return out

def cxx_vector_push[T](a: mutable Arena&, vec: mutable darray[T]&, value: T):
    _ = arena_da_append(a, vec, value) can Memory.Allocate, Abort.Panic

def cxx_vector_assign_bytes(a: mutable Arena&, vec: mutable darray[u8]&, src: void&, size: usize):
    can Memory.Allocate, Abort.Panic:
        vec.count <- 0
        if (size == 0):
            return
        bytes: u8& = arena_u8_from_void(src)
        _ = arena_da_append_many(a, vec, bytes, size)

def cxx_deque_new[T](a: mutable Arena&, initial_capacity: usize) -> Deque[T]:
    return arena_deque_with_capacity[T](a, initial_capacity) can Memory.Allocate, Abort.Panic

def cxx_deque_push_back[T](a: mutable Arena&, deque: mutable Deque[T]&, item: T):
    _ = arena_deque_push_back[T](a, deque, item) can Memory.Allocate, Abort.Panic

def cxx_deque_pop_front[T](deque: mutable Deque[T]&, out: mutable T&) -> bool:
    return arena_deque_pop_front[T](deque, out) can Abort.Panic

def cxx_hash_map_new[K, T](a: mutable Arena&, initial_capacity: usize) -> dict[K, T]:
    return arena_dict_new[K, T](a, initial_capacity) can Memory.Allocate, Abort.Panic

def cxx_hash_map_put[K, T](a: mutable Arena&, map: mutable dict[K, T]&, key: K, value: T) -> mutable T&? error[RuntimeError]:
    return (try arena_dict_put[K, T](a, map, key, value)) can Memory.Allocate, Abort.Panic

def cxx_hash_map_get[K, T](map: dict[K, T]&, key: K) -> mutable T&?:
    return arena_dict_get[K, T](map, key)

def cxx_hash_map_contains[K, T](map: dict[K, T]&, key: K) -> bool:
    return arena_dict_contains[K, T](map, key)

def cxx_hash_map_remove[K, T](map: mutable dict[K, T]&, key: K) -> bool:
    return arena_dict_remove[K, T](map, key)

def cxx_hash_map_clear[K, T](map: mutable dict[K, T]&):
    arena_dict_clear[K, T](map)

def cxx_u32_map_new[T](a: mutable Arena&, initial_capacity: usize) -> CxxU32Map[T]:
    can Memory.Allocate, Abort.Panic:
        out: mutable CxxU32Map[T] = zeroed
        in a:
            _ = out.entries.reserve(initial_capacity)
        return out

def cxx_u32_map_count[T](map: CxxU32Map[T]&) -> usize:
    return map.entries.count

def cxx_u32_map_find_index[T](map: CxxU32Map[T]&, key: u32) -> usize:
    i: mutable usize = 0
    while (i < map.entries.count):
        if (map.entries[i].key == key):
            return i
        i <- (i + 1)
    return map.entries.count

def cxx_u32_map_get[T](map: CxxU32Map[T]&, key: u32) -> mutable T&?:
    index: usize = cxx_u32_map_find_index[T](map, key)
    if (index >= map.entries.count):
        return null
    return map.entries[index].value.ref[mutable T&]

def cxx_u32_map_contains[T](map: CxxU32Map[T]&, key: u32) -> bool:
    return (cxx_u32_map_find_index[T](map, key) < map.entries.count)

def cxx_u32_map_put[T](a: mutable Arena&, map: mutable CxxU32Map[T]&, key: u32, value: T) -> bool:
    can Memory.Allocate, Abort.Panic:
        index: usize = cxx_u32_map_find_index[T](map, key)
        if (index < map.entries.count):
            map.entries[index].value <- value
            return true
        entry: CxxU32MapEntry[T] = zeroed
        entry.key <- key
        entry.value <- value
        _ = arena_da_append[CxxU32MapEntry[T]](a, map.entries.ref[darray[CxxU32MapEntry[T]]&], entry)
        return true

def cxx_u32_map_remove[T](map: mutable CxxU32Map[T]&, key: u32) -> bool:
    can Abort.Panic:
        index: usize = cxx_u32_map_find_index[T](map, key)
        if (index >= map.entries.count):
            return false
        _ = darray_remove_at[CxxU32MapEntry[T]](map.entries.ref[darray[CxxU32MapEntry[T]]&], index)
        return true

def cxx_u32_map_clear[T](map: mutable CxxU32Map[T]&):
    map.entries.count <- 0

