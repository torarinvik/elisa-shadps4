# @port core/libraries/ime/ime.cpp::sceImeOpen sha256=5ea22403883a2f39 oracle@a3773841
def sceImeOpen(param: OrbisImeParam&?, extended: OrbisImeParamExtended&?) -> int:
    if g_ime_open:
        return ORBIS_IME_ERROR_BUSY
    if (param == null):
        return ORBIS_IME_ERROR_INVALID_ADDRESS
    if (not ime_valid_user_id(param.user_id)):
        return ORBIS_IME_ERROR_INVALID_USER_ID
    if (param.type_ > ORBIS_IME_TYPE_NUMBER):
        return ORBIS_IME_ERROR_INVALID_TYPE
    lang_mask: u64 = ime_get_language_mask()
    if (((((~lang_mask) & param.supported_languages)) != 0u64)):
        return ORBIS_IME_ERROR_INVALID_SUPPORTED_LANGUAGES
    if (param.enter_label > ORBIS_IME_ENTER_LABEL_GO):
        return ORBIS_IME_ERROR_INVALID_ENTER_LABEL
    if (param.input_method != ORBIS_IME_INPUT_METHOD_DEFAULT):
        return ORBIS_IME_ERROR_INVALID_INPUT_METHOD
    option: u32 = param.option
    if ime_has_invalid_option(option):
        return ORBIS_IME_ERROR_INVALID_OPTION
    multiline: bool = (((option & ORBIS_IME_OPTION_MULTILINE)) != 0u32)
    password: bool = (((option & ORBIS_IME_OPTION_PASSWORD)) != 0u32)
    if (multiline and password):
        return ORBIS_IME_ERROR_INVALID_PARAM
    if ((multiline and (param.type_ != ORBIS_IME_TYPE_DEFAULT)) and (param.type_ != ORBIS_IME_TYPE_BASIC_LATIN)):
        return ORBIS_IME_ERROR_INVALID_PARAM
    if ((password and (param.type_ != ORBIS_IME_TYPE_BASIC_LATIN)) and (param.type_ != ORBIS_IME_TYPE_NUMBER)):
        return ORBIS_IME_ERROR_INVALID_PARAM
    if ((param.maxTextLength == 0u32) or (param.maxTextLength > ORBIS_IME_DIALOG_MAX_TEXT_LENGTH)):
        return ORBIS_IME_ERROR_INVALID_MAX_TEXT_LENGTH
    if (param.inputTextBuffer == null):
        return ORBIS_IME_ERROR_INVALID_INPUT_TEXT_BUFFER
    sdk: u32 = ime_get_compiled_sdk_version()
    maxWidth: mutable f32 = 1920.0
    maxHeight: mutable f32 = 1080.0
    if (sdk >= 0x01500000u32):
        use_high_res: bool = (((option & ORBIS_IME_OPTION_USE_OVER_2K_COORDINATES)) != 0u32)
        maxWidth <- ((3840.0 if use_high_res else 1920.0))
        maxHeight <- ((2160.0 if use_high_res else 1080.0))
    if ((param.posx < 0.0) or (param.posx >= maxWidth)):
        return ORBIS_IME_ERROR_INVALID_POSX
    if ((param.posy < 0.0) or (param.posy >= maxHeight)):
        return ORBIS_IME_ERROR_INVALID_POSY
    if (param.horizontal_alignment > 2u32):
        return ORBIS_IME_ERROR_INVALID_HORIZONTAL_ALIGNMENT
    if (param.vertical_alignment > 2u32):
        return ORBIS_IME_ERROR_INVALID_VERTICAL_ALIGNMENT
    if (extended != null):
        if (extended.priority > ORBIS_IME_PANEL_PRIORITY_ACCENT):
            return ORBIS_IME_ERROR_INVALID_EXTENDED
        if (not ime_valid_ext_option(extended.option)):
            return ORBIS_IME_ERROR_INVALID_EXTENDED
        if (((extended.ext_keyboard_mode & 0xe3fffffcu32)) != 0u32):
            return ORBIS_IME_ERROR_INVALID_EXTENDED
        if (not ime_all_zero_i8_60(extended.reserved)):
            return ORBIS_IME_ERROR_INVALID_EXTENDED
        if (extended.disable_device > 7u32):
            return ORBIS_IME_ERROR_INVALID_EXTENDED
    if (param.work == null):
        return ORBIS_IME_ERROR_INVALID_WORK
    if (((param.work.usize() & 0x3usize)) != 0usize):
        return ORBIS_IME_ERROR_INVALID_WORK
    if (param.handler == null):
        return ORBIS_IME_ERROR_INVALID_HANDLER
    if (not ime_all_zero_i8_8(param.reserved)):
        return ORBIS_IME_ERROR_INVALID_RESERVED
    if (not ime_valid_text(param.inputTextBuffer, param.maxTextLength, multiline, sdk)):
        return ORBIS_IME_ERROR_INVALID_TEXT
    g_ime_open <- true
    g_ime_handler <- param.handler
    g_ime_option_bits <- option
    g_ime_max_text_length <- param.maxTextLength
    g_ime_current_text_length <- ime_count_utf16(param.inputTextBuffer, param.maxTextLength)
    return ORBIS_OK

