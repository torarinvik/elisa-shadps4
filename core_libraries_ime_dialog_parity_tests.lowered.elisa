# @port core/libraries/ime/ime_dialog.cpp::sceImeDialogSetPanelPosition sha256=b0bff32e0b3ffa61 oracle@a3773841
def sceImeDialogSetPanelPosition(posx: i32, posy: i32) -> int:
    if (not g_ime_dialog_has_client):
        return ORBIS_IME_ERROR_DIALOG_NOT_IN_USE
    if ((g_ime_dialog_status == ORBIS_IME_DIALOG_STATUS_RUNNING) or (g_ime_dialog_status == ORBIS_IME_DIALOG_STATUS_FINISHED)):
        return ORBIS_IME_ERROR_IME_SUSPENDING
    g_ime_dialog_param.posx <- posx.f32()
    g_ime_dialog_param.posy <- posy.f32()
    return ORBIS_OK

# @port core/libraries/ime/ime_dialog.cpp::sceImeDialogTerm sha256=ba800ddd2043c1b5 oracle@a3773841
def sceImeDialogTerm() -> int:
    if (not g_ime_dialog_has_client):
        return ORBIS_IME_ERROR_DIALOG_NOT_IN_USE
    if (g_ime_dialog_status != ORBIS_IME_DIALOG_STATUS_FINISHED):
        return ORBIS_IME_ERROR_DIALOG_NOT_FINISHED
    ime_dialog_reset_state()
    return ORBIS_OK

def ImeDialog_RegisterLib(sym: void&?) -> void:
    _ = sym
    LIB_FUNCTION("oBmw4xrmfKs", "libSceImeDialog", 1, "libSceImeDialog", sceImeDialogAbort)
    LIB_FUNCTION("bX4H+sxPI-o", "libSceImeDialog", 1, "libSceImeDialog", sceImeDialogForceClose)
    LIB_FUNCTION("UFcyYDf+e88", "libSceImeDialog", 1, "libSceImeDialog", sceImeDialogForTestFunction)
    LIB_FUNCTION("fy6ntM25pEc", "libSceImeDialog", 1, "libSceImeDialog", sceImeDialogGetCurrentStarState)
    LIB_FUNCTION("8jqzzPioYl8", "libSceImeDialog", 1, "libSceImeDialog", sceImeDialogGetPanelPositionAndForm)
    LIB_FUNCTION("wqsJvRXwl58", "libSceImeDialog", 1, "libSceImeDialog", sceImeDialogGetPanelSize)
    LIB_FUNCTION("CRD+jSErEJQ", "libSceImeDialog", 1, "libSceImeDialog", sceImeDialogGetPanelSizeExtended)
    LIB_FUNCTION("x01jxu+vxlc", "libSceImeDialog", 1, "libSceImeDialog", sceImeDialogGetResult)
    LIB_FUNCTION("IADmD4tScBY", "libSceImeDialog", 1, "libSceImeDialog", sceImeDialogGetStatus)
    LIB_FUNCTION("NUeBrN7hzf0", "libSceImeDialog", 1, "libSceImeDialog", sceImeDialogInit)
    LIB_FUNCTION("KR6QDasuKco", "libSceImeDialog", 1, "libSceImeDialog", sceImeDialogInitInternal)
    LIB_FUNCTION("oe92cnJQ9HE", "libSceImeDialog", 1, "libSceImeDialog", sceImeDialogInitInternal2)
    LIB_FUNCTION("IoKIpNf9EK0", "libSceImeDialog", 1, "libSceImeDialog", sceImeDialogInitInternal3)
    LIB_FUNCTION("-2WqB87KKGg", "libSceImeDialog", 1, "libSceImeDialog", sceImeDialogSetPanelPosition)
    LIB_FUNCTION("gyTyVn+bXMw", "libSceImeDialog", 1, "libSceImeDialog", sceImeDialogTerm)

def ime_dialog_make_valid_param(buf: mutable u16&, max_len: u32) -> OrbisImeDialogParam:
    p: mutable OrbisImeDialogParam = zeroed
    p.user_id <- 1
    p.type_ <- ORBIS_IME_TYPE_DEFAULT
    p.supported_languages <- 0x3ff1fffffu64
    p.enter_label <- ORBIS_IME_ENTER_LABEL_GO
    p.input_method <- ORBIS_IME_INPUT_METHOD_DEFAULT
    p.option <- 0u32
    p.max_text_length <- max_len
    p.input_text_buffer <- buf
    p.posx <- 100.0
    p.posy <- 200.0
    p.horizontal_alignment <- 0u32
    p.vertical_alignment <- 0u32
    return p

@test
def error_dialog_lifecycle() -> void:
    can Abort.Panic:
        assert((sceErrorDialogGetStatus() == ORBIS_COMMON_DIALOG_STATUS_NONE))
        assert((sceErrorDialogInitialize() == ORBIS_OK.u32()))
        assert((sceErrorDialogGetStatus() == ORBIS_COMMON_DIALOG_STATUS_INITIALIZED))
        assert((sceErrorDialogOpen(null) == ORBIS_COMMON_DIALOG_ERROR_ARG_NULL.u32()))
        p: mutable ErrorDialogParam = zeroed
        p.size <- 16
        p.errorCode <- 0x80bc0001
        p.userId <- 1
        assert((sceErrorDialogOpen(p.ref[ErrorDialogParam&]) == ORBIS_OK.u32()))
        assert((sceErrorDialogGetStatus() == ORBIS_COMMON_DIALOG_STATUS_RUNNING))
        assert((sceErrorDialogClose() == ORBIS_OK.u32()))
        assert((sceErrorDialogGetStatus() == ORBIS_COMMON_DIALOG_STATUS_FINISHED))
        assert((sceErrorDialogTerminate() == ORBIS_OK.u32()))
        assert((sceErrorDialogGetStatus() == ORBIS_COMMON_DIALOG_STATUS_NONE))
        assert((sceErrorDialogTerminate() == ORBIS_COMMON_DIALOG_ERROR_NOT_INITIALIZED.u32()))

@test
def ime_dialog_lifecycle_and_panel_size() -> void:
    can Abort.Panic:
        txt: mutable u16[64] = zeroed
        p: mutable OrbisImeDialogParam = ime_dialog_make_valid_param(txt.ref[mutable u16&], 64u32)
        w: mutable u32 = 0u32
        h: mutable u32 = 0u32
        assert((sceImeDialogGetPanelSize(p.ref[OrbisImeDialogParam&], w.ref[mutable u32&], h.ref[mutable u32&]) == ORBIS_OK))
        assert((w == 0x319u32))
        assert((h == 0x210u32))
        p.type_ <- ORBIS_IME_TYPE_NUMBER
        assert((sceImeDialogGetPanelSize(p.ref[OrbisImeDialogParam&], w.ref[mutable u32&], h.ref[mutable u32&]) == ORBIS_OK))
        assert((w == 0x172u32))
        assert((h == 0x20au32))
        assert((sceImeDialogInit(p.ref[mutable OrbisImeDialogParam&], null) == ORBIS_OK))
        assert((sceImeDialogGetStatus() == ORBIS_IME_DIALOG_STATUS_RUNNING))
        assert((sceImeDialogSetPanelPosition(10, 20) == ORBIS_IME_ERROR_IME_SUSPENDING))
        result: mutable OrbisImeDialogResult = zeroed
        assert((sceImeDialogGetResult(result.ref[mutable OrbisImeDialogResult&]) == ORBIS_IME_ERROR_DIALOG_NOT_FINISHED))
        assert((sceImeDialogAbort() == ORBIS_OK))
        assert((sceImeDialogGetStatus() == ORBIS_IME_DIALOG_STATUS_FINISHED))
        assert((sceImeDialogGetResult(result.ref[mutable OrbisImeDialogResult&]) == ORBIS_OK))
        assert((result.endstatus == ORBIS_IME_DIALOG_END_STATUS_ABORTED))
        assert((sceImeDialogTerm() == ORBIS_OK))
        assert((sceImeDialogGetStatus() == ORBIS_IME_DIALOG_STATUS_NONE))
        assert((sceImeDialogTerm() == ORBIS_IME_ERROR_DIALOG_NOT_IN_USE))
