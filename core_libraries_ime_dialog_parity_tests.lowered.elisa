const CTX_SMALL_STRING_CACHE_BUCKETS: usize = 1024

const CTX_STRING_LEN_CACHE_BUCKETS: usize = 4096

const CTX_ENABLE_SMALL_STRING_CACHE_EXPERIMENT: bool = false

global mutable perm_arena: Arena = Arena(null, null, 0)

global mutable scratch_arena: Arena = Arena(null, null, 0)

struct SmallStringCacheEntry:
    next: mutable heap SmallStringCacheEntry&?
    len: mutable usize
    text: mutable tail u8

struct StringLenCacheEntry:
    next: mutable heap StringLenCacheEntry&?
    ptr: mutable u8&
    len: mutable usize

struct StringBuilder:
    len: mutable i64
    cap: mutable i64
    data: mutable heap u8&?

struct StringView:
    data: mutable u8&
    len: mutable i64

struct ProgressBudget:
    remaining_steps: mutable i64
    max_depth: mutable i64
    current_depth: mutable i64
    cancelled: mutable bool

global mutable small_string_cache: heap SmallStringCacheEntry&?[CTX_SMALL_STRING_CACHE_BUCKETS] = zeroed

global mutable string_len_cache: heap StringLenCacheEntry&?[CTX_STRING_LEN_CACHE_BUCKETS] = zeroed

def progress_budget_steps(steps: i64) -> ProgressBudget:
    budget: ProgressBudget = zeroed
    budget.remaining_steps <- steps
    budget.max_depth <- 0
    budget.current_depth <- 0
    budget.cancelled <- false
    return budget

def progress_budget_steps_and_depth(steps: i64, max_depth: i64) -> ProgressBudget:
    budget: ProgressBudget = progress_budget_steps(steps)
    budget.max_depth <- max_depth
    return budget

def progress_cancel(budget: mutable ProgressBudget&):
    budget.cancelled <- true

def progress_check_cancel(budget: mutable ProgressBudget&):
    can Progress.CheckCancel, Abort.Panic:
        if budget.cancelled:
            panic("progress budget cancelled")

def progress_tick(budget: mutable ProgressBudget&):
    can Progress.Tick, Progress.CheckCancel, Abort.Panic:
        progress_check_cancel(budget)
        if (budget.remaining_steps <= 0):
            panic("progress budget exhausted")
        budget.remaining_steps <- (budget.remaining_steps - 1)

def progress_enter_recursion(budget: mutable ProgressBudget&):
    can Progress.EnterRecursion, Progress.CheckCancel, Abort.Panic:
        progress_check_cancel(budget)
        if ((budget.max_depth > 0) and (budget.current_depth >= budget.max_depth)):
            panic("progress recursion depth exhausted")
        budget.current_depth <- (budget.current_depth + 1)

def progress_leave_recursion(budget: mutable ProgressBudget&):
    can Progress.LeaveRecursion:
        if (budget.current_depth > 0):
            budget.current_depth <- (budget.current_depth - 1)

def alloc_perm(size: i64) -> mutable heap void&:
    resolved: usize = (size.usize() if (size > 0) else 1)
    return arena_alloc(perm_arena.ref[Arena&], resolved) can Memory.Allocate, Abort.Panic

def alloc_scratch(size: i64) -> mutable heap void&:
    resolved: usize = (size.usize() if (size > 0) else 1)
    return arena_alloc(scratch_arena.ref[Arena&], resolved) can Memory.Allocate, Abort.Panic

def reset_scratch():
    arena_reset(scratch_arena.ref[Arena&])

def string_len_bucket(ptr: u8&) -> usize:
    bits: mutable uintptr = ptr.uintptr()
    bits ^= ((bits >> 33))
    bits *= 0xff51afd7ed558ccd.uintptr()
    bits ^= ((bits >> 33))
    return ((bits & ((CTX_STRING_LEN_CACHE_BUCKETS - 1)).uintptr())).usize()

def register_perm_string_len(ptr: u8&?, len: usize):
    can Memory.Allocate, Abort.Panic:
        if ((ptr == null) or (len == 0)):
            return
        bucket: usize = string_len_bucket(ptr.cast[u8&])
        entry: mutable heap StringLenCacheEntry&? = string_len_cache[bucket]
        trusted Unsafe.AssumeProgress:
            while (entry != null):
                if (entry.ptr == ptr.cast[u8&]):
                    entry.len <- len
                    return
                entry <- entry.next
        new_entry: heap StringLenCacheEntry& = alloc_perm(size_of(StringLenCacheEntry).i64()).cast[heap StringLenCacheEntry&]
        new_entry.next <- string_len_cache[bucket]
        new_entry.ptr <- ptr.cast[u8&]
        new_entry.len <- len
        string_len_cache[bucket] <- new_entry

def lookup_cached_string_len(ptr: u8&?, len_out: mutable usize&) -> int:
    if (ptr == null):
        return 0
    bucket: usize = string_len_bucket(ptr.cast[u8&])
    prev: mutable heap StringLenCacheEntry&? = null
    entry: mutable heap StringLenCacheEntry&? = string_len_cache[bucket]
    trusted Unsafe.AssumeProgress:
        while (entry != null):
            if (entry.ptr == ptr.cast[u8&]):
                if (prev != null):
                    prev.next <- entry.next
                    entry.next <- string_len_cache[bucket]
                    string_len_cache[bucket] <- entry
                len_out <- entry.len
                return 1
            prev <- entry
            entry <- entry.next
    return 0

def runtime_strlen(value: u8&?) -> usize:
    src: u8& = (value if (value != null) else "")
    if (src[0] == 0):
        return 0
    return strlen(src)

def intern_small_string(src: u8&, len: usize) -> heap u8&:
    can Memory.Allocate, Abort.Panic:
        out: heap u8& = alloc_perm(((len + 1)).i64()).cast[heap u8&]
        if (len > 0):
            memcpy(out.cast[mutable void&], src.cast[void&], len)
        out[len] <- 0
        register_perm_string_len(out.cast[u8&], len)
        return out

def int_to_string_into(arena: mutable Arena&, value: i64) -> heap u8&:
    can Memory.Allocate, Console.Format, Abort.Panic:
        len: int = snprintf(null, 0, "%lld", value)
        if ((len > 0) and (len <= 8)):
            text: u8[9]
            snprintf(text[0].ref[u8&], (len.usize() + 1), "%lld", value)
            return intern_small_string(text[0].ref[u8&], len.usize())
        out: heap u8& = arena_alloc(arena, (len.usize() + 1)).cast[heap u8&]
        snprintf(out.cast[u8&?], (len.usize() + 1), "%lld", value)
        if (arena == perm_arena.ref[Arena&]):
            register_perm_string_len(out.cast[u8&], len.usize())
        return out

def bool_to_string_into(arena: Arena&, value: int) -> u8&:
    _ = arena
    return ("True" if (value != 0) else "False")

def char_to_string_into(arena: Arena&, value: i64) -> heap u8&:
    can Memory.Allocate, Abort.Panic:
        _ = arena
        text: u8[2]
        text[0] <- value.u8()
        text[1] <- 0
        return intern_small_string(text[0].ref[u8&], 1)

def string_builder_next_cap(min_cap: i64) -> i64:
    cap: mutable i64 = 16
    trusted Unsafe.AssumeProgress:
        while (cap < min_cap):
            cap *= 2
    return cap

def string_builder_new(initial: u8&?) -> mutable heap StringBuilder&:
    can Memory.Allocate, Abort.Panic:
        src: u8& = (initial if (initial != null) else "")
        len: usize = runtime_strlen(src)
        builder: heap StringBuilder& = alloc_perm(size_of(StringBuilder).i64()).cast[heap StringBuilder&]
        builder.len <- len.i64()
        builder.cap <- string_builder_next_cap((len.i64() + 1))
        builder.data <- alloc_perm(builder.cap).cast[heap u8&]
        if (len > 0):
            memcpy(builder.data.cast[mutable void&], src.cast[void&], len)
        builder.data[len] <- 0
        return builder

def string_builder_append(builder: mutable heap StringBuilder&?, suffix: u8&?) -> mutable heap StringBuilder&:
    can Memory.Allocate, Abort.Panic:
        src: u8& = (suffix if (suffix != null) else "")
        suffix_len: usize = runtime_strlen(src)
        if (builder == null):
            return string_builder_new(src)
        if (suffix_len == 0):
            return builder
        b: heap StringBuilder& = builder
        needed: i64 = ((b.len + suffix_len.i64()) + 1)
        if (needed > b.cap):
            new_cap: i64 = string_builder_next_cap(needed)
            new_data: heap u8& = alloc_perm(new_cap).cast[heap u8&]
            if (b.len > 0):
                assert((b.data != null))
                memcpy(new_data.cast[mutable void&], b.data.cast[void&], b.len.usize())
            b.data <- new_data
            b.cap <- new_cap
        assert((b.data != null))
        memmove(((b.data + b.len.usize())).cast[mutable void&], src.cast[void&], suffix_len)
        b.len += suffix_len.i64()
        b.data[b.len.usize()] <- 0
        return b

def string_builder_finish(builder: heap StringBuilder&?) -> heap u8&:
    can Memory.Allocate, Abort.Panic:
        if (builder == null):
            return intern_small_string("", 0)
        b: heap StringBuilder& = builder
        if (b.len <= 0):
            return intern_small_string("", 0)
        assert((b.data != null))
        if (b.len <= 8):
            return intern_small_string(b.data.cast[u8&], b.len.usize())
        register_perm_string_len(b.data.cast[u8&], b.len.usize())
        return b.data

struct Thread[T, S]:
    handle: mutable uintptr
    state: mutable void&?

struct Task[T, S]:
    handle: mutable uintptr
    state: mutable void&?

struct ThreadPool:
    handle: mutable void&?

struct TaskGroup:
    handle: mutable void&?
    cleanup: mutable void&?

struct Mutex:
    handle: mutable void&?

struct MutexGuard[S]:
    handle: mutable void&?

struct CondVar:
    handle: mutable void&?

struct atomic[T]:
    value: mutable T

struct ConcurrencyBox[T]:
    value: mutable T

struct ConcurrencyWorkStart1:
    fn_bits: mutable uintptr
    arg_bits: mutable void&
    result_bits: mutable void&
    refs: mutable atomic[i64]

struct ConcurrencyTaskGroupNode:
    next: mutable heap ConcurrencyTaskGroupNode&?
    state_bits: mutable void&

struct ConcurrencyRawTaskNode:
    next: mutable heap ConcurrencyRawTaskNode&?
    handle: mutable uintptr

struct ConcurrencyPoolState:
    worker_count: mutable usize

enum MemoryOrder:
    Relaxed
    Acquire
    Release
    AcqRel
    SeqCst

static if ELISA_TARGET_OS_POSIX:
    extern pthread_create(thread: mutable uintptr&, attr: void&?, start_routine: void&, arg: void&?) -> int effects[Thread.Spawn]
    extern pthread_join(thread: uintptr, retval: mutable void&?) -> int effects[Thread.Join]
    extern pthread_detach(thread: uintptr) -> int effects[Thread.Detach]
    extern pthread_mutex_lock(mutex: void&) -> int effects[Sync.Lock]
    extern pthread_mutex_unlock(mutex: void&) -> int effects[Sync.Unlock]
    extern pthread_cond_wait(cond: void&, mutex: void&) -> int effects[Sync.Wait]
    extern pthread_cond_signal(cond: void&) -> int effects[Sync.Notify]
    extern pthread_cond_broadcast(cond: void&) -> int effects[Sync.Notify]
    def ctx_platform_mutex_lock(handle: void&) -> int:
        return pthread_mutex_lock(handle) can Sync.Lock
    def ctx_platform_mutex_unlock(handle: void&) -> int:
        return pthread_mutex_unlock(handle) can Sync.Unlock
    def ctx_platform_cond_wait(cond: void&, mutex: void&) -> int:
        return pthread_cond_wait(cond, mutex) can Sync.Wait
    def ctx_platform_cond_signal(cond: void&) -> int:
        return pthread_cond_signal(cond) can Sync.Notify
    def ctx_platform_cond_broadcast(cond: void&) -> int:
        return pthread_cond_broadcast(cond) can Sync.Notify
static elif ELISA_TARGET_OS_WINDOWS:
    @c_opaque(windows.h, CRITICAL_SECTION)
    extern Win32CriticalSection
    @c_opaque(windows.h, CONDITION_VARIABLE)
    extern Win32ConditionVariable
    const WIN32_WAIT_INFINITE = 0xffffffffu32
    @callconv(winapi)
    extern EnterCriticalSection(section: mutable Win32CriticalSection&) -> void effects[Sync.Lock]
    @callconv(winapi)
    extern LeaveCriticalSection(section: mutable Win32CriticalSection&) -> void effects[Sync.Unlock]
    @callconv(winapi)
    extern SleepConditionVariableCS(cond: mutable Win32ConditionVariable&, section: mutable Win32CriticalSection&, milliseconds: u32) -> bool effects[Sync.Wait]
    @callconv(winapi)
    extern WakeConditionVariable(cond: mutable Win32ConditionVariable&) -> void effects[Sync.Notify]
    @callconv(winapi)
    extern WakeAllConditionVariable(cond: mutable Win32ConditionVariable&) -> void effects[Sync.Notify]
    def ctx_platform_mutex_lock(handle: void&) -> int:
        can Sync.Lock:
            EnterCriticalSection(handle.cast[mutable Win32CriticalSection&])
            return 0
    def ctx_platform_mutex_unlock(handle: void&) -> int:
        can Sync.Unlock:
            LeaveCriticalSection(handle.cast[mutable Win32CriticalSection&])
            return 0
    def ctx_platform_cond_wait(cond: void&, mutex: void&) -> int:
        can Sync.Wait:
            ok: bool = SleepConditionVariableCS(cond.cast[mutable Win32ConditionVariable&], mutex.cast[mutable Win32CriticalSection&], WIN32_WAIT_INFINITE)
            return (0 if ok else (-1))
    def ctx_platform_cond_signal(cond: void&) -> int:
        can Sync.Notify:
            WakeConditionVariable(cond.cast[mutable Win32ConditionVariable&])
            return 0
    def ctx_platform_cond_broadcast(cond: void&) -> int:
        can Sync.Notify:
            WakeAllConditionVariable(cond.cast[mutable Win32ConditionVariable&])
            return 0

