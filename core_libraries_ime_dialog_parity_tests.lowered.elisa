def sceErrorDialogTerminate() -> u32:
    if (g_error_dialog_status == ORBIS_COMMON_DIALOG_STATUS_RUNNING):
        _ = sceErrorDialogClose()
    if (g_error_dialog_status == ORBIS_COMMON_DIALOG_STATUS_NONE):
        return ORBIS_COMMON_DIALOG_ERROR_NOT_INITIALIZED.u32()
    g_error_dialog_status <- ORBIS_COMMON_DIALOG_STATUS_NONE
    g_error_dialog_error_code <- 0
    return ORBIS_OK.u32()

