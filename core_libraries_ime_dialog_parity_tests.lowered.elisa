# @port core/libraries/ime/ime.cpp::sceImeSetCaret sha256=ddc5ade1e857f03b oracle@a3773841
def sceImeSetCaret(caret: OrbisImeCaret&?) -> int:
    if (not g_ime_open):
        return ORBIS_IME_ERROR_NOT_OPENED
    sdk: u32 = ime_get_compiled_sdk_version()
    if (caret == null):
        return (ORBIS_IME_ERROR_INVALID_PARAM if (sdk < 0x01500000u32) else ORBIS_IME_ERROR_INVALID_ADDRESS)
    if (caret.index > g_ime_current_text_length):
        return ORBIS_IME_ERROR_INVALID_PARAM
    return ORBIS_OK

# @port core/libraries/ime/ime.cpp::sceImeSetText sha256=cfca65d1e074e345 oracle@a3773841
def sceImeSetText(text: u16&?, length: u32) -> int:
    if (not g_ime_open):
        return ORBIS_IME_ERROR_NOT_OPENED
    if (text == null):
        return ORBIS_IME_ERROR_INVALID_ADDRESS
    sdk: u32 = ime_get_compiled_sdk_version()
    if ((sdk < 0x01560000u32) and (length == 0u32)):
        return ORBIS_IME_ERROR_INVALID_PARAM
    if (length != 0u32):
        multiline: bool = (((g_ime_option_bits & ORBIS_IME_OPTION_MULTILINE)) != 0u32)
        if (not ime_valid_text(text, length, multiline, sdk)):
            return ORBIS_IME_ERROR_INVALID_TEXT
    g_ime_current_text_length <- length
    return ORBIS_OK

# @port core/libraries/ime/ime.cpp::sceImeSetTextGeometry sha256=ab48ce84b901ba3b oracle@a3773841
def sceImeSetTextGeometry(mode: u32, geometry: OrbisImeTextGeometry&?) -> int:
    if (not g_ime_open):
        return ORBIS_IME_ERROR_NOT_OPENED
    if (geometry == null):
        return ORBIS_IME_ERROR_INVALID_ADDRESS
    x: f32 = geometry.x
    y: f32 = geometry.y
    if ((((x < 0.0) or (x >= 1920.0)) or (y < 0.0)) or (y >= 1080.0)):
        return ORBIS_IME_ERROR_INVALID_PARAM
    if ((mode != ORBIS_IME_TEXT_AREA_MODE_SELECT) and (mode != ORBIS_IME_TEXT_AREA_MODE_PREEDIT)):
        return ORBIS_IME_ERROR_INVALID_PARAM
    return ORBIS_OK

