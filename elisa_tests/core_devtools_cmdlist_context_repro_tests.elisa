include "../../compiler/runtime/elisacore_std/elisacore_runtime.elisa"
include "../common/string_util.elisa"
include "../core/devtools/widget/imgui_abi.elisa"
include "../core/devtools/widget/imgui_memory_editor.elisa"
include "../core/devtools/widget/reg_popup.elisa"

def Devtools_CmdListContextRepro_RichQueueName(vqid: int) -> static u8&:
    can Memory.Allocate, Abort.Panic:
        queue: static u8& = "GFX" if vqid > 254 else "ASC"
        builder: mutable heap StringBuilder& = string_builder_new(queue)
        builder <- string_builder_append(builder, "[")
        builder <- string_builder_append(builder, Devtools_Widget_RegPopup_U32ToDecimal(vqid.u32()))
        builder <- string_builder_append(builder, "]")
        return string_builder_finish(builder).cast[static u8&]
    return ""

@test
def devtools_cmd_list_context_rich_queue_name_repro() -> void:
    can Abort.Panic, Memory.Allocate:
        for i in 0..<20000:
            label: static u8& = Devtools_CmdListContextRepro_RichQueueName((i % 260).int())
            assert runtime_strlen(label) >= 6
