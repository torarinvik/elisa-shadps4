include "../../compiler/runtime/elisacore_std/elisacore_runtime.elisa"
include "../common/types.elisa"
include "../core/libraries/error_codes.elisa"
include "../core/libraries/camera/camera_error.elisa"
include "../core/libraries/camera/camera.elisa"

@test
def camera_open_close_basic() -> void:
    Camera_DebugResetState()
    open_param: OrbisCameraOpenParameter = zeroed
    h: int = sceCameraOpen(ORBIS_CAMERA_USER_SERVICE_USER_ID_SYSTEM, 0, 0, open_param)
    assert h == 1
    assert sceCameraClose(h) == ORBIS_OK
    assert sceCameraClose(h) == ORBIS_CAMERA_ERROR_NOT_OPEN

@test
def camera_open_param_contract() -> void:
    Camera_DebugResetState()
    open_param: OrbisCameraOpenParameter = zeroed
    assert sceCameraOpen(0, 0, 0, open_param) == ORBIS_CAMERA_ERROR_PARAM
    assert sceCameraOpen(ORBIS_CAMERA_USER_SERVICE_USER_ID_SYSTEM, 1, 0, open_param) == ORBIS_CAMERA_ERROR_PARAM
    assert sceCameraOpen(ORBIS_CAMERA_USER_SERVICE_USER_ID_SYSTEM, 0, 1, open_param) == ORBIS_CAMERA_ERROR_PARAM

@test
def camera_get_attribute_defaults() -> void:
    Camera_DebugResetState()
    open_param: OrbisCameraOpenParameter = zeroed
    h: int = sceCameraOpen(ORBIS_CAMERA_USER_SERVICE_USER_ID_SYSTEM, 0, 0, open_param)
    attr: OrbisCameraAttribute = zeroed
    attr.sizeThis <- size_of(OrbisCameraAttribute).u32()
    attr.channel <- ORBIS_CAMERA_CHANNEL_0
    assert sceCameraGetAttribute(h, attr.ref[mutable OrbisCameraAttribute&]) == ORBIS_OK
    assert attr.exposureGain.exposure == 83
    assert attr.whiteBalance.gainRed == 768
    assert attr.gamma.value == 4
    assert attr.contrast == 32

@test
def camera_get_config_and_set_config_contracts() -> void:
    Camera_DebugResetState()
    open_param: OrbisCameraOpenParameter = zeroed
    h: int = sceCameraOpen(ORBIS_CAMERA_USER_SERVICE_USER_ID_SYSTEM, 0, 0, open_param)

    cfg: OrbisCameraConfig = zeroed
    cfg.sizeThis <- size_of(OrbisCameraConfig).u32()
    assert sceCameraGetConfig(h, cfg.ref[mutable OrbisCameraConfig&]) == ORBIS_OK
    assert cfg.configType == ORBIS_CAMERA_CONFIG_TYPE1
    assert cfg.configExtention[0].format.formatLevel0 == ORBIS_CAMERA_FORMAT_YUV422
    assert cfg.configExtention[1].format.formatLevel0 == ORBIS_CAMERA_FORMAT_YUV422

    set_cfg: OrbisCameraConfig = zeroed
    set_cfg.sizeThis <- size_of(OrbisCameraConfig).u32()
    set_cfg.configType <- ORBIS_CAMERA_CONFIG_TYPE4
    assert sceCameraSetConfig(h, set_cfg.ref[mutable OrbisCameraConfig&]) == ORBIS_OK
    assert g_camera_output_config0.format.formatLevel0 == ORBIS_CAMERA_FORMAT_RAW16
    assert g_camera_output_config1.format.formatLevel0 == ORBIS_CAMERA_FORMAT_RAW16
    set_cfg.configType <- 99
    assert sceCameraSetConfig(h, set_cfg.ref[mutable OrbisCameraConfig&]) == ORBIS_CAMERA_ERROR_PARAM

@test
def camera_set_video_sync_contract() -> void:
    Camera_DebugResetState()
    open_param: OrbisCameraOpenParameter = zeroed
    h: int = sceCameraOpen(ORBIS_CAMERA_USER_SERVICE_USER_ID_SYSTEM, 0, 0, open_param)
    vs: OrbisCameraVideoSyncParameter = zeroed
    vs.sizeThis <- size_of(OrbisCameraVideoSyncParameter).u32()
    vs.videoSyncMode <- 0
    assert sceCameraSetVideoSync(h, vs) == ORBIS_OK
    vs.videoSyncMode <- 2
    assert sceCameraSetVideoSync(h, vs) == ORBIS_CAMERA_ERROR_PARAM

@test
def camera_set_auto_exposure_gain_sdk_and_target_validation() -> void:
    Camera_DebugResetState()
    open_param: OrbisCameraOpenParameter = zeroed
    h: int = sceCameraOpen(ORBIS_CAMERA_USER_SERVICE_USER_ID_SYSTEM, 0, 0, open_param)

    option: OrbisCameraAutoExposureGainTarget = zeroed
    option.sizeThis <- size_of(OrbisCameraAutoExposureGainTarget).u32()
    option.target <- ORBIS_CAMERA_ATTRIBUTE_AECAGC_TARGET_DEF

    g_camera_firmware_version <- ORBIS_CAMERA_SDK_FW_30 - 1
    assert sceCameraSetAutoExposureGain(h, ORBIS_CAMERA_CHANNEL_0, 0, option) == ORBIS_CAMERA_ERROR_PARAM

    g_camera_firmware_version <- ORBIS_CAMERA_SDK_FW_30
    option.target <- 3
    assert sceCameraSetAutoExposureGain(h, ORBIS_CAMERA_CHANNEL_0, 0, option) == ORBIS_CAMERA_ERROR_PARAM

    option.target <- ORBIS_CAMERA_ATTRIBUTE_AECAGC_TARGET_2_0
    assert sceCameraSetAutoExposureGain(h, ORBIS_CAMERA_CHANNEL_0, 0, option) == ORBIS_CAMERA_ERROR_NOT_CONNECTED

@test
def camera_set_sharpness_sdk_validation() -> void:
    Camera_DebugResetState()
    open_param: OrbisCameraOpenParameter = zeroed
    h: int = sceCameraOpen(ORBIS_CAMERA_USER_SERVICE_USER_ID_SYSTEM, 0, 0, open_param)

    g_camera_firmware_version <- ORBIS_CAMERA_SDK_FW_35
    assert sceCameraSetSharpness(h, ORBIS_CAMERA_CHANNEL_0, 11, null) == ORBIS_CAMERA_ERROR_PARAM
    assert sceCameraSetSharpness(h, ORBIS_CAMERA_CHANNEL_0, 10, null) == ORBIS_CAMERA_ERROR_NOT_CONNECTED

@test
def camera_start_format_level_validation() -> void:
    Camera_DebugResetState()
    open_param: OrbisCameraOpenParameter = zeroed
    h: int = sceCameraOpen(ORBIS_CAMERA_USER_SERVICE_USER_ID_SYSTEM, 0, 0, open_param)

    p: OrbisCameraStartParameter = zeroed
    p.sizeThis <- size_of(OrbisCameraStartParameter).u32()
    p.formatLevel[0] <- 0
    p.formatLevel[1] <- 0

    g_camera_firmware_version <- 0x02500000
    assert sceCameraStart(h, p) == ORBIS_CAMERA_ERROR_FORMAT_UNKNOWN
    p.formatLevel[0] <- 1
    p.formatLevel[1] <- 1
    assert sceCameraStart(h, p) == ORBIS_CAMERA_ERROR_NOT_CONNECTED

@test
def camera_start_and_frame_ready_runtime_model() -> void:
    Camera_DebugResetState()
    open_param: OrbisCameraOpenParameter = zeroed
    h: int = sceCameraOpen(ORBIS_CAMERA_USER_SERVICE_USER_ID_SYSTEM, 0, 0, open_param)
    p: OrbisCameraStartParameter = zeroed
    p.sizeThis <- size_of(OrbisCameraStartParameter).u32()
    p.formatLevel[0] <- 1
    p.formatLevel[1] <- 1

    Camera_DebugSetBackendConnected(true)
    assert sceCameraStart(h, p) == ORBIS_OK

    frame: OrbisCameraFrameData = zeroed
    frame.sizeThis <- size_of(OrbisCameraFrameData).u32()
    assert sceCameraGetFrameData(h, frame.ref[mutable OrbisCameraFrameData&]) == ORBIS_CAMERA_ERROR_BUSY
    Camera_DebugSetFrameReady(true)
    assert sceCameraGetFrameData(h, frame.ref[mutable OrbisCameraFrameData&]) == ORBIS_OK
    assert frame.meta.format[0] == ORBIS_CAMERA_FORMAT_YUV422
    assert frame.meta.format[1] == ORBIS_CAMERA_FORMAT_RAW16

@test
def camera_get_device_info_open_and_param_contract() -> void:
    Camera_DebugResetState()
    info: OrbisCameraDeviceInfo = zeroed
    info.sizeThis <- size_of(OrbisCameraDeviceInfo).u32()
    info.infoRevision <- 1
    assert sceCameraGetDeviceInfo(0, info.ref[mutable OrbisCameraDeviceInfo&]) == ORBIS_CAMERA_ERROR_NOT_INIT

    open_param: OrbisCameraOpenParameter = zeroed
    _ = sceCameraOpen(ORBIS_CAMERA_USER_SERVICE_USER_ID_SYSTEM, 0, 0, open_param)
    info.infoRevision <- 2
    assert sceCameraGetDeviceInfo(0, info.ref[mutable OrbisCameraDeviceInfo&]) == ORBIS_CAMERA_ERROR_PARAM
    info.infoRevision <- 1
    assert sceCameraGetDeviceInfo(0, info.ref[mutable OrbisCameraDeviceInfo&]) == ORBIS_CAMERA_ERROR_NOT_CONNECTED

@test
def camera_set_config_type5_sdk_gate() -> void:
    Camera_DebugResetState()
    open_param: OrbisCameraOpenParameter = zeroed
    h: int = sceCameraOpen(ORBIS_CAMERA_USER_SERVICE_USER_ID_SYSTEM, 0, 0, open_param)
    cfg: OrbisCameraConfig = zeroed
    cfg.sizeThis <- size_of(OrbisCameraConfig).u32()
    cfg.configType <- ORBIS_CAMERA_CONFIG_TYPE5

    g_camera_firmware_version <- ORBIS_CAMERA_SDK_FW_45 - 1
    assert sceCameraSetConfig(h, cfg.ref[mutable OrbisCameraConfig&]) == ORBIS_CAMERA_ERROR_UNKNOWN_CONFIG
    g_camera_firmware_version <- ORBIS_CAMERA_SDK_FW_45
    assert sceCameraSetConfig(h, cfg.ref[mutable OrbisCameraConfig&]) == ORBIS_OK
    assert g_camera_output_config0.format.formatLevel0 == ORBIS_CAMERA_FORMAT_YUV422
    assert g_camera_output_config1.format.formatLevel0 == ORBIS_CAMERA_FORMAT_RAW16
