include "../shader_recompiler/specialization.elisa"
include "../../compiler/runtime/elisacore_std/elisacore_runtime.elisa"

@test
def buffer_conditional_equality() -> void:
    can Abort.Panic:
        # (1) Differ only in data_format, but is_formatted=0 on both -> Equal.
        a: mutable BufferSpecialization = zeroed
        b: mutable BufferSpecialization = zeroed
        a.stride <- 32u32
        b.stride <- 32u32
        a.is_storage <- 1u32
        b.is_storage <- 1u32
        a.data_format <- 3u32
        b.data_format <- 7u32
        assert BufferSpecialization_Equal(a.ref[BufferSpecialization&], b.ref[BufferSpecialization&]) == true

        # (2) Same two, now with is_formatted=1 on both -> data_format compared -> not Equal.
        a.is_formatted <- 1u32
        b.is_formatted <- 1u32
        assert BufferSpecialization_Equal(a.ref[BufferSpecialization&], b.ref[BufferSpecialization&]) == false

        # Make data_format match -> Equal again.
        b.data_format <- 3u32
        assert BufferSpecialization_Equal(a.ref[BufferSpecialization&], b.ref[BufferSpecialization&]) == true

@test
def buffer_swizzle_gating() -> void:
    can Abort.Panic:
        # (3) Differ in index_stride/element_size, swizzle_enable=0 -> ignored -> Equal.
        a: mutable BufferSpecialization = zeroed
        b: mutable BufferSpecialization = zeroed
        a.index_stride <- 1u32
        b.index_stride <- 2u32
        a.element_size <- 1u32
        b.element_size <- 3u32
        assert BufferSpecialization_Equal(a.ref[BufferSpecialization&], b.ref[BufferSpecialization&]) == true

        # Enable swizzle on both -> swizzle fields now compared -> not Equal.
        a.swizzle_enable <- 1u32
        b.swizzle_enable <- 1u32
        assert BufferSpecialization_Equal(a.ref[BufferSpecialization&], b.ref[BufferSpecialization&]) == false

@test
def fmask_equality() -> void:
    can Abort.Panic:
        a: mutable FMaskSpecialization = zeroed
        b: mutable FMaskSpecialization = zeroed
        a.width <- 64u32
        a.height <- 32u32
        b.width <- 64u32
        b.height <- 32u32
        assert FMaskSpecialization_Equal(a.ref[FMaskSpecialization&], b.ref[FMaskSpecialization&]) == true
        b.height <- 16u32
        assert FMaskSpecialization_Equal(a.ref[FMaskSpecialization&], b.ref[FMaskSpecialization&]) == false

@test
def sampler_equality() -> void:
    can Abort.Panic:
        a: mutable SamplerSpecialization = zeroed
        b: mutable SamplerSpecialization = zeroed
        a.force_unnormalized <- true
        b.force_unnormalized <- true
        assert SamplerSpecialization_Equal(a.ref[SamplerSpecialization&], b.ref[SamplerSpecialization&]) == true
        b.force_degamma <- true
        assert SamplerSpecialization_Equal(a.ref[SamplerSpecialization&], b.ref[SamplerSpecialization&]) == false
