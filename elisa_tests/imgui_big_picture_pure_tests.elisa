include "../../compiler/runtime/elisacore_std/elisacore_runtime.elisa"
include "../imgui/big_picture/big_picture.elisa"
include "../imgui/big_picture/settings_dialog_imgui.elisa"
include "../imgui/big_picture/settings_dialog_layer.elisa"
include "../imgui/big_picture/imgui_impl_sdl3_big_picture.elisa"
include "../imgui/big_picture/imgui_impl_sdlrenderer3.elisa"

@test
def imgui_big_picture_icon_sorting_and_profile_state() -> void:
    can Abort.Panic:
        BigPicture_ResetForTests()
        assert BigPicture_AddIconForTests("Zeta", "CUSAZ", "/tmp/zeta") == 0
        assert BigPicture_AddIconForTests("Alpha", "CUSAA", "/tmp/alpha") == 0
        assert GetGameIconInfo() == 2

        t0: static u8&? = BigPicture_GetIconTitleAtForTests(0)
        t1_name: static u8&? = BigPicture_GetIconTitleAtForTests(1)
        assert t0 != null
        assert t1_name != null
        assert strcmp(t0.cast[u8&], "Alpha") == 0
        assert strcmp(t1_name.cast[u8&], "Zeta") == 0

@test
def imgui_big_picture_icon_selection_triggers_launch_state() -> void:
    can Abort.Panic:
        BigPicture_ResetForTests()
        assert BigPicture_AddIconForTests("Alpha", "CUSAA", "/tmp/alpha") == 0
        blob: mutable u8[4] = zeroed
        tex: void&? = LoadSdlTextureData(blob.ref[mutable u8&].cast[void&?], 4)
        assert tex != null
        gameIcons[0].textureId <- tex
        done <- false
        runEbootPath <- null
        BigPicture_SelectIconForTests(0)
        SetGameIcons(1)
        assert done == true
        assert runEbootPath != null
        assert runEbootPath == "/tmp/alpha"

@test
def imgui_big_picture_settings_window_category_navigation() -> void:
    can Abort.Panic:
        window: mutable SettingsWindow = SettingsWindow_Create(false)
        assert window.currentCategory == SETTINGS_CATEGORY_PROFILES
        assert window.currentProfile != null
        assert strcmp(window.currentProfile.cast[u8&], "Global") == 0

        SettingsWindow_CycleCategoryNext(window.ref[mutable SettingsWindow&])
        assert window.currentCategory == SETTINGS_CATEGORY_GENERAL

        SettingsWindow_CycleCategoryPrev(window.ref[mutable SettingsWindow&])
        assert window.currentCategory == SETTINGS_CATEGORY_PROFILES

        SettingsWindow_LoadSettings(window.ref[mutable SettingsWindow&], "CUSA00001 - Demo")
        assert window.currentProfile != null
        assert strcmp(window.currentProfile.cast[u8&], "CUSA00001 - Demo") == 0
        assert SettingsWindow_CategoryLast(window.ref[mutable SettingsWindow&]) == SETTINGS_CATEGORY_EXPERIMENTAL

@test
def imgui_big_picture_settings_layer_lifecycle() -> void:
    can Abort.Panic:
        SettingsLayer_ResetForTests()
        OpenInGameSettingsDialog()
        assert g_settings_layer_has_value == true
        assert g_settings_running == true

        OpenInGameSettingsDialog()
        assert g_settings_layer_has_value == true

        g_settings_running <- false
        SettingsLayer_Draw()
        assert g_settings_layer_has_value == false

@test
def imgui_big_picture_save_apply_cancel_flow() -> void:
    can Abort.Panic:
        window: mutable SettingsWindow = SettingsWindow_Create(true)
        open: mutable bool = true

        SettingsWindow_DrawMainContent(window.ref[mutable SettingsWindow&], open.ref[mutable bool&], false, true, false)
        assert open == true
        assert window.closeOnSave == false

        SettingsWindow_DrawMainContent(window.ref[mutable SettingsWindow&], open.ref[mutable bool&], true, false, false)
        assert open == false
        assert window.closeOnSave == false

        open <- true
        SettingsWindow_DrawMainContent(window.ref[mutable SettingsWindow&], open.ref[mutable bool&], false, false, true)
        assert open == false
