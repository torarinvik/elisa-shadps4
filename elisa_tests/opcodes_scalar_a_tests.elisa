include "../shader_recompiler/frontend/opcodes_scalar_a.elisa"
include "../../compiler/runtime/elisacore_std/elisacore_runtime.elisa"

@test def test_opcodes_scalar_a() -> void:
  can Abort.Panic:
    assert(OPCODE_SOP2_S_ADD_U32 == 0u32)
    assert(OPCODE_SOP2_S_MUL_I32 == 38u32)
    assert(OPCODE_SOP2_OP_RANGE_SOP2 == 45u32)
    assert(OPCODE_SOPK_S_MOVK_I32 == 0u32)
    assert(OPCODE_SOPK_OP_RANGE_SOPK == 22u32)
    assert(OPCODE_SOP1_S_MOV_B32 == 3u32)
    assert(OPCODE_SOP1_OP_RANGE_SOP1 == 54u32)
