include "../shader_recompiler/frontend/tessellation.elisa"
include "../../compiler/runtime/elisacore_std/elisacore_runtime.elisa"

@test
def tess_constant_buffer_roundtrip() -> void:
    can Abort.Panic:
        tcb: mutable TessellationDataConstantBuffer = zeroed
        tcb.ls_stride <- 16u32
        tcb.num_patches <- 4u32
        tcb.patch_const_size <- 64u32
        tcb.off_chip_tessellation_factor_threshold <- 0.5f32
        tcb.first_edge_tess_factor_index <- 9u32
        assert tcb.ls_stride == 16u32
        assert tcb.num_patches == 4u32
        assert tcb.patch_const_size == 64u32
        assert tcb.off_chip_tessellation_factor_threshold == 0.5f32
        assert tcb.first_edge_tess_factor_index == 9u32

@test
def tess_constant_attributes_are_sequential() -> void:
    can Abort.Panic:
        assert TESS_CONST_ATTR_LS_STRIDE == 0u32
        assert TESS_CONST_ATTR_HS_NUM_PATCH == 2u32
        assert TESS_CONST_ATTR_PATCH_OUTPUT_SIZE == 6u32
        assert TESS_CONST_ATTR_FIRST_EDGE_TESS_FACTOR_INDEX == 8u32
