include "../shader_recompiler/frontend/tessellation.elisa"
include "../../compiler/runtime/elisacore_std/elisacore_runtime.elisa"

@test
def tess_constant_buffer_roundtrip() -> void:
    can Abort.Panic:
        tcb: mutable TessellationDataConstantBuffer = zeroed
        tcb.ls_stride <- 16
        tcb.num_patches <- 4
        tcb.patch_const_size <- 64
        tcb.off_chip_tessellation_factor_threshold <- 0.5
        tcb.first_edge_tess_factor_index <- 9
        assert tcb.ls_stride == 16
        assert tcb.num_patches == 4
        assert tcb.patch_const_size == 64
        assert tcb.off_chip_tessellation_factor_threshold == 0.5
        assert tcb.first_edge_tess_factor_index == 9

@test
def tess_constant_attributes_are_sequential() -> void:
    can Abort.Panic:
        assert TESS_CONST_ATTR_LS_STRIDE == 0
        assert TESS_CONST_ATTR_HS_NUM_PATCH == 2
        assert TESS_CONST_ATTR_PATCH_OUTPUT_SIZE == 6
        assert TESS_CONST_ATTR_FIRST_EDGE_TESS_FACTOR_INDEX == 8
