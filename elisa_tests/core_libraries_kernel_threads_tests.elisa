include "../core/libraries/kernel/time.elisa"
include "../../compiler/runtime/elisacore_std/elisacore_runtime.elisa"
include "../core/libraries/kernel/threads/threads.elisa"

global mutable g_thread_dtor_called: int = 0
global mutable g_tls_dtor_called: int = 0
global mutable g_tls_dtor_data: void&? = null
global mutable g_cleanup_called: int = 0
global mutable g_cleanup_data: void&? = null

def test_thread_dtor_hook() -> void:
    g_thread_dtor_called <- g_thread_dtor_called + 1

def test_tls_destructor(data: void&?) -> void:
    g_tls_dtor_called <- g_tls_dtor_called + 1
    g_tls_dtor_data <- data

def test_cleanup_handler(data: void&?) -> void:
    g_cleanup_called <- g_cleanup_called + 1
    g_cleanup_data <- data

def test_thread_entry(arg: void&?) -> void&?:
    return arg

def main() -> int:
    attr: mutable PthreadAttr&? = null
    init_res: int = posix_pthread_attr_init(attr)
    if init_res != 0:
        return 1

    detach: mutable int = -1
    if posix_pthread_attr_getdetachstate(attr, detach) != 0:
        return 2
    if detach != 0:
        return 3

    if posix_pthread_attr_setdetachstate(attr, 1) != 0:
        return 4

    if posix_pthread_attr_getdetachstate(attr, detach) != 0:
        return 5
    if detach != 1:
        return 6

    if posix_pthread_attr_destroy(attr) != 0:
        return 7

    # C++ parity quirk: setscope currently returns EINVAL for both values.
    attr2: mutable PthreadAttr&? = null
    if posix_pthread_attr_init(attr2) != 0:
        return 24
    if posix_pthread_attr_setscope(attr2, 0) != POSIX_EINVAL:
        return 25
    if posix_pthread_attr_setscope(attr2, 2) != POSIX_EINVAL:
        return 26
    if posix_pthread_attr_setschedpolicy(attr2, 1) != 0:
        return 161
    bad_attr_param: mutable SchedParam = SchedParam(100)
    if posix_pthread_attr_setschedparam(attr2, bad_attr_param) != POSIX_ENOTSUP:
        return 162
    good_attr_param: mutable SchedParam = SchedParam(700)
    if posix_pthread_attr_setschedparam(attr2, good_attr_param) != 0:
        return 163
    attr_mask: mutable u64 = 0u64
    if posix_pthread_attr_getaffinity_np(attr2, 8u64, attr_mask as mutable void&?) != 0:
        return 164
    if attr_mask != 0xffffffffffffffffu64:
        return 165
    new_attr_mask: mutable u64 = 0x55aau64
    if posix_pthread_attr_setaffinity_np(attr2, 8u64, new_attr_mask as void&?) != 0:
        return 166
    if attr2.cpusetsize != 8u64:
        return 167
    attr_mask <- 0u64
    if posix_pthread_attr_getaffinity_np(attr2, 8u64, attr_mask as mutable void&?) != 0:
        return 169
    if attr_mask != new_attr_mask:
        return 170
    if posix_pthread_attr_setaffinity_np(attr2, 0u64, new_attr_mask as void&?) != 0:
        return 171
    if attr2.cpusetsize != 0u64 or attr2.cpuset != null:
        return 172
    if scePthreadAttrSetdetachstate(attr2, 3) != ORBIS_KERNEL_ERROR_EINVAL:
        return 176
    if scePthreadAttrSetschedparam(attr2, null) != ORBIS_KERNEL_ERROR_ENOTSUP:
        return 177
    if scePthreadAttrSetstacksize(attr2, 1u64) != ORBIS_KERNEL_ERROR_EINVAL:
        return 178
    sce_attr_mask: mutable u64 = 0u64
    if scePthreadAttrGetaffinity(null, sce_attr_mask) != ORBIS_KERNEL_ERROR_EINVAL:
        return 179
    if scePthreadAttrSetaffinity(null, 0xffffu64) != ORBIS_KERNEL_ERROR_EINVAL:
        return 180

    mattr: mutable PthreadMutexAttr&? = null
    if posix_pthread_mutexattr_init(mattr) != 0:
        return 27
    if posix_pthread_mutexattr_setprotocol(mattr, 3) != POSIX_EINVAL:
        return 28
    if posix_pthread_mutexattr_setprotocol(mattr, 2) != 0:
        return 29
    if posix_pthread_mutexattr_setprioceiling(mattr, 800) != POSIX_EINVAL:
        return 133
    if posix_pthread_mutexattr_setprioceiling(mattr, 700) != 0:
        return 134
    if posix_pthread_mutexattr_settype(mattr, 5) != POSIX_EINVAL:
        return 135
    if posix_pthread_mutexattr_settype(mattr, 4) != 0:
        return 136

    cattr: mutable PthreadCondAttr&? = null
    if posix_pthread_condattr_init(cattr) != 0:
        return 30
    if posix_pthread_condattr_setclock(cattr, 3) != POSIX_EINVAL:
        return 31
    if posix_pthread_condattr_setclock(cattr, 4) != 0:
        return 32

    cond: mutable PthreadCond&? = null
    if posix_pthread_cond_init(cond, cattr) != 0:
        return 33
    empty_cond: mutable PthreadCond&? = null
    if posix_pthread_cond_destroy(empty_cond) != 0:
        return 197
    bad_cond_init: mutable PthreadCond&? = null
    if scePthreadCondInit(bad_cond_init, cattr, null) != 0:
        return 188
    mtx: mutable PthreadMutex&? = null
    if posix_pthread_mutex_init(mtx, mattr) != 0:
        return 34
    empty_mtx: mutable PthreadMutex&? = null
    if posix_pthread_mutex_destroy(empty_mtx) != 0:
        return 198
    bad_mtx_init: mutable PthreadMutex&? = null
    bad_init_attr: mutable PthreadMutexAttr = PthreadMutexAttr(5, 0, 0)
    if scePthreadMutexInit(bad_mtx_init, bad_init_attr, null) != ORBIS_KERNEL_ERROR_EINVAL:
        return 189
    if mtx.spinloops != 2000:
        return 137
    if posix_pthread_cond_wait(cond, mtx) != POSIX_EPERM:
        return 35
    if posix_pthread_mutex_lock(mtx) != 0:
        return 36
    if posix_pthread_cond_timedwait(cond, mtx, null) != POSIX_EINVAL:
        return 37
    bad_cond_ts: mutable OrbisKernelTimespec = OrbisKernelTimespec(0, 1000000000)
    if posix_pthread_cond_timedwait(cond, mtx, bad_cond_ts as void&?) != POSIX_EINVAL:
        return 138
    if posix_pthread_mutex_timedlock(mtx, bad_cond_ts as void&?) != POSIX_EINVAL:
        return 139

    sem_id: mutable int = -1
    sem_create: int = sceKernelCreateSema(sem_id, "t", 0u32, 1, 2, null)
    if sem_create != ORBIS_OK:
        return 8
    if sceKernelWaitSema(sem_id, 1, null) != ORBIS_OK:
        return 53
    if sceKernelPollSema(sem_id, 1) != ORBIS_KERNEL_ERROR_EBUSY:
        return 9
    if sceKernelSignalSema(sem_id, 1) != ORBIS_OK:
        return 10
    if sceKernelPollSema(sem_id, 1) != ORBIS_OK:
        return 11
    if sceKernelSignalSema(sem_id, 1) != ORBIS_OK:
        return 12
    if sceKernelWaitSema(sem_id, 0, null) != ORBIS_OK:
        return 108
    if sceKernelPollSema(sem_id, 0) != ORBIS_OK:
        return 109
    if sceKernelSignalSema(sem_id, -1) != ORBIS_OK:
        return 110
    sem_timeout: mutable u32 = 7u32
    if sceKernelWaitSema(sem_id, 2, sem_timeout) != ORBIS_KERNEL_ERROR_ETIMEDOUT:
        return 141
    if sem_timeout != 0u32:
        return 142
    if sceKernelDeleteSema(sem_id) != ORBIS_OK:
        return 54
    if sceKernelCancelSema(sem_id, 0, null) != ORBIS_KERNEL_ERROR_ESRCH:
        return 45

    bad_sem: mutable PthreadSem&? = null
    if scePthreadSemWait(bad_sem) != ORBIS_KERNEL_ERROR_EINVAL:
        return 46
    if scePthreadSemTrywait(bad_sem) != ORBIS_KERNEL_ERROR_EINVAL:
        return 47
    if scePthreadSemTimedwait(bad_sem, 1u32) != ORBIS_KERNEL_ERROR_EINVAL:
        return 48
    if scePthreadSemPost(bad_sem) != ORBIS_KERNEL_ERROR_EINVAL:
        return 49
    sem_obj: mutable PthreadSem&? = null
    if posix_sem_init(sem_obj, 0, 2u32) != 0:
        return 103
    if posix_sem_getvalue(sem_obj, null) != 0:
        return 104
    sem_value: mutable int = 0
    if scePthreadSemGetvalue(sem_obj, sem_value) != ORBIS_OK:
        return 105
    if sem_value != 2:
        return 106
    if scePthreadSemGetvalue(sem_obj, null) != ORBIS_OK:
        return 107

    key: mutable int = -1
    if posix_pthread_key_create(key, null) != 0:
        return 13
    if posix_pthread_setspecific(key, 0x1234 as void&?) != 0:
        return 14
    got: void&? = posix_pthread_getspecific(key)
    if got == null:
        return 15
    if posix_pthread_key_delete(key) != 0:
        return 16

    cleanup_arg: void&? = 0x2468 as void&?
    posix_pthread_cleanup_push(test_cleanup_handler.cast[void&], cleanup_arg)
    posix_pthread_cleanup_pop(0)
    if g_cleanup_called != 0:
        return 148
    posix_pthread_cleanup_push(test_cleanup_handler.cast[void&], cleanup_arg)
    posix_pthread_cleanup_pop(1)
    if g_cleanup_called != 1:
        return 149
    if g_cleanup_data != cleanup_arg:
        return 150

    tls_key: mutable int = -1
    tls_data: void&? = 0x4321 as void&?
    if posix_pthread_key_create(tls_key, test_tls_destructor.cast[void&]) != 0:
        return 115
    if posix_pthread_setspecific(tls_key, tls_data) != 0:
        return 116
    if posix_pthread_getspecific(tls_key) != tls_data:
        return 117
    stale_key: mutable int = -1
    stale_data: void&? = 0x8765 as void&?
    if posix_pthread_key_create(stale_key, test_tls_destructor.cast[void&]) != 0:
        return 118
    if posix_pthread_setspecific(stale_key, stale_data) != 0:
        return 119
    if posix_pthread_key_delete(stale_key) != 0:
        return 120
    if posix_pthread_getspecific(stale_key) != null:
        return 121
    if scePthreadKeyDelete(stale_key) != threads_posix_to_orbis_errno(POSIX_EINVAL):
        return 127
    if scePthreadSetspecific(stale_key, stale_data) != threads_posix_to_orbis_errno(POSIX_EINVAL):
        return 128

    ev: mutable int = -1
    if sceKernelCreateEventFlag(ev, "ev", 0u32, 0u64, null) != ORBIS_OK:
        return 17
    bad_ev: mutable int = -1
    if sceKernelCreateEventFlag(bad_ev, "bad", 0x23u32, 0u64, null) != ORBIS_KERNEL_ERROR_EINVAL:
        return 50
    long_ev: mutable int = -1
    if sceKernelCreateEventFlag(long_ev, "12345678901234567890123456789012", 0u32, 0u64, null) != ORBIS_KERNEL_ERROR_ENAMETOOLONG:
        return 140
    if sceKernelSetEventFlag(ev, 0x2u64) != ORBIS_OK:
        return 18
    out_pat: mutable u64 = 0u64
    if sceKernelPollEventFlag(ev, 0x2u64, 0x02u32, out_pat) != ORBIS_OK:
        return 19
    if sceKernelPollEventFlag(ev, 0x2u64, 0x03u32, out_pat) != ORBIS_KERNEL_ERROR_EINVAL:
        return 51
    if sceKernelPollEventFlag(ev, 0x2u64, 0x32u32, out_pat) != ORBIS_KERNEL_ERROR_EINVAL:
        return 52
    timeout_us: mutable u32 = 1u32
    if sceKernelWaitEventFlag(ev, 0x2u64, 0x03u32, out_pat, timeout_us) != ORBIS_KERNEL_ERROR_EINVAL:
        return 55
    miss_timeout: mutable u32 = 5u32
    if sceKernelWaitEventFlag(ev, 0x8u64, 0x02u32, null, miss_timeout) != ORBIS_KERNEL_ERROR_ETIMEDOUT:
        return 143
    if miss_timeout != 0u32:
        return 144
    waiters: mutable int = -1
    if sceKernelCancelEventFlag(ev, 0x4u64, null) != ORBIS_OK:
        return 145
    if sceKernelCancelEventFlag(ev, 0x4u64, waiters) != ORBIS_OK:
        return 146
    if waiters != 0:
        return 147
    if sceKernelDeleteEventFlag(ev) != ORBIS_OK:
        return 20

    if sceKernelInstallExceptionHandler(30, null) != ORBIS_OK:
        return 21
    if sceKernelInstallExceptionHandler(2, null) != ORBIS_KERNEL_ERROR_EINVAL:
        return 41
    if sceKernelInstallExceptionHandler(30, null) != ORBIS_KERNEL_ERROR_EAGAIN:
        return 42
    if sceKernelRaiseException(null, 30) != ORBIS_OK:
        return 22
    if sceKernelRaiseException(null, 2) != ORBIS_KERNEL_ERROR_EINVAL:
        return 43
    if sceKernelRemoveExceptionHandler(30) != ORBIS_OK:
        return 23
    if sceKernelRemoveExceptionHandler(2) != ORBIS_KERNEL_ERROR_EINVAL:
        return 44

    rw: mutable PthreadRwlock&? = null
    if posix_pthread_rwlock_destroy(rw) != 0:
        return 38
    rwa: mutable PthreadRwlockAttr&? = null
    if posix_pthread_rwlockattr_init(rwa) != 0:
        return 39
    rwa.type_ <- 3
    if posix_pthread_rwlockattr_settype_np(rwa, 1) != POSIX_EINVAL:
        return 40
    invalid_rw: mutable PthreadRwlock&? = null
    if posix_pthread_rwlock_init(invalid_rw, rwa) != POSIX_EINVAL:
        return 153
    rwa.type_ <- 0
    busy_rw: mutable PthreadRwlock&? = null
    if posix_pthread_rwlock_init(busy_rw, rwa) != 0:
        return 154
    if posix_pthread_rwlock_wrlock(busy_rw) != 0:
        return 155
    if posix_pthread_rwlock_timedrdlock(busy_rw, bad_cond_ts as void&?) != POSIX_EINVAL:
        return 156
    if posix_pthread_rwlock_unlock(busy_rw) != 0:
        return 157
    if posix_pthread_rwlock_rdlock(busy_rw) != 0:
        return 158
    if posix_pthread_rwlock_timedwrlock(busy_rw, bad_cond_ts as void&?) != POSIX_EINVAL:
        return 159
    if posix_pthread_rwlock_unlock(busy_rw) != 0:
        return 160
    if scePthreadMutexLock(null) != ORBIS_KERNEL_ERROR_EINVAL:
        return 190
    bad_mattr2: mutable PthreadMutexAttr&? = null
    if scePthreadMutexattrDestroy(bad_mattr2) != ORBIS_KERNEL_ERROR_EINVAL:
        return 191
    if scePthreadCondWait(cond, null) != ORBIS_KERNEL_ERROR_EINVAL:
        return 192
    if scePthreadCondSignal(null) != ORBIS_KERNEL_ERROR_EINVAL:
        return 193
    if scePthreadCondattrSetclock(cattr, 3) != ORBIS_KERNEL_ERROR_EINVAL:
        return 194
    if scePthreadRwlockUnlock(null) != ORBIS_KERNEL_ERROR_EINVAL:
        return 195
    bad_rwa2: mutable PthreadRwlockAttr&? = null
    if scePthreadRwlockattrDestroy(bad_rwa2) != ORBIS_KERNEL_ERROR_EINVAL:
        return 196

    created_thr: mutable void&? = null
    if posix_pthread_create(created_thr, null, null, null) != 0:
        return 56
    if created_thr == null:
        return 57
    if posix_pthread_setprio(created_thr, 700) != 0:
        return 58
    if posix_pthread_detach(created_thr) != 0:
        return 59
    if posix_pthread_join(created_thr, null) != POSIX_EINVAL:
        return 60
    if posix_pthread_join(posix_pthread_self(), null) != POSIX_EDEADLK:
        return 61
    if posix_pthread_detach(0x7fffffff as void&?) != POSIX_ESRCH:
        return 62
    bad_policy: mutable int = 0
    bad_param: mutable SchedParam = SchedParam(0)
    if posix_pthread_getschedparam(0x7fffffff as void&?, bad_policy, bad_param) != POSIX_ESRCH:
        return 63
    if scePthreadDetach(null) != ORBIS_KERNEL_ERROR_EINVAL:
        return 181
    if scePthreadJoin(null, null) != ORBIS_KERNEL_ERROR_EINVAL:
        return 182
    if scePthreadGetschedparam(0x7fffffff as void&?, bad_policy, bad_param) != ORBIS_KERNEL_ERROR_ESRCH:
        return 183
    if scePthreadGetnameNp(null, null) != ORBIS_KERNEL_ERROR_EINVAL:
        return 184
    if scePthreadSetprio(0x7fffffff as void&?, 700) != ORBIS_KERNEL_ERROR_ESRCH:
        return 185
    if scePthreadGetaffinityOrbis(null, null) != ORBIS_KERNEL_ERROR_EINVAL:
        return 186
    if scePthreadSetaffinityOrbis(null, 0xffffu64) != ORBIS_KERNEL_ERROR_EINVAL:
        return 187
    get_np_attr: mutable PthreadAttr&? = null
    if posix_pthread_attr_init(get_np_attr) != 0:
        return 173
    if posix_pthread_attr_get_np(null, get_np_attr) != POSIX_EINVAL:
        return 174
    if posix_pthread_attr_get_np(0x7fffffff as void&?, get_np_attr) != POSIX_ESRCH:
        return 175
    timed_thr: mutable void&? = null
    g_fake_threads_autocomplete <- false
    if posix_pthread_create(timed_thr, null, null, null) != 0:
        return 64
    timed_id: int = timed_thr as int
    if not g_fake_threads_running[timed_id]:
        return 80
    timed_ret: mutable void&? = null
    past_ts: mutable OrbisKernelTimespec = OrbisKernelTimespec(0, 0)
    future_ts: mutable OrbisKernelTimespec = OrbisKernelTimespec(4102444800, 0)
    bad_nsec_ts: mutable OrbisKernelTimespec = OrbisKernelTimespec(0, 1000000000)
    if posix_pthread_timedjoin_np(null, timed_ret, future_ts as void&?) != POSIX_EINVAL:
        return 75
    self_thr: void&? = posix_pthread_self()
    if posix_pthread_timedjoin_np(self_thr, timed_ret, future_ts as void&?) != POSIX_EDEADLK:
        return 76
    self_policy: mutable int = 0
    self_param: mutable SchedParam = SchedParam(0)
    if posix_pthread_getschedparam(self_thr, self_policy, self_param) != 0:
        return 77
    if posix_pthread_setprio(self_thr, 701) != 0:
        return 78
    if posix_pthread_getname_np(self_thr, null) != POSIX_EINVAL:
        return 79
    name_buf: mutable u8 = 0u8
    if posix_pthread_getname_np(self_thr, name_buf) != 0:
        return 99
    if posix_pthread_rename_np(self_thr, "thr-main") != 0:
        return 100
    if posix_pthread_rename_np(self_thr, null) != POSIX_EINVAL:
        return 102
    if posix_pthread_rename_np(0x7fffffff as void&?, "bad") != POSIX_ESRCH:
        return 101
    if scePthreadGetprio(self_thr, null) != ORBIS_KERNEL_ERROR_EINVAL:
        return 94
    self_prio: mutable int = 0
    if scePthreadGetprio(self_thr, self_prio) != 0:
        return 95
    if scePthreadGetaffinity(self_thr, null) != POSIX_EINVAL:
        return 96
    self_mask: mutable u64 = 0u64
    if scePthreadGetaffinity(self_thr, self_mask) != 0:
        return 97
    if scePthreadSetaffinity(null, 0xffffu64) != POSIX_EINVAL:
        return 98
    old_cancel: mutable int = -1
    if posix_pthread_setcancelstate(1, old_cancel) != 0:
        return 86
    if old_cancel != 0 and old_cancel != 1:
        return 87
    if posix_pthread_setcancelstate(0, null) != 0:
        return 88
    if posix_pthread_setcancelstate(3, old_cancel) != POSIX_EINVAL:
        return 89
    if posix_pthread_setcancelstate(1, null) != 0:
        return 122
    if posix_pthread_cancel(self_thr) != 0:
        return 123
    if g_fake_cancel_pending != true:
        return 124
    named_thr: mutable void&? = null
    if posix_pthread_create_name_np(named_thr, null, null, null, "worker0") != 0:
        return 90
    if named_thr == null:
        return 91
    bad_named_thr: mutable void&? = null
    if posix_pthread_create_name_np(bad_named_thr, null, null, null, null) != 0:
        return 92
    if posix_pthread_create_name_np(null, null, null, null, "bad") != POSIX_EINVAL:
