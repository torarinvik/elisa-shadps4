    if posix_pthread_timedjoin_np(timed_thr, timed_ret, null) != POSIX_EINVAL:
        return 65
    if posix_pthread_timedjoin_np(timed_thr, timed_ret, bad_nsec_ts as void&?) != POSIX_EINVAL:
        return 129
    if posix_pthread_timedjoin_np(timed_thr, timed_ret, past_ts as void&?) != POSIX_ETIMEDOUT:
        return 66
    g_fake_threads_autocomplete <- true

    done_thr: mutable void&? = null
    done_arg: void&? = 0x1234 as void&?
    if posix_pthread_create(done_thr, null, null, done_arg) != 0:
        return 67
    done_id: int = done_thr as int
    if g_fake_threads_running[done_id]:
        return 81
    done_ret: mutable void&? = null
    if posix_pthread_join(done_thr, done_ret) != 0:
        return 68
    if done_ret != done_arg:
        return 69
    if posix_pthread_join(done_thr, done_ret) != POSIX_ESRCH:
        return 71

    detached_done_thr: mutable void&? = null
    if posix_pthread_create(detached_done_thr, null, null, null) != 0:
        return 72
    if posix_pthread_detach(detached_done_thr) != 0:
        return 73
    if posix_pthread_join(detached_done_thr, null) != POSIX_ESRCH:
        return 74

    create_detached_attr: mutable PthreadAttr&? = null
    if posix_pthread_attr_init(create_detached_attr) != 0:
        return 82
    if posix_pthread_attr_setdetachstate(create_detached_attr, 1) != 0:
        return 83
    detached_from_attr_thr: mutable void&? = null
    if posix_pthread_create(detached_from_attr_thr, create_detached_attr as void&?, null, null) != 0:
        return 84
    if posix_pthread_join(detached_from_attr_thr, null) != POSIX_EINVAL:
        return 85

    real_thr: mutable void&? = null
    real_arg: void&? = 0x5678 as void&?
    if posix_pthread_create(real_thr, null, test_thread_entry.cast[void&], real_arg) != 0:
        return 111
    if real_thr == null:
        return 112
    real_ret: mutable void&? = null
    if posix_pthread_join(real_thr, real_ret) != 0:
        return 113
    if real_ret != real_arg:
        return 114
    timed_real_thr: mutable void&? = null
    timed_real_arg: void&? = 0x9876 as void&?
    if posix_pthread_create(timed_real_thr, null, test_thread_entry.cast[void&], timed_real_arg) != 0:
        return 130
    timed_real_ret: mutable void&? = null
    if posix_pthread_timedjoin_np(timed_real_thr, timed_real_ret, future_ts as void&?) != 0:
        return 131
    if timed_real_ret != timed_real_arg:
        return 132

    g_thread_dtor_called <- 0
    g_tls_dtor_called <- 0
    g_tls_dtor_data <- null
    g_cleanup_called <- 0
    g_cleanup_data <- null
    exit_cleanup_arg: void&? = 0x1357 as void&?
    posix_pthread_cleanup_push(test_cleanup_handler.cast[void&], exit_cleanup_arg)
    _sceKernelSetThreadDtors(test_thread_dtor_hook)
    posix_pthread_exit(null)
    if g_cleanup_called != 1:
        return 151
    if g_cleanup_data != exit_cleanup_arg:
        return 152
    if g_thread_dtor_called != 1:
        return 70
    if g_tls_dtor_called != 1:
        return 125
    if g_tls_dtor_data != tls_data:
        return 126

    return 0
