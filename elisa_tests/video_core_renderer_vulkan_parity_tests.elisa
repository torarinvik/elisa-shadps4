@test
def video_core_cache_storage_and_renderdoc_contracts() -> void:
    can Abort.Panic, Memory.Allocate:
        db: mutable DataBase& = DataBase_Instance()
        DataBase_Open(db, "cache", false)
        assert DataBase_IsOpened(db)

        bytes: darray[u8] = [1, 2, 3]
        words: darray[u32] = [11, 22, 33]
        assert DataBase_SaveBytes(db, BlobType.ShaderMeta, "meta_a", bytes)
        assert DataBase_SaveWords(db, BlobType.ShaderBinary, "bin_a", words)

        loaded_bytes: darray[u8] = DataBase_LoadBytes(db, BlobType.ShaderMeta, "meta_a")
        loaded_words: darray[u32] = DataBase_LoadWords(db, BlobType.ShaderBinary, "bin_a")
        assert loaded_bytes.count == 3
        assert loaded_words.count == 3

        bucket: mutable darray[darray[u8]] = []
        DataBase_ForEachBlob(db, BlobType.ShaderMeta, bucket)
        assert bucket.count == 1

        DataBase_FinishPreload(db)
        assert db.preload_finished
        DataBase_Close(db)
        assert not DataBase_IsOpened(db)

        LoadRenderDoc()
        assert IsRenderDocLoaded()
        TriggerCapture()
        StartCapture()
        assert g_capture_state == CaptureState.InProgress
        EndCapture()
        assert g_capture_state == CaptureState.Idle
        RequestScreenshot(ScreenshotRequest.GameOnly)
        RequestScreenshot(ScreenshotRequest.WithOverlays)
        counts: ScreenshotRequests = ConsumeScreenshotRequests()
        assert counts.game_only_count == 1
        assert counts.with_overlays_count == 1

@test
def video_core_page_manager_and_mapping_contracts() -> void:
    can Abort.Panic, Memory.Allocate:
        pm: mutable PageManager = PageManager_New()
        PageManager_OnGpuMap(pm, 0x10000, 0x5000)
        assert PageManager_IsMapped(pm, 0x10000, 0x1000)

        PageManager_UpdatePageWatchers_TrackWrite(pm, 0x10000, 0x3000)
        assert pm.protect_events.count > 0

        bits: mutable RegionBits = zeroed
        RegionBits_Clear(bits)
        RegionBits_SetRange(bits, 1, 4)
        PageManager_UpdatePageWatchersForRegion(pm, 0x10000, bits, true, true)
        assert pm.states.count >= 3

        PageManager_OnGpuUnmap(pm, 0x10000, 0x5000)
        assert not PageManager_IsMapped(pm, 0x10000, 0x1000)

@test
def video_core_liverpool_and_instance_contracts() -> void:
    can Abort.Panic, Memory.Allocate:
        assert PrimitiveType(AMD_PRIM_TRIANGLE_LIST) == 3
        assert IsDualSourceBlendFactor(AMD_BLEND_SRC1_ALPHA)
        fmt: u32 = SurfaceFormat(AMD_DATA_FORMAT_8_8_8_8, AMD_NUMBER_UNORM)
        assert fmt == VK_FORMAT_R8G8B8A8_UNORM
        depth_fmt: u32 = DepthFormat(AMD_Z_32, AMD_STENCIL_8)
        assert depth_fmt == VK_FORMAT_D32_SFLOAT_S8_UINT
        assert NumSamples(4, VK_SAMPLE_COUNT_4 | VK_SAMPLE_COUNT_1) == VK_SAMPLE_COUNT_4

        inst: mutable Instance = Instance_NewWithWindow(WindowSystemType.X11, 0, true, false, true)
        assert inst.instance_handle != 0
        assert Instance_IsShaderInt16Supported(inst)
        assert Instance_IsDynamicColorWriteMaskSupported(inst)
        assert Instance_IsFormatSupported(inst, VK_FORMAT_R8G8B8A8_UNORM, 0xffff)

        fallback: u32 = Instance_GetSupportedFormat(inst, VK_FORMAT_R8G8B8A8_SRGB, 0xffff)
        assert fallback == VK_FORMAT_R8G8B8A8_SRGB or fallback == VK_FORMAT_R8G8B8A8_UNORM

@test
def video_core_sync_pool_scheduler_contracts() -> void:
    can Abort.Panic, Memory.Allocate:
        sem: mutable MasterSemaphore = MasterSemaphore_New()
        tick0: u64 = MasterSemaphore_CurrentTick(sem)
        tick1: u64 = MasterSemaphore_NextTick(sem)
        assert tick1 == tick0
        MasterSemaphore_Refresh(sem, tick1)
        assert MasterSemaphore_IsFree(sem, tick1)

        cmd_pool: mutable CommandPool = CommandPool_New(sem, 2)
        cmd_a: u64 = CommandPool_Commit(cmd_pool)
        cmd_b: u64 = CommandPool_Commit(cmd_pool)
        assert cmd_a != 0
        assert cmd_b != 0

        descriptor_heap: mutable DescriptorHeap = DescriptorHeap_New(sem, 64)
        set_a: u64 = DescriptorHeap_Commit(descriptor_heap, 0x11)
        set_b: u64 = DescriptorHeap_Commit(descriptor_heap, 0x11)
        assert set_a != set_b

        inst: Instance = Instance_New()
        sched: mutable Scheduler = Scheduler_New(inst)
        ds: mutable DynamicState& = &sched.dynamic_state
        DynamicState_SetDepthTestEnabled(ds, true)
        committed: u32 = DynamicState_Commit(ds, inst, sched.current_cmdbuf)
        assert committed > 0

        submit_info: mutable SubmitInfo = SubmitInfo_New()
        submitted_tick: u64 = Scheduler_Flush(sched, submit_info)
        assert submitted_tick >= 1
        Scheduler_Wait(sched, submitted_tick)

@test
def video_core_pipeline_cache_and_shader_contracts() -> void:
    can Abort.Panic, Memory.Allocate:
        inst: Instance = Instance_New()
        sched: mutable Scheduler = Scheduler_New(inst)
        cache: mutable PipelineCache = PipelineCache_New(inst, sched)

        gkey: mutable GraphicsPipelineKey = GraphicsPipelineKey_Default()
        gkey.stage_hashes[0] <- 0x1111
        gkey.stage_hashes[3] <- 0x2222
        gkey.mrt_mask <- 0x1
        PipelineCache_SetGraphicsKey(cache, gkey)
        gp_opt: GraphicsPipeline? = PipelineCache_GetGraphicsPipeline(cache)
        assert gp_opt != null
        gp: GraphicsPipeline = gp_opt.value()
        assert GraphicsPipeline_Handle(gp) != 0

        ckey: ComputePipelineKey = ComputePipelineKey(0x55)
        PipelineCache_SetComputeKey(cache, ckey)
        cp_opt: ComputePipeline? = PipelineCache_GetComputePipeline(cache)
        assert cp_opt != null
        cp: ComputePipeline = cp_opt.value()
        assert ComputePipeline_Handle(cp) != 0

        pr: ProgramResult = PipelineCache_GetProgram(cache, ShaderStage.Compute, LogicalStage.Compute, 0xabcdef)
        assert pr.module != 0

        spv_module: u64 = CompileSPV([0x07230203, 0, 0, 0], inst.device_handle)
        assert spv_module != 0
        glsl_module: u64 = Compile("void main(){}", ShaderStage.Fragment.u32(), inst.device_handle)
        assert glsl_module != 0

        replaced: u64 = PipelineCache_ReplaceShader(cache, pr.module, [1, 2]) else 0
        assert replaced != 0

        RegisterPipelineDataCompute(ckey, ComputePipelineSerializationSupport_Default())
        RegisterPipelineDataGraphics(gkey, 0x1234, GraphicsPipelineSerializationSupport_Default())
        RegisterShaderMeta(pr.info, null, pr.perm_hash, 0)
        RegisterShaderBinary([1, 2, 3], pr.info.pgm_hash, 0)

        PipelineCache_Sync(cache)

@test
def video_core_rasterizer_and_presenter_contracts() -> void:
    can Abort.Panic, Memory.Allocate:
        inst: Instance = Instance_NewWithWindow(WindowSystemType.X11, 0, false, false, true)
        sched: mutable Scheduler = Scheduler_New(inst)
        rast: mutable Rasterizer = Rasterizer_New(inst, sched)

        gkey: mutable GraphicsPipelineKey = GraphicsPipelineKey_Default()
        gkey.stage_hashes[0] <- 0x10
        gkey.stage_hashes[3] <- 0x20
        PipelineCache_SetGraphicsKey(rast.pipeline_cache, gkey)

        ckey: ComputePipelineKey = ComputePipelineKey(0x40)
        PipelineCache_SetComputeKey(rast.pipeline_cache, ckey)

        Rasterizer_MapMemory(rast, 0x800000, 0x2000)
        assert Rasterizer_IsMapped(rast, 0x800000, 0x1000)
        assert Rasterizer_InvalidateMemory(rast, 0x800000, 0x1000)

        Rasterizer_Draw(rast, false)
        Rasterizer_DrawIndirect(rast, true, 0x900000, 0, 16, 1, 0)

        rast.cs_program <- ComputeProgram(4, 1, 1)
        Rasterizer_DispatchDirect(rast)
        Rasterizer_DispatchIndirect(rast, 0x810000, 0, 12)
        tick: u64 = Rasterizer_Flush(rast)
        assert tick >= 1
        Rasterizer_OnSubmit(rast)

        presenter: mutable Presenter = Presenter_New(WindowSystemType.X11, 1280, 720, true)
        attr: VideoOutBufferAttributeGroup = VideoOutBufferAttributeGroup(1280, 720, 1280, VK_FORMAT_R8G8B8A8_UNORM)
        frame_opt: Frame? = Presenter_PrepareFrame(presenter, attr, 0x12340000)
        assert frame_opt != null
        frame: Frame = frame_opt.value()
        assert frame.width == 1280
        assert Presenter_Present(presenter, frame, false)

        last_frame_opt: Frame? = Presenter_PrepareLastFrame(presenter)
        assert last_frame_opt != null
        last_frame: Frame = last_frame_opt.value()
        assert last_frame.id == frame.id
        Presenter_SetHDR(presenter, true)
        Presenter_SetExpectedGameSize(presenter, 1920, 1080)
