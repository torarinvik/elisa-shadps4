include "../shader_recompiler/frontend/opcodes_scalar_b.elisa"
include "../../compiler/runtime/elisacore_std/elisacore_runtime.elisa"

@test
def opcodes_scalar_b_consts() -> void:
    can Abort.Panic:
        assert OPCODE_SOPC_S_CMP_EQ_I32 == 0u32
        assert OPCODE_SOPC_OP_RANGE_SOPC == 17u32
        assert OPCODE_SOPP_S_NOP == 0u32
        assert OPCODE_SOPP_S_WAITCNT == 12u32
        assert OPCODE_SOPP_OP_RANGE_SOPP == 27u32
        assert OPCODE_SMRD_S_LOAD_DWORD == 0u32
        assert OPCODE_SMRD_OP_RANGE_SMRD == 32u32
