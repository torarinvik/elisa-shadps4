include "../core/platform.elisa"

@test
def platform_irq_tracks_persistent_and_one_time_subscribers() -> void:
    can Abort.Panic, Memory.Allocate:
        arena: Arena = zeroed
        in arena:
            Platform_IrqReset()
            if not Platform_IrqRegister(PLATFORM_IRQ_GFX_FLIP, 0x1000.uintptr()):
                panic("expected persistent irq registration")
            if not Platform_IrqRegisterOnce(PLATFORM_IRQ_GFX_FLIP, 0x2000.uintptr()):
                panic("expected one-shot irq registration")
            delivered: u32 = Platform_IrqSignal(PLATFORM_IRQ_GFX_FLIP)
            if delivered != 2.u32():
                panic("expected persistent and one-shot delivery")
            second: u32 = Platform_IrqSignal(PLATFORM_IRQ_GFX_FLIP)
            if second != 1.u32():
                panic("expected one-shot delivery to be consumed")
            if not Platform_IrqUnregister(PLATFORM_IRQ_GFX_FLIP, 0x1000.uintptr()):
                panic("expected persistent unregister")
            if Platform_IrqActiveHandlerCount() != 0:
                panic("expected no active irq handlers")

@test
def platform_irq_rejects_invalid_or_duplicate_handlers() -> void:
    can Abort.Panic, Memory.Allocate:
        arena: Arena = zeroed
        in arena:
            Platform_IrqReset()
            if Platform_IrqRegister(0x41.u32(), 0x1000.uintptr()):
                panic("expected invalid irq rejection")
            if Platform_IrqRegister(PLATFORM_IRQ_GFX_EOP, 0.uintptr()):
                panic("expected null uid rejection")
            if not Platform_IrqRegister(PLATFORM_IRQ_GFX_EOP, 0x1000.uintptr()):
                panic("expected valid irq registration")
            if Platform_IrqRegister(PLATFORM_IRQ_GFX_EOP, 0x1000.uintptr()):
                panic("expected duplicate persistent rejection")
