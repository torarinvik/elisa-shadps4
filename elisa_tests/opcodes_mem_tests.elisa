include "../shader_recompiler/frontend/opcodes_mem.elisa"
include "../../compiler/runtime/elisacore_std/elisacore_runtime.elisa"

@test
def opcodes_mem_values() -> void:
    can Abort.Panic:
        assert OPCODE_DS_DS_ADD_U32 == 0u32
        assert OPCODE_DS_OP_RANGE_DS == 256u32
        assert OPCODE_MUBUF_BUFFER_LOAD_FORMAT_X == 0u32
        assert OPCODE_MUBUF_OP_RANGE_MUBUF == 114u32
        assert OPCODE_MTBUF_TBUFFER_LOAD_FORMAT_X == 0u32
        assert OPCODE_MTBUF_OP_RANGE_MTBUF == 8u32
        assert OPCODE_MIMG_IMAGE_LOAD == 0u32
        assert OPCODE_MIMG_OP_RANGE_MIMG == 112u32
        assert OPCODE_EXP_EXP == 0u32
        assert OPCODE_EXP_OP_RANGE_EXP == 1u32
