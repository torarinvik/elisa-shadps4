include "../shader_recompiler/frontend/opcodes_vop12.elisa"
include "../../compiler/runtime/elisacore_std/elisacore_runtime.elisa"

@test
def opcodes_vop12_values() -> void:
    can Abort.Panic:
        assert OPCODE_VOP2_V_CNDMASK_B32 == 0u32
        assert OPCODE_VOP2_V_LDEXP_F16 == 59u32
        assert OPCODE_VOP2_OP_RANGE_VOP2 == 60u32
        assert OPCODE_VOP1_V_NOP == 0u32
        assert OPCODE_VOP1_V_EXP_LEGACY_F32 == 70u32
        assert OPCODE_VOP1_OP_RANGE_VOP1 == 86u32
