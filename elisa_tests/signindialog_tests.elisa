include "../core/libraries/signin_dialog/signindialog.elisa"
include "../../compiler/runtime/elisacore_std/elisacore_runtime.elisa"

@test
def signin_dialog_status_values() -> void:
    can Abort.Panic:
        assert SIGNIN_DIALOG_STATUS_NONE == 0u32
        assert SIGNIN_DIALOG_STATUS_INITIALIZED == 1u32
        assert SIGNIN_DIALOG_STATUS_RUNNING == 2u32
        assert SIGNIN_DIALOG_STATUS_FINISHED == 3u32
