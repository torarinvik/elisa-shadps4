include "../shader_recompiler/frontend/opcode_unified_vopc.elisa"
include "../../compiler/runtime/elisacore_std/elisacore_runtime.elisa"

@test def opcode_unified_vopc_test() -> void:
    can Abort.Panic:
        assert(OPCODE_V_CMP_F_F32 == OPCODE_MAP_OP_MAP_VOPC)
        assert(OPCODE_V_CMP_LT_F32 == 1u32 + OPCODE_MAP_OP_MAP_VOPC)
        assert(OPCODE_V_CMPX_T_U64 == 247u32 + OPCODE_MAP_OP_MAP_VOPC)
        assert(OPCODE_V_CMP_F_F32 != OPCODE_V_CMP_LT_F32)
        assert(OPCODE_V_CMP_F_F64 != OPCODE_V_CMP_F_I32)
