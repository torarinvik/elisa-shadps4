include "../core_libraries_font_integration.elisa"

@test
def font_character_helpers() -> void:
    can Abort.Panic:
        lvl: mutable int = 0
        assert sceFontCharacterGetBidiLevel(null, lvl.ref[mutable int&]) == ORBIS_FONT_ERROR_INVALID_PARAMETER
        assert sceFontCharacterGetBidiLevel(null, null) == ORBIS_FONT_ERROR_INVALID_PARAMETER

        ch: mutable OrbisFontTextCharacter = zeroed
        ch.bidiLevel <- 3.u8()
        assert sceFontCharacterGetBidiLevel(ch.ref[mutable OrbisFontTextCharacter&], lvl.ref[mutable int&]) == 0
        assert lvl == 3

        out_ptr: mutable void&? = null
        assert sceFontCharacterGetTextOrder(ch.ref[mutable OrbisFontTextCharacter&], null) == ORBIS_FONT_ERROR_INVALID_PARAMETER
        assert sceFontCharacterGetTextOrder(null, out_ptr.ref[mutable void&?&]) == ORBIS_FONT_ERROR_INVALID_PARAMETER
        assert out_ptr == null

        token: mutable int = 77
        ch.textOrder <- token.ref[mutable int&] as mutable void&?
        assert sceFontCharacterGetTextOrder(ch.ref[mutable OrbisFontTextCharacter&], out_ptr.ref[mutable void&?&]) == 0
        assert out_ptr != null

        ch.characterCode <- 0x41.u32()
        ch.formatFlags <- 0x04.u8()
        assert sceFontCharacterLooksFormatCharacters(ch.ref[mutable OrbisFontTextCharacter&]) == 0x41.u32()
        ch.formatFlags <- 0.u8()
        assert sceFontCharacterLooksFormatCharacters(ch.ref[mutable OrbisFontTextCharacter&]) == 0.u32()

        ch.charType <- 0x0e.u8()
        assert sceFontCharacterLooksWhiteSpace(ch.ref[mutable OrbisFontTextCharacter&]) == 0x41.u32()
        ch.charType <- 1.u8()
        assert sceFontCharacterLooksWhiteSpace(ch.ref[mutable OrbisFontTextCharacter&]) == 0.u32()

@test
def font_character_navigation_and_surface() -> void:
    can Abort.Panic:
        a: mutable OrbisFontTextCharacter = zeroed
        b: mutable OrbisFontTextCharacter = zeroed
        c: mutable OrbisFontTextCharacter = zeroed

        a.next <- b.ref[mutable OrbisFontTextCharacter&]
        b.prev <- a.ref[mutable OrbisFontTextCharacter&]
        b.next <- c.ref[mutable OrbisFontTextCharacter&]
        c.prev <- b.ref[mutable OrbisFontTextCharacter&]

        b.unkn_0x31 <- 1.u8()
        b.unkn_0x33 <- 0.u8()
        c.unkn_0x31 <- 0.u8()
        c.unkn_0x33 <- 0.u8()
        a.unkn_0x31 <- 0.u8()
        a.unkn_0x33 <- 0.u8()

        assert sceFontCharacterRefersTextNext(a.ref[mutable OrbisFontTextCharacter&]) == c.ref[mutable OrbisFontTextCharacter&]
        assert sceFontCharacterRefersTextBack(c.ref[mutable OrbisFontTextCharacter&]) == a.ref[mutable OrbisFontTextCharacter&]

        surf: mutable OrbisFontRenderSurface = zeroed
        sceFontRenderSurfaceInit(surf.ref[mutable OrbisFontRenderSurface&], null, 64, 1, 100, 40)
        assert surf.width == 100
        assert surf.height == 40
        assert surf.sc_x0 == 0.u32()
        assert surf.sc_y0 == 0.u32()
        assert surf.sc_x1 == 100.u32()
        assert surf.sc_y1 == 40.u32()

        sceFontRenderSurfaceSetScissor(surf.ref[mutable OrbisFontRenderSurface&], -10, -2, 30, 50)
        assert surf.sc_x0 == 0.u32()
        assert surf.sc_x1 == 20.u32()
        assert surf.sc_y0 == 0.u32()
        assert surf.sc_y1 == 40.u32()

@test
def font_style_frame_helpers() -> void:
    can Abort.Panic:
        surf: mutable OrbisFontRenderSurface = zeroed
        sf: mutable OrbisFontStyleFrame = zeroed

        assert sceFontRenderSurfaceSetStyleFrame(null, sf.ref[mutable OrbisFontStyleFrame&]) == ORBIS_FONT_ERROR_INVALID_PARAMETER
        sf.magic <- 0x0f09.u16()
        assert sceFontRenderSurfaceSetStyleFrame(surf.ref[mutable OrbisFontRenderSurface&], sf.ref[mutable OrbisFontStyleFrame&]) == 0
        assert_true((surf.styleFlag & 0x01.u8()) == 0x01.u8())

        sf.flags <- 0x02.u16()
        sf.slantRatio <- 0.25
        out_slant: mutable f32 = 0.0
        assert sceFontStyleFrameGetEffectSlant(sf.ref[mutable OrbisFontStyleFrame&], out_slant.ref[mutable f32&]) == 0
        assert out_slant == 0.25

        sf.flags <- 0x04.u16()
        sf.weightXScale <- 2.0
        sf.weightYScale <- 3.0
        wx: mutable f32 = 0.0
        wy: mutable f32 = 0.0
        mode: mutable u32 = 99.u32()
        assert sceFontStyleFrameGetEffectWeight(sf.ref[mutable OrbisFontStyleFrame&], wx.ref[mutable f32&], wy.ref[mutable f32&], mode.ref[mutable u32&]) == 0
        assert wx == 3.0
        assert wy == 4.0
        assert mode == 0.u32()

        sf.flags <- 0x01.u16()
        sf.scalingFlag <- 1
        sf.dpiX <- 144
        sf.dpiY <- 72
        sf.scaleWidth <- 5.0
        sf.scaleHeight <- 6.0
        sw: mutable f32 = 0.0
        sh: mutable f32 = 0.0
        assert sceFontStyleFrameGetScalePixel(sf.ref[mutable OrbisFontStyleFrame&], sw.ref[mutable f32&], sh.ref[mutable f32&]) == 0
        assert sw == 10.0
        assert sh == 6.0
