include "../../compiler/runtime/elisacore_std/elisacore_runtime.elisa"
include "../core/libraries/razor_cpu/razor_cpu.elisa"

@test
def razor_cpu_stub_contracts() -> void:
    can Abort.Panic:
        assert sceRazorCpuBeginLogicalFileAccess() == ORBIS_OK
        sceRazorCpuDisableFiberUserMarkers()
        assert sceRazorCpuEndLogicalFileAccess() == ORBIS_OK
        assert sceRazorCpuFiberLogNameChange() == ORBIS_OK
        assert sceRazorCpuFiberSwitch() == ORBIS_OK
        assert sceRazorCpuFlushOccurred() == false
        assert sceRazorCpuGetDataTagStorageSize() == ORBIS_OK
        assert sceRazorCpuGpuMarkerSync() == ORBIS_OK
        assert sceRazorCpuInitDataTags() == ORBIS_OK
        assert sceRazorCpuInitializeGpuMarkerContext() == ORBIS_OK
        assert sceRazorCpuInitializeInternal() == ORBIS_OK
        assert sceRazorCpuIsCapturing() == false
        assert sceRazorCpuJobManagerDispatch() == ORBIS_OK
        assert sceRazorCpuJobManagerJob() == ORBIS_OK
        assert sceRazorCpuJobManagerSequence() == ORBIS_OK
        assert sceRazorCpuNamedSync() == ORBIS_OK
        assert sceRazorCpuPlotValue() == ORBIS_OK
        assert sceRazorCpuPopMarker() == ORBIS_OK
        assert sceRazorCpuPushMarker() == ORBIS_OK
        assert sceRazorCpuPushMarkerStatic() == ORBIS_OK
        assert sceRazorCpuResizeTaggedBuffer() == ORBIS_OK
        sceRazorCpuSetPopMarkerCallback()
        sceRazorCpuSetPushMarkerCallback()
        sceRazorCpuSetPushMarkerStaticCallback()
        assert sceRazorCpuShutdownDataTags() == ORBIS_OK
        assert sceRazorCpuStartCaptureInternal() == ORBIS_OK
        assert sceRazorCpuStopCaptureInternal() == ORBIS_OK
        assert sceRazorCpuSync() == ORBIS_OK
        assert sceRazorCpuTagArray() == ORBIS_OK
        assert sceRazorCpuTagBuffer() == ORBIS_OK
        assert sceRazorCpuUnTagBuffer() == ORBIS_OK
        assert sceRazorCpuWorkloadRunBegin() == ORBIS_OK
        assert sceRazorCpuWorkloadRunEnd() == ORBIS_OK
        assert sceRazorCpuWorkloadSubmit() == ORBIS_OK
        assert sceRazorCpuWriteBookmark() == ORBIS_OK
