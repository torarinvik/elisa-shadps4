include "../core/libraries/kernel/lib_function_stub.elisa"
include "../common/types.elisa"
include "../../compiler/runtime/elisacore_std/elisacore_runtime.elisa"
include "../core/libraries/video_recording/video_recording.elisa"

@test
def video_recording_invalid_value_contracts() -> void:
    can Abort.Panic:
        payload: mutable u32 = 1u32
        p: mutable void& = (&payload).cast[mutable void&]

        assert sceVideoRecordingSetInfo(0x1, p, 4u64) == ORBIS_VIDEO_RECORDING_ERROR_INVALID_VALUE
        assert sceVideoRecordingSetInfo(0x3, p, 4u64) == ORBIS_VIDEO_RECORDING_ERROR_INVALID_VALUE
        assert sceVideoRecordingSetInfo(0x9, p, 4u64) == ORBIS_VIDEO_RECORDING_ERROR_INVALID_VALUE
        assert sceVideoRecordingSetInfo(0xe, p, 4u64) == ORBIS_VIDEO_RECORDING_ERROR_INVALID_VALUE
        assert sceVideoRecordingSetInfo(0xa00, p, 4u64) == ORBIS_VIDEO_RECORDING_ERROR_INVALID_VALUE
        assert sceVideoRecordingSetInfo(0xa00a, p, 4u64) == ORBIS_VIDEO_RECORDING_ERROR_INVALID_VALUE

@test
def video_recording_null_info_contract() -> void:
    can Abort.Panic:
        assert sceVideoRecordingSetInfo(0x2, null, 0u64) == ORBIS_VIDEO_RECORDING_ERROR_INVALID_VALUE
        assert sceVideoRecordingSetInfo(0xa009, null, 0u64) == ORBIS_VIDEO_RECORDING_ERROR_INVALID_VALUE

@test
def video_recording_ok_contracts() -> void:
    can Abort.Panic:
        payload: mutable array[u8, 16] = zeroed
        p: mutable void& = (&payload[0]).cast[mutable void&]

        assert sceVideoRecordingSetInfo(0x2, p, 16u64) == ORBIS_OK
        assert sceVideoRecordingSetInfo(0x6, p, 16u64) == ORBIS_OK
        assert sceVideoRecordingSetInfo(0x7, p, 16u64) == ORBIS_OK
        assert sceVideoRecordingSetInfo(0x8, p, 16u64) == ORBIS_OK
        assert sceVideoRecordingSetInfo(0xd, p, 16u64) == ORBIS_OK
        assert sceVideoRecordingSetInfo(0xa01, p, 16u64) == ORBIS_OK
        assert sceVideoRecordingSetInfo(0xa007, p, 16u64) == ORBIS_OK
        assert sceVideoRecordingSetInfo(0xa008, p, 16u64) == ORBIS_OK
        assert sceVideoRecordingSetInfo(0xa009, p, 16u64) == ORBIS_OK

def main() -> int:
    payload: mutable u32 = 7u32
    p: mutable void& = (&payload).cast[mutable void&]

    if sceVideoRecordingSetInfo(0x2, p, 4u64) != ORBIS_OK:
        return 1
    if sceVideoRecordingSetInfo(0x1, p, 4u64) != ORBIS_VIDEO_RECORDING_ERROR_INVALID_VALUE:
        return 2
    if sceVideoRecordingSetInfo(0xa009, null, 0u64) != ORBIS_VIDEO_RECORDING_ERROR_INVALID_VALUE:
        return 3
    return 0
