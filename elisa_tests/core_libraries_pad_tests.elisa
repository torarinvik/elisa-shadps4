include "../core/libraries/pad/pad.elisa"

def assert(cond: bool) -> void:
    if not cond:
        panic("pad test assertion failed")

@test
def pad_init_open_get_close_lifecycle() -> void:
    can Abort.Panic:
        assert scePadGetHandle(1, 0, 0) == ORBIS_PAD_ERROR_NOT_INITIALIZED
        assert scePadInit() == ORBIS_OK
        h: int = scePadOpen(1, 0, 0, null)
        assert h > 0
        assert scePadGetHandle(1, 0, 0) == h
        assert scePadClose(h) == ORBIS_OK
        assert scePadClose(h) == ORBIS_PAD_ERROR_INVALID_HANDLE

@test
def pad_validation_paths() -> void:
    can Abort.Panic:
        _ = scePadInit()
        assert scePadGetHandle(-1, 0, 0) == ORBIS_PAD_ERROR_DEVICE_NO_HANDLE
        assert scePadOpen(-5, 0, 0, null) == ORBIS_DEVICE_SERVICE_ERROR_INVALID_USER
        h: int = scePadOpen(2, 0, 0, null)
        assert h > 0
        assert scePadOpen(2, 0, 0, null) == ORBIS_PAD_ERROR_ALREADY_OPENED
        assert scePadSetLightBar(h, null) == ORBIS_PAD_ERROR_INVALID_ARG

        dim: mutable OrbisPadLightBarParam = zeroed
        dim.r <- 1
        dim.g <- 1
        dim.b <- 1
        assert scePadSetLightBar(h, dim.ref[OrbisPadLightBarParam&]) == ORBIS_PAD_ERROR_INVALID_LIGHTBAR_SETTING

@test
def pad_read_info() -> void:
    can Abort.Panic:
        _ = scePadInit()
        h: int = scePadOpen(3, 0, 0, null)
        d: mutable OrbisPadData = zeroed
        assert scePadRead(h, d.ref[mutable OrbisPadData&], 1) == 1
        assert d.connected
        assert scePadReadState(h, d.ref[mutable OrbisPadData&]) == ORBIS_OK

        info: mutable OrbisPadInfo = zeroed
        assert scePadGetInfo(info.ref[mutable OrbisPadInfo&]) == ORBIS_OK
        assert info.unk1 == 1

@test
def pad_controller_info_paths() -> void:
    can Abort.Panic:
        _ = scePadInit()
        h: int = scePadOpen(4, 0, 0, null)

        ctrl: mutable OrbisPadControllerInformation = zeroed
        assert scePadGetControllerInformation(h, ctrl.ref[mutable OrbisPadControllerInformation&]) == ORBIS_OK
        assert ctrl.connected

        ext: mutable OrbisPadExtendedControllerInformation = zeroed
        assert scePadGetExtControllerInformation(h, ext.ref[mutable OrbisPadExtendedControllerInformation&]) == ORBIS_OK
        assert ext.base.connected == false

@test
def pad_device_class_extended_info_paths() -> void:
    can Abort.Panic:
        _ = scePadInit()
        assert scePadDeviceClassGetExtendedInformation(12345, null) == ORBIS_PAD_ERROR_INVALID_HANDLE

        h: int = scePadOpen(5, 0, 0, null)
        assert h > 0
        assert scePadDeviceClassGetExtendedInformation(h, null) == ORBIS_PAD_ERROR_INVALID_ARG

        ext: mutable OrbisPadDeviceClassExtendedInformation = zeroed
        assert scePadDeviceClassGetExtendedInformation(h, ext.ref[mutable OrbisPadDeviceClassExtendedInformation&]) == ORBIS_OK
        assert ext.deviceClass == 0

@test
def pad_lightbar_colour_state_paths() -> void:
    can Abort.Panic:
        _ = scePadInit()
        h: int = scePadOpen(6, 0, 0, null)
        assert h > 0

        info: mutable OrbisPadInfo = zeroed
        assert scePadGetInfo(info.ref[mutable OrbisPadInfo&]) == ORBIS_OK
        # Blue default from reset fallback: 0 + (0 << 8) + (255 << 16)
        assert info.colour == 16711680

        light: mutable OrbisPadLightBarParam = zeroed
        light.r <- 20
        light.g <- 30
        light.b <- 40
        assert scePadSetLightBar(h, light.ref[OrbisPadLightBarParam&]) == ORBIS_OK
        assert scePadGetInfo(info.ref[mutable OrbisPadInfo&]) == ORBIS_OK
        assert info.colour == (20 + (30 << 8) + (40 << 16))

@test
def pad_get_info_uses_controller_zero_colour() -> void:
    can Abort.Panic:
        _ = scePadInit()
        # Open a non-zero user first to make sure the info path does not track
        # "first open handle" ordering.
        h2: int = scePadOpen(2, 0, 0, null)
        assert h2 > 0
        h1: int = scePadOpen(1, 0, 0, null)
        assert h1 > 0

        info: mutable OrbisPadInfo = zeroed
        assert scePadGetInfo(info.ref[mutable OrbisPadInfo&]) == ORBIS_OK
        # Controller 0 is the user-1 slot and should still report its blue lightbar.
        assert info.colour == 0xff0000

        assert scePadClose(h2) == ORBIS_OK
        assert scePadClose(h1) == ORBIS_OK

@test
def pad_input_runtime_sdl_smoke() -> void:
    can Abort.Panic:
        ctrls: mutable InputGameControllers& = Input_ControllersEnsure()
        Input_GameControllersTryOpenSDLControllers(ctrls)
        _ = scePadInit()
        h: int = scePadOpen(7, 0, 0, null)
        assert h > 0
        d: mutable OrbisPadData = zeroed
        assert scePadRead(h, d.ref[mutable OrbisPadData&], 1) == 1
        assert scePadClose(h) == ORBIS_OK
