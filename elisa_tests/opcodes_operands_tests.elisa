include "../shader_recompiler/frontend/opcodes_operands.elisa"
include "../../compiler/runtime/elisacore_std/elisacore_runtime.elisa"

@test
def opcodes_operands_values() -> void:
    can Abort.Panic:
        assert OPERAND_FIELD_VccLo == 106u32
        assert OPERAND_FIELD_Undefined == 0xFFFFFFFFu32
        assert SYSTEM_VALUE_SubgroupLtMask == 78u32
        assert INTERPOLATION_MODE_LinearSample == 6u32
        assert MIMG_MODIFIER_Offset == 7u32
        assert IMAGE_RES_COMPONENT_Width == 0u32
        assert IMAGE_ADDR_COMPONENT_Clamp == 16u32
        assert MESSAGE_System == 15u32
        assert GS_OP_EmitCut == 3u32
