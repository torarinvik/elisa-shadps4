include "../../compiler/runtime/elisacore_std/elisacore_runtime.elisa"
include "../shader_recompiler/frontend/instruction.elisa"
include "../shader_recompiler/frontend/format.elisa"
include "../shader_recompiler/frontend/decode.elisa"
include "../shader_recompiler/frontend/copy_shader.elisa"
include "../shader_recompiler/frontend/fetch_shader.elisa"
include "../shader_recompiler/frontend/control_flow_graph.elisa"
include "../shader_recompiler/frontend/structured_control_flow.elisa"


def _encode_sop2(op: u32, ssrc0: u32, ssrc1: u32, sdst: u32) -> u32:
    return INST_ENCODING_SOP2 | ((op & 0x7F) << 23) | ((sdst & 0x7F) << 16) | ((ssrc1 & 0xFF) << 8) | (ssrc0 & 0xFF)


def _encode_sop1(op: u32, ssrc0: u32, sdst: u32) -> u32:
    return INST_ENCODING_SOP1 | ((sdst & 0x7F) << 16) | ((op & 0xFF) << 8) | (ssrc0 & 0xFF)


def _encode_sopp(op: u32, simm: int) -> u32:
    raw: u32 = simm.u32()
    return INST_ENCODING_SOPP | ((op & 0x7F) << 16) | (raw & 0xFFFF)


def _encode_sopk(op: u32, sdst: u32, simm: int) -> u32:
    raw: u32 = simm.u32()
    return INST_ENCODING_SOPK | ((op & 0x1F) << 23) | ((sdst & 0x7F) << 16) | (raw & 0xFFFF)


def _encode_vop2(op: u32, src0: u32, vsrc1: u32, vdst: u32) -> u32:
    return ((op & 0x3F) << 25) | ((vdst & 0xFF) << 17) | ((vsrc1 & 0xFF) << 9) | (src0 & 0x1FF)


def _encode_smrd(op: u32, sbase: u32, sdst: u32, offset: u32, imm: bool) -> u32:
    imm_bit: mutable u32 = 0
    if imm:
        imm_bit <- 1
    return INST_ENCODING_SMRD | ((op & 0x1F) << 22) | ((sdst & 0x7F) << 15) | ((sbase & 0x3F) << 9) | (imm_bit << 8) | (offset & 0xFF)


def _encode_mubuf(op: u32, offset: u32, vaddr: u32, vdata: u32, srsrc: u32, soffset: u32) -> u64:
    v: mutable u64 = INST_ENCODING_MUBUF.u64()
    v <- v | ((op & 0x7F).u64() << 18)
    v <- v | (offset.u64() & 0xFFF)
    v <- v | ((vaddr & 0xFF).u64() << 32)
    v <- v | ((vdata & 0xFF).u64() << 40)
    v <- v | ((srsrc & 0x1F).u64() << 48)
    v <- v | ((soffset & 0xFF).u64() << 56)
    return v


def _encode_mtbuf(op: u32, offset: u32, dfmt: u32, nfmt: u32, vaddr: u32, vdata: u32, srsrc: u32, soffset: u32) -> u64:
    v: mutable u64 = INST_ENCODING_MTBUF.u64()
    v <- v | ((op & 0x7).u64() << 16)
    v <- v | (offset.u64() & 0xFFF)
    v <- v | ((dfmt & 0xF).u64() << 19)
    v <- v | ((nfmt & 0x7).u64() << 23)
    v <- v | ((vaddr & 0xFF).u64() << 32)
    v <- v | ((vdata & 0xFF).u64() << 40)
    v <- v | ((srsrc & 0x1F).u64() << 48)
    v <- v | ((soffset & 0xFF).u64() << 56)
    return v


def _encode_exp(en: u32, target: u32, vsrc0: u32, vsrc1: u32, vsrc2: u32, vsrc3: u32) -> u64:
    v: mutable u64 = INST_ENCODING_EXP.u64()
    v <- v | (en.u64() & 0xF)
    v <- v | ((target & 0x3F).u64() << 4)
    v <- v | ((vsrc0 & 0xFF).u64() << 32)
    v <- v | ((vsrc1 & 0xFF).u64() << 40)
    v <- v | ((vsrc2 & 0xFF).u64() << 48)
    v <- v | ((vsrc3 & 0xFF).u64() << 56)
    return v


def _encode_vop3(op: u32, vdst: u32, sdst: u32, src0: u32, src1: u32, src2: u32) -> u64:
    v: mutable u64 = INST_ENCODING_VOP3.u64()
    v <- v | (vdst.u64() & 0xFF)
    v <- v | ((sdst & 0x7F).u64() << 8)
    v <- v | (((op >> 9) & 1).u64() << 16)
    v <- v | ((op & 0x1FF).u64() << 17)
    v <- v | ((src0 & 0x1FF).u64() << 32)
    v <- v | ((src1 & 0x1FF).u64() << 41)
    v <- v | ((src2 & 0x1FF).u64() << 50)
    return v


def _encode_vop3p(op: u32, vdst: u32, src0: u32, src1: u32, src2: u32) -> u64:
    v: mutable u64 = INST_ENCODING_VOP3P.u64()
    v <- v | (vdst.u64() & 0xFF)
    v <- v | ((op & 0x7F).u64() << 16)
    v <- v | ((src0 & 0x1FF).u64() << 32)
    v <- v | ((src1 & 0x1FF).u64() << 41)
    v <- v | ((src2 & 0x1FF).u64() << 50)
    return v


def _write_u64_words(words: mutable u32&, word_index: u32, value: u64) -> void:
    words[word_index.usize()] <- (value & 0xFFFFFFFF).u32()
    words[(word_index + 1).usize()] <- (value >> 32).u32()


@test
def shader_frontend_instruction_branch_and_cmpx_contracts() -> void:
    can Abort.Panic:
        inst: mutable GcnInst = GcnInst_Default()
        inst.opcode <- OPCODE_S_BRANCH
        inst.control_sopp_simm <- 2
        assert GcnInst_BranchTarget(inst, 100) == 112
        assert GcnInst_IsUnconditionalBranch(inst) == true
        assert GcnInst_IsConditionalBranch(inst) == false
        assert GcnInst_IsTerminateInstruction(inst) == true

        inst.opcode <- OPCODE_S_CBRANCH_EXECNZ
        assert GcnInst_IsConditionalBranch(inst) == true

        inst.opcode <- OPCODE_V_CMPX_F_U64
        assert GcnInst_IsCmpx(inst) == true


@test
def shader_frontend_decode_core_paths_contracts() -> void:
    can Abort.Panic:
        words: mutable u32[8] = zeroed
        words[0] <- _encode_sopk(0, 4, -5)
        words[1] <- _encode_sopp(2, 3)
        words[2] <- _encode_vop2(37, 1, 0, 3)
        words[3] <- _encode_smrd(2, 2, 8, 12, true)

        slice: mutable GcnCodeSlice = zeroed
        GcnCodeSlice_Init(slice, words[0], 4)
        ctx: mutable GcnDecodeContext = zeroed

        inst0: GcnInst = GcnDecodeContext_decodeInstruction(ctx, slice)
        assert inst0.opcode == OPCODE_S_MOVK_I32
        assert inst0.control_sopk_simm == -5
        assert inst0.dst[0].code == 4

        inst1: GcnInst = GcnDecodeContext_decodeInstruction(ctx, slice)
        assert inst1.opcode == OPCODE_S_BRANCH
        assert GcnInst_BranchTarget(inst1, 0) == 16

        inst2: GcnInst = GcnDecodeContext_decodeInstruction(ctx, slice)
        assert inst2.opcode == OPCODE_V_ADD_I32

        inst3: GcnInst = GcnDecodeContext_decodeInstruction(ctx, slice)
        assert inst3.opcode == OPCODE_S_LOAD_DWORDX4
        assert inst3.control_smrd_offset == 12

        assert GetInstructionEncoding(words[0]) == INST_ENCODING_SOPK
        assert GetEncodingLength(INST_ENCODING_MUBUF) == 8


@test
def shader_frontend_proven_decode_operand_fields_survive_gcninst_storage() -> void:
    can Abort.Panic:
        words: mutable u32[16] = zeroed
        wi: mutable u32 = 0

        sop2_word: u32 = _encode_sop2(36, 103, 208, 12)
        words[wi.usize()] <- sop2_word
        wi <- wi + 1

        mubuf_word: u64 = _encode_mubuf(80, 0x5A5, 245, 246, 31, 255)
        _write_u64_words(words[0], wi, mubuf_word)
        wi <- wi + 2

        exp_word: u64 = _encode_exp(0xF, 32, 11, 22, 33, 44)
        _write_u64_words(words[0], wi, exp_word)
        wi <- wi + 2

        # VOP3 encoding of V_ADD_I32: op field maps back through the VOP2 alias window.
        vop3_op: u32 = VOP3_TO_VOP2 + (OPCODE_V_ADD_I32 - OP_MAP_VOP2)
        vop3_word: u64 = _encode_vop3(vop3_op, 5, 17, 260, 42, 255)
        _write_u64_words(words[0], wi, vop3_word)
        wi <- wi + 2

        vop3p_word: u64 = _encode_vop3p(1, 7, 259, 10, 511)
        _write_u64_words(words[0], wi, vop3p_word)
        wi <- wi + 2

        sop2: Sop2Inst = decode_sop2(sop2_word)
        assert sop2.op == 36
        assert sop2.sdst == 12
        assert sop2.ssrc0 == 103
        assert sop2.ssrc1 == 208

        mubuf: Mubuf64 = decode_mubuf64(mubuf_word)
        assert mubuf.op == 80
        assert mubuf.vaddr == 245
        assert mubuf.vdata == 246
        assert mubuf.srsrc == 31
        assert mubuf.soffset == 255

        exp: Exp64 = decode_exp64(exp_word)
        assert exp.vsrc0 == 11
        assert exp.vsrc1 == 22
        assert exp.vsrc2 == 33
        assert exp.vsrc3 == 44

        vop3: Vop3Operands = decode_vop3_operands(vop3_word)
        assert vop3.vdst == 5
        assert vop3.sdst == 17
        assert vop3.src0 == 260
        assert vop3.src1 == 42
        assert vop3.src2 == 255

        vop3p: Vop3pOperands = decode_vop3p_operands(vop3p_word)
        assert vop3p.vdst == 7
        assert vop3p.src0 == 259
        assert vop3p.src1 == 10
        assert vop3p.src2 == 511

        slice: mutable GcnCodeSlice = zeroed
        GcnCodeSlice_Init(slice, words[0], wi)
        ctx: mutable GcnDecodeContext = zeroed

        inst0: GcnInst = GcnDecodeContext_decodeInstruction(ctx, slice)
        assert inst0.encoding == INST_ENCODING_SOP2
        assert inst0.src[0].field == OPERAND_FIELD_SCALAR_GPR
        assert inst0.src[0].code == 103
        assert inst0.src[1].field == OPERAND_FIELD_SIGNED_CONST_INT_NEG
        assert inst0.src[1].code == 208
        assert inst0.dst[0].field == OPERAND_FIELD_SCALAR_GPR
        assert inst0.dst[0].code == 12

        inst1: GcnInst = GcnDecodeContext_decodeInstruction(ctx, slice)
        assert inst1.encoding == INST_ENCODING_MUBUF
        assert inst1.opcode == OP_MAP_MUBUF + 80
        assert inst1.src[0].field == OPERAND_FIELD_VECTOR_GPR
        assert inst1.src[0].code == 245
        assert inst1.src[1].field == OPERAND_FIELD_VECTOR_GPR
        assert inst1.src[1].code == 246
        assert inst1.src[2].field == OPERAND_FIELD_SCALAR_GPR
        assert inst1.src[2].code == 31
        assert inst1.src[3].field == OPERAND_FIELD_LITERAL_CONST
        assert inst1.src[3].code == 255

        inst2: GcnInst = GcnDecodeContext_decodeInstruction(ctx, slice)
        assert inst2.encoding == INST_ENCODING_EXP
        assert inst2.opcode == OP_MAP_EXP
        assert inst2.src[0].field == OPERAND_FIELD_VECTOR_GPR
        assert inst2.src[0].code == 11
        assert inst2.src[1].field == OPERAND_FIELD_VECTOR_GPR
        assert inst2.src[1].code == 22
        assert inst2.src[2].field == OPERAND_FIELD_VECTOR_GPR
        assert inst2.src[2].code == 33
        assert inst2.src[3].field == OPERAND_FIELD_VECTOR_GPR
        assert inst2.src[3].code == 44

        inst3: GcnInst = GcnDecodeContext_decodeInstruction(ctx, slice)
        assert inst3.encoding == INST_ENCODING_VOP3
        assert inst3.opcode == OPCODE_V_ADD_I32
        assert inst3.src[0].field == OPERAND_FIELD_VECTOR_GPR
        assert inst3.src[0].code == 4
        assert inst3.src[1].field == OPERAND_FIELD_SCALAR_GPR
        assert inst3.src[1].code == 42
        assert inst3.src[2].field == OPERAND_FIELD_LITERAL_CONST
        assert inst3.src[2].code == 255
        assert inst3.dst[0].field == OPERAND_FIELD_VECTOR_GPR
        assert inst3.dst[0].code == 5
        assert inst3.dst[1].field == OPERAND_FIELD_SCALAR_GPR
        assert inst3.dst[1].code == 17

        inst4: GcnInst = GcnDecodeContext_decodeInstruction(ctx, slice)
        assert inst4.encoding == INST_ENCODING_VOP3P
        assert inst4.opcode == OP_MAP_VOP3P + 1
        assert inst4.src[0].field == OPERAND_FIELD_VECTOR_GPR
        assert inst4.src[0].code == 3
        assert inst4.src[1].field == OPERAND_FIELD_SCALAR_GPR
        assert inst4.src[1].code == 10
        assert inst4.src[2].field == OPERAND_FIELD_VECTOR_GPR
        assert inst4.src[2].code == 255
        assert inst4.dst[0].field == OPERAND_FIELD_VECTOR_GPR
        assert inst4.dst[0].code == 7


@test
def shader_frontend_copy_shader_parse_contracts() -> void:
    can Abort.Panic:
        words: mutable u32[24] = zeroed
        wi: mutable u32 = 0

        words[wi.usize()] <- _encode_mubuf(12, 0, 0, 0, 0, 128).u32()
        words[(wi + 1).usize()] <- (_encode_mubuf(12, 0, 0, 0, 0, 128) >> 32).u32()
        wi <- wi + 2
        words[wi.usize()] <- _encode_exp(1, 32, 0, 0, 0, 0).u32()
        words[(wi + 1).usize()] <- (_encode_exp(1, 32, 0, 0, 0, 0) >> 32).u32()
        wi <- wi + 2

        words[wi.usize()] <- _encode_mubuf(12, 64, 1, 1, 0, 128).u32()
        words[(wi + 1).usize()] <- (_encode_mubuf(12, 64, 1, 1, 0, 128) >> 32).u32()
        wi <- wi + 2
        words[wi.usize()] <- _encode_exp(1, 33, 1, 0, 0, 0).u32()
        words[(wi + 1).usize()] <- (_encode_exp(1, 33, 1, 0, 0, 0) >> 32).u32()
        wi <- wi + 2

        data: CopyShaderData = ParseCopyShader(words[0], wi)
        assert data.num_comps == 2
        assert data.attr_map_count >= 2
        assert data.num_attrs >= 2
        assert data.output_vertices == 1


@test
def shader_frontend_fetch_shader_parse_contracts() -> void:
    can Abort.Panic:
        info: mutable ShaderInfoLite = zeroed
        info.has_fetch_shader <- true
        info.fetch_shader_sgpr_base <- 0

        wi: mutable u32 = 0
        info.fetch_shader_code[wi.usize()] <- _encode_smrd(2, 2, 8, 0, true)
        wi <- wi + 1

        info.fetch_shader_code[wi.usize()] <- _encode_vop2(37, 7, 0, 0)
        wi <- wi + 1

        mt: u64 = _encode_mtbuf(3, 8, 5, 2, 0, 4, 2, 128)
        _write_u64_words(info.fetch_shader_code[0], wi, mt)
        wi <- wi + 2

        info.fetch_shader_code[wi.usize()] <- _encode_sop1(32, 0, 0)
        wi <- wi + 1

        info.fetch_shader_word_count <- wi

        parsed: FetchShaderDataOptional = ParseFetchShader(info)
        assert parsed.has_value == true
        assert parsed.value.attribute_count == 1
        assert parsed.value.size > 0
        assert parsed.value.vertex_offset_sgpr == 7
        assert parsed.value.attributes[0].semantic == 0
        assert parsed.value.attributes[0].dest_vgpr == 4
        assert parsed.value.attributes[0].num_elements == 4
        assert parsed.value.attributes[0].sgpr_base == 4
        assert parsed.value.attributes[0].dword_offset == 0
        assert parsed.value.attributes[0].inst_offset == 8
        assert parsed.value.attributes[0].data_format == 5
        assert parsed.value.attributes[0].num_format == 2


@test
def shader_frontend_cfg_and_asl_contracts() -> void:
    can Abort.Panic:
        insts: mutable GcnInst[8] = zeroed

        i0: mutable GcnInst = GcnInst_Default()
        i0.opcode <- OPCODE_S_CBRANCH_SCC1
        i0.control_sopp_simm <- 2
        i0.length <- 4
        i0.category <- INST_CATEGORY_FLOW_CONTROL
        insts[0] <- i0

        i1: mutable GcnInst = GcnInst_Default()
        i1.opcode <- OPCODE_S_ENDPGM
        i1.length <- 4
        i1.category <- INST_CATEGORY_FLOW_CONTROL
        insts[1] <- i1

        i2: mutable GcnInst = GcnInst_Default()
        i2.opcode <- OPCODE_S_ENDPGM
        i2.length <- 4
        i2.category <- INST_CATEGORY_FLOW_CONTROL
        insts[2] <- i2

        cfg: mutable CFG& = CFG_Build(insts[0], 3)
        assert cfg.block_count >= 2

        asl: AbstractSyntaxListModel = BuildASL(cfg)
        assert asl.node_count >= 2
        assert CFG_Dot(cfg) != null
