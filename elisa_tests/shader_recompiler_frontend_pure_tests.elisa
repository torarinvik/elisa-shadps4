include "../../compiler/runtime/elisacore_std/elisacore_runtime.elisa"
include "../shader_recompiler/frontend/instruction.elisa"
include "../shader_recompiler/frontend/format.elisa"
include "../shader_recompiler/frontend/decode.elisa"
include "../shader_recompiler/frontend/copy_shader.elisa"
include "../shader_recompiler/frontend/fetch_shader.elisa"
include "../shader_recompiler/frontend/control_flow_graph.elisa"
include "../shader_recompiler/frontend/structured_control_flow.elisa"


def _encode_sop2(op: u32, ssrc0: u32, ssrc1: u32, sdst: u32) -> u32:
    return INST_ENCODING_SOP2 | ((op & 0x7Fu32) << 23u32) | ((sdst & 0x7Fu32) << 16u32) | ((ssrc1 & 0xFFu32) << 8u32) | (ssrc0 & 0xFFu32)


def _encode_sop1(op: u32, ssrc0: u32, sdst: u32) -> u32:
    return INST_ENCODING_SOP1 | ((sdst & 0x7Fu32) << 16u32) | ((op & 0xFFu32) << 8u32) | (ssrc0 & 0xFFu32)


def _encode_sopp(op: u32, simm: int) -> u32:
    raw: u32 = simm.u32()
    return INST_ENCODING_SOPP | ((op & 0x7Fu32) << 16u32) | (raw & 0xFFFFu32)


def _encode_sopk(op: u32, sdst: u32, simm: int) -> u32:
    raw: u32 = simm.u32()
    return INST_ENCODING_SOPK | ((op & 0x1Fu32) << 23u32) | ((sdst & 0x7Fu32) << 16u32) | (raw & 0xFFFFu32)


def _encode_vop2(op: u32, src0: u32, vsrc1: u32, vdst: u32) -> u32:
    return ((op & 0x3Fu32) << 25u32) | ((vdst & 0xFFu32) << 17u32) | ((vsrc1 & 0xFFu32) << 9u32) | (src0 & 0x1FFu32)


def _encode_smrd(op: u32, sbase: u32, sdst: u32, offset: u32, imm: bool) -> u32:
    imm_bit: mutable u32 = 0u32
    if imm:
        imm_bit <- 1u32
    return INST_ENCODING_SMRD | ((op & 0x1Fu32) << 22u32) | ((sdst & 0x7Fu32) << 15u32) | ((sbase & 0x3Fu32) << 9u32) | (imm_bit << 8u32) | (offset & 0xFFu32)


def _encode_mubuf(op: u32, offset: u32, vaddr: u32, vdata: u32, srsrc: u32, soffset: u32) -> u64:
    v: mutable u64 = INST_ENCODING_MUBUF.u64()
    v <- v | ((op & 0x7Fu32).u64() << 18u64)
    v <- v | (offset.u64() & 0xFFFu64)
    v <- v | ((vaddr & 0xFFu32).u64() << 32u64)
    v <- v | ((vdata & 0xFFu32).u64() << 40u64)
    v <- v | ((srsrc & 0x1Fu32).u64() << 48u64)
    v <- v | ((soffset & 0xFFu32).u64() << 56u64)
    return v


def _encode_mtbuf(op: u32, offset: u32, dfmt: u32, nfmt: u32, vaddr: u32, vdata: u32, srsrc: u32, soffset: u32) -> u64:
    v: mutable u64 = INST_ENCODING_MTBUF.u64()
    v <- v | ((op & 0x7u32).u64() << 16u64)
    v <- v | (offset.u64() & 0xFFFu64)
    v <- v | ((dfmt & 0xFu32).u64() << 19u64)
    v <- v | ((nfmt & 0x7u32).u64() << 23u64)
    v <- v | ((vaddr & 0xFFu32).u64() << 32u64)
    v <- v | ((vdata & 0xFFu32).u64() << 40u64)
    v <- v | ((srsrc & 0x1Fu32).u64() << 48u64)
    v <- v | ((soffset & 0xFFu32).u64() << 56u64)
    return v


def _encode_exp(en: u32, target: u32, vsrc0: u32, vsrc1: u32, vsrc2: u32, vsrc3: u32) -> u64:
    v: mutable u64 = INST_ENCODING_EXP.u64()
    v <- v | (en.u64() & 0xFu64)
    v <- v | ((target & 0x3Fu32).u64() << 4u64)
    v <- v | ((vsrc0 & 0xFFu32).u64() << 32u64)
    v <- v | ((vsrc1 & 0xFFu32).u64() << 40u64)
    v <- v | ((vsrc2 & 0xFFu32).u64() << 48u64)
    v <- v | ((vsrc3 & 0xFFu32).u64() << 56u64)
    return v


def _write_u64_words(words: mutable u32&, word_index: u32, value: u64) -> void:
    words[word_index.usize()] <- (value & 0xFFFFFFFFu64).u32()
    words[(word_index + 1u32).usize()] <- (value >> 32u64).u32()


@test
def shader_frontend_instruction_branch_and_cmpx_contracts() -> void:
    can Abort.Panic:
        inst: mutable GcnInst = GcnInst_Default()
        inst.opcode <- OPCODE_S_BRANCH
        inst.control_sopp_simm <- 2
        assert GcnInst_BranchTarget(inst, 100u32) == 112u32
        assert GcnInst_IsUnconditionalBranch(inst) == true
        assert GcnInst_IsConditionalBranch(inst) == false
        assert GcnInst_IsTerminateInstruction(inst) == true

        inst.opcode <- OPCODE_S_CBRANCH_EXECNZ
        assert GcnInst_IsConditionalBranch(inst) == true

        inst.opcode <- OPCODE_V_CMPX_F_U64
        assert GcnInst_IsCmpx(inst) == true


@test
def shader_frontend_decode_core_paths_contracts() -> void:
    can Abort.Panic:
        words: mutable u32[8] = zeroed
        words[0] <- _encode_sopk(0u32, 4u32, -5)
        words[1] <- _encode_sopp(2u32, 3)
        words[2] <- _encode_vop2(37u32, 1u32, 0u32, 3u32)
        words[3] <- _encode_smrd(2u32, 2u32, 8u32, 12u32, true)

        slice: mutable GcnCodeSlice = zeroed
        GcnCodeSlice_Init(slice, words[0].ref[u32&], 4u32)
        ctx: mutable GcnDecodeContext = zeroed

        inst0: GcnInst = GcnDecodeContext_decodeInstruction(ctx, slice.ref[mutable GcnCodeSlice&])
        assert inst0.opcode == OPCODE_S_MOVK_I32
        assert inst0.control_sopk_simm == -5
        assert inst0.dst[0].code == 4u32

        inst1: GcnInst = GcnDecodeContext_decodeInstruction(ctx, slice.ref[mutable GcnCodeSlice&])
        assert inst1.opcode == OPCODE_S_BRANCH
        assert GcnInst_BranchTarget(inst1, 0u32) == 16u32

        inst2: GcnInst = GcnDecodeContext_decodeInstruction(ctx, slice.ref[mutable GcnCodeSlice&])
        assert inst2.opcode == OPCODE_V_ADD_I32

        inst3: GcnInst = GcnDecodeContext_decodeInstruction(ctx, slice.ref[mutable GcnCodeSlice&])
        assert inst3.opcode == OPCODE_S_LOAD_DWORDX4
        assert inst3.control_smrd_offset == 12u32

        assert GetInstructionEncoding(words[0]) == INST_ENCODING_SOPK
        assert GetEncodingLength(INST_ENCODING_MUBUF) == 8u32


@test
def shader_frontend_copy_shader_parse_contracts() -> void:
    can Abort.Panic:
        words: mutable u32[24] = zeroed
        wi: mutable u32 = 0u32

        words[wi.usize()] <- _encode_mubuf(12u32, 0u32, 0u32, 0u32, 0u32, 128u32).u32()
        words[(wi + 1u32).usize()] <- (_encode_mubuf(12u32, 0u32, 0u32, 0u32, 0u32, 128u32) >> 32u64).u32()
        wi <- wi + 2u32
        words[wi.usize()] <- _encode_exp(1u32, 32u32, 0u32, 0u32, 0u32, 0u32).u32()
        words[(wi + 1u32).usize()] <- (_encode_exp(1u32, 32u32, 0u32, 0u32, 0u32, 0u32) >> 32u64).u32()
        wi <- wi + 2u32

        words[wi.usize()] <- _encode_mubuf(12u32, 64u32, 1u32, 1u32, 0u32, 128u32).u32()
        words[(wi + 1u32).usize()] <- (_encode_mubuf(12u32, 64u32, 1u32, 1u32, 0u32, 128u32) >> 32u64).u32()
        wi <- wi + 2u32
        words[wi.usize()] <- _encode_exp(1u32, 33u32, 1u32, 0u32, 0u32, 0u32).u32()
        words[(wi + 1u32).usize()] <- (_encode_exp(1u32, 33u32, 1u32, 0u32, 0u32, 0u32) >> 32u64).u32()
        wi <- wi + 2u32

        data: CopyShaderData = ParseCopyShader(words[0].ref[u32&], wi)
        assert data.num_comps == 2u32
        assert data.attr_map_count >= 2u32
        assert data.num_attrs >= 2u32
        assert data.output_vertices == 1u32


@test
def shader_frontend_fetch_shader_parse_contracts() -> void:
    can Abort.Panic:
        info: mutable ShaderInfoLite = zeroed
        info.has_fetch_shader <- true
        info.fetch_shader_sgpr_base <- 0u32

        wi: mutable u32 = 0u32
        info.fetch_shader_code[wi.usize()] <- _encode_smrd(2u32, 2u32, 8u32, 0u32, true)
        wi <- wi + 1u32

        info.fetch_shader_code[wi.usize()] <- _encode_vop2(37u32, 7u32, 0u32, 0u32)
        wi <- wi + 1u32

        mt: u64 = _encode_mtbuf(3u32, 8u32, 5u32, 2u32, 0u32, 4u32, 2u32, 128u32)
        _write_u64_words(info.fetch_shader_code[0].ref[mutable u32&], wi, mt)
        wi <- wi + 2u32

        info.fetch_shader_code[wi.usize()] <- _encode_sop1(32u32, 0u32, 0u32)
        wi <- wi + 1u32

        info.fetch_shader_word_count <- wi

        parsed: FetchShaderDataOptional = ParseFetchShader(info)
        assert parsed.has_value == true
        assert parsed.value.attribute_count == 1u32
        assert parsed.value.size > 0u32
        assert parsed.value.vertex_offset_sgpr == 7
        assert parsed.value.attributes[0].semantic == 0u8
        assert parsed.value.attributes[0].dest_vgpr == 4u8
        assert parsed.value.attributes[0].num_elements == 4u8
        assert parsed.value.attributes[0].sgpr_base == 4u8
        assert parsed.value.attributes[0].dword_offset == 0u8
        assert parsed.value.attributes[0].inst_offset == 8u8
        assert parsed.value.attributes[0].data_format == 5u8
        assert parsed.value.attributes[0].num_format == 2u8


@test
def shader_frontend_cfg_and_asl_contracts() -> void:
    can Abort.Panic:
        insts: mutable GcnInst[8] = zeroed

        i0: mutable GcnInst = GcnInst_Default()
        i0.opcode <- OPCODE_S_CBRANCH_SCC1
        i0.control_sopp_simm <- 2
        i0.length <- 4u32
        i0.category <- INST_CATEGORY_FLOW_CONTROL
        insts[0] <- i0

        i1: mutable GcnInst = GcnInst_Default()
        i1.opcode <- OPCODE_S_ENDPGM
        i1.length <- 4u32
        i1.category <- INST_CATEGORY_FLOW_CONTROL
        insts[1] <- i1

        i2: mutable GcnInst = GcnInst_Default()
        i2.opcode <- OPCODE_S_ENDPGM
        i2.length <- 4u32
        i2.category <- INST_CATEGORY_FLOW_CONTROL
        insts[2] <- i2

        cfg: CFG = CFG_Build(insts[0].ref[GcnInst&], 3u32)
        assert cfg.block_count >= 2u32

        asl: AbstractSyntaxListModel = BuildASL(cfg)
        assert asl.node_count >= 2u32
        assert CFG_Dot(cfg) != null
