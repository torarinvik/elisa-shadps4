include "../shader_recompiler/backend/spirv/spirv_backend.elisa"
include "../../compiler/runtime/elisacore_std/elisacore_runtime.elisa"

@test
def spirv_backend_primitive_modes_match_cpp_switches() -> void:
    can Abort.Panic:
        assert SpirvGetInputPrimitiveExecutionMode(AMDGPU_PRIMITIVE_POINT_LIST) == SPIRV_EXECUTION_MODE_INPUT_POINTS
        assert SpirvGetInputPrimitiveExecutionMode(AMDGPU_PRIMITIVE_LINE_LIST) == SPIRV_EXECUTION_MODE_INPUT_LINES
        assert SpirvGetInputPrimitiveExecutionMode(AMDGPU_PRIMITIVE_LINE_STRIP) == SPIRV_EXECUTION_MODE_INPUT_LINES
        assert SpirvGetInputPrimitiveExecutionMode(AMDGPU_PRIMITIVE_TRIANGLE_LIST) == SPIRV_EXECUTION_MODE_TRIANGLES
        assert SpirvGetInputPrimitiveExecutionMode(AMDGPU_PRIMITIVE_TRIANGLE_STRIP) == SPIRV_EXECUTION_MODE_TRIANGLES
        assert SpirvGetInputPrimitiveExecutionMode(AMDGPU_PRIMITIVE_RECT_LIST) == SPIRV_EXECUTION_MODE_TRIANGLES
        assert SpirvGetInputPrimitiveExecutionMode(AMDGPU_PRIMITIVE_ADJ_TRIANGLE_LIST) == SPIRV_EXECUTION_MODE_INPUT_TRIANGLES_ADJACENCY
        assert SpirvGetInputPrimitiveExecutionMode(AMDGPU_PRIMITIVE_ADJ_LINE_LIST) == SPIRV_EXECUTION_MODE_INPUT_LINES_ADJACENCY
        assert SpirvGetInputPrimitiveExecutionMode(AMDGPU_PRIMITIVE_TRIANGLE_FAN) == 0u32

@test
def spirv_backend_output_modes_match_cpp_switches() -> void:
    can Abort.Panic:
        assert SpirvGetOutputPrimitiveExecutionMode(AMDGPU_GS_OUTPUT_POINT_LIST) == SPIRV_EXECUTION_MODE_OUTPUT_VERTICES
        assert SpirvGetOutputPrimitiveExecutionMode(AMDGPU_GS_OUTPUT_LINE_STRIP) == SPIRV_EXECUTION_MODE_OUTPUT_LINE_STRIP
        assert SpirvGetOutputPrimitiveExecutionMode(AMDGPU_GS_OUTPUT_TRIANGLE_STRIP) == SPIRV_EXECUTION_MODE_OUTPUT_TRIANGLE_STRIP
        assert SpirvGetOutputPrimitiveExecutionMode(99u32) == 0u32

@test
def spirv_backend_vector_ids_are_one_based_like_cpp() -> void:
    can Abort.Panic:
        ids: mutable SpirvVectorIds = SpirvVectorIds_Default()
        assert SpirvVectorIds_Set(ids, 1u32, 11u32) == true
        assert SpirvVectorIds_Set(ids, 4u32, 44u32) == true
        assert SpirvVectorIds_Set(ids, 0u32, 99u32) == false
        assert SpirvVectorIds_Get(ids, 1u32) == 11u32
        assert SpirvVectorIds_Get(ids, 4u32) == 44u32
        assert SpirvVectorIds_Get(ids, 5u32) == SPIRV_INVALID_ID

@test
def spirv_backend_binding_and_header_are_deterministic() -> void:
    can Abort.Panic, Memory.Allocate:
        binding: mutable ShaderBackendBindings = ShaderBackendBindings_Default()
        result: SpirvEmitResult = SpirvEmitMinimalModule(binding)
        assert result.ok == true
        assert result.words.count == 5
        assert result.words[0] == SPIRV_MAGIC
        assert result.words[1] == SPIRV_VERSION_1_6
        assert result.words[3] == result.bound
        assert binding.unified == 1u32
        assert binding.buffer == 1u32
        assert binding.user_data == 0u32

@test
def spirv_module_dedups_declarations_like_sirit() -> void:
    can Abort.Panic, Memory.Allocate:
        m: mutable SpirvModule = SpirvModule_Default()
        # First use of each type allocates a fresh id.
        u32_a: u32 = SpirvModule_TypeInt(m, 32u32, 0u32)
        f32_t: u32 = SpirvModule_TypeFloat(m, 32u32)
        assert u32_a == 1u32
        assert f32_t == 2u32
        # Re-emitting an identical type returns the same id and adds no words.
        before: usize = m.declarations.count
        bound_before: u32 = m.bound
        u32_b: u32 = SpirvModule_TypeInt(m, 32u32, 0u32)
        assert u32_b == u32_a
        assert m.declarations.count == before
        assert m.bound == bound_before
        # A differing operand (signedness) is a distinct declaration.
        s32_t: u32 = SpirvModule_TypeInt(m, 32u32, 1u32)
        assert s32_t == 3u32
        # Constants dedup too (result-type word precedes the id).
        c0_a: u32 = SpirvModule_Constant32(m, u32_a, 0u32)
        c0_b: u32 = SpirvModule_Constant32(m, u32_a, 0u32)
        c1: u32 = SpirvModule_Constant32(m, u32_a, 1u32)
        assert c0_a == c0_b
        assert c1 != c0_a

@test
def spirv_module_assemble_emits_header_and_sections() -> void:
    can Abort.Panic, Memory.Allocate:
        m: mutable SpirvModule = SpirvModule_Default()
        m.addressing_model <- 0u32
        m.memory_model <- 1u32
        SpirvModule_AddCapability(m, 1u32)
        u32_t: u32 = SpirvModule_TypeInt(m, 32u32, 0u32)
        a: u32 = SpirvModule_Constant32(m, u32_t, 10u32)
        b: u32 = SpirvModule_Constant32(m, u32_t, 20u32)
        sum: u32 = SpirvModule_EmitCodeBinary(m, SPIRV_OP_I_ADD, u32_t, a, b)
        words: darray[u32] = SpirvModule_Assemble(m)
        # Header.
        assert words[0] == SPIRV_MAGIC
        assert words[1] == SPIRV_VERSION_1_6
        assert words[3] == m.bound + 1u32
        assert words[4] == SPIRV_SCHEMA_RESERVED
        # OpCapability(2), value=1.
        assert words[5] == SpirvWord(SPIRV_OP_CAPABILITY, 2u16)
        assert words[6] == 1u32
        # OpMemoryModel(3) follows (no ext-inst imports were added).
        assert words[7] == SpirvWord(SPIRV_OP_MEMORY_MODEL, 3u16)
        assert words[8] == 0u32
        assert words[9] == 1u32
        # The IAdd from the code section is the last instruction (5 words).
        assert words[words.count - 5usize] == SpirvWord(SPIRV_OP_I_ADD, 5u16)
        assert words[words.count - 4usize] == u32_t
        assert words[words.count - 3usize] == sum
        assert words[words.count - 2usize] == a
        assert words[words.count - 1usize] == b

@test
def spirv_backend_arithmetic_type_ids_follow_cpp_order() -> void:
    can Abort.Panic:
        ctx: mutable SpirvEmitContext = SpirvEmitContext_Default()
        SpirvEmitContext_DefineArithmeticTypes(ctx)
        # Scalar types (fp16/fp64 disabled by default), matching the C++ order.
        assert ctx.void_id == 1u32
        assert ctx.u1_id == 2u32
        assert ctx.u8_id == 3u32
        assert ctx.s8_id == 4u32
        assert ctx.u16_id == 5u32
        assert ctx.s16_id == 6u32
        assert ctx.f32_id == 7u32
        assert ctx.s32_id == 8u32
        assert ctx.u32_id == 9u32
        assert ctx.u64_id == 10u32
        # Vector types, component counts 2..4.
        assert ctx.f32x2_id == 11u32
        assert ctx.u1x2_id == 14u32
        assert ctx.f32x4_id == 19u32
        assert ctx.u1x4_id == 22u32
        # Constants, then input/output pointers, then struct result types.
        assert ctx.true_value == 23u32
        assert ctx.u32_zero_value == 29u32
        assert ctx.pi_x2 == 33u32
        assert ctx.input_f32 == 34u32
        assert ctx.output_s32 == 39u32
        assert ctx.full_result_i32x2 == 40u32
        assert ctx.frexp_result_f32 == 42u32
        # Next free id after the arithmetic-type section.
        assert ctx.next_id == 43u32
        assert SpirvTypeId(ctx, SHADER_IR_TYPE_U1) == 2u32
        assert SpirvTypeId(ctx, SHADER_IR_TYPE_U32) == 9u32
        assert SpirvTypeId(ctx, SHADER_IR_TYPE_VOID) == SPIRV_INVALID_ID

@test
def spirv_backend_word_packs_count_and_opcode() -> void:
    can Abort.Panic:
        assert SpirvWord(19u16, 2u16) == 0x00020013u32

@test
def spirv_backend_emit_select_matches_cpp_opselect() -> void:
    can Abort.Panic, Memory.Allocate:
        ctx: mutable SpirvEmitContext = SpirvEmitContext_Default()
        SpirvEmitContext_DefineArithmeticTypes(ctx)
        # Arithmetic types occupy ids 1..42; f32 is id 7, next free id is 43.
        assert ctx.f32_id == 7u32
        before: usize = ctx.words.count
        result: u32 = SpirvEmitSelectU32(ctx, 10u32, 11u32, 12u32)
        # OpSelect emits 6 words and allocates the result id (43).
        assert result == 43u32
        assert ctx.words.count == before + 6usize
        assert ctx.words[before] == SpirvWord(SPIRV_OP_SELECT, 6u16)
        assert ctx.words[before + 1usize] == ctx.u32_id
        assert ctx.words[before + 2usize] == result
        assert ctx.words[before + 3usize] == 10u32
        assert ctx.words[before + 4usize] == 11u32
        assert ctx.words[before + 5usize] == 12u32
        # Typed variants pick the matching scalar result type.
        u1_sel: u32 = SpirvEmitSelectU1(ctx, 1u32, 2u32, 3u32)
        assert ctx.words[ctx.words.count - 5usize] == ctx.u1_id
        f32_sel: u32 = SpirvEmitSelectF32(ctx, 4u32, 5u32, 6u32)
        assert ctx.words[ctx.words.count - 5usize] == ctx.f32_id
        _ = u1_sel
        _ = f32_sel

@test
def spirv_backend_emit_composite_matches_cpp() -> void:
    can Abort.Panic, Memory.Allocate:
        ctx: mutable SpirvEmitContext = SpirvEmitContext_Default()
        SpirvEmitContext_DefineArithmeticTypes(ctx)
        # Vector types come from the arithmetic-type section: u32x2=13, f32x4=19.
        assert ctx.u32x2_id == 13u32
        assert ctx.f32x4_id == 19u32
        # --- Construct U32x4: 7 words. ---
        b0: usize = ctx.words.count
        v: u32 = SpirvEmitCompositeConstructU32x4(ctx, 11u32, 12u32, 13u32, 14u32)
        assert ctx.words.count == b0 + 7usize
        assert ctx.words[b0] == SpirvWord(SPIRV_OP_COMPOSITE_CONSTRUCT, 7u16)
        assert ctx.words[b0 + 1usize] == ctx.u32x4_id
        assert ctx.words[b0 + 2usize] == v
        assert ctx.words[b0 + 3usize] == 11u32
        assert ctx.words[b0 + 6usize] == 14u32
        # --- Construct F32x2: 5 words. ---
        b1: usize = ctx.words.count
        v2: u32 = SpirvEmitCompositeConstructF32x2(ctx, 15u32, 16u32)
        assert ctx.words.count == b1 + 5usize
        assert ctx.words[b1] == SpirvWord(SPIRV_OP_COMPOSITE_CONSTRUCT, 5u16)
        assert ctx.words[b1 + 1usize] == ctx.f32x2_id
        _ = v2
        # --- Extract U32: scalar result, 5 words. ---
        b2: usize = ctx.words.count
        x: u32 = SpirvEmitCompositeExtractU32(ctx, v, 2u32)
        assert ctx.words.count == b2 + 5usize
        assert ctx.words[b2] == SpirvWord(SPIRV_OP_COMPOSITE_EXTRACT, 5u16)
        assert ctx.words[b2 + 1usize] == ctx.u32_id
        assert ctx.words[b2 + 2usize] == x
        assert ctx.words[b2 + 3usize] == v
        assert ctx.words[b2 + 4usize] == 2u32
        # --- Insert F32x4: object before composite, 6 words. ---
        b3: usize = ctx.words.count
        ins: u32 = SpirvEmitCompositeInsertF32x4(ctx, 20u32, 21u32, 3u32)
        assert ctx.words.count == b3 + 6usize
        assert ctx.words[b3] == SpirvWord(SPIRV_OP_COMPOSITE_INSERT, 6u16)
        assert ctx.words[b3 + 1usize] == ctx.f32x4_id
        assert ctx.words[b3 + 2usize] == ins
        assert ctx.words[b3 + 3usize] == 21u32
        assert ctx.words[b3 + 4usize] == 20u32
        assert ctx.words[b3 + 5usize] == 3u32
        # --- Shuffle F32x4: 4 components, 9 words. ---
        b4: usize = ctx.words.count
        sh: u32 = SpirvEmitCompositeShuffleF32x4(ctx, 30u32, 31u32, 0u32, 1u32, 4u32, 5u32)
        assert ctx.words.count == b4 + 9usize
        assert ctx.words[b4] == SpirvWord(SPIRV_OP_VECTOR_SHUFFLE, 9u16)
        assert ctx.words[b4 + 1usize] == ctx.f32x4_id
        assert ctx.words[b4 + 3usize] == 30u32
        assert ctx.words[b4 + 4usize] == 31u32
        assert ctx.words[b4 + 8usize] == 5u32
        _ = sh

@test
def spirv_backend_emit_integer_matches_cpp() -> void:
    can Abort.Panic, Memory.Allocate:
        ctx: mutable SpirvEmitContext = SpirvEmitContext_Default()
        SpirvEmitContext_DefineArithmeticTypes(ctx)
        SpirvEmitContext_DefineExtInst(ctx)
        # --- Core binary arithmetic: 5-word op with U32 result type. ---
        b0: usize = ctx.words.count
        add: u32 = SpirvEmitIAdd32(ctx, 10u32, 11u32)
        assert ctx.words.count == b0 + 5usize
        assert ctx.words[b0] == SpirvWord(SPIRV_OP_I_ADD, 5u16)
        assert ctx.words[b0 + 1usize] == ctx.u32_id
        assert ctx.words[b0 + 2usize] == add
        b1: usize = ctx.words.count
        _shr: u32 = SpirvEmitShiftRightArithmetic32(ctx, 12u32, 2u32)
        assert ctx.words[b1] == SpirvWord(SPIRV_OP_SHIFT_RIGHT_ARITHMETIC, 5u16)
        # --- Unary: OpNot is a 4-word op. ---
        b2: usize = ctx.words.count
        notv: u32 = SpirvEmitBitwiseNot32(ctx, 13u32)
        assert ctx.words.count == b2 + 4usize
        assert ctx.words[b2] == SpirvWord(SPIRV_OP_NOT, 4u16)
        assert ctx.words[b2 + 2usize] == notv
        # --- BitFieldInsert: 4 operands -> 7-word op. ---
        b3: usize = ctx.words.count
        bfi: u32 = SpirvEmitBitFieldInsert(ctx, 1u32, 2u32, 3u32, 4u32)
        assert ctx.words.count == b3 + 7usize
        assert ctx.words[b3] == SpirvWord(SPIRV_OP_BIT_FIELD_INSERT, 7u16)
        assert ctx.words[b3 + 2usize] == bfi
        assert ctx.words[b3 + 3usize] == 1u32
        assert ctx.words[b3 + 6usize] == 4u32
        # --- BitFieldUExtract: 3 operands -> 6-word op. ---
        b4: usize = ctx.words.count
        bfe: u32 = SpirvEmitBitFieldUExtract(ctx, 5u32, 6u32, 7u32)
        assert ctx.words.count == b4 + 6usize
        assert ctx.words[b4] == SpirvWord(SPIRV_OP_BIT_FIELD_U_EXTRACT, 6u16)
        _ = bfe
        # --- Comparison: U1 result type. ---
        b5: usize = ctx.words.count
        lt: u32 = SpirvEmitSLessThan32(ctx, 20u32, 21u32)
        assert ctx.words[b5] == SpirvWord(SPIRV_OP_S_LESS_THAN, 5u16)
        assert ctx.words[b5 + 1usize] == ctx.u1_id
        assert ctx.words[b5 + 2usize] == lt
        # --- GLSL.std.450 min: 7-word ext-inst with U32 result. ---
        b6: usize = ctx.words.count
        smin: u32 = SpirvEmitSMin32(ctx, 30u32, 31u32)
        assert ctx.words[b6] == SpirvWord(SPIRV_OP_EXT_INST, 7u16)
        assert ctx.words[b6 + 1usize] == ctx.u32_id
        assert ctx.words[b6 + 4usize] == GLSL_STD_450_SMIN
        _ = smin
        # --- GLSL.std.450 clamp: 8-word ext-inst. ---
        b7: usize = ctx.words.count
        clamp: u32 = SpirvEmitUClamp32(ctx, 40u32, 41u32, 42u32)
        assert ctx.words[b7] == SpirvWord(SPIRV_OP_EXT_INST, 8u16)
        assert ctx.words[b7 + 4usize] == GLSL_STD_450_UCLAMP
        assert ctx.words[b7 + 7usize] == 42u32
        _ = clamp
        # --- IAbs via GLSL SAbs: 6-word ext-inst. ---
        b8: usize = ctx.words.count
        iabs: u32 = SpirvEmitIAbs32(ctx, 50u32)
        assert ctx.words[b8] == SpirvWord(SPIRV_OP_EXT_INST, 6u16)
        assert ctx.words[b8 + 4usize] == GLSL_STD_450_SABS
        _ = iabs

@test
def spirv_backend_emit_bitwise_conversion_matches_cpp() -> void:
    can Abort.Panic, Memory.Allocate:
        ctx: mutable SpirvEmitContext = SpirvEmitContext_Default()
        ctx.uses_fp16 <- true
        ctx.uses_fp64 <- true
        SpirvEmitContext_DefineArithmeticTypes(ctx)
        SpirvEmitContext_DefineExtInst(ctx)
        # --- Plain reinterprets are single 4-word OpBitcast. ---
        b0: usize = ctx.words.count
        bc: u32 = SpirvEmitBitCastU32F32(ctx, 100u32)
        assert ctx.words.count == b0 + 4usize
        assert ctx.words[b0] == SpirvWord(SPIRV_OP_BITCAST, 4u16)
        assert ctx.words[b0 + 1usize] == ctx.u32_id
        assert ctx.words[b0 + 2usize] == bc
        # --- PackUint2x32 reinterprets to U64. ---
        b1: usize = ctx.words.count
        p2x32: u32 = SpirvEmitPackUint2x32(ctx, 101u32)
        assert ctx.words[b1 + 1usize] == ctx.u64_id
        _ = p2x32
        # --- PackHalf2x16: 6-word GLSL ext-inst producing U32. ---
        b2: usize = ctx.words.count
        ph: u32 = SpirvEmitPackHalf2x16(ctx, 102u32)
        assert ctx.words.count == b2 + 6usize
        assert ctx.words[b2] == SpirvWord(SPIRV_OP_EXT_INST, 6u16)
        assert ctx.words[b2 + 1usize] == ctx.u32_id
        assert ctx.words[b2 + 4usize] == GLSL_STD_450_PACK_HALF2X16
        _ = ph
        # --- UnpackUnorm4x8 produces F32x4. ---
        b3: usize = ctx.words.count
        uu: u32 = SpirvEmitUnpackUnorm4x8(ctx, 103u32)
        assert ctx.words[b3 + 1usize] == ctx.f32x4_id
        assert ctx.words[b3 + 4usize] == GLSL_STD_450_UNPACK_UNORM4X8
        _ = uu
        # --- PackUint2x16: bitcast u32x2, two extracts, two consts, insert. ---
        b4: usize = ctx.words.count
        p2x16: u32 = SpirvEmitPackUint2x16(ctx, 104u32)
        assert ctx.words[b4] == SpirvWord(SPIRV_OP_BITCAST, 4u16)
        assert ctx.words[b4 + 1usize] == ctx.u32x2_id
        # Final instruction is a 7-word OpBitFieldInsert producing the result.
        assert ctx.words[ctx.words.count - 7usize] == SpirvWord(SPIRV_OP_BIT_FIELD_INSERT, 7u16)
        assert p2x16 == ctx.words[ctx.words.count - 5usize]
        # --- UnpackSint4x8 ends in a bitcast to F32x4. ---
        b5: usize = ctx.words.count
        us4: u32 = SpirvEmitUnpackSint4x8(ctx, 105u32)
        # The offset/size ConstU32 operands are emitted before the first extract.
        assert ctx.words[b5] == SpirvWord(SPIRV_OP_CONSTANT, 4u16)
        assert ctx.words[ctx.words.count - 4usize] == SpirvWord(SPIRV_OP_BITCAST, 4u16)
        assert ctx.words[ctx.words.count - 3usize] == ctx.f32x4_id
        assert us4 == ctx.words[ctx.words.count - 2usize]

@test
def spirv_backend_emit_convert_matches_cpp() -> void:
    can Abort.Panic, Memory.Allocate:
        ctx: mutable SpirvEmitContext = SpirvEmitContext_Default()
        ctx.uses_fp16 <- true
        ctx.uses_fp64 <- true
        SpirvEmitContext_DefineArithmeticTypes(ctx)
        # --- Simple FToS to U32: single 4-word unary op. ---
        b0: usize = ctx.words.count
        s32: u32 = SpirvEmitConvertS32F32(ctx, 100u32)
        assert ctx.words.count == b0 + 4usize
        assert ctx.words[b0] == SpirvWord(SPIRV_OP_CONVERT_F_TO_S, 4u16)
        assert ctx.words[b0 + 1usize] == ctx.u32_id
        assert ctx.words[b0 + 2usize] == s32
        assert ctx.words[b0 + 3usize] == 100u32
        # --- FToU to U64. ---
        b1: usize = ctx.words.count
        u64v: u32 = SpirvEmitConvertU64F32(ctx, 101u32)
        assert ctx.words[b1] == SpirvWord(SPIRV_OP_CONVERT_F_TO_U, 4u16)
        assert ctx.words[b1 + 1usize] == ctx.u64_id
        _ = u64v
        # --- ConvertU16F32: inner FToU to U16, then UConvert to U32. ---
        b2: usize = ctx.words.count
        u16f: u32 = SpirvEmitConvertU16F32(ctx, 102u32)
        assert ctx.words.count == b2 + 8usize
        assert ctx.words[b2] == SpirvWord(SPIRV_OP_CONVERT_F_TO_U, 4u16)
        assert ctx.words[b2 + 1usize] == ctx.u16_id
        assert ctx.words[b2 + 4usize] == SpirvWord(SPIRV_OP_U_CONVERT, 4u16)
        assert ctx.words[b2 + 5usize] == ctx.u32_id
        assert ctx.words[b2 + 6usize] == u16f
        # outer operand is the inner FToU result id.
        assert ctx.words[b2 + 7usize] == ctx.words[b2 + 2usize]
        # --- ConvertF32S8: ExtractS8 (SConvert to S8) then SToF to F32. ---
        b3: usize = ctx.words.count
        f32s8: u32 = SpirvEmitConvertF32S8(ctx, 103u32)
        assert ctx.words.count == b3 + 8usize
        assert ctx.words[b3] == SpirvWord(SPIRV_OP_S_CONVERT, 4u16)
        assert ctx.words[b3 + 1usize] == ctx.s8_id
        assert ctx.words[b3 + 4usize] == SpirvWord(SPIRV_OP_CONVERT_S_TO_F, 4u16)
        assert ctx.words[b3 + 5usize] == ctx.f32_id
        assert ctx.words[b3 + 6usize] == f32s8
        assert ctx.words[b3 + 7usize] == ctx.words[b3 + 2usize]
        # --- FConvert F32<-F16 and F64<-F32. ---
        b4: usize = ctx.words.count
        f16f: u32 = SpirvEmitConvertF16F32(ctx, 104u32)
        assert ctx.words[b4] == SpirvWord(SPIRV_OP_F_CONVERT, 4u16)
        assert ctx.words[b4 + 1usize] == ctx.f16_id
        _ = f16f
        b5: usize = ctx.words.count
        f64f: u32 = SpirvEmitConvertF64F32(ctx, 105u32)
        assert ctx.words[b5 + 1usize] == ctx.f64_id
        _ = f64f

@test
def spirv_backend_emit_integer_completion_matches_cpp() -> void:
    can Abort.Panic, Memory.Allocate:
        ctx: mutable SpirvEmitContext = SpirvEmitContext_Default()
        SpirvEmitContext_DefineArithmeticTypes(ctx)
        SpirvEmitContext_DefineExtInst(ctx)
        # --- 64-bit arithmetic uses the u64 result type. ---
        b0: usize = ctx.words.count
        add64: u32 = SpirvEmitIAdd64(ctx, 100u32, 101u32)
        assert ctx.words[b0] == SpirvWord(SPIRV_OP_I_ADD, 5u16)
        assert ctx.words[b0 + 1usize] == ctx.u64_id
        assert ctx.words[b0 + 2usize] == add64
        # --- UMulHi: OpUMulExtended (full_result_u32x2) then extract hi word. ---
        b1: usize = ctx.words.count
        umulhi: u32 = SpirvEmitUMulHi(ctx, 5u32, 6u32)
        assert ctx.words[b1] == SpirvWord(SPIRV_OP_U_MUL_EXTENDED, 5u16)
        assert ctx.words[b1 + 1usize] == ctx.full_result_u32x2
        # extract: result_type u32, composite = mul_ext id (b1+2), index 1.
        assert ctx.words[b1 + 5usize] == SpirvWord(SPIRV_OP_COMPOSITE_EXTRACT, 5u16)
        assert ctx.words[b1 + 6usize] == ctx.u32_id
        assert ctx.words[b1 + 7usize] == umulhi
        assert ctx.words[b1 + 8usize] == ctx.words[b1 + 2usize]
        assert ctx.words[b1 + 9usize] == 1u32
        # --- SMulHi: two bitcasts to S32, SMulExtended (i32x2), extract, bitcast. ---
        b2: usize = ctx.words.count
        smulhi: u32 = SpirvEmitSMulHi(ctx, 7u32, 8u32)
        assert ctx.words[b2] == SpirvWord(SPIRV_OP_BITCAST, 4u16)
        assert ctx.words[b2 + 1usize] == ctx.s32_id
        assert ctx.words[b2 + 8usize] == SpirvWord(SPIRV_OP_S_MUL_EXTENDED, 5u16)
        assert ctx.words[b2 + 9usize] == ctx.full_result_i32x2
        _ = smulhi
        # --- BitCount64: bitcast u32x2, extract lo/hi, two BitCount32, IAdd32. ---
        b3: usize = ctx.words.count
        bc64: u32 = SpirvEmitBitCount64(ctx, 9u32)
        assert ctx.words[b3] == SpirvWord(SPIRV_OP_BITCAST, 4u16)
        assert ctx.words[b3 + 1usize] == ctx.u32x2_id
        # last instruction is the IAdd32 of the two popcounts.
        assert ctx.words[ctx.words.count - 5usize] == SpirvWord(SPIRV_OP_I_ADD, 5u16)
        assert bc64 == ctx.words[ctx.words.count - 3usize]
        # --- FindUMsb64 ends in an OpSelect choosing shifted-hi vs lo msb. ---
        b4: usize = ctx.words.count
        fmsb: u32 = SpirvEmitFindUMsb64(ctx, 10u32)
        assert ctx.words[ctx.words.count - 6usize] == SpirvWord(SPIRV_OP_SELECT, 6u16)
        assert ctx.words[ctx.words.count - 5usize] == ctx.u32_id
        assert fmsb == ctx.words[ctx.words.count - 4usize]
        _ = b4

@test
def spirv_backend_emit_floating_point_matches_cpp() -> void:
    can Abort.Panic, Memory.Allocate:
        ctx: mutable SpirvEmitContext = SpirvEmitContext_Default()
        SpirvEmitContext_DefineArithmeticTypes(ctx)
        SpirvEmitContext_DefineExtInst(ctx)
        # Arithmetic types occupy ids 1..42; the GLSL.std.450 import id is 43.
        assert ctx.glsl_std_450_id == 43u32
        # --- Core arithmetic: 5-word binary op with the F32 result type. ---
        b0: usize = ctx.words.count
        add: u32 = SpirvEmitFPAdd32(ctx, 10u32, 11u32)
        assert ctx.words.count == b0 + 5usize
        assert ctx.words[b0] == SpirvWord(SPIRV_OP_F_ADD, 5u16)
        assert ctx.words[b0 + 1usize] == ctx.f32_id
        assert ctx.words[b0 + 2usize] == add
        assert ctx.words[b0 + 3usize] == 10u32
        assert ctx.words[b0 + 4usize] == 11u32
        b1: usize = ctx.words.count
        _mul: u32 = SpirvEmitFPMul32(ctx, 12u32, 13u32)
        assert ctx.words[b1] == SpirvWord(SPIRV_OP_F_MUL, 5u16)
        # FNegate is a 4-word unary op.
        b2: usize = ctx.words.count
        neg: u32 = SpirvEmitFPNeg32(ctx, 14u32)
        assert ctx.words.count == b2 + 4usize
        assert ctx.words[b2] == SpirvWord(SPIRV_OP_F_NEGATE, 4u16)
        assert ctx.words[b2 + 2usize] == neg
        # --- GLSL.std.450 unary: OpExtInst is 6 words. ---
        b3: usize = ctx.words.count
        sq: u32 = SpirvEmitFPSqrt32(ctx, 20u32)
        assert ctx.words.count == b3 + 6usize
        assert ctx.words[b3] == SpirvWord(SPIRV_OP_EXT_INST, 6u16)
        assert ctx.words[b3 + 1usize] == ctx.f32_id
        assert ctx.words[b3 + 2usize] == sq
        assert ctx.words[b3 + 3usize] == ctx.glsl_std_450_id
        assert ctx.words[b3 + 4usize] == GLSL_STD_450_SQRT
        assert ctx.words[b3 + 5usize] == 20u32
        # --- GLSL.std.450 binary: OpExtInst is 7 words (FMax). ---
        b4: usize = ctx.words.count
        mx: u32 = SpirvEmitFPMax32(ctx, 21u32, 22u32)
        assert ctx.words.count == b4 + 7usize
        assert ctx.words[b4] == SpirvWord(SPIRV_OP_EXT_INST, 7u16)
        assert ctx.words[b4 + 4usize] == GLSL_STD_450_FMAX
        assert ctx.words[b4 + 5usize] == 21u32
        assert ctx.words[b4 + 6usize] == 22u32
        _ = mx
        # --- GLSL.std.450 ternary: OpExtInst is 8 words (Fma). ---
        b5: usize = ctx.words.count
        fma: u32 = SpirvEmitFPFma32(ctx, 23u32, 24u32, 25u32)
        assert ctx.words.count == b5 + 8usize
        assert ctx.words[b5] == SpirvWord(SPIRV_OP_EXT_INST, 8u16)
        assert ctx.words[b5 + 4usize] == GLSL_STD_450_FMA
        assert ctx.words[b5 + 7usize] == 25u32
        _ = fma
        # --- MinTri fallback: two nested GLSL FMin ext-insts (7 words each). ---
        b6: usize = ctx.words.count
        tri: u32 = SpirvEmitFPMinTri32(ctx, 30u32, 31u32, 32u32)
        assert ctx.words.count == b6 + 14usize
        assert ctx.words[b6] == SpirvWord(SPIRV_OP_EXT_INST, 7u16)
        assert ctx.words[b6 + 4usize] == GLSL_STD_450_FMIN
        # First (inner) min combines b=31,c=32.
        assert ctx.words[b6 + 5usize] == 31u32
        assert ctx.words[b6 + 6usize] == 32u32
        # Second (outer) min combines a=30 with the inner result.
        assert ctx.words[b6 + 7usize] == SpirvWord(SPIRV_OP_EXT_INST, 7u16)
        assert ctx.words[b6 + 11usize] == GLSL_STD_450_FMIN
        assert ctx.words[b6 + 12usize] == 30u32
        assert ctx.words[b6 + 13usize] == ctx.words[b6 + 2usize]
        assert tri == ctx.words[b6 + 9usize]

@test
def spirv_backend_emit_floating_point_completion_matches_cpp() -> void:
    can Abort.Panic, Memory.Allocate:
        ctx: mutable SpirvEmitContext = SpirvEmitContext_Default()
        ctx.uses_fp64 <- true
        SpirvEmitContext_DefineArithmeticTypes(ctx)
        SpirvEmitContext_DefineExtInst(ctx)
        # --- F64 arithmetic uses the f64 result type. ---
        b0: usize = ctx.words.count
        add64: u32 = SpirvEmitFPAdd64(ctx, 100u32, 101u32)
        assert ctx.words[b0] == SpirvWord(SPIRV_OP_F_ADD, 5u16)
        assert ctx.words[b0 + 1usize] == ctx.f64_id
        assert ctx.words[b0 + 2usize] == add64
        # --- Sin: FMul(pi_x2, value) then GLSL Sin of the product. ---
        b1: usize = ctx.words.count
        sin: u32 = SpirvEmitFPSin(ctx, 200u32)
        assert ctx.words.count == b1 + 11usize
        assert ctx.words[b1] == SpirvWord(SPIRV_OP_F_MUL, 5u16)
        assert ctx.words[b1 + 3usize] == ctx.pi_x2
        assert ctx.words[b1 + 4usize] == 200u32
        assert ctx.words[b1 + 5usize] == SpirvWord(SPIRV_OP_EXT_INST, 6u16)
        assert ctx.words[b1 + 6usize] == ctx.f32_id
        assert ctx.words[b1 + 7usize] == sin
        assert ctx.words[b1 + 9usize] == GLSL_STD_450_SIN
        # The Sin operand is the FMul result id (id at b1+2).
        assert ctx.words[b1 + 10usize] == ctx.words[b1 + 2usize]
        # --- FClamp32: 8-word GLSL ternary ext-inst. ---
        b2: usize = ctx.words.count
        clamp: u32 = SpirvEmitFPClamp32(ctx, 1u32, 2u32, 3u32)
        assert ctx.words[b2] == SpirvWord(SPIRV_OP_EXT_INST, 8u16)
        assert ctx.words[b2 + 4usize] == GLSL_STD_450_FCLAMP
        _ = clamp
        # --- FrexpExp32: FrexpStruct -> extract S32 component 1 -> bitcast U32. ---
        b3: usize = ctx.words.count
        fexp: u32 = SpirvEmitFPFrexpExp32(ctx, 7u32)
        assert ctx.words.count == b3 + 15usize
        assert ctx.words[b3] == SpirvWord(SPIRV_OP_EXT_INST, 6u16)
        assert ctx.words[b3 + 1usize] == ctx.frexp_result_f32
        assert ctx.words[b3 + 4usize] == GLSL_STD_450_FREXP_STRUCT
        assert ctx.words[b3 + 6usize] == SpirvWord(SPIRV_OP_COMPOSITE_EXTRACT, 5u16)
        assert ctx.words[b3 + 7usize] == ctx.s32_id
        assert ctx.words[b3 + 10usize] == 1u32
        assert ctx.words[b3 + 11usize] == SpirvWord(SPIRV_OP_BITCAST, 4u16)
        assert ctx.words[b3 + 12usize] == ctx.u32_id
        assert ctx.words[b3 + 13usize] == fexp
        # --- Comparisons produce the U1 type; IsNan is a unary U1 op. ---
        b4: usize = ctx.words.count
        lt: u32 = SpirvEmitFOrdLessThan(ctx, 10u32, 11u32)
        assert ctx.words[b4] == SpirvWord(SPIRV_OP_F_ORD_LESS_THAN, 5u16)
        assert ctx.words[b4 + 1usize] == ctx.u1_id
        assert ctx.words[b4 + 2usize] == lt
        b5: usize = ctx.words.count
        nan: u32 = SpirvEmitFPIsNan(ctx, 12u32)
        assert ctx.words.count == b5 + 4usize
        assert ctx.words[b5] == SpirvWord(SPIRV_OP_IS_NAN, 4u16)
        assert ctx.words[b5 + 1usize] == ctx.u1_id
        assert ctx.words[b5 + 2usize] == nan

@test
def spirv_backend_emit_special_matches_cpp() -> void:
    can Abort.Panic, Memory.Allocate:
        ctx: mutable SpirvEmitContext = SpirvEmitContext_Default()
        SpirvEmitContext_DefineArithmeticTypes(ctx)
        # Zero-operand void ops are a single word.
        b0: usize = ctx.words.count
        SpirvEmitDiscard(ctx)
        assert ctx.words.count == b0 + 1usize
        assert ctx.words[b0] == SpirvWord(SPIRV_OP_DEMOTE_TO_HELPER_INVOCATION, 1u16)
        b1: usize = ctx.words.count
        SpirvEmitEmitVertex(ctx)
        assert ctx.words.count == b1 + 1usize
        assert ctx.words[b1] == SpirvWord(SPIRV_OP_EMIT_VERTEX, 1u16)
        b2: usize = ctx.words.count
        SpirvEmitEmitPrimitive(ctx)
        assert ctx.words[b2] == SpirvWord(SPIRV_OP_END_PRIMITIVE, 1u16)
        # EmitDiscardCond: SelectionMerge(3) + BranchConditional(4) + Label(2)
        # + Discard(1) + Branch(2) + Label(2) = 14 words.
        next_id: u32 = ctx.next_id
        b3: usize = ctx.words.count
        SpirvEmitDiscardCond(ctx, 77u32)
        assert ctx.words.count == b3 + 14usize
        # kill_label = next_id, merge_label = next_id + 1.
        kill_label: u32 = next_id
        merge_label: u32 = next_id + 1u32
        assert ctx.words[b3] == SpirvWord(SPIRV_OP_SELECTION_MERGE, 3u16)
        assert ctx.words[b3 + 1usize] == merge_label
        assert ctx.words[b3 + 2usize] == SPIRV_SELECTION_CONTROL_NONE
        assert ctx.words[b3 + 3usize] == SpirvWord(SPIRV_OP_BRANCH_CONDITIONAL, 4u16)
        assert ctx.words[b3 + 4usize] == 77u32
        assert ctx.words[b3 + 5usize] == kill_label
        assert ctx.words[b3 + 6usize] == merge_label
        assert ctx.words[b3 + 7usize] == SpirvWord(SPIRV_OP_LABEL, 2u16)
        assert ctx.words[b3 + 8usize] == kill_label
        assert ctx.words[b3 + 9usize] == SpirvWord(SPIRV_OP_DEMOTE_TO_HELPER_INVOCATION, 1u16)
        assert ctx.words[b3 + 10usize] == SpirvWord(SPIRV_OP_BRANCH, 2u16)
        assert ctx.words[b3 + 11usize] == merge_label
        assert ctx.words[b3 + 12usize] == SpirvWord(SPIRV_OP_LABEL, 2u16)
        assert ctx.words[b3 + 13usize] == merge_label
        assert ctx.last_label == merge_label

@test
def spirv_backend_emit_warp_matches_cpp() -> void:
    can Abort.Panic, Memory.Allocate:
        ctx: mutable SpirvEmitContext = SpirvEmitContext_Default()
        SpirvEmitContext_DefineArithmeticTypes(ctx)
        SpirvEmitContext_DefineWarpInputs(ctx)
        # u32x4 is part of the arithmetic types (id 21); the subgroup invocation
        # input id is the first allocation after the type section (id 43).
        assert ctx.u32x4_id == 21u32
        assert ctx.subgroup_local_invocation_id == 43u32
        # EmitLaneId: OpLoad U32 from the subgroup pointer (4-word unary op).
        b0: usize = ctx.words.count
        lane: u32 = SpirvEmitLaneId(ctx)
        assert ctx.words.count == b0 + 4usize
        assert ctx.words[b0] == SpirvWord(SPIRV_OP_LOAD, 4u16)
        assert ctx.words[b0 + 1usize] == ctx.u32_id
        assert ctx.words[b0 + 2usize] == lane
        assert ctx.words[b0 + 3usize] == ctx.subgroup_local_invocation_id
        # EmitReadFirstLane: ConstU32(Subgroup) then a 5-word group op.
        b1: usize = ctx.words.count
        rfl: u32 = SpirvEmitReadFirstLane(ctx, 42u32)
        assert ctx.words[b1] == SpirvWord(SPIRV_OP_CONSTANT, 4u16)
        assert ctx.words[b1 + 3usize] == SPIRV_SCOPE_SUBGROUP
        gop: usize = b1 + 4usize
        assert ctx.words[gop] == SpirvWord(SPIRV_OP_GROUP_NON_UNIFORM_BROADCAST_FIRST, 5u16)
        assert ctx.words[gop + 1usize] == ctx.u32_id
        assert ctx.words[gop + 2usize] == rfl
        assert ctx.words[gop + 3usize] == ctx.words[b1 + 2usize]
        assert ctx.words[gop + 4usize] == 42u32
        # EmitQuadShuffle: scope const then a 6-word ternary group op.
        b2: usize = ctx.words.count
        qs: u32 = SpirvEmitQuadShuffle(ctx, 7u32, 8u32)
        q: usize = b2 + 4usize
        assert ctx.words[q] == SpirvWord(SPIRV_OP_GROUP_NON_UNIFORM_QUAD_BROADCAST, 6u16)
        assert ctx.words[q + 1usize] == ctx.u32_id
        assert ctx.words[q + 3usize] == ctx.words[b2 + 2usize]
        assert ctx.words[q + 4usize] == 7u32
        assert ctx.words[q + 5usize] == 8u32
        # EmitBallot: result type is the uvec4 type.
        b3: usize = ctx.words.count
        bal: u32 = SpirvEmitBallot(ctx, 9u32)
        bb: usize = b3 + 4usize
        assert ctx.words[bb] == SpirvWord(SPIRV_OP_GROUP_NON_UNIFORM_BALLOT, 5u16)
        assert ctx.words[bb + 1usize] == ctx.u32x4_id
        # EmitGroupAny: result type is U1.
        b4: usize = ctx.words.count
        any: u32 = SpirvEmitGroupAny(ctx, 10u32)
        ab: usize = b4 + 4usize
        assert ctx.words[ab] == SpirvWord(SPIRV_OP_GROUP_NON_UNIFORM_ANY, 5u16)
        assert ctx.words[ab + 1usize] == ctx.u1_id
        _ = qs
        _ = bal
        _ = any

@test
def spirv_backend_emit_barriers_match_cpp() -> void:
    can Abort.Panic, Memory.Allocate:
        ctx: mutable SpirvEmitContext = SpirvEmitContext_Default()
        SpirvEmitContext_DefineArithmeticTypes(ctx)
        # --- EmitBarrier (non-tessellation): two ConstU32 + OpControlBarrier ---
        b0: usize = ctx.words.count
        SpirvEmitBarrier(ctx, false)
        # execution=Workgroup const, memory=Workgroup const, semantics const, then barrier.
        assert ctx.words.count == b0 + 4usize + 4usize + 4usize + 4usize
        assert ctx.words[b0] == SpirvWord(SPIRV_OP_CONSTANT, 4u16)
        assert ctx.words[b0 + 3usize] == SPIRV_SCOPE_WORKGROUP
        assert ctx.words[b0 + 7usize] == SPIRV_SCOPE_WORKGROUP
        assert ctx.words[b0 + 11usize] == (SPIRV_MEM_SEM_ACQUIRE_RELEASE | SPIRV_MEM_SEM_WORKGROUP_MEMORY)
        cb: usize = b0 + 12usize
        assert ctx.words[cb] == SpirvWord(SPIRV_OP_CONTROL_BARRIER, 4u16)
        # The three operands are the const ids allocated above.
        assert ctx.words[cb + 1usize] == ctx.words[b0 + 2usize]
        assert ctx.words[cb + 2usize] == ctx.words[b0 + 6usize]
        assert ctx.words[cb + 3usize] == ctx.words[b0 + 10usize]
        # --- EmitBarrier (tessellation control): Invocation scope, no semantics ---
        b1: usize = ctx.words.count
        SpirvEmitBarrier(ctx, true)
        assert ctx.words[b1 + 7usize] == SPIRV_SCOPE_INVOCATION
        assert ctx.words[b1 + 11usize] == SPIRV_MEM_SEM_NONE
        # --- EmitWorkgroupMemoryBarrier: two ConstU32 + OpMemoryBarrier ---
        b2: usize = ctx.words.count
        SpirvEmitWorkgroupMemoryBarrier(ctx)
        assert ctx.words.count == b2 + 4usize + 4usize + 3usize
        assert ctx.words[b2 + 3usize] == SPIRV_SCOPE_WORKGROUP
        assert ctx.words[b2 + 7usize] == SpirvMemoryBarrierSemantics()
        mb: usize = b2 + 8usize
        assert ctx.words[mb] == SpirvWord(SPIRV_OP_MEMORY_BARRIER, 3u16)
        assert ctx.words[mb + 1usize] == ctx.words[b2 + 2usize]
        assert ctx.words[mb + 2usize] == ctx.words[b2 + 6usize]
        # --- EmitDeviceMemoryBarrier: scope = Device ---
        b3: usize = ctx.words.count
        SpirvEmitDeviceMemoryBarrier(ctx)
        assert ctx.words[b3 + 3usize] == SPIRV_SCOPE_DEVICE
        assert ctx.words[b3 + 7usize] == SpirvMemoryBarrierSemantics()

@test
def spirv_backend_emit_undefined_matches_cpp() -> void:
    can Abort.Panic, Memory.Allocate:
        ctx: mutable SpirvEmitContext = SpirvEmitContext_Default()
        SpirvEmitContext_DefineArithmeticTypes(ctx)
        # Arithmetic types occupy ids 1..42; next free id is 43.
        b0: usize = ctx.words.count
        u1u: u32 = SpirvEmitUndefU1(ctx)
        # OpUndef emits 3 words and allocates the result id.
        assert u1u == 43u32
        assert ctx.words.count == b0 + 3usize
        assert ctx.words[b0] == SpirvWord(SPIRV_OP_UNDEF, 3u16)
        assert ctx.words[b0 + 1usize] == ctx.u1_id
        assert ctx.words[b0 + 2usize] == u1u
        # The U32 variant picks the U32 result type.
        b1: usize = ctx.words.count
        u32u: u32 = SpirvEmitUndefU32(ctx)
        assert u32u == 44u32
        assert ctx.words[b1] == SpirvWord(SPIRV_OP_UNDEF, 3u16)
        assert ctx.words[b1 + 1usize] == ctx.u32_id
        assert ctx.words[b1 + 2usize] == u32u

@test
def spirv_backend_emit_logical_matches_cpp() -> void:
    can Abort.Panic, Memory.Allocate:
        ctx: mutable SpirvEmitContext = SpirvEmitContext_Default()
        SpirvEmitContext_DefineArithmeticTypes(ctx)
        # Binary logical ops emit 5 words with the U1 result type.
        b0: usize = ctx.words.count
        _or: u32 = SpirvEmitLogicalOr(ctx, 10u32, 11u32)
        assert ctx.words.count == b0 + 5usize
        assert ctx.words[b0] == SpirvWord(SPIRV_OP_LOGICAL_OR, 5u16)
        assert ctx.words[b0 + 1usize] == ctx.u1_id
        assert ctx.words[b0 + 3usize] == 10u32
        assert ctx.words[b0 + 4usize] == 11u32
        # Xor lowers to OpLogicalNotEqual (matches the C++).
        b1: usize = ctx.words.count
        _xor: u32 = SpirvEmitLogicalXor(ctx, 20u32, 21u32)
        assert ctx.words[b1] == SpirvWord(SPIRV_OP_LOGICAL_NOT_EQUAL, 5u16)
        # Not is a 4-word unary op.
        b2: usize = ctx.words.count
        notv: u32 = SpirvEmitLogicalNot(ctx, 30u32)
        assert ctx.words.count == b2 + 4usize
        assert ctx.words[b2] == SpirvWord(SPIRV_OP_LOGICAL_NOT, 4u16)
        assert ctx.words[b2 + 1usize] == ctx.u1_id
        assert ctx.words[b2 + 2usize] == notv
        assert ctx.words[b2 + 3usize] == 30u32
        _ = _or
        _ = _xor
