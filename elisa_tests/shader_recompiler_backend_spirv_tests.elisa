include "../shader_recompiler/backend/spirv/spirv_backend.elisa"
include "../../compiler/runtime/elisacore_std/elisacore_runtime.elisa"

@test
def spirv_backend_primitive_modes_match_cpp_switches() -> void:
    can Abort.Panic:
        assert SpirvGetInputPrimitiveExecutionMode(AMDGPU_PRIMITIVE_POINT_LIST) == SPIRV_EXECUTION_MODE_INPUT_POINTS
        assert SpirvGetInputPrimitiveExecutionMode(AMDGPU_PRIMITIVE_LINE_LIST) == SPIRV_EXECUTION_MODE_INPUT_LINES
        assert SpirvGetInputPrimitiveExecutionMode(AMDGPU_PRIMITIVE_LINE_STRIP) == SPIRV_EXECUTION_MODE_INPUT_LINES
        assert SpirvGetInputPrimitiveExecutionMode(AMDGPU_PRIMITIVE_TRIANGLE_LIST) == SPIRV_EXECUTION_MODE_TRIANGLES
        assert SpirvGetInputPrimitiveExecutionMode(AMDGPU_PRIMITIVE_TRIANGLE_STRIP) == SPIRV_EXECUTION_MODE_TRIANGLES
        assert SpirvGetInputPrimitiveExecutionMode(AMDGPU_PRIMITIVE_RECT_LIST) == SPIRV_EXECUTION_MODE_TRIANGLES
        assert SpirvGetInputPrimitiveExecutionMode(AMDGPU_PRIMITIVE_ADJ_TRIANGLE_LIST) == SPIRV_EXECUTION_MODE_INPUT_TRIANGLES_ADJACENCY
        assert SpirvGetInputPrimitiveExecutionMode(AMDGPU_PRIMITIVE_ADJ_LINE_LIST) == SPIRV_EXECUTION_MODE_INPUT_LINES_ADJACENCY
        assert SpirvGetInputPrimitiveExecutionMode(AMDGPU_PRIMITIVE_TRIANGLE_FAN) == 0

@test
def spirv_backend_output_modes_match_cpp_switches() -> void:
    can Abort.Panic:
        assert SpirvGetOutputPrimitiveExecutionMode(AMDGPU_GS_OUTPUT_POINT_LIST) == SPIRV_EXECUTION_MODE_OUTPUT_VERTICES
        assert SpirvGetOutputPrimitiveExecutionMode(AMDGPU_GS_OUTPUT_LINE_STRIP) == SPIRV_EXECUTION_MODE_OUTPUT_LINE_STRIP
        assert SpirvGetOutputPrimitiveExecutionMode(AMDGPU_GS_OUTPUT_TRIANGLE_STRIP) == SPIRV_EXECUTION_MODE_OUTPUT_TRIANGLE_STRIP
        assert SpirvGetOutputPrimitiveExecutionMode(99) == 0

@test
def spirv_backend_vector_ids_are_one_based_like_cpp() -> void:
    can Abort.Panic:
        ids: mutable SpirvVectorIds = SpirvVectorIds_Default()
        assert SpirvVectorIds_Set(ids, 1, 11) == true
        assert SpirvVectorIds_Set(ids, 4, 44) == true
        assert SpirvVectorIds_Set(ids, 0, 99) == false
        assert SpirvVectorIds_Get(ids, 1) == 11
        assert SpirvVectorIds_Get(ids, 4) == 44
        assert SpirvVectorIds_Get(ids, 5) == SPIRV_INVALID_ID

@test
def spirv_backend_binding_and_header_are_deterministic() -> void:
    can Abort.Panic, Memory.Allocate:
        binding: mutable ShaderBackendBindings = ShaderBackendBindings_Default()
        result: SpirvEmitResult = SpirvEmitMinimalModule(binding)
        assert result.ok == true
        assert result.words.count == 5
        assert result.words[0] == SPIRV_MAGIC
        assert result.words[1] == SPIRV_VERSION_1_6
        assert result.words[3] == result.bound
        assert binding.unified == 1
        assert binding.buffer == 1
        assert binding.user_data == 0

@test
def spirv_quad_rect_passthrough_tes_assembles() -> void:
    can Abort.Panic, Memory.Allocate:
        # One forwarded vertex param at location 0.
        locs: mutable darray[u32] = zeroed
        owner: mutable Arena& = &scratch_arena
        in owner:
            locs.push(0)
        words: darray[u32] = SpirvEmitPassthroughTESModule(locs)
        # Header: magic, SPIR-V 1.5, generator, bound+1, schema.
        assert words[0] == SPIRV_MAGIC
        assert words[1] == SPIRV_VERSION_1_5
        assert words[4] == SPIRV_SCHEMA_RESERVED
        # First section is the two OpCapability (Shader, Tessellation).
        assert words[5] == SpirvWord(SPIRV_OP_CAPABILITY, 2)
        assert words[6] == SPIRV_CAPABILITY_SHADER
        assert words[7] == SpirvWord(SPIRV_OP_CAPABILITY, 2)
        assert words[8] == SPIRV_CAPABILITY_TESSELLATION
        # OpMemoryModel follows the (empty) ext-inst-import section.
        assert words[9] == SpirvWord(SPIRV_OP_MEMORY_MODEL, 3)
        # The OpEntryPoint is for a TessellationEvaluation shader named "main".
        # 5 base words + 5 interface ids (gl_TessCoord, gl_in, 1 input,
        # gl_PerVertex, 1 output) = 10 words.
        assert words[12] == SpirvWord(SPIRV_OP_ENTRY_POINT, 10)
        assert words[13] == SPIRV_EXEC_MODEL_TESS_EVAL
        assert words[15] == SPIRV_NAME_MAIN_W0
        assert words[16] == SPIRV_NAME_MAIN_W1
        # The module ends with the function body: ... OpReturn, OpFunctionEnd.
        assert words[words.count - 1] == SpirvWord(SPIRV_OP_FUNCTION_END, 1)
        assert words[words.count - 2] == SpirvWord(SPIRV_OP_RETURN, 1)

@test
def spirv_quad_rect_tcs_shaders_assemble() -> void:
    can Abort.Panic, Memory.Allocate:
        locs: mutable darray[u32] = zeroed
        owner: mutable Arena& = &scratch_arena
        in owner:
            locs.push(0)
        # --- QuadListTCS: TessControl entry + OutputVertices 4 exec mode. ---
        qw: darray[u32] = SpirvEmitQuadListTCSModule(locs)
        assert qw[0] == SPIRV_MAGIC
        assert qw[1] == SPIRV_VERSION_1_5
        assert qw[5] == SpirvWord(SPIRV_OP_CAPABILITY, 2)
        # OpEntryPoint (after caps + memory model) is a TessControl shader.
        # 5 base words + 7 interface ids (invocation_id, gl_in, 1 input, gl_out,
        # tess_inner, tess_outer, 1 output) = 12 words.
        assert qw[12] == SpirvWord(SPIRV_OP_ENTRY_POINT, 12)
        assert qw[13] == SPIRV_EXEC_MODEL_TESS_CONTROL
        # The execution-modes section follows the 12-word entry point (at word 24).
        assert qw[24] == SpirvWord(SPIRV_OP_EXECUTION_MODE, 4)
        assert qw[26] == SPIRV_EXEC_MODE_OUTPUT_VERTICES
        assert qw[27] == 4
        assert qw[qw.count - 1] == SpirvWord(SPIRV_OP_FUNCTION_END, 1)
        # --- RectListTCS: also a TessControl shader, larger body (interp). ---
        rw: darray[u32] = SpirvEmitRectListTCSModule(locs)
        assert rw[1] == SPIRV_VERSION_1_5
        assert rw[13] == SPIRV_EXEC_MODEL_TESS_CONTROL
        assert rw[rw.count - 1] == SpirvWord(SPIRV_OP_FUNCTION_END, 1)
        assert rw[rw.count - 2] == SpirvWord(SPIRV_OP_RETURN, 1)
        # The rect interpolation emits OpVectorTimesScalar; ensure it appears.
        found_vts: mutable bool = false
        for i in 0..<rw.count:
            if rw[i] == SpirvWord(SPIRV_OP_VECTOR_TIMES_SCALAR, 5):
                found_vts <- true
        assert found_vts == true

@test
def spirv_module_dedups_declarations_like_sirit() -> void:
    can Abort.Panic, Memory.Allocate:
        m: mutable SpirvModule = SpirvModule_Default()
        # First use of each type allocates a fresh id.
        u32_a: u32 = SpirvModule_TypeInt(m, 32, 0)
        f32_t: u32 = SpirvModule_TypeFloat(m, 32)
        assert u32_a == 1
        assert f32_t == 2
        # Re-emitting an identical type returns the same id and adds no words.
        before: usize = m.declarations.count
        bound_before: u32 = m.bound
        u32_b: u32 = SpirvModule_TypeInt(m, 32, 0)
        assert u32_b == u32_a
        assert m.declarations.count == before
        assert m.bound == bound_before
        # A differing operand (signedness) is a distinct declaration.
        s32_t: u32 = SpirvModule_TypeInt(m, 32, 1)
        assert s32_t == 3
        # Constants dedup too (result-type word precedes the id).
        c0_a: u32 = SpirvModule_Constant32(m, u32_a, 0)
        c0_b: u32 = SpirvModule_Constant32(m, u32_a, 0)
        c1: u32 = SpirvModule_Constant32(m, u32_a, 1)
        assert c0_a == c0_b
        assert c1 != c0_a

@test
def spirv_module_assemble_emits_header_and_sections() -> void:
    can Abort.Panic, Memory.Allocate:
        m: mutable SpirvModule = SpirvModule_Default()
        m.addressing_model <- 0
        m.memory_model <- 1
        SpirvModule_AddCapability(m, 1)
        u32_t: u32 = SpirvModule_TypeInt(m, 32, 0)
        a: u32 = SpirvModule_Constant32(m, u32_t, 10)
        b: u32 = SpirvModule_Constant32(m, u32_t, 20)
        sum: u32 = SpirvModule_EmitCodeBinary(m, SPIRV_OP_I_ADD, u32_t, a, b)
        words: darray[u32] = SpirvModule_Assemble(m)
        # Header.
        assert words[0] == SPIRV_MAGIC
        assert words[1] == SPIRV_VERSION_1_6
        assert words[3] == m.bound + 1
        assert words[4] == SPIRV_SCHEMA_RESERVED
        # OpCapability(2), value=1.
        assert words[5] == SpirvWord(SPIRV_OP_CAPABILITY, 2)
        assert words[6] == 1
        # OpMemoryModel(3) follows (no ext-inst imports were added).
        assert words[7] == SpirvWord(SPIRV_OP_MEMORY_MODEL, 3)
        assert words[8] == 0
        assert words[9] == 1
        # The IAdd from the code section is the last instruction (5 words).
        assert words[words.count - 5] == SpirvWord(SPIRV_OP_I_ADD, 5)
        assert words[words.count - 4] == u32_t
        assert words[words.count - 3] == sum
        assert words[words.count - 2] == a
        assert words[words.count - 1] == b

@test
def spirv_backend_arithmetic_type_ids_follow_cpp_order() -> void:
    can Abort.Panic:
        ctx: mutable SpirvEmitContext = SpirvEmitContext_Default()
        SpirvEmitContext_DefineArithmeticTypes(ctx)
        # Scalar types (fp16/fp64 disabled by default), matching the C++ order.
        assert ctx.void_id == 1
        assert ctx.u1_id == 2
        assert ctx.u8_id == 3
        assert ctx.s8_id == 4
        assert ctx.u16_id == 5
        assert ctx.s16_id == 6
        assert ctx.f32_id == 7
        assert ctx.s32_id == 8
        assert ctx.u32_id == 9
        assert ctx.u64_id == 10
        # Vector types, component counts 2..4.
        assert ctx.f32x2_id == 11
        assert ctx.u1x2_id == 14
        assert ctx.f32x4_id == 19
        assert ctx.u1x4_id == 22
        # Constants, then input/output pointers, then struct result types.
        assert ctx.true_value == 23
        assert ctx.u32_zero_value == 29
        assert ctx.pi_x2 == 33
        assert ctx.input_f32 == 34
        assert ctx.output_s32 == 39
        assert ctx.full_result_i32x2 == 40
        assert ctx.frexp_result_f32 == 42
        # Next free id after the arithmetic-type section.
        assert ctx.next_id == 43
        assert SpirvTypeId(ctx, SHADER_IR_TYPE_U1) == 2
        assert SpirvTypeId(ctx, SHADER_IR_TYPE_U32) == 9
        assert SpirvTypeId(ctx, SHADER_IR_TYPE_VOID) == SPIRV_INVALID_ID

@test
def spirv_backend_word_packs_count_and_opcode() -> void:
    can Abort.Panic:
        assert SpirvWord(19, 2) == 0x00020013

@test
def spirv_backend_emit_select_matches_cpp_opselect() -> void:
    can Abort.Panic, Memory.Allocate:
        ctx: mutable SpirvEmitContext = SpirvEmitContext_Default()
        SpirvEmitContext_DefineArithmeticTypes(ctx)
        # Arithmetic types occupy ids 1..42; f32 is id 7, next free id is 43.
        assert ctx.f32_id == 7
        before: usize = ctx.words.count
        result: u32 = SpirvEmitSelectU32(ctx, 10, 11, 12)
        # OpSelect emits 6 words and allocates the result id (43).
        assert result == 43
        assert ctx.words.count == before + 6
        assert ctx.words[before] == SpirvWord(SPIRV_OP_SELECT, 6)
        assert ctx.words[before + 1] == ctx.u32_id
        assert ctx.words[before + 2] == result
        assert ctx.words[before + 3] == 10
        assert ctx.words[before + 4] == 11
        assert ctx.words[before + 5] == 12
        # Typed variants pick the matching scalar result type.
        u1_sel: u32 = SpirvEmitSelectU1(ctx, 1, 2, 3)
        assert ctx.words[ctx.words.count - 5] == ctx.u1_id
        f32_sel: u32 = SpirvEmitSelectF32(ctx, 4, 5, 6)
        assert ctx.words[ctx.words.count - 5] == ctx.f32_id
        _ = u1_sel
        _ = f32_sel

@test
def spirv_backend_emit_composite_matches_cpp() -> void:
    can Abort.Panic, Memory.Allocate:
        ctx: mutable SpirvEmitContext = SpirvEmitContext_Default()
        SpirvEmitContext_DefineArithmeticTypes(ctx)
        # Vector types come from the arithmetic-type section: u32x2=13, f32x4=19.
        assert ctx.u32x2_id == 13
        assert ctx.f32x4_id == 19
        # --- Construct U32x4: 7 words. ---
        b0: usize = ctx.words.count
        v: u32 = SpirvEmitCompositeConstructU32x4(ctx, 11, 12, 13, 14)
        assert ctx.words.count == b0 + 7
        assert ctx.words[b0] == SpirvWord(SPIRV_OP_COMPOSITE_CONSTRUCT, 7)
        assert ctx.words[b0 + 1] == ctx.u32x4_id
        assert ctx.words[b0 + 2] == v
        assert ctx.words[b0 + 3] == 11
        assert ctx.words[b0 + 6] == 14
        # --- Construct F32x2: 5 words. ---
        b1: usize = ctx.words.count
        v2: u32 = SpirvEmitCompositeConstructF32x2(ctx, 15, 16)
        assert ctx.words.count == b1 + 5
        assert ctx.words[b1] == SpirvWord(SPIRV_OP_COMPOSITE_CONSTRUCT, 5)
        assert ctx.words[b1 + 1] == ctx.f32x2_id
        _ = v2
        # --- Extract U32: scalar result, 5 words. ---
        b2: usize = ctx.words.count
        x: u32 = SpirvEmitCompositeExtractU32(ctx, v, 2)
        assert ctx.words.count == b2 + 5
        assert ctx.words[b2] == SpirvWord(SPIRV_OP_COMPOSITE_EXTRACT, 5)
        assert ctx.words[b2 + 1] == ctx.u32_id
        assert ctx.words[b2 + 2] == x
        assert ctx.words[b2 + 3] == v
        assert ctx.words[b2 + 4] == 2
        # --- Insert F32x4: object before composite, 6 words. ---
        b3: usize = ctx.words.count
        ins: u32 = SpirvEmitCompositeInsertF32x4(ctx, 20, 21, 3)
        assert ctx.words.count == b3 + 6
        assert ctx.words[b3] == SpirvWord(SPIRV_OP_COMPOSITE_INSERT, 6)
        assert ctx.words[b3 + 1] == ctx.f32x4_id
        assert ctx.words[b3 + 2] == ins
        assert ctx.words[b3 + 3] == 21
        assert ctx.words[b3 + 4] == 20
        assert ctx.words[b3 + 5] == 3
        # --- Shuffle F32x4: 4 components, 9 words. ---
        b4: usize = ctx.words.count
        sh: u32 = SpirvEmitCompositeShuffleF32x4(ctx, 30, 31, 0, 1, 4, 5)
        assert ctx.words.count == b4 + 9
        assert ctx.words[b4] == SpirvWord(SPIRV_OP_VECTOR_SHUFFLE, 9)
        assert ctx.words[b4 + 1] == ctx.f32x4_id
        assert ctx.words[b4 + 3] == 30
        assert ctx.words[b4 + 4] == 31
        assert ctx.words[b4 + 8] == 5
        _ = sh

@test
def spirv_backend_emit_integer_matches_cpp() -> void:
    can Abort.Panic, Memory.Allocate:
        ctx: mutable SpirvEmitContext = SpirvEmitContext_Default()
        SpirvEmitContext_DefineArithmeticTypes(ctx)
        SpirvEmitContext_DefineExtInst(ctx)
        # --- Core binary arithmetic: 5-word op with U32 result type. ---
        b0: usize = ctx.words.count
        add: u32 = SpirvEmitIAdd32(ctx, 10, 11)
        assert ctx.words.count == b0 + 5
        assert ctx.words[b0] == SpirvWord(SPIRV_OP_I_ADD, 5)
        assert ctx.words[b0 + 1] == ctx.u32_id
        assert ctx.words[b0 + 2] == add
        b1: usize = ctx.words.count
        _shr: u32 = SpirvEmitShiftRightArithmetic32(ctx, 12, 2)
        assert ctx.words[b1] == SpirvWord(SPIRV_OP_SHIFT_RIGHT_ARITHMETIC, 5)
        # --- Unary: OpNot is a 4-word op. ---
        b2: usize = ctx.words.count
        notv: u32 = SpirvEmitBitwiseNot32(ctx, 13)
        assert ctx.words.count == b2 + 4
        assert ctx.words[b2] == SpirvWord(SPIRV_OP_NOT, 4)
        assert ctx.words[b2 + 2] == notv
        # --- BitFieldInsert: 4 operands -> 7-word op. ---
        b3: usize = ctx.words.count
        bfi: u32 = SpirvEmitBitFieldInsert(ctx, 1, 2, 3, 4)
        assert ctx.words.count == b3 + 7
        assert ctx.words[b3] == SpirvWord(SPIRV_OP_BIT_FIELD_INSERT, 7)
        assert ctx.words[b3 + 2] == bfi
        assert ctx.words[b3 + 3] == 1
        assert ctx.words[b3 + 6] == 4
        # --- BitFieldUExtract: 3 operands -> 6-word op. ---
        b4: usize = ctx.words.count
        bfe: u32 = SpirvEmitBitFieldUExtract(ctx, 5, 6, 7)
        assert ctx.words.count == b4 + 6
        assert ctx.words[b4] == SpirvWord(SPIRV_OP_BIT_FIELD_U_EXTRACT, 6)
        _ = bfe
        # --- Comparison: U1 result type. ---
        b5: usize = ctx.words.count
        lt: u32 = SpirvEmitSLessThan32(ctx, 20, 21)
        assert ctx.words[b5] == SpirvWord(SPIRV_OP_S_LESS_THAN, 5)
        assert ctx.words[b5 + 1] == ctx.u1_id
        assert ctx.words[b5 + 2] == lt
        # --- GLSL.std.450 min: 7-word ext-inst with U32 result. ---
        b6: usize = ctx.words.count
        smin: u32 = SpirvEmitSMin32(ctx, 30, 31)
        assert ctx.words[b6] == SpirvWord(SPIRV_OP_EXT_INST, 7)
        assert ctx.words[b6 + 1] == ctx.u32_id
        assert ctx.words[b6 + 4] == GLSL_STD_450_SMIN
        _ = smin
        # --- GLSL.std.450 clamp: 8-word ext-inst. ---
        b7: usize = ctx.words.count
        clamp: u32 = SpirvEmitUClamp32(ctx, 40, 41, 42)
        assert ctx.words[b7] == SpirvWord(SPIRV_OP_EXT_INST, 8)
        assert ctx.words[b7 + 4] == GLSL_STD_450_UCLAMP
        assert ctx.words[b7 + 7] == 42
        _ = clamp
        # --- IAbs via GLSL SAbs: 6-word ext-inst. ---
        b8: usize = ctx.words.count
        iabs: u32 = SpirvEmitIAbs32(ctx, 50)
        assert ctx.words[b8] == SpirvWord(SPIRV_OP_EXT_INST, 6)
        assert ctx.words[b8 + 4] == GLSL_STD_450_SABS
        _ = iabs

@test
def spirv_backend_emit_bitwise_conversion_matches_cpp() -> void:
    can Abort.Panic, Memory.Allocate:
        ctx: mutable SpirvEmitContext = SpirvEmitContext_Default()
        ctx.uses_fp16 <- true
        ctx.uses_fp64 <- true
        SpirvEmitContext_DefineArithmeticTypes(ctx)
        SpirvEmitContext_DefineExtInst(ctx)
        # --- Plain reinterprets are single 4-word OpBitcast. ---
        b0: usize = ctx.words.count
        bc: u32 = SpirvEmitBitCastU32F32(ctx, 100)
        assert ctx.words.count == b0 + 4
        assert ctx.words[b0] == SpirvWord(SPIRV_OP_BITCAST, 4)
        assert ctx.words[b0 + 1] == ctx.u32_id
        assert ctx.words[b0 + 2] == bc
        # --- PackUint2x32 reinterprets to U64. ---
        b1: usize = ctx.words.count
        p2x32: u32 = SpirvEmitPackUint2x32(ctx, 101)
        assert ctx.words[b1 + 1] == ctx.u64_id
        _ = p2x32
        # --- PackHalf2x16: 6-word GLSL ext-inst producing U32. ---
        b2: usize = ctx.words.count
        ph: u32 = SpirvEmitPackHalf2x16(ctx, 102)
        assert ctx.words.count == b2 + 6
        assert ctx.words[b2] == SpirvWord(SPIRV_OP_EXT_INST, 6)
        assert ctx.words[b2 + 1] == ctx.u32_id
        assert ctx.words[b2 + 4] == GLSL_STD_450_PACK_HALF2X16
        _ = ph
        # --- UnpackUnorm4x8 produces F32x4. ---
        b3: usize = ctx.words.count
        uu: u32 = SpirvEmitUnpackUnorm4x8(ctx, 103)
        assert ctx.words[b3 + 1] == ctx.f32x4_id
        assert ctx.words[b3 + 4] == GLSL_STD_450_UNPACK_UNORM4X8
        _ = uu
        # --- PackUint2x16: bitcast u32x2, two extracts, two consts, insert. ---
        b4: usize = ctx.words.count
        p2x16: u32 = SpirvEmitPackUint2x16(ctx, 104)
        assert ctx.words[b4] == SpirvWord(SPIRV_OP_BITCAST, 4)
        assert ctx.words[b4 + 1] == ctx.u32x2_id
        # Final instruction is a 7-word OpBitFieldInsert producing the result.
        assert ctx.words[ctx.words.count - 7] == SpirvWord(SPIRV_OP_BIT_FIELD_INSERT, 7)
        assert p2x16 == ctx.words[ctx.words.count - 5]
        # --- UnpackSint4x8 ends in a bitcast to F32x4. ---
        b5: usize = ctx.words.count
        us4: u32 = SpirvEmitUnpackSint4x8(ctx, 105)
        # The offset/size ConstU32 operands are emitted before the first extract.
        assert ctx.words[b5] == SpirvWord(SPIRV_OP_CONSTANT, 4)
        assert ctx.words[ctx.words.count - 4] == SpirvWord(SPIRV_OP_BITCAST, 4)
        assert ctx.words[ctx.words.count - 3] == ctx.f32x4_id
        assert us4 == ctx.words[ctx.words.count - 2]

@test
def spirv_backend_emit_buffer_load_store_matches_cpp() -> void:
    can Abort.Panic, Memory.Allocate:
        ctx: mutable SpirvEmitContext = SpirvEmitContext_Default()
        SpirvEmitContext_DefineArithmeticTypes(ctx)
        base_var: u32 = SpirvEmitContext_AllocateId(ctx)
        ptr_ty: u32 = SpirvEmitContext_AllocateId(ctx)
        buf: mutable SpirvBufferDefinition = zeroed
        buf.alias_ids[SPIRV_POINTER_TYPE_U32.usize()] <- base_var
        buf.alias_ptrs[SPIRV_POINTER_TYPE_U32.usize()] <- ptr_ty
        _ = SpirvEmitContext_PushBuffer(ctx, buf)
        # --- ReadConstBuffer: single access chain + load (no offset). ---
        b0: usize = ctx.words.count
        rc: u32 = SpirvEmitReadConstBuffer(ctx, 0, 200)
        assert ctx.words.count == b0 + 10
        assert ctx.words[b0] == SpirvWord(SPIRV_OP_ACCESS_CHAIN, 6)
        assert ctx.words[b0 + 1] == ptr_ty
        assert ctx.words[b0 + 3] == base_var
        assert ctx.words[b0 + 4] == ctx.u32_zero_value
        assert ctx.words[b0 + 5] == 200
        assert ctx.words[b0 + 6] == SpirvWord(SPIRV_OP_LOAD, 4)
        assert ctx.words[b0 + 7] == ctx.u32_id
        assert rc == ctx.words[b0 + 8]
        # --- LoadBufferU32x2: two element loads, then a CompositeConstruct. ---
        b1: usize = ctx.words.count
        v2: u32 = SpirvEmitLoadBufferU32x2(ctx, 0, 300)
        assert ctx.words[b1] == SpirvWord(SPIRV_OP_ACCESS_CHAIN, 6)
        # The second element index is address + ConstU32(1).
        assert ctx.words[ctx.words.count - 5] == SpirvWord(SPIRV_OP_COMPOSITE_CONSTRUCT, 5)
        assert ctx.words[ctx.words.count - 4] == ctx.u32x2_id
        assert v2 == ctx.words[ctx.words.count - 3]
        # --- StoreBufferU32: access chain + store (no result id). ---
        b2: usize = ctx.words.count
        SpirvEmitStoreBufferU32(ctx, 0, 400, 77)
        assert ctx.words.count == b2 + 9
        assert ctx.words[b2] == SpirvWord(SPIRV_OP_ACCESS_CHAIN, 6)
        assert ctx.words[b2 + 6] == SpirvWord(SPIRV_OP_STORE, 3)
        assert ctx.words[b2 + 8] == 77
        # --- StoreBufferU32x4: 4 stores, last value is CompositeExtract index 3. ---
        b3: usize = ctx.words.count
        SpirvEmitStoreBufferU32x4(ctx, 0, 500, 88)
        assert ctx.words[ctx.words.count - 3] == SpirvWord(SPIRV_OP_STORE, 3)
        # The stored value came from an OpCompositeExtract of component 3
        # (5-word extract immediately precedes the 3-word store).
        assert ctx.words[ctx.words.count - 8] == SpirvWord(SPIRV_OP_COMPOSITE_EXTRACT, 5)
        assert ctx.words[ctx.words.count - 4] == 3

@test
def spirv_backend_emit_image_primitives_match_cpp() -> void:
    can Abort.Panic, Memory.Allocate:
        ctx: mutable SpirvEmitContext = SpirvEmitContext_Default()
        SpirvEmitContext_DefineArithmeticTypes(ctx)
        # --- OpSampledImage: 5-word binary combine of image + sampler. ---
        b0: usize = ctx.words.count
        si: u32 = SpirvEmitSampledImage(ctx, 50, 51, 52)
        assert ctx.words.count == b0 + 5
        assert ctx.words[b0] == SpirvWord(SPIRV_OP_SAMPLED_IMAGE, 5)
        assert ctx.words[b0 + 1] == 50
        assert ctx.words[b0 + 3] == 51
        assert ctx.words[b0 + 4] == 52
        # --- Sample with no operands: 5 words, mask omitted. ---
        empty: SpirvImageOperands = SpirvImageOperands_Default()
        b1: usize = ctx.words.count
        s0: u32 = SpirvEmitImageSampleImplicitLod(ctx, ctx.f32x4_id, si, 60, empty)
        assert ctx.words.count == b1 + 5
        assert ctx.words[b1] == SpirvWord(SPIRV_OP_IMAGE_SAMPLE_IMPLICIT_LOD, 5)
        assert ctx.words[b1 + 1] == ctx.f32x4_id
        assert ctx.words[b1 + 2] == s0
        assert ctx.words[b1 + 3] == si
        assert ctx.words[b1 + 4] == 60
        # --- Sample with a Bias operand: 5 + (mask + 1 operand) = 7 words. ---
        ops: mutable SpirvImageOperands = SpirvImageOperands_Default()
        SpirvImageOperands_Add1(ops, SPIRV_IMAGE_OPERAND_BIAS, 70)
        b2: usize = ctx.words.count
        s1: u32 = SpirvEmitImageSampleImplicitLod(ctx, ctx.f32x4_id, si, 61, ops)
        assert ctx.words.count == b2 + 7
        assert ctx.words[b2] == SpirvWord(SPIRV_OP_IMAGE_SAMPLE_IMPLICIT_LOD, 7)
        assert ctx.words[b2 + 4] == 61
        assert ctx.words[b2 + 5] == SPIRV_IMAGE_OPERAND_BIAS
        assert ctx.words[b2 + 6] == 70
        _ = s1
        # --- Invalid (zero) operand is ignored by the builder. ---
        ops2: mutable SpirvImageOperands = SpirvImageOperands_Default()
        SpirvImageOperands_Add1(ops2, SPIRV_IMAGE_OPERAND_LOD, 0)
        assert ops2.mask == 0
        # --- ImageWrite: no result id; 4 words + Sample operand tail (mask+1). ---
        wops: mutable SpirvImageOperands = SpirvImageOperands_Default()
        SpirvImageOperands_Add1(wops, SPIRV_IMAGE_OPERAND_SAMPLE, 80)
        b3: usize = ctx.words.count
        SpirvEmitImageWrite(ctx, 81, 82, 83, wops)
        assert ctx.words.count == b3 + 6
        assert ctx.words[b3] == SpirvWord(SPIRV_OP_IMAGE_WRITE, 6)
        assert ctx.words[b3 + 1] == 81
        assert ctx.words[b3 + 2] == 82
        assert ctx.words[b3 + 3] == 83
        assert ctx.words[b3 + 4] == SPIRV_IMAGE_OPERAND_SAMPLE
        assert ctx.words[b3 + 5] == 80
        # --- Gather: extra Component operand; QuerySizeLod is a 5-word binary op. ---
        gops: SpirvImageOperands = SpirvImageOperands_Default()
        b4: usize = ctx.words.count
        g: u32 = SpirvEmitImageGather(ctx, ctx.f32x4_id, si, 62, 1, gops)
        assert ctx.words[b4] == SpirvWord(SPIRV_OP_IMAGE_GATHER, 6)
        assert ctx.words[b4 + 5] == 1
        _ = g
        b5: usize = ctx.words.count
        q: u32 = SpirvEmitImageQuerySizeLod(ctx, ctx.u32x2_id, 90, 91)
        assert ctx.words[b5] == SpirvWord(SPIRV_OP_IMAGE_QUERY_SIZE_LOD, 5)
        assert ctx.words[b5 + 1] == ctx.u32x2_id
        assert q == ctx.words[b5 + 2]

@test
def spirv_backend_emit_buffer_image_atomic_matches_cpp() -> void:
    can Abort.Panic, Memory.Allocate:
        ctx: mutable SpirvEmitContext = SpirvEmitContext_Default()
        SpirvEmitContext_DefineArithmeticTypes(ctx)
        # Register a buffer with a U32 alias (stand-in for DefineBuffers).
        base_var: u32 = SpirvEmitContext_AllocateId(ctx)
        ptr_ty: u32 = SpirvEmitContext_AllocateId(ctx)
        buf: mutable SpirvBufferDefinition = zeroed
        buf.alias_ids[SPIRV_POINTER_TYPE_U32.usize()] <- base_var
        buf.alias_ptrs[SPIRV_POINTER_TYPE_U32.usize()] <- ptr_ty
        _ = SpirvEmitContext_PushBuffer(ctx, buf)
        # --- BufferAtomicIAdd32: access chain (no offset), scope const, atomic. ---
        b0: usize = ctx.words.count
        r: u32 = SpirvEmitBufferAtomicIAdd32(ctx, 0, 300, 9)
        assert ctx.words.count == b0 + 17
        assert ctx.words[b0] == SpirvWord(SPIRV_OP_ACCESS_CHAIN, 6)
        assert ctx.words[b0 + 1] == ptr_ty
        assert ctx.words[b0 + 3] == base_var
        assert ctx.words[b0 + 4] == ctx.u32_zero_value
        assert ctx.words[b0 + 5] == 300
        assert ctx.words[b0 + 10] == SpirvWord(SPIRV_OP_ATOMIC_I_ADD, 7)
        assert ctx.words[b0 + 11] == ctx.u32_id
        assert ctx.words[b0 + 12] == r
        assert ctx.words[b0 + 16] == 9
        # --- BufferAtomicCmpSwap32 ends in a 9-word OpAtomicCompareExchange. ---
        b1: usize = ctx.words.count
        cs: u32 = SpirvEmitBufferAtomicCmpSwap32(ctx, 0, 300, 7, 8)
        assert ctx.words[ctx.words.count - 9] == SpirvWord(SPIRV_OP_ATOMIC_COMPARE_EXCHANGE, 9)
        assert ctx.words[ctx.words.count - 2] == 7
        assert ctx.words[ctx.words.count - 1] == 8
        _ = cs
        _ = b1
        # Register an image + the texel-pointer type.
        tex: mutable SpirvTextureDefinition = zeroed
        tex.id <- SpirvEmitContext_AllocateId(ctx)
        tex_id: u32 = tex.id
        _ = SpirvEmitContext_PushImage(ctx, tex)
        ctx.image_u32 <- SpirvEmitContext_AllocateId(ctx)
        # --- ImageAtomicIAdd32: ConstU32(sample), OpImageTexelPointer, scope, atomic. ---
        b2: usize = ctx.words.count
        ir: u32 = SpirvEmitImageAtomicIAdd32(ctx, 0, 400, 5)
        assert ctx.words[b2 + 4] == SpirvWord(SPIRV_OP_IMAGE_TEXEL_POINTER, 6)
        assert ctx.words[b2 + 5] == ctx.image_u32
        assert ctx.words[b2 + 7] == tex_id
        assert ctx.words[b2 + 8] == 400
        assert ctx.words[b2 + 14] == SpirvWord(SPIRV_OP_ATOMIC_I_ADD, 7)
        assert ctx.words[b2 + 15] == ctx.u32_id
        assert ctx.words[b2 + 16] == ir

@test
def spirv_backend_emit_shared_atomic_matches_cpp() -> void:
    can Abort.Panic, Memory.Allocate:
        ctx: mutable SpirvEmitContext = SpirvEmitContext_Default()
        SpirvEmitContext_DefineArithmeticTypes(ctx)
        ctx.shared_u32 <- SpirvEmitContext_AllocateId(ctx)
        ctx.shared_memory_u32 <- SpirvEmitContext_AllocateId(ctx)
        ctx.shared_memory_is_layered <- false
        # --- IAdd32: ConstU32 shift, shift-right, access chain, scope const, atomic. ---
        b0: usize = ctx.words.count
        r: u32 = SpirvEmitSharedAtomicIAdd32(ctx, 700, 9)
        assert ctx.words.count == b0 + 25
        assert ctx.words[b0 + 3] == 2
        assert ctx.words[b0 + 9] == SpirvWord(SPIRV_OP_ACCESS_CHAIN, 5)
        # Scope is a fresh ConstU32(Device).
        assert ctx.words[b0 + 14] == SpirvWord(SPIRV_OP_CONSTANT, 4)
        assert ctx.words[b0 + 17] == SPIRV_SCOPE_DEVICE
        # The atomic op: 7 words, U32 result, pointer/scope/semantics/value.
        assert ctx.words[b0 + 18] == SpirvWord(SPIRV_OP_ATOMIC_I_ADD, 7)
        assert ctx.words[b0 + 19] == ctx.u32_id
        assert ctx.words[b0 + 20] == r
        assert ctx.words[b0 + 21] == ctx.words[b0 + 11]
        assert ctx.words[b0 + 22] == ctx.words[b0 + 16]
        assert ctx.words[b0 + 23] == ctx.u32_zero_value
        assert ctx.words[b0 + 24] == 9
        # --- Inc32: increment is a 6-word atomic with no value operand. ---
        b1: usize = ctx.words.count
        inc: u32 = SpirvEmitSharedAtomicInc32(ctx, 701)
        assert ctx.words[ctx.words.count - 6] == SpirvWord(SPIRV_OP_ATOMIC_I_INCREMENT, 6)
        assert ctx.words[ctx.words.count - 5] == ctx.u32_id
        assert inc == ctx.words[ctx.words.count - 4]
        _ = b1
        # --- Or64: shift is 3 and the result type is U64. ---
        ctx.shared_u64 <- SpirvEmitContext_AllocateId(ctx)
        ctx.shared_memory_u64 <- SpirvEmitContext_AllocateId(ctx)
        b2: usize = ctx.words.count
        or64: u32 = SpirvEmitSharedAtomicOr64(ctx, 702, 3)
        assert ctx.words[b2 + 3] == 3
        assert ctx.words[ctx.words.count - 7] == SpirvWord(SPIRV_OP_ATOMIC_OR, 7)
        assert ctx.words[ctx.words.count - 6] == ctx.u64_id
        assert or64 == ctx.words[ctx.words.count - 5]

@test
def spirv_backend_emit_shared_memory_matches_cpp() -> void:
    can Abort.Panic, Memory.Allocate:
        ctx: mutable SpirvEmitContext = SpirvEmitContext_Default()
        SpirvEmitContext_DefineArithmeticTypes(ctx)
        # Stand in for DefineSharedMemory: pointer types + variable ids.
        ctx.shared_u32 <- SpirvEmitContext_AllocateId(ctx)
        ctx.shared_memory_u32 <- SpirvEmitContext_AllocateId(ctx)
        # --- Single-type block: ConstU32 shift, shift-right, access chain, load. ---
        ctx.shared_memory_is_layered <- false
        b0: usize = ctx.words.count
        v: u32 = SpirvEmitLoadSharedU32(ctx, 500)
        assert ctx.words.count == b0 + 18
        # ConstU32(2) for the byte->element shift.
        assert ctx.words[b0] == SpirvWord(SPIRV_OP_CONSTANT, 4)
        assert ctx.words[b0 + 3] == 2
        # ShiftRightLogical(offset, shift).
        assert ctx.words[b0 + 4] == SpirvWord(SPIRV_OP_SHIFT_RIGHT_LOGICAL, 5)
        assert ctx.words[b0 + 7] == 500
        # OpAccessChain (single index) into the shared variable.
        assert ctx.words[b0 + 9] == SpirvWord(SPIRV_OP_ACCESS_CHAIN, 5)
        assert ctx.words[b0 + 10] == ctx.shared_u32
        assert ctx.words[b0 + 12] == ctx.shared_memory_u32
        # OpLoad of the U32 element.
        assert ctx.words[b0 + 14] == SpirvWord(SPIRV_OP_LOAD, 4)
        assert ctx.words[b0 + 15] == ctx.u32_id
        assert ctx.words[b0 + 16] == v
        # --- Multi-type (layered) block: access chain gains the u32_zero member. ---
        ctx.shared_memory_is_layered <- true
        b1: usize = ctx.words.count
        v2: u32 = SpirvEmitLoadSharedU32(ctx, 501)
        assert ctx.words[b1 + 9] == SpirvWord(SPIRV_OP_ACCESS_CHAIN, 6)
        # Layout: word, result_type, result_id, base, i0=u32_zero, i1=index.
        assert ctx.words[b1 + 12] == ctx.shared_memory_u32
        assert ctx.words[b1 + 13] == ctx.u32_zero_value
        _ = v2
        # --- Write path ends in an OpStore (no result id). ---
        ctx.shared_memory_is_layered <- false
        b2: usize = ctx.words.count
        SpirvEmitWriteSharedU32(ctx, 502, 99)
        assert ctx.words[ctx.words.count - 3] == SpirvWord(SPIRV_OP_STORE, 3)
        assert ctx.words[ctx.words.count - 1] == 99

@test
def spirv_backend_emit_convert_matches_cpp() -> void:
    can Abort.Panic, Memory.Allocate:
        ctx: mutable SpirvEmitContext = SpirvEmitContext_Default()
        ctx.uses_fp16 <- true
        ctx.uses_fp64 <- true
        SpirvEmitContext_DefineArithmeticTypes(ctx)
        # --- Simple FToS to U32: single 4-word unary op. ---
        b0: usize = ctx.words.count
        s32: u32 = SpirvEmitConvertS32F32(ctx, 100)
        assert ctx.words.count == b0 + 4
        assert ctx.words[b0] == SpirvWord(SPIRV_OP_CONVERT_F_TO_S, 4)
        assert ctx.words[b0 + 1] == ctx.u32_id
        assert ctx.words[b0 + 2] == s32
        assert ctx.words[b0 + 3] == 100
        # --- FToU to U64. ---
        b1: usize = ctx.words.count
        u64v: u32 = SpirvEmitConvertU64F32(ctx, 101)
        assert ctx.words[b1] == SpirvWord(SPIRV_OP_CONVERT_F_TO_U, 4)
        assert ctx.words[b1 + 1] == ctx.u64_id
        _ = u64v
        # --- ConvertU16F32: inner FToU to U16, then UConvert to U32. ---
        b2: usize = ctx.words.count
        u16f: u32 = SpirvEmitConvertU16F32(ctx, 102)
        assert ctx.words.count == b2 + 8
        assert ctx.words[b2] == SpirvWord(SPIRV_OP_CONVERT_F_TO_U, 4)
        assert ctx.words[b2 + 1] == ctx.u16_id
        assert ctx.words[b2 + 4] == SpirvWord(SPIRV_OP_U_CONVERT, 4)
        assert ctx.words[b2 + 5] == ctx.u32_id
        assert ctx.words[b2 + 6] == u16f
        # outer operand is the inner FToU result id.
        assert ctx.words[b2 + 7] == ctx.words[b2 + 2]
        # --- ConvertF32S8: ExtractS8 (SConvert to S8) then SToF to F32. ---
        b3: usize = ctx.words.count
        f32s8: u32 = SpirvEmitConvertF32S8(ctx, 103)
        assert ctx.words.count == b3 + 8
        assert ctx.words[b3] == SpirvWord(SPIRV_OP_S_CONVERT, 4)
        assert ctx.words[b3 + 1] == ctx.s8_id
        assert ctx.words[b3 + 4] == SpirvWord(SPIRV_OP_CONVERT_S_TO_F, 4)
        assert ctx.words[b3 + 5] == ctx.f32_id
        assert ctx.words[b3 + 6] == f32s8
        assert ctx.words[b3 + 7] == ctx.words[b3 + 2]
        # --- FConvert F32<-F16 and F64<-F32. ---
        b4: usize = ctx.words.count
        f16f: u32 = SpirvEmitConvertF16F32(ctx, 104)
        assert ctx.words[b4] == SpirvWord(SPIRV_OP_F_CONVERT, 4)
        assert ctx.words[b4 + 1] == ctx.f16_id
        _ = f16f
        b5: usize = ctx.words.count
        f64f: u32 = SpirvEmitConvertF64F32(ctx, 105)
        assert ctx.words[b5 + 1] == ctx.f64_id
        _ = f64f

@test
def spirv_backend_emit_integer_completion_matches_cpp() -> void:
    can Abort.Panic, Memory.Allocate:
        ctx: mutable SpirvEmitContext = SpirvEmitContext_Default()
        SpirvEmitContext_DefineArithmeticTypes(ctx)
        SpirvEmitContext_DefineExtInst(ctx)
        # --- 64-bit arithmetic uses the u64 result type. ---
        b0: usize = ctx.words.count
        add64: u32 = SpirvEmitIAdd64(ctx, 100, 101)
        assert ctx.words[b0] == SpirvWord(SPIRV_OP_I_ADD, 5)
        assert ctx.words[b0 + 1] == ctx.u64_id
        assert ctx.words[b0 + 2] == add64
        # --- UMulHi: OpUMulExtended (full_result_u32x2) then extract hi word. ---
        b1: usize = ctx.words.count
        umulhi: u32 = SpirvEmitUMulHi(ctx, 5, 6)
        assert ctx.words[b1] == SpirvWord(SPIRV_OP_U_MUL_EXTENDED, 5)
        assert ctx.words[b1 + 1] == ctx.full_result_u32x2
        # extract: result_type u32, composite = mul_ext id (b1+2), index 1.
        assert ctx.words[b1 + 5] == SpirvWord(SPIRV_OP_COMPOSITE_EXTRACT, 5)
        assert ctx.words[b1 + 6] == ctx.u32_id
        assert ctx.words[b1 + 7] == umulhi
        assert ctx.words[b1 + 8] == ctx.words[b1 + 2]
        assert ctx.words[b1 + 9] == 1
        # --- SMulHi: two bitcasts to S32, SMulExtended (i32x2), extract, bitcast. ---
        b2: usize = ctx.words.count
        smulhi: u32 = SpirvEmitSMulHi(ctx, 7, 8)
        assert ctx.words[b2] == SpirvWord(SPIRV_OP_BITCAST, 4)
        assert ctx.words[b2 + 1] == ctx.s32_id
        assert ctx.words[b2 + 8] == SpirvWord(SPIRV_OP_S_MUL_EXTENDED, 5)
        assert ctx.words[b2 + 9] == ctx.full_result_i32x2
        _ = smulhi
        # --- BitCount64: bitcast u32x2, extract lo/hi, two BitCount32, IAdd32. ---
        b3: usize = ctx.words.count
        bc64: u32 = SpirvEmitBitCount64(ctx, 9)
        assert ctx.words[b3] == SpirvWord(SPIRV_OP_BITCAST, 4)
        assert ctx.words[b3 + 1] == ctx.u32x2_id
        # last instruction is the IAdd32 of the two popcounts.
        assert ctx.words[ctx.words.count - 5] == SpirvWord(SPIRV_OP_I_ADD, 5)
        assert bc64 == ctx.words[ctx.words.count - 3]
        # --- FindUMsb64 ends in an OpSelect choosing shifted-hi vs lo msb. ---
        b4: usize = ctx.words.count
        fmsb: u32 = SpirvEmitFindUMsb64(ctx, 10)
        assert ctx.words[ctx.words.count - 6] == SpirvWord(SPIRV_OP_SELECT, 6)
        assert ctx.words[ctx.words.count - 5] == ctx.u32_id
        assert fmsb == ctx.words[ctx.words.count - 4]
        _ = b4

@test
def spirv_backend_emit_floating_point_matches_cpp() -> void:
    can Abort.Panic, Memory.Allocate:
        ctx: mutable SpirvEmitContext = SpirvEmitContext_Default()
        SpirvEmitContext_DefineArithmeticTypes(ctx)
        SpirvEmitContext_DefineExtInst(ctx)
        # Arithmetic types occupy ids 1..42; the GLSL.std.450 import id is 43.
        assert ctx.glsl_std_450_id == 43
        # --- Core arithmetic: 5-word binary op with the F32 result type. ---
        b0: usize = ctx.words.count
        add: u32 = SpirvEmitFPAdd32(ctx, 10, 11)
        assert ctx.words.count == b0 + 5
        assert ctx.words[b0] == SpirvWord(SPIRV_OP_F_ADD, 5)
        assert ctx.words[b0 + 1] == ctx.f32_id
        assert ctx.words[b0 + 2] == add
        assert ctx.words[b0 + 3] == 10
        assert ctx.words[b0 + 4] == 11
        b1: usize = ctx.words.count
        _mul: u32 = SpirvEmitFPMul32(ctx, 12, 13)
        assert ctx.words[b1] == SpirvWord(SPIRV_OP_F_MUL, 5)
        # FNegate is a 4-word unary op.
        b2: usize = ctx.words.count
        neg: u32 = SpirvEmitFPNeg32(ctx, 14)
        assert ctx.words.count == b2 + 4
        assert ctx.words[b2] == SpirvWord(SPIRV_OP_F_NEGATE, 4)
        assert ctx.words[b2 + 2] == neg
        # --- GLSL.std.450 unary: OpExtInst is 6 words. ---
        b3: usize = ctx.words.count
        sq: u32 = SpirvEmitFPSqrt32(ctx, 20)
        assert ctx.words.count == b3 + 6
        assert ctx.words[b3] == SpirvWord(SPIRV_OP_EXT_INST, 6)
        assert ctx.words[b3 + 1] == ctx.f32_id
        assert ctx.words[b3 + 2] == sq
        assert ctx.words[b3 + 3] == ctx.glsl_std_450_id
        assert ctx.words[b3 + 4] == GLSL_STD_450_SQRT
        assert ctx.words[b3 + 5] == 20
        # --- GLSL.std.450 binary: OpExtInst is 7 words (FMax). ---
        b4: usize = ctx.words.count
        mx: u32 = SpirvEmitFPMax32(ctx, 21, 22)
        assert ctx.words.count == b4 + 7
        assert ctx.words[b4] == SpirvWord(SPIRV_OP_EXT_INST, 7)
        assert ctx.words[b4 + 4] == GLSL_STD_450_FMAX
        assert ctx.words[b4 + 5] == 21
        assert ctx.words[b4 + 6] == 22
        _ = mx
        # --- GLSL.std.450 ternary: OpExtInst is 8 words (Fma). ---
        b5: usize = ctx.words.count
        fma: u32 = SpirvEmitFPFma32(ctx, 23, 24, 25)
        assert ctx.words.count == b5 + 8
        assert ctx.words[b5] == SpirvWord(SPIRV_OP_EXT_INST, 8)
        assert ctx.words[b5 + 4] == GLSL_STD_450_FMA
        assert ctx.words[b5 + 7] == 25
        _ = fma
        # --- MinTri fallback: two nested GLSL FMin ext-insts (7 words each). ---
        b6: usize = ctx.words.count
        tri: u32 = SpirvEmitFPMinTri32(ctx, 30, 31, 32)
        assert ctx.words.count == b6 + 14
        assert ctx.words[b6] == SpirvWord(SPIRV_OP_EXT_INST, 7)
        assert ctx.words[b6 + 4] == GLSL_STD_450_FMIN
        # First (inner) min combines b=31,c=32.
        assert ctx.words[b6 + 5] == 31
        assert ctx.words[b6 + 6] == 32
        # Second (outer) min combines a=30 with the inner result.
        assert ctx.words[b6 + 7] == SpirvWord(SPIRV_OP_EXT_INST, 7)
        assert ctx.words[b6 + 11] == GLSL_STD_450_FMIN
        assert ctx.words[b6 + 12] == 30
        assert ctx.words[b6 + 13] == ctx.words[b6 + 2]
        assert tri == ctx.words[b6 + 9]

@test
def spirv_backend_emit_floating_point_completion_matches_cpp() -> void:
    can Abort.Panic, Memory.Allocate:
        ctx: mutable SpirvEmitContext = SpirvEmitContext_Default()
        ctx.uses_fp64 <- true
        SpirvEmitContext_DefineArithmeticTypes(ctx)
        SpirvEmitContext_DefineExtInst(ctx)
        # --- F64 arithmetic uses the f64 result type. ---
        b0: usize = ctx.words.count
        add64: u32 = SpirvEmitFPAdd64(ctx, 100, 101)
        assert ctx.words[b0] == SpirvWord(SPIRV_OP_F_ADD, 5)
        assert ctx.words[b0 + 1] == ctx.f64_id
        assert ctx.words[b0 + 2] == add64
        # --- Sin: FMul(pi_x2, value) then GLSL Sin of the product. ---
        b1: usize = ctx.words.count
        sin: u32 = SpirvEmitFPSin(ctx, 200)
        assert ctx.words.count == b1 + 11
        assert ctx.words[b1] == SpirvWord(SPIRV_OP_F_MUL, 5)
        assert ctx.words[b1 + 3] == ctx.pi_x2
        assert ctx.words[b1 + 4] == 200
        assert ctx.words[b1 + 5] == SpirvWord(SPIRV_OP_EXT_INST, 6)
        assert ctx.words[b1 + 6] == ctx.f32_id
        assert ctx.words[b1 + 7] == sin
        assert ctx.words[b1 + 9] == GLSL_STD_450_SIN
        # The Sin operand is the FMul result id (id at b1+2).
        assert ctx.words[b1 + 10] == ctx.words[b1 + 2]
        # --- FClamp32: 8-word GLSL ternary ext-inst. ---
        b2: usize = ctx.words.count
        clamp: u32 = SpirvEmitFPClamp32(ctx, 1, 2, 3)
        assert ctx.words[b2] == SpirvWord(SPIRV_OP_EXT_INST, 8)
        assert ctx.words[b2 + 4] == GLSL_STD_450_FCLAMP
        _ = clamp
        # --- FrexpExp32: FrexpStruct -> extract S32 component 1 -> bitcast U32. ---
        b3: usize = ctx.words.count
        fexp: u32 = SpirvEmitFPFrexpExp32(ctx, 7)
        assert ctx.words.count == b3 + 15
        assert ctx.words[b3] == SpirvWord(SPIRV_OP_EXT_INST, 6)
        assert ctx.words[b3 + 1] == ctx.frexp_result_f32
        assert ctx.words[b3 + 4] == GLSL_STD_450_FREXP_STRUCT
        assert ctx.words[b3 + 6] == SpirvWord(SPIRV_OP_COMPOSITE_EXTRACT, 5)
        assert ctx.words[b3 + 7] == ctx.s32_id
        assert ctx.words[b3 + 10] == 1
        assert ctx.words[b3 + 11] == SpirvWord(SPIRV_OP_BITCAST, 4)
        assert ctx.words[b3 + 12] == ctx.u32_id
        assert ctx.words[b3 + 13] == fexp
        # --- Comparisons produce the U1 type; IsNan is a unary U1 op. ---
        b4: usize = ctx.words.count
        lt: u32 = SpirvEmitFOrdLessThan(ctx, 10, 11)
        assert ctx.words[b4] == SpirvWord(SPIRV_OP_F_ORD_LESS_THAN, 5)
        assert ctx.words[b4 + 1] == ctx.u1_id
        assert ctx.words[b4 + 2] == lt
        b5: usize = ctx.words.count
        nan: u32 = SpirvEmitFPIsNan(ctx, 12)
        assert ctx.words.count == b5 + 4
        assert ctx.words[b5] == SpirvWord(SPIRV_OP_IS_NAN, 4)
        assert ctx.words[b5 + 1] == ctx.u1_id
        assert ctx.words[b5 + 2] == nan

@test
def spirv_backend_emit_special_matches_cpp() -> void:
    can Abort.Panic, Memory.Allocate:
        ctx: mutable SpirvEmitContext = SpirvEmitContext_Default()
        SpirvEmitContext_DefineArithmeticTypes(ctx)
        # Zero-operand void ops are a single word.
        b0: usize = ctx.words.count
        SpirvEmitDiscard(ctx)
        assert ctx.words.count == b0 + 1
        assert ctx.words[b0] == SpirvWord(SPIRV_OP_DEMOTE_TO_HELPER_INVOCATION, 1)
        b1: usize = ctx.words.count
        SpirvEmitEmitVertex(ctx)
        assert ctx.words.count == b1 + 1
        assert ctx.words[b1] == SpirvWord(SPIRV_OP_EMIT_VERTEX, 1)
        b2: usize = ctx.words.count
        SpirvEmitEmitPrimitive(ctx)
        assert ctx.words[b2] == SpirvWord(SPIRV_OP_END_PRIMITIVE, 1)
        # EmitDiscardCond: SelectionMerge(3) + BranchConditional(4) + Label(2)
        # + Discard(1) + Branch(2) + Label(2) = 14 words.
        next_id: u32 = ctx.next_id
        b3: usize = ctx.words.count
        SpirvEmitDiscardCond(ctx, 77)
        assert ctx.words.count == b3 + 14
        # kill_label = next_id, merge_label = next_id + 1.
        kill_label: u32 = next_id
        merge_label: u32 = next_id + 1
        assert ctx.words[b3] == SpirvWord(SPIRV_OP_SELECTION_MERGE, 3)
        assert ctx.words[b3 + 1] == merge_label
        assert ctx.words[b3 + 2] == SPIRV_SELECTION_CONTROL_NONE
        assert ctx.words[b3 + 3] == SpirvWord(SPIRV_OP_BRANCH_CONDITIONAL, 4)
        assert ctx.words[b3 + 4] == 77
        assert ctx.words[b3 + 5] == kill_label
        assert ctx.words[b3 + 6] == merge_label
        assert ctx.words[b3 + 7] == SpirvWord(SPIRV_OP_LABEL, 2)
        assert ctx.words[b3 + 8] == kill_label
        assert ctx.words[b3 + 9] == SpirvWord(SPIRV_OP_DEMOTE_TO_HELPER_INVOCATION, 1)
        assert ctx.words[b3 + 10] == SpirvWord(SPIRV_OP_BRANCH, 2)
        assert ctx.words[b3 + 11] == merge_label
        assert ctx.words[b3 + 12] == SpirvWord(SPIRV_OP_LABEL, 2)
        assert ctx.words[b3 + 13] == merge_label
        assert ctx.last_label == merge_label

@test
def spirv_backend_emit_warp_matches_cpp() -> void:
    can Abort.Panic, Memory.Allocate:
        ctx: mutable SpirvEmitContext = SpirvEmitContext_Default()
        SpirvEmitContext_DefineArithmeticTypes(ctx)
        SpirvEmitContext_DefineWarpInputs(ctx)
        # u32x4 is part of the arithmetic types (id 21); the subgroup invocation
        # input id is the first allocation after the type section (id 43).
        assert ctx.u32x4_id == 21
        assert ctx.subgroup_local_invocation_id == 43
        # EmitLaneId: OpLoad U32 from the subgroup pointer (4-word unary op).
        b0: usize = ctx.words.count
        lane: u32 = SpirvEmitLaneId(ctx)
        assert ctx.words.count == b0 + 4
        assert ctx.words[b0] == SpirvWord(SPIRV_OP_LOAD, 4)
        assert ctx.words[b0 + 1] == ctx.u32_id
        assert ctx.words[b0 + 2] == lane
        assert ctx.words[b0 + 3] == ctx.subgroup_local_invocation_id
        # EmitReadFirstLane: ConstU32(Subgroup) then a 5-word group op.
        b1: usize = ctx.words.count
        rfl: u32 = SpirvEmitReadFirstLane(ctx, 42)
        assert ctx.words[b1] == SpirvWord(SPIRV_OP_CONSTANT, 4)
        assert ctx.words[b1 + 3] == SPIRV_SCOPE_SUBGROUP
        gop: usize = b1 + 4
        assert ctx.words[gop] == SpirvWord(SPIRV_OP_GROUP_NON_UNIFORM_BROADCAST_FIRST, 5)
        assert ctx.words[gop + 1] == ctx.u32_id
        assert ctx.words[gop + 2] == rfl
        assert ctx.words[gop + 3] == ctx.words[b1 + 2]
        assert ctx.words[gop + 4] == 42
        # EmitQuadShuffle: scope const then a 6-word ternary group op.
        b2: usize = ctx.words.count
        qs: u32 = SpirvEmitQuadShuffle(ctx, 7, 8)
        q: usize = b2 + 4
        assert ctx.words[q] == SpirvWord(SPIRV_OP_GROUP_NON_UNIFORM_QUAD_BROADCAST, 6)
        assert ctx.words[q + 1] == ctx.u32_id
        assert ctx.words[q + 3] == ctx.words[b2 + 2]
        assert ctx.words[q + 4] == 7
        assert ctx.words[q + 5] == 8
        # EmitBallot: result type is the uvec4 type.
        b3: usize = ctx.words.count
        bal: u32 = SpirvEmitBallot(ctx, 9)
        bb: usize = b3 + 4
        assert ctx.words[bb] == SpirvWord(SPIRV_OP_GROUP_NON_UNIFORM_BALLOT, 5)
        assert ctx.words[bb + 1] == ctx.u32x4_id
        # EmitGroupAny: result type is U1.
        b4: usize = ctx.words.count
        any: u32 = SpirvEmitGroupAny(ctx, 10)
        ab: usize = b4 + 4
        assert ctx.words[ab] == SpirvWord(SPIRV_OP_GROUP_NON_UNIFORM_ANY, 5)
        assert ctx.words[ab + 1] == ctx.u1_id
        _ = qs
        _ = bal
        _ = any

@test
def spirv_backend_emit_barriers_match_cpp() -> void:
    can Abort.Panic, Memory.Allocate:
        ctx: mutable SpirvEmitContext = SpirvEmitContext_Default()
        SpirvEmitContext_DefineArithmeticTypes(ctx)
        # --- EmitBarrier (non-tessellation): two ConstU32 + OpControlBarrier ---
        b0: usize = ctx.words.count
        SpirvEmitBarrier(ctx, false)
        # execution=Workgroup const, memory=Workgroup const, semantics const, then barrier.
        assert ctx.words.count == b0 + 4 + 4 + 4 + 4
        assert ctx.words[b0] == SpirvWord(SPIRV_OP_CONSTANT, 4)
        assert ctx.words[b0 + 3] == SPIRV_SCOPE_WORKGROUP
        assert ctx.words[b0 + 7] == SPIRV_SCOPE_WORKGROUP
        assert ctx.words[b0 + 11] == (SPIRV_MEM_SEM_ACQUIRE_RELEASE | SPIRV_MEM_SEM_WORKGROUP_MEMORY)
        cb: usize = b0 + 12
        assert ctx.words[cb] == SpirvWord(SPIRV_OP_CONTROL_BARRIER, 4)
        # The three operands are the const ids allocated above.
        assert ctx.words[cb + 1] == ctx.words[b0 + 2]
        assert ctx.words[cb + 2] == ctx.words[b0 + 6]
        assert ctx.words[cb + 3] == ctx.words[b0 + 10]
        # --- EmitBarrier (tessellation control): Invocation scope, no semantics ---
        b1: usize = ctx.words.count
        SpirvEmitBarrier(ctx, true)
        assert ctx.words[b1 + 7] == SPIRV_SCOPE_INVOCATION
        assert ctx.words[b1 + 11] == SPIRV_MEM_SEM_NONE
        # --- EmitWorkgroupMemoryBarrier: two ConstU32 + OpMemoryBarrier ---
        b2: usize = ctx.words.count
        SpirvEmitWorkgroupMemoryBarrier(ctx)
        assert ctx.words.count == b2 + 4 + 4 + 3
        assert ctx.words[b2 + 3] == SPIRV_SCOPE_WORKGROUP
        assert ctx.words[b2 + 7] == SpirvMemoryBarrierSemantics()
        mb: usize = b2 + 8
        assert ctx.words[mb] == SpirvWord(SPIRV_OP_MEMORY_BARRIER, 3)
        assert ctx.words[mb + 1] == ctx.words[b2 + 2]
        assert ctx.words[mb + 2] == ctx.words[b2 + 6]
        # --- EmitDeviceMemoryBarrier: scope = Device ---
        b3: usize = ctx.words.count
        SpirvEmitDeviceMemoryBarrier(ctx)
        assert ctx.words[b3 + 3] == SPIRV_SCOPE_DEVICE
        assert ctx.words[b3 + 7] == SpirvMemoryBarrierSemantics()

@test
def spirv_backend_emit_undefined_matches_cpp() -> void:
    can Abort.Panic, Memory.Allocate:
        ctx: mutable SpirvEmitContext = SpirvEmitContext_Default()
        SpirvEmitContext_DefineArithmeticTypes(ctx)
        # Arithmetic types occupy ids 1..42; next free id is 43.
        b0: usize = ctx.words.count
        u1u: u32 = SpirvEmitUndefU1(ctx)
        # OpUndef emits 3 words and allocates the result id.
        assert u1u == 43
        assert ctx.words.count == b0 + 3
        assert ctx.words[b0] == SpirvWord(SPIRV_OP_UNDEF, 3)
        assert ctx.words[b0 + 1] == ctx.u1_id
        assert ctx.words[b0 + 2] == u1u
        # The U32 variant picks the U32 result type.
        b1: usize = ctx.words.count
        u32u: u32 = SpirvEmitUndefU32(ctx)
        assert u32u == 44
        assert ctx.words[b1] == SpirvWord(SPIRV_OP_UNDEF, 3)
        assert ctx.words[b1 + 1] == ctx.u32_id
        assert ctx.words[b1 + 2] == u32u

@test
def spirv_backend_emit_logical_matches_cpp() -> void:
    can Abort.Panic, Memory.Allocate:
        ctx: mutable SpirvEmitContext = SpirvEmitContext_Default()
        SpirvEmitContext_DefineArithmeticTypes(ctx)
        # Binary logical ops emit 5 words with the U1 result type.
        b0: usize = ctx.words.count
        _or: u32 = SpirvEmitLogicalOr(ctx, 10, 11)
        assert ctx.words.count == b0 + 5
        assert ctx.words[b0] == SpirvWord(SPIRV_OP_LOGICAL_OR, 5)
        assert ctx.words[b0 + 1] == ctx.u1_id
        assert ctx.words[b0 + 3] == 10
        assert ctx.words[b0 + 4] == 11
        # Xor lowers to OpLogicalNotEqual (matches the C++).
        b1: usize = ctx.words.count
        _xor: u32 = SpirvEmitLogicalXor(ctx, 20, 21)
        assert ctx.words[b1] == SpirvWord(SPIRV_OP_LOGICAL_NOT_EQUAL, 5)
        # Not is a 4-word unary op.
        b2: usize = ctx.words.count
        notv: u32 = SpirvEmitLogicalNot(ctx, 30)
        assert ctx.words.count == b2 + 4
        assert ctx.words[b2] == SpirvWord(SPIRV_OP_LOGICAL_NOT, 4)
        assert ctx.words[b2 + 1] == ctx.u1_id
        assert ctx.words[b2 + 2] == notv
        assert ctx.words[b2 + 3] == 30
        _ = _or
        _ = _xor
