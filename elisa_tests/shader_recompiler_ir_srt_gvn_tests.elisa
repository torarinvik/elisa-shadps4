include "../shader_recompiler/ir/srt_gvn_table.elisa"
include "../../compiler/runtime/elisacore_std/elisacore_runtime.elisa"

def gvn_add_readconst(program: mutable ShaderIrProgram&, b: u32, x: u32, y: u32) -> u32:
    args: mutable ShaderIrValue[6] = zeroed
    args[0] <- ShaderIrValue_FromU32(x)
    args[1] <- ShaderIrValue_FromU32(y)
    return ShaderIrProgram_AppendInst(program, b, IR_OPCODE_READCONST, args, 2, 0)

@test
def gvn_dedups_structurally_identical() -> void:
    can Abort.Panic, Memory.Allocate:
        info: ShaderIrProgramInfo = zeroed
        program: mutable heap ShaderIrProgram& = ShaderIrProgram_New(info)
        b: u32 = ShaderIrProgram_AddBlock(program)
        i0: u32 = gvn_add_readconst(program, b, 1, 2)
        i1: u32 = gvn_add_readconst(program, b, 1, 2)   # identical to i0
        i2: u32 = gvn_add_readconst(program, b, 1, 3)   # different second arg

        table: mutable SrtGvnTable = SrtGvnTable_New()
        vn0: u32 = SrtGvnTable_GetValueNumber(table, program, ShaderIrValue_FromInst(b, i0))
        vn1: u32 = SrtGvnTable_GetValueNumber(table, program, ShaderIrValue_FromInst(b, i1))
        vn2: u32 = SrtGvnTable_GetValueNumber(table, program, ShaderIrValue_FromInst(b, i2))

        assert vn0 == vn1     # same opcode + same arg value numbers -> same VN
        assert vn0 != vn2     # different argument -> different VN

@test
def gvn_caches_repeated_lookup() -> void:
    can Abort.Panic, Memory.Allocate:
        info: ShaderIrProgramInfo = zeroed
        program: mutable heap ShaderIrProgram& = ShaderIrProgram_New(info)
        b: u32 = ShaderIrProgram_AddBlock(program)
        i0: u32 = gvn_add_readconst(program, b, 7, 8)
        table: mutable SrtGvnTable = SrtGvnTable_New()
        first: u32 = SrtGvnTable_GetValueNumber(table, program, ShaderIrValue_FromInst(b, i0))
        again: u32 = SrtGvnTable_GetValueNumber(table, program, ShaderIrValue_FromInst(b, i0))
        assert first == again     # cached, same value

@test
def gvn_side_effecting_insts_are_distinct() -> void:
    can Abort.Panic, Memory.Allocate:
        info: ShaderIrProgramInfo = zeroed
        program: mutable heap ShaderIrProgram& = ShaderIrProgram_New(info)
        b: u32 = ShaderIrProgram_AddBlock(program)
        sa: mutable ShaderIrValue[6] = zeroed
        sa[0] <- ShaderIrValue_FromU32(1)
        s0: u32 = ShaderIrProgram_AppendInst(program, b, IR_OPCODE_STOREBUFFERU32, sa, 1, 0)
        s1: u32 = ShaderIrProgram_AppendInst(program, b, IR_OPCODE_STOREBUFFERU32, sa, 1, 0)
        table: mutable SrtGvnTable = SrtGvnTable_New()
        vs0: u32 = SrtGvnTable_GetValueNumber(table, program, ShaderIrValue_FromInst(b, s0))
        vs1: u32 = SrtGvnTable_GetValueNumber(table, program, ShaderIrValue_FromInst(b, s1))
        # Side-effecting stores never share a value number.
        assert vs0 != vs1
