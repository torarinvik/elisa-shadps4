def diff_eq_int(label: static u8&, lhs: int, rhs: int) -> void:
    _ = label
    assert lhs == rhs

def diff_eq_u64(label: static u8&, lhs: u64, rhs: u64) -> void:
    _ = label
    assert lhs == rhs

@test
def parity_thread_lifecycle_join_and_detach() -> void:
    can Abort.Panic:
        oe: mutable int = 0
        ee: mutable int = 0
        ot: void&? = oracle_thread_create(2, oe)
        et: void&? = elisa_adapter_thread_create(2, ee)
        diff_eq_int("thread_create_error", oe, ee)
        orv: mutable void&? = null
        erv: mutable void&? = null
        orc: int = oracle_thread_join(ot, orv)
        erc: int = elisa_adapter_thread_join(et, erv)
        diff_eq_int("thread_join_ret", orc, erc)

        ot2: void&? = oracle_thread_create(1, oe)
        et2: void&? = elisa_adapter_thread_create(1, ee)
        diff_eq_int("thread_create2_error", oe, ee)
        orc2: int = oracle_thread_detach(ot2)
        erc2: int = elisa_adapter_thread_detach(et2)
        diff_eq_int("thread_detach_ret", orc2, erc2)

@test
def parity_timedjoin_and_cancel_ordering() -> void:
    can Abort.Panic:
        oe: mutable int = 0
        ee: mutable int = 0
        ot: void&? = oracle_thread_create(1, oe)
        et: void&? = elisa_adapter_thread_create(1, ee)
        orv: mutable void&? = null
        erv: mutable void&? = null
        diff_eq_int("timedjoin_like_cpp", oracle_thread_timedjoin_like_cpp(ot, orv), elisa_adapter_thread_timedjoin_like_cpp(et, erv))

        # invalid handle ordering
        diff_eq_int("join_null", oracle_thread_join(null, orv), elisa_adapter_thread_join(null, erv))
        diff_eq_int("detach_null", oracle_thread_detach(null), elisa_adapter_thread_detach(null))

@test
def parity_name_and_affinity_self() -> void:
    can Abort.Panic:
        b1: mutable u8[64] = zeroed
        b2: mutable u8[64] = zeroed
        diff_eq_int("setname_null", oracle_thread_setname_self(null), elisa_adapter_thread_setname_self(null))
        diff_eq_int("getname_self", oracle_thread_getname_self(b1[0], 32u64), elisa_adapter_thread_getname_self(b2[0], 32u64))
        om: mutable u64 = 0
        em: mutable u64 = 0
        diff_eq_int("getaffinity_self", oracle_thread_getaffinity_self(om), elisa_adapter_thread_getaffinity_self(em))
        diff_eq_u64("getaffinity_mask", om, em)
        diff_eq_int("setaffinity_self", oracle_thread_setaffinity_self(0x1u64), elisa_adapter_thread_setaffinity_self(0x1u64))

@test
def parity_mutex_and_cond_paths() -> void:
    can Abort.Panic:
        oe: mutable int = 0
        ee: mutable int = 0
        om: void&? = oracle_mutex_create(3, oe)
        em: void&? = elisa_adapter_mutex_create(3, ee)
        diff_eq_int("mutex_create_error", oe, ee)
        diff_eq_int("mutex_isowned_initial", oracle_mutex_isowned(om), elisa_adapter_mutex_isowned(em))
        diff_eq_int("mutex_lock", oracle_mutex_lock(om), elisa_adapter_mutex_lock(em))
        diff_eq_int("mutex_trylock_busy", oracle_mutex_trylock(om), elisa_adapter_mutex_trylock(em))
        diff_eq_int("mutex_unlock", oracle_mutex_unlock(om), elisa_adapter_mutex_unlock(em))

        oc: void&? = oracle_cond_create(oe)
        ec: void&? = elisa_adapter_cond_create(ee)
        diff_eq_int("cond_create_error", oe, ee)
        diff_eq_int("cond_timedwait_invalid", oracle_cond_timedwait(oc, om, -1, 0), elisa_adapter_cond_timedwait(ec, em, -1, 0))
        diff_eq_int("cond_signal", oracle_cond_signal(oc), elisa_adapter_cond_signal(ec))

        diff_eq_int("cond_destroy", oracle_cond_destroy(oc), elisa_adapter_cond_destroy(ec))
        diff_eq_int("mutex_destroy", oracle_mutex_destroy(om), elisa_adapter_mutex_destroy(em))

@test
def parity_rwlock_sem_event_paths() -> void:
    can Abort.Panic:
        oe: mutable int = 0
        ee: mutable int = 0

        orw: void&? = oracle_rwlock_create(oe)
        erw: void&? = elisa_adapter_rwlock_create(ee)
        diff_eq_int("rwlock_create_error", oe, ee)
        diff_eq_int("rwlock_rdlock", oracle_rwlock_rdlock(orw), elisa_adapter_rwlock_rdlock(erw))
        diff_eq_int("rwlock_trywrlock_busy", oracle_rwlock_trywrlock(orw), elisa_adapter_rwlock_trywrlock(erw))
        diff_eq_int("rwlock_unlock", oracle_rwlock_unlock(orw), elisa_adapter_rwlock_unlock(erw))
        diff_eq_int("rwlock_destroy", oracle_rwlock_destroy(orw), elisa_adapter_rwlock_destroy(erw))

        os: void&? = oracle_sem_create(0, 4, oe)
        es: void&? = elisa_adapter_sem_create(0, 4, ee)
        diff_eq_int("sem_create_error", oe, ee)
        diff_eq_int("sem_trywait_empty", oracle_sem_trywait(os, 1), elisa_adapter_sem_trywait(es, 1))
        diff_eq_int("sem_post", oracle_sem_post(os, 1), elisa_adapter_sem_post(es, 1))
        diff_eq_int("sem_wait", oracle_sem_wait(os, 1), elisa_adapter_sem_wait(es, 1))
        ow: mutable int = 0
        ew: mutable int = 0
        diff_eq_int("sem_cancel", oracle_sem_cancel(os, 0, ow), elisa_adapter_sem_cancel(es, 0, ew))
        diff_eq_int("sem_destroy", oracle_sem_destroy(os), elisa_adapter_sem_destroy(es))

        oeve: void&? = oracle_event_create(0u64, oe)
        eeve: void&? = elisa_adapter_event_create(0u64, ee)
        diff_eq_int("event_create_error", oe, ee)
        bits_o: mutable u64 = 0u64
        bits_e: mutable u64 = 0u64
        diff_eq_int("event_wait_timeout", oracle_event_wait(oeve, 0x1u64, 0x02u32, bits_o, 1000u64), elisa_adapter_event_wait(eeve, 0x1u64, 0x02u32, bits_e, 1000u64))
        diff_eq_int("event_set", oracle_event_set(oeve, 0x1u64), elisa_adapter_event_set(eeve, 0x1u64))
        ow2: mutable int = 0
        ew2: mutable int = 0
        diff_eq_int("event_cancel", oracle_event_cancel(oeve, 0u64, ow2), elisa_adapter_event_cancel(eeve, 0u64, ew2))
        diff_eq_int("event_destroy", oracle_event_destroy(oeve), elisa_adapter_event_destroy(eeve))

@test
def parity_sem_delete_and_event_cancel_wakeup() -> void:
    can Abort.Panic:
        diff_eq_int("sem_delete_wakeup", oracle_sem_delete_wake_scenario(), elisa_adapter_sem_delete_wake_scenario())
        diff_eq_int("event_cancel_wakeup", oracle_event_cancel_wake_scenario(), elisa_adapter_event_cancel_wake_scenario())

@test
def parity_cancel_cleanup_tls_destructor_ordering() -> void:
    can Abort.Panic:
        o: int = oracle_cancel_cleanup_tls_scenario()
        # The Elisa cancel-cleanup path is covered directly by the comprehensive
        # runtime tests; this C bridge keeps the native pthread oracle alive.
        diff_eq_int("cancel_cleanup_tls_oracle_ok", o, 0)

@test
def parity_gate_metadata() -> void:
    can Abort.Panic:
        host_win: int = parity_host_is_windows()
        assert host_win == 0 or host_win == 1

@test
def parity_mutex_cond_contention_timeout_stress_cycles() -> void:
    can Abort.Panic:
        cycle: mutable int = 0
        trusted Unsafe.AssumeProgress:
            while cycle < 80:
                oe: mutable int = 0
                ee: mutable int = 0
                om: void&? = oracle_mutex_create(3, oe)
                em: void&? = elisa_adapter_mutex_create(3, ee)
                diff_eq_int("mutex_create_error", oe, ee)
                diff_eq_int("mutex_lock", oracle_mutex_lock(om), elisa_adapter_mutex_lock(em))
                diff_eq_int("mutex_trylock_busy", oracle_mutex_trylock(om), elisa_adapter_mutex_trylock(em))
                diff_eq_int("mutex_unlock", oracle_mutex_unlock(om), elisa_adapter_mutex_unlock(em))

                oc: void&? = oracle_cond_create(oe)
                ec: void&? = elisa_adapter_cond_create(ee)
                diff_eq_int("cond_create_error", oe, ee)
                diff_eq_int("cond_timedwait_timeout", oracle_cond_timedwait(oc, om, 0, 1000000), elisa_adapter_cond_timedwait(ec, em, 0, 1000000))
                diff_eq_int("cond_signal", oracle_cond_signal(oc), elisa_adapter_cond_signal(ec))
                diff_eq_int("cond_destroy", oracle_cond_destroy(oc), elisa_adapter_cond_destroy(ec))
                diff_eq_int("mutex_destroy", oracle_mutex_destroy(om), elisa_adapter_mutex_destroy(em))
                cycle <- cycle + 1

@test
def parity_rwlock_sema_event_cancel_timeout_stress_cycles() -> void:
    can Abort.Panic:
        cycle: mutable int = 0
        trusted Unsafe.AssumeProgress:
            while cycle < 60:
                oe: mutable int = 0
                ee: mutable int = 0

                orw: void&? = oracle_rwlock_create(oe)
                erw: void&? = elisa_adapter_rwlock_create(ee)
                diff_eq_int("rwlock_create_error", oe, ee)
                diff_eq_int("rwlock_rdlock", oracle_rwlock_rdlock(orw), elisa_adapter_rwlock_rdlock(erw))
                diff_eq_int("rwlock_trywrlock_busy", oracle_rwlock_trywrlock(orw), elisa_adapter_rwlock_trywrlock(erw))
                diff_eq_int("rwlock_unlock", oracle_rwlock_unlock(orw), elisa_adapter_rwlock_unlock(erw))
                diff_eq_int("rwlock_destroy", oracle_rwlock_destroy(orw), elisa_adapter_rwlock_destroy(erw))

                os: void&? = oracle_sem_create(0, 4, oe)
                es: void&? = elisa_adapter_sem_create(0, 4, ee)
                diff_eq_int("sem_create_error", oe, ee)
                diff_eq_int("sem_timedwait_timeout", oracle_sem_timedwait(os, 1, 1000u64), elisa_adapter_sem_timedwait(es, 1, 1000u64))
                ow: mutable int = 0
                ew: mutable int = 0
                diff_eq_int("sem_cancel", oracle_sem_cancel(os, 0, ow), elisa_adapter_sem_cancel(es, 0, ew))
                diff_eq_int("sem_waiters_after_cancel", ow, ew)
                diff_eq_int("sem_destroy", oracle_sem_destroy(os), elisa_adapter_sem_destroy(es))

                oeve: void&? = oracle_event_create(0u64, oe)
                eeve: void&? = elisa_adapter_event_create(0u64, ee)
                diff_eq_int("event_create_error", oe, ee)
                bits_o: mutable u64 = 0u64
                bits_e: mutable u64 = 0u64
                diff_eq_int("event_wait_timeout", oracle_event_wait(oeve, 0x1u64, 0x02u32, bits_o, 1000u64), elisa_adapter_event_wait(eeve, 0x1u64, 0x02u32, bits_e, 1000u64))
                ow2: mutable int = 0
                ew2: mutable int = 0
                diff_eq_int("event_cancel", oracle_event_cancel(oeve, 0u64, ow2), elisa_adapter_event_cancel(eeve, 0u64, ew2))
                diff_eq_int("event_waiters_after_cancel", ow2, ew2)
                diff_eq_int("event_destroy", oracle_event_destroy(oeve), elisa_adapter_event_destroy(eeve))
                cycle <- cycle + 1
