include "../core/libraries/kernel/threads/kt_runtime.elisa"
include "./kernel_threads_parity_diff_support.elisa"

extern abort() -> void

def assert(condition: bool) -> void:
    if not condition:
        abort()

const POSIX_EINVAL: int = 22
const POSIX_EBUSY: int = 16
const POSIX_ETIMEDOUT: int = 60
const ORBIS_KERNEL_ERROR_ECANCELED: int = 0x80020055

