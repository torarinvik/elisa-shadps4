include "../core/libraries/kernel/lib_function_stub.elisa"
include "../../compiler/runtime/elisacore_std/elisacore_runtime.elisa"
include "../core/libraries/remote_play/remoteplay.elisa"

@test
def remoteplay_stub_contracts() -> void:
    can Abort.Panic:
        assert sceRemoteplayInitialize() == ORBIS_OK
        assert sceRemoteplayApprove() == ORBIS_OK
        assert sceRemoteplayTerminate() == ORBIS_OK
        assert Func_1D5EE365ED5FADB3() == ORBIS_OK

@test
def remoteplay_connection_status_contract() -> void:
    can Abort.Panic:
        status: mutable int = ORBIS_REMOTEPLAY_CONNECTION_STATUS_CONNECT
        assert sceRemoteplayGetConnectionStatus(1, status) == ORBIS_OK
        assert status == ORBIS_REMOTEPLAY_CONNECTION_STATUS_DISCONNECT

def main() -> int:
    if sceRemoteplayInitialize() != ORBIS_OK:
        return 1
    status: mutable int = ORBIS_REMOTEPLAY_CONNECTION_STATUS_CONNECT
    if sceRemoteplayGetConnectionStatus(1, status) != ORBIS_OK:
        return 2
    if status != ORBIS_REMOTEPLAY_CONNECTION_STATUS_DISCONNECT:
        return 3
    if sceRemoteplayTerminate() != ORBIS_OK:
        return 4
    return 0
