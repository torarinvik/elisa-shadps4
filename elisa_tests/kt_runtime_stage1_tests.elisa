include "../../compiler/runtime/elisacore_std/elisacore_runtime.elisa"
include "../core/libraries/kernel/threads/kt_runtime.elisa"

@test
def kt_mutex_basic_lock_unlock() -> void:
    can Abort.Panic, Memory.Allocate:
        err: mutable int = -1
        h: mutable void&? = kt_mutex_create(1, err.ref[mutable int&])
        assert h != null
        assert err == 0
        assert kt_mutex_isowned(h) == 0
        assert kt_mutex_lock(h) == 0
        assert kt_mutex_isowned(h) == 1
        assert kt_mutex_unlock(h) == 0
        assert kt_mutex_isowned(h) == 0
        assert kt_mutex_destroy(h) == 0

@test
def kt_mutex_recursive_and_trylock() -> void:
    can Abort.Panic, Memory.Allocate:
        err: mutable int = -1
        h: mutable void&? = kt_mutex_create(2, err.ref[mutable int&])
        assert h != null
        assert kt_mutex_lock(h) == 0
        assert kt_mutex_lock(h) == 0
        assert kt_mutex_unlock(h) == 0
        assert kt_mutex_isowned(h) == 1
        assert kt_mutex_unlock(h) == 0
        assert kt_mutex_trylock(h) == 0
        assert kt_mutex_unlock(h) == 0
        assert kt_mutex_destroy(h) == 0

@test
def kt_mutex_null_and_unowned_contracts() -> void:
    can Abort.Panic, Memory.Allocate:
        assert kt_mutex_lock(null) == KT_PS4_EINVAL
        assert kt_mutex_destroy(null) == KT_PS4_EINVAL
        assert kt_mutex_isowned(null) == KT_PS4_EINVAL
        err: mutable int = -1
        h: mutable void&? = kt_mutex_create(1, err.ref[mutable int&])
        assert h != null
        assert kt_mutex_unlock(h) == KT_PS4_EPERM
        assert kt_mutex_destroy(h) == 0

@test
def kt_rwlock_lifecycle() -> void:
    can Abort.Panic, Memory.Allocate:
        err: mutable int = -1
        h: mutable void&? = kt_rwlock_create(err.ref[mutable int&])
        assert h != null
        assert err == 0
        assert kt_rwlock_rdlock(h) == 0
        assert kt_rwlock_unlock(h) == 0
        assert kt_rwlock_wrlock(h) == 0
        assert kt_rwlock_unlock(h) == 0
        assert kt_rwlock_tryrdlock(h) == 0
        assert kt_rwlock_unlock(h) == 0
        assert kt_rwlock_trywrlock(h) == 0
        assert kt_rwlock_unlock(h) == 0
        assert kt_rwlock_destroy(h) == 0

@test
def kt_rwlock_null_contracts() -> void:
    can Abort.Panic:
        assert kt_rwlock_rdlock(null) == KT_PS4_EINVAL
        assert kt_rwlock_destroy(null) == KT_PS4_EINVAL

@test
def kt_cond_lifecycle_signal_broadcast() -> void:
    can Abort.Panic, Memory.Allocate:
        err: mutable int = -1
        c: mutable void&? = kt_cond_create(err.ref[mutable int&])
        assert c != null
        assert err == 0
        # No waiters: signal/broadcast are well-defined no-ops returning 0.
        assert kt_cond_signal(c) == 0
        assert kt_cond_broadcast(c) == 0
        assert kt_cond_destroy(c) == 0

@test
def kt_cond_null_contracts() -> void:
    can Abort.Panic:
        assert kt_cond_signal(null) == KT_PS4_EINVAL
        assert kt_cond_destroy(null) == KT_PS4_EINVAL
        assert kt_cond_wait(null, null) == KT_PS4_EINVAL

@test
def kt_cond_wait_requires_held_mutex() -> void:
    can Abort.Panic, Memory.Allocate:
        merr: mutable int = -1
        cerr: mutable int = -1
        m: mutable void&? = kt_mutex_create(1, merr.ref[mutable int&])
        c: mutable void&? = kt_cond_create(cerr.ref[mutable int&])
        assert m != null
        assert c != null
        # Mutex not held by caller -> wait returns EPERM (no block).
        assert kt_cond_wait(c, m) == KT_PS4_EPERM
        assert kt_cond_destroy(c) == 0
        assert kt_mutex_destroy(m) == 0
