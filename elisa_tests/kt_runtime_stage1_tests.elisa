include "../core/libraries/kernel/threads/kt_runtime.elisa"

extern abort() -> void

def assert(condition: bool) -> void:
    if not condition:
        abort()

@test
def kt_mutex_basic_lock_unlock() -> void:
    can Abort.Panic, Memory.Allocate:
        err: mutable int = -1
        h: mutable void&? = kt_mutex_create(1, err.ref[mutable int&])
        assert h != null
        assert err == 0
        assert kt_mutex_isowned(h) == 0
        assert kt_mutex_lock(h) == 0
        assert kt_mutex_isowned(h) == 1
        assert kt_mutex_unlock(h) == 0
        assert kt_mutex_isowned(h) == 0
        assert kt_mutex_destroy(h) == 0

@test
def kt_mutex_recursive_and_trylock() -> void:
    can Abort.Panic, Memory.Allocate:
        err: mutable int = -1
        h: mutable void&? = kt_mutex_create(2, err.ref[mutable int&])
        assert h != null
        assert kt_mutex_lock(h) == 0
        assert kt_mutex_lock(h) == 0
        assert kt_mutex_unlock(h) == 0
        assert kt_mutex_isowned(h) == 1
        assert kt_mutex_unlock(h) == 0
        assert kt_mutex_trylock(h) == 0
        assert kt_mutex_unlock(h) == 0
        assert kt_mutex_destroy(h) == 0

@test
def kt_mutex_null_and_unowned_contracts() -> void:
    can Abort.Panic, Memory.Allocate:
        assert kt_mutex_lock(null) == KT_PS4_EINVAL
        assert kt_mutex_destroy(null) == KT_PS4_EINVAL
        assert kt_mutex_isowned(null) == KT_PS4_EINVAL
        err: mutable int = -1
        h: mutable void&? = kt_mutex_create(1, err.ref[mutable int&])
        assert h != null
        assert kt_mutex_unlock(h) == KT_PS4_EPERM
        assert kt_mutex_destroy(h) == 0

@test
def kt_rwlock_lifecycle() -> void:
    can Abort.Panic, Memory.Allocate:
        err: mutable int = -1
        h: mutable void&? = kt_rwlock_create(err.ref[mutable int&])
        assert h != null
        assert err == 0
        assert kt_rwlock_rdlock(h) == 0
        assert kt_rwlock_unlock(h) == 0
        assert kt_rwlock_wrlock(h) == 0
        assert kt_rwlock_unlock(h) == 0
        assert kt_rwlock_tryrdlock(h) == 0
        assert kt_rwlock_unlock(h) == 0
        assert kt_rwlock_trywrlock(h) == 0
        assert kt_rwlock_unlock(h) == 0
        assert kt_rwlock_destroy(h) == 0

@test
def kt_rwlock_null_contracts() -> void:
    can Abort.Panic:
        assert kt_rwlock_rdlock(null) == KT_PS4_EINVAL
        assert kt_rwlock_destroy(null) == KT_PS4_EINVAL

@test
def kt_cond_lifecycle_signal_broadcast() -> void:
    can Abort.Panic, Memory.Allocate:
        err: mutable int = -1
        c: mutable void&? = kt_cond_create(err.ref[mutable int&])
        assert c != null
        assert err == 0
        # No waiters: signal/broadcast are well-defined no-ops returning 0.
        assert kt_cond_signal(c) == 0
        assert kt_cond_broadcast(c) == 0
        assert kt_cond_destroy(c) == 0

@test
def kt_cond_null_contracts() -> void:
    can Abort.Panic:
        assert kt_cond_signal(null) == KT_PS4_EINVAL
        assert kt_cond_destroy(null) == KT_PS4_EINVAL
        assert kt_cond_wait(null, null) == KT_PS4_EINVAL

@test
def kt_cond_wait_requires_held_mutex() -> void:
    can Abort.Panic, Memory.Allocate:
        merr: mutable int = -1
        cerr: mutable int = -1
        m: mutable void&? = kt_mutex_create(1, merr.ref[mutable int&])
        c: mutable void&? = kt_cond_create(cerr.ref[mutable int&])
        assert m != null
        assert c != null
        # Mutex not held by caller -> wait returns EPERM (no block).
        assert kt_cond_wait(c, m) == KT_PS4_EPERM
        assert kt_cond_destroy(c) == 0
        assert kt_mutex_destroy(m) == 0

@test
def kt_sem_nonblocking_paths() -> void:
    can Abort.Panic, Memory.Allocate:
        err: mutable int = -1
        s: mutable void&? = kt_sem_create(2, 4, err.ref[mutable int&])
        assert s != null
        assert err == 0
        val: mutable int = -1
        assert kt_sem_getvalue(s, val.ref[mutable int&]) == 0
        assert val == 2
        # available -> wait does not block
        assert kt_sem_wait(s, 1) == 0
        assert kt_sem_getvalue(s, val.ref[mutable int&]) == 0
        assert val == 1
        # trywait success then exhaustion
        assert kt_sem_trywait(s, 1) == 0
        assert kt_sem_trywait(s, 1) == KT_PS4_EAGAIN
        # post back up; overflow guarded by max_value
        assert kt_sem_post(s, 4) == 0
        assert kt_sem_post(s, 1) == KT_PS4_EOVERFLOW
        assert kt_sem_set(s, 3) == 0
        assert kt_sem_getvalue(s, val.ref[mutable int&]) == 0
        assert val == 3
        assert kt_sem_destroy(s) == 0

@test
def kt_sem_cancel_delete_and_nulls() -> void:
    can Abort.Panic, Memory.Allocate:
        assert kt_sem_wait(null, 1) == KT_PS4_EINVAL
        assert kt_sem_destroy(null) == KT_PS4_EINVAL
        err: mutable int = -1
        w: mutable int = -1
        s: mutable void&? = kt_sem_create(0, 4, err.ref[mutable int&])
        assert s != null
        assert kt_sem_cancel(s, 1, w.ref[mutable int&]) == 0
        assert w == 0
        # cancel with no waiters leaves value set
        val: mutable int = -1
        assert kt_sem_getvalue(s, val.ref[mutable int&]) == 0
        assert val == 1
        assert kt_sem_delete(s, w.ref[mutable int&]) == 0
        assert w == 0

@test
def kt_event_nonblocking_paths() -> void:
    can Abort.Panic, Memory.Allocate:
        err: mutable int = -1
        e: mutable void&? = kt_event_create(0x3u64, err.ref[mutable int&])
        assert e != null
        assert err == 0
        bits: mutable u64 = 0u64
        # OR match (0x02 low), no clear
        assert kt_event_poll(e, 0x1u64, 0x02u32, bits.ref[mutable u64&]) == 0
        assert bits == 0x3u64
        # AND match (0x01 low) requires all bits
        assert kt_event_poll(e, 0x7u64, 0x01u32, bits.ref[mutable u64&]) == KT_PS4_EAGAIN
        assert kt_event_set(e, 0x4u64) == 0
        assert kt_event_poll(e, 0x7u64, 0x01u32, bits.ref[mutable u64&]) == 0
        # already-set -> wait returns immediately; clear-all mode 0x10
        assert kt_event_wait(e, 0x4u64, 0x12u32, bits.ref[mutable u64&], KT_U64_MAX) == 0
        assert kt_event_poll(e, 0x1u64, 0x02u32, bits.ref[mutable u64&]) == KT_PS4_EAGAIN
        assert kt_event_destroy(e) == 0

@test
def kt_event_cancel_delete_and_nulls() -> void:
    can Abort.Panic, Memory.Allocate:
        assert kt_event_set(null, 1u64) == KT_PS4_EINVAL
        assert kt_event_poll(null, 1u64, 0x02u32, null) == KT_PS4_EINVAL
        err: mutable int = -1
        w: mutable int = -1
        e: mutable void&? = kt_event_create(0u64, err.ref[mutable int&])
        assert e != null
        assert kt_event_cancel(e, 0x9u64, w.ref[mutable int&]) == 0
        assert w == 0
        bits: mutable u64 = 0u64
        assert kt_event_poll(e, 0x9u64, 0x01u32, bits.ref[mutable u64&]) == 0
        assert kt_event_delete(e, w.ref[mutable int&]) == 0
        assert w == 0
