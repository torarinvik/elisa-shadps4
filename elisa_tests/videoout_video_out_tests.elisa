include "../core/libraries/videoout/video_out.elisa"
include "../../compiler/runtime/elisacore_std/elisacore_runtime.elisa"

@test
def videoout_constants() -> void:
    can Abort.Panic:
        assert SCE_VIDEO_OUT_PIXEL_FORMAT_A16R16G16B16_FLOAT == 0xC1060000u32
        assert SCE_VIDEO_OUT_REFRESH_RATE_ANY == 0xFFFFFFFFFFFFFFFFu64
        assert VIDEO_OUT_INTERNAL_EVENT_SYS_VBLANK == 0x63u32

@test
def videoout_struct_defaults() -> void:
    can Abort.Panic:
        fs: mutable FlipStatus = FlipStatus_New()
        assert fs.flip_arg == -1i64
        assert fs.current_buffer == -1i32

        rs: mutable SceVideoOutResolutionStatus = SceVideoOutResolutionStatus_New()
        assert rs.full_width == 1280i32
        assert rs.refresh_rate == 3u64
