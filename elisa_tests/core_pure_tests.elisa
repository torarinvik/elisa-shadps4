include "../core/libraries/ngs2/ngs2_error.elisa"
include "../core/libraries/error_codes.elisa"
include "../../compiler/runtime/elisacore_std/elisacore_runtime.elisa"
include "../common/types.elisa"
include "../core/emulator_state.elisa"
include "../core_libraries_errors_port.elisa"
include "../core/libraries/random/random.elisa"

@test
def emulator_state_defaults_and_setters_match_cpp() -> void:
    can Abort.Panic:
        EmulatorState_ResetInstance()
        state: mutable EmulatorState& = EmulatorState_GetInstance()
        assert not EmulatorState_IsGameRunning(state)
        assert EmulatorState_IsAutoPatchesLoadEnabled(state)
        assert not EmulatorState_IsGameSpecifigConfigUsed(state)

        EmulatorState_SetGameRunning(state, true)
        EmulatorState_SetAutoPatchesLoadEnabled(state, false)
        EmulatorState_SetGameSpecifigConfigUsed(state, true)

        assert EmulatorState_IsGameRunning(state)
        assert not EmulatorState_IsAutoPatchesLoadEnabled(state)
        assert EmulatorState_IsGameSpecifigConfigUsed(state)

@test
def emulator_state_set_instance_copies_state() -> void:
    can Abort.Panic:
        replacement: EmulatorState = EmulatorState(true, false, true)
        EmulatorState_SetInstance(replacement)
        state: mutable EmulatorState& = EmulatorState_GetInstance()
        assert EmulatorState_IsGameRunning(state)
        assert not EmulatorState_IsAutoPatchesLoadEnabled(state)
        assert EmulatorState_IsGameSpecifigConfigUsed(state)

@test
def core_error_constants_match_cpp_headers() -> void:
    can Abort.Panic:
        assert ORBIS_OK == 0
        assert ORBIS_FAIL == 0xFFFFFFFF
        assert ORBIS_KERNEL_ERROR_EPERM == 0x80020001
        assert ORBIS_KERNEL_ERROR_EWOULDBLOCK == ORBIS_KERNEL_ERROR_EAGAIN
        assert ORBIS_KERNEL_ERROR_ESTART == 0x80020064
        assert POSIX_EPERM == 1
        assert POSIX_EWOULDBLOCK == POSIX_EAGAIN
        assert POSIX_ELAST == 102
        assert POSIX_ETIME == 1074
        assert ORBIS_AUDIO_OUT_ERROR_INVALID_PORT == 0x80260003
        assert ORBIS_NET_EWOULDBLOCK == ORBIS_NET_EAGAIN
        assert ORBIS_NGS2_ERROR_INVALID_NUM_MODULE_BUFFERS == 0x804A0A02
        assert ORBIS_ZLIB_ERROR_NOT_FOUND == 0x81120002

@test
def random_rejects_oversized_buffers_like_cpp() -> void:
    can Abort.Panic:
        assert sceRandomGetRandomNumber(null, 65) == SCE_RANDOM_ERROR_INVALID
