include "../shader_recompiler/frontend/opcode_unified_vop2.elisa"
include "../../compiler/runtime/elisacore_std/elisacore_runtime.elisa"

@test
def opcode_unified_vop2_values() -> void:
    can Abort.Panic:
        assert OPCODE_V_CNDMASK_B32 == OPCODE_MAP_OP_MAP_VOP2
        assert OPCODE_V_ADD_F32 == 3u32 + OPCODE_MAP_OP_MAP_VOP2
        assert OPCODE_V_LDEXP_F16 == 59u32 + OPCODE_MAP_OP_MAP_VOP2
        assert OPCODE_V_CNDMASK_B32 != OPCODE_V_ADD_F32
        assert OPCODE_V_MIN_F16 != OPCODE_V_MAX_F16
