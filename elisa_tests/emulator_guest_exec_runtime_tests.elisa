@test
def emulator_guest_exec_first_boundary_classifies_probe_or_unsupported() -> void:
    can Abort.Panic:
        GuestExec_ResetState()
        GuestExec_Enable(true)
        GuestExec_SetProbeMode(true)
        GuestExec_RunMainEntry(0x1234000.uintptr(), 0, null)
        stage: s32 = GuestExec_ClassifyFirstBoundary()
        if GuestExec_IsSupported():
            if stage != GUEST_EXEC_BOUNDARY_ARMED_PROBE_ONLY:
                panic("expected armed probe boundary classification")
            if GuestExec_FirstBoundaryReason() != GUEST_EXEC_BOUNDARY_REASON_PROBE_ONLY:
                panic("expected probe-only boundary reason")
        else:
            if stage != GUEST_EXEC_BOUNDARY_UNSUPPORTED_HOST:
                panic("expected unsupported host boundary classification")
            if GuestExec_FirstBoundaryReason() != GUEST_EXEC_BOUNDARY_REASON_UNSUPPORTED_HOST:
                panic("expected unsupported-host boundary reason")

@test
def emulator_guest_exec_first_boundary_classifies_real_hle_boundary() -> void:
    can Abort.Panic:
        GuestExec_ResetState()
        GuestExec_RecordHandoff(0x1234000.uintptr(), 0, true)
        GuestExec_RecordFirstBoundary(GUEST_EXEC_BOUNDARY_REASON_NATIVE_HLE)
        stage: s32 = GuestExec_ClassifyFirstBoundary()
        if GuestExec_IsSupported():
            if stage != GUEST_EXEC_BOUNDARY_FIRST_HLE_IMPORT:
                panic("expected first HLE import boundary classification")
            if GuestExec_FirstBoundaryReason() != GUEST_EXEC_BOUNDARY_REASON_NATIVE_HLE:
                panic("expected native HLE boundary reason")
            if GuestExec_ExecutionStage() != GUEST_EXEC_STAGE_FIRST_BOUNDARY:
                panic("expected first-boundary execution stage")
        else:
            if stage != GUEST_EXEC_BOUNDARY_UNSUPPORTED_HOST:
                panic("expected unsupported host boundary classification")

@test
def emulator_guest_exec_pre_boundary_fault_reports_crash_captured_stage() -> void:
    can Abort.Panic:
        if not GuestExec_IsSupported():
            return
        GuestExec_ResetState()
        crash_entry: VAddr = GuestExec_GetSyntheticCrashAddress()
        if crash_entry == 0.uintptr():
            panic("expected synthetic crash function address")
        status: s32 = GuestExec_RunMainEntryGuarded(crash_entry, 0, null, 10.u32())
        if status >= 0:
            panic("expected guarded crash status")
        if GuestExec_LastSignal() == 0:
            panic("expected crash signal")
        if GuestExec_LastGuestPC() == 0.uintptr():
            panic("expected parent-visible fork crash pc")
        if GuestExec_SignalGuestPC() == 0.uintptr():
            if not GuestExec_LastPCWasFallback():
                panic("expected zero signal pc to be marked as fallback-sourced")
            if GuestExec_FallbackGuestPC() == 0.uintptr():
                panic("expected fallback pc when signal pc is missing")
        else:
            if GuestExec_LastPCWasFallback():
                panic("expected real signal pc not to be marked as fallback")
            if GuestExec_LastGuestPC() != GuestExec_SignalGuestPC():
                panic("expected effective pc to equal true signal pc when available")
        if GuestExec_ClassifyFirstBoundary() != GUEST_EXEC_BOUNDARY_PRE_BOUNDARY_FAULT:
            panic("expected pre-boundary fault classification")
        if GuestExec_FirstBoundaryReason() != GUEST_EXEC_BOUNDARY_REASON_HOST_CRASH:
            panic("expected host crash first-boundary reason")
        if GuestExec_ExecutionStage() != GUEST_EXEC_STAGE_CRASH_CAPTURED:
            panic("expected crash-captured execution stage")

@test
def emulator_guest_exec_guarded_entry_trap_reports_entry_params_context() -> void:
    can Abort.Panic:
        if not GuestExec_IsSupported():
            return
        GuestExec_ResetState()
        GuestExec_Enable(true)
        mapped_entry: VAddr = GuestExec_AllocateRegion(4096.u64(), 3.u32())
        if mapped_entry == 0.uintptr():
            panic("expected guarded trap page allocation")
        code: mutable u8[2] = [0x0Fu8, 0x0Bu8] # ud2
        if not GuestExec_WriteBytes(mapped_entry, code[0].ref[void&], 2.u64()):
            panic("expected guarded trap machine code write")
        if not GuestExec_ProtectRegion(mapped_entry, 4096.u64(), 5.u32()):
            panic("expected guarded trap executable protection")
        status: s32 = GuestExec_RunMainEntryGuarded(mapped_entry, 91, null, 100.u32())
        if status >= 0:
            panic("expected guarded trap to fail before boundary")
        if GuestExec_ExpectedEntryParams() == 0.uintptr():
            panic("expected guarded trap entry params")
        if GuestExec_PreJumpRDI() != GuestExec_ExpectedEntryParams():
            panic("expected guarded trap prejump rdi to be EntryParams")
        if GuestExec_SignalPCValid():
            if GuestExec_SignalGuestPC() >= mapped_entry and GuestExec_SignalGuestPC() < mapped_entry + 2.uintptr():
                if GuestExec_SignalRDIValid() and GuestExec_LastGuestRDI() != GuestExec_ExpectedEntryParams():
                    panic("expected guarded trap signal rdi to be EntryParams")
                if GuestExec_SignalNativeRegionIndex() < 0:
                    panic("expected guarded trap signal pc to resolve to native region")
            else:
                if GuestExec_SignalUContext() == 0.uintptr():
                    panic("expected divergent guarded trap signal pc to preserve raw ucontext diagnostic")
        else:
            if GuestExec_SignalUContext() == 0.uintptr():
                panic("expected missing signal pc to preserve raw ucontext diagnostic")
        if not GuestExec_UnmapRegion(mapped_entry, 4096.u64()):
            panic("expected guarded trap page unmap")

@test
def emulator_guest_exec_x64_subprocess_capability_probe_is_deterministic() -> void:
    can Abort.Panic:
        first: bool = GuestExec_HostCanRunX64Subprocess()
        second: bool = GuestExec_HostCanRunX64Subprocess()
        if first != second:
            panic("expected x64 subprocess capability probe to be deterministic")

@test
def emulator_guest_exec_x64_subprocess_capability_matches_host_mode() -> void:
    can Abort.Panic:
        host_arch: static u8&? = GuestExec_HostArchitecture()
        host_mode: static u8&? = GuestExec_HostMode()
        can_run_x64_subprocess: bool = GuestExec_HostCanRunX64Subprocess()
        if GuestExec_IsSupported():
            if not can_run_x64_subprocess:
                panic("expected native x64 hosts to report x64 subprocess capability")
            return
        if host_mode != null and host_arch != null and streq(host_mode, "macOS") == 1 and streq(host_arch, "arm64") == 1:
            # On Apple Silicon this may be false when Rosetta is unavailable.
            if can_run_x64_subprocess:
                return
            return
        if can_run_x64_subprocess:
            panic("expected non-x64 unsupported hosts to report no x64 subprocess capability")
