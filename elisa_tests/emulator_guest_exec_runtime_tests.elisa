include "../common/streq.elisa"
include "../common/types.elisa"
include "../core/guest_exec.elisa"

def guest_exec_test_posix_mutex_lock_shape(mutex: mutable void&?&?) -> int:
    slot: mutable uintptr = 0.uintptr()
    if mutex != null:
        slot <- mutex.cast[void&].uintptr()
    GuestExec_RecordRuntimeHle("libkernel", "posix_pthread_mutex_lock", slot, 0.uintptr(), 0.uintptr(), 22.uintptr())
    return 22

@test
def emulator_guest_exec_entry_params_abi_matches_native_layout() -> void:
    can Abort.Panic:
        if GuestExec_EntryParamsArgcOffset() != 0.u64():
            panic("expected EntryParams argc offset")
        if GuestExec_EntryParamsArgvOffset() != 8.u64():
            panic("expected EntryParams argv offset")
        if GuestExec_EntryParamsEntryAddrOffset() != 272.u64():
            panic("expected EntryParams entry_addr offset")
        if GuestExec_EntryParamsSize() != 280.u64():
            panic("expected EntryParams size")

        params: mutable GuestEntryParams = zeroed
        params.argc <- 77.s32()
        params.padding <- 0xA5A5A5A5.u32()
        params.argv[0] <- 0x12345678.uintptr().cast[static u8&?]
        params.entry_addr <- 0x8877665544332211.uintptr()

        probe: u64 = GuestExec_ProbeEntryParams(params.ref[mutable GuestEntryParams&])
        expected: u64 = 0xE100000000000000.u64() | 77.u64() | (1.u64() << 16) | (1.u64() << 17) | (1.u64() << 18)
        if probe != expected:
            panic("expected native ABI probe to observe Elisa-filled EntryParams")

@test
def emulator_guest_exec_synthetic_function_executes_and_returns() -> void:
    can Abort.Panic:
        if not GuestExec_IsSupported():
            return
        entry: VAddr = GuestExec_GetSyntheticAddAddress()
        if entry == 0.uintptr():
            panic("expected synthetic function address")
        result: u64 = GuestExec_RunSyntheticFunction(entry, 40.u64(), 2.u64())
        if result != 0x125E.u64():
            panic("expected synthetic function result")

@test
def emulator_guest_exec_synthetic_mapped_trampoline_executes_and_returns() -> void:
    can Abort.Panic:
        GuestExec_ResetState()
        if not GuestExec_IsSupported():
            if not GuestExec_IsProbeOnly():
                panic("expected unsupported host to report probe-only mode")
            if GuestExec_SupportedNativeExecution():
                panic("expected unsupported host native execution to be false")
            return
        GuestExec_Enable(true)
        mapped_entry: VAddr = GuestExec_AllocateRegion(4096.u64(), 3.u32())
        if mapped_entry == 0.uintptr():
            panic("expected executable test page allocation")
        code: mutable u8[6] = [0xB8u8, 0x2Au8, 0x00u8, 0x00u8, 0x00u8, 0xC3u8]
        if not GuestExec_WriteBytes(mapped_entry, code[0].ref[void&], 6.u64()):
            panic("expected machine code write")
        if not GuestExec_ProtectRegion(mapped_entry, 4096.u64(), 5.u32()):
            panic("expected executable protection")
        result: u64 = GuestExec_RunSyntheticFunction(mapped_entry, 0.u64(), 0.u64())
        if result != 42.u64():
            panic("expected mapped trampoline to return 42")
        if GuestExec_LastStatus() != 1:
            panic("expected successful trampoline status")
        if not GuestExec_UnmapRegion(mapped_entry, 4096.u64()):
            panic("expected executable test page unmap")

@test
def emulator_guest_exec_mapped_guest_calls_host_hle_probe() -> void:
    can Abort.Panic:
        GuestExec_ResetState()
        if not GuestExec_IsSupported():
            return
        GuestExec_Enable(true)
        hle_probe: VAddr = GuestExec_GetSyntheticHleBoundaryProbeAddress()
        if hle_probe == 0.uintptr():
            panic("expected synthetic HLE probe address")
        mapped_entry: VAddr = GuestExec_AllocateRegion(4096.u64(), 3.u32())
        if mapped_entry == 0.uintptr():
            panic("expected executable HLE-call test page allocation")
        code: mutable u8[18] = [
            0x48u8, 0xB8u8, 0x00u8, 0x00u8, 0x00u8, 0x00u8, 0x00u8, 0x00u8, 0x00u8, 0x00u8,
            0xFFu8, 0xD0u8,
            0xB8u8, 0x2Bu8, 0x00u8, 0x00u8, 0x00u8,
            0xC3u8
        ]
        if not GuestExec_WriteBytes(mapped_entry, code[0].ref[void&], 18.u64()):
            panic("expected HLE-call machine code write")
        if not GuestExec_WriteU64(mapped_entry + 2.uintptr(), hle_probe.u64()):
            panic("expected HLE probe address patch")
        if not GuestExec_ProtectRegion(mapped_entry, 4096.u64(), 5.u32()):
            panic("expected executable HLE-call page protection")
        result: u64 = GuestExec_RunSyntheticFunction(mapped_entry, 0.u64(), 0.u64())
        if result != 43.u64():
            panic("expected mapped guest HLE-call trampoline to return 43")
        if streq(GuestExec_RuntimeHleSymbol(), "synthetic_hle_boundary_probe") != 1:
            panic("expected mapped guest code to execute host HLE probe")
        if not GuestExec_UnmapRegion(mapped_entry, 4096.u64()):
            panic("expected executable HLE-call test page unmap")

@test
def emulator_guest_exec_mapped_guest_calls_posix_mutex_lock_and_returns() -> void:
    can Abort.Panic:
        GuestExec_ResetState()
        if not GuestExec_IsSupported():
            return
        GuestExec_Enable(true)
        lock_addr: VAddr = guest_exec_test_posix_mutex_lock_shape as uintptr
        if lock_addr == 0.uintptr():
            panic("expected posix pthread mutex lock address")
        mapped_entry: VAddr = GuestExec_AllocateRegion(4096.u64(), 3.u32())
        if mapped_entry == 0.uintptr():
            panic("expected executable mutex-call test page allocation")
        code: mutable u8[28] = [
            0x48u8, 0xBFu8, 0xF4u8, 0x01u8, 0x00u8, 0x00u8, 0x00u8, 0x00u8, 0x00u8, 0x00u8,
            0x48u8, 0xB8u8, 0x00u8, 0x00u8, 0x00u8, 0x00u8, 0x00u8, 0x00u8, 0x00u8, 0x00u8,
            0xFFu8, 0xD0u8,
            0xB8u8, 0x2Bu8, 0x00u8, 0x00u8, 0x00u8,
            0xC3u8
        ]
        if not GuestExec_WriteBytes(mapped_entry, code[0].ref[void&], 28.u64()):
            panic("expected mutex-call machine code write")
        if not GuestExec_WriteU64(mapped_entry + 12.uintptr(), lock_addr.u64()):
            panic("expected mutex lock address patch")
        if not GuestExec_ProtectRegion(mapped_entry, 4096.u64(), 5.u32()):
            panic("expected executable mutex-call page protection")
        result: u64 = GuestExec_RunSyntheticFunction(mapped_entry, 0.u64(), 0.u64())
        if result != 43.u64():
            panic("expected mapped guest mutex HLE call to return to guest code")
        if streq(GuestExec_RuntimeHleSymbol(), "posix_pthread_mutex_lock") != 1:
            panic("expected mapped guest code to execute posix mutex lock HLE")
        if GuestExec_RuntimeHleArg0() != 0x1F4.uintptr():
            panic("expected runtime HLE arg0 to match CUSA mutex argument")
        if GuestExec_RuntimeHleRet().u64() != 22.u64():
            panic("expected low guest mutex pointer to return POSIX_EINVAL")
        if not GuestExec_UnmapRegion(mapped_entry, 4096.u64()):
            panic("expected executable mutex-call test page unmap")

@test
def emulator_guest_exec_mapped_fault_reports_signal_context() -> void:
    can Abort.Panic:
        GuestExec_ResetState()
        if not GuestExec_IsSupported():
            return
        GuestExec_Enable(true)
        mapped_entry: VAddr = GuestExec_AllocateRegion(4096.u64(), 3.u32())
        if mapped_entry == 0.uintptr():
            panic("expected executable fault test page allocation")
        code: mutable u8[2] = [0x0Fu8, 0x0Bu8] # ud2
        if not GuestExec_WriteBytes(mapped_entry, code[0].ref[void&], 2.u64()):
            panic("expected fault machine code write")
        if not GuestExec_ProtectRegion(mapped_entry, 4096.u64(), 5.u32()):
            panic("expected executable fault page protection")
        sentinel_rdi: u64 = 0x123456789ABCDEF0u64
        result: u64 = GuestExec_RunSyntheticFunction(mapped_entry, sentinel_rdi, 0.u64())
        if result != 0xFFFFFFFFFFFFFFFD.u64():
            panic("expected mapped fault sentinel")
        if GuestExec_LastSignal() == 0:
            panic("expected mapped fault signal")
        if not GuestExec_SignalPCValid():
            panic("expected mapped in-process fault to have signal pc")
        if GuestExec_SignalGuestPC() < mapped_entry or GuestExec_SignalGuestPC() >= mapped_entry + 2.uintptr():
            panic("expected signal pc inside mapped fault instruction")
        if not GuestExec_SignalRDIValid():
            panic("expected mapped fault rdi validity bit")
        if GuestExec_LastGuestRDI() != sentinel_rdi.uintptr():
            panic("expected mapped fault rdi to preserve arg0")
        if GuestExec_SignalNativeRegionIndex() < 0:
            panic("expected signal pc to resolve to native region")
        if (GuestExec_LastPCNativeProt() & 5u32) != 5u32:
            panic("expected signal pc native region to be readable/executable")
        if not GuestExec_UnmapRegion(mapped_entry, 4096.u64()):
            panic("expected executable fault test page unmap")

@test
def emulator_guest_exec_map_protect_unmap_validation_contracts() -> void:
    can Abort.Panic:
        GuestExec_ResetState()
        GuestExec_Enable(true)
        if not GuestExec_IsSupported():
            if GuestExec_UnmapRegion(0x1000.uintptr(), 4096.u64()):
                panic("expected unsupported host unmap to fail")
            return
        if GuestExec_UnmapRegion(0.uintptr(), 4096.u64()):
            panic("expected null unmap to fail")
        if GuestExec_UnmapRegion(0x1000.uintptr(), 0.u64()):
            panic("expected zero-size unmap to fail")
        mapped: VAddr = GuestExec_AllocateRegion(4096.u64(), 3.u32())
        if mapped == 0.uintptr():
            panic("expected allocation for unmap validation")
        if not GuestExec_ProtectRegion(mapped, 4096.u64(), 1.u32()):
            panic("expected read-only protection")
        if not GuestExec_UnmapRegion(mapped, 4096.u64()):
            panic("expected allocated region unmap")

