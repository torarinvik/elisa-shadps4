def guest_exec_record_trace_variant(value: VAddr) -> u64:
    can Debug.Trace:
        GuestExec_SetDebugTraceEnabled(true)
        GuestExec_ResetState()
        GuestExec_SetDebugTraceEnabled(true)
        GuestExec_SetDebugTrapOnCallableGuard(true)
        _ = GuestExec_DebugGuardCallableTarget(value, 44u64)
        GuestExec_RecordRuntimeHle("libkernel", "trace_probe", value, 7.uintptr(), 9.uintptr(), 22.uintptr())
        return GuestExec_DebugTraceFingerprint()

@test
def emulator_guest_exec_debug_trace_tape_fingerprints_boundary_events() -> void:
    can Abort.Panic, Debug.Trace:
        first: u64 = guest_exec_record_trace_variant(0x1F4.uintptr())
        count: usize = GuestExec_DebugTraceCount()
        if count < 4.usize():
            panic("expected guest-exec trace tape to record reset/guard/HLE events")
        if GuestExec_DebugTraceEventKindAt(0.usize()) != DEBUG_TRACE_KIND_CHECKPOINT:
            panic("expected guest-exec trace to start with reset checkpoint")
        if GuestExec_DebugTraceEventAAt(1.usize()) != 0x1F4.uintptr():
            panic("expected guest-exec trace to preserve the bad callable value")
        second: u64 = guest_exec_record_trace_variant(0x1F4.uintptr())
        if first != second:
            panic("expected identical guest-exec traces to have identical fingerprints")
        third: u64 = guest_exec_record_trace_variant(0x200.uintptr())
        if first == third:
            panic("expected guest-exec trace fingerprint to change when boundary value changes")

@test
def emulator_guest_exec_debug_trace_diff_locates_first_divergence() -> void:
    can Abort.Panic, Debug.Trace:
        # Record a reference run and snapshot it as the baseline tape.
        _ = guest_exec_record_trace_variant(0x1F4.uintptr())
        GuestExec_DebugTraceSnapshot()
        if GuestExec_DebugTraceSnapshotCount() < 4.usize():
            panic("expected snapshot to capture the reference tape")
        # An identical re-run must NOT diverge.
        _ = guest_exec_record_trace_variant(0x1F4.uintptr())
        if GuestExec_DebugTraceFirstDivergence() != -1:
            panic("expected identical guest-exec traces to have no divergence")
        # A run with a changed boundary value must diverge, and the locator must
        # surface both the live and reference values at the divergence point.
        _ = guest_exec_record_trace_variant(0x200.uintptr())
        idx: int = GuestExec_DebugTraceFirstDivergence()
        if idx < 0:
            panic("expected guest-exec trace divergence when boundary value changes")
        if GuestExec_DebugTraceDivergenceLiveA() != 0x200.uintptr():
            panic("expected divergence live value to be the changed callable target")
        if GuestExec_DebugTraceDivergenceSnapA() != 0x1F4.uintptr():
            panic("expected divergence reference value to be the original callable target")

@test
def emulator_guest_exec_debug_trace_reference_load_diff() -> void:
    can Abort.Panic, Debug.Trace:
        # Record a live run, then build a reference identical to it via the
        # external-load API (this is the path a recorded shadPS4 tape uses).
        _ = guest_exec_record_trace_variant(0x1F4.uintptr())
        n: usize = GuestExec_DebugTraceCount()
        if n < 4.usize():
            panic("expected a populated live tape to build a reference from")
        GuestExec_DebugTraceBeginReference()
        i: mutable usize = 0usize
        while i < n:
            _ = GuestExec_DebugTraceLoadReferenceEvent(i, GuestExec_DebugTraceEventKindAt(i), GuestExec_DebugTraceEventAAt(i), GuestExec_DebugTraceEventBAt(i), GuestExec_DebugTraceEventCAt(i))
            i <- i + 1usize
        GuestExec_DebugTraceCommitReference(n)
        # Identical reference -> no divergence against the (unchanged) live tape.
        if GuestExec_DebugTraceFirstDivergence() != -1:
            panic("expected a loaded reference identical to the live tape to have no divergence")
        # Mutate reference event 1 -> divergence must localize to index 1 and
        # surface the reference value at that point.
        _ = GuestExec_DebugTraceLoadReferenceEvent(1.usize(), GuestExec_DebugTraceEventKindAt(1.usize()), 0xDEAD.uintptr(), GuestExec_DebugTraceEventBAt(1.usize()), GuestExec_DebugTraceEventCAt(1.usize()))
        GuestExec_DebugTraceCommitReference(n)
        if GuestExec_DebugTraceFirstDivergence() != 1:
            panic("expected a mutated reference event to diverge at index 1")
        if GuestExec_DebugTraceDivergenceSnapA() != 0xDEAD.uintptr():
            panic("expected the reference value at the divergence to be the mutated value")

@test
def emulator_guest_exec_debug_trace_captures_barrier_trip() -> void:
    can Abort.Panic, Debug.Trace:
        # A barrier trip (poison callable target) must be both rejected AND
        # recorded on the trace tape, so a differential tape diff can localize a
        # *barrier trip*, not only a changed value.
        _ = guest_exec_record_trace_variant(GE_BOUNDARY_POISON_WORD.uintptr())
        if GuestExec_DebugTrapReason() != GE_BOUNDARY_GUARD_POISON:
            panic("expected the poison callable target to trip the callable guard")
        if GuestExec_DebugTraceEventAAt(1.usize()).u64() != GE_BOUNDARY_POISON_WORD:
            panic("expected the trace tape to record the poison callable target value")

@test
def emulator_guest_exec_thread_affinity_guard_detects_cross_thread_access() -> void:
    can Abort.Panic:
        GuestExec_ResetState()
        GuestExec_DebugThreadAffinityReset()
        GuestExec_SetDebugTrapOnThreadAffinity(true)
        # First touch by thread 0xA111 captures ownership of slot 3.
        if not GuestExec_DebugThreadAffinityCheck(3.usize(), 0xA111u64):
            panic("expected first touch to capture thread affinity")
        # Same thread may touch it again.
        if not GuestExec_DebugThreadAffinityCheck(3.usize(), 0xA111u64):
            panic("expected the owning thread to retain access")
        if GuestExec_DebugThreadAffinityViolationCount() != 0u64:
            panic("expected no violation for the owning thread")
        # A different thread touching the same slot is a cross-thread violation.
        if GuestExec_DebugThreadAffinityCheck(3.usize(), 0xB222u64):
            panic("expected a different thread to be rejected by the affinity guard")
        if GuestExec_DebugThreadAffinityViolationCount() != 1u64:
            panic("expected one recorded cross-thread affinity violation")
        if GuestExec_DebugThreadAffinityLastSlot() != 3.usize():
            panic("expected the violation to record the touched slot")
        if GuestExec_DebugThreadAffinityLastOwner() != 0xA111u64:
            panic("expected the violation to record the original owner")
        if GuestExec_DebugThreadAffinityLastIntruder() != 0xB222u64:
            panic("expected the violation to record the intruding thread")
        if GuestExec_DebugTrapReason() != GE_DEBUG_TRAP_THREAD_AFFINITY_STATUS.u64():
            panic("expected an armed affinity guard to trip the referee")

@test
def emulator_guest_exec_mapped_guest_calls_host_hle_probe() -> void:
    can Abort.Panic:
        GuestExec_ResetState()
        if not GuestExec_IsSupported():
            return
        GuestExec_Enable(true)
        hle_probe: VAddr = GuestExec_GetSyntheticHleBoundaryProbeAddress()
        if hle_probe == 0.uintptr():
            panic("expected synthetic HLE probe address")
        mapped_entry: VAddr = GuestExec_AllocateRegion(4096.u64(), 3.u32())
        if mapped_entry == 0.uintptr():
            panic("expected executable HLE-call test page allocation")
        code: mutable u8[18] = [
            0x48u8, 0xB8u8, 0x00u8, 0x00u8, 0x00u8, 0x00u8, 0x00u8, 0x00u8, 0x00u8, 0x00u8,
            0xFFu8, 0xD0u8,
            0xB8u8, 0x2Bu8, 0x00u8, 0x00u8, 0x00u8,
            0xC3u8
        ]
        if not GuestExec_WriteBytes(mapped_entry, code[0].ref[void&], 18.u64()):
            panic("expected HLE-call machine code write")
        if not GuestExec_WriteU64(mapped_entry + 2.uintptr(), hle_probe.u64()):
            panic("expected HLE probe address patch")
        if not GuestExec_ProtectRegion(mapped_entry, 4096.u64(), 5.u32()):
            panic("expected executable HLE-call page protection")
        result: u64 = GuestExec_RunSyntheticFunction(mapped_entry, 0.u64(), 0.u64())
        if result != 43.u64():
            panic("expected mapped guest HLE-call trampoline to return 43")
        if streq(GuestExec_RuntimeHleSymbol(), "synthetic_hle_boundary_probe") != 1:
            panic("expected mapped guest code to execute host HLE probe")
        if not GuestExec_UnmapRegion(mapped_entry, 4096.u64()):
            panic("expected executable HLE-call test page unmap")

@test
def emulator_guest_exec_mapped_guest_calls_posix_mutex_lock_and_returns() -> void:
    can Abort.Panic:
        GuestExec_ResetState()
        if not GuestExec_IsSupported():
            return
        GuestExec_Enable(true)
        lock_addr: VAddr = guest_exec_test_posix_mutex_lock_shape as uintptr
        if lock_addr == 0.uintptr():
            panic("expected posix pthread mutex lock address")
        mapped_entry: VAddr = GuestExec_AllocateRegion(4096.u64(), 3.u32())
        if mapped_entry == 0.uintptr():
            panic("expected executable mutex-call test page allocation")
        code: mutable u8[28] = [
            0x48u8, 0xBFu8, 0xF4u8, 0x01u8, 0x00u8, 0x00u8, 0x00u8, 0x00u8, 0x00u8, 0x00u8,
            0x48u8, 0xB8u8, 0x00u8, 0x00u8, 0x00u8, 0x00u8, 0x00u8, 0x00u8, 0x00u8, 0x00u8,
            0xFFu8, 0xD0u8,
            0xB8u8, 0x2Bu8, 0x00u8, 0x00u8, 0x00u8,
            0xC3u8
        ]
        if not GuestExec_WriteBytes(mapped_entry, code[0].ref[void&], 28.u64()):
            panic("expected mutex-call machine code write")
        if not GuestExec_WriteU64(mapped_entry + 12.uintptr(), lock_addr.u64()):
            panic("expected mutex lock address patch")
        if not GuestExec_ProtectRegion(mapped_entry, 4096.u64(), 5.u32()):
            panic("expected executable mutex-call page protection")
        result: u64 = GuestExec_RunSyntheticFunction(mapped_entry, 0.u64(), 0.u64())
        if result != 43.u64():
            panic("expected mapped guest mutex HLE call to return to guest code")
        if streq(GuestExec_RuntimeHleSymbol(), "posix_pthread_mutex_lock") != 1:
            panic("expected mapped guest code to execute posix mutex lock HLE")
        if GuestExec_RuntimeHleArg0() != 0x1F4.uintptr():
            panic("expected runtime HLE arg0 to match CUSA mutex argument")
        if GuestExec_RuntimeHleRet().u64() != 22.u64():
            panic("expected low guest mutex pointer to return POSIX_EINVAL")
        if GuestExec_RuntimeHleArg2().u64() != 3.u64():
            panic("expected low guest mutex pointer reject reason")
        if GuestExec_RuntimeHleBoundaryGuardSequence() == 0.u64():
            panic("expected boundary guard to record tiny unmapped HLE arg")
        if GuestExec_RuntimeHleBoundaryGuardReason() != 2.u64():
            panic("expected boundary guard reason to be near-null unmapped")
        if GuestExec_RuntimeHleBoundaryGuardIndex() != 0.u64():
            panic("expected boundary guard to identify arg0")
        if GuestExec_RuntimeHleBoundaryGuardValue() != 0x1F4.uintptr():
            panic("expected boundary guard value to match tiny mutex argument")
        if not GuestExec_UnmapRegion(mapped_entry, 4096.u64()):
            panic("expected executable mutex-call test page unmap")

@test
