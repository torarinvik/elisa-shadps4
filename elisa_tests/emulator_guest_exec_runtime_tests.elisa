        if entry == 0.uintptr() or callback == 0.uintptr():
            panic("expected synthetic boundary callback addresses")
        status: s32 = GuestExec_RunMainEntryGuarded(entry, 88, callback.cast[void&?], 100.u32())
        if status != 1:
            panic("expected guarded boundary callback success")
        if GuestExec_BoundaryCallbackCount() != 1:
            panic("expected guest-to-host boundary callback")
        if GuestExec_BoundaryCallbackReason() != 0xB000000000000042.u64():
            panic("expected boundary callback reason")

@test
def emulator_guest_exec_guarded_fork_reports_first_boundary_to_parent() -> void:
    can Abort.Panic:
        if not GuestExec_IsSupported():
            return
        GuestExec_ResetState()
        GuestExec_Enable(true)
        entry: VAddr = GuestExec_GetNonSyntheticMainReportBoundaryAddress()
        if entry == 0.uintptr():
            panic("expected non-synthetic report-boundary entry")
        status: s32 = GuestExec_RunMainEntryGuarded(entry, 89, null, 100.u32())
        if status != -11:
            panic("expected guarded fork boundary entry to exit through guard")
        if not GuestExec_HasReachedFirstBoundary():
            panic("expected fork child boundary report to reach parent")
        if GuestExec_FirstBoundaryReason() != GUEST_EXEC_BOUNDARY_REASON_NATIVE_HLE:
            panic("expected native HLE boundary reason from fork child")
        if GuestExec_ExpectedEntryParams() == 0.uintptr():
            panic("expected fork child entry params pointer to reach parent")
        if GuestExec_ExpectedStackWord0() != 89.uintptr():
            panic("expected fork child argc stack word to reach parent")
        if GuestExec_EntryStackWord0() != GuestExec_ExpectedStackWord0():
            panic("expected fork child entry stack snapshot to reach parent")
        if GuestExec_PreJumpRDI() != GuestExec_ExpectedEntryParams():
            panic("expected fork child pre-jump rdi to reach parent")
        if GuestExec_PreJumpRSP() == 0.uintptr():
            panic("expected fork child pre-jump rsp to reach parent")

