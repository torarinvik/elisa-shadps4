include "../common/types.elisa"
include "../core/guest_exec.elisa"

def guest_exec_test_posix_mutex_lock_shape(mutex: mutable void&?&?) -> int:
    slot: mutable uintptr = 0.uintptr()
    reason: mutable uintptr = 0.uintptr()
    if mutex != null:
        slot <- mutex.cast[void&].uintptr()
        if slot != 0.uintptr() and slot < 4096.uintptr():
            reason <- 3.uintptr()
    GuestExec_RecordRuntimeHle("libkernel", "posix_pthread_mutex_lock", slot, 0.uintptr(), reason, 22.uintptr())
    return 22

@test
def emulator_guest_exec_entry_params_abi_matches_native_layout() -> void:
    can Abort.Panic:
        if GuestExec_EntryParamsArgcOffset() != 0.u64():
            panic("expected EntryParams argc offset")
        if GuestExec_EntryParamsArgvOffset() != 8.u64():
            panic("expected EntryParams argv offset")
        if GuestExec_EntryParamsEntryAddrOffset() != 272.u64():
            panic("expected EntryParams entry_addr offset")
        if GuestExec_EntryParamsSize() != 280.u64():
            panic("expected EntryParams size")

        params: mutable GuestEntryParams = zeroed
        params.argc <- 77.s32()
        params.padding <- 0xA5A5A5A5.u32()
        params.argv[0] <- 0x12345678.uintptr().cast[static u8&?]
        params.entry_addr <- 0x8877665544332211.uintptr()

        probe: u64 = GuestExec_ProbeEntryParams(params.ref[mutable GuestEntryParams&])
        expected: u64 = 0xE100000000000000.u64() | 77.u64() | (1.u64() << 16) | (1.u64() << 17) | (1.u64() << 18)
        if probe != expected:
            panic("expected native ABI probe to observe Elisa-filled EntryParams")

@test
def emulator_guest_exec_synthetic_function_executes_and_returns() -> void:
    can Abort.Panic:
        if not GuestExec_IsSupported():
            return
        entry: VAddr = GuestExec_GetSyntheticAddAddress()
        if entry == 0.uintptr():
            panic("expected synthetic function address")
        result: u64 = GuestExec_RunSyntheticFunction(entry, 40.u64(), 2.u64())
        if result != 0x125E.u64():
            panic("expected synthetic function result")

@test
def emulator_guest_exec_synthetic_mapped_trampoline_executes_and_returns() -> void:
    can Abort.Panic:
        GuestExec_ResetState()
        if not GuestExec_IsSupported():
            if not GuestExec_IsProbeOnly():
                panic("expected unsupported host to report probe-only mode")
            if GuestExec_SupportedNativeExecution():
                panic("expected unsupported host native execution to be false")
            return
        GuestExec_Enable(true)
        mapped_entry: VAddr = GuestExec_AllocateRegion(4096.u64(), 3.u32())
        if mapped_entry == 0.uintptr():
            panic("expected executable test page allocation")
        code: mutable u8[6] = [0xB8u8, 0x2Au8, 0x00u8, 0x00u8, 0x00u8, 0xC3u8]
        if not GuestExec_WriteBytes(mapped_entry, code[0].ref[void&], 6.u64()):
            panic("expected machine code write")
        if not GuestExec_ProtectRegion(mapped_entry, 4096.u64(), 5.u32()):
            panic("expected executable protection")
        result: u64 = GuestExec_RunSyntheticFunction(mapped_entry, 0.u64(), 0.u64())
        if result != 42.u64():
            panic("expected mapped trampoline to return 42")
        if GuestExec_LastStatus() != 1:
            panic("expected successful trampoline status")
        if not GuestExec_UnmapRegion(mapped_entry, 4096.u64()):
            panic("expected executable test page unmap")

@test
def emulator_guest_exec_publish_executable_code_requires_exec_mapping() -> void:
    can Abort.Panic:
        GuestExec_ResetState()
        if not GuestExec_IsSupported():
            return
        GuestExec_Enable(true)
        mapped_entry: VAddr = GuestExec_AllocateRegion(4096.u64(), 3.u32())
        if mapped_entry == 0.uintptr():
            panic("expected publish test page allocation")
        code: mutable u8[6] = [0xB8u8, 0x07u8, 0x00u8, 0x00u8, 0x00u8, 0xC3u8]
        if not GuestExec_WriteBytes(mapped_entry, code[0].ref[void&], 6.u64()):
            panic("expected publish test write")
        GuestExec_SetDebugTrapOnUnpublishedExec(true)
        unpublished_result: u64 = GuestExec_RunSyntheticFunction(mapped_entry, 0.u64(), 0.u64())
        if unpublished_result != 0xFFFFFFFFFFFFFFFB.u64():
            panic("expected debug referee to stop unpublished executable entry")
        if GuestExec_DebugTrapReason() != GE_DEBUG_TRAP_UNPUBLISHED_EXEC_STATUS.u64():
            panic("expected unpublished executable debug trap reason")
        if GuestExec_DebugTrapValue() != mapped_entry:
            panic("expected unpublished executable debug trap value")
        GuestExec_SetDebugTrapOnUnpublishedExec(false)
        trusted Unsafe.ExecutableCodePublish:
            if GuestExec_PublishExecutableCode(mapped_entry, 1.u64()):
                panic("expected publish to reject non-executable mapping")
        if GuestExec_PublishExecutableRejectCount() != 1.u64():
            panic("expected publish reject counter")
        if GuestExec_PublishExecutableLastResult() != -2:
            panic("expected non-executable publish reject result")
        if not GuestExec_ProtectRegion(mapped_entry, 4096.u64(), 5.u32()):
            panic("expected publish test executable protection")
        trusted Unsafe.ExecutableCodePublish:
            if not GuestExec_PublishExecutableCode(mapped_entry, 6.u64()):
                panic("expected executable publish to succeed")
        if GuestExec_PublishExecutableCount() != 1.u64():
            panic("expected publish counter")
        if GuestExec_PublishedExecutableCount() != 1.u32():
            panic("expected published executable ledger count")
        if not GuestExec_IsExecutableCodePublished(mapped_entry, 6.u64()):
            panic("expected published executable ledger lookup")
        GuestExec_SetDebugTrapOnUnpublishedExec(true)
        published_result: u64 = GuestExec_RunSyntheticFunction(mapped_entry, 0.u64(), 0.u64())
        if published_result != 7.u64():
            panic("expected published executable entry to run under debug referee")
        GuestExec_SetDebugTrapOnUnpublishedExec(false)
        if GuestExec_PublishExecutableLastAddr() != mapped_entry:
            panic("expected publish last address")
        if GuestExec_PublishExecutableLastSize() != 6.u64():
            panic("expected publish last size")
        if (GuestExec_PublishExecutableLastProt() & 4.u32()) == 0.u32():
            panic("expected publish last prot to be executable")
        if GuestExec_PublishExecutableLastResult() != 0:
            panic("expected publish success result")
        if not GuestExec_UnmapRegion(mapped_entry, 4096.u64()):
            panic("expected publish test page unmap")

@test
def emulator_guest_exec_debug_callable_guard_records_bad_targets() -> void:
    can Abort.Panic:
        GuestExec_ResetState()
        GuestExec_SetDebugTrapOnCallableGuard(true)
        if GuestExec_DebugGuardCallableTarget(GE_BOUNDARY_POISON_WORD.uintptr(), 11u64):
            panic("expected callable guard to reject poison target")
        if GuestExec_DebugTrapReason() != GE_BOUNDARY_GUARD_POISON:
            panic("expected callable guard poison reason")
        if GuestExec_DebugTrapValue().u64() != GE_BOUNDARY_POISON_WORD:
            panic("expected callable guard poison value")
        if GuestExec_DebugTrapSequence() != 11u64:
            panic("expected callable guard poison sequence")

        GuestExec_ResetState()
        GuestExec_SetDebugTrapOnCallableGuard(true)
        if GuestExec_DebugGuardCallableTarget(0xDEAD0000DEAD0000u64.uintptr(), 12u64):
            panic("expected callable guard to reject non-canonical target")
        if GuestExec_DebugTrapReason() != GE_BOUNDARY_GUARD_NON_CANONICAL:
            panic("expected callable guard non-canonical reason")
        if GuestExec_DebugTrapValue().u64() != 0xDEAD0000DEAD0000u64:
            panic("expected callable guard non-canonical value")

        GuestExec_ResetState()
        GuestExec_SetDebugTrapOnCallableGuard(true)
        if GuestExec_DebugGuardCallableTarget(0x1F4.uintptr(), 13u64):
            panic("expected callable guard to reject tiny target")
        if GuestExec_DebugTrapReason() != GE_BOUNDARY_GUARD_NEAR_NULL_UNMAPPED:
            panic("expected callable guard tiny unmapped reason")
        if GuestExec_DebugTrapValue() != 0x1F4.uintptr():
            panic("expected callable guard tiny value")

@test
def emulator_guest_exec_debug_guest_pointer_guard_rejects_unmapped_pointer_args() -> void:
    can Abort.Panic:
        GuestExec_ResetState()
        GuestExec_SetDebugTrapOnBoundaryGuard(true)
        if GuestExec_DebugGuardGuestPointer(0x100000.uintptr().cast[GuestVAddr[void]], 17u64):
            panic("expected guest pointer guard to reject unmapped pointer")
        if GuestExec_LastStatus() != GE_DEBUG_TRAP_BOUNDARY_GUARD_STATUS:
            panic("expected guest pointer guard trap status")
        if GuestExec_DebugTrapReason() != GE_BOUNDARY_GUARD_UNMAPPED_POINTER:
            panic("expected unmapped pointer guard reason")
        if GuestExec_DebugTrapValue() != 0x100000.uintptr():
            panic("expected unmapped pointer guard value")
        if GuestExec_DebugTrapSequence() != 17u64:
            panic("expected unmapped pointer guard sequence")

        GuestExec_ResetState()
        GuestExec_SetDebugTrapOnBoundaryGuard(true)
        if not GuestExec_IsSupported():
            return
        mapped: VAddr = GuestExec_AllocateRegion(4096.u64(), 3.u32())
        if mapped == 0.uintptr():
            panic("expected mapped pointer test page")
        if not GuestExec_DebugGuardGuestPointer(mapped.cast[GuestVAddr[void]], 18u64):
            panic("expected mapped guest pointer to pass")
        if GuestExec_DebugTrapCount() != 0u64:
            panic("expected no debug trap for mapped guest pointer")
        if not GuestExec_UnmapRegion(mapped, 4096.u64()):
            panic("expected mapped pointer test page unmap")

