@test
def emulator_guest_exec_guarded_main_uses_guest_trampoline_abi() -> void:
    can Abort.Panic:
        if not GuestExec_IsSupported():
            return
        GuestExec_ResetState()
        entry: VAddr = GuestExec_GetSyntheticMainReturnAddress()
        if entry == 0.uintptr():
            panic("expected synthetic main-return address")
        sentinel_argv: VAddr = 0x12345678.uintptr()
        status: s32 = GuestExec_RunMainEntryGuarded(entry, 77, sentinel_argv.cast[void&?], 100.u32())
        if status != 1:
            panic("expected guarded main-return success")
        if GuestExec_LastStatus() != 1:
            panic("expected native guarded main-return status")
        if GuestExec_SyntheticObservedArgc() != 77:
            panic("expected guest trampoline to pass argc")
        if GuestExec_SyntheticObservedArgv0() != sentinel_argv:
            panic("expected guest trampoline to pass argv")
        if GuestExec_SyntheticObservedEntry() != entry:
            panic("expected guest trampoline to preserve entry")
        if GuestExec_SyntheticObservedParams() == 0.uintptr():
            panic("expected guest trampoline params pointer")
        if GuestExec_SyntheticObservedExitFunc() == 0.uintptr():
            panic("expected guest trampoline exit callback")
        if GuestExec_SyntheticObservedStack() == 0.uintptr():
            panic("expected guest trampoline stack capture")
        stack_mod: u64 = GuestExec_SyntheticObservedStackMod16()
        if stack_mod != 0.u64() and stack_mod != 8.u64():
            panic("expected guest trampoline stack to be ABI-aligned")
        if GuestExec_ClassifyFirstBoundary() != GUEST_EXEC_BOUNDARY_EXITED_BEFORE_BOUNDARY:
            panic("expected return-before-boundary classification")
        if GuestExec_FirstBoundaryReason() != GUEST_EXEC_BOUNDARY_REASON_EXITED_BEFORE_BOUNDARY:
            panic("expected return-before-boundary reason")

@test
def emulator_guest_exec_guarded_main_can_call_host_boundary_callback() -> void:
    can Abort.Panic:
