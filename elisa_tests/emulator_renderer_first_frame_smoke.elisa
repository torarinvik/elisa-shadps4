include "../../compiler/runtime/elisacore_std/elisacore_runtime.elisa"
include "../core/libraries/videoout/videoout.elisa"
include "../core/libraries/videoout/videoout_error.elisa"
include "../shader_recompiler/recompiler_backend.elisa"

def renderer_first_frame_reset() -> void:
    _ = sceVideoOutClose(1)
    videoout_reset_port_state()
    ShaderRecompiler_ResetArtifactState()

def renderer_first_frame_expect_real_spirv_status(program: mutable void&?, payload_kind: u32) -> void:
    can Abort.Panic:
        real_status: u32 = elisa_shader_recompiler_program_real_spirv_status(program)
        if payload_kind == ELISA_RECOMPILER_PAYLOAD_KIND_REAL_SPIRV:
            assert real_status == ELISA_RECOMPILER_REAL_SPIRV_SUCCEEDED
        else:
            assert real_status == ELISA_RECOMPILER_REAL_SPIRV_NOT_REQUESTED or real_status == ELISA_RECOMPILER_REAL_SPIRV_FAILED or real_status == ELISA_RECOMPILER_REAL_SPIRV_UNAVAILABLE

@test
def emulator_renderer_first_frame_synthetic_ladder_smoke() -> void:
    can Abort.Panic:
        renderer_first_frame_reset()

        shader_words: mutable u32[8] = [
            0xbeeb03ff,
            0x00000003,
            0x7e000280,
            0x5e000100,
            0xbf800000,
            0xf8001c0f,
            0x00000000,
            0xbf810000
        ]
        metadata: mutable ShaderRecompilerTranslateMetadata = ShaderRecompilerTranslateMetadata(
            ELISA_RECOMPILER_STAGE_FRAGMENT.u32(),
            ELISA_RECOMPILER_LOGICAL_STAGE_FRAGMENT.u32()
        )
        program: mutable void&? = null
        shader_rc: int = ShaderRecompiler_TranslateProgramViaFfi(
            shader_words[0],
            8,
            metadata,
            program
        )
        assert shader_rc == ELISA_RECOMPILER_BRIDGE_OK
        assert program != null
        assert g_shader_artifact_translate_attempted_emitted
        assert g_shader_artifact_path_bridge_emitted
        assert g_shader_artifact_result_ok_emitted
        assert g_shader_artifact_status_emitted
        status: int = elisa_shader_recompiler_program_status(program)
        if status == ELISA_RECOMPILER_PROGRAM_STATUS_TRANSLATED:
            assert g_shader_artifact_output_nonzero_emitted
            assert g_shader_artifact_spirv_magic_emitted
            assert g_shader_artifact_payload_kind_emitted
            assert g_shader_artifact_real_spirv_status_emitted
            assert elisa_shader_recompiler_program_output_byte_size(program) > 0
            assert elisa_shader_recompiler_program_output_word_count(program) > 4
            assert elisa_shader_recompiler_program_output_word_at(program, 0) == ELISA_SPIRV_MAGIC
            payload_kind: u32 = elisa_shader_recompiler_program_payload_kind(program)
            assert payload_kind == ELISA_RECOMPILER_PAYLOAD_KIND_SPIRV_ENVELOPE or payload_kind == ELISA_RECOMPILER_PAYLOAD_KIND_REAL_SPIRV
            renderer_first_frame_expect_real_spirv_status(program, payload_kind)
            assert elisa_shader_recompiler_program_output_hash(program) != 0
            assert elisa_shader_recompiler_program_diagnostic_code(program) == ELISA_RECOMPILER_DIAGNOSTIC_NONE
        else:
            assert status == ELISA_RECOMPILER_PROGRAM_STATUS_FAILED_WITH_DIAGNOSTIC
            assert not g_shader_artifact_output_nonzero_emitted
            assert not g_shader_artifact_spirv_magic_emitted
            assert g_shader_artifact_payload_kind_emitted
            assert g_shader_artifact_real_spirv_status_emitted
            assert elisa_shader_recompiler_program_output_byte_size(program) == 0
            assert elisa_shader_recompiler_program_output_word_count(program) == 0
            assert elisa_shader_recompiler_program_output_word_at(program, 0) == 0
            assert elisa_shader_recompiler_program_payload_kind(program) == ELISA_RECOMPILER_PAYLOAD_KIND_NONE
            assert elisa_shader_recompiler_program_real_spirv_status(program) == ELISA_RECOMPILER_REAL_SPIRV_NOT_REQUESTED
            assert elisa_shader_recompiler_program_output_hash(program) == 0
            diag: int = elisa_shader_recompiler_program_diagnostic_code(program)
            assert diag == ELISA_RECOMPILER_DIAGNOSTIC_UNSUPPORTED or diag == ELISA_RECOMPILER_DIAGNOSTIC_REAL_LINK_NOT_AVAILABLE
        ShaderRecompiler_FreeProgramViaFfi(program)
        assert elisa_shader_recompiler_program_status(program) == ELISA_RECOMPILER_PROGRAM_STATUS_FREED

        handle: int = sceVideoOutOpen(0, 0, 0, null)
        assert handle == 1
        assert g_videoout_artifact_opened_emitted
        assert not g_videoout_artifact_buffers_registered_emitted
        assert not g_videoout_artifact_first_flip_emitted
        assert not g_videoout_artifact_flip_completed_emitted
        assert not g_videoout_artifact_first_frame_candidate_emitted

        attr: mutable VideoOutBufferAttribute = zeroed
        sceVideoOutSetBufferAttribute((&attr).cast[void&?], 0x80000000, 0, 0, 64, 64, 64)

        frame_buffer: mutable array[u8, 256] = zeroed
        addresses: mutable array[u64, 1] = zeroed
        addresses[0] <- (&frame_buffer[0]).cast[void&].uintptr().u64()

        group_index: int = sceVideoOutRegisterBuffers(
            handle.i64(),
            0,
            (&addresses[0]).cast[void&?],
            1,
            (&attr).cast[void&?]
        )
        assert group_index == 0
        assert g_videoout_artifact_buffers_registered_emitted
        assert not g_videoout_artifact_first_flip_emitted
        assert not g_videoout_artifact_flip_completed_emitted
        assert not g_videoout_artifact_first_frame_candidate_emitted

        assert sceVideoOutSubmitFlip(handle.i64(), 0, 1, 0x1234) == ORBIS_OK
        assert g_videoout_artifact_first_flip_emitted
        assert sceVideoOutIsFlipPending(handle.i64()) >= 1
        assert not g_videoout_artifact_flip_completed_emitted
        assert not g_videoout_artifact_first_frame_candidate_emitted

        assert sceVideoOutWaitVblank(handle.i64()) == ORBIS_OK
        assert g_videoout_artifact_flip_completed_emitted
        assert g_videoout_artifact_first_frame_candidate_emitted
        assert sceVideoOutIsFlipPending(handle.i64()) == 0

        flip_status: mutable FlipStatus = zeroed
        assert sceVideoOutGetFlipStatus(handle.i64(), (&flip_status).cast[void&?]) == ORBIS_OK
        assert flip_status.count >= 1
        assert flip_status.current_buffer == 0

        vblank_status: mutable SceVideoOutVblankStatus = zeroed
        assert sceVideoOutGetVblankStatus(handle.i64(), (&vblank_status).cast[void&?]) == ORBIS_OK
        assert vblank_status.count >= 1

        label_addr: mutable i64 = 0
        assert sceVideoOutGetBufferLabelAddress(handle.i64(), (&label_addr).cast[void&?]) == 16
        assert label_addr != 0
        labels: mutable u64& = label_addr.cast[mutable u64&]
        assert labels[0] == 1

        assert sceVideoOutSubmitFlip(handle.i64(), 0, 1, 0x1235) == ORBIS_OK
        assert sceVideoOutWaitVblank(handle.i64()) == ORBIS_OK
        assert g_videoout_artifact_first_flip_emitted
        assert g_videoout_artifact_flip_completed_emitted
        assert g_videoout_artifact_first_frame_candidate_emitted
        assert sceVideoOutIsFlipPending(handle.i64()) == 0
        assert labels[0] == 1

        assert sceVideoOutClose(handle.i64()) == ORBIS_OK
