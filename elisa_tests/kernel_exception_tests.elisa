include "../core/libraries/kernel/threads/exception.elisa"
include "../../compiler/runtime/elisacore_std/elisacore_runtime.elisa"

@test
def signal_and_flag_constants() -> void:
    can Abort.Panic:
        assert POSIX_SIGKILL == 9i32
        assert POSIX_SIGSYS == 12i32
        assert POSIX_SA_SIGINFO == 4i32
        # (i32)0x80000000 == -2147483648
        assert POSIX_SA_RESETHAND == ~0x7fffffffi32

@test
def mcontext_round_trip() -> void:
    can Abort.Panic:
        mc: mutable Mcontext = zeroed
        mc.mc_rax <- 0x1122334455667788u64
        mc.mc_rdi <- 42u64
        mc.mc_trapno <- 13i32
        mc.mc_fs <- 7u16
        assert mc.mc_rax == 0x1122334455667788u64
        assert mc.mc_rdi == 42u64
        assert mc.mc_trapno == 13i32
        assert mc.mc_fs == 7u16
        assert mc.mc_rbx == 0u64

@test
def exception_handler_stack_round_trip() -> void:
    can Abort.Panic:
        st: mutable OrbisKernelExceptionHandlerStack = zeroed
        st.ss_sp <- 0xdeadbeefu64
        st.ss_flags <- 1i32
        st.ss_size <- 4096usize
        assert st.ss_sp == 0xdeadbeefu64
        assert st.ss_flags == 1i32
        assert st.ss_size == 4096usize
