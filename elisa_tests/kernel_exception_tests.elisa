include "../core/libraries/kernel/threads/exception.elisa"
include "../../compiler/runtime/elisacore_std/elisacore_runtime.elisa"

@test
def signal_and_flag_constants() -> void:
    can Abort.Panic:
        assert POSIX_SIGKILL == 9
        assert POSIX_SIGSYS == 12
        assert POSIX_SA_SIGINFO == 4
        # (i32)0x80000000 == -2147483648
        assert POSIX_SA_RESETHAND == ~0x7fffffff

@test
def mcontext_round_trip() -> void:
    can Abort.Panic:
        mc: mutable Mcontext = zeroed
        mc.mc_rax <- 0x1122334455667788
        mc.mc_rdi <- 42
        mc.mc_trapno <- 13
        mc.mc_fs <- 7
        assert mc.mc_rax == 0x1122334455667788
        assert mc.mc_rdi == 42
        assert mc.mc_trapno == 13
        assert mc.mc_fs == 7
        assert mc.mc_rbx == 0

@test
def exception_handler_stack_round_trip() -> void:
    can Abort.Panic:
        st: mutable OrbisKernelExceptionHandlerStack = zeroed
        st.ss_sp <- 0xdeadbeef
        st.ss_flags <- 1
        st.ss_size <- 4096
        assert st.ss_sp == 0xdeadbeef
        assert st.ss_flags == 1
        assert st.ss_size == 4096
