include "../shader_recompiler/profile.elisa"
include "../../compiler/runtime/elisacore_std/elisacore_runtime.elisa"

@test
def profile_default_spirv_and_zeroed() -> void:
    can Abort.Panic:
        p: Profile = Profile_Default()
        assert p.supported_spirv == 0x00010000u32
        assert p.max_ubo_size == 0u64
        assert p.subgroup_size == 0u32
        assert p.support_int64 == false
        assert p.needs_clip_distance_emulation == false

@test
def profile_fields_roundtrip() -> void:
    can Abort.Panic:
        p: mutable Profile = Profile_Default()
        p.max_ubo_size <- 65536u64
        p.subgroup_size <- 64u32
        p.support_float16 <- true
        p.needs_lds_barriers <- true
        assert p.max_ubo_size == 65536u64
        assert p.subgroup_size == 64u32
        assert p.support_float16 == true
        assert p.needs_lds_barriers == true
        assert p.support_float64 == false
