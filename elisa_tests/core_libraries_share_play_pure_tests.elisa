include "../../compiler/runtime/elisacore_std/elisacore_runtime.elisa"
include "../core/libraries/share_play/share_play.elisa"

@test
def share_play_stub_contracts() -> void:
    can Abort.Panic:
        assert sceSharePlayCrashDaemon() == ORBIS_OK

        info: mutable OrbisSharePlayConnectionInfo = zeroed
        info.status <- ORBIS_SHARE_PLAY_CONNECTION_STATUS_CONNECTED
        info.mode <- 1234
        info.host_online_id.data[0] <- 77.u8()
        info.visitor_online_id.data[0] <- 55.u8()
        info.host_user_id <- 42
        info.visitor_user_id <- 43

        assert sceSharePlayGetCurrentConnectionInfo(info.ref[mutable OrbisSharePlayConnectionInfo&]) == ORBIS_OK
        assert info.status == ORBIS_SHARE_PLAY_CONNECTION_STATUS_DORMANT
        assert info.mode == 0
        assert info.host_online_id.data[0] == 0.u8()
        assert info.visitor_online_id.data[0] == 0.u8()
        assert info.host_user_id == 0
        assert info.visitor_user_id == 0

        assert sceSharePlayGetCurrentConnectionInfoA() == ORBIS_OK
        assert sceSharePlayGetCurrentInfo() == ORBIS_OK
        assert sceSharePlayGetEvent() == ORBIS_OK
        assert sceSharePlayInitialize() == ORBIS_OK
        assert sceSharePlayNotifyDialogOpen() == ORBIS_OK
        assert sceSharePlayNotifyForceCloseForCdlg() == ORBIS_OK
        assert sceSharePlayNotifyOpenQuickMenu() == ORBIS_OK
        assert sceSharePlayResumeScreenForCdlg() == ORBIS_OK
        assert sceSharePlayServerLock() == ORBIS_OK
        assert sceSharePlayServerUnLock() == ORBIS_OK
        assert sceSharePlaySetMode() == ORBIS_OK
        assert sceSharePlaySetProhibition() == ORBIS_OK
        assert sceSharePlaySetProhibitionModeWithAppId() == ORBIS_OK
        assert sceSharePlayStartStandby() == ORBIS_OK
        assert sceSharePlayStartStreaming() == ORBIS_OK
        assert sceSharePlayStopStandby() == ORBIS_OK
        assert sceSharePlayStopStreaming() == ORBIS_OK
        assert sceSharePlayTerminate() == ORBIS_OK
        assert Func_2E93C0EA6A6B67C4() == ORBIS_OK
        assert Func_C1C236728D88E177() == ORBIS_OK
        assert Func_E9E80C474781F115() == ORBIS_OK
        assert Func_F3DD6199DA15ED44() == ORBIS_OK
