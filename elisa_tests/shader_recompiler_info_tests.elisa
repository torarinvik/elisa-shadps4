include "../shader_recompiler/info.elisa"
include "../../compiler/runtime/elisacore_std/elisacore_runtime.elisa"

@test
def info_countr_zero() -> void:
    can Abort.Panic:
        assert ShaderCountrZero32(1u32) == 0u32
        assert ShaderCountrZero32(2u32) == 1u32
        assert ShaderCountrZero32(8u32) == 3u32
        assert ShaderCountrZero32(0x80000000u32) == 31u32
        assert ShaderCountrZero32(0u32) == 32u32

@test
def info_add_bindings() -> void:
    can Abort.Panic:
        info: mutable Info = zeroed
        info.persistent <- InfoPersistent_New(
            SHADER_STAGE_VERTEX, SHADER_LOGICAL_STAGE_VERTEX, 7u64)
        owner: mutable Arena& = scratch_arena.ref[mutable Arena&]
        in owner:
            buf: mutable BufferResource = zeroed
            info.persistent.buffers.push(buf)
            info.persistent.buffers.push(buf)
            img: mutable ImageResource = zeroed
            info.persistent.images.push(img)
        UserDataMask_Set(info.persistent.ud_mask.ref[mutable UserDataMask&], 0u32)
        UserDataMask_Set(info.persistent.ud_mask.ref[mutable UserDataMask&], 3u32)
        bnd: mutable ShaderBackendBindings = ShaderBackendBindings_Default()
        Info_AddBindings(info.ref[Info&], bnd.ref[mutable ShaderBackendBindings&])
        # buffer += 2 buffers
        assert bnd.buffer == 2u32
        # unified += buffers(2) + images(1) + samplers(0)
        assert bnd.unified == 3u32
        # user_data += ud_mask.NumRegs() == 2
        assert bnd.user_data == 2u32

@test
def info_push_ud() -> void:
    can Abort.Panic:
        info: mutable Info = zeroed
        owner: mutable Arena& = scratch_arena.ref[mutable Arena&]
        in owner:
            info.user_data.push(100u32)  # reg 0
            info.user_data.push(101u32)  # reg 1
            info.user_data.push(102u32)  # reg 2
            info.user_data.push(103u32)  # reg 3
        # Reference registers 1 and 3.
        UserDataMask_Set(info.persistent.ud_mask.ref[mutable UserDataMask&], 1u32)
        UserDataMask_Set(info.persistent.ud_mask.ref[mutable UserDataMask&], 3u32)
        bnd: mutable ShaderBackendBindings = ShaderBackendBindings_Default()
        push: mutable PushData = zeroed
        Info_PushUd(info.ref[Info&], bnd.ref[mutable ShaderBackendBindings&],
                    push.ref[mutable PushData&])
        # Lowest set bit first: reg 1 -> slot 0, reg 3 -> slot 1.
        assert push.ud_regs[0usize] == 101u32
        assert push.ud_regs[1usize] == 103u32
        assert bnd.user_data == 2u32

@test
def info_gs_copy_data() -> void:
    can Abort.Panic:
        # The gs_copy_data field embeds CopyShaderData (folded in after
        # de-duplicating the IR_ATTRIBUTE_* constants).
        info: mutable Info = zeroed
        info.gs_copy_data <- CopyShaderData_Default()
        assert info.gs_copy_data.num_attrs == 0u32
        assert info.gs_copy_data.attr_map_count == 0u32
        assert info.gs_copy_data.output_vertices == 0u32
        info.gs_copy_data.num_attrs <- 4u32
        assert info.gs_copy_data.num_attrs == 4u32
