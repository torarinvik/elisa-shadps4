include "../core/libraries/videodec/videodec2.elisa"
include "../../compiler/runtime/elisacore_std/elisacore_runtime.elisa"

@test
def videodec2_structs_roundtrip() -> void:
    can Abort.Panic:
        cfg: mutable OrbisVideodec2DecoderConfigInfo = zeroed
        cfg.thisSize <- 0x48u64
        cfg.maxFrameWidth <- 1920i32
        cfg.optimizeProgressiveVideo <- true
        assert cfg.thisSize == 0x48u64
        assert cfg.maxFrameWidth == 1920i32
        assert cfg.optimizeProgressiveVideo == true
        assert cfg.maxFrameHeight == 0i32

        mem: mutable OrbisVideodec2DecoderMemoryInfo = zeroed
        mem.cpuMemorySize <- 4096u64
        mem.frameBufferAlignment <- 256u32
        assert mem.cpuMemorySize == 4096u64
        assert mem.frameBufferAlignment == 256u32

        inp: mutable OrbisVideodec2InputData = zeroed
        inp.auSize <- 1024u64
        assert inp.auSize == 1024u64

        out: mutable OrbisVideodec2OutputInfo = zeroed
        out.isValid <- true
        out.pictureCount <- 2u8
        out.frameWidth <- 1280u32
        assert out.isValid == true
        assert out.pictureCount == 2u8
        assert out.frameWidth == 1280u32

        fb: mutable OrbisVideodec2FrameBuffer = zeroed
        fb.frameBufferSize <- 8192u64
        fb.isAccepted <- true
        assert fb.frameBufferSize == 8192u64
        assert fb.isAccepted == true

        cmem: mutable OrbisVideodec2ComputeMemoryInfo = zeroed
        cmem.cpuGpuMemorySize <- 512u64
        assert cmem.cpuGpuMemorySize == 512u64

        ccfg: mutable OrbisVideodec2ComputeConfigInfo = zeroed
        ccfg.computePipeId <- 3u16
        ccfg.computeQueueId <- 5u16
        ccfg.checkMemoryType <- true
        assert ccfg.computePipeId == 3u16
        assert ccfg.computeQueueId == 5u16
        assert ccfg.checkMemoryType == true
