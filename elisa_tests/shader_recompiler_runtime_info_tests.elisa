include "../shader_recompiler/runtime_info.elisa"
include "../../compiler/runtime/elisacore_std/elisacore_runtime.elisa"

@test
def runtime_info_stage_enums() -> void:
    can Abort.Panic:
        assert SHADER_STAGE_FRAGMENT == 0u32
        assert SHADER_STAGE_COMPUTE == 6u32
        assert ShaderStageFromIndex(4u32) == SHADER_STAGE_HULL
        assert SHADER_LOGICAL_STAGE_NUM == 6u32
        assert SHADER_MAX_STAGE_TYPES == SHADER_LOGICAL_STAGE_NUM

@test
def runtime_info_output_and_swizzle() -> void:
    can Abort.Panic:
        # Output cull/clip ranges are contiguous 8-wide blocks.
        assert SHADER_OUTPUT_CULL_DIST7 == SHADER_OUTPUT_CULL_DIST0 + 7u32
        assert SHADER_OUTPUT_CLIP_DIST0 == SHADER_OUTPUT_CULL_DIST7 + 1u32
        assert SHADER_OUTPUT_CLIP_DIST7 == SHADER_OUTPUT_CLIP_DIST0 + 7u32
        assert SHADER_MRT_SWIZZLE_REVERSE_ALT == 3u32
        assert SHADER_MAX_COLOR_BUFFERS == 8u32
