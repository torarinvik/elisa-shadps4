include "../video_core/multi_level_page_table.elisa"

@test
def multi_level_page_table_lazily_creates_entries() -> void:
    can Abort.Panic, Memory.Allocate:
        arena: Arena = zeroed
        in arena:
            table: mutable MultiLevelPageTableU64 = MultiLevelPageTableU64_New(20, 4, 12)
            if MultiLevelPageTableU64_Find(table, 3) != VIDEO_CORE_MLPT_INVALID_ENTRY:
                panic("expected missing page lookup")
            if not MultiLevelPageTableU64_Set(table, 3, 0xCAFE.u64()):
                panic("expected page set")
            if MultiLevelPageTableU64_Find(table, 3) != 0xCAFE.u64():
                panic("expected stored page value")
            if table.allocated_pages != 1:
                panic("expected one allocated page")
            if MultiLevelPageTableU64_L1Index(table, 3) != 0:
                panic("expected l1 index")
            if MultiLevelPageTableU64_L2Index(table, 3) != 3:
                panic("expected l2 index")

@test
def multi_level_page_table_rejects_out_of_range_pages() -> void:
    can Abort.Panic, Memory.Allocate:
        arena: Arena = zeroed
        in arena:
            table: mutable MultiLevelPageTableU64 = MultiLevelPageTableU64_New(16, 4, 12)
            if MultiLevelPageTableU64_Set(table, 16, 0xFF.u64()):
                panic("expected out of range page rejection")
            if MultiLevelPageTableU64_GetOrCreate(table, 16) != VIDEO_CORE_MLPT_INVALID_ENTRY:
                panic("expected out of range get rejection")
