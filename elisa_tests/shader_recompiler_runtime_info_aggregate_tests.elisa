include "../shader_recompiler/runtime_info_aggregate.elisa"
include "../../compiler/runtime/elisacore_std/elisacore_runtime.elisa"

@test
def runtime_info_initialize() -> void:
    can Abort.Panic:
        ri: mutable RuntimeInfo = zeroed
        ri.num_user_data <- 99u32
        ri.cs_info.shared_memory_size <- 1234u32
        RuntimeInfo_Initialize(ri.ref[mutable RuntimeInfo&], SHADER_STAGE_COMPUTE)
        assert ri.stage == SHADER_STAGE_COMPUTE
        # Everything else is reset to zero.
        assert ri.num_user_data == 0u32
        assert ri.cs_info.shared_memory_size == 0u32

@test
def runtime_info_stage_dispatched_equality() -> void:
    can Abort.Panic:
        a: mutable RuntimeInfo = zeroed
        b: mutable RuntimeInfo = zeroed
        RuntimeInfo_Initialize(a.ref[mutable RuntimeInfo&], SHADER_STAGE_COMPUTE)
        RuntimeInfo_Initialize(b.ref[mutable RuntimeInfo&], SHADER_STAGE_COMPUTE)
        a.cs_info.workgroup_size[0usize] <- 8u32
        b.cs_info.workgroup_size[0usize] <- 8u32
        # shared_memory_size is ignored by ComputeRuntimeInfo equality.
        a.cs_info.shared_memory_size <- 100u32
        b.cs_info.shared_memory_size <- 200u32
        assert RuntimeInfo_Equal(a.ref[RuntimeInfo&], b.ref[RuntimeInfo&]) == true
        b.cs_info.workgroup_size[0usize] <- 16u32
        assert RuntimeInfo_Equal(a.ref[RuntimeInfo&], b.ref[RuntimeInfo&]) == false

@test
def runtime_info_hull_equality_and_tess() -> void:
    can Abort.Panic:
        a: mutable RuntimeInfo = zeroed
        b: mutable RuntimeInfo = zeroed
        RuntimeInfo_Initialize(a.ref[mutable RuntimeInfo&], SHADER_STAGE_HULL)
        RuntimeInfo_Initialize(b.ref[mutable RuntimeInfo&], SHADER_STAGE_HULL)
        assert RuntimeInfo_Equal(a.ref[RuntimeInfo&], b.ref[RuntimeInfo&]) == true
        # Apply tess constants to the hull stage.
        tess: mutable TessellationDataConstantBuffer = zeroed
        tess.hs_cp_stride <- 32u32
        tess.ls_stride <- 16u32
        tess.hs_output_base <- 4u32
        RuntimeInfo_InitFromTessConstants(a.ref[mutable RuntimeInfo&], tess.ref[TessellationDataConstantBuffer&])
        assert a.hs_info.hs_output_cp_stride == 32u32
        assert a.hs_info.ls_stride == 16u32
        assert a.hs_info.hs_output_base == 4u32
        assert a.hs_es_vs_info.hs_output_cp_stride == 32u32
        # a now differs from b.
        assert RuntimeInfo_Equal(a.ref[RuntimeInfo&], b.ref[RuntimeInfo&]) == false

@test
def runtime_info_cross_stage_not_compared() -> void:
    can Abort.Panic:
        # Different stages: equality dispatches on a.stage only (mirrors C++).
        a: mutable RuntimeInfo = zeroed
        b: mutable RuntimeInfo = zeroed
        RuntimeInfo_Initialize(a.ref[mutable RuntimeInfo&], SHADER_STAGE_LOCAL)
        RuntimeInfo_Initialize(b.ref[mutable RuntimeInfo&], SHADER_STAGE_LOCAL)
        a.ls_info.ls_stride <- 64u32
        b.ls_info.ls_stride <- 64u32
        assert RuntimeInfo_Equal(a.ref[RuntimeInfo&], b.ref[RuntimeInfo&]) == true
        b.ls_info.ls_stride <- 128u32
        assert RuntimeInfo_Equal(a.ref[RuntimeInfo&], b.ref[RuntimeInfo&]) == false
