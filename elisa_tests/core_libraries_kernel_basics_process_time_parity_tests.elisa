include "../common/types.elisa"
include "../core/libraries/kernel/kernel.elisa"
include "../core/libraries/kernel/process.elisa"
include "../core/libraries/kernel/time.elisa"
include "../core/libraries/kernel/kernel_nids.elisa"
include "../core/libraries/kernel/orbis_error.elisa"
include "../core/libraries/kernel/posix_error.elisa"

def kpt_check(cond: bool, msg: static u8&) -> void:
    can Abort.Panic:
        if not cond:
            panic(msg)

@test
def kernel_basics_sdk_and_sw_version_contracts() -> void:
    can Abort.Panic:
        sdk: mutable int = 0
        kpt_check(sceKernelGetAllowedSdkVersionOnSystem(sdk.ref[mutable int&].cast[void&?]) == ORBIS_OK, "allowed sdk should succeed")
        kpt_check(sdk == (CURRENT_FIRMWARE_VERSION | 0xfff), "allowed sdk should match firmware mask")
        kpt_check(sceKernelGetAllowedSdkVersionOnSystem(null) == ORBIS_KERNEL_ERROR_EINVAL, "allowed sdk null should fail")

        sw: mutable SwVersionStruct = zeroed
        kpt_check(sceKernelGetSystemSwVersion(sw.ref[mutable SwVersionStruct&].cast[void&?]) == ORBIS_OK, "sw version should succeed")
        kpt_check(sw.hex_representation == CURRENT_FIRMWARE_VERSION.u32(), "sw version hex should match")
        kpt_check(sw.text_representation[0] == '1'.i8(), "sw version text[0]")
        kpt_check(sw.text_representation[1] == '.'.i8(), "sw version text[1]")
        kpt_check(sw.text_representation[2] == '3'.i8(), "sw version text[2]")
        kpt_check(sw.text_representation[3] == '5'.i8(), "sw version text[3]")
        kpt_check(sceKernelGetSystemSwVersion(null) == ORBIS_OK, "sw version null is tolerated")

@test
def kernel_basics_authinfo_and_process_type_contracts() -> void:
    can Abort.Panic:
        info: mutable AuthInfoData = zeroed
        err_ref: mutable int&? = __Error() as mutable int&?
        if err_ref == null:
            panic("__Error pointer should be present")

        kpt_check(get_authinfo(GLOBAL_PID, info.ref[mutable AuthInfoData&].cast[void&?]) == ORBIS_OK, "authinfo for global pid should succeed")
        kpt_check(info.caps[0] == 0x2000000000000000u64, "authinfo cap bit should match")
        kpt_check(get_authinfo(77, info.ref[mutable AuthInfoData&].cast[void&?]) == -1, "authinfo for unknown pid should fail")
        if err_ref != null:
            kpt_check(err_ref[0] == POSIX_ESRCH, "authinfo unknown pid should set ESRCH")
        kpt_check(get_authinfo(GLOBAL_PID, null) == -1, "authinfo null output should fail")
        if err_ref != null:
            kpt_check(err_ref[0] == POSIX_EPERM, "authinfo null output should set EPERM")

        kpt_check(sceKernelGetProcessType(GLOBAL_PID) == 0, "global pid process type should be app")
        kpt_check(sceKernelGetProcessType(GLOBAL_PID + 1) == ORBIS_KERNEL_ERROR_ENOSYS, "unknown pid process type should fail")

@test
def kernel_process_missing_cpp_apis_are_registered_and_stubbed() -> void:
    can Abort.Panic:
        out: mutable int = -1
        kpt_check(sceKernelStopUnloadModule(1, 0u64, null, 0u32, null, out.ref[mutable int&].cast[void&?]) == ORBIS_OK, "stop unload module should succeed")
        kpt_check(out == ORBIS_OK, "stop unload module should write success result")

        usage: mutable u8[0x90] = zeroed
        usage[0] <- 0xABu8
        usage[0x8f] <- 0xCDu8
        kpt_check(posix_getrusage(0, usage[0].ref[mutable u8&].cast[void&?]) == 0, "getrusage should succeed")
        kpt_check(usage[0] == 0u8 and usage[0x8f] == 0u8, "getrusage should zero PS4-sized rusage buffer")
        kpt_check(posix_getrusage(0, null) == -1, "getrusage null usage should fail")

        old_len: mutable u64 = 777u64
        kpt_check(posix_sysctl(null, 0u32, null, old_len.ref[mutable u64&].cast[void&?], null, 0u64) == 0, "sysctl stub should succeed")
        kpt_check(old_len == 0u64, "sysctl should zero old length output")

        old_state: mutable int = -1
        kpt_check(scePthreadSetcancelstate(1, old_state.ref[mutable int&].cast[void&?]) == ORBIS_OK, "setcancelstate stub should succeed")
        kpt_check(old_state == 0, "setcancelstate should output old state 0")

@test
def kernel_process_nid_table_includes_cpp_process_tail_entries() -> void:
    can Abort.Panic:
        kpt_check(KERNEL_NIDS_COUNT >= 612usize, "kernel nid table should include full non-coredump C++ libkernel export surface")
        e0: KernelNidEntry = Kernel_NidEntryAt(564usize)
        e1: KernelNidEntry = Kernel_NidEntryAt(565usize)
        e9: KernelNidEntry = Kernel_NidEntryAt(573usize)
        e10: KernelNidEntry = Kernel_NidEntryAt(574usize)
        e37: KernelNidEntry = Kernel_NidEntryAt(611usize)
        kpt_check(e0.nid == "QKd0qM58Qes" and e0.symbol_name == "sceKernelStopUnloadModule", "missing stop unload nid")
        kpt_check(e1.nid == "hHlZQUnlxSM" and e1.symbol_name == "posix_getrusage", "missing getrusage nid")
        kpt_check(e9.nid == "OAmWq+OHSjw" and e9.symbol_name == "scePthreadSetcancelstate", "missing setcancelstate nid")
        kpt_check(e10.nid == "-YTW+qXc3CQ" and e10.symbol_name == "sceKernelInternalMemoryGetModuleSegmentInfo", "missing module segment info nid")
        kpt_check(e37.nid == "DjpBvGlaWbQ" and e37.symbol_name == "scePthreadSemGetvalue", "missing final semaphore nid")

@test
def kernel_register_lib_walks_full_registration_chain() -> void:
    can Abort.Panic:
        RegisterLib(null)
        kpt_check(true, "kernel register lib should compile and return")

@test
def kernel_time_error_and_conversion_contracts() -> void:
    can Abort.Panic:
        kpt_check(posix_clock_gettime(ORBIS_CLOCK_MONOTONIC, null) == -1, "clock_gettime null output should fail")
        err_ref: mutable int&? = __Error() as mutable int&?
        if err_ref == null:
            panic("__Error pointer should be available")
        if err_ref != null:
            kpt_check(err_ref[0] == POSIX_EFAULT, "clock_gettime null output should set EFAULT")
        kpt_check(sceKernelClockGettime(ORBIS_CLOCK_MONOTONIC, null) == ORBIS_KERNEL_ERROR_EFAULT, "kernel clock_gettime should map EFAULT")

        bad_ts: mutable OrbisKernelTimespec = OrbisKernelTimespec(0, 1000000000)
        kpt_check(posix_nanosleep(bad_ts.ref[OrbisKernelTimespec&].cast[void&], null) == -1, "nanosleep invalid nsec should fail")
        if err_ref != null:
            kpt_check(err_ref[0] == POSIX_EINVAL, "nanosleep invalid nsec should set EINVAL")
        kpt_check(sceKernelNanosleep(bad_ts.ref[OrbisKernelTimespec&].cast[void&], null) == ORBIS_KERNEL_ERROR_EINVAL, "kernel nanosleep should map EINVAL")

        tz: mutable OrbisKernelTimezone = zeroed
        sec_out: mutable i64 = 0
        dst_out: mutable int = 0
        kpt_check(sceKernelConvertLocaltimeToUtc(12345, 0, sec_out.ref[mutable i64&].cast[void&?], tz.ref[mutable OrbisKernelTimezone&].cast[void&?], dst_out.ref[mutable int&].cast[void&?]) == ORBIS_OK, "local->utc should succeed")
        kpt_check(sceKernelConvertLocaltimeToUtc(12345, 0, null, null, null) == ORBIS_KERNEL_ERROR_EINVAL, "local->utc should reject null timezone")

        local_time: mutable i64 = 0
        ts: mutable OrbisTimesec = zeroed
        dst: mutable u64 = 0u64
        kpt_check(sceKernelConvertUtcToLocaltime(12345, local_time.ref[mutable i64&].cast[void&?], ts.ref[mutable OrbisTimesec&].cast[void&?], dst.ref[mutable u64&].cast[void&?]) == ORBIS_OK, "utc->local should succeed")
        kpt_check(ts.t == 12345, "utc->local should preserve source time in OrbisTimesec")
