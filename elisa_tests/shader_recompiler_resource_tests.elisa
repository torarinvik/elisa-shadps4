include "../shader_recompiler/resource.elisa"
include "../../compiler/runtime/elisacore_std/elisacore_runtime.elisa"

@test
def resource_limits_and_buffer_type() -> void:
    can Abort.Panic:
        assert SHADER_NUM_USER_DATA_REGS == 16u32
        assert SHADER_NUM_IMAGES == 64u32
        assert SHADER_NUM_BUFFERS == 40u32
        assert ShaderBufferType_IsSpecial(SHADER_BUFFER_TYPE_GUEST) == false
        assert ShaderBufferType_IsSpecial(SHADER_BUFFER_TYPE_SHARED_MEMORY) == true
        # BufOffsetIndex = UdRegsIndex(4) + NUM_USER_DATA_REGS(16)/4 = 8
        assert SHADER_PUSH_BUF_OFFSET_INDEX == SHADER_PUSH_UD_REGS_INDEX + SHADER_NUM_USER_DATA_REGS / 4u32

@test
def push_data_add_offset_clamps() -> void:
    can Abort.Panic:
        push: mutable PushData = zeroed
        PushData_AddOffset(push.ref[mutable PushData&], 3u32, 200u32)
        PushData_AddOffset(push.ref[mutable PushData&], 5u32, 999u32)   # clamps to 255
        PushData_AddOffset(push.ref[mutable PushData&], 100u32, 7u32)   # out of range, ignored
        assert push.buf_offsets[3usize] == 200u8
        assert push.buf_offsets[5usize] == 255u8
        assert push.buf_offsets[0usize] == 0u8
