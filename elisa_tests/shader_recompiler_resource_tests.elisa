include "../shader_recompiler/resource.elisa"
include "../../compiler/runtime/elisacore_std/elisacore_runtime.elisa"

@test
def resource_limits_and_buffer_type() -> void:
    can Abort.Panic:
        assert SHADER_NUM_USER_DATA_REGS == 16u32
        assert SHADER_NUM_IMAGES == 64u32
        assert SHADER_NUM_BUFFERS == 40u32
        assert ShaderBufferType_IsSpecial(SHADER_BUFFER_TYPE_GUEST) == false
        assert ShaderBufferType_IsSpecial(SHADER_BUFFER_TYPE_SHARED_MEMORY) == true
        # BufOffsetIndex = UdRegsIndex(4) + NUM_USER_DATA_REGS(16)/4 = 8
        assert SHADER_PUSH_BUF_OFFSET_INDEX == SHADER_PUSH_UD_REGS_INDEX + SHADER_NUM_USER_DATA_REGS / 4u32

@test
def push_data_add_offset_clamps() -> void:
    can Abort.Panic:
        push: mutable PushData = zeroed
        PushData_AddOffset(push.ref[mutable PushData&], 3u32, 200u32)
        PushData_AddOffset(push.ref[mutable PushData&], 5u32, 999u32)   # clamps to 255
        PushData_AddOffset(push.ref[mutable PushData&], 100u32, 7u32)   # out of range, ignored
        assert push.buf_offsets[3usize] == 200u8
        assert push.buf_offsets[5usize] == 255u8
        assert push.buf_offsets[0usize] == 0u8

@test
def resource_descriptor_helpers() -> void:
    can Abort.Panic:
        buf: mutable BufferResource = zeroed
        buf.buffer_type <- SHADER_BUFFER_TYPE_GUEST
        assert BufferResource_IsSpecial(buf.ref[BufferResource&]) == false
        # Guest, small, not written -> not storage.
        assert BufferResource_IsStorage(buf.ref[BufferResource&], 16u32, 64u32) == false
        # Large total size -> storage.
        assert BufferResource_IsStorage(buf.ref[BufferResource&], 256u32, 1024u32) == true
        buf.is_written <- true
        # Written -> storage regardless of size.
        assert BufferResource_IsStorage(buf.ref[BufferResource&], 4u32, 1u32) == true
        buf.buffer_type <- SHADER_BUFFER_TYPE_SHARED_MEMORY
        assert BufferResource_IsSpecial(buf.ref[BufferResource&]) == true

        img: mutable ImageResource = zeroed
        img.mip_fallback_mode <- SHADER_MIP_FALLBACK_DYNAMIC_INDEX
        assert img.is_depth == false
        assert img.mip_fallback_mode == SHADER_MIP_FALLBACK_DYNAMIC_INDEX

        smp: mutable SamplerResource = zeroed
        smp.is_inline_sampler <- true
        assert smp.is_inline_sampler == true
        assert smp.associated_image == 0u32
