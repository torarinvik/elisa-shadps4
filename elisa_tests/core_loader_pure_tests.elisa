include "../core/aerolib/aerolib_find.elisa"
include "../common/types.elisa"
include "../../compiler/runtime/elisacore_std/elisacore_runtime.elisa"
include "../core/loader/elf.elisa"
include "../core/loader/dwarf.elisa"
include "../core/loader/symbols_resolver.elisa"

@test
def loader_self_validation_contracts() -> void:
    can Abort.Panic:
        e: mutable Elf = Elf_new()
        e.self.magic <- 0x1D3D154F
        e.self.version <- 0x00
        e.self.mode <- 0x01
        e.self.endian <- 0x01
        e.self.attributes <- 0x12
        e.self.category <- 0x01
        e.self.program_type <- 0x01
        assert Elf_IsSelfFile(e)
        e.self.attributes <- 0x00
        assert not Elf_IsSelfFile(e)

@test
def loader_elf_validation_contracts() -> void:
    can Abort.Panic:
        e: mutable Elf = Elf_new()
        e.elf_header_value.e_ident.magic[0] <- 0x7F
        e.elf_header_value.e_ident.magic[1] <- 'E'.u8()
        e.elf_header_value.e_ident.magic[2] <- 'L'.u8()
        e.elf_header_value.e_ident.magic[3] <- 'F'.u8()
        e.elf_header_value.e_ident.ei_class <- 0x02
        e.elf_header_value.e_ident.ei_data <- 0x01
        e.elf_header_value.e_ident.ei_version <- 0x01
        e.elf_header_value.e_ident.ei_osabi <- 0x09
        e.elf_header_value.e_ident.ei_abiversion <- 0x00
        e.elf_header_value.e_type <- ET_SCE_DYNEXEC
        e.elf_header_value.e_machine <- EM_X86_64
        e.elf_header_value.e_version <- EV_CURRENT
        e.elf_header_value.e_phentsize <- size_of(elf_program_header).u16()
        e.elf_header_value.e_shentsize <- 64
        assert Elf_IsElfFile(e)
        e.elf_header_value.e_shentsize <- 16
        assert not Elf_IsElfFile(e)

@test
def loader_self_segment_flag_helpers() -> void:
    can Abort.Panic:
        seg: mutable self_segment_header = zeroed
        seg.flags <- (0x123 << 20) | 0x800 | 0x1 | 0x2 | 0x4 | 0x8
        assert SelfSegment_IsBlocked(seg)
        assert SelfSegment_GetId(seg) == 0x123
        assert SelfSegment_IsOrdered(seg)
        assert SelfSegment_IsEncrypted(seg)
        assert SelfSegment_IsSigned(seg)
        assert SelfSegment_IsCompressed(seg)

@test
def loader_shared_lib_flag() -> void:
    can Abort.Panic:
        e: mutable Elf = Elf_new()
        e.elf_header_value.e_type <- ET_SCE_DYNAMIC
        assert Elf_IsSharedLib(e)
        e.elf_header_value.e_type <- ET_SCE_EXEC
        assert not Elf_IsSharedLib(e)

@test
def loader_dwarf_decode_rejects_short_header() -> void:
    can Abort.Panic:
        info: mutable EHHeaderInfo = zeroed
        assert not DecodeEHHdr(0.uintptr(), 0.uintptr(), info)

@test
def loader_dwarf_leb128_helpers() -> void:
    can Abort.Panic:
        uleb: mutable u8[2] = [0xE5, 0x8E]
        # Append termination byte for value 624485 => E5 8E 26.
        uleb3: mutable u8[3] = [0xE5, 0x8E, 0x26]
        p1: mutable uintptr = (&uleb3[0]).uintptr()
        assert Dwarf_ReadULEB128(p1) == 624485

        sleb: mutable u8[1] = [0x7f] # -1
        p2: mutable uintptr = (&sleb[0]).uintptr()
        assert Dwarf_ReadSLEB128(p2).cast[s64] == (-1).s64()

@test
def loader_symbols_findsymbol_prefix_fallback() -> void:
    can Abort.Panic:
        r: mutable SymbolsResolver = SymbolsResolver_new()
        exact: SymbolResolver = SymbolResolver("foo", "NID_FOO", "libSce", 1, "core", SymbolType.Function)
        fallback: SymbolResolver = SymbolResolver("bar", "NID_BAR", "libSce", 1, "core", SymbolType.Function)
        SymbolsResolver_AddSymbol(r, fallback, 0x2000)
        SymbolsResolver_AddSymbol(r, exact, 0x3000)
        query_exact: SymbolResolver = SymbolResolver("foo", "NID_FOO", "libSce", 1, "core", SymbolType.Function)
        found_exact: SymbolRecord? = SymbolsResolver_FindSymbol(r, query_exact)
        assert found_exact != null
        assert found_exact.value().virtual_address == 0x3000
        query_mismatch_type: SymbolResolver = SymbolResolver("foo", "NID_FOO", "libSce", 1, "core", SymbolType.Object)
        found_prefix: SymbolRecord? = SymbolsResolver_FindSymbol(r, query_mismatch_type)
        assert found_prefix != null
        assert found_prefix.value().virtual_address == 0x3000
