include "../shader_recompiler/frontend/opcode_unified_vop3.elisa"
include "../../compiler/runtime/elisacore_std/elisacore_runtime.elisa"

@test
def opcode_unified_vop3_values() -> void:
    can Abort.Panic:
        assert OPCODE_V_MAD_LEGACY_F32 == 320u32 + OPCODE_MAP_OP_MAP_VOP3
        assert OPCODE_V_OR3_B32 == 882u32 + OPCODE_MAP_OP_MAP_VOP3
        assert OPCODE_V_PK_MAD_I16 == 0u32 + OPCODE_MAP_OP_MAP_VOP3P
        assert OPCODE_V_MAD_MIXHI_F16 == 34u32 + OPCODE_MAP_OP_MAP_VOP3P
        assert OPCODE_V_MAD_LEGACY_F32 != OPCODE_V_PK_MAD_I16
