include "../core_libraries_ime_integration.elisa"

@test
def ime_panel_size_and_param_init() -> void:
    can Abort.Panic:
        p: mutable OrbisImeParam = zeroed
        sceImeParamInit(p)
        assert p.user_id == ORBIS_IME_USER_SERVICE_USER_ID_INVALID

        buf: mutable u16[32] = zeroed
        work: mutable u8[0x5000] = zeroed
        p.user_id <- 1
        p.type_ <- ORBIS_IME_TYPE_NUMBER
        p.supported_languages <- 0x3ff1fffff
        p.enter_label <- 0
        p.input_method <- ORBIS_IME_INPUT_METHOD_DEFAULT
        p.option <- 0
        p.maxTextLength <- 32
        p.inputTextBuffer <- (&buf).cast[mutable u16&]
        p.posx <- 100.0
        p.posy <- 100.0
        p.horizontal_alignment <- 0
        p.vertical_alignment <- 0
        p.work <- (&work).cast[mutable u8&].cast[mutable void&]

        w: mutable u32 = 0
        h: mutable u32 = 0
        assert sceImeGetPanelSize(p, w, h) == ORBIS_OK
        assert w == 0x172
        assert h == 0x192

@test
def ime_open_settext_setcaret_close() -> void:
    can Abort.Panic:
        buf: mutable u16[16] = zeroed
        work: mutable u8[0x5000] = zeroed

        p: mutable OrbisImeParam = zeroed
        p.user_id <- 1
        p.type_ <- ORBIS_IME_TYPE_DEFAULT
        p.supported_languages <- 0x3ff1fffff
        p.enter_label <- 0
        p.input_method <- ORBIS_IME_INPUT_METHOD_DEFAULT
        p.option <- 0
        p.maxTextLength <- 16
        p.inputTextBuffer <- (&buf).cast[mutable u16&]
        p.posx <- 10.0
        p.posy <- 10.0
        p.horizontal_alignment <- 0
        p.vertical_alignment <- 0
        p.work <- (&work).cast[mutable u8&].cast[mutable void&]

        assert sceImeOpen(p, null) == ORBIS_IME_ERROR_INVALID_HANDLER

        p.handler <- ime_test_handler
        assert sceImeOpen(p, null) == ORBIS_OK

        txt: mutable u16[4] = zeroed
        txt[0] <- 97u16
        txt[1] <- 98u16
        assert sceImeSetText((&txt).cast[mutable u16&], 2) == ORBIS_OK

        caret: mutable OrbisImeCaret = zeroed
        caret.index <- 2
        assert sceImeSetCaret(caret) == ORBIS_OK
        caret.index <- 3
        assert sceImeSetCaret(caret) == ORBIS_IME_ERROR_INVALID_PARAM

        assert sceImeClose() == ORBIS_OK
        assert sceImeClose() == ORBIS_IME_ERROR_NOT_OPENED

@test
def ime_keyboard_paths() -> void:
    can Abort.Panic:
        kp: mutable OrbisImeKeyboardParam = zeroed
        assert sceImeKeyboardOpen(1, kp) == ORBIS_IME_ERROR_INVALID_HANDLER

        kp.handler <- ime_test_handler
        kp.option <- ORBIS_IME_KEYBOARD_OPTION_MASK
        assert sceImeKeyboardOpen(1, kp) == ORBIS_OK

        ids: mutable OrbisImeKeyboardResourceIdArray = zeroed
        assert sceImeKeyboardGetResourceId(1, ids) == ORBIS_IME_ERROR_CONNECTION_FAILED
        assert ids.user_id == 1
        assert ids.resource_id[0] == 0
        assert ids.resource_id[1] == 0
        assert ids.resource_id[2] == 0
        assert ids.resource_id[3] == 0
        assert ids.resource_id[4] == 0

        assert sceImeKeyboardClose(1) == ORBIS_OK

def ime_test_handler(arg: void&?, e: OrbisImeEvent&?) -> void:
    _ = arg
    _ = e
    return
