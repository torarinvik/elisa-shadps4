include "../shader_recompiler/info_flags.elisa"
include "../../compiler/runtime/elisacore_std/elisacore_runtime.elisa"

@test
def info_flags_popcount_and_enums() -> void:
    can Abort.Panic:
        assert ShaderPopCount32(0u32) == 0u32
        assert ShaderPopCount32(1u32) == 1u32
        assert ShaderPopCount32(0xFFFFFFFFu32) == 32u32
        assert ShaderPopCount32(11u32) == 3u32  # 0b1011
        assert SHADER_QUALIFIER_SAMPLE == 6u32
        assert SHADER_READ_CONST_IMMEDIATE == 1u32
        assert SHADER_READ_CONST_DYNAMIC == 2u32

@test
def info_flags_user_data_mask() -> void:
    can Abort.Panic:
        ud: mutable UserDataMask = zeroed
        UserDataMask_Set(ud.ref[mutable UserDataMask&], 2u32)
        UserDataMask_Set(ud.ref[mutable UserDataMask&], 5u32)
        UserDataMask_Set(ud.ref[mutable UserDataMask&], 7u32)
        assert UserDataMask_NumRegs(ud.ref[UserDataMask&]) == 3u32
        # Index = popcount of set bits below reg.
        assert UserDataMask_Index(ud.ref[UserDataMask&], 2u32) == 0u32
        assert UserDataMask_Index(ud.ref[UserDataMask&], 5u32) == 1u32
        assert UserDataMask_Index(ud.ref[UserDataMask&], 7u32) == 2u32
        # Setting an already-set bit is idempotent.
        UserDataMask_Set(ud.ref[mutable UserDataMask&], 2u32)
        assert UserDataMask_NumRegs(ud.ref[UserDataMask&]) == 3u32

@test
def info_flags_attribute_flags() -> void:
    can Abort.Panic:
        af: mutable AttributeFlags = zeroed
        assert AttributeFlags_GetAny(af.ref[AttributeFlags&], IR_ATTRIBUTE_DEPTH) == false
        AttributeFlags_Set(af.ref[mutable AttributeFlags&], IR_ATTRIBUTE_DEPTH, 0u32)
        AttributeFlags_Set(af.ref[mutable AttributeFlags&], IR_ATTRIBUTE_DEPTH, 2u32)
        assert AttributeFlags_Get(af.ref[AttributeFlags&], IR_ATTRIBUTE_DEPTH, 0u32) == true
        assert AttributeFlags_Get(af.ref[AttributeFlags&], IR_ATTRIBUTE_DEPTH, 1u32) == false
        assert AttributeFlags_Get(af.ref[AttributeFlags&], IR_ATTRIBUTE_DEPTH, 2u32) == true
        assert AttributeFlags_GetAny(af.ref[AttributeFlags&], IR_ATTRIBUTE_DEPTH) == true
        # A different attribute slot is untouched.
        assert AttributeFlags_GetAny(af.ref[AttributeFlags&], IR_ATTRIBUTE_RENDERTARGET0) == false
        assert AttributeFlags_NumComponents(af.ref[AttributeFlags&], IR_ATTRIBUTE_DEPTH) == 4u32
