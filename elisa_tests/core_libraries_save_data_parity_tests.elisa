include "../core/libraries/kernel/lib_function_stub.elisa"
include "../../compiler/runtime/elisacore_std/elisacore_runtime.elisa"
include "../core/libraries/save_data/savedata.elisa"
include "../core/libraries/save_data/savedata_bridge_test_ffi.elisa"

const SAVE_DATA_OK: int = 0
const SAVE_DATA_PARAMETER: i32 = -2137063424  # 0x809F0000
const SAVE_DATA_MOUNT_MODE_RDWR_CREATE: u32 = 0x2 | 0x4

@test
def save_data_preinit_error_contracts() -> void:
    can Abort.Panic:
        assert sceSaveDataClearProgress() != SAVE_DATA_OK
        assert sceSaveDataGetProgress(null) != SAVE_DATA_OK
        assert sceSaveDataTerminate() != SAVE_DATA_OK

@test
def save_data_stubbed_ok_contracts() -> void:
    can Abort.Panic:
        assert sceSaveDataDebug() == SAVE_DATA_OK
        assert sceSaveDataUpload() == SAVE_DATA_OK
        assert sceSaveDataDownload() == SAVE_DATA_OK
        assert sceSaveDataRegisterEventCallback() == SAVE_DATA_OK
        assert sceSaveDataUnregisterEventCallback() == SAVE_DATA_OK
        assert Func_02E4C4D201716422() == SAVE_DATA_OK

@test
def save_data_mount_param_umount_contracts() -> void:
    can Abort.Panic:
        assert sceSaveDataInitialize(null) == SAVE_DATA_OK

        mount_point_buf: mutable array[u8, 64] = zeroed
        mount_rc: int = c_savedata_test_mount2(1, "ELISA_PARITY_SLOT", SAVE_DATA_MOUNT_MODE_RDWR_CREATE, 128, mount_point_buf[0], 64)
        assert mount_rc == SAVE_DATA_OK

        blocks: mutable u64 = 0
        free_blocks: mutable u64 = 0
        assert c_savedata_test_get_mount_info(mount_point_buf[0], blocks, free_blocks) == SAVE_DATA_OK
        assert blocks > 0

        assert c_savedata_test_set_param_title(mount_point_buf[0], "Elisa SaveData Parity") == SAVE_DATA_OK

        title_buf: mutable array[u8, 128] = zeroed
        got_size: mutable u64 = 0
        assert c_savedata_test_get_param_title(mount_point_buf[0], title_buf[0], 128, got_size) == SAVE_DATA_OK
        assert got_size > 0

        assert c_savedata_test_set_param_user(mount_point_buf[0], 77) == SAVE_DATA_OK
        user_param: mutable u32 = 0
        user_size: mutable u64 = 0
        assert c_savedata_test_get_param_user(mount_point_buf[0], user_param, user_size) == SAVE_DATA_OK
        assert user_param == 77

        assert c_savedata_test_umount(mount_point_buf[0]) == SAVE_DATA_OK
        assert sceSaveDataTerminate() == SAVE_DATA_OK

def main() -> int:
    if sceSaveDataInitialize(null) != SAVE_DATA_OK:
        return 1

    progress: mutable i64 = 0
    if sceSaveDataGetProgress((&progress).cast[void&?]) != SAVE_DATA_OK:
        return 2
    if sceSaveDataGetProgress(null) != SAVE_DATA_PARAMETER:
        return 3

    mount_point_buf: mutable array[u8, 64] = zeroed
    if c_savedata_test_mount2(1, "ELISA_PARITY_MAIN", SAVE_DATA_MOUNT_MODE_RDWR_CREATE, 128, mount_point_buf[0], 64) != SAVE_DATA_OK:
        return 4
    if c_savedata_test_set_param_user(mount_point_buf[0], 123) != SAVE_DATA_OK:
        return 5
    if c_savedata_test_umount(mount_point_buf[0]) != SAVE_DATA_OK:
        return 6

    if sceSaveDataTerminate() != SAVE_DATA_OK:
        return 7

    return 0
