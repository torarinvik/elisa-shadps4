#
# SaveData parity tests, fully NATIVE — no C/C++ bridge. The sceSaveData* entry
# points (core/libraries/save_data/savedata.elisa) run on the dependency-free
# lifecycle guard (savedata_state.elisa); the mount/param store runs on the
# host-backed native core (save_mount.elisa over common/sys_fs.elisa + PSF).
# This replaces the abandoned c_savedata_test_* / Libraries::SaveData::* path.

include "../common/string_util.elisa"
include "../common/types.elisa"
include "../../compiler/runtime/elisacore_std/elisacore_runtime.elisa"
include "../common/arch.elisa"
include "../common/io_file.elisa"
include "../core/file_format/binary.elisa"
include "../core/file_format/psf.elisa"
include "../common/sys_fs.elisa"
include "../core/libraries/kernel/lib_function_stub.elisa"
include "../core/libraries/save_data/savedata_error.elisa"
include "../core/libraries/save_data/savedata_state.elisa"
include "../core/libraries/save_data/save_mount.elisa"
include "../core/libraries/save_data/savedata.elisa"

const SAVE_DATA_OK: int = 0
const SAVE_DATA_PARAMETER: int = -2137063424  # 0x809F0000 as i32

# The sceSaveData* entry points guard on initialization exactly like shadPS4.
@test
def save_data_preinit_error_contracts() -> void:
    can Abort.Panic:
        # Force a known un-initialized state for this test.
        savedata_core_set_terminated()
        assert sceSaveDataClearProgress() != SAVE_DATA_OK
        assert sceSaveDataGetProgress(null) != SAVE_DATA_OK
        assert sceSaveDataTerminate() != SAVE_DATA_OK

# The ~stub entry points return OK once initialized (matching shadPS4).
@test
def save_data_stubbed_ok_contracts() -> void:
    can Abort.Panic:
        assert sceSaveDataInitialize(null) == SAVE_DATA_OK
        assert sceSaveDataDebug() == SAVE_DATA_OK
        assert sceSaveDataUpload() == SAVE_DATA_OK
        assert sceSaveDataDownload() == SAVE_DATA_OK
        assert sceSaveDataRegisterEventCallback() == SAVE_DATA_OK
        assert sceSaveDataUnregisterEventCallback() == SAVE_DATA_OK
        assert Func_02E4C4D201716422() == SAVE_DATA_OK
        assert sceSaveDataTerminate() == SAVE_DATA_OK

# GetProgress: NULL output pointer is a PARAMETER error; a real one is OK.
@test
def save_data_get_progress_contracts() -> void:
    can Abort.Panic:
        assert sceSaveDataInitialize(null) == SAVE_DATA_OK
        progress: mutable i64 = 0
        assert sceSaveDataGetProgress((&progress).cast[void&?]) == SAVE_DATA_OK
        assert sceSaveDataGetProgress(null) == SAVE_DATA_PARAMETER
        assert sceSaveDataTerminate() == SAVE_DATA_OK

# Native mount/param/umount round-trip through the host-backed core.
@test
def save_data_mount_param_umount_contracts() -> void:
    can Memory.Allocate, Abort.Panic:
        assert sceSaveDataInitialize(null) == SAVE_DATA_OK

        handle: int = savedata_mount(1, "ELISA_PARITY_SLOT", 128)
        assert handle >= 0

        blocks: mutable u64 = 0
        free_blocks: mutable u64 = 0
        assert savedata_get_mount_info(handle, blocks, free_blocks) == SAVE_DATA_ERROR_OK
        assert blocks == 128

        assert savedata_set_param_title(handle, "Elisa SaveData Parity") == SAVE_DATA_ERROR_OK
        title_buf: mutable array[u8, 128] = zeroed
        got_size: mutable u64 = 0
        assert savedata_get_param_title(handle, title_buf[0], 128, got_size) == SAVE_DATA_ERROR_OK
        assert got_size > 0

        assert savedata_set_param_user(handle, 77) == SAVE_DATA_ERROR_OK
        user_param: mutable u32 = 0
        user_size: mutable u64 = 0
        assert savedata_get_param_user(handle, user_param, user_size) == SAVE_DATA_ERROR_OK
        assert user_param == 77

        assert savedata_umount(handle) == SAVE_DATA_ERROR_OK
        assert sceSaveDataTerminate() == SAVE_DATA_OK

# Full PS4-ABI path: build real Orbis structs in memory and drive the sceSaveData* entry
# points, which decode them by byte offset (savedata_abi.elisa) and call the native core.
@test
def save_data_abi_struct_decode() -> void:
    can Memory.Allocate, Abort.Panic:
        assert sceSaveDataInitialize(null) == SAVE_DATA_OK

        # OrbisSaveDataDirName: CString<32>.
        dirname: mutable array[u8, 32] = zeroed
        dn_src: static u8& = "ELISA_ABI_SLOT"
        for i in 0..<runtime_strlen(dn_src):
            dirname[i] <- dn_src[i]

        # OrbisSaveDataMount2 (64 bytes): userId@0, dirName*@8, blocks@16, mountMode@24.
        mount_buf: mutable array[u8, 64] = zeroed
        result_buf: mutable array[u8, 64] = zeroed
        mount_ref: mutable void& = (&mount_buf[0]).cast[mutable void&]
        mount_view: MutableAbiView = abi_mut_view(mount_ref, 64)
        abi_store_u32(mount_view, 0, 1)
        abi_store_u64(mount_view, 8, (&dirname[0]).uintptr().u64())
        abi_store_u64(mount_view, 16, 128)
        abi_store_u32(mount_view, 24, 0x2 | 0x4)  # RDWR | CREATE

        assert sceSaveDataMount2((&mount_buf[0]).cast[void&?], (&result_buf[0]).cast[void&?]) == SAVE_DATA_OK
        # result.mount_point begins "/savedata"; required_blocks@16==128; mount_status@28==1
        assert result_buf[0] == '/'.u8()
        assert result_buf[1] == 's'.u8()
        result_ref: void& = (&result_buf[0]).cast[void&]
        result_view: AbiView = abi_view(result_ref, 64)
        assert abi_u64_at(result_view, 16) == 128
        assert abi_u32_at(result_view, 28) == 1

        mp: void&? = (&result_buf[0]).cast[void&?]  # the mount point CString keys later calls

        # SetParam(USER_PARAM=4) then GetParam back.
        ubuf: mutable array[u8, 4] = zeroed
        ubuf_view: MutableAbiView = abi_mut_view((&ubuf[0]).cast[mutable void&], 4)
        abi_store_u32(ubuf_view, 0, 99)
        assert sceSaveDataSetParam(mp, 4, (&ubuf[0]).cast[void&?], 4) == SAVE_DATA_OK
        obuf: mutable array[u8, 4] = zeroed
        gsize: mutable array[u8, 8] = zeroed
        assert sceSaveDataGetParam(mp, 4, (&obuf[0]).cast[void&?], 4, (&gsize[0]).cast[void&?]) == SAVE_DATA_OK
        assert abi_u32_at(abi_view((&obuf[0]).cast[void&], 4), 0) == 99
        assert abi_u64_at(abi_view((&gsize[0]).cast[void&], 8), 0) == 4

        # SetParam(TITLE=1) — a NUL-terminated guest string buffer.
        tbuf: mutable array[u8, 32] = zeroed
        t_src: static u8& = "ABI Title"
        for i in 0..<runtime_strlen(t_src):
            tbuf[i] <- t_src[i]
        assert sceSaveDataSetParam(mp, 1, (&tbuf[0]).cast[void&?], 32) == SAVE_DATA_OK
        tout: mutable array[u8, 64] = zeroed
        tgsize: mutable array[u8, 8] = zeroed
        assert sceSaveDataGetParam(mp, 1, (&tout[0]).cast[void&?], 64, (&tgsize[0]).cast[void&?]) == SAVE_DATA_OK
        assert abi_u64_at(abi_view((&tgsize[0]).cast[void&], 8), 0) == 9
        assert tout[0] == 'A'.u8()

        # GetMountInfo (OrbisSaveDataMountInfo: blocks@0, freeBlocks@8).
        info_buf: mutable array[u8, 48] = zeroed
        assert sceSaveDataGetMountInfo(mp, (&info_buf[0]).cast[void&?]) == SAVE_DATA_OK
        assert abi_u64_at(abi_view((&info_buf[0]).cast[void&], 48), 0) == 128

        assert sceSaveDataUmount(mp) == SAVE_DATA_OK
        # After umount the mount point no longer resolves.
        assert sceSaveDataUmount(mp) != SAVE_DATA_OK

        # sceSaveDataDelete removes the on-disk save dir (OrbisSaveDataDelete: dirName*@16).
        del_buf: mutable array[u8, 64] = zeroed
        abi_store_u64(abi_mut_view((&del_buf[0]).cast[mutable void&], 64), 16, (&dirname[0]).uintptr().u64())
        assert sceSaveDataDelete((&del_buf[0]).cast[void&?]) == SAVE_DATA_OK
        # Deleting again reports NOT_FOUND (non-zero).
        assert sceSaveDataDelete((&del_buf[0]).cast[void&?]) != SAVE_DATA_OK

        assert sceSaveDataTerminate() == SAVE_DATA_OK

# sceSaveDataDirNameSearch enumerates on-disk saves and fills OrbisSaveDataDirNameSearchResult
# (dirNames[] sorted ascending, params[] from each param.sfo, infos[] blocks/freeBlocks).
@test
def save_data_abi_dir_name_search() -> void:
    can Memory.Allocate, Abort.Panic:
        assert sceSaveDataInitialize(null) == SAVE_DATA_OK
        # Clean the save root so the enumeration is deterministic, then create two saves.
        _ = fs_remove_tree("/tmp/elisa_savedata")

        hb: int = savedata_mount(1, "SAVE_B", 64)
        assert hb >= 0
        assert savedata_set_param_title(hb, "Bravo") == SAVE_DATA_ERROR_OK
        assert savedata_umount(hb) == SAVE_DATA_ERROR_OK
        ha: int = savedata_mount(1, "SAVE_A", 128)
        assert ha >= 0
        assert savedata_set_param_title(ha, "Alpha") == SAVE_DATA_ERROR_OK
        assert savedata_umount(ha) == SAVE_DATA_ERROR_OK

        # OrbisSaveDataDirNameSearchCond (userId@0; dirName null = all; key/order 0).
        cond: mutable array[u8, 64] = zeroed
        abi_store_u32(abi_mut_view((&cond[0]).cast[mutable void&], 64), 0, 1)

        # Caller-provided output arrays (capacity 2).
        dirnames: mutable array[u8, 64] = zeroed    # 2 * CString<32>
        params: mutable array[u8, 2656] = zeroed    # 2 * OrbisSaveDataParam(1328)
        infos: mutable array[u8, 96] = zeroed       # 2 * OrbisSaveDataSearchInfo(48)
        result: mutable array[u8, 64] = zeroed
        rmut: mutable void& = (&result[0]).cast[mutable void&]
        rview: MutableAbiView = abi_mut_view(rmut, 64)
        abi_store_u32(rview, 16, 2)                                          # dirNamesNum
        abi_store_u64(rview, 8, (&dirnames[0]).uintptr().u64())             # dirNames*
        abi_store_u64(rview, 24, (&params[0]).uintptr().u64())             # params*
        abi_store_u64(rview, 32, (&infos[0]).uintptr().u64())             # infos*

        assert sceSaveDataDirNameSearch((&cond[0]).cast[void&?], (&result[0]).cast[void&?]) == SAVE_DATA_OK
        rref: void& = (&result[0]).cast[void&]
        rread: AbiView = abi_view(rref, 64)
        assert abi_u32_at(rread, 0) == 2    # hitNum
        assert abi_u32_at(rread, 20) == 2   # setNum

        # Sorted ascending: "SAVE_A" (idx 0) then "SAVE_B" (idx 1, stride 32).
        assert dirnames[5] == 'A'.u8()
        assert dirnames[32 + 5] == 'B'.u8()
        # infos[0].blocks == 128 (SAVE_A); params[0].title begins "Alpha".
        assert abi_u64_at(abi_view((&infos[0]).cast[void&], 96), 0) == 128
        assert params[0] == 'A'.u8()

        assert sceSaveDataTerminate() == SAVE_DATA_OK
