include "../../compiler/runtime/elisacore_std/elisacore_runtime.elisa"
include "../core/libraries/videoout/videoout.elisa"
type VAddr = u64
include "../core/libraries/gnmdriver/gnmdriver.elisa"

global mutable g_test_submit_bridge_calls: u32 = 0
global mutable g_test_submit_flip_bridge_calls: u32 = 0
global mutable g_test_submit_done_bridge_calls: u32 = 0
global mutable g_test_last_submit_workload: u32 = 0
global mutable g_test_last_submit_count: u32 = 0
global mutable g_test_last_flip_arg: i64 = 0

def gnmdriver_test_submit_bridge(workload: u32, count: u32, dcb_gpu_addrs: u32&?, dcb_sizes_in_bytes: u32&?,
                                 ccb_gpu_addrs: u32&?, ccb_sizes_in_bytes: u32&?) -> int:
    g_test_submit_bridge_calls <- g_test_submit_bridge_calls + 1
    g_test_last_submit_workload <- workload
    g_test_last_submit_count <- count
    _ = dcb_gpu_addrs
    _ = dcb_sizes_in_bytes
    _ = ccb_gpu_addrs
    _ = ccb_sizes_in_bytes
    return ORBIS_OK

def gnmdriver_test_submit_flip_bridge(workload: u32, count: u32, dcb_gpu_addrs: u32&?, dcb_sizes_in_bytes: u32&?,
                                      ccb_gpu_addrs: u32&?, ccb_sizes_in_bytes: u32&?,
                                      vo_handle: u32, buf_idx: u32, flip_mode: u32, flip_arg: i64) -> int:
    g_test_submit_flip_bridge_calls <- g_test_submit_flip_bridge_calls + 1
    g_test_last_submit_workload <- workload
    g_test_last_submit_count <- count
    g_test_last_flip_arg <- flip_arg
    _ = dcb_gpu_addrs
    _ = dcb_sizes_in_bytes
    _ = ccb_gpu_addrs
    _ = ccb_sizes_in_bytes
    _ = vo_handle
    _ = buf_idx
    _ = flip_mode
    return ORBIS_OK

def gnmdriver_test_submit_done_bridge() -> int:
    g_test_submit_done_bridge_calls <- g_test_submit_done_bridge_calls + 1
    return ORBIS_OK

@test
def gnmdriver_stub_defaults_do_not_crash() -> void:
    can Abort.Panic:
        sceGnmDingDong(0, 0)
        sceGnmDingDongForWorkload(0, 0, 0)
        sceGnmFlushGarlic()
        sceGnmGpuPaDebugEnter()
        sceGnmGpuPaDebugLeave()
        sceGnmRegisterGnmLiveCallbackConfig()
        GnmDriver_RegisterLib(null)

@test
def gnmdriver_stub_return_values_match_expected_defaults() -> void:
    can Abort.Panic:
        assert sceGnmDebuggerGetAddressWatch() == ORBIS_GNM_ERROR_FAILURE
        assert sceGnmDebugHardwareStatus() == ORBIS_OK
        assert sceGnmDriverInternalRetrieveGnmInterface() == -2147483648
        assert sceGnmDriverCaptureInProgress() == false
        assert sceGnmGetTheTessellationFactorRingBufferBaseAddress() == ORBIS_GNM_TESSELLATION_FALLBACK_ADDR
        assert sceGnmAreSubmitsAllowed() == 1

@test
def gnmdriver_stub_int_paths_are_stable() -> void:
    can Abort.Panic:
        assert sceGnmAddEqEvent(0, 0, null) == ORBIS_KERNEL_ERROR_EBADF
        assert sceGnmDeleteEqEvent(0, 0) == ORBIS_KERNEL_ERROR_EBADF
        assert sceGnmDriverTriggerCapture() == ORBIS_GNM_ERROR_CAPTURE_FAILED_INTERNAL

@test
def gnmdriver_workload_and_queue_paths() -> void:
    can Abort.Panic:
        assert sceGnmBeginWorkload(0, null) == 3
        workload: mutable u64 = 0
        assert sceGnmBeginWorkload(0x0f, workload) == 0
        assert workload == 1
        assert sceGnmBeginWorkload(0x10, workload) == 1
        assert workload == 0
        assert sceGnmCreateWorkloadStream(0, null) == 3
        workload_stream: mutable u32 = 0
        assert sceGnmCreateWorkloadStream(0xdeadbeef, workload_stream) == 0
        assert workload_stream == 1
        assert sceGnmEndWorkload(0x00123456abcdef11) == 0
        assert sceGnmEndWorkload(0) == 2

@test
def gnmdriver_compute_queue_paths() -> void:
    can Abort.Panic:
        assert sceGnmMapComputeQueue(0x4, 0, 0x1000, 0x100, null) == ORBIS_GNM_ERROR_COMPUTEQUEUE_INVALID_PIPE_ID
        assert sceGnmMapComputeQueue(0, 0x20, 0x1000, 0x100, null) == ORBIS_GNM_ERROR_COMPUTEQUEUE_INVALID_QUEUE_ID
        assert sceGnmMapComputeQueue(0, 0, 0x1003, 0x100, null) == ORBIS_GNM_ERROR_COMPUTEQUEUE_INVALID_RING_BASE_ADDR
        assert sceGnmMapComputeQueue(0, 0, 0x1000, 0x123, null) == ORBIS_GNM_ERROR_COMPUTEQUEUE_INVALID_RING_SIZE
        read_ptr: mutable u32 = 0
        assert sceGnmMapComputeQueue(0, 0, 0x1000, 0x100, read_ptr) == 1
        assert sceGnmUnmapComputeQueue(0) == ORBIS_OK
        assert sceGnmUnmapComputeQueue(1) == ORBIS_OK

@test
def gnmdriver_submit_validation_paths() -> void:
    can Abort.Panic:
        assert sceGnmSubmitCommandBuffers(1, null, null, null, null) == ORBIS_GNM_ERROR_SUBMISSION_FAILED_INVALID_ARGUMENT
        assert sceGnmSubmitCommandBuffersForWorkload(0, 1, null, null, null, null) == ORBIS_GNM_ERROR_SUBMISSION_FAILED_INVALID_ARGUMENT
        assert sceGnmSubmitDone() == ORBIS_OK

@test
def gnmdriver_connected_submit_smoke_records_liverpool_and_rasterizer_progress() -> void:
    can Abort.Panic:
        GnmDriver_RegisterLib(null)
        assert g_send_init_packet == true
        assert g_graphics_submit_count == 0
        assert g_graphics_init_packet_submit_count == 0
        assert g_liverpool_submit_gfx_count == 0
        assert g_rasterizer_on_submit_count == 0
        assert g_rasterizer_flush_count == 0
        assert g_runtime_scheduler_submit_count == 0
        assert g_runtime_scheduler_last_tick == 0
        assert g_runtime_present_prepare_count == 0
        assert g_runtime_present_count == 0
        assert g_runtime_present_success_count == 0
        assert g_runtime_submit_bridge_count == 0
        assert g_runtime_submit_flip_bridge_count == 0
        assert g_runtime_submit_done_bridge_count == 0
        assert not g_gnm_artifact_submit_path_native_emitted
        assert not g_gnm_artifact_submit_path_bridge_emitted

        dcb_addrs: mutable u32[2] = [0x1000, 0x2000]
        dcb_sizes: mutable u32[2] = [0x40, 0x80]
        ccb_addrs: mutable u32[2] = [0x3000, 0x4000]
        ccb_sizes: mutable u32[2] = [0x20, 0x30]

        assert sceGnmSubmitCommandBuffers(2, dcb_addrs[0], dcb_sizes[0],
                                          ccb_addrs[0], ccb_sizes[0]) == ORBIS_OK
        assert g_send_init_packet == false
        assert g_graphics_init_packet_submit_count == 1
        assert g_graphics_submit_count == 2
        assert g_liverpool_submit_gfx_count == 3
        assert g_rasterizer_on_submit_count == 2
        assert g_rasterizer_flush_count == 2
        assert g_runtime_scheduler_submit_count == 2
        assert g_runtime_scheduler_last_tick >= 1
        assert g_graphics_last_submit_dcb_addr == 0x2000
        assert g_graphics_last_submit_dcb_size == 0x80
        assert g_graphics_last_submit_ccb_addr == 0x4000
        assert g_graphics_last_submit_ccb_size == 0x30
        assert g_gnm_artifact_submit_path_native_emitted
        assert not g_gnm_artifact_submit_path_bridge_emitted

        assert sceGnmSubmitCommandBuffers(1, dcb_addrs[0], dcb_sizes[0],
                                          null, null) == ORBIS_OK
        assert g_graphics_init_packet_submit_count == 1
        assert g_graphics_submit_count == 3
        assert g_liverpool_submit_gfx_count == 4
        assert g_rasterizer_on_submit_count == 3
        assert g_runtime_scheduler_submit_count == 3
        assert g_graphics_last_submit_ccb_addr == 0
        assert g_graphics_last_submit_ccb_size == 0

        assert sceGnmSubmitDone() == ORBIS_OK
        assert g_liverpool_submit_done_count == 1
        assert g_frames_submitted == 1
        assert g_send_init_packet == true

        assert sceGnmSubmitCommandBuffers(1, dcb_addrs[0], dcb_sizes[0],
                                          null, null) == ORBIS_OK
        assert g_graphics_init_packet_submit_count == 2
        assert g_graphics_submit_count == 4
        assert g_liverpool_submit_gfx_count == 6
        assert g_runtime_scheduler_submit_count == 4

        assert sceGnmSubmitAndFlipCommandBuffers(1, dcb_addrs[0], dcb_sizes[0],
                                                 ccb_addrs[0], ccb_sizes[0],
                                                 7, 2, 1, 42.i64()) == ORBIS_OK
        assert g_graphics_submit_count == 5
        assert g_liverpool_submit_gfx_count == 7
        assert g_rasterizer_on_submit_count == 5
        assert g_runtime_scheduler_submit_count == 5
        assert g_runtime_present_prepare_count == 1
        assert g_runtime_present_count == 1
        assert g_runtime_present_success_count == 1
        assert g_runtime_last_present_ok
        assert g_runtime_last_flip_vo_handle == 7
        assert g_runtime_last_flip_buf_idx == 2
        assert g_runtime_last_flip_mode == 1
        assert g_runtime_last_flip_arg == 42.i64()
        assert g_gnm_artifact_submit_path_native_emitted

@test
def gnmdriver_runtime_present_routes_to_videoout_first_frame() -> void:
    can Abort.Panic:
        GnmDriver_RegisterLib(null)
        _ = sceVideoOutClose(1)
        videoout_reset_port_state()

        handle: int = sceVideoOutOpen(0, 0, 0, null)
        assert handle == 1
        assert g_videoout_artifact_opened_emitted
        assert not g_videoout_artifact_buffers_registered_emitted
        assert not g_videoout_artifact_first_flip_emitted
        assert not g_videoout_artifact_flip_completed_emitted
        assert not g_videoout_artifact_first_frame_candidate_emitted

        attr: mutable VideoOutBufferAttribute = zeroed
        sceVideoOutSetBufferAttribute(
            (&attr).cast[void&?],
            0x80000000,
            0,
            0,
            64,
            64,
            64
        )

        frame_buffer: mutable array[u8, 256] = zeroed
        addresses: mutable array[u64, 1] = zeroed
        addresses[0] <- (&frame_buffer[0]).cast[void&].uintptr().u64()

        group_index: int = sceVideoOutRegisterBuffers(
            handle.i64(),
            0,
            (&addresses[0]).cast[void&?],
            1,
            (&attr).cast[void&?]
        )
        assert group_index == 0

        dcb_addrs: mutable u32[1] = [0x5000]
        dcb_sizes: mutable u32[1] = [0x40]

        assert sceGnmSubmitAndFlipCommandBuffers(
            1,
            dcb_addrs[0],
            dcb_sizes[0],
            null,
            null,
            handle.u32(),
            0,
            1,
            123.i64()
        ) == ORBIS_OK

        assert g_runtime_present_prepare_count == 1
        assert g_runtime_present_count == 1
        assert g_runtime_present_success_count == 1
        assert g_runtime_last_present_ok
        assert g_videoout_artifact_first_flip_emitted
        assert g_videoout_artifact_flip_completed_emitted
        assert g_videoout_artifact_first_frame_candidate_emitted
        assert sceVideoOutIsFlipPending(handle.i64()) == 0
        label_addr: mutable i64 = 0
        assert sceVideoOutGetBufferLabelAddress(handle.i64(), (&label_addr).cast[void&?]) == 16
        labels: mutable u64& = label_addr.cast[mutable u64&]
        assert labels[0] == 1

        assert sceVideoOutClose(handle.i64()) == ORBIS_OK

@test
def gnmdriver_runtime_frame_path_callbacks_dispatch() -> void:
    can Abort.Panic:
        GnmDriver_RegisterLib(null)
        GnmDriver_BindRuntimeFramePathCallbacks(
            gnmdriver_test_submit_bridge.cast[GnmRuntimeSubmitCallback],
            gnmdriver_test_submit_flip_bridge.cast[GnmRuntimeSubmitAndFlipCallback],
            gnmdriver_test_submit_done_bridge.cast[GnmRuntimeSubmitDoneCallback]
        )

        g_test_submit_bridge_calls <- 0
        g_test_submit_flip_bridge_calls <- 0
        g_test_submit_done_bridge_calls <- 0
        g_test_last_submit_workload <- 0
        g_test_last_submit_count <- 0
        g_test_last_flip_arg <- 0

        dcb_addrs: mutable u32[1] = [0x5000]
        dcb_sizes: mutable u32[1] = [0x40]
        ccb_addrs: mutable u32[1] = [0x6000]
        ccb_sizes: mutable u32[1] = [0x20]

        assert sceGnmSubmitCommandBuffers(1, dcb_addrs[0], dcb_sizes[0],
                                          ccb_addrs[0], ccb_sizes[0]) == ORBIS_OK
        assert g_test_submit_bridge_calls == 1
        assert g_test_submit_flip_bridge_calls == 0
        assert g_runtime_submit_bridge_count == 1
        assert g_runtime_submit_flip_bridge_count == 0
        assert g_test_last_submit_workload == 1
        assert g_test_last_submit_count == 1
        assert g_gnm_artifact_submit_path_bridge_emitted

        assert sceGnmSubmitAndFlipCommandBuffers(1, dcb_addrs[0], dcb_sizes[0],
                                                 ccb_addrs[0], ccb_sizes[0],
                                                 3, 0, 1, 99.i64()) == ORBIS_OK
        assert g_test_submit_bridge_calls == 1
        assert g_test_submit_flip_bridge_calls == 1
        assert g_runtime_submit_bridge_count == 1
        assert g_runtime_submit_flip_bridge_count == 1
        assert g_test_last_submit_workload == 1
        assert g_test_last_submit_count == 1
        assert g_test_last_flip_arg == 99.i64()
        assert g_runtime_present_prepare_count == 1
        assert g_runtime_present_count == 1
        assert g_runtime_present_success_count == 1
        assert g_runtime_last_present_ok
        assert g_runtime_last_flip_vo_handle == 3
        assert g_runtime_last_flip_buf_idx == 0
        assert g_runtime_last_flip_mode == 1
        assert g_runtime_last_flip_arg == 99.i64()

        assert sceGnmSubmitDone() == ORBIS_OK
        assert g_test_submit_done_bridge_calls == 1
        assert g_runtime_submit_done_bridge_count == 1

        GnmDriver_ClearRuntimeFramePathCallbacks()

@test
def gnmdriver_wait_flip_done_emits_write_data_then_nop_label() -> void:
    can Abort.Panic:
        cmdbuf: mutable u32[7] = zeroed
        assert sceGnmInsertWaitFlipDone(cmdbuf[0], 7, 1, 2) == ORBIS_OK
        assert cmdbuf[0] == gnm_create_pm4_header(0x37, 3)
        assert cmdbuf[1] == 0x500
        assert cmdbuf[2] == 16
        assert cmdbuf[3] == 0
        assert cmdbuf[4] == 1
        assert cmdbuf[5] == gnm_create_pm4_header(PM4ItOpcode_Nop, 1)
        assert cmdbuf[6] == PM4CmdNop_DebugSetMarker
