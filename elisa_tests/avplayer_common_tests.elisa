include "../core/libraries/avplayer/avplayer_common.elisa"
include "../../compiler/runtime/elisacore_std/elisacore_runtime.elisa"

@test
def avplayer_common_enums_and_event() -> void:
    can Abort.Panic:
        assert AV_STATE_ERROR == 14
        assert AV_EVENT_TYPE_ERROR == 255
        assert AV_EVENT_TYPE_REVERT_STATE == 30

        ev: mutable AvPlayerEvent = zeroed
        ev.event <- AV_EVENT_TYPE_ADD_SOURCE
        ev.payload.attempt <- 3
        assert ev.event == AV_EVENT_TYPE_ADD_SOURCE
        assert ev.payload.attempt == 3
