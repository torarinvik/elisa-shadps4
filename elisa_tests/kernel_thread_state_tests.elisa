include "../core/libraries/kernel/threads/thread_state.elisa"
include "../../compiler/runtime/elisacore_std/elisacore_runtime.elisa"

@test
def thread_state_constants_and_stack() -> void:
    can Abort.Panic:
        assert THREAD_STATE_GC_THRESHOLD == 5
        assert THREAD_STATE_MAX_THREADS == 100000
        assert THREAD_STATE_MAX_CACHED_THREADS == 100

        s: mutable Stack = zeroed
        s.stacksize <- 4096
        s.stackaddr <- 0x1000
        assert s.stacksize == 4096
        assert s.stackaddr == 0x1000
