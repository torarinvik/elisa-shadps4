include "../core/libraries/error_codes.elisa"
include "../../compiler/runtime/elisacore_std/elisacore_runtime.elisa"
include "../common/types.elisa"
include "../common/logging/log.elisa"
include "../common/va_ctx.elisa"
include "../core_libraries_errors_port.elisa"
include "../core/libraries/random/random.elisa"
include "../core/file_sys/devices/devices.elisa"

@test
def file_sys_devices_base_and_nop_return_expected_defaults() -> void:
    base: mutable BaseDevice = BaseDevice_new()
    nop: mutable NopDevice = NopDevice_new(7)
    assert BaseDevice_ioctl(base, 0, null) == ORBIS_KERNEL_ERROR_ENOTTY.i32()
    assert BaseDevice_read(base, null, 4) == ORBIS_KERNEL_ERROR_EBADF.i64()
    assert NopDevice_ioctl(nop, 0, null) == 0
    assert NopDevice_read(nop, null, 4) == 0

@test
def file_sys_devices_ioccom_extracts_command_fields() -> void:
    cmd: u64 = _IOWR(83.u64(), 2, 64)
    assert IOCPARM_LEN(cmd) == 64
    assert IOCGROUP(cmd) == 83.u64()
    assert IOCBASECMD(cmd) == _IOWR(83.u64(), 2, 0)

@test
def file_sys_devices_random_read_and_fstat_match_device_contract() -> void:
    can Abort.Panic, Memory.Allocate:
        dev: mutable RandomDevice = RandomDevice_new(1)
        bytes: mutable darray[u8] = []
        owner: mutable Arena& = scratch_arena.ref[mutable Arena&]
        for i in 0..<8:
            in owner:
                bytes.push(0)
        read: s64 = RandomDevice_read(dev, bytes[0].ref[mutable void&], bytes.count.u64())
        stat: mutable OrbisKernelStat = zeroed
        assert read == 8
        assert RandomDevice_fstat(dev, stat.ref[mutable OrbisKernelStat&]) == 0
        assert stat.st_mode == DEVICE_CHAR_MODE

@test
def file_sys_devices_rng_ioctl_fills_args_and_rejects_unknown_commands() -> void:
    dev: mutable RngDevice = RngDevice_new(2)
    args: mutable RngGetRandomArgs = zeroed
    assert RngDevice_ioctl_args(dev, RNG_GET_RANDOM_CMD_1, args) == 0
    assert args.result == 0
    assert RngDevice_ioctl_args(dev, 0, args) == RNG_ENOIOCTL

@test
def file_sys_devices_logger_buffers_until_newline_or_fsync() -> void:
    logger: mutable DeviceLogger = DeviceLogger_new("test", false)
    assert DeviceLogger_write(logger, "abc".cast[void&], 3) == 3
    assert logger.buffer.count == 3
    assert DeviceLogger_write(logger, "\n".cast[void&], 1) == 1
    assert logger.buffer.count == 0

@test
def file_sys_devices_stub_error_matrix_is_stable() -> void:
    assert Device_StubLseek("dev", 0, 0) == ORBIS_KERNEL_ERROR_ESPIPE.i64()
    assert Device_StubGetdents("dev", null, 0, null) == ORBIS_KERNEL_ERROR_ENOTDIR.i64()
    assert Device_StubFtruncate("dev", 0) == ORBIS_KERNEL_ERROR_EINVAL.i32()
    assert Device_StubFsync("dev") == ORBIS_OK.i32()
