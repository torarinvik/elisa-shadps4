#
# Dogfood for the Aligned[N] / Fits[bits] modular refinements: page-alignment and
# register-field width stated as TYPES and proven statically. This reopens the E6 design
# note where alignment had to be dropped to an operational guard (it was an undischargeable
# modular `requires`); the modular refinement vocabulary now discharges these.
#
# SCOPE: this exercises the soundly-working RETURN-position form (proven constructors). The
# parameter-position story (stating alignment as a *precondition* on map/protect) has open
# gaps — see verification_findings/aligned-refinement-dogfood.md.

include "../../compiler/runtime/elisacore_std/elisacore_runtime.elisa"
include "../common/types.elisa"

const PAGE_MASK: u64 = 0xFFFFFFFFFFFFF000

# Proven page-aligned constructor: any address from this is STATICALLY known 4K-aligned, so
# downstream code needs no runtime alignment guard. Discharged at the cheap tier (low 12 bits
# cleared by the mask), no SMT required.
def page_align_down(raw: u64) -> u64 is Aligned[4096]:
    return raw & PAGE_MASK

# Proven 6-bit register field: the extraction is statically known to fit in 6 bits.
def reg_field6(reg: u32) -> u32 is Fits[6]:
    return (reg >> 12) & 0x3F

@test
def aligned_refinement_constructors_prove() -> void:
    # The proofs are static (the two refined returns above discharge at compile time under
    # -strict); this @test anchors the file as a runnable target and sanity-checks values.
    can Abort.Panic:
        if (page_align_down(0x12345) & 0xFFF) != 0:
            panic("align_down not page-aligned")
        if reg_field6(0xFFFFFFFF) > 0x3F:
            panic("reg field exceeds 6 bits")
