include "../../compiler/runtime/elisacore_std/elisacore_runtime.elisa"
include "../imgui/big_picture/imgui_big_picture_ffi_bridge.elisa"
include "../imgui/big_picture/imgui_impl_sdl3_big_picture.elisa"
include "../imgui/big_picture/imgui_impl_sdlrenderer3.elisa"
include "../imgui/big_picture/big_picture.elisa"

@test
def imgui_big_picture_sdl3_bridge_lifecycle_and_viewports() -> void:
    can Abort.Panic:
        ImguiBigPictureBridge_Reset()

        fake_window: void&? = 1.cast[void&?]
        fake_renderer: void&? = 2.cast[void&?]
        fake_gl: void&? = 3.cast[void&?]

        assert ImGui_ImplSDL3_InitForSDLRenderer(fake_window, fake_renderer) == true
        assert ImguiBigPictureBridge_GetSDL3Initialized() == 1
        assert ImguiBigPictureBridge_GetSDL3InitCalls() == 1
        assert ImguiBigPictureBridge_GetSDL3BackendKind() == IMGUI_IMPL_SDL3_BACKEND_SDLRENDERER
        assert ImguiBigPictureBridge_GetSDL3ViewportInitCalls() == 1

        ImGui_ImplSDL3_NewFrame()
        assert ImguiBigPictureBridge_GetSDL3NewFrameCalls() == 1

        assert ImGui_ImplSDL3_ProcessEvent(null) == false
        assert ImGui_ImplSDL3_ProcessEvent(fake_gl) == true
        assert ImguiBigPictureBridge_GetSDL3ProcessEventCalls() == 2

        ImGui_ImplSDL3_SetGamepadMode(2, fake_renderer, 4)
        assert g_imgui_impl_sdl3_gamepad_mode == 2
        assert ImguiBigPictureBridge_GetSDL3GamepadMode() == 2
        assert ImguiBigPictureBridge_GetSDL3ManualGamepadsCount() == 4

        ImGui_ImplSDL3_UpdateMonitors()
        ImGui_ImplSDL3_CreateWindow(fake_window)
        ImGui_ImplSDL3_ShowWindow(fake_window)
        ImGui_ImplSDL3_UpdateWindow(fake_window)
        ImGui_ImplSDL3_RenderWindow(fake_window, null)
        ImGui_ImplSDL3_SwapBuffers(fake_window, null)
        ImGui_ImplSDL3_DestroyWindow(fake_window)

        assert ImguiBigPictureBridge_GetSDL3UpdateMonitorsCalls() >= 2
        assert ImguiBigPictureBridge_GetSDL3ViewportCreateCalls() == 1
        assert ImguiBigPictureBridge_GetSDL3ViewportShowCalls() == 1
        assert ImguiBigPictureBridge_GetSDL3ViewportUpdateCalls() >= 1
        assert ImguiBigPictureBridge_GetSDL3ViewportRenderCalls() == 1
        assert ImguiBigPictureBridge_GetSDL3ViewportSwapCalls() == 1
        assert ImguiBigPictureBridge_GetSDL3ViewportDestroyCalls() == 1

        ImGui_ImplSDL3_Shutdown()
        assert ImguiBigPictureBridge_GetSDL3Initialized() == 0
        assert ImguiBigPictureBridge_GetSDL3ShutdownCalls() == 1
        assert ImguiBigPictureBridge_GetSDL3ViewportShutdownCalls() == 1

@test
def imgui_big_picture_sdlrenderer3_bridge_lifecycle() -> void:
    can Abort.Panic:
        ImguiBigPictureBridge_Reset()
        fake_renderer: void&? = 44.cast[void&?]
        fake_draw_data: void&? = 55.cast[void&?]

        assert ImGui_ImplSDLRenderer3_Init(fake_renderer) == true
        assert ImguiBigPictureBridge_GetRendererInitialized() == 1
        assert ImguiBigPictureBridge_GetRendererInitCalls() == 1

        assert ImGui_ImplSDLRenderer3_CreateDeviceObjects() == true
        assert ImguiBigPictureBridge_GetRendererCreateDeviceCalls() == 1
        assert ImguiBigPictureBridge_GetRendererCreateFontsCalls() == 1
        assert ImguiBigPictureBridge_GetRendererDeviceObjectsLive() == 1
        assert ImguiBigPictureBridge_GetRendererFontTextureLive() == 1

        ImGui_ImplSDLRenderer3_NewFrame()
        assert ImguiBigPictureBridge_GetRendererNewFrameCalls() == 1

        ImGui_ImplSDLRenderer3_RenderDrawData(fake_draw_data, fake_renderer)
        assert ImguiBigPictureBridge_GetRendererSetupRenderStateCalls() == 1
        assert ImguiBigPictureBridge_GetRendererRenderCalls() == 1

        ImGui_ImplSDLRenderer3_DestroyDeviceObjects()
        assert ImguiBigPictureBridge_GetRendererDestroyDeviceCalls() == 1
        assert ImguiBigPictureBridge_GetRendererDestroyFontsCalls() == 1

        ImGui_ImplSDLRenderer3_Shutdown()
        assert ImguiBigPictureBridge_GetRendererInitialized() == 0
        assert ImguiBigPictureBridge_GetRendererShutdownCalls() == 1

@test
def imgui_big_picture_texture_and_launch_ffi_paths() -> void:
    can Abort.Panic:
        BigPicture_ResetForTests()

        assert LoadSdlTextureData(null, 0) == null
        assert LoadSdlTextureDataFromFile(null) == null
        assert ImguiBigPictureBridge_GetTextureFromBytesCalls() == 0
        assert ImguiBigPictureBridge_GetTextureFromFileCalls() == 0

        blob: mutable u8[4] = zeroed
        t0: void&? = LoadSdlTextureData(blob.ref[mutable u8&].cast[void&?], 4)
        t1: void&? = LoadSdlTextureDataFromFile("/tmp/icon0.png")
        assert t0 != null
        assert t1 != null
        assert ImguiBigPictureBridge_GetTextureFromBytesCalls() == 1
        assert ImguiBigPictureBridge_GetTextureFromFileCalls() == 1

        showSettings <- true
        ImguiBigPictureBridge_LaunchSetContinueBudget(2)
        ImguiBigPictureBridge_LaunchQueueEventType(BIG_PICTURE_EVENT_NONE)
        ImguiBigPictureBridge_LaunchQueueEventType(BIG_PICTURE_EVENT_QUIT)
        Launch(null)
        assert done == true
        assert g_big_picture_last_launch_has_executable == false
        assert ImguiBigPictureBridge_GetLaunchCalls() == 1
        assert ImguiBigPictureBridge_GetLaunchBeginCalls() == 1
        assert ImguiBigPictureBridge_GetLaunchEndCalls() == 1
        assert ImguiBigPictureBridge_GetLaunchActive() == 0
        assert ImguiBigPictureBridge_GetLastLaunchHasExecutable() == 0
        assert streq(ImguiBigPictureBridge_GetLaunchWindowTitle(), "elisa_shadps4") == 1
        assert ImguiBigPictureBridge_GetLaunchPollEventCalls() >= 1
        assert ImguiBigPictureBridge_GetLaunchRenderPresentCalls() >= 1
        assert ImguiBigPictureBridge_GetLaunchSettingsOpenCount() >= 1
        assert showSettings == false
        assert ImguiBigPictureBridge_GetLaunchWindowLive() == 0
        assert ImguiBigPictureBridge_GetLaunchRendererLive() == 0
        assert ImguiBigPictureBridge_GetLaunchImGuiContextLive() == 0
        assert ImguiBigPictureBridge_GetLaunchSeqBegin() > 0
        assert ImguiBigPictureBridge_GetLaunchSeqInitSDL3() > ImguiBigPictureBridge_GetLaunchSeqBegin()
        assert ImguiBigPictureBridge_GetLaunchSeqInitRenderer() > ImguiBigPictureBridge_GetLaunchSeqInitSDL3()
        assert ImguiBigPictureBridge_GetLaunchSeqShutdownRenderer() > ImguiBigPictureBridge_GetLaunchSeqInitRenderer()
        assert ImguiBigPictureBridge_GetLaunchSeqShutdownSDL3() > ImguiBigPictureBridge_GetLaunchSeqShutdownRenderer()
        assert ImguiBigPictureBridge_GetLaunchSeqDestroyImGui() > ImguiBigPictureBridge_GetLaunchSeqShutdownSDL3()
        assert ImguiBigPictureBridge_GetLaunchSeqEnd() > ImguiBigPictureBridge_GetLaunchSeqDestroyImGui()

        done <- false
        ImguiBigPictureBridge_LaunchSetContinueBudget(1)
        Launch(99.cast[void&?])
        assert done == true
        assert g_big_picture_last_launch_has_executable == true
        assert ImguiBigPictureBridge_GetLaunchCalls() == 2
        assert ImguiBigPictureBridge_GetLaunchBeginCalls() == 2
        assert ImguiBigPictureBridge_GetLaunchEndCalls() == 2
        assert ImguiBigPictureBridge_GetLastLaunchHasExecutable() == 1

@test
def imgui_big_picture_launch_init_fail_paths() -> void:
    can Abort.Panic:
        BigPicture_ResetForTests()
        ImguiBigPictureBridge_SetForceWindowCreateFail(1)
        Launch(null)
        assert done == true
        assert ImguiBigPictureBridge_GetLaunchBeginCalls() == 1
        assert ImguiBigPictureBridge_GetLaunchEndCalls() == 1
        assert ImguiBigPictureBridge_GetSDL3InitCalls() == 0
        assert ImguiBigPictureBridge_GetRendererInitCalls() == 0
        assert renderer == null
        ImguiBigPictureBridge_SetForceWindowCreateFail(0)

        BigPicture_ResetForTests()
        ImguiBigPictureBridge_SetForceSDL3InitFail(1)
        Launch(null)
        assert done == true
        assert ImguiBigPictureBridge_GetLaunchBeginCalls() == 1
        assert ImguiBigPictureBridge_GetLaunchEndCalls() == 1
        assert ImguiBigPictureBridge_GetSDL3InitCalls() == 1
        assert ImguiBigPictureBridge_GetRendererInitCalls() == 0
        assert renderer == null
        ImguiBigPictureBridge_SetForceSDL3InitFail(0)

        BigPicture_ResetForTests()
        ImguiBigPictureBridge_SetForceRendererInitFail(1)
        Launch(null)
        assert done == true
        assert ImguiBigPictureBridge_GetLaunchBeginCalls() == 1
        assert ImguiBigPictureBridge_GetLaunchEndCalls() == 1
        assert ImguiBigPictureBridge_GetSDL3InitCalls() == 1
        assert ImguiBigPictureBridge_GetRendererInitCalls() == 1
        assert ImguiBigPictureBridge_GetSDL3ShutdownCalls() == 1
        assert renderer == null
        ImguiBigPictureBridge_SetForceRendererInitFail(0)
