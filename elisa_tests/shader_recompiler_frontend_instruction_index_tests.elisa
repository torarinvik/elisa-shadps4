include "../../compiler/runtime/elisacore_std/elisacore_runtime.elisa"
include "../shader_recompiler/frontend/instruction.elisa"


@test
def shader_frontend_instruction_refined_register_index_contracts() -> void:
    can Abort.Panic:
        scalar_operand: mutable InstOperand = InstOperand_Default()
        scalar_operand.field <- OPERAND_FIELD_SCALAR_GPR
        InstOperand_SetScalarRegisterCode(scalar_operand, 103)

        vector_operand: mutable InstOperand = InstOperand_Default()
        vector_operand.field <- OPERAND_FIELD_VECTOR_GPR
        InstOperand_SetVectorSelectorAsCode(vector_operand, 511)
        InstOperand_SetVectorRegisterCode(vector_operand, 255)

        sgprs: mutable u32[128] = zeroed
        vgprs: mutable u32[256] = zeroed
        sgprs[103] <- 0x1234
        vgprs[255] <- 0x5678

        sidx: GcnScalarOperandRegisterIndexOptional = InstOperand_TryScalarRegisterIndex(scalar_operand)
        assert sidx.has_value == true
        assert GcnReadScalarRegister(sidx.value, sgprs) == 0x1234

        vidx: GcnVectorRegisterIndexOptional = InstOperand_TryVectorRegisterIndex(vector_operand)
        assert vidx.has_value == true
        assert GcnReadVectorRegister(vidx.value, vgprs) == 0x5678
        GcnWriteVectorRegister(vidx.value, vgprs, 0x9ABC)
        assert vgprs[255] == 0x9ABC

        pair: GcnVectorRegisterPairIndexOptional = GcnVectorRegisterPairIndex_Try(254)
        assert pair.has_value == true
        assert GcnVectorRegisterPairIndex_Try(255).has_value == false

        default_operand: mutable InstOperand = InstOperand_Default()
        forged_operand: mutable InstOperand = InstOperand_Default()
        forged_operand.field <- OPERAND_FIELD_VECTOR_GPR
        forged_operand.code <- 255
        assert InstOperand_TryScalarRegisterIndex(vector_operand).has_value == false
        assert InstOperand_TryVectorOperandSelector(vector_operand).has_value == true
        assert InstOperand_TryVectorOperandSelector(default_operand).has_value == false
        assert InstOperand_TryVectorRegisterIndex(forged_operand).has_value == false
