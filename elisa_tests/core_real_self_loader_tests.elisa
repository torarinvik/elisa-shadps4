@test
def real_self_loader_import_symbol_parsing_and_resolution_kinds() -> void:
    can Memory.Allocate, Abort.Panic:
        Linker_Reset()
        linker: mutable Linker& = Linker_GetInstance()
        HLELibs_InitForLinker(linker)
        scratch_module: mutable Module = Module_New("/app0/eboot.bin", "/app0/eboot.bin", MODULE_LOAD_BASE.uintptr(), false)

        parsed_nid: mutable static u8& = ""
        parsed_lib: mutable static u8& = ""
        parsed_mod: mutable static u8& = ""
        RealSelfLoader_Check(Module_ParseImportSymbol("D4yla3vx4tY#libkernel#libkernel", (&parsed_nid).cast[mutable static u8&], (&parsed_lib).cast[mutable static u8&], (&parsed_mod).cast[mutable static u8&]), "expected full nid#lib#module parse success")
        RealSelfLoader_Check(streq(parsed_nid, "D4yla3vx4tY") == 1, "expected parsed nid")
        RealSelfLoader_Check(streq(parsed_lib, "libkernel") == 1, "expected parsed library")
        RealSelfLoader_Check(streq(parsed_mod, "libkernel") == 1, "expected parsed module")

        parsed_nid <- ""
        parsed_lib <- ""
        parsed_mod <- ""
        RealSelfLoader_Check(Module_ParseImportSymbol("D4yla3vx4tY", (&parsed_nid).cast[mutable static u8&], (&parsed_lib).cast[mutable static u8&], (&parsed_mod).cast[mutable static u8&]), "expected nid-only parse success")
        RealSelfLoader_Check(streq(parsed_nid, "D4yla3vx4tY") == 1, "expected nid-only preserved")
        RealSelfLoader_Check(static_strlen(parsed_lib) == 0 and static_strlen(parsed_mod) == 0, "expected empty lib/module for nid-only")

        resolved_addr: mutable u64 = 0
        resolved_kind: mutable u8 = IMPORT_RESOLUTION_UNRESOLVED
        RealSelfLoader_Check(Linker_Resolve(linker, "D4yla3vx4tY", scratch_module, IMPORT_SYMBOL_TYPE_FUNCTION, resolved_addr, resolved_kind), "expected HLE nid resolve")
        RealSelfLoader_Check(resolved_kind == IMPORT_RESOLUTION_NATIVE_HLE, "expected HLE kind by nid")

        resolved_addr <- 0
        resolved_kind <- IMPORT_RESOLUTION_UNRESOLVED
        RealSelfLoader_Check(Linker_Resolve(linker, "D4yla3vx4tY#libkernel#libkernel", scratch_module, IMPORT_SYMBOL_TYPE_FUNCTION, resolved_addr, resolved_kind), "expected HLE full-symbol resolve")
        RealSelfLoader_Check(resolved_kind == IMPORT_RESOLUTION_NATIVE_HLE, "expected HLE kind by full symbol")

        resolved_addr <- 0
        resolved_kind <- IMPORT_RESOLUTION_UNRESOLVED
        RealSelfLoader_Check(not Linker_Resolve(linker, "", scratch_module, IMPORT_SYMBOL_TYPE_FUNCTION, resolved_addr, resolved_kind), "expected empty symbol unresolved")
        RealSelfLoader_Check(resolved_kind == IMPORT_RESOLUTION_MALFORMED, "expected malformed kind for empty symbol")

        resolved_addr <- 0
        resolved_kind <- IMPORT_RESOLUTION_UNRESOLVED
        RealSelfLoader_Check(Linker_Resolve(linker, "ZZZUnknownNid123", scratch_module, IMPORT_SYMBOL_TYPE_FUNCTION, resolved_addr, resolved_kind), "expected unknown symbol fallback resolve")
        RealSelfLoader_Check(resolved_kind == IMPORT_RESOLUTION_AEROLIB_FALLBACK, "expected fallback kind for unknown symbol")

        index: s32 = Linker_LoadModuleFromHost(linker, "/app0/eboot.bin", REAL_SELF_TEST_EBOOT, false)
        RealSelfLoader_Check(index >= 0, "expected real eboot for PRX-export test")

@test
def real_self_loader_kernel_module_info_apis_reflect_linker_state() -> void:
    can Memory.Allocate, Abort.Panic, Segment.Host, Unsafe.SegmentMutation:
        Linker_Reset()
        linker: mutable Linker& = Linker_GetInstance()
        index: s32 = Linker_LoadModuleFromHost(linker, "/app0/eboot.bin", REAL_SELF_TEST_EBOOT, false)
        RealSelfLoader_Check(index >= 0, "expected real eboot module index for module-info APIs")
        module: Module = linker.modules[index.usize()]

        basic: mutable OrbisKernelModuleInfo = Module_GetModuleInfo(module)
        basic.st_size <- 0x160.u64()
        RealSelfLoader_Check(sceKernelGetModuleInfo(index.int(), (&basic).cast[void&?]) == ORBIS_OK, "expected sceKernelGetModuleInfo success")
        RealSelfLoader_Check(streq(basic.name, module.name) == 1, "expected basic module info name")
        RealSelfLoader_Check(basic.num_segments == module.info.num_segments, "expected basic module info segment count")

        bad_basic: mutable OrbisKernelModuleInfo = Module_GetModuleInfo(module)
        bad_basic.st_size <- 0
        RealSelfLoader_Check(sceKernelGetModuleInfo(index.int(), (&bad_basic).cast[void&?]) == ORBIS_KERNEL_ERROR_EINVAL, "expected basic module info size validation")
        RealSelfLoader_Check(sceKernelGetModuleInfo(-77, (&basic).cast[void&?]) == ORBIS_KERNEL_ERROR_ESRCH, "expected invalid handle module info failure")
        RealSelfLoader_Check(sceKernelGetModuleInfo(index.int(), null) == ORBIS_KERNEL_ERROR_EFAULT, "expected null basic module info failure")

        ex: mutable OrbisKernelModuleInfoEx = Module_GetModuleInfoEx(module)
        ex.st_size <- 0x1A8.u64()
        RealSelfLoader_Check(sceKernelGetModuleInfoInternal(index.int(), (&ex).cast[void&?]) == ORBIS_OK, "expected internal module info success")
        RealSelfLoader_Check(ex.init_proc_addr == module.base_virtual_addr + module.dynamic_info.init_virtual_addr.uintptr(), "expected internal module info init address")
        RealSelfLoader_Check(ex.eh_frame_hdr_addr == module.base_virtual_addr + module.eh_frame_hdr_addr, "expected internal module info eh header address")

        from_addr: mutable OrbisKernelModuleInfoEx = zeroed
        RealSelfLoader_Check(sceKernelGetModuleInfoFromAddr(module.base_virtual_addr.u64(), 0, (&from_addr).cast[void&?]) == ORBIS_OK, "expected module info from mapped address")
        RealSelfLoader_Check(streq(from_addr.name, module.name) == 1, "expected from-address module name")
        RealSelfLoader_Check(sceKernelGetModuleInfoFromAddr(module.base_virtual_addr.u64(), 3, (&from_addr).cast[void&?]) == ORBIS_KERNEL_ERROR_EINVAL, "expected from-address flags validation")
        RealSelfLoader_Check(from_addr.st_size == 0, "expected invalid flags to clear module info ex")

        unwind: mutable OrbisModuleInfoForUnwind = zeroed
        unwind.st_size <- size_of(OrbisModuleInfoForUnwind).u64()
        RealSelfLoader_Check(sceKernelGetModuleInfoForUnwind(module.base_virtual_addr.u64(), 0, (&unwind).cast[void&?]) == ORBIS_OK, "expected unwind module info success")
        RealSelfLoader_Check(streq(unwind.name[0], module.name) == 1, "expected unwind module name")
        RealSelfLoader_Check(unwind.eh_frame_hdr_addr == module.base_virtual_addr + module.eh_frame_hdr_addr, "expected unwind eh header address")
        RealSelfLoader_Check(unwind.seg0_addr == module.base_virtual_addr, "expected unwind first segment address")
        handles: mutable s32[4] = zeroed
        count: mutable u64 = 0
        RealSelfLoader_Check(sceKernelGetModuleList((&handles[0]).cast[void&?], 4, (&count).cast[void&?]) == ORBIS_OK, "expected module list success")
        RealSelfLoader_Check(count == linker.modules.count.u64(), "expected module list count")
        RealSelfLoader_Check(handles[0] == index, "expected module list first handle")
