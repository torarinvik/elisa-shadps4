include "../core_libraries_audio3d_integration.elisa"

def audio3d_build_default_params() -> OrbisAudio3dOpenParameters:
    out: mutable OrbisAudio3dOpenParameters = zeroed
    out.size_this <- size_of(OrbisAudio3dOpenParameters).u64()
    out.granularity <- 0x100
    out.rate <- ORBIS_AUDIO3D_RATE_48000
    out.max_objects <- 8
    out.queue_depth <- 2
    out.buffer_mode <- ORBIS_AUDIO3D_BUFFER_ADVANCE_AND_PUSH
    out.reserved <- 0
    out.num_beds <- 0
    return out

@test
def audio3d_default_open_parameters_contract() -> void:
    can Abort.Panic:
        params: mutable OrbisAudio3dOpenParameters = zeroed
        assert sceAudio3dGetDefaultOpenParameters((&params).cast[mutable void&]) == ORBIS_OK
        assert params.size_this == 0x20
        assert params.granularity == 0x100
        assert params.rate == ORBIS_AUDIO3D_RATE_48000
        assert params.max_objects == 512
        assert params.queue_depth == 2
        assert params.buffer_mode == ORBIS_AUDIO3D_BUFFER_ADVANCE_AND_PUSH
        assert params.num_beds == 0

@test
def audio3d_port_object_lifecycle() -> void:
    can Abort.Panic:
        assert sceAudio3dInitialize(0) == ORBIS_OK
        params: OrbisAudio3dOpenParameters = audio3d_build_default_params()

        port_id: mutable u32 = 0
        assert sceAudio3dPortOpen(0, (&params).cast[void&], port_id) == ORBIS_OK
        assert port_id != 0

        obj1: mutable u32 = 0
        obj2: mutable u32 = 0
        assert sceAudio3dObjectReserve(port_id, obj1) == ORBIS_OK
        assert sceAudio3dObjectReserve(port_id, obj2) == ORBIS_OK
        assert obj1 != ORBIS_AUDIO3D_OBJECT_INVALID
        assert obj2 != ORBIS_AUDIO3D_OBJECT_INVALID
        assert obj1 != obj2

        assert sceAudio3dObjectUnreserve(port_id, obj1) == ORBIS_OK
        assert sceAudio3dObjectUnreserve(port_id, obj1) == ORBIS_AUDIO3D_ERROR_INVALID_OBJECT
        assert sceAudio3dPortClose(port_id) == ORBIS_OK
        assert sceAudio3dTerminate() == ORBIS_OK

@test
def audio3d_invalid_port_paths() -> void:
    can Abort.Panic:
        assert sceAudio3dPortPush(0, ORBIS_AUDIO3D_BLOCKING_ASYNC) == ORBIS_AUDIO3D_ERROR_INVALID_PORT
        assert sceAudio3dPortFlush(0) == ORBIS_AUDIO3D_ERROR_INVALID_PORT
