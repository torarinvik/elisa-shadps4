include "../../compiler/runtime/elisacore_std/elisacore_runtime_prelude.elisa"
include "../core/libraries/audio/audioout.elisa"
include "../core/libraries/audio/audioin.elisa"
include "../core/libraries/pad/pad.elisa"
include "../core/libraries/system/userservice.elisa"

@link_name(ElisaGuestExec_EmitCusaArtifactKV)
extern c_GuestExec_EmitCusaArtifactKV(key: static u8&?, value: u64) -> void

def arena_alloc(a: mutable void&, size_bytes: usize) -> mutable heap void&?:
    _ = a
    _ = size_bytes
    return null

def ctx_strlen(value: void&?) -> i64:
    _ = value
    return 0

def ctx_string_view_slice(view: void&?, start: i64, end: i64) -> void&?:
    _ = start
    _ = end
    return view

def emit_flag(key: static u8&, enabled: bool) -> void:
    c_GuestExec_EmitCusaArtifactKV(key, 1u64 if enabled else 0u64)

def smoke_assert(condition: bool, message: static u8&) -> void:
    can Abort.Panic:
        if not condition:
            panic(message)

def count_login_users(list: mutable OrbisUserServiceLoginUserIdList&) -> int:
    count: mutable int = 0
    i: mutable int = 0
    while i < ORBIS_USER_SERVICE_MAX_LOGIN_USERS:
        if list.user_id[i.usize()] >= 0:
            count <- count + 1
        i <- i + 1
    return count

@test
def emulator_runtime_services_smoke() -> void:
    can Abort.Panic:
        c_GuestExec_EmitCusaArtifactKV("runtime_services_smoke_started", 1u64)

        smoke_assert(sceUserServiceInitialize(null) == ORBIS_OK, "user service init failed")
        emit_flag("user_service_initialized", true)

        initial_user: mutable int = -1
        smoke_assert(sceUserServiceGetInitialUser(initial_user.ref[mutable int&]) == ORBIS_OK, "get initial user failed")
        c_GuestExec_EmitCusaArtifactKV("user_service_initial_user", initial_user)

        login_users: mutable OrbisUserServiceLoginUserIdList = zeroed
        smoke_assert(sceUserServiceGetLoginUserIdList(login_users.ref[mutable void&]) == ORBIS_OK, "get login list failed")
        c_GuestExec_EmitCusaArtifactKV("user_service_login_user_count", count_login_users(login_users))
        smoke_assert(sceUserServiceGetInitialUser(null) == ORBIS_USER_SERVICE_ERROR_INVALID_ARGUMENT, "null initial user validation failed")
        smoke_assert(sceUserServiceGetLoginUserIdList(null) == ORBIS_USER_SERVICE_ERROR_INVALID_ARGUMENT, "null login list validation failed")

        smoke_assert(scePadInit() == ORBIS_OK, "pad init failed")
        emit_flag("pad_initialized", true)
        invalid_pad_data: mutable OrbisPadData = zeroed
        smoke_assert(scePadRead(-12345, invalid_pad_data.ref[mutable OrbisPadData&], 1) == ORBIS_PAD_ERROR_INVALID_HANDLE, "pad read invalid handle failed")
        smoke_assert(scePadClose(-12345) == ORBIS_PAD_ERROR_INVALID_HANDLE, "pad close invalid handle failed")

        pad_handle: mutable int = 0
        c_GuestExec_EmitCusaArtifactKV("pad_open_attempted", 1u64)
        pad_handle <- scePadOpen(ORBIS_PAD_USER_SERVICE_USER_ID_SYSTEM, ORBIS_PAD_PORT_TYPE_REMOTE_CONTROL, 0, null)
        if pad_handle > 0:
            emit_flag("pad_opened", true)
            pad_data: mutable OrbisPadData = zeroed
            c_GuestExec_EmitCusaArtifactKV("pad_read_attempted", 1u64)
            pad_read_rc: int = scePadRead(pad_handle, pad_data.ref[mutable OrbisPadData&], 1)
            smoke_assert(pad_read_rc == 1, "pad read failed")
            c_GuestExec_EmitCusaArtifactKV("pad_read_rc", pad_read_rc)
            emit_flag("pad_no_controller", not pad_data.connected)
            smoke_assert(scePadReadState(pad_handle, pad_data.ref[mutable OrbisPadData&]) == ORBIS_OK, "pad read state failed")
            smoke_assert(scePadClose(pad_handle) == ORBIS_OK, "pad close failed")
            emit_flag("pad_closed", true)
        else:
            emit_flag("pad_opened", false)
            c_GuestExec_EmitCusaArtifactKV("pad_read_attempted", 0u64)
            c_GuestExec_EmitCusaArtifactKV("pad_read_rc", pad_handle)
            emit_flag("pad_no_controller", false)

        audioout_handle: mutable int = 0
        c_GuestExec_EmitCusaArtifactKV("audio_sdl_available", 1u64 if AudioFFI_InitSDL() == ORBIS_OK else 0u64)
        emit_flag("audio_openal_available", AudioFFI_ProbeOpenAL())

        smoke_assert(sceAudioOutInit() == ORBIS_OK, "audio out init failed")
        c_GuestExec_EmitCusaArtifactKV("audio_output_attempted", 1u64)
        audioout_handle <- sceAudioOutOpen(initial_user, 0, 0, 256u32, 48000u32, 1u32)
        if audioout_handle > 0:
            emit_flag("audio_output_opened", true)
            audio_out_buf: mutable u8[1024] = zeroed
            c_GuestExec_EmitCusaArtifactKV("audio_output_write_attempted", 1u64)
            smoke_assert(sceAudioOutOutput(audioout_handle, null) == 0, "audio out null output failed")
            audio_out_rc: int = sceAudioOutOutput(audioout_handle, audio_out_buf[0].ref[mutable u8&])
            smoke_assert(audio_out_rc > 0, "audio out buffer write failed")
            c_GuestExec_EmitCusaArtifactKV("audio_output_write_ok", 1u64)
            smoke_assert(sceAudioOutClose(audioout_handle) == ORBIS_OK, "audio out close failed")
            emit_flag("audio_output_closed", true)
            smoke_assert(sceAudioOutOutput(audioout_handle, audio_out_buf[0].ref[mutable u8&]) == ORBIS_AUDIO_OUT_ERROR_NOT_OPENED, "audio out closed-handle validation failed")
        else:
            emit_flag("audio_output_opened", false)
            c_GuestExec_EmitCusaArtifactKV("audio_output_write_attempted", 0u64)
            c_GuestExec_EmitCusaArtifactKV("audio_output_write_ok", 0u64)
            emit_flag("audio_output_closed", false)

        audioin_handle: mutable int = 0
        smoke_assert(sceAudioInInit() == ORBIS_OK, "audio in init failed")
        c_GuestExec_EmitCusaArtifactKV("audio_input_attempted", 1u64)
        audioin_handle <- sceAudioInOpen(initial_user, 0u32, 0u32, 256u32, 48000u32, 1u32)
        if audioin_handle > 0:
            emit_flag("audio_input_opened", true)
            audio_in_buf: mutable u8[1024] = zeroed
            c_GuestExec_EmitCusaArtifactKV("audio_input_read_attempted", 1u64)
            smoke_assert(sceAudioInInput(audioin_handle, null) == ORBIS_AUDIO_IN_ERROR_INVALID_POINTER, "audio in null pointer validation failed")
            audio_in_rc: int = sceAudioInInput(audioin_handle, audio_in_buf[0].ref[mutable u8&])
            smoke_assert(audio_in_rc >= 0, "audio in read failed")
            c_GuestExec_EmitCusaArtifactKV("audio_input_read_rc", audio_in_rc)
            c_GuestExec_EmitCusaArtifactKV("audio_input_silent_state", 1u64 if sceAudioInGetSilentState(audioin_handle) == 0 else 0u64)
            smoke_assert(sceAudioInClose(audioin_handle) == ORBIS_OK, "audio in close failed")
            emit_flag("audio_input_closed", true)
            smoke_assert(sceAudioInInput(audioin_handle, audio_in_buf[0].ref[mutable u8&]) == ORBIS_AUDIO_IN_ERROR_NOT_OPENED, "audio in closed-handle validation failed")
        else:
            emit_flag("audio_input_opened", false)
            c_GuestExec_EmitCusaArtifactKV("audio_input_read_attempted", 0u64)
            c_GuestExec_EmitCusaArtifactKV("audio_input_read_rc", audioin_handle)
            c_GuestExec_EmitCusaArtifactKV("audio_input_silent_state", 0u64)
            emit_flag("audio_input_closed", false)

        AudioIn_ShutdownBackends()
        AudioOut_ShutdownBackends()
        smoke_assert(sceUserServiceTerminate() == ORBIS_OK, "user service terminate failed")
        c_GuestExec_EmitCusaArtifactKV("runtime_services_smoke_complete", 1u64)
