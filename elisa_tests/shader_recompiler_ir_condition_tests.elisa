include "../shader_recompiler/ir/condition.elisa"
include "../../compiler/runtime/elisacore_std/elisacore_runtime.elisa"

@test
def condition_names_match_cpp() -> void:
    can Abort.Panic:
        assert ShaderIrCondition_NameOf(IR_CONDITION_FALSE) == "False"
        assert ShaderIrCondition_NameOf(IR_CONDITION_TRUE) == "True"
        assert ShaderIrCondition_NameOf(IR_CONDITION_SCC0) == "Scc0"
        assert ShaderIrCondition_NameOf(IR_CONDITION_SCC1) == "Scc1"
        assert ShaderIrCondition_NameOf(IR_CONDITION_VCCZ) == "Vccz"
        assert ShaderIrCondition_NameOf(IR_CONDITION_VCCNZ) == "Vccnz"
        assert ShaderIrCondition_NameOf(IR_CONDITION_EXECZ) == "Execz"
        assert ShaderIrCondition_NameOf(IR_CONDITION_EXECNZ) == "Execnz"

@test
def condition_values_are_sequential() -> void:
    can Abort.Panic:
        # Mirrors the C++ enum ordering (False=0 .. Execnz=7).
        assert IR_CONDITION_FALSE == 0u32
        assert IR_CONDITION_EXECNZ == 7u32
