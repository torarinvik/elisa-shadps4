include "../../compiler/runtime/elisacore_std/elisacore_runtime.elisa"
include "../common/arch.elisa"
include "../common/io_file.elisa"
include "../common/path_util.elisa"
include "../common/string_util.elisa"
include "../common/va_ctx.elisa"

type s32 = i32
type s64 = i64

include "../core/file_sys/bridge.elisa"
include "../core/file_sys/fs.elisa"
include "../core/libraries/kernel/file_system.elisa"

global mutable g_kernel_file_test_errno: int = 0

def __Error() -> void&?:
    return g_kernel_file_test_errno.ref[mutable int&].cast[void&]

def SetPosixErrno(e: int) -> void:
    g_kernel_file_test_errno <- e

def ErrnoToSceKernelError(err: int) -> int:
    return ORBIS_KERNEL_ERROR_UNKNOWN + err

@test
def kernel_file_sys_smoke_existing_asset_is_readable() -> void:
    can Abort.Panic, Memory.Allocate:
        asset: static u8& = "/etc/hosts"
        assert fs_exists(asset)
        f: mutable IOFile = IOFile_opened(asset, FileAccessMode.Read, FileType.BinaryFile, FileShareFlag.ShareReadWrite)
        assert IOFile_IsOpen(f)
        assert IOFile_GetSize(f) > 0
        IOFile_Close(f)

@test
def kernel_file_sys_smoke_resolves_app0_path() -> void:
    can Abort.Panic, Memory.Allocate:
        KernelFile_ResetForTest()
        app0: static u8& = "/etc"
        KernelFile_MountForTest(app0, "/app0", false)
        read_only: mutable bool = true
        resolved: static u8& = KernelFile_ResolveHostPath("/app0/hosts", read_only.ref[mutable bool&])
        assert read_only == false
        assert streq(resolved, "/etc/hosts") == 1

@test
def kernel_file_sys_open_read_lseek_stat_close_app0_asset() -> void:
    can Abort.Panic, Memory.Allocate:
        KernelFile_ResetForTest()
        app0: static u8& = "/etc"
        asset: static u8& = "/etc/hosts"
        assert fs_exists(asset)

        KernelFile_MountForTest(app0, "/app0", false)
        fd: int = sceKernelOpen("/app0/hosts".cast[u8&?], 0, null)
        assert fd >= 3
        st: mutable OrbisKernelStat = zeroed
        assert sceKernelStat("/app0/hosts".cast[u8&?], st.ref[mutable OrbisKernelStat&].cast[void&?]) == ORBIS_OK
        assert st.st_size > 5
        assert st.st_mode == KERNEL_FILE_REGULAR_MODE

        fst: mutable OrbisKernelStat = zeroed
        assert posix_fstat(fd, fst.ref[mutable OrbisKernelStat&].cast[void&?]) == ORBIS_OK
        assert fst.st_size == st.st_size

        buf: mutable array[u8, 3] = zeroed
        assert sceKernelRead(fd, buf[0].ref[mutable void&], 3) == 3
        assert buf[0] != 0
        assert sceKernelLseek(fd, 1, 0) == 1
        one: mutable array[u8, 1] = zeroed
        assert posix_read(fd, one[0].ref[mutable void&], 1) == 1
        assert one[0] != 0
        assert sceKernelLseek(fd, -1, 2) == st.st_size - 1
        assert sceKernelRead(fd, one[0].ref[mutable void&], 1) == 1
        assert one[0] != 0
        assert sceKernelClose(fd) == ORBIS_OK
        assert posix_read(fd, one[0].ref[mutable void&], 1) == -1

@test
def kernel_file_sys_invalid_fd_and_null_pointer_ordering() -> void:
    can Abort.Panic, Memory.Allocate:
        KernelFile_ResetForTest()
        assert posix_read(99, null, 4) == -1
        assert sceKernelRead(99, null, 4) == ORBIS_KERNEL_ERROR_EBADF.i64()
        assert posix_lseek(99, 0, 0) == -1
        assert sceKernelLseek(99, 0, 0) == ORBIS_KERNEL_ERROR_EBADF.i64()
        assert posix_close(99) == -1
        assert sceKernelClose(99) == ORBIS_KERNEL_ERROR_EBADF
        assert posix_stat(null, null) == -1
        assert sceKernelStat(null, null) == ORBIS_KERNEL_ERROR_EFAULT

@test
def kernel_file_sys_write_pread_pwrite_roundtrip() -> void:
    can Abort.Panic, Memory.Allocate:
        KernelFile_ResetForTest()
        KernelFile_MountForTest("/tmp", "/app0", false)
        guest_path: static u8& = "/app0/elisa_fs_roundtrip.bin"
        host_path: static u8& = KernelFile_ResolveHostPath(guest_path, null)
        if fs_exists(host_path):
            _ = posix_unlink(guest_path.cast[u8&?])

        fd: int = sceKernelOpen(guest_path.cast[u8&?], ORBIS_KERNEL_O_RDWR | ORBIS_KERNEL_O_CREAT, null)
        assert fd >= 3

        payload: mutable array[u8, 5] = zeroed
        payload[0] <- 'a'.u8()
        payload[1] <- 'b'.u8()
        payload[2] <- 'c'.u8()
        payload[3] <- 'd'.u8()
        payload[4] <- 'e'.u8()
        assert posix_write(fd, payload[0].ref[mutable void&], 5) == 5

        patch: mutable array[u8, 1] = zeroed
        patch[0] <- 'Z'.u8()
        assert posix_pwrite(fd, patch[0].ref[mutable void&], 1, 1) == 1

        out: mutable array[u8, 5] = zeroed
        assert posix_pread(fd, out[0].ref[mutable void&], 5, 0) == 5
        assert out[0] == 'a'.u8()
        assert out[1] == 'Z'.u8()
        assert out[2] == 'c'.u8()
        assert out[3] == 'd'.u8()
        assert out[4] == 'e'.u8()

        assert sceKernelClose(fd) == ORBIS_OK
        assert posix_unlink(guest_path.cast[u8&?]) == ORBIS_OK

@test
def kernel_file_sys_write_error_ordering_invalid_fd() -> void:
    can Abort.Panic, Memory.Allocate:
        KernelFile_ResetForTest()
        KernelFile_MountForTest("/tmp", "/app0", false)

        bad_write: i64 = posix_write(99, null, 4)
        assert bad_write == -1
        assert sceKernelWrite(99, null, 4) == ORBIS_KERNEL_ERROR_EBADF.i64()

@test
def kernel_file_sys_getdents_error_ordering() -> void:
    can Abort.Panic, Memory.Allocate:
        KernelFile_ResetForTest()
        KernelFile_MountForTest("/tmp", "/app0", false)

        dir_fd: int = sceKernelOpen("/app0".cast[u8&?], ORBIS_KERNEL_O_RDONLY | ORBIS_KERNEL_O_DIRECTORY, null)
        assert dir_fd >= 3
        tiny: mutable array[u8, 8] = zeroed
        assert posix_getdents(dir_fd, null, 1024) == -1
        assert posix_getdents(dir_fd, tiny[0].ref[mutable u8&], 8) == -1
        assert sceKernelClose(dir_fd) == ORBIS_OK

@test
def kernel_file_sys_directory_open_close() -> void:
    can Abort.Panic, Memory.Allocate:
        KernelFile_ResetForTest()
        KernelFile_MountForTest("/tmp", "/app0", false)
        dir_fd: int = sceKernelOpen("/app0".cast[u8&?], ORBIS_KERNEL_O_RDONLY | ORBIS_KERNEL_O_DIRECTORY, null)
        assert dir_fd >= 3
        assert sceKernelClose(dir_fd) == ORBIS_OK

@test
def kernel_file_sys_getdirentries_emits_dirents_and_updates_basep() -> void:
    can Abort.Panic, Memory.Allocate:
        KernelFile_ResetForTest()
        KernelFile_MountForTest("/tmp", "/app0", false)

        dir_guest: static u8& = "/app0/elisa_fs_getdents_dir"
        file_guest: static u8& = "/app0/elisa_fs_getdents_dir/item.txt"
        dir_host: static u8& = KernelFile_ResolveHostPath(dir_guest, null)
        file_host: static u8& = KernelFile_ResolveHostPath(file_guest, null)
        if fs_exists(file_host):
            _ = posix_unlink(file_guest.cast[u8&?])
        if fs_exists(dir_host):
            _ = posix_rmdir(dir_guest.cast[u8&?])

        assert posix_mkdir(dir_guest.cast[u8&?], 0x1ff) == ORBIS_OK
        item_fd: int = sceKernelOpen(file_guest.cast[u8&?], ORBIS_KERNEL_O_RDWR | ORBIS_KERNEL_O_CREAT, null)
        assert item_fd >= 3
        assert sceKernelClose(item_fd) == ORBIS_OK

        dir_fd: int = sceKernelOpen(dir_guest.cast[u8&?], ORBIS_KERNEL_O_RDONLY | ORBIS_KERNEL_O_DIRECTORY, null)
        assert dir_fd >= 3
        out: mutable array[u8, 2048] = zeroed
        basep: mutable i64 = 0
        first: i64 = sceKernelGetdirentries(dir_fd, out[0].ref[mutable u8&], 2048, basep.ref[mutable i64&].cast[void&])
        assert first > 0
        assert basep > 0
        reclen: u16 = (out[4].u16() | (out[5].u16() << 8)).u16()
        assert reclen >= 24
        prev_basep: i64 = basep
        second: i64 = sceKernelGetdirentries(dir_fd, out[0].ref[mutable u8&], 2048, basep.ref[mutable i64&].cast[void&])
        assert second >= 0
        assert basep >= prev_basep
        assert sceKernelClose(dir_fd) == ORBIS_OK

        assert posix_unlink(file_guest.cast[u8&?]) == ORBIS_OK
        assert posix_rmdir(dir_guest.cast[u8&?]) == ORBIS_OK

@test
def kernel_file_sys_mkdir_rename_unlink_rmdir_cycle() -> void:
    can Abort.Panic, Memory.Allocate:
        KernelFile_ResetForTest()
        KernelFile_MountForTest("/tmp", "/sandbox", false)

        dir_guest: static u8& = "/sandbox/elisa_fs_dir"
        file_a_guest: static u8& = "/sandbox/elisa_fs_dir/a.txt"
        file_b_guest: static u8& = "/sandbox/elisa_fs_dir/b.txt"
        dir_host: static u8& = KernelFile_ResolveHostPath(dir_guest, null)
        file_a_host: static u8& = KernelFile_ResolveHostPath(file_a_guest, null)
        file_b_host: static u8& = KernelFile_ResolveHostPath(file_b_guest, null)

        if fs_exists(file_a_host):
            _ = posix_unlink(file_a_guest.cast[u8&?])
        if fs_exists(file_b_host):
            _ = posix_unlink(file_b_guest.cast[u8&?])
        if fs_exists(dir_host):
            _ = posix_rmdir(dir_guest.cast[u8&?])

        assert posix_mkdir(dir_guest.cast[u8&?], 0x1ff) == ORBIS_OK
        assert fs_exists(dir_host)

        fd: int = sceKernelOpen(file_a_guest.cast[u8&?], ORBIS_KERNEL_O_RDWR | ORBIS_KERNEL_O_CREAT, null)
        assert fd >= 3
        one: mutable array[u8, 1] = zeroed
        one[0] <- 'x'.u8()
        assert posix_write(fd, one[0].ref[mutable void&], 1) == 1
        assert sceKernelClose(fd) == ORBIS_OK
        assert fs_exists(file_a_host)

        assert posix_rename(file_a_guest.cast[u8&?], file_b_guest.cast[u8&?]) == ORBIS_OK
        assert not fs_exists(file_a_host)
        assert fs_exists(file_b_host)

        assert posix_unlink(file_b_guest.cast[u8&?]) == ORBIS_OK
        assert not fs_exists(file_b_host)

        assert posix_rmdir(dir_guest.cast[u8&?]) == ORBIS_OK
        assert not fs_exists(dir_host)
