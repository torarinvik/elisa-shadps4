include "../shader_recompiler/frontend/opcodes_map.elisa"
include "../../compiler/runtime/elisacore_std/elisacore_runtime.elisa"

@test
def opcode_map_cumulative_offsets() -> void:
    can Abort.Panic:
        # First map starts at 0.
        assert OPCODE_MAP_OP_MAP_SOP2 == 0u32
        # Each subsequent base is the running sum of preceding OP_RANGE sizes.
        assert OPCODE_MAP_OP_MAP_SOPK == OPCODE_SOP2_OP_RANGE_SOP2
        assert OPCODE_MAP_OP_MAP_SOP1 == OPCODE_MAP_OP_MAP_SOPK + OPCODE_SOPK_OP_RANGE_SOPK
        # VINTRP sits just past VOP3's 1024-wide block.
        assert OPCODE_MAP_OP_MAP_VINTRP == OPCODE_MAP_OP_MAP_VOP3 + 1024u32
        # Bases are strictly increasing.
        assert OPCODE_MAP_OP_MAP_VOP3P > OPCODE_MAP_OP_MAP_EXP
        assert OPMAP_VOP3_VOPX_VOP3_TO_VOP1 == 384u32
