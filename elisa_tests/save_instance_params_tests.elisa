include "../core/libraries/save_data/save_instance.elisa"
include "../../compiler/runtime/elisacore_std/elisacore_runtime.elisa"

@test
def save_params_keys_match_text() -> void:
    can Abort.Panic:
        assert SaveParam_AccountId() == "ACCOUNT_ID"
        assert SaveParam_Attribute() == "ATTRIBUTE"
        assert SaveParam_Category() == "CATEGORY"
        assert SaveParam_Detail() == "DETAIL"
        assert SaveParam_Format() == "FORMAT"
        assert SaveParam_MainTitle() == "MAINTITLE"
        assert SaveParam_Params() == "PARAMS"
        assert SaveParam_SaveDataBlocks() == "SAVEDATA_BLOCKS"
        assert SaveParam_SaveDataDirectory() == "SAVEDATA_DIRECTORY"
        assert SaveParam_SaveDataListParam() == "SAVEDATA_LIST_PARAM"
        assert SaveParam_SubTitle() == "SUBTITLE"
        assert SaveParam_TitleId() == "TITLE_ID"
