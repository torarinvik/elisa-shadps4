include "../common/streq.elisa"
include "../video_core/renderer_vulkan/vk_wait_diagnostics.elisa"

@test
def vulkan_gpu_command_diagnostics_records_ring_when_enabled() -> void:
    can Abort.Panic:
        VulkanGpuCommandDiagnostics_Reset()
        if VulkanGpuCommandDiagnostics_Record(10.u32()) != 0.u64():
            panic("expected disabled diagnostic record to be ignored")
        VulkanGpuCommandDiagnostics_SetEnabled(true)
        if VulkanGpuCommandDiagnostics_Record(10.u32()) != 1.u64():
            panic("expected first diagnostic serial")
        if VulkanGpuCommandDiagnostics_Record(11.u32()) != 2.u64():
            panic("expected second diagnostic serial")
        if VulkanGpuCommandDiagnostics_Dump(99.u32()) != 2.u64():
            panic("expected latest diagnostic serial on dump")
        if VulkanGpuCommandDiagnostics.last_dump_reason_code != 99.u32():
            panic("expected dump reason to be recorded")

@test
def vulkan_wait_diagnostics_models_timeout_retry_and_fatal_policy() -> void:
    can Abort.Panic:
        VulkanGpuCommandDiagnostics_Reset()
        VulkanGpuCommandDiagnostics_SetEnabled(true)
        _ = VulkanGpuCommandDiagnostics_Record(55.u32())
        VulkanGpuWaitDiagnostics_Reset()
        VulkanGpuWaitDiagnostics_Configure("25", "3", "1", "0")
        if not VulkanGpuWaitDiagnostics_IsFiniteTimeoutEnabled():
            panic("expected finite timeout")
        if VulkanGpuWaitDiagnostics.timeout_ns != 25000000.u64():
            panic("expected timeout ns conversion")
        if VulkanGpuWaitDiagnostics_AbortIfRetryLimitReached(7.u32(), 2.u32()):
            panic("expected retry below limit")
        if not VulkanGpuWaitDiagnostics_AbortIfRetryLimitReached(7.u32(), 3.u32()):
            panic("expected fatal retry limit")
        if VulkanGpuCommandDiagnostics.last_dump_reason_code != 7.u32():
            panic("expected timeout to dump gpu diagnostics")
