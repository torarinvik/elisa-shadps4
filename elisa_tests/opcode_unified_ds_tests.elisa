include "../shader_recompiler/frontend/opcode_unified_ds.elisa"
include "../../compiler/runtime/elisacore_std/elisacore_runtime.elisa"

@test
def opcode_unified_ds_values() -> void:
    can Abort.Panic:
        assert OPCODE_DS_ADD_U32 == OPCODE_MAP_OP_MAP_DS
        assert OPCODE_DS_AND_B32 == 9u32 + OPCODE_MAP_OP_MAP_DS
        assert OPCODE_DS_READ_B128 == 255u32 + OPCODE_MAP_OP_MAP_DS
        assert OPCODE_DS_ADD_U32 != OPCODE_DS_SUB_U32
        assert OPCODE_DS_WRITE_B96 != OPCODE_DS_WRITE_B128
