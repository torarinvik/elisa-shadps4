include "../shader_recompiler/info_persistent.elisa"
include "../../compiler/runtime/elisacore_std/elisacore_runtime.elisa"

@test
def info_persistent_constructor_defaults() -> void:
    can Abort.Panic:
        info: mutable InfoPersistent = InfoPersistent_New(
            SHADER_STAGE_FRAGMENT, SHADER_LOGICAL_STAGE_FRAGMENT, 0xDEADBEEFu64)
        assert info.stage == SHADER_STAGE_FRAGMENT
        assert info.l_stage == SHADER_LOGICAL_STAGE_FRAGMENT
        assert info.pgm_hash == 0xDEADBEEFu64
        # C++ default member initializers.
        assert info.tess_consts_dword_offset == -1i32
        assert info.tess_consts_ptr_base == IR_NUM_SCALAR_REGS
        # Zero-initialized remainder.
        assert info.fetch_shader_sgpr_base == 0u32
        assert info.mrt_mask == 0u8
        assert info.has_fetch_shader == false
        assert info.uses_dma == false
        assert info.ud_mask.mask == 0u32

@test
def info_persistent_ud_mask_roundtrip() -> void:
    can Abort.Panic:
        info: mutable InfoPersistent = InfoPersistent_New(
            SHADER_STAGE_COMPUTE, SHADER_LOGICAL_STAGE_COMPUTE, 1u64)
        UserDataMask_Set(info.ud_mask.ref[mutable UserDataMask&], 4u32)
        UserDataMask_Set(info.ud_mask.ref[mutable UserDataMask&], 8u32)
        assert UserDataMask_NumRegs(info.ud_mask.ref[UserDataMask&]) == 2u32
        assert UserDataMask_Index(info.ud_mask.ref[UserDataMask&], 8u32) == 1u32
        assert info.stage == SHADER_STAGE_COMPUTE
