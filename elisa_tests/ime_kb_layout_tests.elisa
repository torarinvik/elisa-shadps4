include "../core/libraries/ime/ime_kb_layout.elisa"
include "../../compiler/runtime/elisacore_std/elisacore_runtime.elisa"

@test
def ime_kb_layout_enum_values() -> void:
    can Abort.Panic:
        assert IME_KB_LAYOUT_FAMILY_SPECIALS == 2
        assert IME_KB_CASE_STATE_CAPS_LOCK == 2
        assert IME_KB_LAYOUT_ID_SPECIALS_PAGE2 == 6
        assert IME_KB_KEY_ACTION_PAGE_NEXT == 17
        assert IME_KB_KEY_GLYPH_CAPS_LOCK_FILLED == 8
        assert IME_TOP_PANEL_ELEMENT_ID_CLOSE == 1
        assert IME_SELECTION_KEYBOARD_MAX_COL == 9
        assert IME_SELECTION_DEFAULT_FUNCTION_ROWS == 2

@test
def ime_kb_layout_selection_roundtrip() -> void:
    can Abort.Panic:
        sel: mutable ImeKbLayoutSelection = zeroed
        assert sel.family == 0
        assert sel.case_state == 0
        assert sel.page == 0
        sel.family <- IME_KB_LAYOUT_FAMILY_SYMBOLS.cast[u8]
        sel.case_state <- IME_KB_CASE_STATE_UPPER.cast[u8]
        sel.page <- 1
        assert sel.family == 1
        assert sel.case_state == 1
        assert sel.page == 1

@test
def ime_top_panel_element_spec_roundtrip() -> void:
    can Abort.Panic:
        e: mutable ImeTopPanelElementSpec = zeroed
        e.id <- IME_TOP_PANEL_ELEMENT_ID_PREDICTION.cast[u8]
        e.col <- 3
        e.col_span <- 2
        assert e.id == 0
        assert e.col == 3
        assert e.col_span == 2

@test
def ime_edge_wrap_nav_state_roundtrip() -> void:
    can Abort.Panic:
        s: mutable ImeEdgeWrapNavState = zeroed
        assert s.last_step_time == 0.0
        assert s.hold_active == false
        s.last_step_row <- -1
        s.hold_release_time <- 1.5
        s.hold_active <- true
        assert s.last_step_row == -1
        assert s.hold_release_time == 1.5
        assert s.hold_active == true
