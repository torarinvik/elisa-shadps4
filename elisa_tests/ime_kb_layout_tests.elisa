include "../core/libraries/ime/ime_kb_layout.elisa"
include "../../compiler/runtime/elisacore_std/elisacore_runtime.elisa"

@test
def ime_kb_layout_enum_values() -> void:
    can Abort.Panic:
        assert IME_KB_LAYOUT_FAMILY_SPECIALS == 2u32
        assert IME_KB_CASE_STATE_CAPS_LOCK == 2u32
        assert IME_KB_LAYOUT_ID_SPECIALS_PAGE2 == 6u32
        assert IME_KB_KEY_ACTION_PAGE_NEXT == 17u32
        assert IME_KB_KEY_GLYPH_CAPS_LOCK_FILLED == 8u32
        assert IME_TOP_PANEL_ELEMENT_ID_CLOSE == 1u32
        assert IME_SELECTION_KEYBOARD_MAX_COL == 9u32
        assert IME_SELECTION_DEFAULT_FUNCTION_ROWS == 2u32

@test
def ime_kb_layout_selection_roundtrip() -> void:
    can Abort.Panic:
        sel: mutable ImeKbLayoutSelection = zeroed
        assert sel.family == 0u8
        assert sel.case_state == 0u8
        assert sel.page == 0u8
        sel.family <- IME_KB_LAYOUT_FAMILY_SYMBOLS.cast[u8]
        sel.case_state <- IME_KB_CASE_STATE_UPPER.cast[u8]
        sel.page <- 1u8
        assert sel.family == 1u8
        assert sel.case_state == 1u8
        assert sel.page == 1u8

@test
def ime_top_panel_element_spec_roundtrip() -> void:
    can Abort.Panic:
        e: mutable ImeTopPanelElementSpec = zeroed
        e.id <- IME_TOP_PANEL_ELEMENT_ID_PREDICTION.cast[u8]
        e.col <- 3u8
        e.col_span <- 2u8
        assert e.id == 0u8
        assert e.col == 3u8
        assert e.col_span == 2u8

@test
def ime_edge_wrap_nav_state_roundtrip() -> void:
    can Abort.Panic:
        s: mutable ImeEdgeWrapNavState = zeroed
        assert s.last_step_time == 0.0f64
        assert s.hold_active == false
        s.last_step_row <- -1i32
        s.hold_release_time <- 1.5f64
        s.hold_active <- true
        assert s.last_step_row == -1i32
        assert s.hold_release_time == 1.5f64
        assert s.hold_active == true
