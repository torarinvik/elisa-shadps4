include "../core/libraries/gnmdriver/gnmdriver_init.elisa"
include "../../compiler/runtime/elisacore_std/elisacore_runtime.elisa"

@test
def gnmdriver_init_packet_size_matches_cpp() -> void:
    can Abort.Panic:
        assert GNM_HW_INIT_PACKET_SIZE == 0x100

@test
def gnmdriver_init_sequences_match_cpp() -> void:
    can Abort.Panic:
        # The helpers return a zero-copy view over the static const tables.
        seq: view[u32] = GnmInitSequence()
        assert seq.len == 117
        assert arena_da_view_get(seq, 0) == 0xc0001200
        assert arena_da_view_get(seq, 1) == 0
        assert arena_da_view_get(seq, 2) == 0xc0017600
        assert arena_da_view_get(seq, seq.len - 1) == 0xe0000000
        assert arena_da_view_get(seq, seq.len - 2) == 0x200

        s175: view[u32] = GnmInitSequence175()
        assert s175.len == 117
        assert arena_da_view_get(s175, 0) == 0xc0001200
        assert arena_da_view_get(s175, 102) == 0x6020000

        s200: view[u32] = GnmInitSequence200()
        assert s200.len == 120
        assert arena_da_view_get(s200, 0) == 0xc0001200

        s200neo: view[u32] = GnmInitSequence200Neo()
        assert s200neo.len == 133
        assert arena_da_view_get(s200neo, s200neo.len - 1) == 0x6d007f

        s200neoc: view[u32] = GnmInitSequence200NeoCompat()
        assert s200neoc.len == 133
        assert arena_da_view_get(s200neoc, s200neoc.len - 1) == 0xd00ff

        s350: view[u32] = GnmInitSequence350()
        assert s350.len == 126
        assert arena_da_view_get(s350, s350.len - 1) == 0xff

        s350neo: view[u32] = GnmInitSequence350Neo()
        assert s350neo.len == 136

        s350neoc: view[u32] = GnmInitSequence350NeoCompat()
        assert s350neoc.len == 136

        ctx: view[u32] = GnmCtxInitSequence()
        assert ctx.len == 15
        assert arena_da_view_get(ctx, 0) == 0xc0012800

        ctxneo: view[u32] = GnmCtxInitSequenceNeo()
        assert ctxneo.len == 19
        assert arena_da_view_get(ctxneo, ctxneo.len - 2) == 0xc00d1000

        ctx400: view[u32] = GnmCtxInitSequence400()
        assert ctx400.len == 97
        assert arena_da_view_get(ctx400, ctx400.len - 1) == 0xc09e1000

        ctx400neo: view[u32] = GnmCtxInitSequence400Neo()
        assert ctx400neo.len == 101
        assert arena_da_view_get(ctx400neo, ctx400neo.len - 1) == 0xc09a1000

        ctx400neoc: view[u32] = GnmCtxInitSequence400NeoCompat()
        assert ctx400neoc.len == 101
        assert arena_da_view_get(ctx400neoc, ctx400neoc.len - 1) == 0xc09a1000
