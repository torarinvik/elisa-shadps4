include "../core/libraries/gnmdriver/gnmdriver_init.elisa"
include "../../compiler/runtime/elisacore_std/elisacore_runtime.elisa"

@test
def gnmdriver_init_packet_size_matches_cpp() -> void:
    can Abort.Panic:
        assert GNM_HW_INIT_PACKET_SIZE == 0x100u32

@test
def gnmdriver_init_sequences_match_cpp() -> void:
    can Abort.Panic:
        # The helpers return a zero-copy dview over the static const tables.
        seq: dview[u32] = GnmInitSequence()
        assert seq.len == 117usize
        assert arena_da_view_get(seq, 0usize) == 0xc0001200u32
        assert arena_da_view_get(seq, 1usize) == 0u32
        assert arena_da_view_get(seq, 2usize) == 0xc0017600u32
        assert arena_da_view_get(seq, seq.len - 1usize) == 0xe0000000u32
        assert arena_da_view_get(seq, seq.len - 2usize) == 0x200u32

        s175: dview[u32] = GnmInitSequence175()
        assert s175.len == 117usize
        assert arena_da_view_get(s175, 0usize) == 0xc0001200u32
        assert arena_da_view_get(s175, 102usize) == 0x6020000u32

        s200: dview[u32] = GnmInitSequence200()
        assert s200.len == 120usize
        assert arena_da_view_get(s200, 0usize) == 0xc0001200u32

        s200neo: dview[u32] = GnmInitSequence200Neo()
        assert s200neo.len == 133usize
        assert arena_da_view_get(s200neo, s200neo.len - 1usize) == 0x6d007fu32

        s200neoc: dview[u32] = GnmInitSequence200NeoCompat()
        assert s200neoc.len == 133usize
        assert arena_da_view_get(s200neoc, s200neoc.len - 1usize) == 0xd00ffu32

        s350: dview[u32] = GnmInitSequence350()
        assert s350.len == 126usize
        assert arena_da_view_get(s350, s350.len - 1usize) == 0xffu32

        s350neo: dview[u32] = GnmInitSequence350Neo()
        assert s350neo.len == 136usize

        s350neoc: dview[u32] = GnmInitSequence350NeoCompat()
        assert s350neoc.len == 136usize

        ctx: dview[u32] = GnmCtxInitSequence()
        assert ctx.len == 15usize
        assert arena_da_view_get(ctx, 0usize) == 0xc0012800u32

        ctxneo: dview[u32] = GnmCtxInitSequenceNeo()
        assert ctxneo.len == 19usize
        assert arena_da_view_get(ctxneo, ctxneo.len - 2usize) == 0xc00d1000u32

        ctx400: dview[u32] = GnmCtxInitSequence400()
        assert ctx400.len == 97usize
        assert arena_da_view_get(ctx400, ctx400.len - 1usize) == 0xc09e1000u32

        ctx400neo: dview[u32] = GnmCtxInitSequence400Neo()
        assert ctx400neo.len == 101usize
        assert arena_da_view_get(ctx400neo, ctx400neo.len - 1usize) == 0xc09a1000u32

        ctx400neoc: dview[u32] = GnmCtxInitSequence400NeoCompat()
        assert ctx400neoc.len == 101usize
        assert arena_da_view_get(ctx400neoc, ctx400neoc.len - 1usize) == 0xc09a1000u32
