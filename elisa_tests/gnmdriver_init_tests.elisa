include "../core/libraries/gnmdriver/gnmdriver_init.elisa"
include "../../compiler/runtime/elisacore_std/elisacore_runtime.elisa"

@test
def gnmdriver_init_packet_size_matches_cpp() -> void:
    can Abort.Panic:
        assert GNM_HW_INIT_PACKET_SIZE == 0x100u32

@test
def gnmdriver_init_sequences_match_cpp() -> void:
    can Abort.Panic:
        owner: mutable Arena& = scratch_arena.ref[mutable Arena&]

        seq: darray[u32] = GnmInitSequence(owner)
        assert seq.count == 117usize
        assert seq[0usize] == 0xc0001200u32
        assert seq[1usize] == 0u32
        assert seq[2usize] == 0xc0017600u32
        assert seq[seq.count - 1usize] == 0xe0000000u32
        assert seq[seq.count - 2usize] == 0x200u32

        s175: darray[u32] = GnmInitSequence175(owner)
        assert s175.count == 117usize
        assert s175[0usize] == 0xc0001200u32
        assert s175[102usize] == 0x6020000u32

        s200: darray[u32] = GnmInitSequence200(owner)
        assert s200.count == 120usize
        assert s200[0usize] == 0xc0001200u32

        s200neo: darray[u32] = GnmInitSequence200Neo(owner)
        assert s200neo.count == 133usize
        assert s200neo[s200neo.count - 1usize] == 0x6d007fu32

        s200neoc: darray[u32] = GnmInitSequence200NeoCompat(owner)
        assert s200neoc.count == 133usize
        assert s200neoc[s200neoc.count - 1usize] == 0xd00ffu32

        s350: darray[u32] = GnmInitSequence350(owner)
        assert s350.count == 126usize
        assert s350[s350.count - 1usize] == 0xffu32

        s350neo: darray[u32] = GnmInitSequence350Neo(owner)
        assert s350neo.count == 136usize

        s350neoc: darray[u32] = GnmInitSequence350NeoCompat(owner)
        assert s350neoc.count == 136usize

        ctx: darray[u32] = GnmCtxInitSequence(owner)
        assert ctx.count == 15usize
        assert ctx[0usize] == 0xc0012800u32

        ctxneo: darray[u32] = GnmCtxInitSequenceNeo(owner)
        assert ctxneo.count == 19usize
        assert ctxneo[ctxneo.count - 2usize] == 0xc00d1000u32

        ctx400: darray[u32] = GnmCtxInitSequence400(owner)
        assert ctx400.count == 97usize
        assert ctx400[ctx400.count - 1usize] == 0xc09e1000u32

        ctx400neo: darray[u32] = GnmCtxInitSequence400Neo(owner)
        assert ctx400neo.count == 101usize
        assert ctx400neo[ctx400neo.count - 1usize] == 0xc09a1000u32

        ctx400neoc: darray[u32] = GnmCtxInitSequence400NeoCompat(owner)
        assert ctx400neoc.count == 101usize
        assert ctx400neoc[ctx400neoc.count - 1usize] == 0xc09a1000u32
