include "../core/libraries/save_data/save_backup.elisa"
include "../../compiler/runtime/elisacore_std/elisacore_runtime.elisa"

@test
def save_backup_enums() -> void:
    can Abort.Panic:
        assert SAVE_BACKUP_WORKER_STATUS_STOPPING == 3
        assert SAVE_DATA_EVENT_TYPE_BACKUP == 2
        assert SAVE_DATA_EVENT_TYPE_DO_NOT_SAVE == 1000000
