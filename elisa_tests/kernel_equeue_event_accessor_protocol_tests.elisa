include "../core/libraries/kernel/equeue.elisa"

def event_accessor_null_default[A: EventAccessor](accessor: A) -> u64:
    return accessor.get(null)

@property
def fuzz_EventAccessor_id_null_default(_seed: i32) -> bool:
    accessor: EventIdAccessor = EventIdAccessor{tag: 0}
    return event_accessor_null_default[EventIdAccessor](accessor) == 0

@property
def fuzz_EventAccessor_data_null_default(_seed: i32) -> bool:
    accessor: EventDataAccessor = EventDataAccessor{tag: 0}
    return event_accessor_null_default[EventDataAccessor](accessor) == 0

@property
def fuzz_EventAccessor_id_garbage_value(seed: i32) -> bool:
    ev: mutable OrbisKernelEvent = zeroed
    ev.ident <- seed.u64()
    accessor: EventIdAccessor = EventIdAccessor{tag: 0}
    return accessor.get((&ev).cast[OrbisKernelEvent&?]) == seed.u64()

@property
def fuzz_EventAccessor_data_garbage_value(seed: i32) -> bool:
    ev: mutable OrbisKernelEvent = zeroed
    ev.data <- seed.u64()
    accessor: EventDataAccessor = EventDataAccessor{tag: 0}
    return accessor.get((&ev).cast[OrbisKernelEvent&?]) == seed.u64()
