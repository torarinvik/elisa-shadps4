include "../core/libraries/ime/ime_ui_shared.elisa"
include "../../compiler/runtime/elisacore_std/elisacore_runtime.elisa"

@test
def ime_ui_constants() -> void:
    can Abort.Panic:
        assert IME_UI_PANEL_EDGE_WRAP_HOLD_DELAY_SEC == 0.5f64
        assert IME_UI_REPEAT_INTENT_WINDOW_SEC == 0.45f64
        assert IME_UI_SELECTOR_FADE_OUT_DURATION_SEC == 0.2f32
        assert IME_UI_SELECTOR_PRESS_PULSE_DURATION_SEC == 0.2f32
        assert IME_UI_SELECTOR_PRESS_PULSE_EXPAND_BORDER_FACTOR == 1.0f32

@test
def osk_pad_input_frame_roundtrip() -> void:
    can Abort.Panic:
        frame: mutable OskPadInputFrame = zeroed
        assert frame.virtual_buttons == 0u32
        assert frame.cross_down == false
        assert frame.l2_analog == 0.0f32
        assert frame.virtual_lstick_dirs.left == false
        frame.virtual_buttons <- 7u32
        frame.l2_analog <- 0.75f32
        frame.cross_down <- true
        frame.virtual_lstick_dirs.up <- true
        frame.nav_down_repeat <- true
        assert frame.virtual_buttons == 7u32
        assert frame.l2_analog == 0.75f32
        assert frame.cross_down == true
        assert frame.virtual_lstick_dirs.up == true
        assert frame.virtual_lstick_dirs.down == false
        assert frame.nav_down_repeat == true
