include "../shader_recompiler/frontend/opcode_unified_buf.elisa"
include "../../compiler/runtime/elisacore_std/elisacore_runtime.elisa"

@test
def opcode_unified_buf() -> void:
    can Abort.Panic:
        assert OPCODE_BUFFER_LOAD_FORMAT_X == OPCODE_MAP_OP_MAP_MUBUF
        assert OPCODE_BUFFER_LOAD_UBYTE == 8u32 + OPCODE_MAP_OP_MAP_MUBUF
        assert OPCODE_S_LOAD_DWORD == OPCODE_MAP_OP_MAP_SMRD
        assert OPCODE_S_DCACHE_INV == 31u32 + OPCODE_MAP_OP_MAP_SMRD
        assert OPCODE_BUFFER_LOAD_FORMAT_X != OPCODE_BUFFER_WBINVL1
