include "../core/libraries/kernel/threads/pthread.elisa"
include "../../compiler/runtime/elisacore_std/elisacore_runtime.elisa"

@test
def pthread_constants_and_enums() -> void:
    can Abort.Panic:
        assert ORBIS_KERNEL_PRIO_FIFO_HIGHEST == 767i32
        assert PTHREAD_THR_STACK_DEFAULT == 1048576u32
        assert PTHREAD_THR_PAGE_SIZE == 16384u32
        assert PTHREAD_MUTEX_TYPE_NORMAL == 3u32
        assert SCHED_POLICY_ROUND_ROBIN == 3u32
        assert PTHREAD_STATE_DEAD == 1u32
