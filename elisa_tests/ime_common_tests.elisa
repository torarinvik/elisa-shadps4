include "../core/libraries/ime/ime_common.elisa"
include "../../compiler/runtime/elisacore_std/elisacore_runtime.elisa"

@test def test_ime_common_values() -> void:
    can Abort.Panic:
        assert(IME_ERROR_OK == 0u32)
        assert(IME_ERROR_BUSY == 0x80bc0001u32)
        assert(IME_ERROR_INTERNAL == 0x80bc00ffu32)
        assert(IME_OPTION_PASSWORD == 4u32)
        assert(ORBIS_IME_MAX_TEXT_LENGTH == 2048u32)
        assert(ORBIS_IME_DIALOG_MAX_TEXT_LENGTH == 2048u32)
        assert(IME_TYPE_NUMBER == 4u32)
        assert(IME_LANGUAGE_HUNGARIAN == 0x0000000100000000u64)
        assert(IME_KEYBOARD_TYPE_HUNGARIAN == 37u32)
        assert(IME_EVENT_ID_KEYBOARD_ABORT == 262u32)
        assert(IME_PANEL_TYPE_ACCESSIBILITY == 6u32)
