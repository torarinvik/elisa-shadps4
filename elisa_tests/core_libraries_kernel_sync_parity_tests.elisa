include "../core_libraries_kernel_sync_integration.elisa"

@test
def timed_mutex_basic() -> void:
    can Abort.Panic:
        mtx: mutable TimedMutex = TimedMutex_new()
        assert TimedMutex_try_lock(mtx)
        assert not TimedMutex_try_lock(mtx)
        TimedMutex_unlock(mtx)
        assert TimedMutex_try_lock_for(mtx, 1000000)
        TimedMutex_unlock(mtx)
        TimedMutex_lock(mtx)
        assert not TimedMutex_try_lock_until(mtx, 123456789)

@test
def semaphore_basic() -> void:
    can Abort.Panic:
        sem: mutable Semaphore = Semaphore_new(1, 3)
        assert Semaphore_try_acquire(sem)
        assert not Semaphore_try_acquire(sem)

        Semaphore_release(sem)
        Semaphore_acquire(sem)
        assert sem.count == 0

        Semaphore_release(sem)
        Semaphore_release(sem)
        Semaphore_release(sem)
        Semaphore_release(sem)
        assert sem.count == 3

@test
def binary_and_counting_aliases() -> void:
    can Abort.Panic:
        b: mutable BinarySemaphore = BinarySemaphore_new(0)
        assert not Semaphore_try_acquire(b)
        Semaphore_release(b)
        Semaphore_release(b)
        assert b.count == 1

        c: mutable CountingSemaphore = CountingSemaphore_new(2)
        assert c.max_count == ORBIS_KERNEL_SEM_VALUE_MAX
        assert Semaphore_try_acquire_for(c, 1)
        assert Semaphore_try_acquire_until(c, 1)
        assert not Semaphore_try_acquire(c)
