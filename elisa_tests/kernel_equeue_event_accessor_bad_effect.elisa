include "../core/libraries/kernel/equeue.elisa"

struct BadEffectEventIdAccessor:
    tag: u8

impl EventAccessor for BadEffectEventIdAccessor:
    def get(self: BadEffectEventIdAccessor, ev: OrbisKernelEvent&?) -> u64 can[Atomics.Load]:
        _ = self
        if ev == null:
            return 0
        e: OrbisKernelEvent& = ev
        return e.ident
