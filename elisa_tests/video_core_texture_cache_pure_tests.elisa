include "../../compiler/runtime/elisacore_std/elisacore_runtime.elisa"
include "../video_core/texture_cache/types.elisa"
include "../video_core/texture_cache/host_compatibility.elisa"
include "../video_core/texture_cache/image_info.elisa"
include "../video_core/texture_cache/image_view.elisa"
include "../video_core/texture_cache/sampler.elisa"
include "../video_core/texture_cache/tile.elisa"
include "../video_core/texture_cache/blit_helper.elisa"
include "../video_core/texture_cache/image.elisa"
include "../video_core/texture_cache/tile_manager.elisa"
include "../video_core/texture_cache/texture_cache.elisa"

@test
def video_core_texture_cache_types_and_compatibility_contracts() -> void:
    can Abort.Panic:
        a: Extent2D = Extent2D_new(64u32, 32u32)
        b: Extent2D = Extent2D_new(64u32, 32u32)
        c: Extent3D = Extent3D_new(64u32, 32u32, 4u32)
        d: Extent3D = Extent3D_new(64u32, 32u32, 4u32)
        assert Extent2D_eq(a, b)
        assert Extent3D_eq(c, d)

        assert IsVulkanFormatCompatible(VK_FORMAT_R8G8B8A8_UNORM, VK_FORMAT_R8G8B8A8_SRGB)
        assert not IsVulkanFormatCompatible(VK_FORMAT_R8G8B8A8_UNORM, VK_FORMAT_B8G8R8A8_UNORM)

@test
def video_core_texture_cache_image_info_and_view_contracts() -> void:
    can Abort.Panic:
        info: mutable ImageInfo = ImageInfo_FromImageResource(
            0x400000u64,
            256u32,
            128u32,
            1u32,
            256u32,
            VK_FORMAT_R8G8B8A8_UNORM,
            ImageType_Color2D,
            TileMode_DisplayLinearAligned,
            ArrayMode_ArrayLinearAligned,
            4u32,
            1u32,
            1u32,
            32u32
        )
        assert info.guest_size > 0u32
        assert ImageInfo_MipOf(info, info) == 0i64
        assert ImageInfo_SliceOf(info, info, 0i64) == 0i64
        assert ImageInfo_IsCompatible(info, info)
        assert ImageInfo_IsTiled(info) == false
        assert ImageInfo_BlockDim(info).width == 256u32

        view_info: ImageViewInfo = ImageViewInfo_FromImage(
            ImageType_Color2D,
            VK_FORMAT_R8G8B8A8_UNORM,
            0u32,
            1u32,
            0u32,
            1u32,
            TEXTURE_COMP_MAPPING_IDENTITY,
            false
        )
        view: ImageView = ImageView_New(view_info, info, 0x888u64, 0x999u64)
        assert view.valid
        assert view.handle == 0x999u64
        assert ConvertImageViewType(ImageType_Color2D) == VK_IMAGE_VIEW_TYPE_2D
        assert IsViewTypeCompatible(ImageType_Color2DArray, ImageType_Color2D)

@test
def video_core_texture_cache_sampler_and_tile_contracts() -> void:
    can Abort.Panic:
        desc: SamplerDesc = SamplerDesc_new(0x01010101u64, 0x10101010u64)
        sampler: Sampler = Sampler_New(desc, 0x44u64, true, 0x55u64)
        assert sampler.valid
        assert Sampler_Handle(sampler) == 0x55u64
        assert sampler.border_color_ptr != 0u64

        macro_ext: Extent2D = GetMacroTileExtents(ArrayMode_Array2dTiledThin, 32u32, 1u32)
        assert macro_ext.width > 0u32
        assert macro_ext.height > 0u32
        assert ImageSizeLinearAligned(64u32, 64u32, 1u32, 64u32, 32u32, 1u32) > 0u64
        assert ImageSizeMicroTiled(64u32, 64u32, 1u32, 32u32, 1u32) > 0u64
        assert ImageSizeMacroTiled(64u32, 64u32, 1u32, 64u32, 32u32, 1u32, ArrayMode_Array2dTiledThin) > 0u64

@test
def video_core_texture_cache_blit_image_tile_manager_contracts() -> void:
    can Abort.Panic, Memory.Allocate:
        info: ImageInfo = ImageInfo_FromVideoOut(0x900000u64, 128u32, 64u32, 128u32, VK_FORMAT_R8G8B8A8_UNORM, true)
        img: mutable Image = Image_New(info, 0x200u64)
        view_info: ImageViewInfo = ImageViewInfo_FromColorBuffer(VK_FORMAT_R8G8B8A8_UNORM, 1u32)
        v: ImageView = Image_FindView(img, view_info, true)
        assert v.valid
        assert img.views.count == 1usize
        assert Image_Overlaps(img, info.guest_address, info.guest_size.usize())
        Image_SetBackingSamples(img, 4u32, true)
        assert img.supported_samples == 4u32

        helper: mutable BlitHelper = BlitHelper_New(1u64, 2u64)
        BlitHelper_ReinterpretColorAsMsDepth(helper, 128u32, 64u32, 4u32, VK_FORMAT_R8G8B8A8_UNORM, VK_FORMAT_D32_SFLOAT, 0x11u64, 0x12u64)
        BlitHelper_CopyBetweenMsImages(helper, 128u32, 64u32, 4u32, VK_FORMAT_R8G8B8A8_UNORM, true, 0x11u64, 0x12u64)
        assert helper.reinterpret_count == 1u64
        assert helper.copy_count == 1u64

        owner: mutable Arena& = &scratch_arena
        stream: mutable StreamBuffer = StreamBuffer_New(owner, MEMORY_USAGE_STREAM, 1u64 << 20u64)
        tm: mutable TileManager = TileManager_New(1u64, 1u64, stream)
        out_buf: Buffer = Buffer_New(0x500000u64, 0x10000usize, MEMORY_USAGE_DEVICE_LOCAL)
        copies: mutable darray[BufferImageCopy] = []
        TileManager_TileImage(tm, img, copies, out_buf, 0u32, 4096u32)
        detile: TileManagerResult = TileManager_DetileImage(tm, 0x77u64, 0u32, info)
        assert detile.ok
        assert tm.tile_dispatch_count == 1u64
        assert tm.detile_dispatch_count == 1u64

@test
def video_core_texture_cache_surface_contracts() -> void:
    can Abort.Panic, Memory.Allocate:
        cache: mutable TextureCache = TextureCache_New(scratch_arena)
        assert cache.images.count >= 1usize
        assert cache.image_alive[0usize]

        info: ImageInfo = ImageInfo_FromImageResource(
            0x1800000u64,
            256u32,
            256u32,
            1u32,
            256u32,
            VK_FORMAT_R8G8B8A8_UNORM,
            ImageType_Color2D,
            TileMode_DisplayLinearAligned,
            ArrayMode_ArrayLinearAligned,
            1u32,
            1u32,
            1u32,
            32u32
        )
        desc: ImageDesc = ImageDesc_FromInfo(info, ImageViewInfo_FromColorBuffer(VK_FORMAT_R8G8B8A8_UNORM, 1u32), TextureCacheBindingType.Texture)
        image_id: ImageId = TextureCache_FindImage(cache, desc, false)
        assert image_id.index > 0u32

        TextureCache_InvalidateMemory(cache, info.guest_address, info.guest_size.usize())
        img: mutable Image&? = TextureCache_GetImage(cache, image_id)
        assert img != null
        assert (img.value().flags & IMAGE_FLAG_CPU_DIRTY) != 0u32

        TextureCache_UpdateImage(cache, image_id)
        assert (img.value().flags & IMAGE_FLAG_CPU_DIRTY) == 0u32

        view: ImageView = TextureCache_FindTexture(cache, image_id, desc)
        assert view.valid

        same_id: ImageId = TextureCache_FindImageFromRange(cache, info.guest_address, info.guest_size.usize(), true)
        assert ImageId_eq(same_id, image_id)

        expanded_id: ImageId = TextureCache_ExpandImage(cache, info, image_id)
        assert expanded_id.index != image_id.index

        overlap: TextureCacheResolveOverlapResult = TextureCache_ResolveOverlap(
            cache,
            info,
            TextureCacheBindingType.Texture,
            image_id,
            expanded_id
        )
        assert ImageId_eq(overlap.image_id, image_id)

        depth_info: ImageInfo = ImageInfo_FromDepthBuffer(0x1900000u64, 128u32, 128u32, 128u32, VK_FORMAT_D32_SFLOAT, 1u32, 1u32, 0x2000000u64, false)
        depth_id: ImageId = TextureCache_ResolveDepthOverlap(cache, depth_info, TextureCacheBindingType.DepthTarget, image_id)
        assert depth_id.index > 0u32

        sampler_handle_a: u64 = TextureCache_GetSampler(cache, SamplerDesc_new(0x11u64, 0x22u64), 0x33u64)
        sampler_handle_b: u64 = TextureCache_GetSampler(cache, SamplerDesc_new(0x11u64, 0x22u64), 0x33u64)
        assert sampler_handle_a == sampler_handle_b

        meta: MetaDataInfo = MetaDataInfo(
            MetaDataType.CMask,
            0i64,
            image_id,
            TextureCacheBindingType.RenderTarget,
            info.guest_address,
            info.guest_size,
            info.size,
            info.pitch,
            info.pixel_format,
            info.num_bits,
            info.num_samples,
            info.tile_mode,
            info.array_mode
        )
        TextureCache_RegisterMetaData(cache, 0xdead0000u64, meta)
        assert TextureCache_IsMeta(cache, 0xdead0000u64)
        assert TextureCache_TouchMeta(cache, 0xdead0000u64, 2u32, true)
        assert TextureCache_IsMetaCleared(cache, 0xdead0000u64, 2u32)
        assert TextureCache_ClearMeta(cache, 0xdead0000u64)

        TextureCache_InvalidateMemoryFromGPU(cache, info.guest_address, info.guest_size.usize())
        assert (img.value().flags & IMAGE_FLAG_GPU_DIRTY) != 0u32
        can Memory.Allocate:
            cache.download_images.push(image_id)
        TextureCache_ProcessDownloadImages(cache)

        TextureCache_RunGarbageCollector(cache)
        assert cache.gc_tick > 0u64
