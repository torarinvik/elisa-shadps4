include "../shader_recompiler/ir/reinterpret.elisa"
include "../../compiler/runtime/elisacore_std/elisacore_runtime.elisa"

# Helper: build a fresh program with one block and an emitter positioned in it.
def reinterpret_setup() -> mutable heap ShaderIrProgram& can[Memory.Allocate, Abort.Panic]:
    info: ShaderIrProgramInfo = zeroed
    program: mutable heap ShaderIrProgram& = ShaderIrProgram_New(info)
    _ = ShaderIrProgram_AddBlock(program)
    return program

@test
def reinterpret_none_is_identity() -> void:
    can Abort.Panic, Memory.Allocate:
        program: mutable heap ShaderIrProgram& = reinterpret_setup()
        emitter: mutable ShaderIrEmitter = ShaderIrEmitter_New(0)
        before: u32 = program.blocks[0].inst_count
        v: ShaderIrValue = ShaderIrEmitter_Imm32FromF32(0.5)
        out: ShaderIrValue = ShaderIrReinterpret_ApplyReadNumberConversion(program, emitter, v, IR_NUMBER_CONVERSION_NONE)
        # Identity: no instruction emitted, returns the input immediate.
        assert program.blocks[0].inst_count == before
        assert out.type_bits == IR_TYPE_F32
        assert out.imm_f32 == 0.5

@test
def reinterpret_unorm_to_ubnorm_first_op_is_fpmul() -> void:
    can Abort.Panic, Memory.Allocate:
        program: mutable heap ShaderIrProgram& = reinterpret_setup()
        emitter: mutable ShaderIrEmitter = ShaderIrEmitter_New(0)
        v: ShaderIrValue = ShaderIrEmitter_Imm32FromF32(0.25)
        _ = ShaderIrReinterpret_ApplyReadNumberConversion(program, emitter, v, IR_NUMBER_CONVERSION_UNORM_TO_UBNORM)
        # The conversion starts by scaling the unorm value by 2.0 (FPMUL32).
        assert program.blocks[0].inst_count >= 1
        assert program.blocks[0].insts[0].opcode == IR_OPCODE_FPMUL32

@test
def reinterpret_uint_to_uscaled_first_op_is_bitcast() -> void:
    can Abort.Panic, Memory.Allocate:
        program: mutable heap ShaderIrProgram& = reinterpret_setup()
        emitter: mutable ShaderIrEmitter = ShaderIrEmitter_New(0)
        v: ShaderIrValue = ShaderIrEmitter_Imm32FromF32(1.0)
        _ = ShaderIrReinterpret_ApplyReadNumberConversion(program, emitter, v, IR_NUMBER_CONVERSION_UINT_TO_USCALED)
        # Read path reinterprets the raw bits as u32 first (BITCASTU32F32).
        assert program.blocks[0].inst_count >= 1
        assert program.blocks[0].insts[0].opcode == IR_OPCODE_BITCASTU32F32

@test
def reinterpret_write_uint_to_uscaled_first_op_is_convert() -> void:
    can Abort.Panic, Memory.Allocate:
        program: mutable heap ShaderIrProgram& = reinterpret_setup()
        emitter: mutable ShaderIrEmitter = ShaderIrEmitter_New(0)
        v: ShaderIrValue = ShaderIrEmitter_Imm32FromF32(3.0)
        _ = ShaderIrReinterpret_ApplyWriteNumberConversion(program, emitter, v, IR_NUMBER_CONVERSION_UINT_TO_USCALED)
        # Write path converts float->uint first (CONVERTU32F32).
        assert program.blocks[0].inst_count >= 1
        assert program.blocks[0].insts[0].opcode == IR_OPCODE_CONVERTU32F32
