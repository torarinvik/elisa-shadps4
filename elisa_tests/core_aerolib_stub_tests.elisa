include "../../compiler/runtime/elisacore_std/elisacore_runtime.elisa"
include "../common/logging/log.elisa"
include "../core/aerolib/aerolib.elisa"
include "../core/aerolib/aerolib_nids.elisa"
include "../core/aerolib/aerolib_find.elisa"
include "../core/aerolib/stubs.elisa"
include "../core/aerolib/stub_handlers.elisa"
include "../core/aerolib/stubs_get.elisa"

@test
def aerolib_get_stub_records_known_and_unknown_nids() -> void:
    can Abort.Panic:
        UsedStubEntries <- 0

        known_addr: u64 = GetStub("++-URPJNZ18")
        assert known_addr != 0
        assert UsedStubEntries == 1
        known_entry: NidEntry? = stub_nids[0]
        assert known_entry != null
        known_resolved: NidEntry = known_entry
        assert AeroLib_StrCmp(known_resolved.nid, "++-URPJNZ18") == 0

        unknown_addr: u64 = GetStub("not-a-real-nid")
        assert unknown_addr != 0
        assert UsedStubEntries == 2
        assert stub_nids[1] == null
        assert AeroLib_StrCmp(stub_nids_unknown[1], "not-a-real-nid") == 0

        UsedStubEntries <- 0

@test
def aerolib_get_stub_uses_unknown_stub_when_slots_are_exhausted() -> void:
    can Abort.Panic:
        UsedStubEntries <- MAX_STUBS

        overflow_addr: u64 = GetStub("++-URPJNZ18")
        assert overflow_addr == AeroLib_UnknownStub.uintptr().u64()
        assert UsedStubEntries == MAX_STUBS

        UsedStubEntries <- 0
