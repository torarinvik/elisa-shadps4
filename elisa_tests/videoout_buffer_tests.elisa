include "../core/libraries/videoout/buffer.elisa"
include "../../compiler/runtime/elisacore_std/elisacore_runtime.elisa"

@test
def videoout_buffer_constants_and_structs() -> void:
    can Abort.Panic:
        # PixelFormat enum values.
        assert VIDEO_OUT_PIXEL_FORMAT_UNKNOWN == 0
        assert VIDEO_OUT_PIXEL_FORMAT_A8R8G8B8_SRGB == 0x80000000
        assert VIDEO_OUT_PIXEL_FORMAT_A16R16G16B16_FLOAT == 0xC1060000

        # TilingMode enum values.
        assert VIDEO_OUT_TILING_MODE_TILE == 0
        assert VIDEO_OUT_TILING_MODE_LINEAR == 1

        # Display buffer limits.
        assert VIDEO_OUT_MAX_DISPLAY_BUFFERS == 16
        assert VIDEO_OUT_MAX_DISPLAY_BUFFER_GROUPS == 4

        # Build a BufferAttribute and round-trip a few fields.
        attr: mutable BufferAttribute = zeroed
        attr.pixel_format <- VIDEO_OUT_PIXEL_FORMAT_A8R8G8B8_SRGB
        attr.tiling_mode <- VIDEO_OUT_TILING_MODE_LINEAR
        attr.aspect_ratio <- 1
        attr.width <- 1920
        attr.height <- 1080
        attr.pitch_in_pixel <- 1920
        assert attr.pixel_format == VIDEO_OUT_PIXEL_FORMAT_A8R8G8B8_SRGB
        assert attr.tiling_mode == VIDEO_OUT_TILING_MODE_LINEAR
        assert attr.width == 1920
        assert attr.height == 1080

        # BufferAttributeGroup embeds a BufferAttribute.
        grp: mutable BufferAttributeGroup = zeroed
        assert grp.is_occupied == false
        grp.is_occupied <- true
        grp.attrib.width <- 640
        assert grp.is_occupied == true
        assert grp.attrib.width == 640

        # VideoOutBuffer_New defaults group_index to -1 (mirrors C++).
        vob: VideoOutBuffer = VideoOutBuffer_New()
        assert vob.group_index == -1

        # GetPixelFormatString compiles and returns for a known format.
        name: static u8& = GetPixelFormatString(VIDEO_OUT_PIXEL_FORMAT_A8R8G8B8_SRGB)
