include "../core/libraries/videodec/native_shims/common/alignment.elisa"
include "../../compiler/runtime/elisacore_std/elisacore_runtime.elisa"

@test
def align_up_rounds_to_next_multiple() -> void:
    can Abort.Panic:
        # Already aligned -> unchanged.
        assert AlignUp_u64(16u64, 16u64) == 16u64
        # Rounding up.
        assert AlignUp_u64(17u64, 16u64) == 32u64
        assert AlignUp_u64(1u64, 16u64) == 16u64
        assert AlignUp_u64(0u64, 16u64) == 0u64
        # Non-power-of-two alignment.
        assert AlignUp_u64(10u64, 4u64) == 12u64

        assert AlignUp_u32(16u32, 16u32) == 16u32
        assert AlignUp_u32(17u32, 16u32) == 32u32
        assert AlignUp_u32(0u32, 16u32) == 0u32
        assert AlignUp_u32(10u32, 4u32) == 12u32

        assert AlignUp_usize(16usize, 16usize) == 16usize
        assert AlignUp_usize(17usize, 16usize) == 32usize
        assert AlignUp_usize(0usize, 16usize) == 0usize
        assert AlignUp_usize(10usize, 4usize) == 12usize
