include "../core/libraries/videodec/native_shims/common/alignment.elisa"
include "../../compiler/runtime/elisacore_std/elisacore_runtime.elisa"

@test
def align_up_rounds_to_next_multiple() -> void:
    can Abort.Panic:
        # Already aligned -> unchanged.
        assert AlignUp_u64(16, 16) == 16
        # Rounding up.
        assert AlignUp_u64(17, 16) == 32
        assert AlignUp_u64(1, 16) == 16
        assert AlignUp_u64(0, 16) == 0
        # Non-power-of-two alignment.
        assert AlignUp_u64(10, 4) == 12

        assert AlignUp_u32(16, 16) == 16
        assert AlignUp_u32(17, 16) == 32
        assert AlignUp_u32(0, 16) == 0
        assert AlignUp_u32(10, 4) == 12

        assert AlignUp_usize(16, 16) == 16
        assert AlignUp_usize(17, 16) == 32
        assert AlignUp_usize(0, 16) == 0
        assert AlignUp_usize(10, 4) == 12
