const ELISA_KERNEL_TEST_SLOT_COUNT: int = 64
const ELISA_KERNEL_TEST_EINVAL: int = 22
const ELISA_KERNEL_TEST_ETIMEDOUT: int = 60
const ELISA_KERNEL_TEST_PTHREAD_CANCELED: u64 = 1u64 if PLATFORM_APPLE else 0xffffffffffffffffu64

global mutable kernel_test_slots: i64[64] = zeroed
global mutable kernel_test_slots_mutex: void&? = null
global mutable kernel_test_slots_cond: void&? = null
global mutable kernel_test_support_ready: bool = false
global mutable kernel_test_cancel_once: KtPthreadOnce = KtPthreadOnce{sig: KT_PTHREAD_ONCE_SIG, opaque: 0u64}
global mutable kernel_test_cancel_key: u64 = 0u64

@fixed_layout
struct KernelTestCancelArgs:
    started_slot: mutable int
    cleanup_slot: mutable int
    tls_slot: mutable int

global mutable kernel_test_cancel_join_args: KernelTestCancelArgs = KernelTestCancelArgs{started_slot: 40, cleanup_slot: 41, tls_slot: 42}
global mutable kernel_test_cancel_timedjoin_args: KernelTestCancelArgs = KernelTestCancelArgs{started_slot: 43, cleanup_slot: 44, tls_slot: 45}

def elisa_kernel_test_valid_slot(slot: int) -> bool:
    return slot >= 0 and slot < ELISA_KERNEL_TEST_SLOT_COUNT

def elisa_kernel_test_ensure_support() -> void:
    if kernel_test_support_ready:
        return
    mutex_err: mutable int = 0
    cond_err: mutable int = 0
    kernel_test_slots_mutex <- kt_mutex_create(3, mutex_err.ref[mutable int&])
    kernel_test_slots_cond <- kt_cond_create(cond_err.ref[mutable int&])
    kernel_test_support_ready <- true

def elisa_kernel_test_lock_slots() -> void:
    elisa_kernel_test_ensure_support()
    _ = kt_mutex_lock(kernel_test_slots_mutex)

def elisa_kernel_test_unlock_slots() -> void:
    _ = kt_mutex_unlock(kernel_test_slots_mutex)

def elisa_kernel_test_broadcast_slots() -> void:
    _ = kt_cond_broadcast(kernel_test_slots_cond)

def elisa_kernel_test_make_realtime_deadline(usec: u64, out: mutable KtTimespec&) -> int:
    return kt_make_deadline_from_usec(usec, out)

def elisa_kernel_test_slots_reset() -> void:
    elisa_kernel_test_lock_slots()
    i: mutable int = 0
    while i < ELISA_KERNEL_TEST_SLOT_COUNT:
        kernel_test_slots[i.usize()] <- 0
        i <- i + 1
    elisa_kernel_test_broadcast_slots()
    elisa_kernel_test_unlock_slots()

def elisa_kernel_test_slot_set(slot: int, value: i64) -> void:
    if not elisa_kernel_test_valid_slot(slot):
        return
    elisa_kernel_test_lock_slots()
    kernel_test_slots[slot.usize()] <- value
    elisa_kernel_test_broadcast_slots()
    elisa_kernel_test_unlock_slots()

def elisa_kernel_test_slot_get(slot: int) -> i64:
    if not elisa_kernel_test_valid_slot(slot):
        return 0
    elisa_kernel_test_lock_slots()
    value: i64 = kernel_test_slots[slot.usize()]
    elisa_kernel_test_unlock_slots()
    return value

def elisa_kernel_test_slot_add(slot: int, delta: i64) -> i64:
    if not elisa_kernel_test_valid_slot(slot):
        return 0
    elisa_kernel_test_lock_slots()
    kernel_test_slots[slot.usize()] <- kernel_test_slots[slot.usize()] + delta
    value: i64 = kernel_test_slots[slot.usize()]
    elisa_kernel_test_broadcast_slots()
    elisa_kernel_test_unlock_slots()
    return value

def elisa_kernel_test_wait_slot(slot: int, expected: i64, timeout_usec: u64) -> int:
    if not elisa_kernel_test_valid_slot(slot):
        return ELISA_KERNEL_TEST_EINVAL
    deadline: mutable KtTimespec = zeroed
    if elisa_kernel_test_make_realtime_deadline(timeout_usec, deadline.ref[mutable KtTimespec&]) != 0:
        return ELISA_KERNEL_TEST_EINVAL
    elisa_kernel_test_lock_slots()
    while kernel_test_slots[slot.usize()] != expected:
        err: int = kt_cond_timedwait(kernel_test_slots_cond, kernel_test_slots_mutex, deadline.tv_sec, deadline.tv_nsec)
        if err != 0:
            elisa_kernel_test_unlock_slots()
            if err == KT_PS4_ETIMEDOUT:
                return ELISA_KERNEL_TEST_ETIMEDOUT
            return err
    elisa_kernel_test_unlock_slots()
    return 0

def elisa_kernel_test_wait_slot_at_least(slot: int, expected: i64, timeout_usec: u64) -> int:
    if not elisa_kernel_test_valid_slot(slot):
        return ELISA_KERNEL_TEST_EINVAL
    deadline: mutable KtTimespec = zeroed
    if elisa_kernel_test_make_realtime_deadline(timeout_usec, deadline.ref[mutable KtTimespec&]) != 0:
        return ELISA_KERNEL_TEST_EINVAL
    elisa_kernel_test_lock_slots()
    while kernel_test_slots[slot.usize()] < expected:
        err: int = kt_cond_timedwait(kernel_test_slots_cond, kernel_test_slots_mutex, deadline.tv_sec, deadline.tv_nsec)
        if err != 0:
            elisa_kernel_test_unlock_slots()
            if err == KT_PS4_ETIMEDOUT:
                return ELISA_KERNEL_TEST_ETIMEDOUT
            return err
    elisa_kernel_test_unlock_slots()
    return 0

def elisa_kernel_test_monotonic_usec() -> u64:
    now: mutable KtTimespec = zeroed
    if kt_clock_gettime(KT_CLOCK_MONOTONIC, now.ref[void&]) != 0:
        return 0
    return (now.tv_sec.u64() * 1000000u64) + (now.tv_nsec.u64() / 1000u64)

@link_name(nanosleep)
extern elisa_kernel_test_nanosleep(req: void&?, rem: void&?) -> int

@link_name(sched_yield)
extern elisa_kernel_test_sched_yield() -> int

def elisa_kernel_test_sleep_usec(usec: u64) -> void:
    req: mutable KtTimespec = zeroed
    req.tv_sec <- (usec / 1000000u64).i64()
    req.tv_nsec <- ((usec % 1000000u64) * 1000u64).i64()
    _ = elisa_kernel_test_nanosleep(req.ref[void&], null)

def elisa_kernel_test_yield() -> void:
    _ = elisa_kernel_test_sched_yield()

@callconv(c)
def elisa_kernel_test_cancel_tls_destructor(raw: void&?) -> void:
    if raw == null:
        return
    args: mutable KernelTestCancelArgs& = raw.cast[mutable KernelTestCancelArgs&]
    if args.cleanup_slot >= 0:
        _ = elisa_kernel_test_slot_add(args.cleanup_slot, 1)
    if args.tls_slot >= 0:
        _ = elisa_kernel_test_slot_add(args.tls_slot, 1)

@callconv(c)
def elisa_kernel_test_cancel_key_init() -> void:
    trusted Unsafe.MutableGlobal, Unsafe.PointerCast:
        dtor: void&? = elisa_kernel_test_cancel_tls_destructor as void&?
        _ = tls_pthread_key_create(kernel_test_cancel_key.ref[void&], dtor)

def elisa_kernel_test_ensure_cancel_key() -> void:
    trusted Unsafe.MutableGlobal, Unsafe.PointerCast:
        init_fn: void& = elisa_kernel_test_cancel_key_init as void&
        _ = kt_pthread_once(kernel_test_cancel_once.ref[void&], init_fn)

def elisa_kernel_test_cancel_worker(raw: void&?) -> void&?:
    if raw == null:
        return null
    args: mutable KernelTestCancelArgs& = raw.cast[mutable KernelTestCancelArgs&]
    elisa_kernel_test_ensure_cancel_key()
    trusted Unsafe.MutableGlobal:
        _ = tls_pthread_setspecific(kernel_test_cancel_key, raw)
    elisa_kernel_test_slot_set(args.started_slot, 1)
    trusted Unsafe.AssumeProgress:
        while true:
            elisa_kernel_test_sleep_usec(5000u64)
    return null

def elisa_kernel_test_cancel_cleanup_tls_join_scenario() -> int:
    err: mutable int = 0
    thr: void&? = kt_thread_create(elisa_kernel_test_cancel_worker as void&?, kernel_test_cancel_join_args.ref[void&], err.ref[mutable int&])
    if thr == null or err != 0:
        return -1
    if elisa_kernel_test_wait_slot(kernel_test_cancel_join_args.started_slot, 1, 250000u64) != 0:
        return -2
    cancel_ret: int = kt_thread_cancel(thr)
    ret: mutable void&? = null
    join_ret: int = kt_thread_join(thr, ret)
    if cancel_ret != 0 or join_ret != 0:
        return -3
    if elisa_kernel_test_wait_slot_at_least(kernel_test_cancel_join_args.cleanup_slot, 1, 250000u64) != 0:
        return -4
    if elisa_kernel_test_wait_slot_at_least(kernel_test_cancel_join_args.tls_slot, 1, 250000u64) != 0:
        return -5
    if ret != ELISA_KERNEL_TEST_PTHREAD_CANCELED.cast[void&?]:
        return -6
    return 0

def elisa_kernel_test_cancel_cleanup_tls_timedjoin_scenario() -> int:
    err: mutable int = 0
    thr: void&? = kt_thread_create(elisa_kernel_test_cancel_worker as void&?, kernel_test_cancel_timedjoin_args.ref[void&], err.ref[mutable int&])
    if thr == null or err != 0:
        return -1
    if elisa_kernel_test_wait_slot(kernel_test_cancel_timedjoin_args.started_slot, 1, 250000u64) != 0:
        return -2
    if kt_thread_cancel(thr) != 0:
        return -3
    now: mutable KtTimespec = zeroed
    if kt_clock_gettime(KT_CLOCK_MONOTONIC, now.ref[void&]) != 0:
        return -4
    sec: mutable i64 = now.tv_sec
    nsec: mutable i64 = now.tv_nsec + 200000000i64
    if nsec >= 1000000000i64:
        sec <- sec + 1
        nsec <- nsec - 1000000000i64
    ret: mutable void&? = null
    join_ret: int = kt_thread_timedjoin(thr, ret, sec, nsec)
    if join_ret != 0:
        return -4
    if elisa_kernel_test_wait_slot_at_least(kernel_test_cancel_timedjoin_args.cleanup_slot, 1, 250000u64) != 0:
        return -5
    if elisa_kernel_test_wait_slot_at_least(kernel_test_cancel_timedjoin_args.tls_slot, 1, 250000u64) != 0:
        return -6
    if ret != ELISA_KERNEL_TEST_PTHREAD_CANCELED.cast[void&?]:
        return -7
    return 0
