include "../shader_recompiler/params.elisa"
include "../../compiler/runtime/elisacore_std/elisacore_runtime.elisa"

@test
def shader_params_constants_and_fields() -> void:
    can Abort.Panic:
        assert SHADER_PARAMS_NUM_USER_DATA == 16u32

        p: mutable ShaderParams = zeroed
        p.hash <- 0xDEADBEEFu64
        p.user_data[3usize] <- 42u32
        p.pgm_base <- 0x1234000u64

        assert p.hash == 0xDEADBEEFu64
        assert p.user_data[3usize] == 42u32
        assert p.user_data[0usize] == 0u32
        assert p.pgm_base == 0x1234000u64
        assert ShaderParams_Base(p.ref[ShaderParams&]) == 0x1234000u64

@test
def shader_params_code_push() -> void:
    can Abort.Panic, Memory.Allocate:
        owner: mutable Arena& = scratch_arena.ref[mutable Arena&]
        p: mutable ShaderParams = zeroed
        in owner:
            p.code.push(7u32)
            p.code.push(9u32)
        assert p.code.count == 2usize
        assert p.code[0usize] == 7u32
        assert p.code[1usize] == 9u32
