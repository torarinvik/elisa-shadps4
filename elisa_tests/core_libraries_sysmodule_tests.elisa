include "../../compiler/runtime/elisacore_std/elisacore_runtime.elisa"
include "../core/libraries/sysmodule/sysmodule.elisa"

@test
def sysmodule_id_validation_and_stub_surface() -> void:
    can Abort.Panic:
        out: mutable int = 0

        assert sceSysmoduleGetModuleHandleInternal(0u32, out.ref[mutable int&]) == ORBIS_SYSMODULE_INVALID_ID
        assert sceSysmoduleGetModuleHandleInternal(1u32, out.ref[mutable int&]) == ORBIS_SYSMODULE_NOT_LOADED

        assert sceSysmoduleIsLoaded(0u16) == ORBIS_SYSMODULE_INVALID_ID
        assert sceSysmoduleIsLoaded(1u16) == ORBIS_SYSMODULE_NOT_LOADED

        assert sceSysmoduleIsLoadedInternal(0u32) == ORBIS_SYSMODULE_INVALID_ID
        assert sceSysmoduleIsLoadedInternal(0x80000000u32) == ORBIS_SYSMODULE_INVALID_ID
        assert sceSysmoduleIsLoadedInternal(1u32) == ORBIS_SYSMODULE_NOT_LOADED

        assert sceSysmoduleLoadModule(0u16) == ORBIS_SYSMODULE_INVALID_ID
        assert sceSysmoduleLoadModule(2u16) == ORBIS_OK
        assert sceSysmoduleIsLoaded(2u16) == ORBIS_OK

        assert sceSysmoduleLoadModuleInternal(0u32) == ORBIS_SYSMODULE_INVALID_ID
        assert sceSysmoduleLoadModuleInternal(3u32) == ORBIS_OK
        assert sceSysmoduleIsLoadedInternal(3u32) == ORBIS_OK
        assert sceSysmoduleGetModuleHandleInternal(3u32, out.ref[mutable int&]) == ORBIS_OK

        assert sceSysmoduleLoadModuleInternalWithArg(0u32, 0, null, 0u64, out.ref[mutable int&]) == ORBIS_SYSMODULE_INVALID_ID
        assert sceSysmoduleLoadModuleInternalWithArg(1u32, 0, null, 1u64, out.ref[mutable int&]) == ORBIS_SYSMODULE_INVALID_ID
        assert sceSysmoduleLoadModuleInternalWithArg(1u32, 0, null, 0u64, out.ref[mutable int&]) == ORBIS_OK

        assert sceSysmoduleUnloadModule(0u16) == ORBIS_SYSMODULE_INVALID_ID
        assert sceSysmoduleUnloadModule(2u16) == ORBIS_OK
        assert sceSysmoduleUnloadModule(2u16) == ORBIS_SYSMODULE_NOT_LOADED

        assert sceSysmoduleGetModuleInfoForUnwind(0u64, 0, null) == ORBIS_OK
        assert sceSysmoduleIsCalledFromSysModule() == ORBIS_OK
        assert sceSysmoduleIsCameraPreloaded() == ORBIS_OK
        assert sceSysmoduleLoadModuleByNameInternal() == ORBIS_OK
        assert sceSysmoduleMapLibcForLibkernel() == ORBIS_OK
        assert sceSysmodulePreloadModuleForLibkernel() == ORBIS_OK
        assert sceSysmoduleUnloadModuleByNameInternal() == ORBIS_OK
        assert sceSysmoduleUnloadModuleInternal() == ORBIS_OK
        assert sceSysmoduleUnloadModuleInternalWithArg() == ORBIS_OK
