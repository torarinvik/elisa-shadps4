include "../../compiler/runtime/elisacore_std/elisacore_runtime.elisa"
include "../core/libraries/sysmodule/sysmodule.elisa"

@test
def sysmodule_id_validation_and_stub_surface() -> void:
    can Abort.Panic:
        out: mutable int = 0

        assert sceSysmoduleGetModuleHandleInternal(0, out) == ORBIS_SYSMODULE_INVALID_ID
        assert sceSysmoduleGetModuleHandleInternal(1, out) == ORBIS_SYSMODULE_NOT_LOADED

        assert sceSysmoduleIsLoaded(0) == ORBIS_SYSMODULE_INVALID_ID
        assert sceSysmoduleIsLoaded(1) == ORBIS_SYSMODULE_NOT_LOADED

        assert sceSysmoduleIsLoadedInternal(0) == ORBIS_SYSMODULE_INVALID_ID
        assert sceSysmoduleIsLoadedInternal(0x80000000) == ORBIS_SYSMODULE_INVALID_ID
        assert sceSysmoduleIsLoadedInternal(1) == ORBIS_SYSMODULE_NOT_LOADED

        assert sceSysmoduleLoadModule(0) == ORBIS_SYSMODULE_INVALID_ID
        assert sceSysmoduleLoadModule(2) == ORBIS_OK
        assert sceSysmoduleIsLoaded(2) == ORBIS_OK

        assert sceSysmoduleLoadModuleInternal(0) == ORBIS_SYSMODULE_INVALID_ID
        assert sceSysmoduleLoadModuleInternal(3) == ORBIS_OK
        assert sceSysmoduleIsLoadedInternal(3) == ORBIS_OK
        assert sceSysmoduleGetModuleHandleInternal(3, out) == ORBIS_OK

        assert sceSysmoduleLoadModuleInternalWithArg(0, 0, null, 0, out) == ORBIS_SYSMODULE_INVALID_ID
        assert sceSysmoduleLoadModuleInternalWithArg(1, 0, null, 1, out) == ORBIS_SYSMODULE_INVALID_ID
        assert sceSysmoduleLoadModuleInternalWithArg(1, 0, null, 0, out) == ORBIS_OK

        assert sceSysmoduleUnloadModule(0) == ORBIS_SYSMODULE_INVALID_ID
        assert sceSysmoduleUnloadModule(2) == ORBIS_OK
        assert sceSysmoduleUnloadModule(2) == ORBIS_SYSMODULE_NOT_LOADED

        assert sceSysmoduleGetModuleInfoForUnwind(0, 0, null) == ORBIS_OK
        assert sceSysmoduleIsCalledFromSysModule() == ORBIS_OK
        assert sceSysmoduleIsCameraPreloaded() == ORBIS_OK
        assert sceSysmoduleLoadModuleByNameInternal() == ORBIS_OK
        assert sceSysmoduleMapLibcForLibkernel() == ORBIS_OK
        assert sceSysmodulePreloadModuleForLibkernel() == ORBIS_OK
        assert sceSysmoduleUnloadModuleByNameInternal() == ORBIS_OK
        assert sceSysmoduleUnloadModuleInternal() == ORBIS_OK
        assert sceSysmoduleUnloadModuleInternalWithArg() == ORBIS_OK
