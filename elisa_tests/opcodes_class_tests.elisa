include "../shader_recompiler/frontend/opcodes_class.elisa"
include "../../compiler/runtime/elisacore_std/elisacore_runtime.elisa"

@test
def opcodes_class_values() -> void:
    can Abort.Panic:
        assert ENCODING_MASK_MASK_1bit == 0x80000000u32
        assert INST_ENCODING_SOP1 == 0xBE800000u32
        assert INST_ENCODING_ILLEGAL == 1u32
        assert INST_CLASS_Undefined == 0u32
        assert INST_CLASS_DbgProf == 79u32
        assert INST_CATEGORY_ScalarALU == 1u32
        assert SCALAR_TYPE_Bool == 11u32
        assert DIVERGENT_ACTION_Nop == 0u32
        assert DIVERGENT_ACTION_Execute == 2u32
