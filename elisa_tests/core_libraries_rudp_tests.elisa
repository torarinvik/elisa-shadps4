include "../../compiler/runtime/elisacore_std/elisacore_runtime.elisa"
include "../core/libraries/rudp/rudp.elisa"

@test
def rudp_stub_surface_returns_ok() -> void:
    can Abort.Panic:
        assert sceRudpInit() == ORBIS_OK
        assert sceRudpCreateContext() == ORBIS_OK
        assert sceRudpEnableInternalIOThread() == ORBIS_OK
        assert sceRudpEnableInternalIOThread2() == ORBIS_OK
        assert sceRudpActivate() == ORBIS_OK
        assert sceRudpBind() == ORBIS_OK
        assert sceRudpListen() == ORBIS_OK
        assert sceRudpInitiate() == ORBIS_OK
        assert sceRudpAccept() == ORBIS_OK
        assert sceRudpRead() == ORBIS_OK
        assert sceRudpWrite() == ORBIS_OK
        assert sceRudpFlush() == ORBIS_OK
        assert sceRudpNetFlush() == ORBIS_OK
        assert sceRudpNetReceived() == ORBIS_OK
        assert sceRudpProcessEvents() == ORBIS_OK
        assert sceRudpGetContextStatus() == ORBIS_OK
        assert sceRudpGetStatus() == ORBIS_OK
        assert sceRudpGetLocalInfo() == ORBIS_OK
        assert sceRudpGetRemoteInfo() == ORBIS_OK
        assert sceRudpGetMaxSegmentSize() == ORBIS_OK
        assert sceRudpSetMaxSegmentSize() == ORBIS_OK
        assert sceRudpGetSizeReadable() == ORBIS_OK
        assert sceRudpGetSizeWritable() == ORBIS_OK
        assert sceRudpGetNumberOfPacketsToRead() == ORBIS_OK
        assert sceRudpGetOption() == ORBIS_OK
        assert sceRudpSetOption() == ORBIS_OK
        assert sceRudpPollCreate() == ORBIS_OK
        assert sceRudpPollControl() == ORBIS_OK
        assert sceRudpPollWait() == ORBIS_OK
        assert sceRudpPollCancel() == ORBIS_OK
        assert sceRudpPollDestroy() == ORBIS_OK
        assert sceRudpSetEventHandler() == ORBIS_OK
        assert sceRudpEnd() == ORBIS_OK
        assert sceRudpTerminate() == ORBIS_OK
