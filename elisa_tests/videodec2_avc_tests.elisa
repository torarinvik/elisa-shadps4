include "../core/libraries/videodec/videodec2_avc.elisa"
include "../../compiler/runtime/elisacore_std/elisacore_runtime.elisa"

@test
def avc_picture_info_fields() -> void:
    can Abort.Panic:
        pic: mutable OrbisVideodec2AvcPictureInfo = zeroed
        # Defaults from zeroed.
        assert pic.thisSize == 0u64
        assert pic.isValid == false
        assert pic.sar_width == 0u16
        assert pic.profile_idc == 0u8
        assert pic.time_scale == 0u32

        # Set a representative field of each width and read back.
        pic.thisSize <- 0x78u64
        pic.isValid <- true
        pic.sar_width <- 1920u16
        pic.profile_idc <- 100u8
        pic.time_scale <- 60000u32

        assert pic.thisSize == 0x78u64
        assert pic.isValid == true
        assert pic.sar_width == 1920u16
        assert pic.profile_idc == 100u8
        assert pic.time_scale == 60000u32
