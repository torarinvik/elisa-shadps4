include "../core/libraries/videodec/videodec2_avc.elisa"
include "../../compiler/runtime/elisacore_std/elisacore_runtime.elisa"

@test
def avc_picture_info_fields() -> void:
    can Abort.Panic:
        pic: mutable OrbisVideodec2AvcPictureInfo = zeroed
        # Defaults from zeroed.
        assert pic.thisSize == 0
        assert pic.isValid == false
        assert pic.sar_width == 0
        assert pic.profile_idc == 0
        assert pic.time_scale == 0

        # Set a representative field of each width and read back.
        pic.thisSize <- 0x78
        pic.isValid <- true
        pic.sar_width <- 1920
        pic.profile_idc <- 100
        pic.time_scale <- 60000

        assert pic.thisSize == 0x78
        assert pic.isValid == true
        assert pic.sar_width == 1920
        assert pic.profile_idc == 100
        assert pic.time_scale == 60000
