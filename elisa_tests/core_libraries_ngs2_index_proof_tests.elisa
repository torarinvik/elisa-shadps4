# Exercises the statically-proven voice-state index helpers in ngs2.elisa.
# `_voice_slot_index` carries a refinement-typed return (`usize is
# BoundedSlot[0, 131071]`) that the tier-2 linear prover discharges from its
# parameter bounds, so the index into the size-131072 voice_* arrays is proven
# in-bounds with no per-access runtime check.

include "../core/libraries/error_codes.elisa"
include "../common/types.elisa"
include "../../compiler/runtime/elisacore_std/elisacore_runtime.elisa"
include "../core/libraries/ngs2/ngs2.elisa"

@test
def ngs2_voice_state_index_spans_array_in_bounds() -> void:
    can Abort.Panic:
        assert _voice_state_index(0, 0) == 0
        assert _voice_state_index(0, 1) == 1
        assert _voice_state_index(1, 0) == 4096
        # Maximum valid (rack 31, voice 4095) lands on the last slot, 131071,
        # one below NGS2_MAX_VOICE_STATE_SLOTS (131072) — the proven upper bound.
        assert _voice_state_index(31, 4095) == 131071

@test
def ngs2_voice_slot_index_proven_core() -> void:
    can Abort.Panic:
        assert _voice_slot_index(0.usize(), 0.usize()) == 0
        assert _voice_slot_index(31.usize(), 4095.usize()) == 131071
