include "./kernel_threads_runtime_test_support.elisa"

const PARITY_POSIX_EINVAL: int = 22

@fixed_layout
struct ParityWaitArg:
    handle: mutable void&?
    is_event: mutable int
    result: mutable int

global mutable parity_wait_arg: ParityWaitArg = zeroed

def parity_host_is_windows() -> int:
    return 0

def parity_worker(mode_raw: void&?) -> void&?:
    mode: u64 = mode_raw.cast[u64]
    if mode == 1:
        elisa_kernel_test_sleep_usec(50000)
        return 0x77.cast[void&?]
    if mode == 2:
        return 0x123456.cast[void&?]
    return null

def parity_wait_worker(raw: void&?) -> void&?:
    _ = raw
    arg: mutable ParityWaitArg& = &parity_wait_arg
    if arg.is_event != 0:
        out: mutable u64 = 0
        arg.result <- kt_event_wait(arg.handle, 0x1, 0x02, out, 250000)
    else:
        arg.result <- kt_sem_wait(arg.handle, 1)
    return null

def parity_thread_create_impl(mode: int, out_error: mutable int&?) -> void&?:
    return kt_thread_create(parity_worker.cast[void&?], mode.cast[void&?], out_error)

def oracle_thread_create(mode: int, out_error: mutable int&?) -> void&?:
    return parity_thread_create_impl(mode, out_error)

def elisa_adapter_thread_create(mode: int, out_error: mutable int&?) -> void&?:
    return parity_thread_create_impl(mode, out_error)

