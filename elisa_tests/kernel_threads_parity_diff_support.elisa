def parity_sem_delete_wake_impl() -> int:
    err: mutable int = 0
    waiters: mutable int = 0
    sem: void&? = kt_sem_create(0, 4, err)
    if sem == null or err != 0:
        return -1
    # Runtime-owned semaphore handle stored into the program-lifetime worker arg (valid until kt_sem_destroy below).
    trusted Unsafe.StaleRef:
        parity_wait_arg.handle <- sem
    parity_wait_arg.is_event <- 0
    parity_wait_arg.result <- 0
    thread_err: mutable int = 0
    thread: void&? = kt_thread_create(parity_wait_worker.cast[void&?], (&parity_wait_arg).cast[void&], thread_err)
    if thread == null or thread_err != 0:
        _ = kt_sem_destroy(sem)
        return -2
    elisa_kernel_test_sleep_usec(20000)
    del_ret: int = kt_sem_delete(sem, waiters)
    ret: mutable void&? = null
    _ = kt_thread_join(thread, ret)
    return ((del_ret & 0xffff) << 16) | (parity_wait_arg.result & 0xffff)

def oracle_sem_delete_wake_scenario() -> int:
    return parity_sem_delete_wake_impl()

def elisa_adapter_sem_delete_wake_scenario() -> int:
    return parity_sem_delete_wake_impl()

def parity_event_cancel_wake_impl() -> int:
    err: mutable int = 0
    waiters: mutable int = 0
    ev: void&? = kt_event_create(0, err)
    if ev == null or err != 0:
        return -1
    # Runtime-owned event handle stored into the program-lifetime worker arg (valid for the scenario).
    trusted Unsafe.StaleRef:
        parity_wait_arg.handle <- ev
    parity_wait_arg.is_event <- 1
    parity_wait_arg.result <- 0
    thread_err: mutable int = 0
    thread: void&? = kt_thread_create(parity_wait_worker.cast[void&?], (&parity_wait_arg).cast[void&], thread_err)
    if thread == null or thread_err != 0:
        _ = kt_event_destroy(ev)
        return -2
    elisa_kernel_test_sleep_usec(20000)
    cancel_ret: int = kt_event_cancel(ev, 0, waiters)
    ret: mutable void&? = null
    _ = kt_thread_join(thread, ret)
    _ = kt_event_destroy(ev)
    return ((cancel_ret & 0xffff) << 16) | (parity_wait_arg.result & 0xffff)

def oracle_event_cancel_wake_scenario() -> int:
    return parity_event_cancel_wake_impl()

def elisa_adapter_event_cancel_wake_scenario() -> int:
    return parity_event_cancel_wake_impl()

