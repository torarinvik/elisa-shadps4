include "../shader_recompiler/recompiler_backend.elisa"
include "../../compiler/runtime/elisacore_std/elisacore_runtime.elisa"

def recompiler_bridge_hash_words(code_words: u32&, code_word_count: usize) -> u64:
    hash: mutable u64 = 1469598103934665603
    hash <- hash ^ code_word_count.u64()
    hash <- hash * 1099511628211
    i: mutable usize = 0
    while i < code_word_count:
        hash <- hash ^ code_words[i].u64()
        hash <- hash * 1099511628211
        i <- i + 1
    return hash

def recompiler_bridge_expect_real_spirv_status_for_payload(program: mutable void&?, payload_kind: u32) -> void:
    can Abort.Panic:
        real_status: u32 = elisa_shader_recompiler_program_real_spirv_status(program)
        if payload_kind == ELISA_RECOMPILER_PAYLOAD_KIND_REAL_SPIRV:
            assert real_status == ELISA_RECOMPILER_REAL_SPIRV_SUCCEEDED
        else:
            assert real_status == ELISA_RECOMPILER_REAL_SPIRV_NOT_REQUESTED or real_status == ELISA_RECOMPILER_REAL_SPIRV_FAILED or real_status == ELISA_RECOMPILER_REAL_SPIRV_UNAVAILABLE

def recompiler_bridge_expect_translated_or_unsupported(program: mutable void&?) -> void:
    can Abort.Panic:
        status: int = elisa_shader_recompiler_program_status(program)
        if status == ELISA_RECOMPILER_PROGRAM_STATUS_TRANSLATED:
            assert elisa_shader_recompiler_program_output_byte_size(program) > 0
            assert elisa_shader_recompiler_program_output_word_count(program) > 0
            assert elisa_shader_recompiler_program_output_word_at(program, 0) == ELISA_SPIRV_MAGIC
            payload_kind: u32 = elisa_shader_recompiler_program_payload_kind(program)
            assert payload_kind == ELISA_RECOMPILER_PAYLOAD_KIND_SPIRV_ENVELOPE or payload_kind == ELISA_RECOMPILER_PAYLOAD_KIND_REAL_SPIRV
            recompiler_bridge_expect_real_spirv_status_for_payload(program, payload_kind)
            assert elisa_shader_recompiler_program_output_hash(program) != 0
            assert elisa_shader_recompiler_program_diagnostic_code(program) == ELISA_RECOMPILER_DIAGNOSTIC_NONE
            return
        assert status == ELISA_RECOMPILER_PROGRAM_STATUS_FAILED_WITH_DIAGNOSTIC
        assert elisa_shader_recompiler_program_output_byte_size(program) == 0
        assert elisa_shader_recompiler_program_output_word_count(program) == 0
        assert elisa_shader_recompiler_program_output_word_at(program, 0) == 0
        assert elisa_shader_recompiler_program_payload_kind(program) == ELISA_RECOMPILER_PAYLOAD_KIND_NONE
        assert elisa_shader_recompiler_program_real_spirv_status(program) == ELISA_RECOMPILER_REAL_SPIRV_NOT_REQUESTED
        assert elisa_shader_recompiler_program_output_hash(program) == 0
        diag: int = elisa_shader_recompiler_program_diagnostic_code(program)
        assert diag == ELISA_RECOMPILER_DIAGNOSTIC_UNSUPPORTED or diag == ELISA_RECOMPILER_DIAGNOSTIC_REAL_LINK_NOT_AVAILABLE

@test
def recompiler_bridge_rejects_missing_arguments() -> void:
    can Abort.Panic:
        out_program: mutable void&? = null
        rc: int = ShaderRecompiler_TranslateProgramViaFfi(null, 0, null, out_program)
        assert rc != ELISA_RECOMPILER_BRIDGE_OK
        assert out_program == null

@test
def recompiler_bridge_valid_arguments_return_owned_handle() -> void:
    can Abort.Panic:
        code_words: mutable u32[8] = [
            0xbeeb03ff,
            0x00000003,
            0x7e000280,
            0x5e000100,
            0xbf800000,
            0xf8001c0f,
            0x00000000,
            0xbf810000
        ]
        metadata: mutable ShaderRecompilerTranslateMetadata = ShaderRecompilerTranslateMetadata(
            ELISA_RECOMPILER_STAGE_FRAGMENT.u32(),
            ELISA_RECOMPILER_LOGICAL_STAGE_FRAGMENT.u32()
        )
        out_program: mutable void&? = null
        rc: int = ShaderRecompiler_TranslateProgramViaFfi(
            code_words[0],
            8,
            metadata,
            out_program
        )
        assert rc == ELISA_RECOMPILER_BRIDGE_OK
        assert out_program != null
        assert elisa_shader_recompiler_program_magic(out_program) == ELISA_RECOMPILER_PROGRAM_MAGIC_LIVE
        assert elisa_shader_recompiler_program_input_word_count(out_program) == 8
        assert elisa_shader_recompiler_program_input_hash(out_program) == recompiler_bridge_hash_words(code_words[0], 8)
        assert elisa_shader_recompiler_program_has_stage_type(out_program) == 1
        assert elisa_shader_recompiler_program_stage_type(out_program) == 0
        recompiler_bridge_expect_translated_or_unsupported(out_program)
        ShaderRecompiler_FreeProgramViaFfi(out_program)

@test
def recompiler_bridge_metadata_accessors_are_deterministic() -> void:
    can Abort.Panic:
        code_words: mutable u32[8] = [
            0xbeeb03ff,
            0x00000003,
            0x7e000280,
            0x5e000100,
            0xbf800000,
            0xf8001c0f,
            0x00000000,
            0xbf810000
        ]
        metadata: mutable ShaderRecompilerTranslateMetadata = ShaderRecompilerTranslateMetadata(
            ELISA_RECOMPILER_STAGE_FRAGMENT.u32(),
            ELISA_RECOMPILER_LOGICAL_STAGE_FRAGMENT.u32()
        )
        out_program: mutable void&? = null
        rc: int = ShaderRecompiler_TranslateProgramViaFfi(
            code_words[0],
            8,
            metadata,
            out_program
        )
        assert rc == ELISA_RECOMPILER_BRIDGE_OK
        assert out_program != null
        assert elisa_shader_recompiler_program_magic(out_program) == ELISA_RECOMPILER_PROGRAM_MAGIC_LIVE
        assert elisa_shader_recompiler_program_input_word_count(out_program) == 8
        assert elisa_shader_recompiler_program_input_hash(out_program) == recompiler_bridge_hash_words(code_words[0], 8)
        assert elisa_shader_recompiler_program_has_stage_type(out_program) == 1
        assert elisa_shader_recompiler_program_stage_type(out_program) == 0
        recompiler_bridge_expect_translated_or_unsupported(out_program)
        ShaderRecompiler_FreeProgramViaFfi(out_program)
        assert elisa_shader_recompiler_program_magic(out_program) == ELISA_RECOMPILER_PROGRAM_MAGIC_FREED
        assert elisa_shader_recompiler_program_input_hash(out_program) == 0
        assert elisa_shader_recompiler_program_input_word_count(out_program) == 0
        assert elisa_shader_recompiler_program_has_stage_type(out_program) == 0
        assert elisa_shader_recompiler_program_stage_type(out_program) == 0
        assert elisa_shader_recompiler_program_output_byte_size(out_program) == 0
        assert elisa_shader_recompiler_program_output_word_count(out_program) == 0
        assert elisa_shader_recompiler_program_output_word_at(out_program, 0) == 0
        assert elisa_shader_recompiler_program_payload_kind(out_program) == ELISA_RECOMPILER_PAYLOAD_KIND_NONE
        assert elisa_shader_recompiler_program_real_spirv_status(out_program) == ELISA_RECOMPILER_REAL_SPIRV_NOT_REQUESTED
        assert elisa_shader_recompiler_program_output_hash(out_program) == 0
        assert elisa_shader_recompiler_program_status(out_program) == ELISA_RECOMPILER_PROGRAM_STATUS_FREED
        ShaderRecompiler_FreeProgramViaFfi(out_program)

@test
def recompiler_bridge_metadata_accessors_handle_null_safely() -> void:
    assert elisa_shader_recompiler_program_magic(null) == 0
    assert elisa_shader_recompiler_program_input_hash(null) == 0
    assert elisa_shader_recompiler_program_input_word_count(null) == 0
    assert elisa_shader_recompiler_program_has_stage_type(null) == 0
    assert elisa_shader_recompiler_program_stage_type(null) == 0
    assert elisa_shader_recompiler_program_output_byte_size(null) == 0

@test
def recompiler_bridge_new_accessors_handle_null_safely() -> void:
    can Abort.Panic:
        assert elisa_shader_recompiler_program_output_hash(null) == 0
        assert elisa_shader_recompiler_program_output_word_count(null) == 0
        assert elisa_shader_recompiler_program_output_word_at(null, 0) == 0
        assert elisa_shader_recompiler_program_payload_kind(null) == ELISA_RECOMPILER_PAYLOAD_KIND_NONE
        assert elisa_shader_recompiler_program_real_spirv_status(null) == ELISA_RECOMPILER_REAL_SPIRV_NOT_REQUESTED
        assert elisa_shader_recompiler_program_status(null) == ELISA_RECOMPILER_PROGRAM_STATUS_INVALID
        assert elisa_shader_recompiler_program_diagnostic_code(null) == ELISA_RECOMPILER_DIAGNOSTIC_NONE

@test
def recompiler_bridge_free_is_idempotent_and_null_safe() -> void:
    ShaderRecompiler_FreeProgramViaFfi(null)
    can Abort.Panic:
        code_words: mutable u32[8] = [
            0xbeeb03ff,
            0x00000003,
            0x7e000280,
            0x5e000100,
            0xbf800000,
            0xf8001c0f,
            0x00000000,
            0xbf810000
        ]
        metadata: mutable ShaderRecompilerTranslateMetadata = ShaderRecompilerTranslateMetadata(
            ELISA_RECOMPILER_STAGE_FRAGMENT.u32(),
            ELISA_RECOMPILER_LOGICAL_STAGE_FRAGMENT.u32()
        )
        out_program: mutable void&? = null
        rc: int = ShaderRecompiler_TranslateProgramViaFfi(
            code_words[0],
            1,
            metadata,
            out_program
        )
        assert rc == ELISA_RECOMPILER_BRIDGE_OK
        assert out_program != null
        ShaderRecompiler_FreeProgramViaFfi(out_program)
        ShaderRecompiler_FreeProgramViaFfi(out_program)
        assert elisa_shader_recompiler_program_status(out_program) == ELISA_RECOMPILER_PROGRAM_STATUS_FREED

# Real GCN fragment shader fixture from shadPS4 gnmdriver.cpp (ps0_code).
# This is the minimal black-frame fragment shader used by sceGnmSetEmbeddedPsShader.
# GCN instructions:
#   s_mov_b32 vcc_hi, $0x00000003
#   v_mov_b32 v0, 0
#   v_cvt_pkrtz_f16_f32 v0, v0, v0
#   s_nop
#   exp mrt0, v0, v0 compr vm done
#   s_endpgm
#
# This target links the native shadPS4 shader path, so the fixture must produce real bytes.
@test
def recompiler_bridge_known_gcn_ps0_fixture_submits_successfully() -> void:
    can Abort.Panic:
        # ps0_code words (shader body only, not the binary header/regs)
        code_words: mutable u32[8] = [
            0xbeeb03ff,  # s_mov_b32 vcc_hi, $0x00000003  (word 0)
            0x00000003,  # immediate operand                (word 1)
            0x7e000280,  # v_mov_b32 v0, 0                 (word 2)
            0x5e000100,  # v_cvt_pkrtz_f16_f32 v0, v0, v0 (word 3)
            0xbf800000,  # s_nop                           (word 4)
            0xf8001c0f,  # exp mrt0, v0, v0 compr vm done  (word 5)
            0x00000000,  # exp operand                     (word 6)
            0xbf810000   # s_endpgm                        (word 7)
        ]
        pools: mutable u64 = 1
        info: mutable u64 = 2
        runtime_info: mutable u64 = 3
        profile: mutable u64 = 4
        metadata: mutable ShaderRecompilerTranslateMetadata = ShaderRecompilerTranslateMetadata(
            ELISA_RECOMPILER_STAGE_FRAGMENT.u32(),
            ELISA_RECOMPILER_LOGICAL_STAGE_FRAGMENT.u32()
        )
        out_program: mutable void&? = null
        rc: int = ShaderRecompiler_TranslateProgramViaFfi(
            code_words[0],
            8,
            metadata,
            out_program
        )
        assert rc == ELISA_RECOMPILER_BRIDGE_OK
        assert out_program != null
        assert elisa_shader_recompiler_program_magic(out_program) == ELISA_RECOMPILER_PROGRAM_MAGIC_LIVE
        assert elisa_shader_recompiler_program_input_word_count(out_program) == 8
        expected_hash: u64 = recompiler_bridge_hash_words(code_words[0], 8)
        assert elisa_shader_recompiler_program_input_hash(out_program) == expected_hash
        assert elisa_shader_recompiler_program_status(out_program) == ELISA_RECOMPILER_PROGRAM_STATUS_TRANSLATED
        assert elisa_shader_recompiler_program_output_byte_size(out_program) > 0
        assert elisa_shader_recompiler_program_output_word_count(out_program) > 4
        assert elisa_shader_recompiler_program_output_word_at(out_program, 0) == ELISA_SPIRV_MAGIC
        payload_kind: u32 = elisa_shader_recompiler_program_payload_kind(out_program)
        assert payload_kind == ELISA_RECOMPILER_PAYLOAD_KIND_SPIRV_ENVELOPE or payload_kind == ELISA_RECOMPILER_PAYLOAD_KIND_REAL_SPIRV
        recompiler_bridge_expect_real_spirv_status_for_payload(out_program, payload_kind)
        assert elisa_shader_recompiler_program_output_hash(out_program) != 0
        assert elisa_shader_recompiler_program_diagnostic_code(out_program) == ELISA_RECOMPILER_DIAGNOSTIC_NONE
        ShaderRecompiler_FreeProgramViaFfi(out_program)
        assert elisa_shader_recompiler_program_status(out_program) == ELISA_RECOMPILER_PROGRAM_STATUS_FREED

@test
def recompiler_bridge_known_gcn_ps0_fixture_is_deterministic_for_payload_metadata() -> void:
    can Abort.Panic:
        code_words: mutable u32[8] = [
            0xbeeb03ff,
            0x00000003,
            0x7e000280,
            0x5e000100,
            0xbf800000,
            0xf8001c0f,
            0x00000000,
            0xbf810000
        ]
        metadata0: mutable ShaderRecompilerTranslateMetadata = ShaderRecompilerTranslateMetadata(
            ELISA_RECOMPILER_STAGE_FRAGMENT.u32(),
            ELISA_RECOMPILER_LOGICAL_STAGE_FRAGMENT.u32()
        )
        metadata1: mutable ShaderRecompilerTranslateMetadata = ShaderRecompilerTranslateMetadata(
            ELISA_RECOMPILER_STAGE_FRAGMENT.u32(),
            ELISA_RECOMPILER_LOGICAL_STAGE_FRAGMENT.u32()
        )
        program0: mutable void&? = null
        program1: mutable void&? = null

        rc0: int = ShaderRecompiler_TranslateProgramViaFfi(
            code_words[0],
            8,
            metadata0,
            program0
        )
        rc1: int = ShaderRecompiler_TranslateProgramViaFfi(
            code_words[0],
            8,
            metadata1,
            program1
        )
        assert rc0 == ELISA_RECOMPILER_BRIDGE_OK
        assert rc1 == ELISA_RECOMPILER_BRIDGE_OK
        assert program0 != null
        assert program1 != null

        assert elisa_shader_recompiler_program_status(program0) == ELISA_RECOMPILER_PROGRAM_STATUS_TRANSLATED
        assert elisa_shader_recompiler_program_status(program1) == ELISA_RECOMPILER_PROGRAM_STATUS_TRANSLATED
        assert elisa_shader_recompiler_program_output_hash(program0) == elisa_shader_recompiler_program_output_hash(program1)
        assert elisa_shader_recompiler_program_output_byte_size(program0) == elisa_shader_recompiler_program_output_byte_size(program1)
        assert elisa_shader_recompiler_program_output_word_count(program0) == elisa_shader_recompiler_program_output_word_count(program1)
        assert elisa_shader_recompiler_program_payload_kind(program0) == elisa_shader_recompiler_program_payload_kind(program1)
        assert elisa_shader_recompiler_program_real_spirv_status(program0) == elisa_shader_recompiler_program_real_spirv_status(program1)
        assert elisa_shader_recompiler_program_output_word_at(program0, 0) == ELISA_SPIRV_MAGIC
        assert elisa_shader_recompiler_program_output_word_at(program1, 0) == ELISA_SPIRV_MAGIC

        ShaderRecompiler_FreeProgramViaFfi(program0)
        ShaderRecompiler_FreeProgramViaFfi(program1)
