include "../shader_recompiler/ir/reg.elisa"
include "../../compiler/runtime/elisacore_std/elisacore_runtime.elisa"

@test
def reg_counts_and_arithmetic() -> void:
    can Abort.Panic:
        assert IR_NUM_SCALAR_REGS == 104
        assert IR_NUM_VECTOR_REGS == 256
        assert ShaderIrReg_Index(7) == 7
        assert ShaderIrScalarReg_Add(4, 3) == 7
        assert ShaderIrScalarReg_Sub(7, 3) == 4
        assert ShaderIrVectorReg_Add(250, 5) == 255

@test
def refined_reg_index_conversions_accept_only_ir_file_bounds() -> void:
    can Abort.Panic:
        sgpr: mutable ShaderIrScalarRegIndex = 0
        vgpr: mutable ShaderIrVectorRegIndex = 0

        assert ShaderIrScalarRegIndex_TryFromU32(103, sgpr)
        assert not ShaderIrScalarRegIndex_TryFromU32(104, sgpr)

        assert ShaderIrVectorRegIndex_TryFromU32(255, vgpr)
        assert not ShaderIrVectorRegIndex_TryFromU32(256, vgpr)

@test
def float_class_combos_match_cpp() -> void:
    can Abort.Panic:
        assert IR_FLOAT_CLASS_NAN == (IR_FLOAT_CLASS_SIGNALING_NAN | IR_FLOAT_CLASS_QUIET_NAN)
        assert IR_FLOAT_CLASS_INFINITY == (IR_FLOAT_CLASS_POSITIVE_INFINITY | IR_FLOAT_CLASS_NEGATIVE_INFINITY)
        assert IR_FLOAT_CLASS_NEGATIVE == (IR_FLOAT_CLASS_NEGATIVE_INFINITY | IR_FLOAT_CLASS_NEGATIVE_NORMAL | IR_FLOAT_CLASS_NEGATIVE_DENORM | IR_FLOAT_CLASS_NEGATIVE_ZERO)
        assert IR_FLOAT_CLASS_FINITE == (IR_FLOAT_CLASS_NEGATIVE_NORMAL | IR_FLOAT_CLASS_NEGATIVE_DENORM | IR_FLOAT_CLASS_NEGATIVE_ZERO | IR_FLOAT_CLASS_POSITIVE_NORMAL | IR_FLOAT_CLASS_POSITIVE_DENORM | IR_FLOAT_CLASS_POSITIVE_ZERO)

@test
def texture_inst_info_bitfields_roundtrip() -> void:
    can Abort.Panic:
        raw: mutable u32 = 0
        raw <- ShaderReg_SetBitsU32(raw, 0, 1, 1)     # is_depth
        raw <- ShaderReg_SetBitsU32(raw, 6, 2, 3)     # gather_comp = 3
        raw <- ShaderReg_SetBitsU32(raw, 16, 16, 0xBEEF)  # pc
        assert TextureInstInfo_IsDepth(raw) == 1
        assert TextureInstInfo_HasBias(raw) == 0
        assert TextureInstInfo_GatherComp(raw) == 3
        assert TextureInstInfo_Pc(raw) == 0xBEEF

@test
def buffer_inst_info_bitfields_roundtrip() -> void:
    can Abort.Panic:
        raw: mutable u64 = 0
        raw <- ShaderReg_SetBitsU64(raw, 0, 1, 1)     # index_enable
        raw <- ShaderReg_SetBitsU64(raw, 2, 12, 0xABC)  # inst_offset
        raw <- ShaderReg_SetBitsU64(raw, 21, 3, 5)    # inst_num_fmt
        raw <- ShaderReg_SetBitsU64(raw, 32, 16, 0x1234)  # pc
        assert BufferInstInfo_IndexEnable(raw) == 1
        assert BufferInstInfo_VOffsetEnable(raw) == 0
        assert BufferInstInfo_InstOffset(raw) == 0xABC
        assert BufferInstInfo_InstNumFmt(raw) == 5
        assert BufferInstInfo_Pc(raw) == 0x1234
