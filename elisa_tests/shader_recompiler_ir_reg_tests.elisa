include "../shader_recompiler/ir/reg.elisa"
include "../../compiler/runtime/elisacore_std/elisacore_runtime.elisa"

@test
def reg_counts_and_arithmetic() -> void:
    can Abort.Panic:
        assert IR_NUM_SCALAR_REGS == 104u32
        assert IR_NUM_VECTOR_REGS == 256u32
        assert ShaderIrReg_Index(7u32) == 7u32
        assert ShaderIrScalarReg_Add(4u32, 3) == 7u32
        assert ShaderIrScalarReg_Sub(7u32, 3) == 4u32
        assert ShaderIrVectorReg_Add(250u32, 5) == 255u32

@test
def float_class_combos_match_cpp() -> void:
    can Abort.Panic:
        assert IR_FLOAT_CLASS_NAN == (IR_FLOAT_CLASS_SIGNALING_NAN | IR_FLOAT_CLASS_QUIET_NAN)
        assert IR_FLOAT_CLASS_INFINITY == (IR_FLOAT_CLASS_POSITIVE_INFINITY | IR_FLOAT_CLASS_NEGATIVE_INFINITY)
        assert IR_FLOAT_CLASS_NEGATIVE == (IR_FLOAT_CLASS_NEGATIVE_INFINITY | IR_FLOAT_CLASS_NEGATIVE_NORMAL | IR_FLOAT_CLASS_NEGATIVE_DENORM | IR_FLOAT_CLASS_NEGATIVE_ZERO)
        assert IR_FLOAT_CLASS_FINITE == (IR_FLOAT_CLASS_NEGATIVE_NORMAL | IR_FLOAT_CLASS_NEGATIVE_DENORM | IR_FLOAT_CLASS_NEGATIVE_ZERO | IR_FLOAT_CLASS_POSITIVE_NORMAL | IR_FLOAT_CLASS_POSITIVE_DENORM | IR_FLOAT_CLASS_POSITIVE_ZERO)

@test
def texture_inst_info_bitfields_roundtrip() -> void:
    can Abort.Panic:
        raw: mutable u32 = 0u32
        raw <- ShaderReg_SetBitsU32(raw, 0u32, 1u32, 1u32)     # is_depth
        raw <- ShaderReg_SetBitsU32(raw, 6u32, 2u32, 3u32)     # gather_comp = 3
        raw <- ShaderReg_SetBitsU32(raw, 16u32, 16u32, 0xBEEFu32)  # pc
        assert TextureInstInfo_IsDepth(raw) == 1u32
        assert TextureInstInfo_HasBias(raw) == 0u32
        assert TextureInstInfo_GatherComp(raw) == 3u32
        assert TextureInstInfo_Pc(raw) == 0xBEEFu32

@test
def buffer_inst_info_bitfields_roundtrip() -> void:
    can Abort.Panic:
        raw: mutable u64 = 0u64
        raw <- ShaderReg_SetBitsU64(raw, 0u32, 1u32, 1u64)     # index_enable
        raw <- ShaderReg_SetBitsU64(raw, 2u32, 12u32, 0xABCu64)  # inst_offset
        raw <- ShaderReg_SetBitsU64(raw, 21u32, 3u32, 5u64)    # inst_num_fmt
        raw <- ShaderReg_SetBitsU64(raw, 32u32, 16u32, 0x1234u64)  # pc
        assert BufferInstInfo_IndexEnable(raw) == 1u64
        assert BufferInstInfo_VOffsetEnable(raw) == 0u64
        assert BufferInstInfo_InstOffset(raw) == 0xABCu64
        assert BufferInstInfo_InstNumFmt(raw) == 5u64
        assert BufferInstInfo_Pc(raw) == 0x1234u64
