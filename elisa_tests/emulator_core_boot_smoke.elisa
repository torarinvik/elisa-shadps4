include "../core/user_settings.elisa"
include "../main.elisa"

# Reset the process-wide singletons touched by the launch pipeline so each
# scenario proves the boot path from a clean emulator runtime state.
def BootSmoke_Check(cond: bool, message: static u8&) -> void:
    if not cond:
        panic(message)


def BootSmoke_CheckHleEntrypoint(symbol_name: static u8&, expected_entrypoint: u64, message: static u8&) -> void:
    entrypoint: u64 = HLELibs_EntrypointForSymbol("", symbol_name)
    BootSmoke_Check(entrypoint == expected_entrypoint, message)
    BootSmoke_Check(entrypoint != HLELibs_DispatcherTrampoline.uintptr().u64(), "expected HLE symbol to avoid dispatcher trampoline")


def BootSmoke_ResetRuntime() -> void:
    Emulator_Reset()
    Linker_Reset()
    EmulatorState_ResetInstance()
    settings: mutable EmulatorSettingsImpl& = EmulatorSettings_GetInstance()
    EmulatorSettings_SetDefaultValues(settings)
    UserSettings_Reset()

@test
def emulator_core_boot_smoke_runs_game_path_from_main() -> void:
    can Memory.Allocate, Abort.Panic:
        BootSmoke_ResetRuntime()

        arena: Arena = zeroed
        result: mutable int = -1
        in arena:
            args: mutable darray[static u8&] = ["shadps4", "CUSA00000", "--", "-SomeGuestArg", "42"]
            can Unsafe.SegmentMutation, Unsafe.GuestSegmentInstall, Segment.Guest, Segment.Host:
                result <- Main_Run(args)
        BootSmoke_Check(result == 0, "expected Main_Run success")

        emu: mutable Emulator& = Emulator_GetInstance()
        BootSmoke_Check(streq(Emulator_GetLastRunPath(emu), "CUSA00000/eboot.bin") == 1, "expected directory launch to append eboot.bin")
        BootSmoke_Check(streq(Emulator_GetLastGameFolder(emu), "CUSA00000") == 1, "expected game folder from launch directory")
        BootSmoke_Check(streq(Emulator_GetLastGuestEbootPath(emu), "/app0/eboot.bin") == 1, "expected guest eboot path")
        BootSmoke_Check(streq(Emulator_GetLastParamSfoPath(emu), "CUSA00000/sce_sys/param.sfo") == 1, "expected param.sfo path")
        BootSmoke_Check(streq(Emulator_GetLastLinkerLoadPath(emu), "/app0/eboot.bin") == 1, "expected linker load path")
        BootSmoke_Check(emu.last_linker_module_index == 0, "expected first linker module index")
        BootSmoke_Check(emu.last_linker_module_count == 1, "expected one loaded module")
        BootSmoke_Check(emu.last_linker_execute_argc <= 3, "expected linker execute argc to mirror guest args")
        BootSmoke_Check(emu.last_linker_start_result == 0, "expected module start success")
        linker: mutable Linker& = Linker_GetInstance()
        BootSmoke_Check(linker.modules.count == 1, "expected linker module record")
        BootSmoke_Check(streq(linker.modules[0].file, "/app0/eboot.bin") == 1, "expected linker module file")
        BootSmoke_Check(linker.num_static_modules == 1, "expected static module count")
        BootSmoke_Check(static_strlen(linker.modules[0].name) > 0, "expected module name from loaded ELF metadata")
        BootSmoke_Check(static_strlen(linker.modules[0].dynamic_info.filename) > 0, "expected parsed ELF metadata path")
        BootSmoke_Check(Module_GetImportSymbolCount(linker.modules[0]) > 0usize, "expected parsed ELF imports")
        BootSmoke_Check(Module_GetResolvedImportSymbolCount(linker.modules[0]) == Module_GetImportSymbolCount(linker.modules[0]), "expected resolved parsed ELF imports")
        BootSmoke_Check(linker.modules[0].executable_segment_permission_mismatch_count == 0usize, "expected executable PT_LOAD mappings to retain execute permission")
        BootSmoke_Check(linker.last_relocated_import_count == Module_GetImportSymbolCount(linker.modules[0]), "expected linker relocated parsed ELF imports")
        BootSmoke_Check(linker.last_unresolved_import_count == 0usize, "expected no unresolved imports")
        BootSmoke_Check(linker.hle_libs_initialized, "expected HLE libraries initialized")
        BootSmoke_Check(linker.hle_registered_symbol_count >= 1883usize, "expected broad boot HLE symbol table")
        BootSmoke_Check(Linker_HleTinyCallableCount() == 0u64, "expected no HLE function to register a zero/tiny callable address")
        BootSmoke_Check(Linker_TinyPointerSlotCount() == 0u64, "expected no pointer relocation to write a near-null value")
        BootSmoke_Check(Linker_NativeHleUnthunkedFunctionCount() == 0u64, "expected every native HLE function relocation to be thunkable")
        BootSmoke_Check(Linker_NativeHleFunctionAddendCount() == 0u64, "expected native HLE function relocations to have zero addend")
        BootSmoke_Check(Linker_NativeHleDataThunkPointerCount() == 0u64, "expected native HLE data relocations to avoid boundary thunks")
        BootSmoke_Check(SymbolsResolver_FindByNid(linker.hle_symbols, "D4yla3vx4tY") >= 0, "expected libkernel sceKernelError NID")
        BootSmoke_Check(SymbolsResolver_FindByNid(linker.hle_symbols, "wzvqT4UqKX8") >= 0, "expected libkernel sceKernelLoadStartModule NID")
        BootSmoke_Check(SymbolsResolver_FindByNid(linker.hle_symbols, "JfEPXVxhFqA") >= 0, "expected libSceAudioOut sceAudioOutInit NID")
        BootSmoke_Check(SymbolsResolver_FindByNid(linker.hle_symbols, "SxQprgjttKE") >= 0, "expected libSceAudioIn sceAudioInInit NID")
        BootSmoke_Check(SymbolsResolver_FindByNid(linker.hle_symbols, "K4KnH0QkT2c") >= 0, "expected libSceHmd sceHmdInitialize NID")
        BootSmoke_Check(SymbolsResolver_FindByNid(linker.hle_symbols, "9yK6Fk8mKOQ") >= 0, "expected libSceGameLiveStreaming terminate NID")
        BootSmoke_Check(SymbolsResolver_FindByNid(linker.hle_symbols, "rWUTcKdkUzQ") >= 0, "expected generated libSceVideoOut NID")
        BootSmoke_Check(SymbolsResolver_FindByNid(linker.hle_symbols, "ekXHb1kDBl0") >= 0, "expected generated libSceErrorDialog NID")
        kernel_error_index: s32 = SymbolsResolver_FindByNid(linker.hle_symbols, "D4yla3vx4tY")
        kernel_error_symbol: SymbolRecord = linker.hle_symbols.symbols[kernel_error_index.usize()]
        BootSmoke_Check(kernel_error_symbol.callable_address == sceKernelError.uintptr().u64(), "expected sceKernelError to bind to its Elisa entrypoint")
        BootSmoke_Check(kernel_error_symbol.callable_address != kernel_error_symbol.virtual_address, "expected sceKernelError binding to replace synthetic HLE address")
        load_start_index: s32 = SymbolsResolver_FindByNid(linker.hle_symbols, "wzvqT4UqKX8")
        load_start_symbol: SymbolRecord = linker.hle_symbols.symbols[load_start_index.usize()]
        BootSmoke_Check(load_start_symbol.callable_address == sceKernelLoadStartModule.uintptr().u64(), "expected sceKernelLoadStartModule to bind to its Elisa entrypoint")
        videoout_index: s32 = SymbolsResolver_FindByNid(linker.hle_symbols, "rWUTcKdkUzQ")
        videoout_symbol: SymbolRecord = linker.hle_symbols.symbols[videoout_index.usize()]
        BootSmoke_Check(videoout_symbol.callable_address == HLELibs_DispatcherTrampoline.uintptr().u64(), "expected unbound generated HLE symbol to use dispatcher trampoline")
        BootSmoke_CheckHleEntrypoint("sceKernelGetModuleInfo", sceKernelGetModuleInfo.uintptr().u64(), "expected process/module info HLE entrypoint")
        BootSmoke_CheckHleEntrypoint("sceKernelMmap", sceKernelMmap.uintptr().u64(), "expected memory HLE entrypoint")
        BootSmoke_CheckHleEntrypoint("sceKernelClockGettime", sceKernelClockGettime.uintptr().u64(), "expected time HLE entrypoint")
        BootSmoke_CheckHleEntrypoint("sceKernelCreateEqueue", sceKernelCreateEqueue.uintptr().u64(), "expected equeue HLE entrypoint")
        BootSmoke_CheckHleEntrypoint("scePthreadMutexInit", scePthreadMutexInit.uintptr().u64(), "expected pthread mutex HLE entrypoint")
        BootSmoke_CheckHleEntrypoint("sceKernelCreateSema", sceKernelCreateSema.uintptr().u64(), "expected semaphore HLE entrypoint")
        BootSmoke_CheckHleEntrypoint("sceKernelCreateEventFlag", sceKernelCreateEventFlag.uintptr().u64(), "expected event flag HLE entrypoint")
        BootSmoke_Check(HLELibs_EntrypointForSymbol("", "sceKernelDefinitelyMissingForSmoke") == HLELibs_DispatcherTrampoline.uintptr().u64(), "expected unknown HLE symbol to use dispatcher trampoline")
        resolved_kernel_error: mutable u64 = 0
        resolved_kind: mutable u8 = 0u8
        BootSmoke_Check(Linker_Resolve(linker, "D4yla3vx4tY", linker.modules[0].ref[mutable Module&], resolved_kernel_error.ref[mutable u64&], resolved_kind.ref[mutable u8&]), "expected linker to resolve sceKernelError")
        BootSmoke_Check(resolved_kernel_error == sceKernelError.uintptr().u64(), "expected linker resolve to return callable sceKernelError entrypoint")
        BootSmoke_Check(linker.relocated_all_imports, "expected import relocation seam")
        BootSmoke_Check(linker.last_started_module_index == 0, "expected started module index")
        BootSmoke_Check(linker.last_start_result == 0, "expected linker start result")
        BootSmoke_Check(linker.last_entry_addr == Module_GetEntryAddress(linker.modules[0], 0.uintptr()), "expected linker to record module entry address")
        BootSmoke_Check(not linker.native_guest_exec_requested, "expected native guest exec disabled by default")
        BootSmoke_Check(not GuestExec_IsEnabled(), "expected native guest exec runtime disabled by default")
        BootSmoke_Check(linker.modules[0].last_start_entry_addr != 0.uintptr(), "expected module start to record callable entry or init address")
        BootSmoke_Check(Memory_Instance().total_direct_size == GB(5), "expected direct memory region setup")
        BootSmoke_Check(Memory_Instance().total_flexible_size == ORBIS_KERNEL_FLEXIBLE_MEMORY_SIZE, "expected flexible memory region setup")
        BootSmoke_Check(emu.app0_mounted, "expected app0 mount")
        BootSmoke_Check(emu.hostapp_mounted, "expected hostapp mount")
        BootSmoke_Check(emu.last_run_argc <= 3, "expected launch to preserve a bounded guest arg vector")
        BootSmoke_Check(streq(emu.executable_name, "shadps4") == 1, "expected executable name")
        BootSmoke_Check(not emu.native_guest_exec_requested, "expected launch to leave native guest exec disabled by default")
        BootSmoke_Check(emu.start_tick == 1.u64(), "expected one start tick")
        BootSmoke_Check(not emu.pending_restart, "expected no pending restart")

        state: mutable EmulatorState& = EmulatorState_GetInstance()
        BootSmoke_Check(EmulatorState_IsGameRunning(state), "expected game running")

@test
def emulator_core_boot_smoke_load_start_module_routes_guest_modules_through_linker() -> void:
    can Memory.Allocate, Abort.Panic, Unsafe.SegmentMutation, Unsafe.GuestSegmentInstall, Segment.Guest, Segment.Host:
        BootSmoke_ResetRuntime()

        arena: Arena = zeroed
        result: mutable int = -1
        in arena:
            args: mutable darray[static u8&] = ["shadps4", "CUSA00000"]
            can Unsafe.SegmentMutation, Unsafe.GuestSegmentInstall, Segment.Guest, Segment.Host:
                result <- Main_Run(args)
        BootSmoke_Check(result == 0, "expected Main_Run success before dynamic module load")

        null_path_result: int = sceKernelLoadStartModule(null, 0u64, null, 0u32, null, null)
        BootSmoke_Check(null_path_result == ORBIS_KERNEL_ERROR_EFAULT, "expected null module path fault")

        empty_start_result: mutable int = -99
        empty_path_result: int = sceKernelLoadStartModule("", 0u64, null, 0u32, null, empty_start_result.ref[mutable int&].cast[void&?])
        BootSmoke_Check(empty_path_result == ORBIS_KERNEL_ERROR_EINVAL, "expected empty module path invalid")
        BootSmoke_Check(empty_start_result == -99, "expected empty module path not to start")

        linker: mutable Linker& = Linker_GetInstance()
        before_count: usize = linker.modules.count
        start_result: mutable int = -99
        handle: int = sceKernelLoadStartModule("fixture_module.prx", 0u64, null, 0u32, null, start_result.ref[mutable int&].cast[void&?])
        BootSmoke_Check(handle >= 0, "expected bare module name to load")
        BootSmoke_Check(start_result == 0, "expected dynamic module start result")
        BootSmoke_Check(linker.modules.count == before_count + 1usize, "expected dynamic module to be appended")
        BootSmoke_Check(linker.last_loaded_dynamic_host_path != null, "expected linker to record resolved dynamic host path")
        BootSmoke_Check(streq(linker.last_loaded_dynamic_host_path, "CUSA00000/fixture_module.prx") == 1, "expected bare module to resolve under app0 root")
        BootSmoke_Check(streq(linker.modules[handle.usize()].file, "fixture_module.prx") == 1, "expected dynamic module guest identity path")
        BootSmoke_Check(streq(linker.modules[handle.usize()].host_file, "CUSA00000/fixture_module.prx") == 1, "expected dynamic module host backing path")
        BootSmoke_Check(linker.last_started_module_index == handle.s32(), "expected dynamic module to be started")

        duplicate_start_result: mutable int = -99
        duplicate_handle: int = sceKernelLoadStartModule("fixture_module.prx", 0u64, null, 0u32, null, duplicate_start_result.ref[mutable int&].cast[void&?])
        BootSmoke_Check(duplicate_handle == handle, "expected duplicate dynamic module load to reuse handle")
        BootSmoke_Check(duplicate_start_result == 0, "expected duplicate dynamic module load to report success")
        BootSmoke_Check(linker.modules.count == before_count + 1usize, "expected duplicate dynamic module load not to append")

        app0_start_result: mutable int = -99
        app0_handle: int = sceKernelLoadStartModule("/app0/sce_sys/about/right.sprx", 0u64, null, 0u32, null, app0_start_result.ref[mutable int&].cast[void&?])
        BootSmoke_Check(app0_handle >= 0, "expected /app0 module path to load")
        BootSmoke_Check(app0_start_result == 0, "expected /app0 module start result")
        BootSmoke_Check(linker.last_loaded_dynamic_host_path != null, "expected linker to record app0 dynamic host path")
        BootSmoke_Check(streq(linker.last_loaded_dynamic_host_path, "CUSA00000/sce_sys/about/right.sprx") == 1, "expected /app0 module to resolve under app0 root")

@test
def emulator_core_boot_smoke_applies_cli_runtime_flags() -> void:
    can Memory.Allocate, Abort.Panic:
        BootSmoke_ResetRuntime()

        arena: Arena = zeroed
        result: mutable int = -1
        in arena:
            args: mutable darray[static u8&] = ["shadps4", "--show-fps", "--fullscreen", "true", "--config-global", "--override-root", "/mnt/app0", "/games/CUSA00001/eboot.bin"]
            can Unsafe.SegmentMutation, Unsafe.GuestSegmentInstall, Segment.Guest, Segment.Host:
                result <- Main_Run(args)
        BootSmoke_Check(result == 0, "expected Main_Run success")

        settings: mutable EmulatorSettingsImpl& = EmulatorSettings_GetInstance()
        BootSmoke_Check(EmulatorSettings_IsShowFpsCounter(settings), "expected show fps")
        BootSmoke_Check(EmulatorSettings_IsFullScreen(settings), "expected fullscreen")
        BootSmoke_Check(EmulatorSettings_GetConfigMode(settings) == ConfigMode.Global, "expected global config")

        emu: mutable Emulator& = Emulator_GetInstance()
        BootSmoke_Check(streq(Emulator_GetLastRunPath(emu), "/games/CUSA00001/eboot.bin") == 1, "expected eboot path")
        BootSmoke_Check(streq(Emulator_GetLastGameFolder(emu), "/mnt/app0") == 1, "expected override root")
        BootSmoke_Check(streq(Emulator_GetLastGuestEbootPath(emu), "/app0/eboot.bin") == 1, "expected override-root guest eboot fallback")

@test
def emulator_core_boot_smoke_import_resolution_classification() -> void:
    can Memory.Allocate, Abort.Panic:
        Linker_Reset()
        parsed_nid: mutable static u8& = ""
        parsed_lib: mutable static u8& = ""
        parsed_mod: mutable static u8& = ""
        BootSmoke_Check(Module_ParseImportSymbol("D4yla3vx4tY#libkernel#libkernel", parsed_nid.ref[mutable static u8&], parsed_lib.ref[mutable static u8&], parsed_mod.ref[mutable static u8&]), "expected full nid#lib#mod parse")
        BootSmoke_Check(streq(parsed_nid, "D4yla3vx4tY") == 1, "expected parsed nid")
        BootSmoke_Check(streq(parsed_lib, "libkernel") == 1, "expected parsed library")
        BootSmoke_Check(streq(parsed_mod, "libkernel") == 1, "expected parsed module")
        parsed_nid <- ""
        parsed_lib <- ""
        parsed_mod <- ""
        BootSmoke_Check(Module_ParseImportSymbol("D4yla3vx4tY", parsed_nid.ref[mutable static u8&], parsed_lib.ref[mutable static u8&], parsed_mod.ref[mutable static u8&]), "expected NID-only parse")
        BootSmoke_Check(streq(parsed_nid, "D4yla3vx4tY") == 1, "expected NID-only parse to preserve nid")
        BootSmoke_ResetRuntime()
        arena: Arena = zeroed
        result: mutable int = -1
        in arena:
            args: mutable darray[static u8&] = ["shadps4", "CUSA00000"]
            can Unsafe.SegmentMutation, Unsafe.GuestSegmentInstall, Segment.Guest, Segment.Host:
                result <- Main_Run(args)
        BootSmoke_Check(result == 0, "expected Main_Run success")
        linker: mutable Linker& = Linker_GetInstance()
        resolved_addr: mutable u64 = 0
        resolved_kind: mutable u8 = 0u8
        BootSmoke_Check(Linker_Resolve(linker, "D4yla3vx4tY", linker.modules[0].ref[mutable Module&], resolved_addr.ref[mutable u64&], resolved_kind.ref[mutable u8&]), "expected HLE match by NID")
        BootSmoke_Check(resolved_kind == IMPORT_RESOLUTION_NATIVE_HLE, "expected NID resolution classified as NativeElisaHLE")
        BootSmoke_Check(Linker_Resolve(linker, "D4yla3vx4tY#libkernel#libkernel", linker.modules[0].ref[mutable Module&], resolved_addr.ref[mutable u64&], resolved_kind.ref[mutable u8&]), "expected HLE match by full symbol")
        BootSmoke_Check(resolved_kind == IMPORT_RESOLUTION_NATIVE_HLE, "expected full symbol resolution classified as NativeElisaHLE")
        BootSmoke_Check(Linker_Resolve(linker, "DefinitelyUnknownSymbol", linker.modules[0].ref[mutable Module&], resolved_addr.ref[mutable u64&], resolved_kind.ref[mutable u8&]), "expected unknown symbol to fallback")
        BootSmoke_Check(resolved_kind == IMPORT_RESOLUTION_AEROLIB_FALLBACK, "expected unknown symbol classified as AeroLibFallback")
        BootSmoke_Check(not Linker_Resolve(linker, "", linker.modules[0].ref[mutable Module&], resolved_addr.ref[mutable u64&], resolved_kind.ref[mutable u8&]), "expected empty symbol to be rejected")
        BootSmoke_Check(resolved_kind == IMPORT_RESOLUTION_MALFORMED, "expected empty symbol classified as malformed")

@test
def emulator_core_boot_smoke_utility_commands_do_not_start_game() -> void:
    can Memory.Allocate, Abort.Panic:
        BootSmoke_ResetRuntime()

        arena: Arena = zeroed
        add_result: mutable int = -1
        in arena:
            add_args: mutable darray[static u8&] = ["shadps4", "--add-game-folder", "/games/library"]
            can Unsafe.SegmentMutation, Unsafe.GuestSegmentInstall, Segment.Guest, Segment.Host:
                add_result <- Main_Run(add_args)
        BootSmoke_Check(add_result == 0, "expected add folder success")

        state: mutable EmulatorState& = EmulatorState_GetInstance()
        BootSmoke_Check(not EmulatorState_IsGameRunning(state), "expected game not running")

        settings: mutable EmulatorSettingsImpl& = EmulatorSettings_GetInstance()
        dirs: darray[static u8&] = EmulatorSettings_GetGameInstallDirs(settings)
        BootSmoke_Check(dirs.count == 1, "expected one game folder")
        BootSmoke_Check(streq(dirs[0], "/games/library") == 1, "expected game folder path")

        addon_result: mutable int = -1
        in arena:
            addon_args: mutable darray[static u8&] = ["shadps4", "--set-addon-folder", "/games/addons"]
            can Unsafe.SegmentMutation, Unsafe.GuestSegmentInstall, Segment.Guest, Segment.Host:
                addon_result <- Main_Run(addon_args)
        BootSmoke_Check(addon_result == 0, "expected addon folder success")
        BootSmoke_Check(not EmulatorState_IsGameRunning(state), "expected game not running")
        BootSmoke_Check(streq(EmulatorSettings_GetAddonInstallDir(settings), "/games/addons") == 1, "expected addon folder")

@test
def emulator_core_boot_smoke_rejects_invalid_or_missing_launch() -> void:
    can Memory.Allocate, Abort.Panic:
        BootSmoke_ResetRuntime()

        arena: Arena = zeroed
        missing_result: mutable int = -1
        in arena:
            missing_args: mutable darray[static u8&] = ["shadps4"]
            can Unsafe.SegmentMutation, Unsafe.GuestSegmentInstall, Segment.Guest, Segment.Host:
                missing_result <- Main_Run(missing_args)
        BootSmoke_Check(missing_result == 1, "expected missing launch failure")
        state: mutable EmulatorState& = EmulatorState_GetInstance()
        BootSmoke_Check(not EmulatorState_IsGameRunning(state), "expected game not running")

        bad_result: mutable int = -1
        in arena:
            bad_fullscreen_args: mutable darray[static u8&] = ["shadps4", "--fullscreen", "maybe", "CUSA00002"]
            can Unsafe.SegmentMutation, Unsafe.GuestSegmentInstall, Segment.Guest, Segment.Host:
                bad_result <- Main_Run(bad_fullscreen_args)
        BootSmoke_Check(bad_result == 1, "expected bad fullscreen failure")
        BootSmoke_Check(not EmulatorState_IsGameRunning(state), "expected game not running")

@test
def emulator_core_boot_smoke_normalizes_update_and_patch_launches() -> void:
    can Memory.Allocate, Abort.Panic:
        BootSmoke_ResetRuntime()

        arena: Arena = zeroed
        result: mutable int = -1
        in arena:
            args: mutable darray[static u8&] = ["shadps4", "/games/CUSA99999-UPDATE/eboot.bin"]
            can Unsafe.SegmentMutation, Unsafe.GuestSegmentInstall, Segment.Guest, Segment.Host:
                result <- Main_Run(args)
        BootSmoke_Check(result == 0, "expected update launch success")

        emu: mutable Emulator& = Emulator_GetInstance()
        BootSmoke_Check(streq(Emulator_GetLastRunPath(emu), "/games/CUSA99999-UPDATE/eboot.bin") == 1, "expected update eboot path")
        BootSmoke_Check(streq(Emulator_GetLastGameFolder(emu), "/games/CUSA99999") == 1, "expected base game folder for update launch")
        BootSmoke_Check(streq(Emulator_GetLastGuestEbootPath(emu), "/app0/eboot.bin") == 1, "expected update guest eboot fallback")
