include "../core/libraries/ime/ime_dialog_ui.elisa"
include "../../compiler/runtime/elisacore_std/elisacore_runtime.elisa"

@test
def ime_dialog_ui_enums() -> void:
    can Abort.Panic:
        assert IME_DIALOG_PANEL_SELECTION_TARGET_INPUT == 0u32
        assert IME_DIALOG_PANEL_SELECTION_TARGET_PREDICTION == 1u32
        assert IME_DIALOG_PANEL_SELECTION_TARGET_CLOSE == 2u32
        assert IME_DIALOG_PANEL_SELECTION_TARGET_KEYBOARD == 3u32
        assert IME_DIALOG_EDIT_MENU_POPUP_NONE == 0u32
        assert IME_DIALOG_EDIT_MENU_POPUP_MAIN == 1u32
        assert IME_DIALOG_EDIT_MENU_POPUP_ACTIONS == 2u32
