include "../core/libraries/error_codes.elisa"
include "../common/types.elisa"
include "../../compiler/runtime/elisacore_std/elisacore_runtime.elisa"
include "../core/libraries/ngs2/ngs2.elisa"

global mutable ngs2_test_alloc_called: u32 = 0u32
global mutable ngs2_test_free_called: u32 = 0u32

def ngs2_test_alloc(info: mutable OrbisNgs2ContextBufferInfo&?) -> s32:
    ngs2_test_alloc_called <- ngs2_test_alloc_called + 1u32
    if info == null:
        return ORBIS_NGS2_ERROR_INVALID_BUFFER_INFO
    static_byte: mutable u8 = 0u8
    info.host_buffer <- &static_byte
    return ORBIS_OK

def ngs2_test_free(info: mutable OrbisNgs2ContextBufferInfo&?) -> s32:
    ngs2_test_free_called <- ngs2_test_free_called + 1u32
    _ = info
    return ORBIS_OK

@test
def ngs2_system_rack_basic_contracts() -> void:
    can Abort.Panic:
        system: mutable u64 = 0
        rack: mutable u64 = 0
        voice: mutable u64 = 0
        voice_again: mutable u64 = 0
        voice_1: mutable u64 = 0
        owner_rack: mutable u64 = 0
        owner_index: mutable u32 = 0u32
        flags: mutable u32 = 0u32
        user_data: mutable usize = 0
        system_info: OrbisNgs2SystemInfo = zeroed
        rack_info: OrbisNgs2RackInfo = zeroed
        wave_info: OrbisNgs2WaveformInfo = zeroed
        one_byte: mutable u8 = 1u8
        query_size: mutable usize = 0
        rack_query_size_default: mutable usize = 0
        rack_query_size_custom: mutable usize = 0
        out_destroy_system_info: mutable OrbisNgs2ContextBufferInfo = zeroed
        out_destroy_rack_info: mutable OrbisNgs2ContextBufferInfo = zeroed

        assert sceNgs2SystemCreate(null, null, system) == ORBIS_NGS2_ERROR_INVALID_BUFFER_INFO

        buffer_info: mutable OrbisNgs2ContextBufferInfo = zeroed
        buffer_info.user_data <- 77
        assert sceNgs2SystemCreate(null, buffer_info, system) == ORBIS_NGS2_ERROR_INVALID_BUFFER_ADDRESS
        assert sceNgs2SystemQueryBufferSize(null, query_size) == ORBIS_OK
        assert query_size == 8
        buffer_info.host_buffer <- &one_byte
        buffer_info.host_buffer_size <- 7
        assert sceNgs2SystemCreate(null, buffer_info, system) == ORBIS_NGS2_ERROR_INVALID_BUFFER_SIZE
        buffer_info.host_buffer_size <- query_size

        bad_option: mutable OrbisNgs2SystemOption = zeroed
        bad_option.size <- 64
        bad_option.max_grain_samples <- 63u32
        bad_option.num_grain_samples <- 256u32
        bad_option.sample_rate <- 48000u32
        assert sceNgs2SystemCreate(bad_option, buffer_info, system) == ORBIS_NGS2_ERROR_INVALID_MAX_GRAIN_SAMPLES
        bad_option.max_grain_samples <- 512u32
        bad_option.sample_rate <- 12345u32
        assert sceNgs2SystemCreate(bad_option, buffer_info, system) == ORBIS_NGS2_ERROR_INVALID_SAMPLE_RATE

        assert sceNgs2SystemCreate(null, buffer_info, system) == ORBIS_OK

        assert sceNgs2SystemEnumHandles(system, 1u32) == 1
        assert sceNgs2SystemGetUserData(system, user_data) == ORBIS_OK
        assert user_data == 77
        assert sceNgs2SystemSetUserData(system, 123) == ORBIS_OK
        assert sceNgs2SystemGetUserData(system, user_data) == ORBIS_OK
        assert user_data == 123

        assert sceNgs2RackCreate(0, 0, null, null, rack) == ORBIS_NGS2_ERROR_INVALID_SYSTEM_HANDLE
        assert sceNgs2RackQueryBufferSize(0u32, null, rack_query_size_default) == ORBIS_OK
        assert rack_query_size_default > 0
        rack_option: mutable OrbisNgs2RackOption = zeroed
        rack_option.max_voices <- 8u32
        assert sceNgs2RackQueryBufferSize(0u32, rack_option, rack_query_size_custom) == ORBIS_OK
        assert rack_query_size_custom < rack_query_size_default
        assert sceNgs2RackCreate(system, 0, null, null, rack) == ORBIS_OK
        assert sceNgs2RackSetUserData(rack, 456) == ORBIS_OK
        assert sceNgs2RackGetUserData(rack, user_data) == ORBIS_OK
        assert user_data == 456

        assert sceNgs2RackGetVoiceHandle(rack, 0u32, voice) == ORBIS_OK
        assert sceNgs2RackGetVoiceHandle(rack, 0u32, voice_again) == ORBIS_OK
        assert voice_again == voice
        assert sceNgs2RackGetVoiceHandle(rack, 1u32, voice_1) == ORBIS_OK
        assert voice_1 != voice
        assert sceNgs2RackGetVoiceHandle(rack, 64u32, voice_again) == ORBIS_NGS2_ERROR_INVALID_VOICE_INDEX
        assert sceNgs2SystemEnumRackHandles(system, rack, 1u32) == 1
        assert sceNgs2VoiceGetStateFlags(voice, flags) == ORBIS_OK
        assert sceNgs2VoiceGetOwner(voice_1, owner_rack, owner_index) == ORBIS_OK
        assert owner_rack == rack
        assert owner_index == 1u32
        assert sceNgs2VoiceGetStateFlags(0, flags) == ORBIS_NGS2_ERROR_INVALID_VOICE_HANDLE

        assert sceNgs2SystemRender(system, null, 0u32) == ORBIS_OK
        assert sceNgs2SystemGetInfo(system, (&system_info).cast[mutable OrbisNgs2SystemInfo&], size_of(OrbisNgs2SystemInfo)) == ORBIS_OK
        assert system_info.system_handle == system
        assert system_info.rack_count == 1u32
        assert system_info.render_count == 1
        assert sceNgs2RackGetInfo(rack, (&rack_info).cast[mutable OrbisNgs2RackInfo&], size_of(OrbisNgs2RackInfo)) == ORBIS_OK
        assert rack_info.rack_handle == rack
        assert rack_info.owner_system_handle == system
        assert rack_info.render_count == 1u64

        assert sceNgs2ParseWaveformData(&one_byte, 1, (&wave_info).cast[mutable OrbisNgs2WaveformInfo&]) == ORBIS_OK
        assert wave_info.format.num_channels == 1u32
        assert wave_info.format.sample_rate == 48000u32
        assert wave_info.num_blocks == 1u32
        assert wave_info.a_block0.data_size == 1u32
        assert wave_info.a_block0.num_repeats == 1u32

        assert sceNgs2RackDestroy(rack, out_destroy_rack_info) == ORBIS_OK
        assert sceNgs2SystemDestroy(system, out_destroy_system_info) == ORBIS_OK
        assert out_destroy_system_info.user_data == 123

@test
def ngs2_multiple_systems_and_racks_are_tracked() -> void:
    can Abort.Panic:
        one_byte: mutable u8 = 1u8
        buffer_info: mutable OrbisNgs2ContextBufferInfo = zeroed
        buffer_info.host_buffer <- &one_byte
        buffer_info.host_buffer_size <- 8

        system_a: mutable u64 = 0
        system_b: mutable u64 = 0
        rack_a0: mutable u64 = 0
        rack_a1: mutable u64 = 0
        rack_b0: mutable u64 = 0
        voice_a: mutable u64 = 0
        voice_b: mutable u64 = 0
        owner: mutable u64 = 0
        index: mutable u32 = 0u32
        info_a: OrbisNgs2SystemInfo = zeroed
        info_b: OrbisNgs2SystemInfo = zeroed
        rack_info: OrbisNgs2RackInfo = zeroed
        handles: mutable u64[4] = zeroed

        buffer_info.user_data <- 101
        assert sceNgs2SystemCreate(null, buffer_info, system_a) == ORBIS_OK
        buffer_info.user_data <- 202
        assert sceNgs2SystemCreate(null, buffer_info, system_b) == ORBIS_OK
        assert system_a != system_b

        assert sceNgs2RackCreate(system_a, 10u32, null, null, rack_a0) == ORBIS_OK
        assert sceNgs2RackCreate(system_a, 11u32, null, null, rack_a1) == ORBIS_OK
        assert sceNgs2RackCreate(system_b, 20u32, null, null, rack_b0) == ORBIS_OK

        assert sceNgs2SystemEnumHandles(handles[0], 4u32) >= 2
        assert sceNgs2SystemEnumRackHandles(system_a, handles[0], 4u32) == 2
        assert sceNgs2SystemEnumRackHandles(system_b, handles[0], 4u32) == 1

        assert sceNgs2RackGetVoiceHandle(rack_a1, 3u32, voice_a) == ORBIS_OK
        assert sceNgs2RackGetVoiceHandle(rack_b0, 3u32, voice_b) == ORBIS_OK
        assert voice_a != voice_b
        assert sceNgs2VoiceGetOwner(voice_a, owner, index) == ORBIS_OK
        assert owner == rack_a1
        assert index == 3u32
        assert sceNgs2VoiceGetOwner(voice_b, owner, index) == ORBIS_OK
        assert owner == rack_b0
        assert index == 3u32

        assert sceNgs2SystemRender(system_a, null, 0u32) == ORBIS_OK
        assert sceNgs2SystemGetInfo(system_a, (&info_a).cast[mutable OrbisNgs2SystemInfo&], size_of(OrbisNgs2SystemInfo)) == ORBIS_OK
        assert sceNgs2SystemGetInfo(system_b, (&info_b).cast[mutable OrbisNgs2SystemInfo&], size_of(OrbisNgs2SystemInfo)) == ORBIS_OK
        assert info_a.rack_count == 2u32
        assert info_b.rack_count == 1u32
        assert info_a.render_count == 1
        assert info_b.render_count == 0
        assert sceNgs2RackGetInfo(rack_a0, (&rack_info).cast[mutable OrbisNgs2RackInfo&], size_of(OrbisNgs2RackInfo)) == ORBIS_OK
        assert rack_info.render_count == 1u64
        assert sceNgs2RackGetInfo(rack_b0, (&rack_info).cast[mutable OrbisNgs2RackInfo&], size_of(OrbisNgs2RackInfo)) == ORBIS_OK
        assert rack_info.render_count == 0u64

        assert sceNgs2SystemDestroy(system_a, null) == ORBIS_OK
        assert sceNgs2RackGetInfo(rack_a0, (&rack_info).cast[mutable OrbisNgs2RackInfo&], size_of(OrbisNgs2RackInfo)) == ORBIS_NGS2_ERROR_INVALID_RACK_HANDLE
        assert sceNgs2VoiceGetOwner(voice_a, owner, index) == ORBIS_NGS2_ERROR_INVALID_VOICE_HANDLE
        assert sceNgs2SystemGetInfo(system_b, (&info_b).cast[mutable OrbisNgs2SystemInfo&], size_of(OrbisNgs2SystemInfo)) == ORBIS_OK
        assert sceNgs2SystemDestroy(system_b, null) == ORBIS_OK

@test
def ngs2_allocator_and_voice_state_paths() -> void:
    can Abort.Panic:
        ngs2_test_alloc_called <- 0u32
        ngs2_test_free_called <- 0u32

        allocator: mutable OrbisNgs2BufferAllocator = zeroed
        allocator.alloc_handler <- ngs2_test_alloc.cast[OrbisNgs2BufferAllocHandler]
        allocator.free_handler <- ngs2_test_free.cast[OrbisNgs2BufferFreeHandler]
        allocator.user_data <- 999

        system: mutable u64 = 0
        rack: mutable u64 = 0
        voice: mutable u64 = 0
        out_flags: mutable u32 = 0u32
        report_handle: mutable u64 = 0
        port_info: mutable OrbisNgs2VoicePortInfo = zeroed
        matrix_info: mutable OrbisNgs2VoiceMatrixInfo = zeroed
        custom_state: mutable OrbisNgs2CustomSamplerVoiceState = zeroed
        level0: mutable f32 = 0.25
        level1: mutable f32 = 0.75
        block: mutable OrbisNgs2WaveformBlock = zeroed
        event_param: mutable OrbisNgs2VoiceEventParam = zeroed
        volume_param: mutable OrbisNgs2VoicePortVolumeParam = zeroed
        patch_param: mutable OrbisNgs2VoicePatchParam = zeroed
        matrix_param: mutable OrbisNgs2VoiceMatrixLevelsParam = zeroed
        blocks_param: mutable OrbisNgs2CustomSamplerVoiceWaveformBlocksParam = zeroed

        assert sceNgs2ParseWaveformUser(null, 0, (&custom_state).cast[mutable OrbisNgs2WaveformInfo&]) == ORBIS_NGS2_ERROR_INVALID_WAVEFORM_ADDRESS
        assert sceNgs2ReportRegisterHandler(0u32, null, 0, report_handle) == ORBIS_NGS2_ERROR_INVALID_REPORT_HANDLE

        assert sceNgs2SystemCreateWithAllocator(null, allocator, system) == ORBIS_OK
        assert ngs2_test_alloc_called == 1u32
        assert sceNgs2RackCreateWithAllocator(system, 5u32, null, allocator, rack) == ORBIS_OK
        assert ngs2_test_alloc_called == 2u32
        assert sceNgs2RackGetVoiceHandle(rack, 0u32, voice) == ORBIS_OK

        event_param.header.size <- size_of(OrbisNgs2VoiceEventParam).u16()
        event_param.header.next <- 0
        event_param.header.id <- VOICE_PARAM_ID_EVENT
        event_param.event_id <- 0u32
        assert sceNgs2VoiceControl(voice, (&event_param).cast[void&]) == ORBIS_OK
        assert sceNgs2VoiceGetStateFlags(voice, out_flags) == ORBIS_OK
        assert out_flags == VOICE_STATE_ACTIVE

        volume_param.header.size <- size_of(OrbisNgs2VoicePortVolumeParam).u16()
        volume_param.header.next <- 0
        volume_param.header.id <- VOICE_PARAM_ID_PORT_VOLUME
        volume_param.port <- 0u32
        volume_param.level <- 0.5
        assert sceNgs2VoiceControl(voice, (&volume_param).cast[void&]) == ORBIS_OK

        patch_param.header.size <- size_of(OrbisNgs2VoicePatchParam).u16()
        patch_param.header.next <- 0
        patch_param.header.id <- VOICE_PARAM_ID_PATCH
        patch_param.port <- 0u32
        patch_param.dest_input_id <- 12u32
        patch_param.dest_handle <- rack
        assert sceNgs2VoiceControl(voice, (&patch_param).cast[void&]) == ORBIS_OK

        matrix_param.header.size <- size_of(OrbisNgs2VoiceMatrixLevelsParam).u16()
        matrix_param.header.next <- 0
        matrix_param.header.id <- VOICE_PARAM_ID_MATRIX_LEVELS
        matrix_param.matrix_id <- 0u32
        matrix_param.num_levels <- 2u32
        matrix_param.a_level <- &level0
        matrix_param.a_level[1] <- level1
        assert sceNgs2VoiceControl(voice, (&matrix_param).cast[void&]) == ORBIS_OK

        block.data_size <- 10u32
        block.num_samples <- 20u32
        blocks_param.header.size <- size_of(OrbisNgs2CustomSamplerVoiceWaveformBlocksParam).u16()
        blocks_param.header.next <- 0
        blocks_param.header.id <- CUSTOM_VOICE_PARAM_ID_WAVEFORM_BLOCKS
        blocks_param.data <- (&rack).cast[void&]
        blocks_param.num_blocks <- 1u32
        blocks_param.a_block <- &block
        assert sceNgs2VoiceControl(voice, (&blocks_param).cast[void&]) == ORBIS_OK

        assert sceNgs2VoiceGetPortInfo(voice, 0u32, (&port_info).cast[mutable void&], size_of(OrbisNgs2VoicePortInfo)) == ORBIS_OK
        assert port_info.volume == 0.5
        assert port_info.dest_input_id == 12u32
        assert port_info.dest_handle == rack

        assert sceNgs2VoiceGetMatrixInfo(voice, 0u32, (&matrix_info).cast[mutable void&], size_of(OrbisNgs2VoiceMatrixInfo)) == ORBIS_OK
        assert matrix_info.num_levels == 2u32
        assert matrix_info.a_level[0] == 0.25
        assert matrix_info.a_level[1] == 0.75

        assert sceNgs2VoiceGetState(voice, (&custom_state).cast[mutable OrbisNgs2VoiceState&], size_of(OrbisNgs2CustomSamplerVoiceState)) == ORBIS_OK
        assert custom_state.voice_state.state_flags == VOICE_STATE_ACTIVE
        assert custom_state.waveform_data == (&rack).cast[void&]
        assert custom_state.num_decoded_samples == 20u64
        assert custom_state.decoded_data_size == 10u64

        assert sceNgs2RackDestroy(rack, null) == ORBIS_OK
        assert sceNgs2SystemDestroy(system, null) == ORBIS_OK
