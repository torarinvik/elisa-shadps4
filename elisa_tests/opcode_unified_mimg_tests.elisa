include "../shader_recompiler/frontend/opcode_unified_mimg.elisa"
include "../../compiler/runtime/elisacore_std/elisacore_runtime.elisa"

@test
def opcode_unified_mimg_values() -> void:
    can Abort.Panic:
        assert OPCODE_IMAGE_LOAD == OPCODE_MAP_OP_MAP_MIMG
        assert OPCODE_IMAGE_STORE == 8u32 + OPCODE_MAP_OP_MAP_MIMG
        assert OPCODE_IMAGE_SAMPLE_C_CD_CL_O == 111u32 + OPCODE_MAP_OP_MAP_MIMG
        assert OPCODE_TBUFFER_LOAD_FORMAT_X == OPCODE_MAP_OP_MAP_MTBUF
        assert OPCODE_EXP == OPCODE_MAP_OP_MAP_EXP
