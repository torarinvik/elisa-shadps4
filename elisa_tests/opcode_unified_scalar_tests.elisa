include "../shader_recompiler/frontend/opcode_unified_scalar.elisa"
include "../../compiler/runtime/elisacore_std/elisacore_runtime.elisa"

@test
def opcode_unified_scalar_sections() -> void:
    can Abort.Panic:
        assert OPCODE_S_ADD_U32 == OPCODE_MAP_OP_MAP_SOP2
        assert OPCODE_S_ABSDIFF_I32 == 44u32 + OPCODE_MAP_OP_MAP_SOP2
        assert OPCODE_S_MOVK_I32 == OPCODE_MAP_OP_MAP_SOPK
        assert OPCODE_S_MOV_B32 == 3u32 + OPCODE_MAP_OP_MAP_SOP1
        assert OPCODE_S_CMP_EQ_I32 == OPCODE_MAP_OP_MAP_SOPC
        assert OPCODE_S_NOP == OPCODE_MAP_OP_MAP_SOPP
