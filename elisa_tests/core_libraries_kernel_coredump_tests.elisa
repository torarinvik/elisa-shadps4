include "../../compiler/runtime/elisacore_std/elisacore_runtime.elisa"
include "../core/libraries/kernel/coredump/coredump.elisa"

def DummyCoredumpHandler(common: void&?) -> s32:
    _ = common
    return 0

def coredump_parity_smoke() -> int:
    # Ensure clean state if prior test run left a handler registered.
    _ = sceCoredumpUnregisterCoredumpHandler()

    res_not_registered: s32 = sceCoredumpUnregisterCoredumpHandler()
    if res_not_registered != ORBIS_COREDUMP_ERROR_NOT_REGISTERED:
        return 1

    res_null_handler: s32 = sceCoredumpRegisterCoredumpHandler(null, 0x1000, null)
    if res_null_handler != ORBIS_COREDUMP_ERROR_PARAM:
        return 2

    res_stack_too_large: s32 = sceCoredumpRegisterCoredumpHandler(DummyCoredumpHandler, 0x20000000, null)
    if res_stack_too_large != ORBIS_COREDUMP_ERROR_PARAM:
        return 3

    res_register: s32 = sceCoredumpRegisterCoredumpHandler(DummyCoredumpHandler, 0x1000, null)
    if res_register != ORBIS_OK:
        return 4

    res_already_registered: s32 = sceCoredumpRegisterCoredumpHandler(DummyCoredumpHandler, 0x1000, null)
    if res_already_registered != ORBIS_COREDUMP_ERROR_ALREADY_REGISTERED:
        return 5

    res_unregister: s32 = sceCoredumpUnregisterCoredumpHandler()
    if res_unregister != ORBIS_OK:
        return 6

    res_unregister_again: s32 = sceCoredumpUnregisterCoredumpHandler()
    if res_unregister_again != ORBIS_COREDUMP_ERROR_NOT_REGISTERED:
        return 7

    if COREDUMP_NIDS_COUNT != 2:
        return 8
    first: CoredumpNidEntry = Coredump_NidEntryAt(0)
    if first.nid != "8zLSfEfW5AU":
        return 9
    if first.symbol_name != "sceCoredumpRegisterCoredumpHandler":
        return 10
    last: CoredumpNidEntry = Coredump_NidEntryAt(1)
    if last.nid != "fFkhOgztiCA":
        return 11
    if last.symbol_name != "sceCoredumpUnregisterCoredumpHandler":
        return 12

    return 0

@test
def coredump_register_unregister_parity() -> void:
    can Abort.Panic:
        assert coredump_parity_smoke() == 0
