        np_assert(sceNpScoreWaitAsync(-1, null) == ORBIS_OK)
        np_assert(sceNpScorePollAsync(-1, null) == ORBIS_OK)
        np_assert(sceNpScoreSanitizeComment(-1, null, null, null) == ORBIS_OK)
        np_assert(sceNpScoreGetFriendsRanking() == ORBIS_OK)
        np_assert(sceNpScoreRecordScore() == ORBIS_OK)

