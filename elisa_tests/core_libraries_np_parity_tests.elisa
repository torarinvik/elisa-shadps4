@test
def np_registered_elisa_contracts_match_cpp() -> void:
    can Abort.Panic:
        request_param: OrbisNpCreateAsyncRequestParameter = zeroed
        request_param.size <- size_of(OrbisNpCreateAsyncRequestParameter).u64()
        request_param.cpu_affinity_mask <- 1u64
        request_param.thread_priority <- 0

        req_id: mutable s32 = sceNpCreateAsyncRequest(request_param)
        np_assert(req_id > ORBIS_NP_MANAGER_REQUEST_ID_OFFSET)
        np_assert(sceNpCheckNpAvailability(req_id, null) == ORBIS_NP_ERROR_SIGNED_OUT)
        np_assert(sceNpDeleteRequest(req_id) == ORBIS_OK)

        np_assert(sceNpCommerceDialogInitialize() == ORBIS_OK)
        np_assert(sceNpCommerceDialogOpen(0) == ORBIS_OK as s16)
        np_assert(sceNpCommerceDialogTerminate() == ORBIS_OK)

        np_assert(sceNpTrophyCreateHandle(null) == ORBIS_NP_TROPHY_ERROR_INVALID_ARGUMENT)

@test
def np_manager_signed_out_contracts_match_cpp_defaults() -> void:
    can Abort.Panic:
        user_id: mutable s32 = 0
        np_assert(sceNpGetUserIdByAccountId(123, null) == ORBIS_NP_ERROR_INVALID_ARGUMENT)
        np_assert(sceNpGetUserIdByAccountId(123, user_id.ref[mutable s32&]) == ORBIS_NP_ERROR_SIGNED_OUT)

        signed_up: mutable bool = true
        np_assert(sceNpHasSignedUp(1, null) == ORBIS_NP_ERROR_INVALID_ARGUMENT)
        np_assert(sceNpHasSignedUp(1, signed_up.ref[mutable bool&]) == ORBIS_OK)
        np_assert(signed_up == false)
