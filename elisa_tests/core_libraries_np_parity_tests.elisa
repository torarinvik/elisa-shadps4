include "../core/libraries/np/np.elisa"

def np_assert(cond: bool) -> void:
    if not cond:
        can Abort.Panic:
            panic("np parity assertion failed")

@test
def np_web_api2_stub_contracts_match_cpp() -> void:
    can Abort.Panic:
        np_assert(sceNpWebApi2Initialize(1, 0x1000) == ORBIS_OK)
        np_assert(sceNpWebApi2InitializeForPresence(1, 0x1000) == ORBIS_OK)
        np_assert(sceNpWebApi2Terminate(123) == ORBIS_OK)
        np_assert(sceNpWebApi2AbortRequest(-1) == ORBIS_OK)
        np_assert(sceNpWebApi2DeleteRequest(-1) == ORBIS_OK)
        np_assert(sceNpWebApi2SetRequestTimeout(-1, 30) == ORBIS_OK)
        np_assert(sceNpWebApi2GetMemoryPoolStats(99, null) == ORBIS_OK)

        np_assert(sceNpWebApi2CreateUserContext(0x8000, 1) == ORBIS_NP_WEBAPI2_ERROR_INVALID_LIB_CONTEXT_ID)
        np_assert(sceNpWebApi2CreateUserContext(1, ORBIS_NP_WEBAPI2_USER_SERVICE_USER_ID_INVALID) == ORBIS_NP_WEBAPI2_ERROR_INVALID_ARGUMENT)
        np_assert(sceNpWebApi2CreateUserContext(1, 42) == ORBIS_OK)

        data: mutable u8[4] = zeroed
        np_assert(sceNpWebApi2ReadData(1, null, 4) == ORBIS_NP_WEBAPI2_ERROR_INVALID_ARGUMENT)
        np_assert(sceNpWebApi2ReadData(1, data[0].ref[mutable u8&].cast[mutable void&], 0) == ORBIS_NP_WEBAPI2_ERROR_INVALID_ARGUMENT)
        np_assert(sceNpWebApi2ReadData(1, data[0].ref[mutable u8&].cast[mutable void&], 4) == ORBIS_OK)
        np_assert(sceNpWebApi2SendRequest() == ORBIS_NP_WEBAPI2_ERROR_NOT_SIGNED_IN)

@test
def np_score_registered_stubs_match_cpp_ok_returns() -> void:
    can Abort.Panic:
        np_assert(sceNpScoreCreateNpTitleCtx(1, null) == ORBIS_OK)
        np_assert(sceNpScoreCreateNpTitleCtxA(1, 42) == ORBIS_OK)
        np_assert(sceNpScoreCreateTitleCtx() == ORBIS_OK)
        np_assert(sceNpScoreCreateRequest(123) == ORBIS_OK)
        np_assert(sceNpScoreAbortRequest(-1) == ORBIS_OK)
        np_assert(sceNpScoreWaitAsync(-1, null) == ORBIS_OK)
        np_assert(sceNpScorePollAsync(-1, null) == ORBIS_OK)
        np_assert(sceNpScoreSanitizeComment(-1, null, null, null) == ORBIS_OK)
        np_assert(sceNpScoreGetFriendsRanking() == ORBIS_OK)
        np_assert(sceNpScoreRecordScore() == ORBIS_OK)

