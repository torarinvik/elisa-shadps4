        RealGameBoot_EmitArtifactSignedKV(file.ref[mutable IOFile&], "boundary_reason", GuestExec_FirstBoundaryReason())
        RealGameBoot_EmitArtifactKV(file.ref[mutable IOFile&], "guest_exec_started", 1 if guest_exec_run_count > 0usize else 0)
        RealGameBoot_EmitArtifactSignedKV(file.ref[mutable IOFile&], "guest_exec_last_argc", guest_exec_last_argc.s32())
