def RealGameBoot_UseNoForkGuestExec() -> bool:
    value: u8&? = getenv("ELISA_GUEST_EXEC_NO_FORK".cast[u8&])
    if value == null:
        return false
    return streq(value.cast[static u8&], "1") == 1

