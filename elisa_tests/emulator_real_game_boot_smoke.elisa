    can Memory.Allocate, Console.Format:
        file: mutable IOFile = IOFile_opened(REAL_GAME_BOOT_ARTIFACT_PATH, FileAccessMode.Create, FileType.TextFile)
        RealGameBoot_EmitArtifactKV(file.ref[mutable IOFile&], "module_count", linker.modules.count.u64())
        RealGameBoot_EmitArtifactKV(file.ref[mutable IOFile&], "total_imports", linker.last_total_import_count.u64())
