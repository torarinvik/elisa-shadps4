extern snprintf(buf: mutable u8&?, bufsize: usize, fmt: u8&, ...) -> int can[Console.Format]
extern getenv(name: u8&) -> u8&?
extern strtoull(s: u8&, endptr: void&?, base: int) -> u64

def RealGameBoot_GetEnvU64(name: static u8&) -> u64:
    value: u8&? = getenv(name)
    if value == null:
        return 0u64
    return strtoull(value, null, 0)

