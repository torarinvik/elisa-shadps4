def RealGameBoot_RuntimeHleDiagnosticCode() -> u64:
    pc: VAddr = GuestExec_LastGuestPC()
    hle_arg0: VAddr = GuestExec_RuntimeHleArg0()
    hle_ret: VAddr = GuestExec_RuntimeHleRet()
    arg0_prot: u32 = GuestExec_RuntimeHleArg0NativeProt()
    crashed_low_pc: bool = pc != 0.uintptr() and pc.u64() < 4096u64
    hle_returned_error_before_crash: bool = hle_ret != 0.uintptr() and hle_ret.u64() < 4096u64 and crashed_low_pc
    hle_arg0_unmapped: bool = hle_arg0 != 0.uintptr() and arg0_prot == 0xffffffffu32
    hle_arg0_small_unmapped: bool = hle_arg0 != 0.uintptr() and hle_arg0.u64() < 4096u64 and hle_arg0_unmapped
    if hle_arg0_small_unmapped and hle_ret.u64() == 22u64:
        return 1001u64
    if hle_arg0_unmapped and hle_ret != 0.uintptr():
        return 1002u64
    if hle_returned_error_before_crash:
        return 1003u64
    return 0u64

def RealGameBoot_EmitArtifactLastHle(file: mutable IOFile&, module: static u8&?, symbol: static u8&?) -> void:
    can Memory.Allocate, Console.Format:
        line: mutable u8[256] = zeroed
        module_text: static u8& = module if module != null else ""
        symbol_text: static u8& = symbol if symbol != null else ""
        written: int = snprintf(line[0], 256usize, "CUSA07399_ARTIFACT last_hle_module=%s last_hle_symbol=%s", module_text, symbol_text)
        RealGameBoot_WriteLine(file, line[0], written)

def RealGameBoot_EmitHleOracleTrace(file: mutable IOFile&) -> void:
    can Memory.Allocate, Console.Format:
        count: u64 = GuestExec_HleOracleTraceCount()
        total: u64 = GuestExec_RuntimeHleSequence()
        start: u64 = total - count
        i: mutable u64 = 0u64
        while i < count:
            seq: u64 = start + i + 1u64
            slot: u64 = ((seq - 1u64) & 2047u64)
            line: mutable u8[512] = zeroed
            written: int = snprintf(line[0], 512usize, "CUSA07399_ARTIFACT hle seq=%llu module=%s symbol=%s return=0x%llx result=0x%llx rdi=0x%llx rsi=0x%llx rdx=0x%llx", seq, GuestExec_HleOracleTraceModule(slot), GuestExec_HleOracleTraceSymbol(slot), GuestExec_HleOracleTraceReturn(slot).u64(), GuestExec_HleOracleTraceResult(slot).u64(), GuestExec_HleOracleTraceRdi(slot).u64(), GuestExec_HleOracleTraceRsi(slot).u64(), GuestExec_HleOracleTraceRdx(slot).u64())
            RealGameBoot_WriteLine(file, line[0], written)
            i <- i + 1u64

def RealGameBoot_EmitModuleStartOracleTrace(file: mutable IOFile&) -> void:
    can Memory.Allocate, Console.Format:
        count: u64 = Module_StartOracleTraceCount()
        i: mutable u64 = 0u64
        while i < count:
            line: mutable u8[512] = zeroed
            written: int = snprintf(line[0], 512usize, "CUSA07399_ARTIFACT modstart seq=%llu phase=%s module=%s label=%s entry=0x%llx count=%llu ret=%d", i + 1u64, Module_StartOracleTracePhase(i), Module_StartOracleTraceModule(i), Module_StartOracleTraceLabel(i), Module_StartOracleTraceEntry(i).u64(), Module_StartOracleTraceCountField(i), Module_StartOracleTraceRet(i))
            RealGameBoot_WriteLine(file, line[0], written)
            i <- i + 1u64

def RealGameBoot_EmitResolvedImportDebug(file: mutable IOFile&, linker: Linker&, nid: static u8&) -> void:
    for mi in 0..<linker.modules.count:
        module: Module = linker.modules[mi]
        for ii in 0..<module.import_symbols.count:
            rec: ImportSymbolRecord = module.import_symbols[ii]
            if streq(rec.nid, nid) == 1 or streq(rec.name, nid) == 1:
                RealGameBoot_EmitArtifactStringKV(file, "dbg_import_module", module.file)
                RealGameBoot_EmitArtifactStringKV(file, "dbg_import_nid", rec.nid)
                RealGameBoot_EmitArtifactStringKV(file, "dbg_import_name", rec.name)
                RealGameBoot_EmitArtifactKV(file, "dbg_import_resolution_kind", rec.resolution_kind.u64())
                RealGameBoot_EmitArtifactKV(file, "dbg_import_resolved_addr", rec.resolved_virtual_addr)
                return

def RealGameBoot_EmitResolvedImportProbe(file: mutable IOFile&, linker: Linker&, label: static u8&, nid: static u8&) -> void:
    can Memory.Allocate, Console.Format:
        for mi in 0..<linker.modules.count:
            module: Module = linker.modules[mi]
            for ii in 0..<module.import_symbols.count:
                rec: ImportSymbolRecord = module.import_symbols[ii]
                if streq(rec.nid, nid) == 1 or streq(rec.name, nid) == 1:
                    line: mutable u8[768] = zeroed
                    written: int = snprintf(line[0], 768usize, "CUSA07399_ARTIFACT import_probe label=%s source=%s nid=%s name=%s kind=%llu resolved_addr=%llu native_prot=%llu native_word0=%llu", label, module.file, rec.nid, rec.name, rec.resolution_kind.u64(), rec.resolved_virtual_addr, GuestExec_AddressNativeProt(rec.resolved_virtual_addr.uintptr()).u64(), GuestExec_ReadNativeU64(rec.resolved_virtual_addr.uintptr()).u64())
                    RealGameBoot_WriteLine(file, line[0], written)
                    return
        line: mutable u8[192] = zeroed
        written: int = snprintf(line[0], 192usize, "CUSA07399_ARTIFACT import_probe label=%s missing_nid=%s", label, nid)
        RealGameBoot_WriteLine(file, line[0], written)

def RealGameBoot_EmitAddressProbe(file: mutable IOFile&, linker: Linker&, label: static u8&, addr: VAddr) -> void:
    can Memory.Allocate, Console.Format:
        module_name: mutable static u8& = ""
        module_base: mutable u64 = 0u64
        module_offset: mutable u64 = 0u64
        module_hit: mutable u64 = 0u64
        i: mutable usize = 0
        while i < linker.modules.count and module_hit == 0u64:
            mod: Module = linker.modules[i]
            if mod.base_virtual_addr <= addr and addr < mod.base_virtual_addr + mod.aligned_base_size.uintptr():
                module_hit <- 1u64
                module_name <- mod.name
                module_base <- mod.base_virtual_addr.u64()
                module_offset <- addr.u64() - mod.base_virtual_addr.u64()
            i <- i + 1
        line: mutable u8[512] = zeroed
        written: int = snprintf(line[0], 512usize, "CUSA07399_ARTIFACT address_probe label=%s addr=%llu native_prot=%llu native_word0=%llu context_word0=%llu guest_module_hit=%llu guest_module=%s guest_base=%llu guest_offset=%llu", label, addr.u64(), GuestExec_AddressNativeProt(addr).u64(), GuestExec_ReadNativeU64(addr).u64(), GuestExec_ReadContextU64(addr).u64(), module_hit, module_name, module_base, module_offset)
        RealGameBoot_WriteLine(file, line[0], written)

def RealGameBoot_EmitNearestSymbolProbe(file: mutable IOFile&, linker: Linker&, label: static u8&, addr: VAddr) -> void:
    can Memory.Allocate, Console.Format:
        best_hit: mutable u64 = 0u64
        best_module: mutable static u8& = ""
        best_name: mutable static u8& = ""
        best_nid: mutable static u8& = ""
        best_addr: mutable u64 = 0u64
        best_size: mutable u64 = 0u64
        best_type: mutable u64 = 0u64
        best_bind: mutable u64 = 0u64
        best_delta: mutable u64 = 0xffffffffffffffffu64
        mi: mutable usize = 0usize
        while mi < linker.modules.count:
            module: Module = linker.modules[mi]
            if module.dynamic_info.symbol_table_offset != 0u64 and module.dynamic_info.symbol_table_total_size != 0u64:
                entry_size: mutable u64 = module.dynamic_info.symbol_table_entries_size
                if entry_size == 0u64:
                    entry_size <- size_of(elf_symbol).u64()
                sym_end: u64 = module.dynamic_info.symbol_table_offset + module.dynamic_info.symbol_table_total_size
                sym_offset: mutable u64 = module.dynamic_info.symbol_table_offset
                while sym_offset + size_of(elf_symbol).u64() <= sym_end and sym_offset + size_of(elf_symbol).u64() <= module.dynamic_data.count.u64():
                    sym: elf_symbol = Module_ReadSymbolAt(module, sym_offset.usize())
                    if sym.st_shndx != ELF_SHN_UNDEF and sym.st_value != 0u64 and sym.st_name != 0u32:
                        sym_addr: u64 = module.base_virtual_addr.u64() + sym.st_value
                        if sym_addr <= addr.u64():
                            delta: u64 = addr.u64() - sym_addr
                            if delta < best_delta:
                                symbol_name: mutable static u8& = ""
                                symbol_nid: mutable static u8& = ""
                                _ = Module_SymbolNameAndNidAt(module, (module.dynamic_info.str_table_offset + sym.st_name.u64()).u32(), (&symbol_name).cast[mutable static u8&], (&symbol_nid).cast[mutable static u8&])
                                best_hit <- 1u64
                                best_module <- module.name
                                best_name <- symbol_name
                                best_nid <- symbol_nid
                                best_addr <- sym_addr
                                best_size <- sym.st_size
                                best_type <- ElfSymbol_GetType(sym).u64()
                                best_bind <- ElfSymbol_GetBind(sym).u64()
                                best_delta <- delta
                        
                    sym_offset <- sym_offset + entry_size
            mi <- mi + 1usize
        line: mutable u8[768] = zeroed
        written: int = snprintf(line[0], 768usize, "CUSA07399_ARTIFACT nearest_symbol label=%s addr=%llu hit=%llu module=%s symbol=%s nid=%s symbol_addr=%llu delta=%llu size=%llu type=%llu bind=%llu native_word0=%llu context_word0=%llu", label, addr.u64(), best_hit, best_module, best_name, best_nid, best_addr, best_delta, best_size, best_type, best_bind, GuestExec_ReadNativeU64(addr).u64(), GuestExec_ReadContextU64(addr).u64())
        RealGameBoot_WriteLine(file, line[0], written)

def RealGameBoot_EmitMainInitArrays(file: mutable IOFile&, linker: mutable Linker&) -> void:
    if linker.modules.count == 0:
        return
    module: Module = linker.modules[0usize]
    can Memory.Allocate, Console.Format:
        line: mutable u8[512] = zeroed
        written: mutable int = snprintf(line[0], 512usize, "CUSA07399_ARTIFACT main_init_arrays dt_init=%llu dt_fini=%llu preinit_va=%llu preinit_size=%llu init_va=%llu init_size=%llu fini_va=%llu fini_size=%llu", module.dynamic_info.init_virtual_addr, module.dynamic_info.fini_virtual_addr, module.dynamic_info.preinit_array_virtual_addr, module.dynamic_info.preinit_array_size, module.dynamic_info.init_array_virtual_addr, module.dynamic_info.init_array_size, module.dynamic_info.fini_array_virtual_addr, module.dynamic_info.fini_array_size)
        RealGameBoot_WriteLine(file, line[0], written)
        init_base: VAddr = module.base_virtual_addr + module.dynamic_info.init_array_virtual_addr.uintptr()
        init_count: u64 = module.dynamic_info.init_array_size / 8u64
        i: mutable u64 = 0u64
        while i < init_count and i < 64u64:
            entry: u64 = MemoryManager_ReadU64(Memory_Instance(), init_base + (i * 8u64).uintptr())
            written <- snprintf(line[0], 512usize, "CUSA07399_ARTIFACT main_init_array_entry index=%llu addr=%llu", i, entry)
            RealGameBoot_WriteLine(file, line[0], written)
            i <- i + 1u64

def RealGameBoot_NativeByteAt(addr: VAddr) -> u8:
    return (GuestExec_ReadNativeU64(addr).u64() & 0xffu64).u8()

def RealGameBoot_NativeU32At(addr: VAddr) -> u32:
    b0: u32 = RealGameBoot_NativeByteAt(addr).u32()
    b1: u32 = RealGameBoot_NativeByteAt(addr + 1.uintptr()).u32()
    b2: u32 = RealGameBoot_NativeByteAt(addr + 2.uintptr()).u32()
    b3: u32 = RealGameBoot_NativeByteAt(addr + 3.uintptr()).u32()
    return b0 | (b1 << 8u32) | (b2 << 16u32) | (b3 << 24u32)

def RealGameBoot_RipRelativeSlot(next_ip: VAddr, disp: u32) -> VAddr:
    if disp < 0x80000000u32:
        return next_ip + disp.u64().uintptr()
    neg: u64 = 0x100000000u64 - disp.u64()
    if next_ip.u64() >= neg:
        return (next_ip.u64() - neg).uintptr()
    return 0.uintptr()

def RealGameBoot_AddSigned8(base: VAddr, disp: u8) -> VAddr:
    if disp < 128.u8():
        return base + disp.u64().uintptr()
    neg: u64 = 256u64 - disp.u64()
    if base.u64() >= neg:
        return (base.u64() - neg).uintptr()
    return 0.uintptr()

def RealGameBoot_EmitArg0ProvenanceProbe(file: mutable IOFile&, label: static u8&, return_addr: VAddr, arg0: VAddr, rbp: VAddr, rsp: VAddr) -> void:
    if return_addr.u64() < 8u64:
        return
    can Memory.Allocate, Console.Format:
        call_start: mutable VAddr = return_addr - 5.uintptr()
        b_call: u8 = RealGameBoot_NativeByteAt(call_start)
        if b_call != 0xe8.u8() and b_call != 0xe9.u8():
            call_start <- return_addr
        scan_start: mutable VAddr = 0.uintptr()
        if call_start.u64() > 96u64:
            scan_start <- call_start - 96.uintptr()
        pos: mutable VAddr = scan_start
        last_kind: mutable u64 = 0u64
        last_pos: mutable VAddr = 0.uintptr()
        source_addr: mutable VAddr = 0.uintptr()
        source_word: mutable VAddr = 0.uintptr()
        computed_value: mutable VAddr = 0.uintptr()
        b0_seen: mutable u8 = 0u8
        b1_seen: mutable u8 = 0u8
        b2_seen: mutable u8 = 0u8
        b3_seen: mutable u8 = 0u8
        while pos < call_start:
            b0: u8 = RealGameBoot_NativeByteAt(pos)
            b1: u8 = RealGameBoot_NativeByteAt(pos + 1.uintptr())
            b2: u8 = RealGameBoot_NativeByteAt(pos + 2.uintptr())
            b3: u8 = RealGameBoot_NativeByteAt(pos + 3.uintptr())
            if b0 == 0xc3.u8() or b0 == 0xcb.u8() or b0 == 0xc2.u8() or b0 == 0xca.u8():
                last_kind <- 8u64 # control-flow reset: ret before this wrapper
                last_pos <- pos
                source_addr <- 0.uintptr()
                source_word <- 0.uintptr()
                computed_value <- 0.uintptr()
                b0_seen <- b0
                b1_seen <- b1
                b2_seen <- b2
                b3_seen <- b3
            elif b0 == 0x55.u8() and b1 == 0x48.u8() and b2 == 0x89.u8() and b3 == 0xe5.u8():
                last_kind <- 9u64 # wrapper prologue; no arg0 materialization seen yet
                last_pos <- pos
                source_addr <- 0.uintptr()
                source_word <- 0.uintptr()
                computed_value <- 0.uintptr()
                b0_seen <- b0
                b1_seen <- b1
                b2_seen <- b2
                b3_seen <- b3
            elif b0 == 0x48.u8() and b1 == 0x8d.u8() and b2 == 0x7d.u8():
                last_kind <- 1u64 # lea disp8(%rbp), %rdi
                last_pos <- pos
                source_addr <- RealGameBoot_AddSigned8(rbp, b3)
                source_word <- GuestExec_ReadContextU64(source_addr)
                computed_value <- source_addr
                b0_seen <- b0
                b1_seen <- b1
                b2_seen <- b2
                b3_seen <- b3
            elif b0 == 0x48.u8() and b1 == 0x8b.u8() and b2 == 0x7d.u8():
                last_kind <- 2u64 # mov disp8(%rbp), %rdi
                last_pos <- pos
                source_addr <- RealGameBoot_AddSigned8(rbp, b3)
                source_word <- GuestExec_ReadContextU64(source_addr)
                computed_value <- source_word
                b0_seen <- b0
                b1_seen <- b1
                b2_seen <- b2
                b3_seen <- b3
            elif b0 == 0x48.u8() and b1 == 0x8d.u8() and b2 == 0x3d.u8():
                disp: u32 = RealGameBoot_NativeU32At(pos + 3.uintptr())
                last_kind <- 3u64 # lea disp32(%rip), %rdi
                last_pos <- pos
                source_addr <- RealGameBoot_RipRelativeSlot(pos + 7.uintptr(), disp)
                source_word <- GuestExec_ReadNativeU64(source_addr)
                computed_value <- source_addr
                b0_seen <- b0
                b1_seen <- b1
                b2_seen <- b2
                b3_seen <- b3
            elif b0 == 0x48.u8() and b1 == 0x8b.u8() and b2 == 0x3d.u8():
                disp2: u32 = RealGameBoot_NativeU32At(pos + 3.uintptr())
                last_kind <- 4u64 # mov disp32(%rip), %rdi
                last_pos <- pos
                source_addr <- RealGameBoot_RipRelativeSlot(pos + 7.uintptr(), disp2)
                source_word <- GuestExec_ReadNativeU64(source_addr)
                computed_value <- source_word
                b0_seen <- b0
                b1_seen <- b1
                b2_seen <- b2
                b3_seen <- b3
            elif b0 == 0xbf.u8():
                imm: u32 = RealGameBoot_NativeU32At(pos + 1.uintptr())
                last_kind <- 5u64 # mov imm32, %edi
                last_pos <- pos
                source_addr <- 0.uintptr()
                source_word <- imm.u64().uintptr()
                computed_value <- imm.u64().uintptr()
                b0_seen <- b0
                b1_seen <- b1
                b2_seen <- b2
                b3_seen <- b3
            elif b0 == 0x48.u8() and b1 == 0xc7.u8() and b2 == 0xc7.u8():
                imm2: u32 = RealGameBoot_NativeU32At(pos + 3.uintptr())
                last_kind <- 6u64 # mov imm32, %rdi
                last_pos <- pos
                source_addr <- 0.uintptr()
                source_word <- imm2.u64().uintptr()
                computed_value <- imm2.u64().uintptr()
                b0_seen <- b0
                b1_seen <- b1
                b2_seen <- b2
                b3_seen <- b3
            elif b0 == 0x48.u8() and b1 == 0x89.u8() and (b2 == 0xc7.u8() or b2 == 0xdf.u8() or b2 == 0xcf.u8() or b2 == 0xd7.u8() or b2 == 0xf7.u8()):
                last_kind <- 7u64 # mov reg, %rdi
                last_pos <- pos
                source_addr <- 0.uintptr()
                source_word <- 0.uintptr()
                computed_value <- arg0
                b0_seen <- b0
                b1_seen <- b1
                b2_seen <- b2
                b3_seen <- b3
            pos <- pos + 1.uintptr()
        line: mutable u8[1024] = zeroed
        written: int = snprintf(line[0], 1024usize, "CUSA07399_ARTIFACT arg0_provenance label=%s return_addr=%llu call_start=%llu arg0=%llu rbp=%llu rsp=%llu kind=%llu insn_addr=%llu source_addr=%llu source_word=%llu computed_value=%llu arg0_match=%llu b0=%llu b1=%llu b2=%llu b3=%llu", label, return_addr.u64(), call_start.u64(), arg0.u64(), rbp.u64(), rsp.u64(), last_kind, last_pos.u64(), source_addr.u64(), source_word.u64(), computed_value.u64(), 1u64 if computed_value == arg0 else 0u64, b0_seen.u64(), b1_seen.u64(), b2_seen.u64(), b3_seen.u64())
        RealGameBoot_WriteLine(file, line[0], written)

def RealGameBoot_FindHleThunkTargetName(linker: Linker&, target: u64) -> static u8&:
    i: mutable usize = 0
    while i < linker.hle_symbols.symbols.count:
        sym: SymbolRecord = linker.hle_symbols.symbols[i]
        if sym.callable_address == target:
            return sym.name
        i <- i + 1
    return ""

def RealGameBoot_EmitByteWindow(file: mutable IOFile&, label: static u8&, addr: VAddr) -> void:
    can Memory.Allocate, Console.Format:
        b0: u8 = RealGameBoot_NativeByteAt(addr)
        b1: u8 = RealGameBoot_NativeByteAt(addr + 1.uintptr())
        b2: u8 = RealGameBoot_NativeByteAt(addr + 2.uintptr())
        b3: u8 = RealGameBoot_NativeByteAt(addr + 3.uintptr())
        b4: u8 = RealGameBoot_NativeByteAt(addr + 4.uintptr())
        b5: u8 = RealGameBoot_NativeByteAt(addr + 5.uintptr())
        b6: u8 = RealGameBoot_NativeByteAt(addr + 6.uintptr())
        b7: u8 = RealGameBoot_NativeByteAt(addr + 7.uintptr())
        b8: u8 = RealGameBoot_NativeByteAt(addr + 8.uintptr())
        b9: u8 = RealGameBoot_NativeByteAt(addr + 9.uintptr())
        b10: u8 = RealGameBoot_NativeByteAt(addr + 10.uintptr())
        b11: u8 = RealGameBoot_NativeByteAt(addr + 11.uintptr())
        b12: u8 = RealGameBoot_NativeByteAt(addr + 12.uintptr())
        b13: u8 = RealGameBoot_NativeByteAt(addr + 13.uintptr())
        b14: u8 = RealGameBoot_NativeByteAt(addr + 14.uintptr())
        b15: u8 = RealGameBoot_NativeByteAt(addr + 15.uintptr())
        line: mutable u8[512] = zeroed
        written: int = snprintf(line[0], 512usize, "CUSA07399_ARTIFACT byte_window label=%s addr=%llu b0=%llu b1=%llu b2=%llu b3=%llu b4=%llu b5=%llu b6=%llu b7=%llu b8=%llu b9=%llu b10=%llu b11=%llu b12=%llu b13=%llu b14=%llu b15=%llu", label, addr.u64(), b0.u64(), b1.u64(), b2.u64(), b3.u64(), b4.u64(), b5.u64(), b6.u64(), b7.u64(), b8.u64(), b9.u64(), b10.u64(), b11.u64(), b12.u64(), b13.u64(), b14.u64(), b15.u64())
        RealGameBoot_WriteLine(file, line[0], written)

def RealGameBoot_EmitContextStackProbe(file: mutable IOFile&, label: static u8&, addr: VAddr) -> void:
    can Memory.Allocate, Console.Format:
        w0: VAddr = GuestExec_ReadContextU64(addr)
        w1: VAddr = GuestExec_ReadContextU64(addr + 8.uintptr())
        w2: VAddr = GuestExec_ReadContextU64(addr + 16.uintptr())
        w3: VAddr = GuestExec_ReadContextU64(addr + 24.uintptr())
        line: mutable u8[512] = zeroed
        written: int = snprintf(line[0], 512usize, "CUSA07399_ARTIFACT context_stack_probe label=%s addr=%llu w0=%llu w1=%llu w2=%llu w3=%llu", label, addr.u64(), w0.u64(), w1.u64(), w2.u64(), w3.u64())
        RealGameBoot_WriteLine(file, line[0], written)

def RealGameBoot_EmitCallsiteProbe(file: mutable IOFile&, linker: Linker&, label: static u8&, return_addr: VAddr) -> void:
    can Memory.Allocate, Console.Format:
        kind: mutable u64 = 0u64
        start: mutable VAddr = 0.uintptr()
        target_or_slot: mutable VAddr = 0.uintptr()
        target_or_slot_word0: mutable VAddr = 0.uintptr()
        target_native_prot: mutable u32 = 0xffffffffu32
        target_word0: mutable VAddr = 0.uintptr()
        target_entry_kind: mutable u64 = 0u64
        target_entry_slot: mutable VAddr = 0.uintptr()
        target_entry_slot_word0: mutable VAddr = 0.uintptr()
        target_entry_thunk_base: mutable u64 = 0u64
        target_entry_thunk_target: mutable u64 = 0u64
        target_entry_thunk_name: mutable static u8& = ""
        b_m8: mutable u8 = 0u8
        b_m7: mutable u8 = 0u8
        b_m6: mutable u8 = 0u8
        b_m5: mutable u8 = 0u8
        b_m4: mutable u8 = 0u8
        b_m3: mutable u8 = 0u8
        b_m2: mutable u8 = 0u8
        b_m1: mutable u8 = 0u8
        if return_addr.u64() >= 8u64:
            b_m8 <- RealGameBoot_NativeByteAt(return_addr - 8.uintptr())
            b_m7 <- RealGameBoot_NativeByteAt(return_addr - 7.uintptr())
            b_m6 <- RealGameBoot_NativeByteAt(return_addr - 6.uintptr())
            b_m5 <- RealGameBoot_NativeByteAt(return_addr - 5.uintptr())
            b_m4 <- RealGameBoot_NativeByteAt(return_addr - 4.uintptr())
            b_m3 <- RealGameBoot_NativeByteAt(return_addr - 3.uintptr())
            b_m2 <- RealGameBoot_NativeByteAt(return_addr - 2.uintptr())
            b_m1 <- RealGameBoot_NativeByteAt(return_addr - 1.uintptr())
            if b_m5 == 0xe8.u8():
                kind <- 1u64
                start <- return_addr - 5.uintptr()
                target_or_slot <- RealGameBoot_RipRelativeSlot(return_addr, RealGameBoot_NativeU32At(return_addr - 4.uintptr()))
            elif b_m6 == 0xff.u8() and b_m5 == 0x15.u8():
                kind <- 2u64
                start <- return_addr - 6.uintptr()
                target_or_slot <- RealGameBoot_RipRelativeSlot(return_addr, RealGameBoot_NativeU32At(return_addr - 4.uintptr()))
                target_or_slot_word0 <- GuestExec_ReadNativeU64(target_or_slot)
            elif b_m2 == 0xff.u8() and b_m1 >= 0xd0.u8() and b_m1 <= 0xd7.u8():
                kind <- 3u64
                start <- return_addr - 2.uintptr()
            elif b_m1 == 0xc3.u8() or b_m1 == 0xcb.u8():
                kind <- 4u64
                start <- return_addr - 1.uintptr()
            elif b_m2 == 0xc2.u8() or b_m2 == 0xca.u8():
                kind <- 5u64
                start <- return_addr - 2.uintptr()
        if target_or_slot != 0.uintptr():
            target_native_prot <- GuestExec_AddressNativeProt(target_or_slot)
            target_word0 <- GuestExec_ReadNativeU64(target_or_slot)
            tb0: u8 = RealGameBoot_NativeByteAt(target_or_slot)
            tb1: u8 = RealGameBoot_NativeByteAt(target_or_slot + 1.uintptr())
            tb4: u8 = RealGameBoot_NativeByteAt(target_or_slot + 4.uintptr())
            if tb0 == 0xff.u8() and tb1 == 0x25.u8():
                target_entry_kind <- 1u64
                target_entry_slot <- RealGameBoot_RipRelativeSlot(target_or_slot + 6.uintptr(), RealGameBoot_NativeU32At(target_or_slot + 2.uintptr()))
                target_entry_slot_word0 <- GuestExec_ReadNativeU64(target_entry_slot)
            elif tb0 == 0xff.u8() and tb1 == 0x15.u8():
                target_entry_kind <- 2u64
                target_entry_slot <- RealGameBoot_RipRelativeSlot(target_or_slot + 6.uintptr(), RealGameBoot_NativeU32At(target_or_slot + 2.uintptr()))
                target_entry_slot_word0 <- GuestExec_ReadNativeU64(target_entry_slot)
            elif tb0 == 0xe9.u8():
                target_entry_kind <- 3u64
                target_entry_slot <- RealGameBoot_RipRelativeSlot(target_or_slot + 5.uintptr(), RealGameBoot_NativeU32At(target_or_slot + 1.uintptr()))
            elif tb0 == 0xe8.u8():
                target_entry_kind <- 4u64
                target_entry_slot <- RealGameBoot_RipRelativeSlot(target_or_slot + 5.uintptr(), RealGameBoot_NativeU32At(target_or_slot + 1.uintptr()))
            elif tb4 == 0xe9.u8():
                target_entry_kind <- 5u64
                target_entry_slot <- RealGameBoot_RipRelativeSlot(target_or_slot + 9.uintptr(), RealGameBoot_NativeU32At(target_or_slot + 5.uintptr()))
        if target_entry_slot_word0 != 0.uintptr():
            target_entry_thunk_base <- Linker_FindNativeHleBoundaryThunkBase(target_entry_slot_word0.u64())
            target_entry_thunk_target <- Linker_FindNativeHleBoundaryThunkTarget(target_entry_slot_word0.u64())
            target_entry_thunk_name <- RealGameBoot_FindHleThunkTargetName(linker, target_entry_thunk_target)
        line: mutable u8[1024] = zeroed
        written: int = snprintf(line[0], 1024usize, "CUSA07399_ARTIFACT callsite_probe label=%s return_addr=%llu kind=%llu start=%llu target_or_slot=%llu target_or_slot_word0=%llu target_native_prot=%llu target_word0=%llu target_entry_kind=%llu target_entry_slot=%llu target_entry_slot_word0=%llu target_entry_thunk_base=%llu target_entry_thunk_target=%llu target_entry_thunk_name=%s native_prot=%llu bytes_m8=%llu bytes_m7=%llu bytes_m6=%llu bytes_m5=%llu bytes_m4=%llu bytes_m3=%llu bytes_m2=%llu bytes_m1=%llu", label, return_addr.u64(), kind, start.u64(), target_or_slot.u64(), target_or_slot_word0.u64(), target_native_prot.u64(), target_word0.u64(), target_entry_kind, target_entry_slot.u64(), target_entry_slot_word0.u64(), target_entry_thunk_base, target_entry_thunk_target, target_entry_thunk_name, GuestExec_AddressNativeProt(return_addr).u64(), b_m8.u64(), b_m7.u64(), b_m6.u64(), b_m5.u64(), b_m4.u64(), b_m3.u64(), b_m2.u64(), b_m1.u64())
        RealGameBoot_WriteLine(file, line[0], written)
        if start != 0.uintptr():
            RealGameBoot_EmitByteWindow(file, "runtime_hle_call_instruction", start)
            if start.u64() >= 32u64:
                RealGameBoot_EmitByteWindow(file, "runtime_hle_call_before32", start - 32.uintptr())
                RealGameBoot_EmitByteWindow(file, "runtime_hle_call_before16", start - 16.uintptr())
        if target_or_slot != 0.uintptr():
            RealGameBoot_EmitByteWindow(file, "runtime_hle_call_target", target_or_slot)

def RealGameBoot_SignExtend32(v: u32) -> u64:
    s: s32 = v.s32()
    return s.i64().u64()

def RealGameBoot_ReadGuestRel32Target(call_addr: VAddr) -> VAddr:
    b0: u32 = MemoryManager_ReadU8(Memory_Instance(), call_addr + 1.uintptr()).u32()
    b1: u32 = MemoryManager_ReadU8(Memory_Instance(), call_addr + 2.uintptr()).u32()
    b2: u32 = MemoryManager_ReadU8(Memory_Instance(), call_addr + 3.uintptr()).u32()
    b3: u32 = MemoryManager_ReadU8(Memory_Instance(), call_addr + 4.uintptr()).u32()
    raw: u32 = b0 | (b1 << 8u32) | (b2 << 16u32) | (b3 << 24u32)
    rel: u64 = RealGameBoot_SignExtend32(raw)
    return call_addr + 5.uintptr() + rel.uintptr()

def RealGameBoot_ReadGuestDisp32At(disp_addr: VAddr) -> u32:
    b0: u32 = MemoryManager_ReadU8(Memory_Instance(), disp_addr).u32()
    b1: u32 = MemoryManager_ReadU8(Memory_Instance(), disp_addr + 1.uintptr()).u32()
    b2: u32 = MemoryManager_ReadU8(Memory_Instance(), disp_addr + 2.uintptr()).u32()
    b3: u32 = MemoryManager_ReadU8(Memory_Instance(), disp_addr + 3.uintptr()).u32()
    return b0 | (b1 << 8u32) | (b2 << 16u32) | (b3 << 24u32)

def RealGameBoot_GuestRipRelativeSlot(next_ip: VAddr, disp: u32) -> VAddr:
    if disp < 0x80000000u32:
        return next_ip + disp.u64().uintptr()
    neg: u64 = 0x100000000u64 - disp.u64()
    if next_ip.u64() >= neg:
        return (next_ip.u64() - neg).uintptr()
    return 0.uintptr()

def RealGameBoot_EntrySlotFromCallsiteReturn(return_addr: VAddr) -> VAddr:
    if return_addr.u64() < 8u64:
        return 0.uintptr()
    b_m5: u8 = RealGameBoot_NativeByteAt(return_addr - 5.uintptr())
    b_m6: u8 = RealGameBoot_NativeByteAt(return_addr - 6.uintptr())
    target_or_slot: mutable VAddr = 0.uintptr()
    if b_m5 == 0xe8.u8() or b_m5 == 0xe9.u8():
        target_or_slot <- RealGameBoot_RipRelativeSlot(return_addr, RealGameBoot_NativeU32At(return_addr - 4.uintptr()))
    elif b_m6 == 0xff.u8() and (b_m5 == 0x15.u8() or b_m5 == 0x25.u8()):
        target_or_slot <- RealGameBoot_RipRelativeSlot(return_addr, RealGameBoot_NativeU32At(return_addr - 4.uintptr()))
    if target_or_slot == 0.uintptr():
        return 0.uintptr()
    tb0: u8 = RealGameBoot_NativeByteAt(target_or_slot)
    tb1: u8 = RealGameBoot_NativeByteAt(target_or_slot + 1.uintptr())
    tb4: u8 = RealGameBoot_NativeByteAt(target_or_slot + 4.uintptr())
    if tb0 == 0xff.u8() and (tb1 == 0x25.u8() or tb1 == 0x15.u8()):
        return RealGameBoot_RipRelativeSlot(target_or_slot + 6.uintptr(), RealGameBoot_NativeU32At(target_or_slot + 2.uintptr()))
    if tb0 == 0xe9.u8() or tb0 == 0xe8.u8():
        return RealGameBoot_RipRelativeSlot(target_or_slot + 5.uintptr(), RealGameBoot_NativeU32At(target_or_slot + 1.uintptr()))
    if tb4 == 0xe9.u8():
        return RealGameBoot_RipRelativeSlot(target_or_slot + 9.uintptr(), RealGameBoot_NativeU32At(target_or_slot + 5.uintptr()))
    return 0.uintptr()

def RealGameBoot_EmitDirectCallers(file: mutable IOFile&, linker: Linker&, label: static u8&, target: VAddr) -> void:
    if target == 0.uintptr():
        return
    can Memory.Allocate, Console.Format:
        emitted: mutable u64 = 0u64
        mi: mutable usize = 0usize
        while mi < linker.modules.count and emitted < 8u64:
            module: Module = linker.modules[mi]
            start: VAddr = module.first_executable_segment_addr
            size: u64 = module.first_executable_segment_size
            if start != 0.uintptr() and size > 5u64:
                pos: mutable VAddr = start
                end: VAddr = start + size.uintptr() - 5.uintptr()
                trusted Unsafe.AssumeProgress:
                    while pos < end and emitted < 8u64:
                        if MemoryManager_ReadU8(Memory_Instance(), pos) == 0xE8u8:
                            dest: VAddr = RealGameBoot_ReadGuestRel32Target(pos)
                            if dest == target:
                                ret_addr: VAddr = pos + 5.uintptr()
                                line: mutable u8[512] = zeroed
                                written: int = snprintf(line[0], 512usize, "CUSA07399_ARTIFACT direct_caller label=%s index=%llu module=%s call_addr=%llu return_addr=%llu target=%llu", label, emitted, module.file, pos.u64(), ret_addr.u64(), target.u64())
                                RealGameBoot_WriteLine(file, line[0], written)
                                RealGameBoot_EmitByteWindow(file, "direct_caller_before16", pos - 16.uintptr())
                                RealGameBoot_EmitByteWindow(file, "direct_caller_instruction", pos)
                                emitted <- emitted + 1u64
                        elif MemoryManager_ReadU8(Memory_Instance(), pos) == 0xE9u8:
                            dest_jmp: VAddr = RealGameBoot_ReadGuestRel32Target(pos)
                            if dest_jmp == target:
                                fallthrough_addr: VAddr = pos + 5.uintptr()
                                line_jmp: mutable u8[512] = zeroed
                                written_jmp: int = snprintf(line_jmp[0], 512usize, "CUSA07399_ARTIFACT direct_jumper label=%s index=%llu module=%s jmp_addr=%llu fallthrough_addr=%llu target=%llu", label, emitted, module.file, pos.u64(), fallthrough_addr.u64(), target.u64())
                                RealGameBoot_WriteLine(file, line_jmp[0], written_jmp)
                                RealGameBoot_EmitByteWindow(file, "direct_jumper_before16", pos - 16.uintptr())
                                RealGameBoot_EmitByteWindow(file, "direct_jumper_instruction", pos)
                                emitted <- emitted + 1u64
                        pos <- pos + 1.uintptr()
            mi <- mi + 1usize
        if emitted == 0u64:
            line2: mutable u8[256] = zeroed
            written2: int = snprintf(line2[0], 256usize, "CUSA07399_ARTIFACT direct_transfer label=%s index=none target=%llu", label, target.u64())
            RealGameBoot_WriteLine(file, line2[0], written2)

def RealGameBoot_EmitIndirectCallersForSlot(file: mutable IOFile&, linker: Linker&, label: static u8&, slot: VAddr) -> void:
    if slot == 0.uintptr():
        return
    can Memory.Allocate, Console.Format:
        emitted: mutable u64 = 0u64
        slot_value: VAddr = MemoryManager_ReadU64(Memory_Instance(), slot)
        mi: mutable usize = 0usize
        while mi < linker.modules.count and emitted < 16u64:
            module: Module = linker.modules[mi]
            start: VAddr = module.base_virtual_addr + module.image_virtual_base.uintptr()
            size: u64 = module.image_virtual_size
            if start != 0.uintptr() and size > 6u64:
                pos: mutable VAddr = start
                end: VAddr = start + size.uintptr() - 6.uintptr()
                trusted Unsafe.AssumeProgress:
                    while pos < end and emitted < 16u64:
                        op0: u8 = MemoryManager_ReadU8(Memory_Instance(), pos)
                        op1: u8 = MemoryManager_ReadU8(Memory_Instance(), pos + 1.uintptr())
                        if op0 == 0xff.u8() and (op1 == 0x15.u8() or op1 == 0x25.u8()):
                            candidate_slot: VAddr = RealGameBoot_GuestRipRelativeSlot(pos + 6.uintptr(), RealGameBoot_ReadGuestDisp32At(pos + 2.uintptr()))
                            if candidate_slot == slot:
                                return_addr: VAddr = pos + 6.uintptr()
                                line: mutable u8[768] = zeroed
                                written: int = snprintf(line[0], 768usize, "CUSA07399_ARTIFACT indirect_caller label=%s index=%llu module=%s call_addr=%llu return_addr=%llu slot=%llu slot_value=%llu opcode0=%llu opcode1=%llu", label, emitted, module.file, pos.u64(), return_addr.u64(), slot.u64(), slot_value.u64(), op0.u64(), op1.u64())
                                RealGameBoot_WriteLine(file, line[0], written)
                                if pos.u64() >= 64u64:
                                    RealGameBoot_EmitByteWindow(file, "indirect_caller_before64", pos - 64.uintptr())
                                if pos.u64() >= 48u64:
                                    RealGameBoot_EmitByteWindow(file, "indirect_caller_before48", pos - 48.uintptr())
                                if pos.u64() >= 32u64:
                                    RealGameBoot_EmitByteWindow(file, "indirect_caller_before32", pos - 32.uintptr())
                                if pos.u64() >= 16u64:
                                    RealGameBoot_EmitByteWindow(file, "indirect_caller_before16", pos - 16.uintptr())
                                RealGameBoot_EmitByteWindow(file, "indirect_caller_instruction", pos)
                                emitted <- emitted + 1u64
                        pos <- pos + 1.uintptr()
            mi <- mi + 1usize
        if emitted == 0u64:
            line2: mutable u8[384] = zeroed
            written2: int = snprintf(line2[0], 384usize, "CUSA07399_ARTIFACT indirect_caller label=%s index=none slot=%llu slot_value=%llu", label, slot.u64(), slot_value.u64())
            RealGameBoot_WriteLine(file, line2[0], written2)

