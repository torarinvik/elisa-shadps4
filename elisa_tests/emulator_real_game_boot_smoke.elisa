        sample_i: mutable u32 = 0u32
        sample_limit: mutable u32 = GuestExec_PCSamplerCount()
        if sample_limit > 8u32:
            sample_limit <- 8u32
        while sample_i < sample_limit:
            sample_key: mutable u8[64] = zeroed
            sample_sp_key: mutable u8[64] = zeroed
            _ = snprintf(sample_key[0], 64usize, "guest_exec_pc_sample_%u", sample_i)
            _ = snprintf(sample_sp_key[0], 64usize, "guest_exec_pc_sample_sp_%u", sample_i)
            RealGameBoot_EmitArtifactKV(file, (&sample_key[0]).cast[static u8&], GuestExec_PCSamplerSamplePC(sample_i).u64())
            RealGameBoot_EmitArtifactKV(file, (&sample_sp_key[0]).cast[static u8&], GuestExec_PCSamplerSampleSP(sample_i).u64())
