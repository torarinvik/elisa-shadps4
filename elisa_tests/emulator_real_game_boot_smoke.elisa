include "../main.elisa"

extern snprintf(buf: mutable u8&?, bufsize: usize, fmt: u8&, ...) -> int effects[Console.Format]

const REAL_GAME_BOOT_ROOT: static u8& = "/Users/torarinvikbjarko/Documents/Coding Projects/Go projects/Elisa-core/shadPS4/Games/CUSA07399"
const REAL_GAME_BOOT_EBOOT: static u8& = "/Users/torarinvikbjarko/Documents/Coding Projects/Go projects/Elisa-core/shadPS4/Games/CUSA07399/eboot.bin"
const REAL_GAME_BOOT_ARTIFACT_PATH: static u8& = "/Users/torarinvikbjarko/Documents/Coding Projects/Go projects/Elisa-core/elisa-shad-ps4-from-scratch/cusa07399_artifacts.txt"
const REAL_GAME_BOOT_HANDOFF_MANIFEST_PATH: static u8& = "/Users/torarinvikbjarko/Documents/Coding Projects/Go projects/Elisa-core/elisa-shad-ps4-from-scratch/cusa07399_handoff_manifest.txt"

def RealGameBoot_Check(cond: bool, message: static u8&) -> void:
    if not cond:
        panic(message)

def RealGameBoot_WriteLine(file: mutable IOFile&, data: mutable u8&, written: int) -> void:
    if written > 0:
        _ = IOFile_WriteSpan(file, data, written.usize())
        _ = IOFile_WriteSpan(file, "\n"[0].ref[u8&], 1usize)

def RealGameBoot_EmitArtifactKV(file: mutable IOFile&, key: static u8&, value: u64) -> void:
    can Memory.Allocate, Console.Format:
        line: mutable u8[128] = zeroed
        written: int = snprintf(line[0].ref[mutable u8&], 128usize, "CUSA07399_ARTIFACT %s=%llu", key, value)
        RealGameBoot_WriteLine(file, line[0].ref[mutable u8&], written)

def RealGameBoot_EmitArtifactSignedKV(file: mutable IOFile&, key: static u8&, value: s32) -> void:
    can Memory.Allocate, Console.Format:
        line: mutable u8[128] = zeroed
        written: int = snprintf(line[0].ref[mutable u8&], 128usize, "CUSA07399_ARTIFACT %s=%d", key, value)
        RealGameBoot_WriteLine(file, line[0].ref[mutable u8&], written)

def RealGameBoot_EmitArtifactStringKV(file: mutable IOFile&, key: static u8&, value: static u8&?) -> void:
    can Memory.Allocate, Console.Format:
        line: mutable u8[256] = zeroed
        value_text: static u8& = value if value != null else ""
        written: int = snprintf(line[0].ref[mutable u8&], 256usize, "CUSA07399_ARTIFACT %s=%s", key, value_text)
        RealGameBoot_WriteLine(file, line[0].ref[mutable u8&], written)

def RealGameBoot_EmitArtifactStringPair(file: mutable IOFile&, prefix: static u8&, left_key: static u8&, left_value: static u8&?, right_key: static u8&, right_value: static u8&?) -> void:
    can Memory.Allocate, Console.Format:
        line: mutable u8[256] = zeroed
        left_text: static u8& = left_value if left_value != null else ""
        right_text: static u8& = right_value if right_value != null else ""
        written: int = snprintf(line[0].ref[mutable u8&], 256usize, "CUSA07399_ARTIFACT %s %s=%s %s=%s", prefix, left_key, left_text, right_key, right_text)
        RealGameBoot_WriteLine(file, line[0].ref[mutable u8&], written)

def RealGameBoot_EmitArtifactModule(file: mutable IOFile&, module: static u8&?, host: static u8&?, shared: s32, relocations: u64, imports: u64, resolved: u64, native_hle: u64, prx_export: u64, aerolib_fallback: u64, malformed: u64, unresolved: u64) -> void:
    can Memory.Allocate, Console.Format:
        line: mutable u8[512] = zeroed
        module_text: static u8& = module if module != null else ""
        host_text: static u8& = host if host != null else ""
        written: int = snprintf(line[0].ref[mutable u8&], 512usize, "CUSA07399_ARTIFACT module=%s host=%s shared=%d relocations=%llu imports=%llu resolved=%llu native_hle=%llu prx_export=%llu aerolib_fallback=%llu malformed=%llu unresolved=%llu", module_text, host_text, shared, relocations, imports, resolved, native_hle, prx_export, aerolib_fallback, malformed, unresolved)
        RealGameBoot_WriteLine(file, line[0].ref[mutable u8&], written)

def RealGameBoot_EmitArtifactImport(file: mutable IOFile&, source: static u8&?, nid: static u8&?, library: static u8&?, module: static u8&?, subsystem: static u8&?, resolution: u64) -> void:
    can Memory.Allocate, Console.Format:
        line: mutable u8[512] = zeroed
        source_text: static u8& = source if source != null else ""
        nid_text: static u8& = nid if nid != null else ""
        library_text: static u8& = library if library != null else ""
        module_text: static u8& = module if module != null else ""
        subsystem_text: static u8& = subsystem if subsystem != null else ""
        written: int = snprintf(line[0].ref[mutable u8&], 512usize, "CUSA07399_ARTIFACT fallback_import=1 source=%s nid=%s library=%s module=%s subsystem=%s status=AeroLibFallback resolution=%llu count=1", source_text, nid_text, library_text, module_text, subsystem_text, resolution)
        RealGameBoot_WriteLine(file, line[0].ref[mutable u8&], written)

def RealGameBoot_CountLoginUsers(list: OrbisUserServiceLoginUserIdList) -> u64:
    i: mutable int = 0
    count: mutable u64 = 0u64
    while i < ORBIS_USER_SERVICE_MAX_LOGIN_USERS:
        if list.user_id[i.usize()] != ORBIS_USER_SERVICE_USER_ID_INVALID:
            count <- count + 1u64
        i <- i + 1
    return count

def RealGameBoot_EmitUserServiceArtifacts(file: mutable IOFile&) -> void:
    init_rc: int = sceUserServiceInitialize(null)
    RealGameBoot_EmitArtifactKV(file, "user_service_initialized", 1u64 if init_rc == ORBIS_OK else 0u64)
    if init_rc != ORBIS_OK:
        return
    initial_user: mutable int = ORBIS_USER_SERVICE_USER_ID_INVALID
    initial_rc: int = sceUserServiceGetInitialUser(initial_user.ref[mutable int&])
    if initial_rc == ORBIS_OK:
        RealGameBoot_EmitArtifactSignedKV(file, "user_service_initial_user", initial_user.s32())
    else:
        RealGameBoot_EmitArtifactKV(file, "user_service_initial_user", 0u64)
    login_users: mutable OrbisUserServiceLoginUserIdList = zeroed
    login_rc: int = sceUserServiceGetLoginUserIdList(login_users.ref[mutable void&])
    if login_rc == ORBIS_OK:
        RealGameBoot_EmitArtifactKV(file, "user_service_login_user_count", RealGameBoot_CountLoginUsers(login_users))
    else:
        RealGameBoot_EmitArtifactKV(file, "user_service_login_user_count", 0u64)
    _ = sceUserServiceTerminate()

def RealGameBoot_EmitArtifactLastHle(file: mutable IOFile&, module: static u8&?, symbol: static u8&?) -> void:
    can Memory.Allocate, Console.Format:
        line: mutable u8[256] = zeroed
        module_text: static u8& = module if module != null else ""
        symbol_text: static u8& = symbol if symbol != null else ""
        written: int = snprintf(line[0].ref[mutable u8&], 256usize, "CUSA07399_ARTIFACT last_hle_module=%s last_hle_symbol=%s", module_text, symbol_text)
        RealGameBoot_WriteLine(file, line[0].ref[mutable u8&], written)

def RealGameBoot_EmitHandoffManifest(linker: Linker&) -> void:
    can Memory.Allocate, Console.Format:
        file: mutable IOFile = IOFile_opened(REAL_GAME_BOOT_HANDOFF_MANIFEST_PATH, FileAccessMode.Create, FileType.TextFile)
        if linker.modules.count == 0:
            IOFile_Close(file)
            return
        main: Module = linker.modules[0]
        line: mutable u8[512] = zeroed
        written: int = snprintf(line[0].ref[mutable u8&], 512usize, "CUSA07399_HANDOFF_MANIFEST version=1 module_count=%llu entry=0x%llx main_entry=0x%llx base=0x%llx image_base=0x%llx image_size=0x%llx aligned_base_size=0x%llx executable_segments=%llu mapped_segments=%llu imports=%llu resolved_imports=%llu patched_import_relocations=%llu", linker.modules.count.u64(), main.last_start_entry_addr.u64(), guest_exec_last_main_entry_addr.u64(), main.base_virtual_addr.u64(), main.image_virtual_base, main.image_virtual_size, main.aligned_base_size, main.executable_segment_count.u64(), main.mapped_segment_count.u64(), Module_GetImportSymbolCount(main).u64(), Module_GetResolvedImportSymbolCount(main).u64(), main.patched_import_relocation_count.u64())
        RealGameBoot_WriteLine(file, line[0].ref[mutable u8&], written)
        i: mutable usize = 0
        limit: mutable usize = linker.modules.count
        if limit > 8:
            limit <- 8
        while i < limit:
            mod_ref: Module = linker.modules[i]
            module_line: mutable u8[512] = zeroed
            written_mod: int = snprintf(module_line[0].ref[mutable u8&], 512usize, "CUSA07399_HANDOFF_MODULE index=%llu file=%s host=%s shared=%d base=0x%llx entry=0x%llx image_base=0x%llx image_size=0x%llx executable_segments=%llu mapped_segments=%llu imports=%llu resolved_imports=%llu", i.u64(), mod_ref.file, mod_ref.host_file, 1 if mod_ref.is_shared_lib else 0, mod_ref.base_virtual_addr.u64(), mod_ref.last_start_entry_addr.u64(), mod_ref.image_virtual_base, mod_ref.image_virtual_size, mod_ref.executable_segment_count.u64(), mod_ref.mapped_segment_count.u64(), Module_GetImportSymbolCount(mod_ref).u64(), Module_GetResolvedImportSymbolCount(mod_ref).u64())
            RealGameBoot_WriteLine(file, module_line[0].ref[mutable u8&], written_mod)
            i <- i + 1
        _ = IOFile_Flush(file)
        IOFile_Close(file)

def RealGameBoot_ResetRuntime() -> void:
    Emulator_Reset()
    Linker_Reset()
    EmulatorState_ResetInstance()
    settings: mutable EmulatorSettingsImpl& = EmulatorSettings_GetInstance()
    EmulatorSettings_SetDefaultValues(settings)
    UserSettings_Reset()

def RealGameBoot_CheckMappedImageMirror(module: Module&) -> bool:
    if module.image.count == 0:
        return false
    max_scan: mutable usize = module.image.count
    if max_scan > 4096:
        max_scan <- 4096
    i: mutable usize = 0
    found: mutable bool = false
    while i < max_scan and not found:
        guest_byte: u8 = MemoryManager_ReadU8(Memory_Instance(), module.base_virtual_addr + module.image_virtual_base.uintptr() + i.uintptr())
        if guest_byte == module.image[i]:
            found <- true
        i <- i + 1
    return found

def RealGameBoot_EmitArtifacts(linker: Linker&, guarded_status: s32) -> void:
    can Memory.Allocate, Console.Format:
        file: mutable IOFile = IOFile_opened(REAL_GAME_BOOT_ARTIFACT_PATH, FileAccessMode.Create, FileType.TextFile)
        RealGameBoot_EmitArtifactKV(file.ref[mutable IOFile&], "module_count", linker.modules.count.u64())
        RealGameBoot_EmitArtifactKV(file.ref[mutable IOFile&], "total_imports", linker.last_total_import_count.u64())
        RealGameBoot_EmitArtifactKV(file.ref[mutable IOFile&], "unresolved_imports", linker.last_unresolved_import_count.u64())
        RealGameBoot_EmitArtifactKV(file.ref[mutable IOFile&], "relocated_imports", linker.last_relocated_import_count.u64())
        RealGameBoot_EmitArtifactKV(file.ref[mutable IOFile&], "native_hle", linker.last_native_hle_resolved_count.u64())
        RealGameBoot_EmitArtifactKV(file.ref[mutable IOFile&], "prx_export", linker.last_prx_export_resolved_count.u64())
        RealGameBoot_EmitArtifactKV(file.ref[mutable IOFile&], "aerolib_fallback", linker.last_aerolib_fallback_resolved_count.u64())
        RealGameBoot_EmitArtifactKV(file.ref[mutable IOFile&], "hle_symbols", linker.hle_registered_symbol_count.u64())
        RealGameBoot_EmitArtifactKV(file.ref[mutable IOFile&], "entry", linker.modules[0].last_start_entry_addr.u64())
        RealGameBoot_EmitArtifactKV(file.ref[mutable IOFile&], "main_entry", guest_exec_last_main_entry_addr.u64())
        RealGameBoot_EmitArtifactSignedKV(file.ref[mutable IOFile&], "guarded_status", guarded_status)
        RealGameBoot_EmitArtifactSignedKV(file.ref[mutable IOFile&], "last_signal", GuestExec_LastSignal())
        RealGameBoot_EmitArtifactKV(file.ref[mutable IOFile&], "fault", GuestExec_LastFaultAddress().u64())
        RealGameBoot_EmitArtifactKV(file.ref[mutable IOFile&], "last_guest_pc", GuestExec_LastGuestPC().u64())
        RealGameBoot_EmitArtifactSignedKV(file.ref[mutable IOFile&], "execution_stage", GuestExec_ExecutionStage())
        RealGameBoot_EmitArtifactSignedKV(file.ref[mutable IOFile&], "boundary_status", GuestExec_ClassifyFirstBoundary())
        RealGameBoot_EmitArtifactSignedKV(file.ref[mutable IOFile&], "boundary_reason", GuestExec_FirstBoundaryReason())
        RealGameBoot_EmitArtifactKV(file.ref[mutable IOFile&], "guest_exec_started", 1 if guest_exec_run_count > 0usize else 0)
        RealGameBoot_EmitArtifactKV(file.ref[mutable IOFile&], "guest_exec_entry_reached", 1 if guest_exec_last_entry_addr != 0.uintptr() else 0)
        RealGameBoot_EmitArtifactKV(file.ref[mutable IOFile&], "guest_exec_first_boundary_reached", 1 if GuestExec_HasReachedFirstBoundary() else 0)
        RealGameBoot_EmitArtifactKV(file.ref[mutable IOFile&], "guest_exec_boundary_reason", GuestExec_FirstBoundaryReason().i64().u64())
        RealGameBoot_EmitArtifactStringKV(file.ref[mutable IOFile&], "guest_exec_boundary_reason_name", GuestExec_FirstBoundaryReasonName())
        RealGameBoot_EmitArtifactStringKV(file.ref[mutable IOFile&], "guest_exec_host_arch", GuestExec_HostArchitecture())
        RealGameBoot_EmitArtifactStringKV(file.ref[mutable IOFile&], "guest_exec_host_mode", GuestExec_HostMode())
        RealGameBoot_EmitArtifactKV(file.ref[mutable IOFile&], "guest_exec_supported_native_execution", 1 if GuestExec_SupportedNativeExecution() else 0)
        RealGameBoot_EmitArtifactKV(file.ref[mutable IOFile&], "guest_exec_x64_subprocess_available", 1 if GuestExec_HostCanRunX64Subprocess() else 0)
        RealGameBoot_EmitArtifactKV(file.ref[mutable IOFile&], "guest_exec_probe_only", 1 if GuestExec_IsProbeOnly() else 0)
        RealGameBoot_EmitArtifactKV(file.ref[mutable IOFile&], "guest_exec_last_pc", GuestExec_LastGuestPC().u64())
        RealGameBoot_EmitArtifactKV(file.ref[mutable IOFile&], "guest_exec_last_signal", GuestExec_LastSignal().i64().u64())
        RealGameBoot_EmitArtifactStringKV(file.ref[mutable IOFile&], "guest_exec_last_module", GuestExec_LastModule())
        RealGameBoot_EmitArtifactStringKV(file.ref[mutable IOFile&], "guest_exec_last_symbol", GuestExec_LastSymbol())
        RealGameBoot_EmitArtifactKV(file.ref[mutable IOFile&], "malformed_imports", linker.last_malformed_import_count.u64())
        RealGameBoot_EmitUserServiceArtifacts(file.ref[mutable IOFile&])
        i: mutable usize = 0
        limit: mutable usize = linker.modules.count
        if limit > 8:
            limit <- 8
        while i < limit:
            native_count: mutable u64 = 0
            prx_count: mutable u64 = 0
            fallback_count: mutable u64 = 0
            malformed_count: mutable u64 = 0
            unresolved_count: mutable u64 = 0
            for j in 0..<linker.modules[i].import_symbols.count:
                rec: ImportSymbolRecord = linker.modules[i].import_symbols[j]
                if rec.resolution_kind == IMPORT_RESOLUTION_NATIVE_HLE:
                    native_count <- native_count + 1
                elif rec.resolution_kind == IMPORT_RESOLUTION_PRX_EXPORT:
                    prx_count <- prx_count + 1
                elif rec.resolution_kind == IMPORT_RESOLUTION_AEROLIB_FALLBACK:
                    fallback_count <- fallback_count + 1
                elif rec.resolution_kind == IMPORT_RESOLUTION_MALFORMED:
                    malformed_count <- malformed_count + 1
                elif not rec.resolved:
                    unresolved_count <- unresolved_count + 1
            RealGameBoot_EmitArtifactModule(file.ref[mutable IOFile&], linker.modules[i].file, linker.modules[i].host_file, 1 if linker.modules[i].is_shared_lib else 0, linker.modules[i].applied_relocation_count.u64(), Module_GetImportSymbolCount(linker.modules[i]).u64(), Module_GetResolvedImportSymbolCount(linker.modules[i]).u64(), native_count, prx_count, fallback_count, malformed_count, unresolved_count)
            RealGameBoot_EmitArtifactKV(file.ref[mutable IOFile&], "module_exec_segments", linker.modules[i].executable_segment_count.u64())
            RealGameBoot_EmitArtifactKV(file.ref[mutable IOFile&], "module_exec_mismatch", linker.modules[i].executable_segment_permission_mismatch_count.u64())
            RealGameBoot_EmitArtifactKV(file.ref[mutable IOFile&], "module_patched_import_relocations", linker.modules[i].patched_import_relocation_count.u64())
            i <- i + 1
        for mi in 0..<linker.modules.count:
            mod_ref: Module = linker.modules[mi]
            for ii in 0..<mod_ref.import_symbols.count:
                rec: ImportSymbolRecord = mod_ref.import_symbols[ii]
                if rec.resolution_kind != IMPORT_RESOLUTION_AEROLIB_FALLBACK:
                    continue
                subsystem: mutable static u8& = "kernel"
                if static_strlen(rec.library) > 0:
                    if Linker_StringHasPrefix(rec.library, "libScePad"):
                        subsystem <- "audio_input_service"
                    elif Linker_StringHasPrefix(rec.library, "libSceGnm") or Linker_StringHasPrefix(rec.library, "libSceVideo") or Linker_StringHasPrefix(rec.library, "libSceFont"):
                        subsystem <- "graphics"
                    elif Linker_StringHasPrefix(rec.library, "libSceSaveData") or Linker_StringHasPrefix(rec.library, "libSceSaveDataDialog") or Linker_StringHasPrefix(rec.library, "libSceCommonDialog") or Linker_StringHasPrefix(rec.library, "libSceWebBrowserDialog") or Linker_StringHasPrefix(rec.library, "libSceSigninDialog"):
                        subsystem <- "save_dialog_misc"
                    elif Linker_StringHasPrefix(rec.library, "libSceAudio") or Linker_StringHasPrefix(rec.library, "libSceAjm") or Linker_StringHasPrefix(rec.library, "libSceCommonDialog"):
                        subsystem <- "audio_input_service"
                    elif Linker_StringHasPrefix(rec.library, "libSceAppContent") or Linker_StringHasPrefix(rec.library, "libSceContentExport"):
                        subsystem <- "kernel"
                RealGameBoot_EmitArtifactImport(file.ref[mutable IOFile&], mod_ref.file, rec.nid, rec.library, rec.module, subsystem, rec.resolution_kind.u64())
        RealGameBoot_EmitArtifactLastHle(file.ref[mutable IOFile&], GuestExec_LastHleModule(), GuestExec_LastHleSymbol())
        _ = IOFile_Flush(file)
        IOFile_Close(file)
        RealGameBoot_EmitHandoffManifest(linker)

@test
def emulator_real_game_boot_smoke_loads_cusa07399_eboot() -> void:
    can Memory.Allocate, Abort.Panic:
        RealGameBoot_ResetRuntime()

        arena: Arena = zeroed
        result: mutable int = -1
        in arena:
            args: mutable darray[static u8&] = ["shadps4", REAL_GAME_BOOT_ROOT, "--", "-RealBootSmoke"]
            result <- Main_Run(args)
        RealGameBoot_Check(result == 0, "expected real game Main_Run success")

        emu: mutable Emulator& = Emulator_GetInstance()
        RealGameBoot_Check(streq(Emulator_GetLastRunPath(emu), REAL_GAME_BOOT_EBOOT) == 1, "expected real game eboot path")
        RealGameBoot_Check(streq(Emulator_GetLastGameFolder(emu), REAL_GAME_BOOT_ROOT) == 1, "expected real game app0 root")
        RealGameBoot_Check(streq(Emulator_GetLastGuestEbootPath(emu), "/app0/eboot.bin") == 1, "expected real game guest eboot path")
        RealGameBoot_Check(emu.last_linker_module_index == 0, "expected real game module index")
        RealGameBoot_Check(emu.last_linker_module_count > 1usize, "expected real game dependencies to load")
        RealGameBoot_Check(emu.last_linker_start_result == 0, "expected real game start result")
        RealGameBoot_Check(emu.app0_mounted, "expected real game app0 mount")
        RealGameBoot_Check(emu.hostapp_mounted, "expected real game hostapp mount")
        RealGameBoot_Check(not emu.native_guest_exec_requested, "expected native guest exec disabled by default")
        RealGameBoot_Check(not GuestExec_IsEnabled(), "expected guest exec runtime disabled by default")

        linker: mutable Linker& = Linker_GetInstance()
        can Memory.Allocate, Abort.Panic, Console:
            RealGameBoot_EmitArtifacts(linker, 0)
        RealGameBoot_Check(linker.modules.count > 1usize, "expected linker to contain real game plus dependencies")
        RealGameBoot_Check(linker.last_started_module_index == 0, "expected real game started module index")
        RealGameBoot_Check(linker.last_start_result == 0, "expected linker start result")
        RealGameBoot_Check(linker.last_unresolved_import_count == 0usize, "expected real game and dependency imports to resolve")
        RealGameBoot_Check(linker.last_relocated_import_count > 0usize, "expected real game import relocations")
        RealGameBoot_Check(linker.last_prx_export_resolved_count > 0usize, "expected CUSA07399 to include PRX-export-backed imports")

        module: Module = linker.modules[0]
        RealGameBoot_Check(streq(module.file, "/app0/eboot.bin") == 1, "expected guest module name")
        RealGameBoot_Check(streq(module.host_file, REAL_GAME_BOOT_EBOOT) == 1, "expected host eboot path")
        RealGameBoot_Check(module.is_valid, "expected real game module valid")
        RealGameBoot_Check(not module.is_shared_lib, "expected eboot not to be marked shared")
        RealGameBoot_Check(module.dynamic_segment.count > 0, "expected dynamic segment")
        RealGameBoot_Check(module.dynamic_data.count > 0, "expected dynamic data")
        RealGameBoot_Check(module.image.count > 0, "expected loaded image")
        RealGameBoot_Check(module.mapped_segment_count > 0, "expected mapped PT_LOAD segments")
        RealGameBoot_Check(module.entry_virtual_addr > 0.uintptr(), "expected entry virtual address")
        RealGameBoot_Check(Module_GetImportSymbolCount(module) > 0, "expected imported HLE symbols")
        RealGameBoot_Check(Module_GetResolvedImportSymbolCount(module) == Module_GetImportSymbolCount(module), "expected all imports resolved")
        RealGameBoot_Check(module.applied_relocation_count > 0usize, "expected relocation writes")
        RealGameBoot_Check(module.executable_segment_permission_mismatch_count == 0usize, "expected executable segment permissions to match expected exec mapping")
        RealGameBoot_Check(RealGameBoot_CheckMappedImageMirror(module), "expected image bytes mirrored into guest memory backing")
        RealGameBoot_Check(Linker_FindByFileOrHost(linker, "/app0/sce_module/libc.prx") != 0xFFFFFFFF.u32(), "expected app-local libc.prx dependency")
        RealGameBoot_Check(Linker_FindByFileOrHost(linker, "/app0/sce_module/libSceFios2.prx") != 0xFFFFFFFF.u32(), "expected app-local libSceFios2.prx dependency")
        RealGameBoot_Check(streq(linker.modules[0].file, "/app0/eboot.bin") == 1, "expected eboot to remain module zero after dependencies")

        state: mutable EmulatorState& = EmulatorState_GetInstance()
        RealGameBoot_Check(EmulatorState_IsGameRunning(state), "expected game running state")

@test
def emulator_real_game_boot_smoke_probes_native_guest_exec_handoff() -> void:
    can Memory.Allocate, Abort.Panic:
        RealGameBoot_ResetRuntime()

        arena: Arena = zeroed
        result: mutable int = -1
        in arena:
            args: mutable darray[static u8&] = ["shadps4", "--native-guest-exec-probe", REAL_GAME_BOOT_ROOT, "--", "-RealBootSmoke"]
            result <- Main_Run(args)
        RealGameBoot_Check(result == 0, "expected native guest exec probe launch success")

        emu: mutable Emulator& = Emulator_GetInstance()
        RealGameBoot_Check(emu.native_guest_exec_requested, "expected native guest exec requested")
        RealGameBoot_Check(emu.native_guest_exec_probe_requested, "expected native guest exec probe requested")
        RealGameBoot_Check(GuestExec_IsProbeMode(), "expected guest exec probe mode")
        RealGameBoot_Check(GuestExec_IsEnabled(), "expected guest exec enabled in probe mode")
        RealGameBoot_Check(guest_exec_run_count > 0usize, "expected guest exec handoff to be reached")
        RealGameBoot_Check(guest_exec_last_entry_addr > 0.uintptr(), "expected guest exec entry address to be recorded")
        RealGameBoot_Check(guest_exec_main_run_count == 1usize, "expected one main executable handoff")
        RealGameBoot_Check(guest_exec_last_main_entry_addr > 0.uintptr(), "expected main executable entry address to be recorded")

        linker: mutable Linker& = Linker_GetInstance()
        can Memory.Allocate, Abort.Panic, Console:
            RealGameBoot_EmitArtifacts(linker, 0)
        RealGameBoot_Check(linker.last_unresolved_import_count == 0usize, "expected native probe launch imports to resolve")
        RealGameBoot_Check(linker.last_entry_addr > 0.uintptr(), "expected linker entry to be recorded")
        RealGameBoot_Check(linker.modules[0].last_start_entry_addr > 0.uintptr(), "expected main module start entry to be recorded")
        RealGameBoot_Check(guest_exec_last_main_entry_addr == linker.modules[0].last_start_entry_addr, "expected main probe entry to match module start entry")
        stage_status: s32 = GuestExec_ClassifyGameExecutionStage()
        if GuestExec_IsSupported():
            RealGameBoot_Check(stage_status == 2, "expected supported host probe to arm game execution stage")
        else:
            RealGameBoot_Check(stage_status == -2, "expected unsupported host game execution classification")
        boundary_status: s32 = GuestExec_ClassifyFirstBoundary()
        if GuestExec_IsSupported():
            RealGameBoot_Check(boundary_status == GUEST_EXEC_BOUNDARY_ARMED_PROBE_ONLY, "expected supported host probe boundary classification")
        else:
            RealGameBoot_Check(boundary_status == GUEST_EXEC_BOUNDARY_UNSUPPORTED_HOST, "expected unsupported host boundary classification")

@test
def emulator_real_game_boot_smoke_guarded_game_entry_reports_host_status() -> void:
    can Memory.Allocate, Abort.Panic:
        RealGameBoot_ResetRuntime()

        arena: Arena = zeroed
        result: mutable int = -1
        in arena:
            args: mutable darray[static u8&] = ["shadps4", "--native-guest-exec-probe", REAL_GAME_BOOT_ROOT, "--", "-RealBootSmoke"]
            result <- Main_Run(args)
        RealGameBoot_Check(result == 0, "expected guarded guest exec launch setup success")

        linker: mutable Linker& = Linker_GetInstance()
        entry: VAddr = linker.modules[0].last_start_entry_addr
        RealGameBoot_Check(entry > 0.uintptr(), "expected main entry before guarded run")

        status: s32 = GuestExec_RunMainEntryGuarded(entry, 0, null, 25.u32())
        if GuestExec_IsSupported():
            RealGameBoot_Check(status != -2, "expected supported host to attempt guarded game entry")
        else:
            RealGameBoot_Check(status == -2, "expected unsupported host guarded game entry status")
        RealGameBoot_Check(guest_exec_last_game_execution_status == status, "expected guarded status to be recorded")
        boundary_status: s32 = GuestExec_ClassifyFirstBoundary()
        stage_code: s32 = GuestExec_ExecutionStage()
        if GuestExec_IsSupported():
            RealGameBoot_Check(boundary_status == GUEST_EXEC_BOUNDARY_FIRST_HLE_IMPORT or boundary_status == GUEST_EXEC_BOUNDARY_TIMEOUT or boundary_status == GUEST_EXEC_BOUNDARY_PRE_BOUNDARY_FAULT or boundary_status == GUEST_EXEC_BOUNDARY_EXITED_BEFORE_BOUNDARY, "expected guarded execution to classify the first-boundary or pre-boundary outcome")
            RealGameBoot_Check(stage_code >= GUEST_EXEC_STAGE_GUARDED_ENTRY, "expected guarded run to advance execution stage beyond handoff")
        else:
            RealGameBoot_Check(boundary_status == GUEST_EXEC_BOUNDARY_UNSUPPORTED_HOST, "expected unsupported host boundary classification after guarded run")
            RealGameBoot_Check(streq(GuestExec_FirstBoundaryReasonName(), "unsupported-host") == 1, "expected unsupported host boundary reason name")
            RealGameBoot_Check(GuestExec_HostArchitecture() != null, "expected host architecture to be reported")
            RealGameBoot_Check(GuestExec_HostMode() != null, "expected host mode to be reported")
            if streq(GuestExec_HostMode(), "macOS") == 1 and streq(GuestExec_HostArchitecture(), "arm64") == 1:
                x64_probe_first: bool = GuestExec_HostCanRunX64Subprocess()
                x64_probe_second: bool = GuestExec_HostCanRunX64Subprocess()
                RealGameBoot_Check(x64_probe_first == x64_probe_second, "expected x64 subprocess capability probe to be deterministic")
            RealGameBoot_Check(GuestExec_IsProbeOnly(), "expected probe-only mode on unsupported host")
            RealGameBoot_Check(stage_code == GUEST_EXEC_STAGE_GUARDED_ENTRY, "expected unsupported host guarded run to report guarded-entry stage")
        can Memory.Allocate, Abort.Panic, Console:
            RealGameBoot_EmitArtifacts(linker, status)
