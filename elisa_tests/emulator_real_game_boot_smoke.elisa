# Dump the guest-exec boundary trace tape so a real (Rosetta) run produces a
# diff-able tape: fingerprint + count + overflow, then one line per event. This
# is what a recorded shadPS4 baseline is compared against via the snapshot/
# DebugTraceFirstDivergence API.
def RealGameBoot_EmitTraceTape(file: mutable IOFile&) -> void:
    can Memory.Allocate, Console.Format:
        RealGameBoot_EmitArtifactKV((&file).cast[mutable IOFile&], "trace_fingerprint", GuestExec_DebugTraceFingerprint())
        RealGameBoot_EmitArtifactKV((&file).cast[mutable IOFile&], "trace_event_count", GuestExec_DebugTraceCount().u64())
        RealGameBoot_EmitArtifactKV((&file).cast[mutable IOFile&], "trace_overflowed", 1u64 if GuestExec_DebugTraceDidOverflow() else 0u64)
        count: usize = GuestExec_DebugTraceCount()
        limit: mutable usize = count
        if limit > 256usize:
            limit <- 256usize
        i: mutable usize = 0usize
        while i < limit:
            line: mutable u8[384] = zeroed
            written: int = snprintf(line[0], 384usize, "CUSA07399_ARTIFACT trace_event index=%llu kind=%lld label=%s a=0x%llx b=0x%llx c=0x%llx", i.u64(), GuestExec_DebugTraceEventKindAt(i).i64(), GuestExec_DebugTraceEventLabelAt(i), GuestExec_DebugTraceEventAAt(i).u64(), GuestExec_DebugTraceEventBAt(i).u64(), GuestExec_DebugTraceEventCAt(i).u64())
            RealGameBoot_WriteLine(file, line[0], written)
            i <- i + 1usize

global mutable dbg_reloc_boot_count: u64 = 0
global mutable dbg_reloc_boot_fp: u64 = 0
global mutable dbg_reloc_pass_a_count: u64 = 0
global mutable dbg_reloc_pass_b_count: u64 = 0
global mutable dbg_reloc_pass_a_fp: u64 = 0
global mutable dbg_reloc_pass_b_fp: u64 = 0

def RealGameBoot_Check(cond: bool, message: static u8&) -> void:
    if not cond:
        panic(message)

def RealGameBoot_WriteLine(file: mutable IOFile&, data: mutable u8&, written: int) -> void:
    if written > 0:
        _ = file.WriteSpan(data, written.usize())
        _ = file.WriteSpan("\n"[0], 1usize)

def RealGameBoot_EmitArtifactKV(file: mutable IOFile&, key: static u8&, value: u64) -> void:
    can Memory.Allocate, Console.Format:
        line: mutable u8[128] = zeroed
        written: int = snprintf(line[0], 128usize, "CUSA07399_ARTIFACT %s=%llu", key, value)
        RealGameBoot_WriteLine(file, line[0], written)

def RealGameBoot_EmitPhaseBreadcrumb(phase: u64) -> void:
    can Memory.Allocate, Console.Format:
        file: mutable IOFile = IOFile(REAL_GAME_BOOT_ARTIFACT_PATH, FileAccessMode.Append, FileType.TextFile)
        RealGameBoot_EmitArtifactKV(file, "guarded_test_phase", phase)
        _ = file.Flush()
        file.Close()

# Dump the complete patch-time AeroLib fallback slot table. Because import
# resolution is currently nondeterministic (which slots fall to the fallback
# stub varies run to run), the full table lets us cross-reference whatever slot
# the guest happens to call first against every unimplemented import, keyed by
# owning module + .dynsym symbol index (the ELF symbol name is usually empty).
def RealGameBoot_EmitFallbackSlotTable(file: mutable IOFile&) -> void:
    can Memory.Allocate, Console.Format:
        count: u32 = Linker_FallbackSlotCount()
        limit: mutable usize = count.usize()
        if limit > 256usize:
            limit <- 256usize
        i: mutable usize = 0
        while i < limit:
            idx: u32 = i.u32()
            line: mutable u8[512] = zeroed
            module_text: static u8& = Linker_FallbackSlotModuleAt(idx)
            symbol_text: static u8& = Linker_FallbackSlotSymbolAt(idx)
            written: int = snprintf(line[0], 512usize, "CUSA07399_ARTIFACT fallback_slot index=%llu slot_va=%llu module=%s symbol=%s symbol_index=%llu rel_type=%llu", i.u64(), Linker_FallbackSlotVaAt(idx), module_text, symbol_text, Linker_FallbackSlotSymbolIndexAt(idx).u64(), Linker_FallbackSlotRelTypeAt(idx).u64())
            RealGameBoot_WriteLine(file, line[0], written)
            i <- i + 1

def RealGameBoot_EmitArtifactSignedKV(file: mutable IOFile&, key: static u8&, value: s32) -> void:
    can Memory.Allocate, Console.Format:
        line: mutable u8[128] = zeroed
        written: int = snprintf(line[0], 128usize, "CUSA07399_ARTIFACT %s=%d", key, value)
        RealGameBoot_WriteLine(file, line[0], written)

def RealGameBoot_EmitArtifactStringKV(file: mutable IOFile&, key: static u8&, value: static u8&?) -> void:
    can Memory.Allocate, Console.Format:
        line: mutable u8[256] = zeroed
        value_text: static u8& = value if value != null else ""
        written: int = snprintf(line[0], 256usize, "CUSA07399_ARTIFACT %s=%s", key, value_text)
        RealGameBoot_WriteLine(file, line[0], written)

def RealGameBoot_EmitArtifactAddrWords(file: mutable IOFile&, key: static u8&, addr: VAddr) -> void:
    can Memory.Allocate, Console.Format:
        word0: u64 = MemoryManager_ReadU64(Memory_Instance(), addr)
        word1: u64 = MemoryManager_ReadU64(Memory_Instance(), addr + 8.uintptr())
        word2: u64 = MemoryManager_ReadU64(Memory_Instance(), addr + 16.uintptr())
        word3: u64 = MemoryManager_ReadU64(Memory_Instance(), addr + 24.uintptr())
        line: mutable u8[256] = zeroed
        written: int = snprintf(line[0], 256usize, "CUSA07399_ARTIFACT %s_addr=0x%llx %s_word0=0x%llx %s_word1=0x%llx %s_word2=0x%llx %s_word3=0x%llx", key, addr.u64(), key, word0, key, word1, key, word2, key, word3)
        RealGameBoot_WriteLine(file, line[0], written)

def RealGameBoot_EmitArtifactStringPair(file: mutable IOFile&, prefix: static u8&, left_key: static u8&, left_value: static u8&?, right_key: static u8&, right_value: static u8&?) -> void:
    can Memory.Allocate, Console.Format:
        line: mutable u8[256] = zeroed
        left_text: static u8& = left_value if left_value != null else ""
        right_text: static u8& = right_value if right_value != null else ""
        written: int = snprintf(line[0], 256usize, "CUSA07399_ARTIFACT %s %s=%s %s=%s", prefix, left_key, left_text, right_key, right_text)
        RealGameBoot_WriteLine(file, line[0], written)

def RealGameBoot_EmitArtifactModule(file: mutable IOFile&, index: u64, module: static u8&?, host: static u8&?, base: u64, size: u64, shared: s32, relocations: u64, imports: u64, resolved: u64, native_hle: u64, prx_export: u64, aerolib_fallback: u64, malformed: u64, unresolved: u64) -> void:
    can Memory.Allocate, Console.Format:
        line: mutable u8[512] = zeroed
        module_text: static u8& = module if module != null else ""
        host_text: static u8& = host if host != null else ""
        written: int = snprintf(line[0], 512usize, "CUSA07399_ARTIFACT module=%s index=%llu base=0x%llx size=0x%llx host=%s shared=%d relocations=%llu imports=%llu resolved=%llu native_hle=%llu prx_export=%llu aerolib_fallback=%llu malformed=%llu unresolved=%llu", module_text, index, base, size, host_text, shared, relocations, imports, resolved, native_hle, prx_export, aerolib_fallback, malformed, unresolved)
        RealGameBoot_WriteLine(file, line[0], written)

def RealGameBoot_SymtypeName(t: u8) -> static u8& :
    if t == IMPORT_SYMBOL_TYPE_FUNCTION:
        return "function"
    if t == IMPORT_SYMBOL_TYPE_OBJECT:
        return "object"
    if t == IMPORT_SYMBOL_TYPE_TLS:
        return "tls"
    return "notype"

# Boot oracle import-resolution record (cross-comparable structural facts only;
# see docs/shadps4_boot_oracle.md). Resolved addresses are intentionally omitted
# since shadPS4 resolves HLE imports to host addresses, not guest thunk VAs.
def RealGameBoot_EmitArtifactResolve(file: mutable IOFile&, nid: static u8&?, symtype: static u8&?, resolved: s32) -> void:
    can Memory.Allocate, Console.Format:
        line: mutable u8[256] = zeroed
        nid_text: static u8& = nid if nid != null else ""
        symtype_text: static u8& = symtype if symtype != null else ""
        written: int = snprintf(line[0], 256usize, "CUSA07399_ARTIFACT resolve nid=%s symtype=%s resolved=%d", nid_text, symtype_text, resolved)
        RealGameBoot_WriteLine(file, line[0], written)

def RealGameBoot_EmitArtifactImport(file: mutable IOFile&, source: static u8&?, nid: static u8&?, library: static u8&?, module: static u8&?, subsystem: static u8&?, resolution: u64) -> void:
    can Memory.Allocate, Console.Format:
        line: mutable u8[512] = zeroed
        source_text: static u8& = source if source != null else ""
        nid_text: static u8& = nid if nid != null else ""
        library_text: static u8& = library if library != null else ""
        module_text: static u8& = module if module != null else ""
        subsystem_text: static u8& = subsystem if subsystem != null else ""
        written: int = snprintf(line[0], 512usize, "CUSA07399_ARTIFACT fallback_import=1 source=%s nid=%s library=%s module=%s subsystem=%s status=AeroLibFallback resolution=%llu count=1", source_text, nid_text, library_text, module_text, subsystem_text, resolution)
        RealGameBoot_WriteLine(file, line[0], written)

def RealGameBoot_CountLoginUsers(list: OrbisUserServiceLoginUserIdList) -> u64:
    i: mutable int = 0
    count: mutable u64 = 0u64
    while i < ORBIS_USER_SERVICE_MAX_LOGIN_USERS:
        if list.user_id[i.usize()] != ORBIS_USER_SERVICE_USER_ID_INVALID:
            count <- count + 1u64
        i <- i + 1
    return count

def RealGameBoot_EmitUserServiceArtifacts(file: mutable IOFile&) -> void:
    init_rc: int = sceUserServiceInitialize(null)
    RealGameBoot_EmitArtifactKV(file, "user_service_initialized", 1u64 if init_rc == ORBIS_OK else 0u64)
    if init_rc != ORBIS_OK:
        return
    initial_user: mutable int = ORBIS_USER_SERVICE_USER_ID_INVALID
    initial_rc: int = sceUserServiceGetInitialUser(initial_user)
    if initial_rc == ORBIS_OK:
        RealGameBoot_EmitArtifactSignedKV(file, "user_service_initial_user", initial_user.s32())
    else:
        RealGameBoot_EmitArtifactKV(file, "user_service_initial_user", 0u64)
    login_users: mutable OrbisUserServiceLoginUserIdList = zeroed
    login_rc: int = sceUserServiceGetLoginUserIdList((&login_users).cast[mutable void&])
    if login_rc == ORBIS_OK:
        RealGameBoot_EmitArtifactKV(file, "user_service_login_user_count", RealGameBoot_CountLoginUsers(login_users))
    else:
        RealGameBoot_EmitArtifactKV(file, "user_service_login_user_count", 0u64)
    _ = sceUserServiceTerminate()

def RealGameBoot_EmitCrashClassificationArtifacts(file: mutable IOFile&) -> void:
    pc: VAddr = GuestExec_LastGuestPC()
    hle_arg0: VAddr = GuestExec_RuntimeHleArg0()
    hle_ret: VAddr = GuestExec_RuntimeHleRet()
    hle_reason: VAddr = GuestExec_RuntimeHleArg2()
    arg0_prot: u32 = GuestExec_RuntimeHleArg0NativeProt()
    crashed_low_pc: bool = pc != 0.uintptr() and pc.u64() < 4096u64
    crashed_unmapped_pc: bool = GuestExec_LastPCNativeProt() == 0xffffffffu32
    hle_returned_error_before_crash: bool = hle_ret != 0.uintptr() and hle_ret.u64() < 4096u64 and crashed_low_pc
    hle_arg0_unmapped: bool = hle_arg0 != 0.uintptr() and arg0_prot == 0xffffffffu32
    hle_arg0_small_nonzero: bool = hle_arg0 != 0.uintptr() and hle_arg0.u64() < 4096u64
    hle_arg0_small_unmapped: bool = hle_arg0_small_nonzero and hle_arg0_unmapped
    saved_return: VAddr = GuestExec_RuntimeHleGuestFrameWord1()
    wrapper_return: VAddr = GuestExec_RuntimeHleGuestReturnAddr()
    wrapper_return_mapped: bool = wrapper_return != 0.uintptr() and GuestExec_AddressNativeProt(wrapper_return) != 0xffffffffu32
    saved_return_tiny_unmapped: bool = saved_return != 0.uintptr() and saved_return.u64() < 4096u64 and GuestExec_AddressNativeProt(saved_return) == 0xffffffffu32
    raw_arg_regs_match_recorder: bool = GuestExec_RuntimeHleGuestRdi() == GuestExec_RuntimeHleArg0() and GuestExec_RuntimeHleGuestRsi() == GuestExec_RuntimeHleArg1()
    runtime_hle_diag: mutable u64 = 0u64
    if hle_arg0_small_unmapped and hle_ret.u64() == 22u64:
        runtime_hle_diag <- 1001u64
    elif hle_arg0_unmapped and hle_ret != 0.uintptr():
        runtime_hle_diag <- 1002u64
    elif hle_returned_error_before_crash:
        runtime_hle_diag <- 1003u64
    fork_local_mutex_state_stale: mutable bool = false
    if streq(GuestExec_RuntimeHleSymbol(), "posix_pthread_mutex_lock") == 1:
        fork_local_mutex_state_stale <- hle_reason.u64() != threads_sync_last_mutex_reject_reason
    RealGameBoot_EmitArtifactKV(file, "guardrail_low_pc_crash", 1u64 if crashed_low_pc else 0u64)
    RealGameBoot_EmitArtifactKV(file, "guardrail_unmapped_pc_crash", 1u64 if crashed_unmapped_pc else 0u64)
    RealGameBoot_EmitArtifactKV(file, "guardrail_hle_error_then_low_pc", 1u64 if hle_returned_error_before_crash else 0u64)
    RealGameBoot_EmitArtifactKV(file, "guardrail_hle_arg0_unmapped", 1u64 if hle_arg0_unmapped else 0u64)
    RealGameBoot_EmitArtifactKV(file, "guardrail_hle_arg0_small_nonzero", 1u64 if hle_arg0_small_nonzero else 0u64)
    RealGameBoot_EmitArtifactKV(file, "guardrail_hle_arg0_small_unmapped", 1u64 if hle_arg0_small_unmapped else 0u64)
    RealGameBoot_EmitArtifactKV(file, "guardrail_runtime_hle_diagnostic_code", runtime_hle_diag)
    RealGameBoot_EmitArtifactKV(file, "guardrail_runtime_hle_reject_reason", hle_reason.u64())
    RealGameBoot_EmitArtifactKV(file, "guardrail_fork_local_mutex_state_stale", 1u64 if fork_local_mutex_state_stale else 0u64)
    RealGameBoot_EmitArtifactKV(file, "guardrail_runtime_hle_wrapper_return_mapped", 1u64 if wrapper_return_mapped else 0u64)
    RealGameBoot_EmitArtifactKV(file, "guardrail_runtime_hle_saved_return_tiny_unmapped", 1u64 if saved_return_tiny_unmapped else 0u64)
    RealGameBoot_EmitArtifactKV(file, "guardrail_runtime_hle_raw_arg_regs_match_recorder", 1u64 if raw_arg_regs_match_recorder else 0u64)
    RealGameBoot_EmitArtifactKV(file, "guardrail_runtime_hle_saved_return", saved_return.u64())
    RealGameBoot_EmitArtifactKV(file, "guardrail_runtime_hle_boundary_sequence", GuestExec_RuntimeHleBoundaryGuardSequence())
    RealGameBoot_EmitArtifactKV(file, "guardrail_runtime_hle_boundary_index", GuestExec_RuntimeHleBoundaryGuardIndex())
    RealGameBoot_EmitArtifactKV(file, "guardrail_runtime_hle_boundary_reason", GuestExec_RuntimeHleBoundaryGuardReason())
    RealGameBoot_EmitArtifactKV(file, "guardrail_runtime_hle_boundary_value", GuestExec_RuntimeHleBoundaryGuardValue().u64())
    RealGameBoot_EmitArtifactKV(file, "guardrail_runtime_hle_boundary_return_addr", GuestExec_RuntimeHleBoundaryGuardReturnAddr().u64())
    RealGameBoot_EmitArtifactKV(file, "guardrail_debug_trap_enabled", 1u64 if RealGameBoot_UseBoundaryDebugTrap() else 0u64)
    RealGameBoot_EmitArtifactKV(file, "guardrail_debug_trap_unpublished_exec_enabled", 1u64 if RealGameBoot_UseUnpublishedExecDebugTrap() else 0u64)
    RealGameBoot_EmitArtifactKV(file, "guardrail_debug_trap_count", GuestExec_DebugTrapCount())
    RealGameBoot_EmitArtifactKV(file, "guardrail_debug_trap_reason", GuestExec_DebugTrapReason())
    RealGameBoot_EmitArtifactKV(file, "guardrail_debug_trap_value", GuestExec_DebugTrapValue().u64())
    RealGameBoot_EmitArtifactKV(file, "guardrail_debug_trap_sequence", GuestExec_DebugTrapSequence())
    RealGameBoot_EmitArtifactKV(file, "guardrail_debug_trap_return_addr", GuestExec_DebugTrapReturnAddr().u64())
    RealGameBoot_EmitArtifactKV(file, "guardrail_debug_trap_arg0", GuestExec_DebugTrapArg0().u64())
    RealGameBoot_EmitArtifactKV(file, "guardrail_debug_trap_arg1", GuestExec_DebugTrapArg1().u64())
    RealGameBoot_EmitArtifactKV(file, "guardrail_debug_trap_arg2", GuestExec_DebugTrapArg2().u64())
    RealGameBoot_EmitArtifactKV(file, "guardrail_debug_trap_pointer_size", GuestExec_DebugTrapPointerSize())
    RealGameBoot_EmitArtifactKV(file, "guardrail_debug_trap_nearest_mapping_base", GuestExec_DebugTrapNearestMappingBase().u64())
    RealGameBoot_EmitArtifactKV(file, "guardrail_debug_trap_nearest_mapping_end", GuestExec_DebugTrapNearestMappingEnd().u64())
    RealGameBoot_EmitArtifactKV(file, "guardrail_debug_trap_nearest_mapping_prot", GuestExec_DebugTrapNearestMappingProt().u64())
    RealGameBoot_EmitArtifactKV(file, "guardrail_debug_trap_tcb_base", GuestExec_DebugTrapTcbBase().u64())
    RealGameBoot_EmitArtifactKV(file, "guardrail_debug_trap_tcb_self", GuestExec_DebugTrapTcbSelf().u64())
    RealGameBoot_EmitArtifactKV(file, "guardrail_debug_trap_install_fs0", GuestExec_DebugTrapInstallFs0().u64())
    RealGameBoot_EmitArtifactKV(file, "fs_state_observations", GuestExec_FsStateObservationCount())
    RealGameBoot_EmitArtifactKV(file, "fs_state_mismatches", GuestExec_FsStateMismatchCount())
    RealGameBoot_EmitArtifactKV(file, "fs_state_last_expect_guest", 1u64 if GuestExec_FsStateLastExpectGuest() else 0u64)
    RealGameBoot_EmitArtifactKV(file, "fs_state_last_expected", GuestExec_FsStateLastExpected().u64())
    RealGameBoot_EmitArtifactKV(file, "fs_state_last_actual", GuestExec_FsStateLastActual().u64())
    RealGameBoot_EmitArtifactKV(file, "fs_state_last_expected_owner", GuestExec_FsStateLastExpectedOwner().u64())
    RealGameBoot_EmitArtifactKV(file, "fs_state_last_actual_owner", GuestExec_FsStateLastActualOwner().u64())
    RealGameBoot_EmitArtifactKV(file, "fs_state_last_guest_selector", GuestExec_FsStateLastGuestSelector().u64())
    RealGameBoot_EmitArtifactKV(file, "fs_state_last_host_selector", GuestExec_FsStateLastHostSelector().u64())
    RealGameBoot_EmitArtifactKV(file, "fs_state_last_tcb_base", GuestExec_FsStateLastTcbBase().u64())
    RealGameBoot_EmitArtifactKV(file, "fs_state_last_fs0", GuestExec_FsStateLastFs0().u64())
    RealGameBoot_EmitArtifactKV(file, "fs_state_last_hle_return_addr", GuestExec_FsStateLastHleReturnAddr().u64())
    RealGameBoot_EmitArtifactStringKV(file, "fs_state_last_hle_module", GuestExec_FsStateLastHleModule())
    RealGameBoot_EmitArtifactStringKV(file, "fs_state_last_hle_symbol", GuestExec_FsStateLastHleSymbol())
    RealGameBoot_EmitArtifactKV(file, "fs_state_shadow_owner", GuestExec_FsStateShadowOwner().u64())
    RealGameBoot_EmitArtifactKV(file, "fs_state_shadow_mismatches", GuestExec_FsStateShadowMismatchCount())
    RealGameBoot_EmitArtifactKV(file, "fs_state_shadow_transitions", GuestExec_FsStateShadowTransitionCount())
    RealGameBoot_EmitArtifactStringKV(file, "fs_state_shadow_last_site", GuestExec_FsStateShadowLastSite())
    RealGameBoot_EmitArtifactKV(file, "hle_thunk_contract_count", GuestExec_HleThunkContractCount())
    RealGameBoot_EmitArtifactKV(file, "hle_thunk_contract_last_thunk", GuestExec_HleThunkContractLastThunk().u64())
    RealGameBoot_EmitArtifactKV(file, "hle_thunk_contract_last_target", GuestExec_HleThunkContractLastTarget().u64())
