        RealGameBoot_EmitArtifactKV(file, "dbg_resolution_relocs", Linker_ResolutionRelocCount())
        RealGameBoot_EmitArtifactKV(file, "dbg_hle_zero_addr_count", Linker_HleZeroAddrCount(linker))
