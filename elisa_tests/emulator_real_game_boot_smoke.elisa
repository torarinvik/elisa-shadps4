        RealGameBoot_EmitArtifactKV(file, "dbg_hle_symbols_checksum", Linker_HleSymbolsStringChecksum(linker))
        RealGameBoot_EmitArtifactKV(file, "dbg_reloc_boot_count", dbg_reloc_boot_count)
        RealGameBoot_EmitArtifactKV(file, "dbg_reloc_boot_fp", dbg_reloc_boot_fp)
