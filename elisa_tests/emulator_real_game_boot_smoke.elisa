def RealGameBoot_UseNoForkGuestExec() -> bool:
    value: u8&? = getenv("ELISA_GUEST_EXEC_NO_FORK".cast[u8&])
    if value == null:
        return false
    return streq(value.cast[static u8&], "1") == 1

global mutable dbg_reloc_boot_count: u64 = 0
global mutable dbg_reloc_boot_fp: u64 = 0
global mutable dbg_reloc_pass_a_count: u64 = 0
global mutable dbg_reloc_pass_b_count: u64 = 0
global mutable dbg_reloc_pass_a_fp: u64 = 0
global mutable dbg_reloc_pass_b_fp: u64 = 0

def RealGameBoot_Check(cond: bool, message: static u8&) -> void:
    if not cond:
        panic(message)

def RealGameBoot_WriteLine(file: mutable IOFile&, data: mutable u8&, written: int) -> void:
    if written > 0:
        _ = IOFile_WriteSpan(file, data, written.usize())
        _ = IOFile_WriteSpan(file, "\n"[0].ref[u8&], 1usize)

def RealGameBoot_EmitArtifactKV(file: mutable IOFile&, key: static u8&, value: u64) -> void:
    can Memory.Allocate, Console.Format:
        line: mutable u8[128] = zeroed
        written: int = snprintf(line[0].ref[mutable u8&], 128usize, "CUSA07399_ARTIFACT %s=%llu", key, value)
        RealGameBoot_WriteLine(file, line[0].ref[mutable u8&], written)

# Dump the complete patch-time AeroLib fallback slot table. Because import
# resolution is currently nondeterministic (which slots fall to the fallback
# stub varies run to run), the full table lets us cross-reference whatever slot
# the guest happens to call first against every unimplemented import, keyed by
# owning module + .dynsym symbol index (the ELF symbol name is usually empty).
def RealGameBoot_EmitFallbackSlotTable(file: mutable IOFile&) -> void:
    can Memory.Allocate, Console.Format:
        count: u32 = Linker_FallbackSlotCount()
        limit: mutable usize = count.usize()
        if limit > 256usize:
            limit <- 256usize
        i: mutable usize = 0
        while i < limit:
            idx: u32 = i.u32()
            line: mutable u8[512] = zeroed
            module_text: static u8& = Linker_FallbackSlotModuleAt(idx)
            symbol_text: static u8& = Linker_FallbackSlotSymbolAt(idx)
            written: int = snprintf(line[0].ref[mutable u8&], 512usize, "CUSA07399_ARTIFACT fallback_slot index=%llu slot_va=%llu module=%s symbol=%s symbol_index=%llu rel_type=%llu", i.u64(), Linker_FallbackSlotVaAt(idx), module_text, symbol_text, Linker_FallbackSlotSymbolIndexAt(idx).u64(), Linker_FallbackSlotRelTypeAt(idx).u64())
            RealGameBoot_WriteLine(file, line[0].ref[mutable u8&], written)
            i <- i + 1

def RealGameBoot_EmitArtifactSignedKV(file: mutable IOFile&, key: static u8&, value: s32) -> void:
    can Memory.Allocate, Console.Format:
        line: mutable u8[128] = zeroed
        written: int = snprintf(line[0].ref[mutable u8&], 128usize, "CUSA07399_ARTIFACT %s=%d", key, value)
        RealGameBoot_WriteLine(file, line[0].ref[mutable u8&], written)

def RealGameBoot_EmitArtifactStringKV(file: mutable IOFile&, key: static u8&, value: static u8&?) -> void:
    can Memory.Allocate, Console.Format:
        line: mutable u8[256] = zeroed
        value_text: static u8& = value if value != null else ""
        written: int = snprintf(line[0].ref[mutable u8&], 256usize, "CUSA07399_ARTIFACT %s=%s", key, value_text)
        RealGameBoot_WriteLine(file, line[0].ref[mutable u8&], written)

def RealGameBoot_EmitArtifactAddrWords(file: mutable IOFile&, key: static u8&, addr: VAddr) -> void:
    can Memory.Allocate, Console.Format:
        word0: u64 = MemoryManager_ReadU64(Memory_Instance(), addr)
        word1: u64 = MemoryManager_ReadU64(Memory_Instance(), addr + 8.uintptr())
        word2: u64 = MemoryManager_ReadU64(Memory_Instance(), addr + 16.uintptr())
        word3: u64 = MemoryManager_ReadU64(Memory_Instance(), addr + 24.uintptr())
        line: mutable u8[256] = zeroed
        written: int = snprintf(line[0].ref[mutable u8&], 256usize, "CUSA07399_ARTIFACT %s_addr=0x%llx %s_word0=0x%llx %s_word1=0x%llx %s_word2=0x%llx %s_word3=0x%llx", key, addr.u64(), key, word0, key, word1, key, word2, key, word3)
        RealGameBoot_WriteLine(file, line[0].ref[mutable u8&], written)

def RealGameBoot_EmitArtifactStringPair(file: mutable IOFile&, prefix: static u8&, left_key: static u8&, left_value: static u8&?, right_key: static u8&, right_value: static u8&?) -> void:
    can Memory.Allocate, Console.Format:
        line: mutable u8[256] = zeroed
        left_text: static u8& = left_value if left_value != null else ""
        right_text: static u8& = right_value if right_value != null else ""
        written: int = snprintf(line[0].ref[mutable u8&], 256usize, "CUSA07399_ARTIFACT %s %s=%s %s=%s", prefix, left_key, left_text, right_key, right_text)
        RealGameBoot_WriteLine(file, line[0].ref[mutable u8&], written)

def RealGameBoot_EmitArtifactModule(file: mutable IOFile&, module: static u8&?, host: static u8&?, shared: s32, relocations: u64, imports: u64, resolved: u64, native_hle: u64, prx_export: u64, aerolib_fallback: u64, malformed: u64, unresolved: u64) -> void:
    can Memory.Allocate, Console.Format:
        line: mutable u8[512] = zeroed
        module_text: static u8& = module if module != null else ""
        host_text: static u8& = host if host != null else ""
        written: int = snprintf(line[0].ref[mutable u8&], 512usize, "CUSA07399_ARTIFACT module=%s host=%s shared=%d relocations=%llu imports=%llu resolved=%llu native_hle=%llu prx_export=%llu aerolib_fallback=%llu malformed=%llu unresolved=%llu", module_text, host_text, shared, relocations, imports, resolved, native_hle, prx_export, aerolib_fallback, malformed, unresolved)
        RealGameBoot_WriteLine(file, line[0].ref[mutable u8&], written)

def RealGameBoot_EmitArtifactImport(file: mutable IOFile&, source: static u8&?, nid: static u8&?, library: static u8&?, module: static u8&?, subsystem: static u8&?, resolution: u64) -> void:
    can Memory.Allocate, Console.Format:
        line: mutable u8[512] = zeroed
        source_text: static u8& = source if source != null else ""
        nid_text: static u8& = nid if nid != null else ""
        library_text: static u8& = library if library != null else ""
        module_text: static u8& = module if module != null else ""
        subsystem_text: static u8& = subsystem if subsystem != null else ""
        written: int = snprintf(line[0].ref[mutable u8&], 512usize, "CUSA07399_ARTIFACT fallback_import=1 source=%s nid=%s library=%s module=%s subsystem=%s status=AeroLibFallback resolution=%llu count=1", source_text, nid_text, library_text, module_text, subsystem_text, resolution)
        RealGameBoot_WriteLine(file, line[0].ref[mutable u8&], written)

def RealGameBoot_CountLoginUsers(list: OrbisUserServiceLoginUserIdList) -> u64:
    i: mutable int = 0
    count: mutable u64 = 0u64
    while i < ORBIS_USER_SERVICE_MAX_LOGIN_USERS:
        if list.user_id[i.usize()] != ORBIS_USER_SERVICE_USER_ID_INVALID:
            count <- count + 1u64
        i <- i + 1
    return count

def RealGameBoot_EmitUserServiceArtifacts(file: mutable IOFile&) -> void:
    init_rc: int = sceUserServiceInitialize(null)
    RealGameBoot_EmitArtifactKV(file, "user_service_initialized", 1u64 if init_rc == ORBIS_OK else 0u64)
    if init_rc != ORBIS_OK:
        return
    initial_user: mutable int = ORBIS_USER_SERVICE_USER_ID_INVALID
    initial_rc: int = sceUserServiceGetInitialUser(initial_user.ref[mutable int&])
    if initial_rc == ORBIS_OK:
        RealGameBoot_EmitArtifactSignedKV(file, "user_service_initial_user", initial_user.s32())
    else:
        RealGameBoot_EmitArtifactKV(file, "user_service_initial_user", 0u64)
    login_users: mutable OrbisUserServiceLoginUserIdList = zeroed
    login_rc: int = sceUserServiceGetLoginUserIdList(login_users.ref[mutable void&])
    if login_rc == ORBIS_OK:
        RealGameBoot_EmitArtifactKV(file, "user_service_login_user_count", RealGameBoot_CountLoginUsers(login_users))
    else:
        RealGameBoot_EmitArtifactKV(file, "user_service_login_user_count", 0u64)
    _ = sceUserServiceTerminate()

def RealGameBoot_EmitCrashClassificationArtifacts(file: mutable IOFile&) -> void:
    pc: VAddr = GuestExec_LastGuestPC()
    hle_arg0: VAddr = GuestExec_RuntimeHleArg0()
    hle_ret: VAddr = GuestExec_RuntimeHleRet()
    hle_reason: VAddr = GuestExec_RuntimeHleArg2()
    arg0_prot: u32 = GuestExec_RuntimeHleArg0NativeProt()
    crashed_low_pc: bool = pc != 0.uintptr() and pc.u64() < 4096u64
    crashed_unmapped_pc: bool = GuestExec_LastPCNativeProt() == 0xffffffffu32
    hle_returned_error_before_crash: bool = hle_ret != 0.uintptr() and hle_ret.u64() < 4096u64 and crashed_low_pc
    hle_arg0_unmapped: bool = hle_arg0 != 0.uintptr() and arg0_prot == 0xffffffffu32
    hle_arg0_small_nonzero: bool = hle_arg0 != 0.uintptr() and hle_arg0.u64() < 4096u64
    hle_arg0_small_unmapped: bool = hle_arg0_small_nonzero and hle_arg0_unmapped
    runtime_hle_diag: mutable u64 = 0u64
    if hle_arg0_small_unmapped and hle_ret.u64() == 22u64:
        runtime_hle_diag <- 1001u64
    elif hle_arg0_unmapped and hle_ret != 0.uintptr():
        runtime_hle_diag <- 1002u64
    elif hle_returned_error_before_crash:
        runtime_hle_diag <- 1003u64
    fork_local_mutex_state_stale: mutable bool = false
    if streq(GuestExec_RuntimeHleSymbol(), "posix_pthread_mutex_lock") == 1:
        fork_local_mutex_state_stale <- hle_reason.u64() != threads_sync_last_mutex_reject_reason
    RealGameBoot_EmitArtifactKV(file, "guardrail_low_pc_crash", 1u64 if crashed_low_pc else 0u64)
    RealGameBoot_EmitArtifactKV(file, "guardrail_unmapped_pc_crash", 1u64 if crashed_unmapped_pc else 0u64)
    RealGameBoot_EmitArtifactKV(file, "guardrail_hle_error_then_low_pc", 1u64 if hle_returned_error_before_crash else 0u64)
    RealGameBoot_EmitArtifactKV(file, "guardrail_hle_arg0_unmapped", 1u64 if hle_arg0_unmapped else 0u64)
    RealGameBoot_EmitArtifactKV(file, "guardrail_hle_arg0_small_nonzero", 1u64 if hle_arg0_small_nonzero else 0u64)
    RealGameBoot_EmitArtifactKV(file, "guardrail_hle_arg0_small_unmapped", 1u64 if hle_arg0_small_unmapped else 0u64)
    RealGameBoot_EmitArtifactKV(file, "guardrail_runtime_hle_diagnostic_code", runtime_hle_diag)
    RealGameBoot_EmitArtifactKV(file, "guardrail_runtime_hle_reject_reason", hle_reason.u64())
    RealGameBoot_EmitArtifactKV(file, "guardrail_fork_local_mutex_state_stale", 1u64 if fork_local_mutex_state_stale else 0u64)

def RealGameBoot_RuntimeHleDiagnosticCode() -> u64:
    pc: VAddr = GuestExec_LastGuestPC()
    hle_arg0: VAddr = GuestExec_RuntimeHleArg0()
    hle_ret: VAddr = GuestExec_RuntimeHleRet()
    arg0_prot: u32 = GuestExec_RuntimeHleArg0NativeProt()
    crashed_low_pc: bool = pc != 0.uintptr() and pc.u64() < 4096u64
    hle_returned_error_before_crash: bool = hle_ret != 0.uintptr() and hle_ret.u64() < 4096u64 and crashed_low_pc
    hle_arg0_unmapped: bool = hle_arg0 != 0.uintptr() and arg0_prot == 0xffffffffu32
    hle_arg0_small_unmapped: bool = hle_arg0 != 0.uintptr() and hle_arg0.u64() < 4096u64 and hle_arg0_unmapped
    if hle_arg0_small_unmapped and hle_ret.u64() == 22u64:
        return 1001u64
    if hle_arg0_unmapped and hle_ret != 0.uintptr():
        return 1002u64
    if hle_returned_error_before_crash:
        return 1003u64
    return 0u64

def RealGameBoot_EmitArtifactLastHle(file: mutable IOFile&, module: static u8&?, symbol: static u8&?) -> void:
    can Memory.Allocate, Console.Format:
        line: mutable u8[256] = zeroed
        module_text: static u8& = module if module != null else ""
        symbol_text: static u8& = symbol if symbol != null else ""
        written: int = snprintf(line[0].ref[mutable u8&], 256usize, "CUSA07399_ARTIFACT last_hle_module=%s last_hle_symbol=%s", module_text, symbol_text)
        RealGameBoot_WriteLine(file, line[0].ref[mutable u8&], written)

def RealGameBoot_EmitResolvedImportDebug(file: mutable IOFile&, linker: Linker&, nid: static u8&) -> void:
    for mi in 0..<linker.modules.count:
        module: Module = linker.modules[mi]
        for ii in 0..<module.import_symbols.count:
            rec: ImportSymbolRecord = module.import_symbols[ii]
            if streq(rec.nid, nid) == 1 or streq(rec.name, nid) == 1:
                RealGameBoot_EmitArtifactStringKV(file, "dbg_import_module", module.file)
                RealGameBoot_EmitArtifactStringKV(file, "dbg_import_nid", rec.nid)
                RealGameBoot_EmitArtifactStringKV(file, "dbg_import_name", rec.name)
                RealGameBoot_EmitArtifactKV(file, "dbg_import_resolution_kind", rec.resolution_kind.u64())
                RealGameBoot_EmitArtifactKV(file, "dbg_import_resolved_addr", rec.resolved_virtual_addr)
                return

def RealGameBoot_EmitResolvedImportProbe(file: mutable IOFile&, linker: Linker&, label: static u8&, nid: static u8&) -> void:
    can Memory.Allocate, Console.Format:
        for mi in 0..<linker.modules.count:
            module: Module = linker.modules[mi]
            for ii in 0..<module.import_symbols.count:
                rec: ImportSymbolRecord = module.import_symbols[ii]
                if streq(rec.nid, nid) == 1 or streq(rec.name, nid) == 1:
                    line: mutable u8[768] = zeroed
                    written: int = snprintf(line[0].ref[mutable u8&], 768usize, "CUSA07399_ARTIFACT import_probe label=%s source=%s nid=%s name=%s kind=%llu resolved_addr=%llu native_prot=%llu native_word0=%llu", label, module.file, rec.nid, rec.name, rec.resolution_kind.u64(), rec.resolved_virtual_addr, GuestExec_AddressNativeProt(rec.resolved_virtual_addr.uintptr()).u64(), GuestExec_ReadNativeU64(rec.resolved_virtual_addr.uintptr()).u64())
                    RealGameBoot_WriteLine(file, line[0].ref[mutable u8&], written)
                    return
        line: mutable u8[192] = zeroed
        written: int = snprintf(line[0].ref[mutable u8&], 192usize, "CUSA07399_ARTIFACT import_probe label=%s missing_nid=%s", label, nid)
        RealGameBoot_WriteLine(file, line[0].ref[mutable u8&], written)

def RealGameBoot_EmitAddressProbe(file: mutable IOFile&, linker: Linker&, label: static u8&, addr: VAddr) -> void:
    can Memory.Allocate, Console.Format:
        module_name: mutable static u8& = ""
        module_base: mutable u64 = 0u64
        module_offset: mutable u64 = 0u64
        module_hit: mutable u64 = 0u64
        i: mutable usize = 0
        while i < linker.modules.count and module_hit == 0u64:
            mod: Module = linker.modules[i]
            if mod.base_virtual_addr <= addr and addr < mod.base_virtual_addr + mod.aligned_base_size.uintptr():
                module_hit <- 1u64
                module_name <- mod.name
                module_base <- mod.base_virtual_addr.u64()
                module_offset <- addr.u64() - mod.base_virtual_addr.u64()
            i <- i + 1
        line: mutable u8[512] = zeroed
        written: int = snprintf(line[0].ref[mutable u8&], 512usize, "CUSA07399_ARTIFACT address_probe label=%s addr=%llu native_prot=%llu native_word0=%llu guest_module_hit=%llu guest_module=%s guest_base=%llu guest_offset=%llu", label, addr.u64(), GuestExec_AddressNativeProt(addr).u64(), GuestExec_ReadNativeU64(addr).u64(), module_hit, module_name, module_base, module_offset)
        RealGameBoot_WriteLine(file, line[0].ref[mutable u8&], written)

def RealGameBoot_NativeByteAt(addr: VAddr) -> u8:
    return (GuestExec_ReadNativeU64(addr).u64() & 0xffu64).u8()

def RealGameBoot_NativeU32At(addr: VAddr) -> u32:
    b0: u32 = RealGameBoot_NativeByteAt(addr).u32()
    b1: u32 = RealGameBoot_NativeByteAt(addr + 1.uintptr()).u32()
    b2: u32 = RealGameBoot_NativeByteAt(addr + 2.uintptr()).u32()
    b3: u32 = RealGameBoot_NativeByteAt(addr + 3.uintptr()).u32()
    return b0 | (b1 << 8u32) | (b2 << 16u32) | (b3 << 24u32)

def RealGameBoot_RipRelativeSlot(next_ip: VAddr, disp: u32) -> VAddr:
    if disp < 0x80000000u32:
        return next_ip + disp.u64().uintptr()
    neg: u64 = 0x100000000u64 - disp.u64()
    if next_ip.u64() >= neg:
        return (next_ip.u64() - neg).uintptr()
    return 0.uintptr()

def RealGameBoot_FindHleThunkTargetName(linker: Linker&, target: u64) -> static u8&:
    i: mutable usize = 0
    while i < linker.hle_symbols.symbols.count:
        sym: SymbolRecord = linker.hle_symbols.symbols[i]
        if sym.callable_address == target:
            return sym.name
        i <- i + 1
    return ""

def RealGameBoot_EmitByteWindow(file: mutable IOFile&, label: static u8&, addr: VAddr) -> void:
    can Memory.Allocate, Console.Format:
        b0: u8 = RealGameBoot_NativeByteAt(addr)
        b1: u8 = RealGameBoot_NativeByteAt(addr + 1.uintptr())
        b2: u8 = RealGameBoot_NativeByteAt(addr + 2.uintptr())
        b3: u8 = RealGameBoot_NativeByteAt(addr + 3.uintptr())
        b4: u8 = RealGameBoot_NativeByteAt(addr + 4.uintptr())
        b5: u8 = RealGameBoot_NativeByteAt(addr + 5.uintptr())
        b6: u8 = RealGameBoot_NativeByteAt(addr + 6.uintptr())
        b7: u8 = RealGameBoot_NativeByteAt(addr + 7.uintptr())
        b8: u8 = RealGameBoot_NativeByteAt(addr + 8.uintptr())
        b9: u8 = RealGameBoot_NativeByteAt(addr + 9.uintptr())
        b10: u8 = RealGameBoot_NativeByteAt(addr + 10.uintptr())
        b11: u8 = RealGameBoot_NativeByteAt(addr + 11.uintptr())
        b12: u8 = RealGameBoot_NativeByteAt(addr + 12.uintptr())
        b13: u8 = RealGameBoot_NativeByteAt(addr + 13.uintptr())
        b14: u8 = RealGameBoot_NativeByteAt(addr + 14.uintptr())
        b15: u8 = RealGameBoot_NativeByteAt(addr + 15.uintptr())
        line: mutable u8[512] = zeroed
        written: int = snprintf(line[0].ref[mutable u8&], 512usize, "CUSA07399_ARTIFACT byte_window label=%s addr=%llu b0=%llu b1=%llu b2=%llu b3=%llu b4=%llu b5=%llu b6=%llu b7=%llu b8=%llu b9=%llu b10=%llu b11=%llu b12=%llu b13=%llu b14=%llu b15=%llu", label, addr.u64(), b0.u64(), b1.u64(), b2.u64(), b3.u64(), b4.u64(), b5.u64(), b6.u64(), b7.u64(), b8.u64(), b9.u64(), b10.u64(), b11.u64(), b12.u64(), b13.u64(), b14.u64(), b15.u64())
        RealGameBoot_WriteLine(file, line[0].ref[mutable u8&], written)

def RealGameBoot_EmitContextStackProbe(file: mutable IOFile&, label: static u8&, addr: VAddr) -> void:
    can Memory.Allocate, Console.Format:
        w0: VAddr = GuestExec_ReadContextU64(addr)
        w1: VAddr = GuestExec_ReadContextU64(addr + 8.uintptr())
        w2: VAddr = GuestExec_ReadContextU64(addr + 16.uintptr())
        w3: VAddr = GuestExec_ReadContextU64(addr + 24.uintptr())
        line: mutable u8[512] = zeroed
        written: int = snprintf(line[0].ref[mutable u8&], 512usize, "CUSA07399_ARTIFACT context_stack_probe label=%s addr=%llu w0=%llu w1=%llu w2=%llu w3=%llu", label, addr.u64(), w0.u64(), w1.u64(), w2.u64(), w3.u64())
        RealGameBoot_WriteLine(file, line[0].ref[mutable u8&], written)

def RealGameBoot_EmitCallsiteProbe(file: mutable IOFile&, linker: Linker&, label: static u8&, return_addr: VAddr) -> void:
    can Memory.Allocate, Console.Format:
        kind: mutable u64 = 0u64
        start: mutable VAddr = 0.uintptr()
        target_or_slot: mutable VAddr = 0.uintptr()
        target_or_slot_word0: mutable VAddr = 0.uintptr()
        target_native_prot: mutable u32 = 0xffffffffu32
        target_word0: mutable VAddr = 0.uintptr()
        target_entry_kind: mutable u64 = 0u64
        target_entry_slot: mutable VAddr = 0.uintptr()
        target_entry_slot_word0: mutable VAddr = 0.uintptr()
        target_entry_thunk_base: mutable u64 = 0u64
        target_entry_thunk_target: mutable u64 = 0u64
        target_entry_thunk_name: mutable static u8& = ""
        b_m8: mutable u8 = 0u8
        b_m7: mutable u8 = 0u8
        b_m6: mutable u8 = 0u8
        b_m5: mutable u8 = 0u8
        b_m4: mutable u8 = 0u8
        b_m3: mutable u8 = 0u8
        b_m2: mutable u8 = 0u8
        b_m1: mutable u8 = 0u8
        if return_addr.u64() >= 8u64:
            b_m8 <- RealGameBoot_NativeByteAt(return_addr - 8.uintptr())
            b_m7 <- RealGameBoot_NativeByteAt(return_addr - 7.uintptr())
            b_m6 <- RealGameBoot_NativeByteAt(return_addr - 6.uintptr())
            b_m5 <- RealGameBoot_NativeByteAt(return_addr - 5.uintptr())
            b_m4 <- RealGameBoot_NativeByteAt(return_addr - 4.uintptr())
            b_m3 <- RealGameBoot_NativeByteAt(return_addr - 3.uintptr())
            b_m2 <- RealGameBoot_NativeByteAt(return_addr - 2.uintptr())
            b_m1 <- RealGameBoot_NativeByteAt(return_addr - 1.uintptr())
            if b_m5 == 0xe8.u8():
                kind <- 1u64
                start <- return_addr - 5.uintptr()
                target_or_slot <- RealGameBoot_RipRelativeSlot(return_addr, RealGameBoot_NativeU32At(return_addr - 4.uintptr()))
            elif b_m6 == 0xff.u8() and b_m5 == 0x15.u8():
                kind <- 2u64
                start <- return_addr - 6.uintptr()
                target_or_slot <- RealGameBoot_RipRelativeSlot(return_addr, RealGameBoot_NativeU32At(return_addr - 4.uintptr()))
                target_or_slot_word0 <- GuestExec_ReadNativeU64(target_or_slot)
            elif b_m2 == 0xff.u8() and b_m1 >= 0xd0.u8() and b_m1 <= 0xd7.u8():
                kind <- 3u64
                start <- return_addr - 2.uintptr()
            elif b_m1 == 0xc3.u8() or b_m1 == 0xcb.u8():
                kind <- 4u64
                start <- return_addr - 1.uintptr()
            elif b_m2 == 0xc2.u8() or b_m2 == 0xca.u8():
                kind <- 5u64
                start <- return_addr - 2.uintptr()
        if target_or_slot != 0.uintptr():
            target_native_prot <- GuestExec_AddressNativeProt(target_or_slot)
            target_word0 <- GuestExec_ReadNativeU64(target_or_slot)
            tb0: u8 = RealGameBoot_NativeByteAt(target_or_slot)
            tb1: u8 = RealGameBoot_NativeByteAt(target_or_slot + 1.uintptr())
            tb4: u8 = RealGameBoot_NativeByteAt(target_or_slot + 4.uintptr())
            if tb0 == 0xff.u8() and tb1 == 0x25.u8():
                target_entry_kind <- 1u64
                target_entry_slot <- RealGameBoot_RipRelativeSlot(target_or_slot + 6.uintptr(), RealGameBoot_NativeU32At(target_or_slot + 2.uintptr()))
                target_entry_slot_word0 <- GuestExec_ReadNativeU64(target_entry_slot)
            elif tb0 == 0xff.u8() and tb1 == 0x15.u8():
                target_entry_kind <- 2u64
                target_entry_slot <- RealGameBoot_RipRelativeSlot(target_or_slot + 6.uintptr(), RealGameBoot_NativeU32At(target_or_slot + 2.uintptr()))
                target_entry_slot_word0 <- GuestExec_ReadNativeU64(target_entry_slot)
            elif tb0 == 0xe9.u8():
                target_entry_kind <- 3u64
                target_entry_slot <- RealGameBoot_RipRelativeSlot(target_or_slot + 5.uintptr(), RealGameBoot_NativeU32At(target_or_slot + 1.uintptr()))
            elif tb0 == 0xe8.u8():
                target_entry_kind <- 4u64
                target_entry_slot <- RealGameBoot_RipRelativeSlot(target_or_slot + 5.uintptr(), RealGameBoot_NativeU32At(target_or_slot + 1.uintptr()))
            elif tb4 == 0xe9.u8():
                target_entry_kind <- 5u64
                target_entry_slot <- RealGameBoot_RipRelativeSlot(target_or_slot + 9.uintptr(), RealGameBoot_NativeU32At(target_or_slot + 5.uintptr()))
        if target_entry_slot_word0 != 0.uintptr():
            target_entry_thunk_base <- Linker_FindNativeHleBoundaryThunkBase(target_entry_slot_word0.u64())
            target_entry_thunk_target <- Linker_FindNativeHleBoundaryThunkTarget(target_entry_slot_word0.u64())
            target_entry_thunk_name <- RealGameBoot_FindHleThunkTargetName(linker, target_entry_thunk_target)
        line: mutable u8[1024] = zeroed
        written: int = snprintf(line[0].ref[mutable u8&], 1024usize, "CUSA07399_ARTIFACT callsite_probe label=%s return_addr=%llu kind=%llu start=%llu target_or_slot=%llu target_or_slot_word0=%llu target_native_prot=%llu target_word0=%llu target_entry_kind=%llu target_entry_slot=%llu target_entry_slot_word0=%llu target_entry_thunk_base=%llu target_entry_thunk_target=%llu target_entry_thunk_name=%s native_prot=%llu bytes_m8=%llu bytes_m7=%llu bytes_m6=%llu bytes_m5=%llu bytes_m4=%llu bytes_m3=%llu bytes_m2=%llu bytes_m1=%llu", label, return_addr.u64(), kind, start.u64(), target_or_slot.u64(), target_or_slot_word0.u64(), target_native_prot.u64(), target_word0.u64(), target_entry_kind, target_entry_slot.u64(), target_entry_slot_word0.u64(), target_entry_thunk_base, target_entry_thunk_target, target_entry_thunk_name, GuestExec_AddressNativeProt(return_addr).u64(), b_m8.u64(), b_m7.u64(), b_m6.u64(), b_m5.u64(), b_m4.u64(), b_m3.u64(), b_m2.u64(), b_m1.u64())
        RealGameBoot_WriteLine(file, line[0].ref[mutable u8&], written)
        if start != 0.uintptr():
            RealGameBoot_EmitByteWindow(file, "runtime_hle_call_instruction", start)
            if start.u64() >= 32u64:
                RealGameBoot_EmitByteWindow(file, "runtime_hle_call_before32", start - 32.uintptr())
                RealGameBoot_EmitByteWindow(file, "runtime_hle_call_before16", start - 16.uintptr())
        if target_or_slot != 0.uintptr():
            RealGameBoot_EmitByteWindow(file, "runtime_hle_call_target", target_or_slot)

def RealGameBoot_EmitThunkProbe(file: mutable IOFile&, linker: Linker&, label: static u8&, addr: VAddr) -> void:
    can Memory.Allocate, Console.Format:
        thunk_base: u64 = Linker_FindNativeHleBoundaryThunkBase(addr.u64())
        thunk_target: u64 = Linker_FindNativeHleBoundaryThunkTarget(addr.u64())
        thunk_offset: mutable u64 = 0u64
        target_name: mutable static u8& = ""
        target_nid: mutable static u8& = ""
        target_module: mutable static u8& = ""
        target_library: mutable static u8& = ""
        target_hit: mutable u64 = 0u64
        if thunk_base != 0u64 and addr.u64() >= thunk_base:
            thunk_offset <- addr.u64() - thunk_base
        i: mutable usize = 0
        while i < linker.hle_symbols.symbols.count and target_hit == 0u64:
            sym: SymbolRecord = linker.hle_symbols.symbols[i]
            if sym.callable_address == thunk_target:
                target_hit <- 1u64
                target_name <- sym.name
                target_nid <- sym.nid_name
                target_module <- sym.module
                target_library <- sym.library
            i <- i + 1
        line: mutable u8[768] = zeroed
        written: int = snprintf(line[0].ref[mutable u8&], 768usize, "CUSA07399_ARTIFACT thunk_probe label=%s addr=%llu thunk_base=%llu thunk_offset=%llu thunk_target=%llu target_hit=%llu target_module=%s target_library=%s target_nid=%s target_name=%s", label, addr.u64(), thunk_base, thunk_offset, thunk_target, target_hit, target_module, target_library, target_nid, target_name)
        RealGameBoot_WriteLine(file, line[0].ref[mutable u8&], written)

def RealGameBoot_EmitHandoffManifest(linker: Linker&) -> void:
    can Memory.Allocate, Console.Format:
        file: mutable IOFile = IOFile_opened(REAL_GAME_BOOT_HANDOFF_MANIFEST_PATH, FileAccessMode.Create, FileType.TextFile)
        if linker.modules.count == 0:
            IOFile_Close(file)
            return
        main: Module = linker.modules[0]
        handoff_entry: VAddr = guest_exec_last_main_entry_addr
        entry_word0: u64 = MemoryManager_ReadU64(Memory_Instance(), handoff_entry)
        entry_word1: u64 = MemoryManager_ReadU64(Memory_Instance(), handoff_entry + 8.uintptr())
        entry_offset: mutable u64 = 0
        entry_in_exec_segment: mutable u64 = 0
        if handoff_entry >= main.base_virtual_addr:
            entry_offset <- handoff_entry.u64() - main.base_virtual_addr.u64()
        if main.first_executable_segment_addr != 0.uintptr() and handoff_entry >= main.first_executable_segment_addr and handoff_entry < (main.first_executable_segment_addr + main.first_executable_segment_size.uintptr()):
            entry_in_exec_segment <- 1
        line: mutable u8[512] = zeroed
        written: int = snprintf(line[0].ref[mutable u8&], 512usize, "CUSA07399_HANDOFF_MANIFEST version=1 module_count=%llu entry=0x%llx init_entry=0x%llx main_entry=0x%llx base=0x%llx entry_offset=0x%llx image_base=0x%llx image_size=0x%llx aligned_base_size=0x%llx entry_word0=0x%llx entry_word1=0x%llx executable_segments=%llu first_exec=0x%llx first_exec_size=0x%llx entry_in_exec=%llu mapped_segments=%llu imports=%llu resolved_imports=%llu patched_import_relocations=%llu", linker.modules.count.u64(), handoff_entry.u64(), main.last_start_entry_addr.u64(), guest_exec_last_main_entry_addr.u64(), main.base_virtual_addr.u64(), entry_offset, main.image_virtual_base, main.image_virtual_size, main.aligned_base_size, entry_word0, entry_word1, main.executable_segment_count.u64(), main.first_executable_segment_addr.u64(), main.first_executable_segment_size, entry_in_exec_segment, main.mapped_segment_count.u64(), Module_GetImportSymbolCount(main).u64(), Module_GetResolvedImportSymbolCount(main).u64(), main.patched_import_relocation_count.u64())
        RealGameBoot_WriteLine(file, line[0].ref[mutable u8&], written)
        i: mutable usize = 0
        limit: mutable usize = linker.modules.count
        if limit > 8:
            limit <- 8
        while i < limit:
            mod_ref: Module = linker.modules[i]
            module_line: mutable u8[512] = zeroed
            written_mod: int = snprintf(module_line[0].ref[mutable u8&], 512usize, "CUSA07399_HANDOFF_MODULE index=%llu file=%s host=%s shared=%d base=0x%llx entry=0x%llx image_base=0x%llx image_size=0x%llx executable_segments=%llu mapped_segments=%llu imports=%llu resolved_imports=%llu", i.u64(), mod_ref.file, mod_ref.host_file, 1 if mod_ref.is_shared_lib else 0, mod_ref.base_virtual_addr.u64(), mod_ref.last_start_entry_addr.u64(), mod_ref.image_virtual_base, mod_ref.image_virtual_size, mod_ref.executable_segment_count.u64(), mod_ref.mapped_segment_count.u64(), Module_GetImportSymbolCount(mod_ref).u64(), Module_GetResolvedImportSymbolCount(mod_ref).u64())
            RealGameBoot_WriteLine(file, module_line[0].ref[mutable u8&], written_mod)
            i <- i + 1
        _ = IOFile_Flush(file)
        IOFile_Close(file)

def RealGameBoot_ResetRuntime() -> void:
    Emulator_Reset()
    Linker_Reset()
    EmulatorState_ResetInstance()
    settings: mutable EmulatorSettingsImpl& = EmulatorSettings_GetInstance()
    EmulatorSettings_SetDefaultValues(settings)
    UserSettings_Reset()

def RealGameBoot_CheckMappedImageMirror(module: Module&) -> bool:
    if module.image.count == 0:
        return false
    max_scan: mutable usize = module.image.count
    if max_scan > 4096:
        max_scan <- 4096
    i: mutable usize = 0
    found: mutable bool = false
    while i < max_scan and not found:
        guest_byte: u8 = MemoryManager_ReadU8(Memory_Instance(), module.base_virtual_addr + module.image_virtual_base.uintptr() + i.uintptr())
        if guest_byte == module.image[i]:
            found <- true
        i <- i + 1
    return found

