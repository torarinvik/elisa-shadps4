        RealGameBoot_EmitArtifactKV(file, "dbg_tls_ldt_addr", TLS_DebugLastLdtAddr().u64())
        RealGameBoot_EmitArtifactSignedKV(file, "dbg_tls_ldt_ret", TLS_DebugLastLdtRet().s32())
        RealGameBoot_EmitArtifactKV(file, "dbg_tls_selector", TLS_DebugLastSelector().u64())
        RealGameBoot_EmitArtifactKV(file, "dbg_tls_fs0", TLS_DebugLastFs0().u64())
        RealGameBoot_EmitArtifactKV(file, "dbg_sceKernelGetModuleInfoForUnwind_fn", sceKernelGetModuleInfoForUnwind.uintptr().u64())
        RealGameBoot_EmitResolvedImportDebug(file, linker, "RpQJJVKTiFM")
        RealGameBoot_EmitResolvedImportDebug(file, linker, "7H0iTOciTLo")
        RealGameBoot_EmitResolvedImportDebug(file, linker, "9UK1vLZQft4")
        RealGameBoot_EmitResolvedImportProbe(file, linker, "sceKernelGetModuleInfoForUnwind", "RpQJJVKTiFM")
        RealGameBoot_EmitResolvedImportProbe(file, linker, "posix_pthread_mutex_lock", "7H0iTOciTLo")
        RealGameBoot_EmitResolvedImportProbe(file, linker, "scePthreadMutexLock", "9UK1vLZQft4")
        RealGameBoot_EmitArtifactStringKV(file, "dbg_first_name", Linker_DbgFirstName())
        RealGameBoot_EmitArtifactKV(file, "dbg_first_index", Linker_DbgFirstIndex().u64())
        RealGameBoot_EmitArtifactKV(file, "dbg_name_setfp", Linker_NameSetFingerprint())
        RealGameBoot_EmitArtifactKV(file, "dbg_name_count", Linker_NameCount())
        dbg_m: mutable usize = 0
        while dbg_m < linker.modules.count:
            RealGameBoot_EmitArtifactKV(file, "dbg_mod_strtab_off", linker.modules[dbg_m].dynamic_info.str_table_offset)
            RealGameBoot_EmitArtifactKV(file, "dbg_mod_strtab_size", linker.modules[dbg_m].dynamic_info.str_table_size)
            dbg_m <- dbg_m + 1
        if linker.modules.count > 0:
            RealGameBoot_EmitArtifactKV(file, "dbg_mod0_symtab_off", linker.modules[0].dynamic_info.symbol_table_offset)
            RealGameBoot_EmitArtifactKV(file, "dbg_mod0_strtab_off", linker.modules[0].dynamic_info.str_table_offset)
            RealGameBoot_EmitArtifactKV(file, "dbg_mod0_syment_size", linker.modules[0].dynamic_info.symbol_table_entries_size)
        RealGameBoot_EmitArtifactKV(file, "dbg_reloc_pass_a_count", dbg_reloc_pass_a_count)
        RealGameBoot_EmitArtifactKV(file, "dbg_reloc_pass_b_count", dbg_reloc_pass_b_count)
        RealGameBoot_EmitArtifactKV(file, "dbg_reloc_pass_a_fp", dbg_reloc_pass_a_fp)
        RealGameBoot_EmitArtifactKV(file, "dbg_reloc_pass_b_fp", dbg_reloc_pass_b_fp)
        dbg_mod: mutable usize = 0
        while dbg_mod < linker.modules.count:
            RealGameBoot_EmitArtifactKV(file, "dbg_mod_dyndata_checksum", Module_DynamicDataChecksum(linker.modules[dbg_mod]))
            dbg_mod <- dbg_mod + 1
        RealGameBoot_EmitFallbackSlotTable(file)
        RealGameBoot_EmitUserServiceArtifacts(file)
        i: mutable usize = 0
        limit: mutable usize = linker.modules.count
        if limit > 8:
            limit <- 8
        while i < limit:
            native_count: mutable u64 = 0
            prx_count: mutable u64 = 0
            fallback_count: mutable u64 = 0
            malformed_count: mutable u64 = 0
            unresolved_count: mutable u64 = 0
            for j in 0..<linker.modules[i].import_symbols.count:
                rec: ImportSymbolRecord = linker.modules[i].import_symbols[j]
                if rec.resolution_kind == IMPORT_RESOLUTION_NATIVE_HLE:
                    native_count <- native_count + 1
                elif rec.resolution_kind == IMPORT_RESOLUTION_PRX_EXPORT:
                    prx_count <- prx_count + 1
                elif rec.resolution_kind == IMPORT_RESOLUTION_AEROLIB_FALLBACK:
                    fallback_count <- fallback_count + 1
                elif rec.resolution_kind == IMPORT_RESOLUTION_MALFORMED:
                    malformed_count <- malformed_count + 1
                elif not rec.resolved:
                    unresolved_count <- unresolved_count + 1
                RealGameBoot_EmitArtifactResolve(file, rec.nid, RealGameBoot_SymtypeName(rec.symbol_type), 1 if rec.resolved else 0)
            RealGameBoot_EmitArtifactModule(file, i.u64(), linker.modules[i].file, linker.modules[i].host_file, linker.modules[i].base_virtual_addr.u64(), linker.modules[i].aligned_base_size, 1 if linker.modules[i].is_shared_lib else 0, linker.modules[i].applied_relocation_count.u64(), Module_GetImportSymbolCount(linker.modules[i]).u64(), Module_GetResolvedImportSymbolCount(linker.modules[i]).u64(), native_count, prx_count, fallback_count, malformed_count, unresolved_count)
            RealGameBoot_EmitArtifactKV(file, "module_exec_segments", linker.modules[i].executable_segment_count.u64())
            RealGameBoot_EmitArtifactKV(file, "module_exec_mismatch", linker.modules[i].executable_segment_permission_mismatch_count.u64())
            RealGameBoot_EmitArtifactKV(file, "module_patched_import_relocations", linker.modules[i].patched_import_relocation_count.u64())
            i <- i + 1
        for mi in 0..<linker.modules.count:
            mod_ref: Module = linker.modules[mi]
            for ii in 0..<mod_ref.import_symbols.count:
                rec: ImportSymbolRecord = mod_ref.import_symbols[ii]
                if rec.resolution_kind != IMPORT_RESOLUTION_AEROLIB_FALLBACK:
                    continue
                subsystem: mutable static u8& = "kernel"
                if static_strlen(rec.library) > 0:
                    if Linker_StringHasPrefix(rec.library, "libScePad"):
                        subsystem <- "audio_input_service"
                    elif Linker_StringHasPrefix(rec.library, "libSceGnm") or Linker_StringHasPrefix(rec.library, "libSceVideo") or Linker_StringHasPrefix(rec.library, "libSceFont"):
                        subsystem <- "graphics"
                    elif Linker_StringHasPrefix(rec.library, "libSceSaveData") or Linker_StringHasPrefix(rec.library, "libSceSaveDataDialog") or Linker_StringHasPrefix(rec.library, "libSceCommonDialog") or Linker_StringHasPrefix(rec.library, "libSceWebBrowserDialog") or Linker_StringHasPrefix(rec.library, "libSceSigninDialog"):
                        subsystem <- "save_dialog_misc"
                    elif Linker_StringHasPrefix(rec.library, "libSceAudio") or Linker_StringHasPrefix(rec.library, "libSceAjm") or Linker_StringHasPrefix(rec.library, "libSceCommonDialog"):
                        subsystem <- "audio_input_service"
                    elif Linker_StringHasPrefix(rec.library, "libSceAppContent") or Linker_StringHasPrefix(rec.library, "libSceContentExport"):
                        subsystem <- "kernel"
                RealGameBoot_EmitArtifactImport(file, mod_ref.file, rec.nid, rec.library, rec.module, subsystem, rec.resolution_kind.u64())
        RealGameBoot_EmitModuleStartOracleTrace(file)
        RealGameBoot_EmitHleOracleTrace(file)
        RealGameBoot_EmitArtifactLastHle(file, GuestExec_LastHleModule(), GuestExec_LastHleSymbol())
        _ = file.Flush()
        file.Close()
        RealGameBoot_EmitHandoffManifest(linker)

@test
def emulator_real_game_boot_smoke_loads_cusa07399_eboot() -> void:
    can Memory.Allocate, Abort.Panic:
        RealGameBoot_ResetRuntime()

        arena: Arena = zeroed
        result: mutable int = -1
        in arena:
            args: mutable darray[static u8&] = ["shadps4", REAL_GAME_BOOT_ROOT, "--", "-RealBootSmoke"]
            can Unsafe.SegmentMutation, Unsafe.GuestSegmentInstall, Segment.Guest, Segment.Host:
                result <- Main_Run(args)
        RealGameBoot_Check(result == 0, "expected real game Main_Run success")

        emu: mutable Emulator& = Emulator_GetInstance()
        RealGameBoot_Check(streq(Emulator_GetLastRunPath(emu), REAL_GAME_BOOT_EBOOT) == 1, "expected real game eboot path")
        RealGameBoot_Check(streq(Emulator_GetLastGameFolder(emu), REAL_GAME_BOOT_ROOT) == 1, "expected real game app0 root")
        RealGameBoot_Check(streq(Emulator_GetLastGuestEbootPath(emu), "/app0/eboot.bin") == 1, "expected real game guest eboot path")
        RealGameBoot_Check(emu.last_linker_module_index == 0, "expected real game module index")
        RealGameBoot_Check(emu.last_linker_module_count > 1usize, "expected real game dependencies to load")
        RealGameBoot_Check(emu.last_linker_start_result == 0, "expected real game start result")
        RealGameBoot_Check(emu.app0_mounted, "expected real game app0 mount")
        RealGameBoot_Check(emu.hostapp_mounted, "expected real game hostapp mount")
        RealGameBoot_Check(not emu.native_guest_exec_requested, "expected native guest exec disabled by default")
        RealGameBoot_Check(not GuestExec_IsEnabled(), "expected guest exec runtime disabled by default")

        linker: mutable Linker& = Linker_GetInstance()
        can Memory.Allocate, Abort.Panic, Console:
            RealGameBoot_EmitArtifacts(linker, 0)
        RealGameBoot_Check(linker.modules.count > 1usize, "expected linker to contain real game plus dependencies")
        RealGameBoot_Check(linker.last_started_module_index == 0, "expected real game started module index")
        RealGameBoot_Check(linker.last_start_result == 0, "expected linker start result")
        RealGameBoot_Check(linker.last_unresolved_import_count == 0usize, "expected real game and dependency imports to resolve")
        RealGameBoot_Check(linker.last_relocated_import_count > 0usize, "expected real game import relocations")
        RealGameBoot_Check(linker.last_prx_export_resolved_count > 0usize, "expected CUSA07399 to include PRX-export-backed imports")

        module: Module = linker.modules[0]
        RealGameBoot_Check(streq(module.file, "/app0/eboot.bin") == 1, "expected guest module name")
        RealGameBoot_Check(streq(module.host_file, REAL_GAME_BOOT_EBOOT) == 1, "expected host eboot path")
        RealGameBoot_Check(module.is_valid, "expected real game module valid")
        RealGameBoot_Check(not module.is_shared_lib, "expected eboot not to be marked shared")
        RealGameBoot_Check(module.dynamic_segment.count > 0, "expected dynamic segment")
        RealGameBoot_Check(module.dynamic_data.count > 0, "expected dynamic data")
        RealGameBoot_Check(module.image.count > 0, "expected loaded image")
        RealGameBoot_Check(module.mapped_segment_count > 0, "expected mapped PT_LOAD segments")
        RealGameBoot_Check(module.entry_virtual_addr > 0.uintptr(), "expected entry virtual address")
        RealGameBoot_Check(Module_GetImportSymbolCount(module) > 0, "expected imported HLE symbols")
        RealGameBoot_Check(Module_GetResolvedImportSymbolCount(module) == Module_GetImportSymbolCount(module), "expected all imports resolved")
        RealGameBoot_Check(module.applied_relocation_count > 0usize, "expected relocation writes")
        RealGameBoot_Check(module.executable_segment_permission_mismatch_count == 0usize, "expected executable segment permissions to match expected exec mapping")
        RealGameBoot_Check(RealGameBoot_CheckMappedImageMirror(module), "expected image bytes mirrored into guest memory backing")
        RealGameBoot_Check(Linker_FindByFileOrHost(linker, "/app0/sce_module/libc.prx") != 0xFFFFFFFF.u32(), "expected app-local libc.prx dependency")
        RealGameBoot_Check(Linker_FindByFileOrHost(linker, "/app0/sce_module/libSceFios2.prx") != 0xFFFFFFFF.u32(), "expected app-local libSceFios2.prx dependency")
        RealGameBoot_Check(streq(linker.modules[0].file, "/app0/eboot.bin") == 1, "expected eboot to remain module zero after dependencies")

        state: mutable EmulatorState& = EmulatorState_GetInstance()
        RealGameBoot_Check(EmulatorState_IsGameRunning(state), "expected game running state")

@test
def emulator_real_game_boot_smoke_probes_native_guest_exec_handoff() -> void:
    can Memory.Allocate, Abort.Panic:
        RealGameBoot_ResetRuntime()

        arena: Arena = zeroed
        result: mutable int = -1
        in arena:
            args: mutable darray[static u8&] = ["shadps4", "--native-guest-exec-probe", REAL_GAME_BOOT_ROOT]
            can Unsafe.SegmentMutation, Unsafe.GuestSegmentInstall, Segment.Guest, Segment.Host:
                result <- Main_Run(args)
        RealGameBoot_Check(result == 0, "expected native guest exec probe launch success")

        emu: mutable Emulator& = Emulator_GetInstance()
        RealGameBoot_Check(emu.native_guest_exec_requested, "expected native guest exec requested")
        RealGameBoot_Check(emu.native_guest_exec_probe_requested, "expected native guest exec probe requested")
        RealGameBoot_Check(GuestExec_IsProbeMode(), "expected guest exec probe mode")
        RealGameBoot_Check(GuestExec_IsEnabled(), "expected guest exec enabled in probe mode")
        RealGameBoot_Check(guest_exec_run_count > 0usize, "expected guest exec handoff to be reached")
        RealGameBoot_Check(guest_exec_last_entry_addr > 0.uintptr(), "expected guest exec entry address to be recorded")
        RealGameBoot_Check(guest_exec_main_run_count == 1usize, "expected one main executable handoff")
        RealGameBoot_Check(guest_exec_last_main_entry_addr > 0.uintptr(), "expected main executable entry address to be recorded")

        linker: mutable Linker& = Linker_GetInstance()
        can Memory.Allocate, Abort.Panic, Console:
            RealGameBoot_EmitArtifacts(linker, 0)
        RealGameBoot_Check(linker.last_unresolved_import_count == 0usize, "expected native probe launch imports to resolve")
        RealGameBoot_Check(linker.last_entry_addr > 0.uintptr(), "expected linker entry to be recorded")
        RealGameBoot_Check(linker.modules[0].last_start_entry_addr > 0.uintptr(), "expected main module start entry to be recorded")
        RealGameBoot_Check(guest_exec_last_main_entry_addr == linker.last_entry_addr, "expected main probe entry to match linker executable entry")
        stage_status: s32 = GuestExec_ClassifyGameExecutionStage()
        if GuestExec_IsSupported():
            RealGameBoot_Check(stage_status == 2, "expected supported host probe to arm game execution stage")
        else:
            RealGameBoot_Check(stage_status == -2, "expected unsupported host game execution classification")
        boundary_status: s32 = GuestExec_ClassifyFirstBoundary()
        if GuestExec_IsSupported():
            RealGameBoot_Check(boundary_status == GUEST_EXEC_BOUNDARY_ARMED_PROBE_ONLY, "expected supported host probe boundary classification")
        else:
            RealGameBoot_Check(boundary_status == GUEST_EXEC_BOUNDARY_UNSUPPORTED_HOST, "expected unsupported host boundary classification")

def RealGameBoot_EmitModuleTable(linker: Linker&) -> void:
    # Write the loaded module ranges to a stable file before the guarded run, so
    # tools/crash_backtrace.py can symbolize PRX frames (not just the eboot) even
    # though the crash truncates the main artifact emission.
    can Memory.Allocate, Console.Format:
        file: mutable IOFile = IOFile("/tmp/elisa_modules.txt", FileAccessMode.Create, FileType.TextFile)
        i: mutable usize = 0usize
        while i < linker.modules.count:
            m: Module& = &linker.modules[i]
            line: mutable u8[320] = zeroed
            written: int = snprintf(line[0], 320usize, "MODULE %s %llu %llu", m.name, m.base_virtual_addr.u64(), m.aligned_base_size)
            RealGameBoot_WriteLine(file, line[0], written)
            i <- i + 1usize
        file.Close()

def RealGameBoot_DumpGuestCode(start: u64, words: u64) -> void:
    # Dump a guest code/data region (as 8-byte little-endian words) to a file for
    # offline disassembly. Used to inspect the crash site without a decrypted SELF.
    can Memory.Allocate, Console.Format:
        file: mutable IOFile = IOFile("/tmp/elisa_code.txt", FileAccessMode.Create, FileType.TextFile)
        i: mutable u64 = 0u64
        while i < words:
            addr: u64 = start + i * 8u64
            line: mutable u8[64] = zeroed
            written: int = snprintf(line[0], 96usize, "%llx %llx %llx", addr, GuestExec_ReadNativeU64(addr.uintptr()).u64(), GuestExec_ReadContextU64(addr.uintptr()).u64())
            RealGameBoot_WriteLine(file, line[0], written)
            i <- i + 1u64
        file.Close()

@test
def emulator_real_game_boot_smoke_guarded_game_entry_reports_host_status() -> void:
    can Memory.Allocate, Abort.Panic:
        RealGameBoot_ResetRuntime()
        RealGameBoot_EmitPhaseBreadcrumb(1u64)
        emergency_watchdog: bool = RealGameBoot_UseEmergencyWatchdogFailfast()
        GuestExec_SetEmergencyWatchdogFailfast(emergency_watchdog)
        ge_emergency_mark(GE_EV_MAIN_RUN_BEGIN, 1.uintptr(), 0.uintptr(), 0.uintptr(), 0.uintptr())
        if emergency_watchdog:
            setup_watchdog_ms: mutable u64 = RealGameBoot_GetEnvU64("ELISA_GUEST_EXEC_EMERGENCY_WATCHDOG_MS")
            if setup_watchdog_ms == 0u64:
                setup_watchdog_ms <- 120000u64
            GuestExec_DebugArmEmergencyTimer(setup_watchdog_ms.u32())

        arena: Arena = zeroed
        result: mutable int = -1
        in arena:
            args: mutable darray[static u8&] = ["shadps4", "--native-guest-exec-probe", REAL_GAME_BOOT_ROOT]
            can Unsafe.SegmentMutation, Unsafe.GuestSegmentInstall, Segment.Guest, Segment.Host:
                result <- Main_Run(args)
        if emergency_watchdog:
            GuestExec_DebugDisarmEmergencyTimer()
        ge_emergency_mark(GE_EV_MAIN_RUN_END, result.u64().uintptr(), 0.uintptr(), 0.uintptr(), 0.uintptr())
        RealGameBoot_EmitPhaseBreadcrumb(2u64)
        RealGameBoot_Check(result == 0, "expected guarded guest exec launch setup success")

        linker: mutable Linker& = Linker_GetInstance()
        entry: VAddr = linker.last_entry_addr
        RealGameBoot_EmitPhaseBreadcrumb(3u64)
        RealGameBoot_Check(entry > 0.uintptr(), "expected executable entry before guarded run")
        RealGameBoot_EmitPhaseBreadcrumb(31u64)
        RealGameBoot_Check(entry == guest_exec_last_main_entry_addr, "expected guarded run to use recorded main executable entry")
        RealGameBoot_EmitPhaseBreadcrumb(32u64)
        GuestExec_SetProbeMode(false)
        RealGameBoot_EmitPhaseBreadcrumb(33u64)
        GuestExec_SetDebugTrapOnBoundaryGuard(RealGameBoot_UseBoundaryDebugTrap())
        GuestExec_SetFsStateCheckEnabled(true)
        GuestExec_SetFsStateTrapOnMismatch(RealGameBoot_UseBoundaryDebugTrap())
        GuestExec_SetEmergencyWatchdogFailfast(emergency_watchdog)
        GuestExec_SetPCSampler(RealGameBoot_UsePCSampler(), 5u32)
        RealGameBoot_EmitPhaseBreadcrumb(34u64)
        GuestExec_SetDebugTrapOnUnpublishedExec(RealGameBoot_UseUnpublishedExecDebugTrap())
        RealGameBoot_EmitPhaseBreadcrumb(35u64)
        if RealGameBoot_UseDebugTrace():
            GuestExec_SetDebugTraceEnabled(true)
            RealGameBoot_EmitPhaseBreadcrumb(36u64)
            GuestExec_DebugTraceReset()
            RealGameBoot_EmitPhaseBreadcrumb(37u64)

        RealGameBoot_EmitModuleTable(linker)
        dump_code_addr: u64 = RealGameBoot_GetEnvU64("ELISA_DUMP_CODE_ADDR")
        if dump_code_addr != 0u64:
            RealGameBoot_DumpGuestCode(dump_code_addr, 96u64)
        find_ref_addr: u64 = RealGameBoot_GetEnvU64("ELISA_FIND_REF_ADDR")
        if find_ref_addr != 0u64:
            ref_file: mutable IOFile = IOFile("/tmp/elisa_find_refs.txt", FileAccessMode.Create, FileType.TextFile)
            find_ref: VAddr = find_ref_addr.uintptr()
            RealGameBoot_EmitAddressProbe(ref_file, linker, "find_ref_addr", find_ref)
            RealGameBoot_EmitPointerReferences(ref_file, linker, "find_ref_addr", find_ref)
            RealGameBoot_EmitUnalignedPointerReferences(ref_file, linker, "find_ref_addr", find_ref)
            RealGameBoot_EmitRipRelativeRefs(ref_file, linker, "find_ref_addr", find_ref)
            RealGameBoot_EmitDirectCallers(ref_file, linker, "find_ref_addr", find_ref)
            RealGameBoot_EmitIndirectTransfersToValue(ref_file, linker, "find_ref_addr", find_ref)
            RealGameBoot_EmitRelocationProbe(ref_file, linker, "find_ref_addr", find_ref)
            _ = ref_file.Flush()
            ref_file.Close()
        call_init_addr: u64 = RealGameBoot_GetEnvU64("ELISA_CALL_GUEST_INIT_ADDR")
        if call_init_addr != 0u64:
            can Unsafe.SegmentMutation, Unsafe.GuestSegmentInstall, Segment.Guest, Segment.Host:
                Module_CallGuestInitArrayEntry(call_init_addr.uintptr())
        proc_file: mutable IOFile = IOFile("/tmp/elisa_procparam.txt", FileAccessMode.Create, FileType.TextFile)
        proc_param_probe: VAddr = Linker_GetProcParam(linker)
        RealGameBoot_EmitAddressProbe(proc_file, linker, "proc_param", proc_param_probe)
        RealGameBoot_EmitMainInitArrays(proc_file, linker)
        if proc_param_probe != 0.uintptr():
            libc_param_probe: VAddr = MemoryManager_ReadU64(Memory_Instance(), proc_param_probe + 56.uintptr()).uintptr()
            RealGameBoot_EmitAddressProbe(proc_file, linker, "libc_param", libc_param_probe)
            word_i: mutable u64 = 0u64
            while word_i < 16u64:
                RealGameBoot_EmitArtifactKV(proc_file, "libc_param_word", MemoryManager_ReadU64(Memory_Instance(), libc_param_probe + (word_i * 8u64).uintptr()))
                word_i <- word_i + 1u64
        RealGameBoot_EmitResolvedImportProbe(proc_file, linker, "malloc", "gQX+4GDQjpM")
        RealGameBoot_EmitResolvedImportProbe(proc_file, linker, "free", "tIhsqj0qsFE")
        RealGameBoot_EmitResolvedImportProbe(proc_file, linker, "__cxa_guard_acquire", "3GPpjQdAMTw")
        RealGameBoot_EmitResolvedImportProbe(proc_file, linker, "__cxa_guard_release", "9rAeANT2tyE")
        RealGameBoot_EmitResolvedImportProbe(proc_file, linker, "__cxa_atexit", "tsvEmnenz48")
        RealGameBoot_EmitResolvedImportProbe(proc_file, linker, "sceKernelGetDirectMemorySize", "pO96TwzOm5E")
        RealGameBoot_EmitResolvedImportProbe(proc_file, linker, "sceKernelAllocateDirectMemory", "rTXw65xmLIA")
        RealGameBoot_EmitResolvedImportProbe(proc_file, linker, "sceKernelMapDirectMemory", "L-Q3LEjIbgA")
        RealGameBoot_EmitResolvedImportProbe(proc_file, linker, "sceKernelDirectMemoryQuery", "BHouLQzh0X0")
        RealGameBoot_EmitAddressProbe(proc_file, linker, "crash_global_802d85190", 0x802d85190.uintptr())
        RealGameBoot_EmitNearestSymbolProbe(proc_file, linker, "crash_global_802d85190", 0x802d85190.uintptr())
        RealGameBoot_EmitAddressProbe(proc_file, linker, "neighbor_global_802d852c0", 0x802d852c0.uintptr())
        RealGameBoot_EmitNearestSymbolProbe(proc_file, linker, "neighbor_global_802d852c0", 0x802d852c0.uintptr())
        RealGameBoot_EmitAddressProbe(proc_file, linker, "suspect_initializer_800dcf7a0", 0x800dcf7a0.uintptr())
        RealGameBoot_EmitNearestSymbolProbe(proc_file, linker, "suspect_initializer_800dcf7a0", 0x800dcf7a0.uintptr())
        RealGameBoot_EmitAddressProbe(proc_file, linker, "crash_object_vtable_8022ff800", 0x8022ff800.uintptr())
        RealGameBoot_EmitAddressProbe(proc_file, linker, "crash_object_vslot_c0_8022ff8c0", 0x8022ff8c0.uintptr())
        RealGameBoot_EmitNearestSymbolProbe(proc_file, linker, "crash_object_vslot_c0_target", GuestExec_ReadNativeU64(0x8022ff8c0.uintptr()).uintptr())
        RealGameBoot_EmitArtifactKV(proc_file, "ptr_HLE_sceKernelGetDirectMemorySize", HLE_sceKernelGetDirectMemorySize.uintptr().u64())
        RealGameBoot_EmitArtifactKV(proc_file, "ptr_HLE_sceKernelAllocateDirectMemory", HLE_sceKernelAllocateDirectMemory.uintptr().u64())
        RealGameBoot_EmitArtifactKV(proc_file, "ptr_HLE_sceKernelMapDirectMemory", HLE_sceKernelMapDirectMemory.uintptr().u64())
        RealGameBoot_EmitArtifactKV(proc_file, "ptr_HLE_sceKernelDirectMemoryQuery", HLE_sceKernelDirectMemoryQuery.uintptr().u64())
        _ = proc_file.Flush()
        proc_file.Close()
        watch_addr: u64 = RealGameBoot_GetEnvU64("ELISA_WATCH_ADDR")
        if watch_addr != 0u64:
            GuestExec_SetValueWatch(watch_addr.uintptr(), RealGameBoot_GetEnvU64("ELISA_WATCH_VALUE"))
        pagewatch_addr: u64 = RealGameBoot_GetEnvU64("ELISA_PAGEWATCH_ADDR")
        if pagewatch_addr != 0u64:
            can Unsafe.SegmentMutation, Segment.Host:
                GuestExec_SetPageWatch(pagewatch_addr.uintptr())
        guard_timeout_ms: mutable u32 = 25u32
        env_timeout: u64 = RealGameBoot_GetEnvU64("ELISA_GUARD_TIMEOUT_MS")
        if env_timeout != 0u64 or getenv("ELISA_GUARD_TIMEOUT_MS".cast[u8&]) != null:
            guard_timeout_ms <- env_timeout.u32()
        status: mutable s32 = 0
        if RealGameBoot_UseNoForkGuestExec():
            RealGameBoot_EmitPhaseBreadcrumb(38u64)
            RealGameBoot_EmitPhaseBreadcrumb(39u64)
            RealGameBoot_EmitPhaseBreadcrumb(4u64)
            ge_raw_breadcrumb("GE:TEST_BEFORE_GUARD\n", 21usize)
            can Unsafe.SegmentMutation, Unsafe.GuestSegmentInstall, Segment.Host, Segment.Guest:
                status <- GuestExec_RunMainEntryGuardedInProcess(entry, guest_exec_last_argc, null, guard_timeout_ms)
            ge_raw_breadcrumb("GE:TEST_AFTER_GUARD\n", 20usize)
            can Console.Format, Unsafe.SegmentMutation, Segment.Host:
                GuestExec_DumpHleCallRing()
                GuestExec_ResolveSignalSymbols()
                fault_sym_line: mutable u8[320] = zeroed
                fsw: int = snprintf(fault_sym_line[0], 320usize, "CUSA07399_ARTIFACT fault_pc_symbol=%s fault_pc_image=%s fault_stack0_symbol=%s", GuestExec_SignalPCSymbol(), GuestExec_SignalPCImage(), GuestExec_SignalStackSymbol0())
                GuestExec_DumpHleCallRingLine(fault_sym_line[0], 320usize, fsw)
            heap_api: uintptr = Linker_GetHeapAPI()
            ge_emergency_mark(GE_EV_HLE_KNOWN_TARGET, heap_api, GuestExec_ReadNativeU64(heap_api), GuestExec_ReadNativeU64(heap_api + 8.uintptr()), GuestExec_ReadNativeU64(heap_api + 16.uintptr()))
            ge_emergency_mark(GE_EV_HLE_KNOWN_TARGET, Kernel_DebugHeapApiFunc(), Kernel_DebugHeapApiReturnAddr(), Linker_GetHeapAPI(), GuestExec_ReadNativeU64(Linker_GetHeapAPI()))
            ge_emergency_mark(GE_EV_HLE_KNOWN_TARGET, 0x444d4441.uintptr(), Kernel_DebugLastDirectAllocResult().u64().uintptr(), Kernel_DebugLastDirectAllocPhys().u64().uintptr(), Kernel_DebugLastDirectAllocLen().uintptr())
            ge_emergency_mark(GE_EV_HLE_KNOWN_TARGET, 0x444d444d.uintptr(), Kernel_DebugLastDirectMapResult().u64().uintptr(), Kernel_DebugLastDirectMapPhys().u64().uintptr(), Kernel_DebugLastDirectMapLen().uintptr())
            ge_emergency_mark(GE_EV_HLE_KNOWN_TARGET, 0x444d444e.uintptr(), Kernel_DebugLastDirectMapAddr(), 0.uintptr(), 0.uintptr())
            ge_emergency_mark(GE_EV_TEST_AFTER_GUARD, status.u64().uintptr(), GuestExec_LastSignal().u64().uintptr(), GuestExec_FsStateShadowOwner().u64().uintptr(), GuestExec_LastStatus().u64().uintptr())
            ge_emergency_dump_raw()
        else:
            RealGameBoot_EmitPhaseBreadcrumb(5u64)
            ge_raw_breadcrumb("GE:TEST_BEFORE_FORK_GUARD\n", 26usize)
            can Unsafe.SegmentMutation, Segment.Host, Segment.Guest:
                status <- GuestExec_RunMainEntryGuarded(entry, guest_exec_last_argc, null, 25.u32())
            ge_raw_breadcrumb("GE:TEST_AFTER_FORK_GUARD\n", 25usize)
        if emergency_watchdog:
            GuestExec_DebugDisarmEmergencyTimer()
        ge_raw_breadcrumb("GE:TEST_AFTER_WATCHDOG\n", 23usize)
        if GuestExec_IsSupported():
            RealGameBoot_Check(status != -2, "expected supported host to attempt guarded game entry")
        else:
            RealGameBoot_Check(status == -2, "expected unsupported host guarded game entry status")
        ge_raw_breadcrumb("GE:TEST_AFTER_SUPPORT_CHECK\n", 28usize)
        RealGameBoot_Check(guest_exec_last_game_execution_status == status, "expected guarded status to be recorded")
        ge_raw_breadcrumb("GE:TEST_AFTER_STATUS_CHECK\n", 27usize)
        boundary_status: s32 = GuestExec_ClassifyFirstBoundary()
        stage_code: s32 = GuestExec_ExecutionStage()
        if GuestExec_IsSupported():
            RealGameBoot_Check(boundary_status == GUEST_EXEC_BOUNDARY_FIRST_HLE_IMPORT or boundary_status == GUEST_EXEC_BOUNDARY_TIMEOUT or boundary_status == GUEST_EXEC_BOUNDARY_PRE_BOUNDARY_FAULT or boundary_status == GUEST_EXEC_BOUNDARY_EXITED_BEFORE_BOUNDARY, "expected guarded execution to classify the first-boundary or pre-boundary outcome")
            RealGameBoot_Check(stage_code >= GUEST_EXEC_STAGE_GUARDED_ENTRY, "expected guarded run to advance execution stage beyond handoff")
            if GuestExec_RuntimeHleArg0() != 0.uintptr() and GuestExec_RuntimeHleArg0().u64() < 4096u64 and GuestExec_RuntimeHleArg0NativeProt() == 0xffffffffu32 and GuestExec_RuntimeHleRet().u64() == 22u64:
                RealGameBoot_Check(RealGameBoot_RuntimeHleDiagnosticCode() == 1001u64, "expected small-unmapped HLE pointer diagnostic")
                RealGameBoot_Check(GuestExec_RuntimeHleArg2().u64() == 3u64, "expected fork-report HLE reject reason for small unmapped pointer")
        else:
            RealGameBoot_Check(boundary_status == GUEST_EXEC_BOUNDARY_UNSUPPORTED_HOST, "expected unsupported host boundary classification after guarded run")
            RealGameBoot_Check(streq(GuestExec_FirstBoundaryReasonName(), "unsupported-host") == 1, "expected unsupported host boundary reason name")
            RealGameBoot_Check(GuestExec_HostArchitecture() != null, "expected host architecture to be reported")
            RealGameBoot_Check(GuestExec_HostMode() != null, "expected host mode to be reported")
            if streq(GuestExec_HostMode(), "macOS") == 1 and streq(GuestExec_HostArchitecture(), "arm64") == 1:
                x64_probe_first: bool = GuestExec_HostCanRunX64Subprocess()
                x64_probe_second: bool = GuestExec_HostCanRunX64Subprocess()
                RealGameBoot_Check(x64_probe_first == x64_probe_second, "expected x64 subprocess capability probe to be deterministic")
            RealGameBoot_Check(GuestExec_IsProbeOnly(), "expected probe-only mode on unsupported host")
            RealGameBoot_Check(stage_code == GUEST_EXEC_STAGE_GUARDED_ENTRY, "expected unsupported host guarded run to report guarded-entry stage")
        can Memory.Allocate, Abort.Panic, Console:
            # Determinism probe: re-run import relocation twice in this same
            # process and capture the fallback-slot count + a fingerprint of the
            # unresolved symbol-index multiset each time. If the two passes
            # differ here (same process), the nondeterminism is an
            # uninitialized/use-after-free read; if they match but vary across
            # process runs, it is ASLR-dependent.
            dbg_reloc_boot_count <- Linker_FallbackSlotCount().u64()
            dbg_reloc_boot_fp <- Linker_FallbackTableFingerprint()
            ge_raw_breadcrumb("GE:TEST_BEFORE_ARTIFACTS\n", 25usize)
            if status != -96:
                RealGameBoot_EmitArtifacts(linker, status)
                ge_raw_breadcrumb("GE:TEST_AFTER_ARTIFACTS\n", 24usize)
