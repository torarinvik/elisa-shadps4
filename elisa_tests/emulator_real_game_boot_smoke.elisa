        RealGameBoot_EmitArtifactKV(file.ref[mutable IOFile&], "last_guest_rcx", GuestExec_LastGuestRCX().u64())
        RealGameBoot_EmitArtifactKV(file.ref[mutable IOFile&], "last_guest_r8", GuestExec_LastGuestR8().u64())
        RealGameBoot_EmitArtifactKV(file.ref[mutable IOFile&], "last_guest_r9", GuestExec_LastGuestR9().u64())
        RealGameBoot_EmitArtifactKV(file.ref[mutable IOFile&], "last_guest_rax", GuestExec_LastGuestRAX().u64())
