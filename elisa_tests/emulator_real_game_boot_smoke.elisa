            RealGameBoot_WriteLine(file, line2[0], written2)

def RealGameBoot_EmitFrameWalk(file: mutable IOFile&, linker: Linker&, label: static u8&, rbp: VAddr) -> void:
    can Memory.Allocate, Console.Format:
        frame: mutable VAddr = rbp
        index: mutable u64 = 0u64
        while frame != 0.uintptr() and index < 6u64:
            next_frame: VAddr = ge_read_context_word(frame)
            return_addr: VAddr = ge_read_context_word(frame + 8.uintptr())
            ret_prot: u32 = GuestExec_AddressNativeProt(return_addr)
            ret_module: mutable static u8& = ""
            ret_offset: mutable u64 = 0u64
            mi: mutable usize = 0usize
            while mi < linker.modules.count and ret_module == "":
                module: Module = linker.modules[mi]
                start: VAddr = module.base_virtual_addr + module.image_virtual_base.uintptr()
                end: VAddr = start + module.image_virtual_size.uintptr()
                if return_addr >= start and return_addr < end:
                    ret_module <- module.file
                    ret_offset <- return_addr.u64() - module.base_virtual_addr.u64()
                mi <- mi + 1usize
            line: mutable u8[768] = zeroed
            written: int = snprintf(line[0], 768usize, "CUSA07399_ARTIFACT frame_walk label=%s index=%llu rbp=%llu next=%llu return=%llu return_prot=%llu return_module=%s return_offset=%llu ret_equals_expected_argc=%llu ret_equals_entry_argc=%llu", label, index, frame.u64(), next_frame.u64(), return_addr.u64(), ret_prot.u64(), ret_module, ret_offset, 1u64 if return_addr == GuestExec_ExpectedStackWord0() else 0u64, 1u64 if return_addr == GuestExec_EntryStackWord0() else 0u64)
            RealGameBoot_WriteLine(file, line[0], written)
            if return_addr != 0.uintptr():
                RealGameBoot_EmitAddressProbe(file, linker, "frame_walk_return", return_addr)
                RealGameBoot_EmitCallsiteProbe(file, linker, "frame_walk_return", return_addr)
            if next_frame == 0.uintptr() or next_frame <= frame:
                return
            frame <- next_frame
            index <- index + 1u64

def RealGameBoot_EmitRuntimeHleFrameSnapshot(file: mutable IOFile&, linker: Linker&) -> void:
    can Memory.Allocate, Console.Format:
        saved_rbp: VAddr = GuestExec_RuntimeHleGuestFrameWord0()
        saved_return: VAddr = GuestExec_RuntimeHleGuestFrameWord1()
        caller_stack_word: VAddr = GuestExec_RuntimeHleGuestStackWord2()
        caller_next_rbp: VAddr = GuestExec_RuntimeHleCallerFrameWord0()
        caller_return: VAddr = GuestExec_RuntimeHleCallerFrameWord1()
        ret_module: mutable static u8& = ""
        ret_offset: mutable u64 = 0u64
        caller_ret_module: mutable static u8& = ""
        caller_ret_offset: mutable u64 = 0u64
        mi: mutable usize = 0usize
        while mi < linker.modules.count and ret_module == "":
            module: Module = linker.modules[mi]
            start: VAddr = module.base_virtual_addr + module.image_virtual_base.uintptr()
            end: VAddr = start + module.image_virtual_size.uintptr()
            if saved_return >= start and saved_return < end:
                ret_module <- module.file
                ret_offset <- saved_return.u64() - module.base_virtual_addr.u64()
            mi <- mi + 1usize
        mi <- 0usize
        while mi < linker.modules.count and caller_ret_module == "":
            module2: Module = linker.modules[mi]
            start2: VAddr = module2.base_virtual_addr + module2.image_virtual_base.uintptr()
            end2: VAddr = start2 + module2.image_virtual_size.uintptr()
            if caller_return >= start2 and caller_return < end2:
                caller_ret_module <- module2.file
                caller_ret_offset <- caller_return.u64() - module2.base_virtual_addr.u64()
            mi <- mi + 1usize
        line: mutable u8[1024] = zeroed
        written: int = snprintf(line[0], 1024usize, "CUSA07399_ARTIFACT runtime_hle_frame_snapshot rbp=%llu saved_rbp=%llu saved_return=%llu caller_stack_word=%llu saved_return_prot=%llu saved_return_module=%s saved_return_offset=%llu saved_return_equals_expected_argc=%llu saved_return_equals_entry_argc=%llu caller_stack_equals_saved_return=%llu wrapper_return=%llu wrapper_return_module_hit=%llu", GuestExec_RuntimeHleGuestRbp().u64(), saved_rbp.u64(), saved_return.u64(), caller_stack_word.u64(), GuestExec_AddressNativeProt(saved_return).u64(), ret_module, ret_offset, 1u64 if saved_return == GuestExec_ExpectedStackWord0() else 0u64, 1u64 if saved_return == GuestExec_EntryStackWord0() else 0u64, 1u64 if caller_stack_word == saved_return else 0u64, GuestExec_RuntimeHleGuestReturnAddr().u64(), 1u64 if GuestExec_AddressNativeProt(GuestExec_RuntimeHleGuestReturnAddr()) != 0xffffffffu32 else 0u64)
        RealGameBoot_WriteLine(file, line[0], written)
        line2: mutable u8[1024] = zeroed
        written2: int = snprintf(line2[0], 1024usize, "CUSA07399_ARTIFACT runtime_hle_caller_frame_snapshot caller_rbp=%llu caller_next_rbp=%llu caller_return=%llu caller_word2=%llu caller_word3=%llu caller_return_prot=%llu caller_return_module=%s caller_return_offset=%llu caller_return_tiny_unmapped=%llu caller_frame_monotonic=%llu", saved_rbp.u64(), caller_next_rbp.u64(), caller_return.u64(), GuestExec_RuntimeHleCallerFrameWord2().u64(), GuestExec_RuntimeHleCallerFrameWord3().u64(), GuestExec_AddressNativeProt(caller_return).u64(), caller_ret_module, caller_ret_offset, 1u64 if caller_return != 0.uintptr() and caller_return.u64() < 4096u64 and GuestExec_AddressNativeProt(caller_return) == 0xffffffffu32 else 0u64, 1u64 if caller_next_rbp == 0.uintptr() or caller_next_rbp > saved_rbp else 0u64)
        RealGameBoot_WriteLine(file, line2[0], written2)

def RealGameBoot_EmitRuntimeHleRegisterSnapshot(file: mutable IOFile&) -> void:
    can Memory.Allocate, Console.Format:
        line: mutable u8[1024] = zeroed
        written: int = snprintf(line[0], 1024usize, "CUSA07399_ARTIFACT runtime_hle_register_snapshot rdi=%llu rsi=%llu rdx=%llu rcx=%llu r8=%llu r9=%llu ret_arg0_match=%llu ret_arg1_match=%llu ret_arg2_match=%llu", GuestExec_RuntimeHleGuestRdi().u64(), GuestExec_RuntimeHleGuestRsi().u64(), GuestExec_RuntimeHleGuestRdx().u64(), GuestExec_RuntimeHleGuestRcx().u64(), GuestExec_RuntimeHleGuestR8().u64(), GuestExec_RuntimeHleGuestR9().u64(), 1u64 if GuestExec_RuntimeHleGuestRdi() == GuestExec_RuntimeHleArg0() else 0u64, 1u64 if GuestExec_RuntimeHleGuestRsi() == GuestExec_RuntimeHleArg1() else 0u64, 1u64 if GuestExec_RuntimeHleGuestRdx() == GuestExec_RuntimeHleArg2() else 0u64)
        RealGameBoot_WriteLine(file, line[0], written)

def RealGameBoot_Imm32ContextKind(pos: VAddr) -> u64:
    if pos.u64() < 8u64:
        return 0u64
    b_m1: u8 = MemoryManager_ReadU8(Memory_Instance(), pos - 1.uintptr())
    b_m2: u8 = MemoryManager_ReadU8(Memory_Instance(), pos - 2.uintptr())
    b_m3: u8 = MemoryManager_ReadU8(Memory_Instance(), pos - 3.uintptr())
    b_m4: u8 = MemoryManager_ReadU8(Memory_Instance(), pos - 4.uintptr())
    b_p4: u8 = MemoryManager_ReadU8(Memory_Instance(), pos + 4.uintptr())
    if b_m1 >= 0xB8u8 and b_m1 <= 0xBFu8:
        return 1u64 # mov r32, imm32
    if b_m2 == 0xC7u8:
        return 2u64 # mov r/m32, imm32
    if b_m1 == 0x68u8:
        return 3u64 # push imm32
    if b_m1 == 0xE8u8 or b_m1 == 0xE9u8:
        return 4u64 # rel32 control transfer
    if b_m2 == 0x81u8 or b_m2 == 0x69u8:
        return 5u64 # alu/imul imm32
    if b_m3 == 0x8Du8:
        return 6u64 # likely lea disp32
    if b_m3 == 0x89u8 or b_m3 == 0x8Bu8 or b_m3 == 0xC7u8:
        return 7u64 # likely memory displacement
    if b_m4 == 0xC5u8 or b_m4 == 0xC4u8 or b_p4 == 0xC5u8 or b_p4 == 0xC4u8:
        return 8u64 # likely vector instruction displacement/constant
    return 0u64

def RealGameBoot_EmitImmediate32Refs(file: mutable IOFile&, linker: Linker&, label: static u8&, imm: u32) -> void:
    can Memory.Allocate, Console.Format:
        emitted: mutable u64 = 0u64
        total: mutable u64 = 0u64
        kind0: mutable u64 = 0u64
        kind1: mutable u64 = 0u64
        kind2: mutable u64 = 0u64
        kind3: mutable u64 = 0u64
        kind4: mutable u64 = 0u64
        kind5: mutable u64 = 0u64
        kind6: mutable u64 = 0u64
        kind7: mutable u64 = 0u64
        kind8: mutable u64 = 0u64
        mi: mutable usize = 0usize
        while mi < linker.modules.count:
            module: Module = linker.modules[mi]
            start: VAddr = module.first_executable_segment_addr
            size: u64 = module.first_executable_segment_size
            if start != 0.uintptr() and size > 4u64:
                pos: mutable VAddr = start
                end: VAddr = start + size.uintptr() - 4.uintptr()
                trusted Unsafe.AssumeProgress:
                    while pos < end:
                        raw: u32 = RealGameBoot_ReadGuestDisp32At(pos)
                        if raw == imm:
                            ctx: u64 = RealGameBoot_Imm32ContextKind(pos)
                            total <- total + 1u64
                            if ctx == 0u64:
                                kind0 <- kind0 + 1u64
                            elif ctx == 1u64:
                                kind1 <- kind1 + 1u64
                            elif ctx == 2u64:
                                kind2 <- kind2 + 1u64
                            elif ctx == 3u64:
                                kind3 <- kind3 + 1u64
                            elif ctx == 4u64:
                                kind4 <- kind4 + 1u64
                            elif ctx == 5u64:
                                kind5 <- kind5 + 1u64
                            elif ctx == 6u64:
                                kind6 <- kind6 + 1u64
                            elif ctx == 7u64:
                                kind7 <- kind7 + 1u64
                            elif ctx == 8u64:
                                kind8 <- kind8 + 1u64
                            if emitted < 16u64:
                                line: mutable u8[640] = zeroed
                                prev8: mutable u64 = 0u64
                                if pos.u64() >= 8u64:
                                    prev8 <- GuestExec_ReadNativeU64(pos - 8.uintptr()).u64()
                                next8: u64 = GuestExec_ReadNativeU64(pos + 4.uintptr()).u64()
                                written: int = snprintf(line[0], 640usize, "CUSA07399_ARTIFACT imm32_ref label=%s index=%llu module=%s addr=%llu imm=%llu module_offset=%llu context_kind=%llu prev8=%llu next8=%llu", label, emitted, module.file, pos.u64(), imm.u64(), pos.u64() - module.base_virtual_addr.u64(), ctx, prev8, next8)
                                RealGameBoot_WriteLine(file, line[0], written)
                                if pos.u64() >= 16u64:
                                    RealGameBoot_EmitByteWindow(file, "imm32_ref_before16", pos - 16.uintptr())
                                RealGameBoot_EmitByteWindow(file, "imm32_ref_at", pos)
                                emitted <- emitted + 1u64
                        pos <- pos + 1.uintptr()
            mi <- mi + 1usize
        summary: mutable u8[768] = zeroed
        written_summary: int = snprintf(summary[0], 768usize, "CUSA07399_ARTIFACT imm32_ref_summary label=%s imm=%llu total=%llu emitted=%llu kind0=%llu kind1_mov_imm=%llu kind2_mov_mem_imm=%llu kind3_push=%llu kind4_rel=%llu kind5_alu=%llu kind6_lea=%llu kind7_mem=%llu kind8_vector=%llu", label, imm.u64(), total, emitted, kind0, kind1, kind2, kind3, kind4, kind5, kind6, kind7, kind8)
        RealGameBoot_WriteLine(file, summary[0], written_summary)
        if total == 0u64:
            line2: mutable u8[256] = zeroed
            written2: int = snprintf(line2[0], 256usize, "CUSA07399_ARTIFACT imm32_ref label=%s index=none imm=%llu", label, imm.u64())
            RealGameBoot_WriteLine(file, line2[0], written2)

def RealGameBoot_EmitPointerReferences(file: mutable IOFile&, linker: Linker&, label: static u8&, target: VAddr) -> void:
    if target == 0.uintptr():
        return
    can Memory.Allocate, Console.Format:
        emitted: mutable u64 = 0u64
        mi: mutable usize = 0usize
        while mi < linker.modules.count and emitted < 16u64:
            module: Module = linker.modules[mi]
            start: VAddr = module.base_virtual_addr + module.image_virtual_base.uintptr()
            size: u64 = module.image_virtual_size
            if start != 0.uintptr() and size >= 8u64:
                pos: mutable VAddr = start
                end: VAddr = start + size.uintptr() - 8.uintptr()
                trusted Unsafe.AssumeProgress:
                    while pos < end and emitted < 16u64:
                        value: VAddr = MemoryManager_ReadU64(Memory_Instance(), pos)
                        if value == target:
                            line: mutable u8[512] = zeroed
                            written: int = snprintf(line[0], 512usize, "CUSA07399_ARTIFACT pointer_ref label=%s index=%llu module=%s addr=%llu target=%llu", label, emitted, module.file, pos.u64(), target.u64())
                            RealGameBoot_WriteLine(file, line[0], written)
                            RealGameBoot_EmitAddressProbe(file, linker, "pointer_ref_addr", pos)
                            emitted <- emitted + 1u64
                        pos <- pos + 8.uintptr()
            mi <- mi + 1usize
        if emitted == 0u64:
            line2: mutable u8[256] = zeroed
            written2: int = snprintf(line2[0], 256usize, "CUSA07399_ARTIFACT pointer_ref label=%s index=none target=%llu", label, target.u64())
            RealGameBoot_WriteLine(file, line2[0], written2)

def RealGameBoot_EmitUnalignedPointerReferences(file: mutable IOFile&, linker: Linker&, label: static u8&, target: VAddr) -> void:
    if target == 0.uintptr():
        return
    can Memory.Allocate, Console.Format:
        emitted: mutable u64 = 0u64
        total: mutable u64 = 0u64
        mi: mutable usize = 0usize
        while mi < linker.modules.count:
            module: Module = linker.modules[mi]
            start: VAddr = module.base_virtual_addr + module.image_virtual_base.uintptr()
            size: u64 = module.image_virtual_size
            if start != 0.uintptr() and size >= 8u64:
                pos: mutable VAddr = start
                end: VAddr = start + size.uintptr() - 8.uintptr()
                trusted Unsafe.AssumeProgress:
                    while pos < end:
                        value: VAddr = MemoryManager_ReadU64(Memory_Instance(), pos)
                        if value == target:
                            total <- total + 1u64
                            if emitted < 16u64:
                                line: mutable u8[640] = zeroed
                                written: int = snprintf(line[0], 640usize, "CUSA07399_ARTIFACT unaligned_pointer_ref label=%s index=%llu module=%s addr=%llu target=%llu module_offset=%llu alignment=%llu", label, emitted, module.file, pos.u64(), target.u64(), pos.u64() - module.base_virtual_addr.u64(), pos.u64() & 7u64)
                                RealGameBoot_WriteLine(file, line[0], written)
                                if pos.u64() >= 16u64:
                                    RealGameBoot_EmitByteWindow(file, "unaligned_pointer_ref_before16", pos - 16.uintptr())
                                RealGameBoot_EmitByteWindow(file, "unaligned_pointer_ref_at", pos)
                                emitted <- emitted + 1u64
                        pos <- pos + 1.uintptr()
            mi <- mi + 1usize
        summary: mutable u8[384] = zeroed
        written_summary: int = snprintf(summary[0], 384usize, "CUSA07399_ARTIFACT unaligned_pointer_ref_summary label=%s target=%llu total=%llu emitted=%llu", label, target.u64(), total, emitted)
        RealGameBoot_WriteLine(file, summary[0], written_summary)

def RealGameBoot_EmitRipRelativeRefs(file: mutable IOFile&, linker: Linker&, label: static u8&, target: VAddr) -> void:
    if target == 0.uintptr():
        return
    can Memory.Allocate, Console.Format:
        emitted: mutable u64 = 0u64
        total: mutable u64 = 0u64
        mi: mutable usize = 0usize
        while mi < linker.modules.count:
            module: Module = linker.modules[mi]
            start: VAddr = module.first_executable_segment_addr
            size: u64 = module.first_executable_segment_size
            if start != 0.uintptr() and size > 4u64:
                pos: mutable VAddr = start
                end: VAddr = start + size.uintptr() - 4.uintptr()
                trusted Unsafe.AssumeProgress:
                    while pos < end:
                        raw: u32 = RealGameBoot_ReadGuestDisp32At(pos)
                        candidate: VAddr = RealGameBoot_GuestRipRelativeSlot(pos + 4.uintptr(), raw)
                        if candidate == target:
                            total <- total + 1u64
                            if emitted < 24u64:
                                line: mutable u8[768] = zeroed
                                prev8: mutable u64 = 0u64
                                if pos.u64() >= 8u64:
                                    prev8 <- GuestExec_ReadNativeU64(pos - 8.uintptr()).u64()
                                written: int = snprintf(line[0], 768usize, "CUSA07399_ARTIFACT riprel_ref label=%s index=%llu module=%s disp_addr=%llu next_ip=%llu target=%llu module_offset=%llu prev8=%llu next8=%llu", label, emitted, module.file, pos.u64(), (pos + 4.uintptr()).u64(), target.u64(), pos.u64() - module.base_virtual_addr.u64(), prev8, GuestExec_ReadNativeU64(pos + 4.uintptr()).u64())
                                RealGameBoot_WriteLine(file, line[0], written)
                                if pos.u64() >= 16u64:
                                    RealGameBoot_EmitByteWindow(file, "riprel_ref_before16", pos - 16.uintptr())
                                RealGameBoot_EmitByteWindow(file, "riprel_ref_at", pos)
                                emitted <- emitted + 1u64
                        pos <- pos + 1.uintptr()
            mi <- mi + 1usize
        summary: mutable u8[384] = zeroed
        written_summary: int = snprintf(summary[0], 384usize, "CUSA07399_ARTIFACT riprel_ref_summary label=%s target=%llu total=%llu emitted=%llu", label, target.u64(), total, emitted)
        RealGameBoot_WriteLine(file, summary[0], written_summary)

def RealGameBoot_EmitRelocationProbe(file: mutable IOFile&, linker: Linker&, label: static u8&, target: VAddr) -> void:
    if target == 0.uintptr():
        return
    can Memory.Allocate, Console.Format:
        emitted: mutable u64 = 0u64
        mi: mutable usize = 0usize
        while mi < linker.modules.count and emitted < 16u64:
            module: Module = linker.modules[mi]
            entry_size: u64 = Module_GetRelaEntrySize(module)
            if entry_size == 0u64:
                mi <- mi + 1usize
                continue
            table_pass: mutable u64 = 0u64
            while table_pass < 2u64 and emitted < 16u64:
                table_offset: u64 = module.dynamic_info.rela_table_offset if table_pass == 0u64 else module.dynamic_info.jmp_relocation_offset
                table_size: u64 = module.dynamic_info.rela_table_total_size if table_pass == 0u64 else module.dynamic_info.jmp_relocation_total_size
                if table_offset != 0u64 and table_size >= entry_size:
                    count: usize = (table_size / entry_size).usize()
                    i: mutable usize = 0usize
                    while i < count and emitted < 16u64:
                        offset: u64 = table_offset + i.u64() * entry_size
                        if offset + size_of(elf_relocation).u64() <= module.dynamic_data.count.u64():
                            rel: elf_relocation = Module_ReadRelocationAt(module, offset.usize())
                            rel_addr: VAddr = module.base_virtual_addr + rel.rel_offset.uintptr()
                            if rel_addr == target:
                                rel_type: u32 = (rel.rel_info & 0xffffffff.u64()).u32()
                                symbol_index: u32 = (rel.rel_info >> 32.u64()).u32()
                                symbol_name: static u8& = Module_GetSymbolNameByIndex((&module).cast[mutable Module&], symbol_index)
                                line: mutable u8[768] = zeroed
                                written: int = snprintf(line[0], 768usize, "CUSA07399_ARTIFACT relocation_probe label=%s index=%llu module=%s table=%llu rel_index=%llu addr=%llu type=%llu symbol_index=%llu symbol=%s addend=%lld word=%llu", label, emitted, module.file, table_pass, i.u64(), rel_addr.u64(), rel_type.u64(), symbol_index.u64(), symbol_name, rel.rel_addend, GuestExec_ReadNativeU64(rel_addr).u64())
                                RealGameBoot_WriteLine(file, line[0], written)
                                emitted <- emitted + 1u64
                        i <- i + 1usize
                table_pass <- table_pass + 1u64
            mi <- mi + 1usize
        if emitted == 0u64:
            line2: mutable u8[256] = zeroed
            written2: int = snprintf(line2[0], 256usize, "CUSA07399_ARTIFACT relocation_probe label=%s index=none target=%llu", label, target.u64())
            RealGameBoot_WriteLine(file, line2[0], written2)

def RealGameBoot_EmitThunkProbe(file: mutable IOFile&, linker: Linker&, label: static u8&, addr: VAddr) -> void:
    can Memory.Allocate, Console.Format:
        thunk_base: u64 = Linker_FindNativeHleBoundaryThunkBase(addr.u64())
        thunk_target: u64 = Linker_FindNativeHleBoundaryThunkTarget(addr.u64())
        thunk_offset: mutable u64 = 0u64
        target_name: mutable static u8& = ""
        target_nid: mutable static u8& = ""
        target_module: mutable static u8& = ""
        target_library: mutable static u8& = ""
        target_hit: mutable u64 = 0u64
        if thunk_base != 0u64 and addr.u64() >= thunk_base:
            thunk_offset <- addr.u64() - thunk_base
        i: mutable usize = 0
        while i < linker.hle_symbols.symbols.count and target_hit == 0u64:
            sym: SymbolRecord = linker.hle_symbols.symbols[i]
            if sym.callable_address == thunk_target:
                target_hit <- 1u64
                target_name <- sym.name
                target_nid <- sym.nid_name
                target_module <- sym.module
                target_library <- sym.library
            i <- i + 1
        line: mutable u8[768] = zeroed
        written: int = snprintf(line[0], 768usize, "CUSA07399_ARTIFACT thunk_probe label=%s addr=%llu thunk_base=%llu thunk_offset=%llu thunk_target=%llu target_hit=%llu target_module=%s target_library=%s target_nid=%s target_name=%s", label, addr.u64(), thunk_base, thunk_offset, thunk_target, target_hit, target_module, target_library, target_nid, target_name)
        RealGameBoot_WriteLine(file, line[0], written)

def RealGameBoot_EmitHandoffManifest(linker: Linker&) -> void:
    can Memory.Allocate, Console.Format:
        file: mutable IOFile = IOFile(REAL_GAME_BOOT_HANDOFF_MANIFEST_PATH, FileAccessMode.Create, FileType.TextFile)
        if linker.modules.count == 0:
            file.Close()
            return
        main: Module = linker.modules[0]
        handoff_entry: VAddr = guest_exec_last_main_entry_addr
        entry_word0: u64 = MemoryManager_ReadU64(Memory_Instance(), handoff_entry)
        entry_word1: u64 = MemoryManager_ReadU64(Memory_Instance(), handoff_entry + 8.uintptr())
        entry_offset: mutable u64 = 0
        entry_in_exec_segment: mutable u64 = 0
        if handoff_entry >= main.base_virtual_addr:
            entry_offset <- handoff_entry.u64() - main.base_virtual_addr.u64()
        if main.first_executable_segment_addr != 0.uintptr() and handoff_entry >= main.first_executable_segment_addr and handoff_entry < (main.first_executable_segment_addr + main.first_executable_segment_size.uintptr()):
            entry_in_exec_segment <- 1
        line: mutable u8[512] = zeroed
        written: int = snprintf(line[0], 512usize, "CUSA07399_HANDOFF_MANIFEST version=1 module_count=%llu entry=0x%llx init_entry=0x%llx main_entry=0x%llx base=0x%llx entry_offset=0x%llx image_base=0x%llx image_size=0x%llx aligned_base_size=0x%llx entry_word0=0x%llx entry_word1=0x%llx executable_segments=%llu first_exec=0x%llx first_exec_size=0x%llx entry_in_exec=%llu mapped_segments=%llu imports=%llu resolved_imports=%llu patched_import_relocations=%llu", linker.modules.count.u64(), handoff_entry.u64(), main.last_start_entry_addr.u64(), guest_exec_last_main_entry_addr.u64(), main.base_virtual_addr.u64(), entry_offset, main.image_virtual_base, main.image_virtual_size, main.aligned_base_size, entry_word0, entry_word1, main.executable_segment_count.u64(), main.first_executable_segment_addr.u64(), main.first_executable_segment_size, entry_in_exec_segment, main.mapped_segment_count.u64(), Module_GetImportSymbolCount(main).u64(), Module_GetResolvedImportSymbolCount(main).u64(), main.patched_import_relocation_count.u64())
        RealGameBoot_WriteLine(file, line[0], written)
        i: mutable usize = 0
        limit: mutable usize = linker.modules.count
        if limit > 8:
            limit <- 8
        while i < limit:
            mod_ref: Module = linker.modules[i]
            module_line: mutable u8[512] = zeroed
            written_mod: int = snprintf(module_line[0], 512usize, "CUSA07399_HANDOFF_MODULE index=%llu file=%s host=%s shared=%d base=0x%llx entry=0x%llx image_base=0x%llx image_size=0x%llx executable_segments=%llu mapped_segments=%llu imports=%llu resolved_imports=%llu", i.u64(), mod_ref.file, mod_ref.host_file, 1 if mod_ref.is_shared_lib else 0, mod_ref.base_virtual_addr.u64(), mod_ref.last_start_entry_addr.u64(), mod_ref.image_virtual_base, mod_ref.image_virtual_size, mod_ref.executable_segment_count.u64(), mod_ref.mapped_segment_count.u64(), Module_GetImportSymbolCount(mod_ref).u64(), Module_GetResolvedImportSymbolCount(mod_ref).u64())
            RealGameBoot_WriteLine(file, module_line[0], written_mod)
            i <- i + 1
        _ = file.Flush()
        file.Close()

def RealGameBoot_ResetRuntime() -> void:
    Emulator_Reset()
    Linker_Reset()
    EmulatorState_ResetInstance()
    settings: mutable EmulatorSettingsImpl& = EmulatorSettings_GetInstance()
    EmulatorSettings_SetDefaultValues(settings)
    UserSettings_Reset()

def RealGameBoot_CheckMappedImageMirror(module: Module&) -> bool:
    if module.image.count == 0:
        return false
    max_scan: mutable usize = module.image.count
    if max_scan > 4096:
        max_scan <- 4096
    i: mutable usize = 0
    found: mutable bool = false
    while i < max_scan and not found:
        guest_byte: u8 = MemoryManager_ReadU8(Memory_Instance(), module.base_virtual_addr + module.image_virtual_base.uintptr() + i.uintptr())
        if guest_byte == module.image[i]:
            found <- true
        i <- i + 1
    return found

def RealGameBoot_EmitArtifacts(linker: Linker&, guarded_status: s32) -> void:
    can Memory.Allocate, Console.Format:
        file: mutable IOFile = IOFile(REAL_GAME_BOOT_ARTIFACT_PATH, FileAccessMode.Create, FileType.TextFile)
        RealGameBoot_EmitArtifactKV(file, "module_count", linker.modules.count.u64())
        RealGameBoot_EmitArtifactKV(file, "total_imports", linker.last_total_import_count.u64())
        RealGameBoot_EmitArtifactKV(file, "unresolved_imports", linker.last_unresolved_import_count.u64())
        RealGameBoot_EmitArtifactKV(file, "relocated_imports", linker.last_relocated_import_count.u64())
        RealGameBoot_EmitArtifactKV(file, "native_hle", linker.last_native_hle_resolved_count.u64())
        RealGameBoot_EmitArtifactKV(file, "prx_export", linker.last_prx_export_resolved_count.u64())
        RealGameBoot_EmitArtifactKV(file, "aerolib_fallback", linker.last_aerolib_fallback_resolved_count.u64())
        RealGameBoot_EmitArtifactKV(file, "hle_symbols", linker.hle_registered_symbol_count.u64())
        RealGameBoot_EmitArtifactKV(file, "entry", linker.modules[0].last_start_entry_addr.u64())
        RealGameBoot_EmitArtifactKV(file, "main_entry", guest_exec_last_main_entry_addr.u64())
        proc_param_addr: VAddr = Linker_GetProcParam(linker)
        RealGameBoot_EmitArtifactKV(file, "proc_param_addr", proc_param_addr.u64())
        RealGameBoot_EmitArtifactKV(file, "proc_param_size", MemoryManager_ReadU64(Memory_Instance(), proc_param_addr))
        RealGameBoot_EmitArtifactKV(file, "proc_param_sdk_version", MemoryManager_ReadU64(Memory_Instance(), proc_param_addr + 16.uintptr()))
        libc_param_addr: u64 = MemoryManager_ReadU64(Memory_Instance(), proc_param_addr + 56.uintptr())
        RealGameBoot_EmitArtifactKV(file, "proc_param_libc_param", libc_param_addr)
        if libc_param_addr != 0u64:
            word_i: mutable u64 = 0u64
            while word_i < 16u64:
                RealGameBoot_EmitArtifactKV(file, "libc_param_word", MemoryManager_ReadU64(Memory_Instance(), libc_param_addr.uintptr() + (word_i * 8u64).uintptr()))
                word_i <- word_i + 1u64
        proc_param_mem_param: u64 = MemoryManager_ReadU64(Memory_Instance(), proc_param_addr + 64.uintptr())
        RealGameBoot_EmitArtifactKV(file, "proc_param_mem_param", proc_param_mem_param)
        if proc_param_mem_param != 0u64:
            RealGameBoot_EmitArtifactKV(file, "proc_param_mem_param_size", MemoryManager_ReadU64(Memory_Instance(), proc_param_mem_param.uintptr()))
            flexible_memory_ptr: u64 = MemoryManager_ReadU64(Memory_Instance(), proc_param_mem_param.uintptr() + 16.uintptr())
            RealGameBoot_EmitArtifactKV(file, "proc_param_flexible_memory_ptr", flexible_memory_ptr)
            if flexible_memory_ptr != 0u64:
                RealGameBoot_EmitArtifactKV(file, "proc_param_flexible_memory_size", MemoryManager_ReadU64(Memory_Instance(), flexible_memory_ptr.uintptr()))
        RealGameBoot_EmitArtifactKV(file, "linker_flexible_memory_size", Linker_GetFlexibleMemorySize(linker))
        RealGameBoot_EmitArtifactAddrWords(file, "init_entry", linker.modules[0].last_start_entry_addr)
        RealGameBoot_EmitArtifactAddrWords(file, "main_entry", guest_exec_last_main_entry_addr)
        RealGameBoot_EmitArtifactSignedKV(file, "guarded_status", guarded_status)
        RealGameBoot_EmitArtifactSignedKV(file, "last_signal", GuestExec_LastSignal())
        RealGameBoot_EmitArtifactSignedKV(file, "guest_exec_last_errno", GuestExec_LastErrno())
        RealGameBoot_EmitArtifactSignedKV(file, "guest_exec_native_phase", GuestExec_LastNativePhase())
        RealGameBoot_EmitArtifactKV(file, "fault", GuestExec_LastFaultAddress().u64())
        RealGameBoot_EmitArtifactKV(file, "last_guest_pc", GuestExec_LastGuestPC().u64())
        RealGameBoot_EmitArtifactKV(file, "last_guest_sp", GuestExec_LastGuestSP().u64())
        RealGameBoot_EmitArtifactKV(file, "last_guest_bp", GuestExec_LastGuestBP().u64())
        RealGameBoot_EmitArtifactKV(file, "last_guest_rdi", GuestExec_LastGuestRDI().u64())
        RealGameBoot_EmitArtifactKV(file, "last_guest_rsi", GuestExec_LastGuestRSI().u64())
        RealGameBoot_EmitArtifactKV(file, "last_guest_rdx", GuestExec_LastGuestRDX().u64())
        RealGameBoot_EmitArtifactKV(file, "last_guest_rcx", GuestExec_LastGuestRCX().u64())
        RealGameBoot_EmitArtifactKV(file, "last_guest_r8", GuestExec_LastGuestR8().u64())
        RealGameBoot_EmitArtifactKV(file, "last_guest_r9", GuestExec_LastGuestR9().u64())
        RealGameBoot_EmitArtifactKV(file, "last_guest_rax", GuestExec_LastGuestRAX().u64())
        RealGameBoot_EmitArtifactKV(file, "last_guest_rbx", GuestExec_LastGuestRBX().u64())
        RealGameBoot_EmitArtifactSignedKV(file, "execution_stage", GuestExec_ExecutionStage())
        RealGameBoot_EmitArtifactSignedKV(file, "boundary_status", GuestExec_ClassifyFirstBoundary())
        RealGameBoot_EmitArtifactSignedKV(file, "boundary_reason", GuestExec_FirstBoundaryReason())
        RealGameBoot_EmitArtifactKV(file, "guest_exec_started", 1 if guest_exec_run_count > 0usize else 0)
        RealGameBoot_EmitArtifactSignedKV(file, "guest_exec_last_argc", guest_exec_last_argc.s32())
        RealGameBoot_EmitArtifactKV(file, "guest_exec_entry_reached", 1 if guest_exec_last_entry_addr != 0.uintptr() else 0)
        RealGameBoot_EmitArtifactKV(file, "guest_exec_first_boundary_reached", 1 if GuestExec_HasReachedFirstBoundary() else 0)
        RealGameBoot_EmitArtifactKV(file, "guest_exec_boundary_reason", GuestExec_FirstBoundaryReason().i64().u64())
        RealGameBoot_EmitArtifactStringKV(file, "guest_exec_boundary_reason_name", GuestExec_FirstBoundaryReasonName())
        RealGameBoot_EmitArtifactStringKV(file, "guest_exec_host_arch", GuestExec_HostArchitecture())
        RealGameBoot_EmitArtifactStringKV(file, "guest_exec_host_mode", GuestExec_HostMode())
        RealGameBoot_EmitArtifactKV(file, "guest_exec_supported_native_execution", 1 if GuestExec_SupportedNativeExecution() else 0)
        RealGameBoot_EmitArtifactKV(file, "guest_exec_x64_subprocess_available", 1 if GuestExec_HostCanRunX64Subprocess() else 0)
        RealGameBoot_EmitArtifactKV(file, "guest_exec_probe_only", 1 if GuestExec_IsProbeOnly() else 0)
        RealGameBoot_EmitArtifactKV(file, "guest_exec_last_pc", GuestExec_LastGuestPC().u64())
        RealGameBoot_EmitArtifactKV(file, "guest_exec_last_sp", GuestExec_LastGuestSP().u64())
