        RealGameBoot_EmitArtifactKV(file.ref[mutable IOFile&], "guest_exec_last_pc_was_fallback", 1 if GuestExec_LastPCWasFallback() else 0)
        RealGameBoot_EmitArtifactKV(file.ref[mutable IOFile&], "guest_exec_signal_pc", GuestExec_SignalGuestPC().u64())
        RealGameBoot_EmitArtifactKV(file.ref[mutable IOFile&], "guest_exec_signal_pc_valid", 1 if GuestExec_SignalPCValid() else 0)
        RealGameBoot_EmitArtifactKV(file.ref[mutable IOFile&], "guest_exec_signal_sp_valid", 1 if GuestExec_SignalSPValid() else 0)
        RealGameBoot_EmitArtifactKV(file.ref[mutable IOFile&], "guest_exec_signal_bp_valid", 1 if GuestExec_SignalBPValid() else 0)
        RealGameBoot_EmitArtifactKV(file.ref[mutable IOFile&], "guest_exec_signal_rdi_valid", 1 if GuestExec_SignalRDIValid() else 0)
        RealGameBoot_EmitArtifactKV(file.ref[mutable IOFile&], "guest_exec_signal_rsi_valid", 1 if GuestExec_SignalRSIValid() else 0)
        RealGameBoot_EmitArtifactKV(file.ref[mutable IOFile&], "guest_exec_signal_uctx", GuestExec_SignalUContext().u64())
        RealGameBoot_EmitArtifactKV(file.ref[mutable IOFile&], "guest_exec_signal_mctx", GuestExec_SignalMContext().u64())
        RealGameBoot_EmitArtifactKV(file.ref[mutable IOFile&], "guest_exec_signal_fault_addr_valid", 1 if GuestExec_SignalFaultAddressValid() else 0)
        RealGameBoot_EmitArtifactSignedKV(file.ref[mutable IOFile&], "guest_exec_signal_native_region_index", GuestExec_SignalNativeRegionIndex())
        RealGameBoot_EmitArtifactKV(file.ref[mutable IOFile&], "guest_exec_fallback_pc", GuestExec_FallbackGuestPC().u64())
        RealGameBoot_EmitArtifactSignedKV(file.ref[mutable IOFile&], "guest_exec_last_pc_source", GuestExec_LastPCSource())
        RealGameBoot_EmitArtifactKV(file.ref[mutable IOFile&], "guest_exec_fault_word0", GuestExec_FaultWord0().u64())
        RealGameBoot_EmitArtifactKV(file.ref[mutable IOFile&], "guest_exec_fault_word1", GuestExec_FaultWord1().u64())
        RealGameBoot_EmitArtifactKV(file.ref[mutable IOFile&], "guest_exec_signal_stack_word0", GuestExec_SignalStackWord0().u64())
        RealGameBoot_EmitArtifactKV(file.ref[mutable IOFile&], "guest_exec_signal_stack_word1", GuestExec_SignalStackWord1().u64())
        RealGameBoot_EmitArtifactStringKV(file.ref[mutable IOFile&], "guest_exec_signal_stack_symbol0", GuestExec_SignalStackSymbol0())
        RealGameBoot_EmitArtifactStringKV(file.ref[mutable IOFile&], "guest_exec_signal_stack_image0", GuestExec_SignalStackImage0())
        RealGameBoot_EmitArtifactStringKV(file.ref[mutable IOFile&], "guest_exec_signal_pc_symbol", GuestExec_SignalPCSymbol())
        RealGameBoot_EmitArtifactStringKV(file.ref[mutable IOFile&], "guest_exec_signal_pc_image", GuestExec_SignalPCImage())
        RealGameBoot_EmitArtifactKV(file.ref[mutable IOFile&], "guest_exec_fault_address", GuestExec_LastFaultAddress().u64())
        RealGameBoot_EmitArtifactKV(file.ref[mutable IOFile&], "guest_exec_last_signal", GuestExec_LastSignal().i64().u64())
        RealGameBoot_EmitArtifactStringKV(file.ref[mutable IOFile&], "threads_sync_last_mutex_op", threads_sync_last_mutex_op)
        RealGameBoot_EmitArtifactKV(file.ref[mutable IOFile&], "threads_sync_last_mutex_slot", threads_sync_last_mutex_slot)
        RealGameBoot_EmitArtifactKV(file.ref[mutable IOFile&], "threads_sync_last_mutex_value", threads_sync_last_mutex_value)
        RealGameBoot_EmitArtifactSignedKV(file.ref[mutable IOFile&], "threads_sync_last_mutex_ret", threads_sync_last_mutex_ret)
        RealGameBoot_EmitArtifactStringKV(file.ref[mutable IOFile&], "guest_exec_runtime_hle_module", GuestExec_RuntimeHleModule())
        RealGameBoot_EmitArtifactStringKV(file.ref[mutable IOFile&], "guest_exec_runtime_hle_symbol", GuestExec_RuntimeHleSymbol())
        RealGameBoot_EmitArtifactKV(file.ref[mutable IOFile&], "guest_exec_runtime_hle_arg0", GuestExec_RuntimeHleArg0().u64())
        RealGameBoot_EmitArtifactKV(file.ref[mutable IOFile&], "guest_exec_runtime_hle_arg1", GuestExec_RuntimeHleArg1().u64())
        RealGameBoot_EmitArtifactKV(file.ref[mutable IOFile&], "guest_exec_runtime_hle_arg2", GuestExec_RuntimeHleArg2().u64())
        RealGameBoot_EmitArtifactKV(file.ref[mutable IOFile&], "guest_exec_runtime_hle_ret", GuestExec_RuntimeHleRet().u64())
        RealGameBoot_EmitArtifactStringKV(file.ref[mutable IOFile&], "guest_exec_last_module", GuestExec_LastModule())
        RealGameBoot_EmitArtifactStringKV(file.ref[mutable IOFile&], "guest_exec_last_symbol", GuestExec_LastSymbol())
        RealGameBoot_EmitArtifactKV(file.ref[mutable IOFile&], "malformed_imports", linker.last_malformed_import_count.u64())
        RealGameBoot_EmitArtifactKV(file.ref[mutable IOFile&], "failed_relocations", linker.last_failed_relocation_count.u64())
        RealGameBoot_EmitArtifactKV(file.ref[mutable IOFile&], "last_failed_relocation_type", linker.last_failed_relocation_type.u64())
        RealGameBoot_EmitArtifactKV(file.ref[mutable IOFile&], "last_failed_relocation_symbol", linker.last_failed_relocation_symbol.u64())
        RealGameBoot_EmitArtifactKV(file.ref[mutable IOFile&], "last_failed_relocation_offset", linker.last_failed_relocation_offset)
        RealGameBoot_EmitArtifactStringKV(file.ref[mutable IOFile&], "last_failed_relocation_module", linker.last_failed_relocation_module)
        RealGameBoot_EmitArtifactStringKV(file.ref[mutable IOFile&], "last_failed_relocation_name", linker.last_failed_relocation_name)
        RealGameBoot_EmitArtifactKV(file.ref[mutable IOFile&], "aerolib_fallback_stub_address", GuestExec_AeroLibFallbackStubAddress().u64())
        RealGameBoot_EmitArtifactKV(file.ref[mutable IOFile&], "aerolib_fallback_invocations", GuestExec_AeroLibFallbackInvocations())
        RealGameBoot_EmitArtifactKV(file.ref[mutable IOFile&], "aerolib_fallback_caller_pc", GuestExec_AeroLibFallbackCallerPc())
        RealGameBoot_EmitArtifactKV(file.ref[mutable IOFile&], "aerolib_fallback_slot_va", GuestExec_AeroLibFallbackSlotVa())
        RealGameBoot_EmitArtifactKV(file.ref[mutable IOFile&], "aerolib_fallback_callsite_bytes", GuestExec_AeroLibFallbackCallsiteBytes())
        RealGameBoot_EmitArtifactKV(file.ref[mutable IOFile&], "aerolib_fallback_plt_va", GuestExec_AeroLibFallbackPltVa())
        RealGameBoot_EmitArtifactKV(file.ref[mutable IOFile&], "aerolib_fallback_plt_bytes", GuestExec_AeroLibFallbackPltBytes())
        hit_slot: u64 = GuestExec_AeroLibFallbackSlotVa()
        RealGameBoot_EmitArtifactSignedKV(file.ref[mutable IOFile&], "aerolib_fallback_slot_index", Linker_FindFallbackSlotIndexBySlot(hit_slot))
        RealGameBoot_EmitArtifactStringKV(file.ref[mutable IOFile&], "aerolib_fallback_module", Linker_FindFallbackModuleBySlot(hit_slot))
        RealGameBoot_EmitArtifactStringKV(file.ref[mutable IOFile&], "aerolib_fallback_symbol", Linker_FindFallbackSymbolBySlot(hit_slot))
        RealGameBoot_EmitArtifactKV(file.ref[mutable IOFile&], "aerolib_fallback_symbol_index", Linker_FindFallbackSymbolIndexBySlot(hit_slot).u64())
        RealGameBoot_EmitArtifactKV(file.ref[mutable IOFile&], "aerolib_fallback_rel_type", Linker_FindFallbackRelTypeBySlot(hit_slot).u64())
        RealGameBoot_EmitArtifactKV(file.ref[mutable IOFile&], "aerolib_fallback_slot_table_count", Linker_FallbackSlotCount().u64())
        RealGameBoot_EmitArtifactKV(file.ref[mutable IOFile&], "dbg_hle_symbols_checksum", Linker_HleSymbolsStringChecksum(linker))
        RealGameBoot_EmitArtifactKV(file.ref[mutable IOFile&], "dbg_reloc_boot_count", dbg_reloc_boot_count)
        RealGameBoot_EmitArtifactKV(file.ref[mutable IOFile&], "dbg_reloc_boot_fp", dbg_reloc_boot_fp)
        RealGameBoot_EmitArtifactKV(file.ref[mutable IOFile&], "dbg_seq_fp", Linker_SeqFingerprintValue())
        RealGameBoot_EmitArtifactKV(file.ref[mutable IOFile&], "dbg_name_fp", Linker_NameFingerprintValue())
        RealGameBoot_EmitArtifactKV(file.ref[mutable IOFile&], "dbg_resolution_fp", Linker_ResolutionFingerprintValue())
        RealGameBoot_EmitArtifactKV(file.ref[mutable IOFile&], "dbg_resolution_relocs", Linker_ResolutionRelocCount())
        RealGameBoot_EmitArtifactKV(file.ref[mutable IOFile&], "dbg_hle_zero_addr_count", Linker_HleZeroAddrCount(linker))
        RealGameBoot_EmitArtifactStringKV(file.ref[mutable IOFile&], "dbg_first_name", Linker_DbgFirstName())
        RealGameBoot_EmitArtifactKV(file.ref[mutable IOFile&], "dbg_first_index", Linker_DbgFirstIndex().u64())
        RealGameBoot_EmitArtifactKV(file.ref[mutable IOFile&], "dbg_name_setfp", Linker_NameSetFingerprint())
        RealGameBoot_EmitArtifactKV(file.ref[mutable IOFile&], "dbg_name_count", Linker_NameCount())
        dbg_m: mutable usize = 0
        while dbg_m < linker.modules.count:
            RealGameBoot_EmitArtifactKV(file.ref[mutable IOFile&], "dbg_mod_strtab_off", linker.modules[dbg_m].dynamic_info.str_table_offset)
            RealGameBoot_EmitArtifactKV(file.ref[mutable IOFile&], "dbg_mod_strtab_size", linker.modules[dbg_m].dynamic_info.str_table_size)
            dbg_m <- dbg_m + 1
        if linker.modules.count > 0:
            RealGameBoot_EmitArtifactKV(file.ref[mutable IOFile&], "dbg_mod0_symtab_off", linker.modules[0].dynamic_info.symbol_table_offset)
            RealGameBoot_EmitArtifactKV(file.ref[mutable IOFile&], "dbg_mod0_strtab_off", linker.modules[0].dynamic_info.str_table_offset)
            RealGameBoot_EmitArtifactKV(file.ref[mutable IOFile&], "dbg_mod0_syment_size", linker.modules[0].dynamic_info.symbol_table_entries_size)
        RealGameBoot_EmitArtifactKV(file.ref[mutable IOFile&], "dbg_reloc_pass_a_count", dbg_reloc_pass_a_count)
        RealGameBoot_EmitArtifactKV(file.ref[mutable IOFile&], "dbg_reloc_pass_b_count", dbg_reloc_pass_b_count)
        RealGameBoot_EmitArtifactKV(file.ref[mutable IOFile&], "dbg_reloc_pass_a_fp", dbg_reloc_pass_a_fp)
        RealGameBoot_EmitArtifactKV(file.ref[mutable IOFile&], "dbg_reloc_pass_b_fp", dbg_reloc_pass_b_fp)
        dbg_mod: mutable usize = 0
        while dbg_mod < linker.modules.count:
            RealGameBoot_EmitArtifactKV(file.ref[mutable IOFile&], "dbg_mod_dyndata_checksum", Module_DynamicDataChecksum(linker.modules[dbg_mod].ref[Module&]))
            dbg_mod <- dbg_mod + 1
        RealGameBoot_EmitFallbackSlotTable(file.ref[mutable IOFile&])
        RealGameBoot_EmitUserServiceArtifacts(file.ref[mutable IOFile&])
        i: mutable usize = 0
        limit: mutable usize = linker.modules.count
        if limit > 8:
            limit <- 8
        while i < limit:
            native_count: mutable u64 = 0
            prx_count: mutable u64 = 0
            fallback_count: mutable u64 = 0
            malformed_count: mutable u64 = 0
            unresolved_count: mutable u64 = 0
            for j in 0..<linker.modules[i].import_symbols.count:
                rec: ImportSymbolRecord = linker.modules[i].import_symbols[j]
                if rec.resolution_kind == IMPORT_RESOLUTION_NATIVE_HLE:
                    native_count <- native_count + 1
                elif rec.resolution_kind == IMPORT_RESOLUTION_PRX_EXPORT:
                    prx_count <- prx_count + 1
                elif rec.resolution_kind == IMPORT_RESOLUTION_AEROLIB_FALLBACK:
                    fallback_count <- fallback_count + 1
                elif rec.resolution_kind == IMPORT_RESOLUTION_MALFORMED:
                    malformed_count <- malformed_count + 1
                elif not rec.resolved:
                    unresolved_count <- unresolved_count + 1
            RealGameBoot_EmitArtifactModule(file.ref[mutable IOFile&], linker.modules[i].file, linker.modules[i].host_file, 1 if linker.modules[i].is_shared_lib else 0, linker.modules[i].applied_relocation_count.u64(), Module_GetImportSymbolCount(linker.modules[i]).u64(), Module_GetResolvedImportSymbolCount(linker.modules[i]).u64(), native_count, prx_count, fallback_count, malformed_count, unresolved_count)
            RealGameBoot_EmitArtifactKV(file.ref[mutable IOFile&], "module_exec_segments", linker.modules[i].executable_segment_count.u64())
            RealGameBoot_EmitArtifactKV(file.ref[mutable IOFile&], "module_exec_mismatch", linker.modules[i].executable_segment_permission_mismatch_count.u64())
            RealGameBoot_EmitArtifactKV(file.ref[mutable IOFile&], "module_patched_import_relocations", linker.modules[i].patched_import_relocation_count.u64())
            i <- i + 1
        for mi in 0..<linker.modules.count:
            mod_ref: Module = linker.modules[mi]
            for ii in 0..<mod_ref.import_symbols.count:
                rec: ImportSymbolRecord = mod_ref.import_symbols[ii]
                if rec.resolution_kind != IMPORT_RESOLUTION_AEROLIB_FALLBACK:
                    continue
                subsystem: mutable static u8& = "kernel"
                if static_strlen(rec.library) > 0:
                    if Linker_StringHasPrefix(rec.library, "libScePad"):
                        subsystem <- "audio_input_service"
                    elif Linker_StringHasPrefix(rec.library, "libSceGnm") or Linker_StringHasPrefix(rec.library, "libSceVideo") or Linker_StringHasPrefix(rec.library, "libSceFont"):
                        subsystem <- "graphics"
                    elif Linker_StringHasPrefix(rec.library, "libSceSaveData") or Linker_StringHasPrefix(rec.library, "libSceSaveDataDialog") or Linker_StringHasPrefix(rec.library, "libSceCommonDialog") or Linker_StringHasPrefix(rec.library, "libSceWebBrowserDialog") or Linker_StringHasPrefix(rec.library, "libSceSigninDialog"):
                        subsystem <- "save_dialog_misc"
                    elif Linker_StringHasPrefix(rec.library, "libSceAudio") or Linker_StringHasPrefix(rec.library, "libSceAjm") or Linker_StringHasPrefix(rec.library, "libSceCommonDialog"):
                        subsystem <- "audio_input_service"
                    elif Linker_StringHasPrefix(rec.library, "libSceAppContent") or Linker_StringHasPrefix(rec.library, "libSceContentExport"):
                        subsystem <- "kernel"
                RealGameBoot_EmitArtifactImport(file.ref[mutable IOFile&], mod_ref.file, rec.nid, rec.library, rec.module, subsystem, rec.resolution_kind.u64())
        RealGameBoot_EmitArtifactLastHle(file.ref[mutable IOFile&], GuestExec_LastHleModule(), GuestExec_LastHleSymbol())
        _ = IOFile_Flush(file)
        IOFile_Close(file)
        RealGameBoot_EmitHandoffManifest(linker)

@test
def emulator_real_game_boot_smoke_loads_cusa07399_eboot() -> void:
    can Memory.Allocate, Abort.Panic:
        RealGameBoot_ResetRuntime()

        arena: Arena = zeroed
        result: mutable int = -1
        in arena:
            args: mutable darray[static u8&] = ["shadps4", REAL_GAME_BOOT_ROOT, "--", "-RealBootSmoke"]
            result <- Main_Run(args)
        RealGameBoot_Check(result == 0, "expected real game Main_Run success")

        emu: mutable Emulator& = Emulator_GetInstance()
        RealGameBoot_Check(streq(Emulator_GetLastRunPath(emu), REAL_GAME_BOOT_EBOOT) == 1, "expected real game eboot path")
        RealGameBoot_Check(streq(Emulator_GetLastGameFolder(emu), REAL_GAME_BOOT_ROOT) == 1, "expected real game app0 root")
        RealGameBoot_Check(streq(Emulator_GetLastGuestEbootPath(emu), "/app0/eboot.bin") == 1, "expected real game guest eboot path")
        RealGameBoot_Check(emu.last_linker_module_index == 0, "expected real game module index")
        RealGameBoot_Check(emu.last_linker_module_count > 1usize, "expected real game dependencies to load")
        RealGameBoot_Check(emu.last_linker_start_result == 0, "expected real game start result")
        RealGameBoot_Check(emu.app0_mounted, "expected real game app0 mount")
        RealGameBoot_Check(emu.hostapp_mounted, "expected real game hostapp mount")
        RealGameBoot_Check(not emu.native_guest_exec_requested, "expected native guest exec disabled by default")
        RealGameBoot_Check(not GuestExec_IsEnabled(), "expected guest exec runtime disabled by default")

        linker: mutable Linker& = Linker_GetInstance()
        can Memory.Allocate, Abort.Panic, Console:
            RealGameBoot_EmitArtifacts(linker, 0)
        RealGameBoot_Check(linker.modules.count > 1usize, "expected linker to contain real game plus dependencies")
        RealGameBoot_Check(linker.last_started_module_index == 0, "expected real game started module index")
        RealGameBoot_Check(linker.last_start_result == 0, "expected linker start result")
        RealGameBoot_Check(linker.last_unresolved_import_count == 0usize, "expected real game and dependency imports to resolve")
        RealGameBoot_Check(linker.last_relocated_import_count > 0usize, "expected real game import relocations")
        RealGameBoot_Check(linker.last_prx_export_resolved_count > 0usize, "expected CUSA07399 to include PRX-export-backed imports")

        module: Module = linker.modules[0]
        RealGameBoot_Check(streq(module.file, "/app0/eboot.bin") == 1, "expected guest module name")
        RealGameBoot_Check(streq(module.host_file, REAL_GAME_BOOT_EBOOT) == 1, "expected host eboot path")
        RealGameBoot_Check(module.is_valid, "expected real game module valid")
        RealGameBoot_Check(not module.is_shared_lib, "expected eboot not to be marked shared")
        RealGameBoot_Check(module.dynamic_segment.count > 0, "expected dynamic segment")
        RealGameBoot_Check(module.dynamic_data.count > 0, "expected dynamic data")
        RealGameBoot_Check(module.image.count > 0, "expected loaded image")
        RealGameBoot_Check(module.mapped_segment_count > 0, "expected mapped PT_LOAD segments")
        RealGameBoot_Check(module.entry_virtual_addr > 0.uintptr(), "expected entry virtual address")
        RealGameBoot_Check(Module_GetImportSymbolCount(module) > 0, "expected imported HLE symbols")
        RealGameBoot_Check(Module_GetResolvedImportSymbolCount(module) == Module_GetImportSymbolCount(module), "expected all imports resolved")
        RealGameBoot_Check(module.applied_relocation_count > 0usize, "expected relocation writes")
        RealGameBoot_Check(module.executable_segment_permission_mismatch_count == 0usize, "expected executable segment permissions to match expected exec mapping")
        RealGameBoot_Check(RealGameBoot_CheckMappedImageMirror(module), "expected image bytes mirrored into guest memory backing")
        RealGameBoot_Check(Linker_FindByFileOrHost(linker, "/app0/sce_module/libc.prx") != 0xFFFFFFFF.u32(), "expected app-local libc.prx dependency")
        RealGameBoot_Check(Linker_FindByFileOrHost(linker, "/app0/sce_module/libSceFios2.prx") != 0xFFFFFFFF.u32(), "expected app-local libSceFios2.prx dependency")
        RealGameBoot_Check(streq(linker.modules[0].file, "/app0/eboot.bin") == 1, "expected eboot to remain module zero after dependencies")

        state: mutable EmulatorState& = EmulatorState_GetInstance()
        RealGameBoot_Check(EmulatorState_IsGameRunning(state), "expected game running state")

@test
def emulator_real_game_boot_smoke_probes_native_guest_exec_handoff() -> void:
    can Memory.Allocate, Abort.Panic:
        RealGameBoot_ResetRuntime()

        arena: Arena = zeroed
        result: mutable int = -1
        in arena:
            args: mutable darray[static u8&] = ["shadps4", "--native-guest-exec-probe", REAL_GAME_BOOT_ROOT, "--", "-RealBootSmoke"]
            result <- Main_Run(args)
        RealGameBoot_Check(result == 0, "expected native guest exec probe launch success")

        emu: mutable Emulator& = Emulator_GetInstance()
        RealGameBoot_Check(emu.native_guest_exec_requested, "expected native guest exec requested")
        RealGameBoot_Check(emu.native_guest_exec_probe_requested, "expected native guest exec probe requested")
        RealGameBoot_Check(GuestExec_IsProbeMode(), "expected guest exec probe mode")
        RealGameBoot_Check(GuestExec_IsEnabled(), "expected guest exec enabled in probe mode")
        RealGameBoot_Check(guest_exec_run_count > 0usize, "expected guest exec handoff to be reached")
        RealGameBoot_Check(guest_exec_last_entry_addr > 0.uintptr(), "expected guest exec entry address to be recorded")
        RealGameBoot_Check(guest_exec_main_run_count == 1usize, "expected one main executable handoff")
        RealGameBoot_Check(guest_exec_last_main_entry_addr > 0.uintptr(), "expected main executable entry address to be recorded")

        linker: mutable Linker& = Linker_GetInstance()
        can Memory.Allocate, Abort.Panic, Console:
            RealGameBoot_EmitArtifacts(linker, 0)
        RealGameBoot_Check(linker.last_unresolved_import_count == 0usize, "expected native probe launch imports to resolve")
        RealGameBoot_Check(linker.last_entry_addr > 0.uintptr(), "expected linker entry to be recorded")
        RealGameBoot_Check(linker.modules[0].last_start_entry_addr > 0.uintptr(), "expected main module start entry to be recorded")
        RealGameBoot_Check(guest_exec_last_main_entry_addr == linker.last_entry_addr, "expected main probe entry to match linker executable entry")
        stage_status: s32 = GuestExec_ClassifyGameExecutionStage()
        if GuestExec_IsSupported():
            RealGameBoot_Check(stage_status == 2, "expected supported host probe to arm game execution stage")
        else:
            RealGameBoot_Check(stage_status == -2, "expected unsupported host game execution classification")
        boundary_status: s32 = GuestExec_ClassifyFirstBoundary()
        if GuestExec_IsSupported():
            RealGameBoot_Check(boundary_status == GUEST_EXEC_BOUNDARY_ARMED_PROBE_ONLY, "expected supported host probe boundary classification")
        else:
            RealGameBoot_Check(boundary_status == GUEST_EXEC_BOUNDARY_UNSUPPORTED_HOST, "expected unsupported host boundary classification")

@test
def emulator_real_game_boot_smoke_guarded_game_entry_reports_host_status() -> void:
    can Memory.Allocate, Abort.Panic:
        RealGameBoot_ResetRuntime()

        arena: Arena = zeroed
        result: mutable int = -1
        in arena:
            args: mutable darray[static u8&] = ["shadps4", "--native-guest-exec-probe", REAL_GAME_BOOT_ROOT, "--", "-RealBootSmoke"]
            result <- Main_Run(args)
        RealGameBoot_Check(result == 0, "expected guarded guest exec launch setup success")

        linker: mutable Linker& = Linker_GetInstance()
        entry: VAddr = linker.last_entry_addr
        RealGameBoot_Check(entry > 0.uintptr(), "expected executable entry before guarded run")
        RealGameBoot_Check(entry == guest_exec_last_main_entry_addr, "expected guarded run to use recorded main executable entry")
        GuestExec_SetProbeMode(false)

        status: s32 = GuestExec_RunMainEntryGuarded(entry, guest_exec_last_argc, null, 25.u32())
        if GuestExec_IsSupported():
            RealGameBoot_Check(status != -2, "expected supported host to attempt guarded game entry")
        else:
            RealGameBoot_Check(status == -2, "expected unsupported host guarded game entry status")
        RealGameBoot_Check(guest_exec_last_game_execution_status == status, "expected guarded status to be recorded")
        boundary_status: s32 = GuestExec_ClassifyFirstBoundary()
        stage_code: s32 = GuestExec_ExecutionStage()
        if GuestExec_IsSupported():
            RealGameBoot_Check(boundary_status == GUEST_EXEC_BOUNDARY_FIRST_HLE_IMPORT or boundary_status == GUEST_EXEC_BOUNDARY_TIMEOUT or boundary_status == GUEST_EXEC_BOUNDARY_PRE_BOUNDARY_FAULT or boundary_status == GUEST_EXEC_BOUNDARY_EXITED_BEFORE_BOUNDARY, "expected guarded execution to classify the first-boundary or pre-boundary outcome")
            RealGameBoot_Check(stage_code >= GUEST_EXEC_STAGE_GUARDED_ENTRY, "expected guarded run to advance execution stage beyond handoff")
        else:
            RealGameBoot_Check(boundary_status == GUEST_EXEC_BOUNDARY_UNSUPPORTED_HOST, "expected unsupported host boundary classification after guarded run")
            RealGameBoot_Check(streq(GuestExec_FirstBoundaryReasonName(), "unsupported-host") == 1, "expected unsupported host boundary reason name")
            RealGameBoot_Check(GuestExec_HostArchitecture() != null, "expected host architecture to be reported")
            RealGameBoot_Check(GuestExec_HostMode() != null, "expected host mode to be reported")
            if streq(GuestExec_HostMode(), "macOS") == 1 and streq(GuestExec_HostArchitecture(), "arm64") == 1:
                x64_probe_first: bool = GuestExec_HostCanRunX64Subprocess()
                x64_probe_second: bool = GuestExec_HostCanRunX64Subprocess()
                RealGameBoot_Check(x64_probe_first == x64_probe_second, "expected x64 subprocess capability probe to be deterministic")
            RealGameBoot_Check(GuestExec_IsProbeOnly(), "expected probe-only mode on unsupported host")
            RealGameBoot_Check(stage_code == GUEST_EXEC_STAGE_GUARDED_ENTRY, "expected unsupported host guarded run to report guarded-entry stage")
        can Memory.Allocate, Abort.Panic, Console:
            # Determinism probe: re-run import relocation twice in this same
            # process and capture the fallback-slot count + a fingerprint of the
            # unresolved symbol-index multiset each time. If the two passes
            # differ here (same process), the nondeterminism is an
            # uninitialized/use-after-free read; if they match but vary across
            # process runs, it is ASLR-dependent.
            dbg_reloc_boot_count <- Linker_FallbackSlotCount().u64()
            dbg_reloc_boot_fp <- Linker_FallbackTableFingerprint()
            RealGameBoot_EmitArtifacts(linker, status)
