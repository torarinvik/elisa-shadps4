        RealGameBoot_EmitArtifactKV(file.ref[mutable IOFile&], "relocated_imports", linker.last_relocated_import_count.u64())
        RealGameBoot_EmitArtifactKV(file.ref[mutable IOFile&], "native_hle", linker.last_native_hle_resolved_count.u64())
