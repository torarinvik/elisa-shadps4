include "../../compiler/runtime/elisacore_std/elisacore_runtime.elisa"
include "../core/libraries/rtc/rtc.elisa"

@test
def rtc_basic_contracts() -> void:
    can Abort.Panic:
        null_time: mutable OrbisRtcDateTime&? = null
        null_tick: mutable OrbisRtcTick&? = null

        assert sceRtcCheckValid(null_time) == ORBIS_RTC_ERROR_INVALID_POINTER
        assert sceRtcGetCurrentTick(null_tick) == ORBIS_RTC_ERROR_DATETIME_UNINITIALIZED

        good: mutable OrbisRtcDateTime = zeroed
        good.year <- 2024u16
        good.month <- 2u16
        good.day <- 29u16
        good.hour <- 23u16
        good.minute <- 59u16
        good.second <- 58u16
        good.microsecond <- 999999u32
        assert sceRtcCheckValid(good.ref[mutable OrbisRtcDateTime&]) == ORBIS_OK

        bad_month: mutable OrbisRtcDateTime = good
        bad_month.month <- 13u16
        assert sceRtcCheckValid(bad_month.ref[mutable OrbisRtcDateTime&]) == ORBIS_RTC_ERROR_INVALID_MONTH

        assert sceRtcGetDaysInMonth(2024, 2) == 29
        assert sceRtcGetDaysInMonth(2023, 2) == 28
        assert sceRtcIsLeapYear(2024) == 1
        assert sceRtcIsLeapYear(2023) == 0

        out_tick: mutable OrbisRtcTick = zeroed
        assert sceRtcGetTick(good.ref[mutable OrbisRtcDateTime&], out_tick.ref[mutable OrbisRtcTick&]) == ORBIS_OK
        roundtrip: mutable OrbisRtcDateTime = zeroed
        assert sceRtcSetTick(roundtrip.ref[mutable OrbisRtcDateTime&], out_tick.ref[mutable OrbisRtcTick&]) == ORBIS_OK
        assert roundtrip.year == good.year
        assert roundtrip.month == good.month
        assert roundtrip.day == good.day
        assert roundtrip.hour == good.hour
        assert roundtrip.minute == good.minute
        assert roundtrip.second == good.second
        assert roundtrip.microsecond == good.microsecond

        cmp_a: mutable OrbisRtcTick = zeroed
        cmp_b: mutable OrbisRtcTick = zeroed
        cmp_a.tick <- 10u64
        cmp_b.tick <- 20u64
        assert sceRtcCompareTick(cmp_a.ref[mutable OrbisRtcTick&], cmp_b.ref[mutable OrbisRtcTick&]) == 1
        assert sceRtcCompareTick(cmp_b.ref[mutable OrbisRtcTick&], cmp_a.ref[mutable OrbisRtcTick&]) == 0

        now_tick: mutable OrbisRtcTick = zeroed
        assert sceRtcGetCurrentTick(now_tick.ref[mutable OrbisRtcTick&]) == ORBIS_OK

        dt_out: mutable OrbisRtcDateTime = zeroed
        assert sceRtcSetTick(dt_out.ref[mutable OrbisRtcDateTime&], now_tick.ref[mutable OrbisRtcTick&]) == ORBIS_OK

        dos: mutable u32 = 0u32
        assert sceRtcGetDosTime(good.ref[mutable OrbisRtcDateTime&], dos.ref[mutable u32&]) == ORBIS_OK

        assert sceRtcTickAddMinutes(null_tick, now_tick.ref[mutable OrbisRtcTick&], 1) == ORBIS_RTC_ERROR_INVALID_POINTER

        formatted: mutable u8[128] = zeroed
        assert sceRtcFormatRFC3339(formatted[0].ref[mutable u8&], out_tick.ref[OrbisRtcTick&], 0) == ORBIS_OK
        assert strcmp(formatted[0].ref[u8&], "2024-02-29T23:59:58.99Z") == 0

        parsed: mutable OrbisRtcTick = zeroed
        assert sceRtcParseRFC3339(parsed.ref[mutable OrbisRtcTick&], "2024-02-29T23:59:58.99Z") == ORBIS_OK
        parsed_dt: mutable OrbisRtcDateTime = zeroed
        assert sceRtcSetTick(parsed_dt.ref[mutable OrbisRtcDateTime&], parsed.ref[mutable OrbisRtcTick&]) == ORBIS_OK
        assert parsed_dt.year == 2024u16
        assert parsed_dt.month == 2u16
        assert parsed_dt.day == 29u16

        assert sceRtcParseDateTime(parsed.ref[mutable OrbisRtcTick&], "Thu, 29 Feb 2024 23:59:58 +0000") == ORBIS_OK
        assert sceRtcSetTick(parsed_dt.ref[mutable OrbisRtcDateTime&], parsed.ref[mutable OrbisRtcTick&]) == ORBIS_OK
        assert parsed_dt.year == 2024u16
        assert parsed_dt.month == 2u16
        assert parsed_dt.day == 29u16
