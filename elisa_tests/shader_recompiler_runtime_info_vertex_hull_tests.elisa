include "../shader_recompiler/runtime_info_vertex_hull.elisa"
include "../../compiler/runtime/elisacore_std/elisacore_runtime.elisa"

@test
def hull_runtime_info_passthrough() -> void:
    can Abort.Panic:
        h: mutable HullRuntimeInfo = zeroed
        h.hs_output_cp_stride <- 16u32
        h.ls_stride <- 16u32
        h.hs_output_base <- 0u32
        h.num_threads <- 1u32
        h.num_input_control_points <- 3u32
        assert HullRuntimeInfo_IsPassthrough(h.ref[HullRuntimeInfo&])
        assert HullRuntimeInfo_NumOutputControlPoints(h.ref[HullRuntimeInfo&]) == 3u32

@test
def hull_runtime_info_non_passthrough() -> void:
    can Abort.Panic:
        h: mutable HullRuntimeInfo = zeroed
        h.hs_output_cp_stride <- 16u32
        h.ls_stride <- 16u32
        h.hs_output_base <- 0u32
        h.num_threads <- 4u32
        h.num_input_control_points <- 3u32
        assert not HullRuntimeInfo_IsPassthrough(h.ref[HullRuntimeInfo&])
        assert HullRuntimeInfo_NumOutputControlPoints(h.ref[HullRuntimeInfo&]) == 4u32

@test
def vertex_runtime_info_outputs() -> void:
    can Abort.Panic:
        v: mutable VertexRuntimeInfo = zeroed
        v.num_outputs <- 2u32
        v.num_exports <- 1u32
        # map 0, comp 0 -> PointSize ; map 1, comp 2 -> ClipDist0
        v.outputs[0usize] <- SHADER_OUTPUT_POINT_SIZE
        v.outputs[6usize] <- SHADER_OUTPUT_CLIP_DIST0
        v.clip_disable <- true
        v.emulate_depth_negative_one_to_one <- false
        assert v.outputs[0usize] == SHADER_OUTPUT_POINT_SIZE
        assert v.outputs[6usize] == SHADER_OUTPUT_CLIP_DIST0
        assert v.clip_disable
        assert not v.emulate_depth_negative_one_to_one
        assert v.num_outputs == 2u32
