#
# Exercises the ergonomic array patterns for building/exposing tables without
# per-element push calls: top-level fixed-array consts, darray.extend from a
# const/array/list, and array_view (zero-copy dview over an addressable array).

include "../../compiler/runtime/elisacore_std/elisacore_runtime.elisa"

const TABLE: u32[5] = [10u32, 20u32, 30u32, 40u32, 50u32]

@test
def extend_darray_from_const_table() -> void:
    can Abort.Panic:
        owner: mutable Arena& = scratch_arena.ref[mutable Arena&]
        out: mutable darray[u32] = []
        in owner:
            out.extend(TABLE)              # bulk copy from a const fixed array
            out.extend([60u32, 70u32])     # bulk copy from a list literal
        assert out.count == 7u32
        assert out[0usize] == 10u32
        assert out[4usize] == 50u32
        assert out[6usize] == 70u32

@test
def darray_literal_assignment() -> void:
    can Abort.Panic:
        owner: mutable Arena& = scratch_arena.ref[mutable Arena&]
        out: mutable darray[u32] = []
        in owner:
            out <- [1u32, 2u32, 3u32]
        assert out.count == 3u32

@test
def array_view_over_stack_array() -> void:
    can Abort.Panic:
        a: mutable u32[4] = [9u32, 8u32, 7u32, 6u32]
        v: dview[u32] = array_view(a.ref[u32[4]&])
        assert v.len == 4usize
        assert arena_da_view_get(v, 0usize) == 9u32
        assert arena_da_view_get(v, 3usize) == 6u32
        # A view can feed extend just like an array.
        owner: mutable Arena& = scratch_arena.ref[mutable Arena&]
        out: mutable darray[u32] = []
        in owner:
            out.extend(v)
        assert out.count == 4u32
        assert out[1usize] == 8u32
