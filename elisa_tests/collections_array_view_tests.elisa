#
# Exercises the ergonomic array patterns for building/exposing tables without
# per-element push calls: top-level fixed-array consts, darray.extend from a
# const/array/list, and array_view (zero-copy view over an addressable array).

include "../../compiler/runtime/elisacore_std/elisacore_runtime.elisa"

const TABLE: u32[5] = [10, 20, 30, 40, 50]

@test
def extend_darray_from_const_table() -> void:
    can Abort.Panic:
        owner: mutable Arena& = &scratch_arena
        out: mutable darray[u32] = []
        in owner:
            out.extend(TABLE)              # bulk copy from a const fixed array
            out.extend([60, 70])     # bulk copy from a list literal
        assert out.count == 7
        assert out[0] == 10
        assert out[4] == 50
        assert out[6] == 70

@test
def darray_literal_assignment() -> void:
    can Abort.Panic:
        owner: mutable Arena& = &scratch_arena
        out: mutable darray[u32] = []
        in owner:
            out <- [1, 2, 3]
        assert out.count == 3

@test
def array_view_over_const_table_zero_copy() -> void:
    can Abort.Panic:
        # A const table is addressable as a read-only global, so it can be
        # handed out as a zero-copy view (no arena, no copy).
        v: view[u32] = array_view(&TABLE)
        assert v.len == 5
        assert arena_da_view_get(v, 0) == 10
        assert arena_da_view_get(v, 4) == 50

@test
def array_view_over_stack_array() -> void:
    can Abort.Panic:
        a: mutable u32[4] = [9, 8, 7, 6]
        v: view[u32] = array_view(&a)
        assert v.len == 4
        assert arena_da_view_get(v, 0) == 9
        assert arena_da_view_get(v, 3) == 6
        # A view can feed extend just like an array.
        owner: mutable Arena& = &scratch_arena
        out: mutable darray[u32] = []
        in owner:
            out.extend(v)
        assert out.count == 4
        assert out[1] == 8
