include "../../compiler/runtime/elisacore_std/elisacore_runtime.elisa"
include "../core/libraries/screenshot/screenshot.elisa"

@test
def screenshot_stub_surface_returns_ok() -> void:
    can Abort.Panic:
        assert _Z5dummyv() == ORBIS_OK
        assert sceScreenShotCapture() == ORBIS_OK
        assert sceScreenShotDisable() == ORBIS_OK
        assert sceScreenShotDisableNotification() == ORBIS_OK
        assert sceScreenShotEnable() == ORBIS_OK
        assert sceScreenShotEnableNotification() == ORBIS_OK
        assert sceScreenShotGetAppInfo() == ORBIS_OK
        assert sceScreenShotGetDrcParam() == ORBIS_OK
        assert sceScreenShotIsDisabled() == ORBIS_OK
        assert sceScreenShotIsVshScreenCaptureDisabled() == ORBIS_OK
        assert sceScreenShotSetOverlayImage() == ORBIS_OK
        assert sceScreenShotSetOverlayImageWithOrigin() == ORBIS_OK
        assert sceScreenShotSetParam() == ORBIS_OK
        assert sceScreenShotSetDrcParam() == ORBIS_OK
