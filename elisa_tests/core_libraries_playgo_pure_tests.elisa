include "../common/io_file.elisa"
include "../common/string_util.elisa"
include "../common/types.elisa"
include "../../compiler/runtime/elisacore_std/elisacore_runtime.elisa"
include "../core/libraries/playgo/playgo.elisa"
include "../core/libraries/playgo/playgo_dialog.elisa"

@test
def playgo_init_open_close_contracts() -> void:
    can Abort.Panic:
        handle: mutable OrbisPlayGoHandle = 0
        entries: mutable u32 = 0
        eta: mutable OrbisPlayGoEta = -1
        speed: mutable OrbisPlayGoInstallSpeed = -1
        lang: mutable OrbisPlayGoLanguageMask = 0
        progress: mutable OrbisPlayGoProgress = zeroed
        chunk_id: mutable OrbisPlayGoChunkId = 0
        locus: mutable OrbisPlayGoLocus = ORBIS_PLAYGO_LOCUS_NOT_DOWNLOADED
        todo: mutable OrbisPlayGoToDo = zeroed

        assert scePlayGoOpen(handle, null) == ORBIS_PLAYGO_ERROR_NOT_INITIALIZED
        assert scePlayGoClose(1) == ORBIS_PLAYGO_ERROR_NOT_INITIALIZED
        assert scePlayGoTerminate() == ORBIS_PLAYGO_ERROR_NOT_INITIALIZED

        bad_init: mutable OrbisPlayGoInitParams = zeroed
        assert scePlayGoInitialize(bad_init) == ORBIS_PLAYGO_ERROR_BAD_POINTER
        bad_init.bufAddr <- 1.cast[void&]
        bad_init.bufSize <- 0x1000
        assert scePlayGoInitialize(bad_init) == ORBIS_PLAYGO_ERROR_BAD_SIZE

        init: mutable OrbisPlayGoInitParams = zeroed
        init.bufAddr <- 1.cast[void&]
        init.bufSize <- 0x200000
        assert scePlayGoInitialize(init) == 0
        assert scePlayGoInitialize(init) == ORBIS_PLAYGO_ERROR_ALREADY_INITIALIZED

        assert scePlayGoOpen(null, null) == ORBIS_PLAYGO_ERROR_BAD_POINTER
        assert scePlayGoOpen(handle, 1.cast[void&]) == ORBIS_PLAYGO_ERROR_INVALID_ARGUMENT
        assert scePlayGoOpen(handle, null) == 0
        assert handle == 1

        assert scePlayGoGetChunkId(1, null, 0, entries) == 0
        assert entries == 0
        assert scePlayGoGetChunkId(1, chunk_id, 0, entries) == ORBIS_PLAYGO_ERROR_BAD_SIZE
        assert scePlayGoGetEta(1, chunk_id, 1, eta) == 0
        assert eta == 0
        assert scePlayGoGetInstallSpeed(1, speed) == 0
        assert speed == ORBIS_PLAYGO_INSTALL_SPEED_TRICKLE
        assert scePlayGoSetInstallSpeed(1, ORBIS_PLAYGO_INSTALL_SPEED_FULL) == 0
        assert scePlayGoGetInstallSpeed(1, speed) == 0
        assert speed == ORBIS_PLAYGO_INSTALL_SPEED_FULL
        assert scePlayGoGetLanguageMask(1, lang) == 0
        assert scePlayGoSetLanguageMask(1, 0xFF) == 0
        assert scePlayGoGetLanguageMask(1, lang) == 0
        assert lang == 0xFF
        assert scePlayGoGetLocus(1, chunk_id, 1, locus) == ORBIS_PLAYGO_ERROR_BAD_CHUNK_ID
        assert scePlayGoGetProgress(1, chunk_id, 1, progress) == ORBIS_PLAYGO_ERROR_BAD_CHUNK_ID
        assert scePlayGoGetToDoList(1, todo, 1, entries) == 0
        assert entries == 0

        assert scePlayGoClose(1) == 0
        assert scePlayGoTerminate() == 0

@test
def playgo_dialog_contracts() -> void:
    can Abort.Panic:
        result: mutable OrbisPlayGoDialogResult = zeroed
        assert scePlayGoDialogInitialize() == 0
        assert scePlayGoDialogGetStatus() == 0
        assert scePlayGoDialogOpen(null) == 0x80B8000D
        assert scePlayGoDialogGetResult(null) == 0x80B8000D
        assert scePlayGoDialogGetResult(result) == 0
        assert result.result == 3
        assert scePlayGoDialogClose() == 0
        assert scePlayGoDialogUpdateStatus() == 0
        assert scePlayGoDialogTerminate() == 0
