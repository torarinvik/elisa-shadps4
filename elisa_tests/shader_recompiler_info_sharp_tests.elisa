include "../shader_recompiler/info_sharp.elisa"
include "../../compiler/runtime/elisacore_std/elisacore_runtime.elisa"

# Helper: push four dwords (a sharp) into an Info's flattened_ud_buf.
def _push4(info: mutable Info&, a: u32, b: u32, c: u32, d: u32) -> void:
    owner: mutable Arena& = scratch_arena.ref[mutable Arena&]
    in owner:
        info.flattened_ud_buf.push(a)
        info.flattened_ud_buf.push(b)
        info.flattened_ud_buf.push(c)
        info.flattened_ud_buf.push(d)

@test
def read_ud_sharp_4() -> void:
    can Abort.Panic:
        info: mutable Info = zeroed
        _push4(info.ref[mutable Info&], 0x11111111u32, 0x22222222u32, 0x33333333u32, 0x44444444u32)
        s: u32[4] = Info_ReadUdSharp4(info.ref[Info&], 0u32)
        assert s[0usize] == 0x11111111u32
        assert s[3usize] == 0x44444444u32
        # w0 combines the first two dwords little-endian.
        assert sharp4_w0(s.ref[u32[4]&]) == 0x2222222211111111u64

@test
def buffer_get_sharp_reads_from_flattened_buf() -> void:
    can Abort.Panic:
        info: mutable Info = zeroed
        # A valid buffer sharp: base_address (44 bits of w0) = 0x1000, w2 type
        # field (bits 30-31) == 0 means valid.
        _push4(info.ref[mutable Info&], 0x00001000u32, 0u32, 0u32, 0u32)
        res: mutable BufferResource = zeroed
        res.sharp_idx <- 0u32
        # No inline cbuf -> reads from flattened_ud_buf.
        sharp: u32[4] = BufferResource_GetSharp(res.ref[BufferResource&], info.ref[Info&])
        assert Buffer_BaseAddress(sharp4_w0(sharp.ref[u32[4]&])) == 0x1000u64

@test
def buffer_get_sharp_invalid_returns_null() -> void:
    can Abort.Panic:
        info: mutable Info = zeroed
        # w2 type field (bits 30-31) != 0 -> invalid -> Null (base_address == 1).
        _push4(info.ref[mutable Info&], 0x00009999u32, 0u32, 0u32, 0x40000000u32)
        res: mutable BufferResource = zeroed
        sharp: u32[4] = BufferResource_GetSharp(res.ref[BufferResource&], info.ref[Info&])
        assert Buffer_BaseAddress(sharp4_w0(sharp.ref[u32[4]&])) == 1u64

@test
def buffer_get_sharp_inline_with_pgm_base_fixup() -> void:
    can Abort.Panic:
        info: mutable Info = zeroed
        info.pgm_base <- 0x10000u64
        res: mutable BufferResource = zeroed
        # inline_cbuf base_address = 0x2000 (not 0, not 1) -> fixup adds pgm_base.
        res.inline_cbuf[0usize] <- 0x00002000u32
        res.inline_cbuf[3usize] <- 0u32  # w2 type 0 -> valid
        sharp: u32[4] = BufferResource_GetSharp(res.ref[BufferResource&], info.ref[Info&])
        assert Buffer_BaseAddress(sharp4_w0(sharp.ref[u32[4]&])) == 0x12000u64

@test
def sampler_get_sharp_inline_vs_read() -> void:
    can Abort.Panic:
        info: mutable Info = zeroed
        _push4(info.ref[mutable Info&], 0xAAAAAAAAu32, 0xBBBBBBBBu32, 0u32, 0u32)
        res: mutable SamplerResource = zeroed
        # read path
        s0: u32[4] = SamplerResource_GetSharp(res.ref[SamplerResource&], info.ref[Info&])
        assert s0[0usize] == 0xAAAAAAAAu32
        # inline path
        res.is_inline_sampler <- true
        res.inline_sampler[0usize] <- 0xCAFEu32
        s1: u32[4] = SamplerResource_GetSharp(res.ref[SamplerResource&], info.ref[Info&])
        assert s1[0usize] == 0xCAFEu32

@test
def image_get_sharp_reads_8_dwords() -> void:
    can Abort.Panic:
        info: mutable Info = zeroed
        _push4(info.ref[mutable Info&], 1u32, 2u32, 3u32, 4u32)
        _push4(info.ref[mutable Info&], 5u32, 6u32, 7u32, 8u32)
        res: mutable ImageResource = zeroed
        img: u32[8] = ImageResource_GetSharp(res.ref[ImageResource&], info.ref[Info&])
        assert img[0usize] == 1u32
        assert img[7usize] == 8u32
        # r128 path reads only the first 4 dwords.
        res.is_r128 <- true
        img2: u32[8] = ImageResource_GetSharp(res.ref[ImageResource&], info.ref[Info&])
        assert img2[0usize] == 1u32
        assert img2[4usize] == 0u32
