include "../../compiler/runtime/elisacore_std/elisacore_runtime.elisa"
include "../core/libraries/error_codes.elisa"
include "../core/libraries/avplayer/avplayer_error.elisa"
include "../core/libraries/avplayer/avplayer_impl.elisa"

@test
def avplayer_common_source_type_resolution_contract() -> void:
    can Abort.Panic:
        assert avimpl_get_source_type_from_path(null) == AVPLAYER_SOURCE_TYPE_UNKNOWN
        assert avimpl_get_source_type_from_path("".cast[i8&?]) == AVPLAYER_SOURCE_TYPE_UNKNOWN

        assert avimpl_get_source_type_from_path("video.mp4".cast[i8&?]) == AVPLAYER_SOURCE_TYPE_FILE_MP4
        assert avimpl_get_source_type_from_path("VIDEO.M4V".cast[i8&?]) == AVPLAYER_SOURCE_TYPE_FILE_MP4
        assert avimpl_get_source_type_from_path("movie.m3u8".cast[i8&?]) == AVPLAYER_SOURCE_TYPE_HLS
        assert avimpl_get_source_type_from_path("https://example.com/path/clip.mov?x=1#frag".cast[i8&?]) == AVPLAYER_SOURCE_TYPE_FILE_MP4
        assert avimpl_get_source_type_from_path("https://example.com/noext?x=1".cast[i8&?]) == AVPLAYER_SOURCE_TYPE_UNKNOWN

        assert avimpl_validate_source_type("https://example.com/live.m3u8".cast[i8&?], AVPLAYER_SOURCE_TYPE_UNKNOWN) == ORBIS_AVPLAYER_ERROR_NOT_SUPPORTED
        assert avimpl_validate_source_type("clip.mp4".cast[i8&?], AVPLAYER_SOURCE_TYPE_UNKNOWN) == ORBIS_OK
