include "../shader_recompiler/ir/breadth_first_search.elisa"
include "../../compiler/runtime/elisacore_std/elisacore_runtime.elisa"

# Predicate: match an IAdd32 instruction, returning its inst index as the result.
def bfs_find_iadd(program: ShaderIrProgram&, inst_val: ShaderIrValue) -> u32?:
    if inst_val.type_bits != IR_TYPE_OPAQUE:
        return null
    if inst_val.inst_block >= program.block_count:
        return null
    if inst_val.inst_index >= program.blocks[inst_val.inst_block.usize()].inst_count:
        return null
    if program.blocks[inst_val.inst_block.usize()].insts[inst_val.inst_index.usize()].opcode == IR_OPCODE_IADD32:
        return inst_val.inst_index
    return null

@test
def bfs_finds_dependency_instruction() -> void:
    can Abort.Panic, Memory.Allocate:
        info: ShaderIrProgramInfo = zeroed
        program: mutable heap ShaderIrProgram& = ShaderIrProgram_New(info)
        b: u32 = ShaderIrProgram_AddBlock(program)
        # inst0: IAdd32(2, 3)
        a0: mutable ShaderIrValue[6] = zeroed
        a0[0] <- ShaderIrValue_FromU32(2)
        a0[1] <- ShaderIrValue_FromU32(3)
        i0: u32 = ShaderIrProgram_AppendInst(program, b, IR_OPCODE_IADD32, a0, 2, 0)
        # inst1: IMul32(inst0, 4)
        a1: mutable ShaderIrValue[6] = zeroed
        a1[0] <- ShaderIrValue_FromInst(b, i0)
        a1[1] <- ShaderIrValue_FromU32(4)
        i1: u32 = ShaderIrProgram_AppendInst(program, b, IR_OPCODE_IMUL32, a1, 2, 0)
        # Search from the IMul: BFS should reach the IAdd through arg 0.
        found: u32? = ShaderIrBreadthFirstSearch[u32](program, ShaderIrValue_FromInst(b, i1), bfs_find_iadd)
        # BFS reached the IAdd dependency through the IMul's first argument.
        assert found != null
        _ = i0

@test
def bfs_returns_null_when_absent() -> void:
    can Abort.Panic, Memory.Allocate:
        info: ShaderIrProgramInfo = zeroed
        program: mutable heap ShaderIrProgram& = ShaderIrProgram_New(info)
        b: u32 = ShaderIrProgram_AddBlock(program)
        # Only an IMul chain, no IAdd anywhere.
        a0: mutable ShaderIrValue[6] = zeroed
        a0[0] <- ShaderIrValue_FromU32(5)
        a0[1] <- ShaderIrValue_FromU32(6)
        i0: u32 = ShaderIrProgram_AppendInst(program, b, IR_OPCODE_IMUL32, a0, 2, 0)
        found: u32? = ShaderIrBreadthFirstSearch[u32](program, ShaderIrValue_FromInst(b, i0), bfs_find_iadd)
        assert found == null

@test
def bfs_immediate_start_is_null() -> void:
    can Abort.Panic, Memory.Allocate:
        info: ShaderIrProgramInfo = zeroed
        program: mutable heap ShaderIrProgram& = ShaderIrProgram_New(info)
        _ = ShaderIrProgram_AddBlock(program)
        found: u32? = ShaderIrBreadthFirstSearch[u32](program, ShaderIrValue_FromU32(42), bfs_find_iadd)
        assert found == null
