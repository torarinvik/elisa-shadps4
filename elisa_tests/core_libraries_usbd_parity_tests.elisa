include "../common/io_file.elisa"
include "../common/string_util.elisa"
include "../common/types.elisa"
include "../../compiler/runtime/elisacore_std/elisacore_runtime.elisa"
include "../core/libraries/usbd/emulated/skylander.elisa"
include "../core/libraries/usbd/emulated/infinity.elisa"
include "../core/libraries/usbd/emulated/dimensions.elisa"
include "../core/libraries/usbd/usbd.elisa"

def usbd_reset_skylander() -> void:
    g_sky_init <- false
    _ = UsbdSkylanderEmu_Init()

def usbd_reset_infinity() -> void:
    g_inf_init <- false
    _ = UsbdInfinityEmu_Init()

def usbd_reset_dimensions() -> void:
    g_dim_init <- false
    _ = UsbdDimensionsEmu_Init()

def usbd_assert_all_zero32(buf: u8[32]) -> void:
    i: mutable usize = 0
    while i < 32:
        assert buf[i] == 0
        i <- i + 1

@test
def usbd_skylander_activation_and_interrupt_contract() -> void:
    can Abort.Panic:
        usbd_reset_skylander()
        req: mutable u8[32] = zeroed
        req[0] <- 'A'.u8()
        req[1] <- 1
        assert UsbdSkylanderEmu_ControlTransfer(req[0], 2) == 10

        out: mutable u8[32] = zeroed
        assert UsbdSkylanderEmu_InterruptIn(out[0]) == 32
        assert out[0] == 0x41
        assert out[1] == 1
        assert out[2] == 0xff
        assert out[3] == 0x77

@test
def usbd_infinity_seed_challenge_and_stub_contract() -> void:
    can Abort.Panic:
        usbd_reset_infinity()
        cmd: mutable u8[32] = zeroed
        out: mutable u8[32] = zeroed

        cmd[2] <- 0x81
        cmd[3] <- 0x05
        _ = UsbdInfinityEmu_CommandOut(cmd[0])
        _ = UsbdInfinityEmu_InterruptIn(out[0])
        assert out[0] == 0xaa
        assert out[1] == 0x01
        assert out[2] == 0x05
        assert out[3] == ((out[0].int() + out[1].int() + out[2].int()) & 0xff).u8()

        cmd <- zeroed
        out <- zeroed
        cmd[2] <- 0xb5
        cmd[3] <- 0x07
        _ = UsbdInfinityEmu_CommandOut(cmd[0])
        _ = UsbdInfinityEmu_InterruptIn(out[0])
        assert out[0] == 0xaa
        assert out[1] == 0x01
        assert out[2] == 0x07

@test
def usbd_skylander_command_vector_contract() -> void:
    can Abort.Panic:
        usbd_reset_skylander()
        cmds: u8[10] = ['A'.u8(), 'C'.u8(), 'J'.u8(), 'L'.u8(), 'M'.u8(), 'Q'.u8(), 'R'.u8(), 'S'.u8(), 'V'.u8(), 'W'.u8()]
        i: mutable usize = 0
        while i < 10:
            req: mutable u8[32] = zeroed
            req[0] <- cmds[i]
            req[1] <- (i + 1).u8()
            _ = UsbdSkylanderEmu_ControlTransfer(req[0], 2)
            out: mutable u8[32] = zeroed
            assert UsbdSkylanderEmu_InterruptIn(out[0]) == 32
            assert out[0] == cmds[i]
            assert out[1] == (i + 1).u8()
            i <- i + 1

@test
def usbd_skylander_default_interrupt_status_packet() -> void:
    can Abort.Panic:
        usbd_reset_skylander()
        out: mutable u8[32] = zeroed
        assert UsbdSkylanderEmu_InterruptIn(out[0]) == 32
        assert out[0] == 0x53

@test
def usbd_skylander_persistence_roundtrip() -> void:
    can Abort.Panic:
        usbd_reset_skylander()
        tmp: static u8& = "usbd_skylander_roundtrip.bin"
        fig: mutable u8[0x40 * 0x10] = zeroed
        fig[0] <- 0x11
        fig[1] <- 0x22
        bytes: mutable darray[u8] = []
        i: mutable usize = 0
        while i < 0x40 * 0x10:
            can Memory.Allocate, Abort.Panic:
                owner: mutable Arena& = &scratch_arena
                in owner:
                    bytes.push(fig[i])
            i <- i + 1
        assert ff_file_write_all(tmp, bytes)
        UsbdSkylanderEmu_LoadFigure(tmp, 0)
        UsbdSkylanderEmu_RemoveFigure(0)
        disk: darray[u8] = ff_file_read_all(tmp)
        assert disk.count == 0x40 * 0x10
        assert disk[0] == 0x11
        assert disk[1] == 0x22

@test
def usbd_dimensions_unimplemented_bucket_returns_zero_packet() -> void:
    can Abort.Panic:
        usbd_reset_dimensions()
        cmd: mutable u8[32] = zeroed
        out: mutable u8[32] = zeroed
        cmd[2] <- 0xd0
        cmd[3] <- 0x22
        assert UsbdDimensionsEmu_CommandOut(cmd[0]) == 32
        assert UsbdDimensionsEmu_InterruptIn(out[0]) == 32
        usbd_assert_all_zero32(out)

@test
def usbd_dimensions_stub_bucket_vector_contract() -> void:
    can Abort.Panic:
        usbd_reset_dimensions()
        cmds: u8[5] = [0xd0, 0xe1, 0xe5, 0xff, 0x7e]
        i: mutable usize = 0
        while i < 5:
            cmd: mutable u8[32] = zeroed
            out: mutable u8[32] = zeroed
            cmd[2] <- cmds[i]
            cmd[3] <- 0x33
            _ = UsbdDimensionsEmu_CommandOut(cmd[0])
            _ = UsbdDimensionsEmu_InterruptIn(out[0])
            usbd_assert_all_zero32(out)
            i <- i + 1

@test
def usbd_dimensions_move_event_ordering_contract() -> void:
    can Abort.Panic:
        usbd_reset_dimensions()
        UsbdDimensionsEmu_LoadFigure("", 0, 0)
        UsbdDimensionsEmu_LoadFigure("", 1, 1)
        drain: mutable u8[32] = zeroed
        _ = UsbdDimensionsEmu_InterruptIn(drain[0])
        _ = UsbdDimensionsEmu_InterruptIn(drain[0])

        UsbdDimensionsEmu_MoveFigure(0, 0, 2, 1)
        first: mutable u8[32] = zeroed
        second: mutable u8[32] = zeroed
        _ = UsbdDimensionsEmu_InterruptIn(first[0])
        _ = UsbdDimensionsEmu_InterruptIn(second[0])

        # Destination remove then moved figure add.
        assert first[0] == 0x56
        assert first[5] == 0x01
        assert second[0] == 0x56
        assert second[5] == 0x00
        assert second[2] == 2
        assert second[4] == 2

@test
def usbd_dimensions_temp_remove_and_cancel_contract() -> void:
    can Abort.Panic:
        usbd_reset_dimensions()
        UsbdDimensionsEmu_LoadFigure("", 0, 3)
        drain: mutable u8[32] = zeroed
        _ = UsbdDimensionsEmu_InterruptIn(drain[0])
        UsbdDimensionsEmu_TempRemoveFigure(3)
        UsbdDimensionsEmu_CancelRemoveFigure(3)
        ev1: mutable u8[32] = zeroed
        ev2: mutable u8[32] = zeroed
        _ = UsbdDimensionsEmu_InterruptIn(ev1[0])
        _ = UsbdDimensionsEmu_InterruptIn(ev2[0])
        assert ev1[0] == 0x56
        assert ev2[0] == 0x56
        assert ev2[5] == 0x00

@test
def usbd_wrapper_control_and_interrupt_routing_contract() -> void:
    can Abort.Panic:
        # Skylander control path.
        _ = sceUsbdOpenDeviceWithVidPid(0x1430, 0x0150)
        ctrl: mutable u8[32] = zeroed
        ctrl[0] <- 'A'.u8()
        ctrl[1] <- 9
        assert sceUsbdControlTransfer(null, 0x21, 0x09, 0, 0, ctrl[0], 2, 0) == 10

        # Dimensions interrupt out/in routing + actual length.
        _ = sceUsbdOpenDeviceWithVidPid(0x0e6f, 0x0241)
        cmd: mutable u8[32] = zeroed
        cmd[2] <- 0xb0
        cmd[3] <- 0x44
        actual: s32 = 0
        assert sceUsbdInterruptTransfer(null, 0x01, cmd[0], 32, (&actual).cast[mutable s32&], 0) == ORBIS_OK
        assert actual == 32
        out: mutable u8[32] = zeroed
        assert sceUsbdInterruptTransfer(null, 0x81, out[0], 32, (&actual).cast[mutable s32&], 0) == ORBIS_OK
        assert actual == 32

@test
def usbd_wrapper_backend_selection_and_interrupt_actual_length() -> void:
    can Abort.Panic:
        _ = sceUsbdOpenDeviceWithVidPid(0x0e6f, 0x0241)
        assert g_usbd_backend_mode == USBD_BACKEND_DIMENSIONS
        data: mutable u8[32] = zeroed
        data[2] <- 0xb0
        data[3] <- 0x01
        actual: s32 = 0
        assert sceUsbdInterruptTransfer(null, 0x01, data[0], 32, (&actual).cast[mutable s32&], 0) == ORBIS_OK
        assert actual == 32
