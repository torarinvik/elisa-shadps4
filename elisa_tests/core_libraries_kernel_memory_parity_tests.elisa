include "../core/memory.elisa"
include "../core/libraries/kernel/memory.elisa"
include "../core/libraries/kernel/orbis_error.elisa"
# memory.elisa pulls in guest_exec.elisa, whose GuestExec_DumpHleCallRing
# references Linker_*/Module_StartOracle* helpers that live in linker.elisa;
# pull it in so this target links (same fix as core_libraries_pad_tests).
include "../core/linker.elisa"


def km_check(condition: bool, message: static u8&) -> void:
    can Abort.Panic, Segment.Host, Unsafe.SegmentMutation:
        if not condition:
            panic(message)

@test
def kernel_memory_mmap_protect_unmap_stateful_contracts() -> void:
    can Abort.Panic, Segment.Host, Unsafe.SegmentMutation:
        Memory_Reset()
        MemoryManager_SetupMemoryRegions(Memory_Instance(), ORBIS_KERNEL_FLEXIBLE_MEMORY_SIZE, true, true)

        mapped: mutable void&? = null
        km_check(sceKernelMmap(null, 0x2000, MemoryProt_CpuReadWrite.int(), MemoryMapFlags_Anon.int(), -1, 0, mapped) == ORBIS_OK, "mmap should succeed")
        km_check(mapped != null, "mmap should return an address")
        km_check(MemoryManager_IsValidMapping(Memory_Instance(), mapped.cast[VAddr], 0x4000), "mmap should map aligned size")

        km_check(sceKernelMprotect((mapped.cast[VAddr] + 1.uintptr()).cast[void&?], 1, MemoryProt_CpuRead.int()) == ORBIS_OK, "mprotect should align and protect")
        start: mutable void&? = null
        end: mutable void&? = null
        prot: mutable u32 = 0
        km_check(sceKernelQueryMemoryProtection(mapped, start, end, prot) == ORBIS_OK, "query protection should succeed")
        km_check(start == mapped, "query start should match mapping")
        km_check(prot == MemoryProt_CpuRead, "query prot should reflect mprotect")

        km_check(sceKernelMunmap(mapped, 0x4000) == ORBIS_OK, "munmap should succeed")
        km_check(not MemoryManager_IsValidMapping(Memory_Instance(), mapped.cast[VAddr], 0x4000), "munmap should remove mapping")
        km_check(sceKernelMunmap(mapped, 0x4000) < 0, "munmap should reject duplicate unmap")

@test
def kernel_memory_nested_reserved_segment_query_prefers_specific_vma() -> void:
    can Abort.Panic, Segment.Host, Unsafe.SegmentMutation:
        Memory_Reset()
        mem: mutable MemoryManager& = Memory_Instance()
        reserved: mutable VAddr = 0x800000000.uintptr()
        segment: mutable VAddr = reserved + 0x1000.uintptr()
        km_check(MemoryManager_MapMemory(mem, reserved, reserved, 0x4000, MemoryProt_NoAccess, MemoryMapFlags_NoFlags, VMAType_Reserved, "reserved", false, 0.uintptr(), 0x1000) == 0, "reserved image range should map")
        km_check(MemoryManager_MapMemory(mem, segment, segment, 0x1000, MemoryProt_CpuReadWrite, MemoryMapFlags_Fixed, VMAType_Code, "code", false, 0.uintptr(), 0x1000) == 0, "fixed segment inside reserved range should map")

        start: mutable VAddr = 0.uintptr()
        end: mutable VAddr = 0.uintptr()
        prot: mutable u32 = 0
        km_check(MemoryManager_QueryProtection(mem, segment, start, end, prot) == 0, "query should find nested segment")
        km_check(start == segment, "query should prefer the specific segment over the reserved parent")
        km_check(end == segment + 0x1000.uintptr(), "query should report the nested segment extent")
        km_check(prot == MemoryProt_CpuReadWrite, "query should report nested segment protection")

        km_check(MemoryManager_Protect(mem, segment, 0x1000, MemoryProt_CpuRead | MemoryProt_CpuExec) == 0, "protect should update nested segment")
        km_check(MemoryManager_QueryProtection(mem, segment, start, end, prot) == 0, "query should find protected nested segment")
        km_check(prot == (MemoryProt_CpuRead | MemoryProt_CpuExec), "query should report updated nested segment protection")

        km_check(MemoryManager_QueryProtection(mem, reserved, start, end, prot) == 0, "query should still find reserved parent")
        km_check(start == reserved, "reserved parent start should remain intact")
        km_check(prot == MemoryProt_NoAccess, "reserved parent protection should remain intact")

@test
def kernel_memory_invalid_pointer_ordering_and_direct_flexible_maps() -> void:
    can Abort.Panic, Segment.Host, Unsafe.SegmentMutation:
        Memory_Reset()
        MemoryManager_SetupMemoryRegions(Memory_Instance(), ORBIS_KERNEL_FLEXIBLE_MEMORY_SIZE, true, true)

        mmap_out: mutable void&? = null
        km_check(sceKernelMmap(null, 0, MemoryProt_CpuReadWrite.int(), MemoryMapFlags_Anon.int(), -1, 0, mmap_out) == ORBIS_KERNEL_ERROR_EINVAL, "mmap len zero should be invalid")
        bad_fixed: void&? = 0x1001.cast[void&?]
        km_check(sceKernelMmap(bad_fixed, 0x4000, MemoryProt_CpuReadWrite.int(), MemoryMapFlags_Fixed.int() | MemoryMapFlags_Anon.int(), -1, 0, mmap_out) == ORBIS_KERNEL_ERROR_EINVAL, "fixed mmap should reject unaligned addr")
        km_check(posix_mmap(null, 0, MemoryProt_CpuReadWrite.int(), MemoryMapFlags_Anon.int(), -1, 0) == KERNEL_MEMORY_MMAP_FAILED.cast[void&?], "posix mmap should return failed sentinel")

        direct_addr: mutable void&? = null
        km_check(sceKernelMapDirectMemory(direct_addr, 0x4000, MemoryProt_CpuReadWrite.int(), MemoryMapFlags_NoFlags.int(), 0, 0) == ORBIS_OK, "direct map should succeed")
        km_check(direct_addr != null, "direct map should return address")
        km_check(sceKernelMapDirectMemory(direct_addr, 0x2000, MemoryProt_CpuReadWrite.int(), MemoryMapFlags_NoFlags.int(), 0, 0) == ORBIS_KERNEL_ERROR_EINVAL, "direct map should reject unaligned len")
        km_check(sceKernelMapDirectMemory(direct_addr, 0x4000, MemoryProt_CpuRead.int() | MemoryProt_CpuExec.int(), MemoryMapFlags_NoFlags.int(), 0, 0) == ORBIS_KERNEL_ERROR_EACCES, "direct map should reject exec")

        flex_addr: mutable void&? = null
        before: u64 = MemoryManager_GetAvailableFlexibleSize(Memory_Instance())
        km_check(sceKernelMapFlexibleMemory(flex_addr, 0x4000, MemoryProt_CpuReadWrite.int(), MemoryMapFlags_NoFlags.int()) == ORBIS_OK, "flex map should succeed")
        km_check(flex_addr != null, "flex map should return address")
        km_check(MemoryManager_GetAvailableFlexibleSize(Memory_Instance()) == before, "current manager does not charge flexible usage yet")

        km_check(sceKernelMunmap(null, 0x4000) == ORBIS_KERNEL_ERROR_EINVAL, "munmap should reject null")
        km_check(sceKernelMunmap(flex_addr, 0x2000) == ORBIS_KERNEL_ERROR_EINVAL, "munmap should reject unaligned len")
        km_check(posix_munmap(null, 0x4000) == -1, "posix munmap should map failure to -1")

@test
def kernel_memory_region_math_rejects_overflow_and_aliasing() -> void:
    can Abort.Panic, Segment.Host, Unsafe.SegmentMutation:
        Memory_Reset()
        mem: mutable MemoryManager& = Memory_Instance()
        base: VAddr = 0x800000000.uintptr()
        mapped: mutable VAddr = 0.uintptr()

        km_check(AddressSpace_PageAligned(base.u64()), "test base should be 4KB aligned")
        km_check(AddressSpace_PageAligned(0x4000), "test len should be 4KB aligned")
        km_check(AddressSpace_WithinReservation(base.u64(), 0x4000, AddressSpace_SystemReservedMin.u64(), AddressSpace_SystemReservedSize), "reserved test range should be within system-reserved")
        km_check(not AddressSpace_WithinReservation(0xfffffffffffff000, 0x4000, AddressSpace_SystemReservedMin.u64(), AddressSpace_SystemReservedSize), "overflowing range should not be within reservation")
        km_check(AddressSpace_RangesOverlap(base.u64(), 0x4000, (base + 0x2000.uintptr()).u64(), 0x4000), "intersecting ranges should overlap")
        km_check(not AddressSpace_RangesOverlap(base.u64(), 0x4000, (base + 0x4000.uintptr()).u64(), 0x4000), "touching ranges should not overlap")

        km_check(MemoryManager_MapMemory(mem, mapped, base, 0x4000, MemoryProt_CpuReadWrite, MemoryMapFlags_NoFlags, VMAType_Reserved, "reserved", false, 0.uintptr(), 0x4000) == 0, "first map should succeed")
        km_check(mapped == base, "fixed map should preserve requested address")
        km_check(MemoryManager_MapMemory(mem, mapped, base + 0x2000.uintptr(), 0x4000, MemoryProt_CpuReadWrite, MemoryMapFlags_NoOverwrite, VMAType_Reserved, "overlap", false, 0.uintptr(), 0x4000) == -1, "no-overwrite map should reject overlap")
        km_check(MemoryManager_MapMemory(mem, mapped, 0xfffffffffffff000.uintptr(), 0x4000, MemoryProt_CpuReadWrite, MemoryMapFlags_NoFlags, VMAType_Reserved, "overflow", false, 0.uintptr(), 0x4000) == -1, "map should reject overflowing virtual range")

@test
def kernel_memory_direct_alloc_and_query_contracts() -> void:
    can Memory.Allocate, Abort.Panic, Segment.Host, Unsafe.SegmentMutation:
        Memory_Reset()
        MemoryManager_SetupMemoryRegions(Memory_Instance(), ORBIS_KERNEL_FLEXIBLE_MEMORY_SIZE, true, true)

        direct_addr: mutable i64 = 0
        km_check(sceKernelAllocateDirectMemory(0x100000000, 0x100200000, 0x4000, 0, 0, (&direct_addr).cast[void&?]) == ORBIS_OK, "allocate direct memory should succeed")
        km_check((direct_addr.u64() % 0x4000) == 0, "allocated direct memory should be 16KB aligned")
        km_check(sceKernelAllocateDirectMemory(0x100000000, 0x100200000, 0x2000, 0, 0, (&direct_addr).cast[void&?]) == ORBIS_KERNEL_ERROR_EINVAL, "allocate direct memory should reject unaligned length")

        avail_phys: mutable i64 = 0
        avail_size: mutable u64 = 0
        km_check(sceKernelAvailableDirectMemorySize(0x100000000, 0x100200000, 0, (&avail_phys).cast[void&?], (&avail_size).cast[void&?]) == ORBIS_OK, "available direct memory query should succeed")
        km_check(avail_phys.u64() >= direct_addr.u64() + 0x4000, "available direct memory should move forward after allocation")
        km_check((avail_size % 0x4000) == 0, "available direct memory size should stay page aligned")

        mem_type: mutable int = -1
        range_start: mutable i64 = 0
        range_end: mutable i64 = 0
        km_check(sceKernelGetDirectMemoryType(direct_addr.u64(), (&mem_type).cast[void&?], (&range_start).cast[void&?], (&range_end).cast[void&?]) == ORBIS_OK, "direct memory type query should succeed for in-range addr")
        km_check(range_start <= direct_addr and range_end > direct_addr, "direct memory type range should include allocated address")
        km_check(sceKernelGetDirectMemoryType(0x1000, (&mem_type).cast[void&?], (&range_start).cast[void&?], (&range_end).cast[void&?]) == ORBIS_KERNEL_ERROR_EINVAL, "direct memory type query should reject non-direct address")
