include "../core/memory.elisa"
include "../core/libraries/kernel/memory.elisa"
include "../core/libraries/kernel/orbis_error.elisa"


def km_check(condition: bool, message: static u8&) -> void:
    can Abort.Panic:
        if not condition:
            panic(message)

@test
def kernel_memory_mmap_protect_unmap_stateful_contracts() -> void:
    can Abort.Panic:
        Memory_Reset()
        MemoryManager_SetupMemoryRegions(Memory_Instance(), ORBIS_KERNEL_FLEXIBLE_MEMORY_SIZE, true, true)

        mapped: mutable void&? = null
        km_check(sceKernelMmap(null, 0x2000u64, MemoryProt_CpuReadWrite.int(), MemoryMapFlags_Anon.int(), -1, 0, mapped.ref[mutable void&?&]) == ORBIS_OK, "mmap should succeed")
        km_check(mapped != null, "mmap should return an address")
        km_check(MemoryManager_IsValidMapping(Memory_Instance(), mapped.cast[VAddr], 0x4000u64), "mmap should map aligned size")

        km_check(sceKernelMprotect((mapped.cast[VAddr] + 1.uintptr()).cast[void&?], 1u64, MemoryProt_CpuRead.int()) == ORBIS_OK, "mprotect should align and protect")
        start: mutable void&? = null
        end: mutable void&? = null
        prot: mutable u32 = 0u32
        km_check(sceKernelQueryMemoryProtection(mapped, start.ref[mutable void&?&], end.ref[mutable void&?&], prot.ref[mutable u32&]) == ORBIS_OK, "query protection should succeed")
        km_check(start == mapped, "query start should match mapping")
        km_check(prot == MemoryProt_CpuRead, "query prot should reflect mprotect")

        km_check(sceKernelMunmap(mapped, 0x4000u64) == ORBIS_OK, "munmap should succeed")
        km_check(not MemoryManager_IsValidMapping(Memory_Instance(), mapped.cast[VAddr], 0x4000u64), "munmap should remove mapping")
        km_check(sceKernelMunmap(mapped, 0x4000u64) < 0, "munmap should reject duplicate unmap")

@test
def kernel_memory_invalid_pointer_ordering_and_direct_flexible_maps() -> void:
    can Abort.Panic:
        Memory_Reset()
        MemoryManager_SetupMemoryRegions(Memory_Instance(), ORBIS_KERNEL_FLEXIBLE_MEMORY_SIZE, true, true)

        mmap_out: mutable void&? = null
        km_check(sceKernelMmap(null, 0u64, MemoryProt_CpuReadWrite.int(), MemoryMapFlags_Anon.int(), -1, 0, mmap_out.ref[mutable void&?&]) == ORBIS_KERNEL_ERROR_EINVAL, "mmap len zero should be invalid")
        bad_fixed: void&? = 0x1001u64.cast[void&?]
        km_check(sceKernelMmap(bad_fixed, 0x4000u64, MemoryProt_CpuReadWrite.int(), MemoryMapFlags_Fixed.int() | MemoryMapFlags_Anon.int(), -1, 0, mmap_out.ref[mutable void&?&]) == ORBIS_KERNEL_ERROR_EINVAL, "fixed mmap should reject unaligned addr")
        km_check(posix_mmap(null, 0u64, MemoryProt_CpuReadWrite.int(), MemoryMapFlags_Anon.int(), -1, 0) == KERNEL_MEMORY_MMAP_FAILED.cast[void&?], "posix mmap should return failed sentinel")

        direct_addr: mutable void&? = null
        km_check(sceKernelMapDirectMemory(direct_addr.ref[mutable void&?&], 0x4000u64, MemoryProt_CpuReadWrite.int(), MemoryMapFlags_NoFlags.int(), 0, 0) == ORBIS_OK, "direct map should succeed")
        km_check(direct_addr != null, "direct map should return address")
        km_check(sceKernelMapDirectMemory(direct_addr.ref[mutable void&?&], 0x2000u64, MemoryProt_CpuReadWrite.int(), MemoryMapFlags_NoFlags.int(), 0, 0) == ORBIS_KERNEL_ERROR_EINVAL, "direct map should reject unaligned len")
        km_check(sceKernelMapDirectMemory(direct_addr.ref[mutable void&?&], 0x4000u64, MemoryProt_CpuRead.int() | MemoryProt_CpuExec.int(), MemoryMapFlags_NoFlags.int(), 0, 0) == ORBIS_KERNEL_ERROR_EACCES, "direct map should reject exec")

        flex_addr: mutable void&? = null
        before: u64 = MemoryManager_GetAvailableFlexibleSize(Memory_Instance())
        km_check(sceKernelMapFlexibleMemory(flex_addr.ref[mutable void&?&], 0x4000u64, MemoryProt_CpuReadWrite.int(), MemoryMapFlags_NoFlags.int()) == ORBIS_OK, "flex map should succeed")
        km_check(flex_addr != null, "flex map should return address")
        km_check(MemoryManager_GetAvailableFlexibleSize(Memory_Instance()) == before, "current manager does not charge flexible usage yet")

        km_check(sceKernelMunmap(null, 0x4000u64) == ORBIS_KERNEL_ERROR_EINVAL, "munmap should reject null")
        km_check(sceKernelMunmap(flex_addr, 0x2000u64) == ORBIS_KERNEL_ERROR_EINVAL, "munmap should reject unaligned len")
        km_check(posix_munmap(null, 0x4000u64) == -1, "posix munmap should map failure to -1")

@test
def kernel_memory_direct_alloc_and_query_contracts() -> void:
    can Abort.Panic:
        Memory_Reset()
        MemoryManager_SetupMemoryRegions(Memory_Instance(), ORBIS_KERNEL_FLEXIBLE_MEMORY_SIZE, true, true)

        direct_addr: mutable i64 = 0
        km_check(sceKernelAllocateDirectMemory(0x100000000i64, 0x100200000i64, 0x4000u64, 0u64, 0, direct_addr.ref[mutable i64&].cast[void&?]) == ORBIS_OK, "allocate direct memory should succeed")
        km_check((direct_addr.u64() % 0x4000u64) == 0u64, "allocated direct memory should be 16KB aligned")
        km_check(sceKernelAllocateDirectMemory(0x100000000i64, 0x100200000i64, 0x2000u64, 0u64, 0, direct_addr.ref[mutable i64&].cast[void&?]) == ORBIS_KERNEL_ERROR_EINVAL, "allocate direct memory should reject unaligned length")

        avail_phys: mutable i64 = 0
        avail_size: mutable u64 = 0u64
        km_check(sceKernelAvailableDirectMemorySize(0x100000000u64, 0x100200000u64, 0u64, avail_phys.ref[mutable i64&].cast[void&?], avail_size.ref[mutable u64&].cast[void&?]) == ORBIS_OK, "available direct memory query should succeed")
        km_check(avail_phys.u64() >= direct_addr.u64() + 0x4000u64, "available direct memory should move forward after allocation")
        km_check((avail_size % 0x4000u64) == 0u64, "available direct memory size should stay page aligned")

        mem_type: mutable int = -1
        range_start: mutable i64 = 0
        range_end: mutable i64 = 0
        km_check(sceKernelGetDirectMemoryType(direct_addr.u64(), mem_type.ref[mutable int&].cast[void&?], range_start.ref[mutable i64&].cast[void&?], range_end.ref[mutable i64&].cast[void&?]) == ORBIS_OK, "direct memory type query should succeed for in-range addr")
        km_check(range_start <= direct_addr and range_end > direct_addr, "direct memory type range should include allocated address")
        km_check(sceKernelGetDirectMemoryType(0x1000u64, mem_type.ref[mutable int&].cast[void&?], range_start.ref[mutable i64&].cast[void&?], range_end.ref[mutable i64&].cast[void&?]) == ORBIS_KERNEL_ERROR_EINVAL, "direct memory type query should reject non-direct address")
