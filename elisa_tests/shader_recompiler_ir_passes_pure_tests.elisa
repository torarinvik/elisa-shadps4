include "../../compiler/runtime/elisacore_std/elisacore_runtime.elisa"
include "../shader_recompiler/ir/passes/ir_passes.elisa"

def inst_invalidated(program: ShaderIrProgram&, id: u32) -> bool:
    b: mutable u32 = 0u32
    i: mutable u32 = 0u32
    if not ShaderIrProgram_FindInst(program, id, b.ref[mutable u32&], i.ref[mutable u32&]):
        return false
    return program.blocks[b.usize()].insts[i.usize()].invalidated


def inst_opcode(program: ShaderIrProgram&, id: u32) -> u32:
    b: mutable u32 = 0u32
    i: mutable u32 = 0u32
    if not ShaderIrProgram_FindInst(program, id, b.ref[mutable u32&], i.ref[mutable u32&]):
        return 0u32
    return program.blocks[b.usize()].insts[i.usize()].opcode


def inst_replacement(program: ShaderIrProgram&, id: u32) -> u32:
    b: mutable u32 = 0u32
    i: mutable u32 = 0u32
    if not ShaderIrProgram_FindInst(program, id, b.ref[mutable u32&], i.ref[mutable u32&]):
        return 0u32
    return program.blocks[b.usize()].insts[i.usize()].replacement_value

@test
def shader_ir_constant_identity_deadcode_passes() -> void:
    can Abort.Panic:
        program: mutable ShaderIrProgram = ShaderIrProgram_Default()
        block: u32 = ShaderIrProgram_AddBlock(program.ref[mutable ShaderIrProgram&])

        add_id: u32 = ShaderIrProgram_AddInst(program.ref[mutable ShaderIrProgram&], block, OPCODE_IADD32)
        mul_id: u32 = ShaderIrProgram_AddInst(program.ref[mutable ShaderIrProgram&], block, OPCODE_IMUL32)
        not_id: u32 = ShaderIrProgram_AddInst(program.ref[mutable ShaderIrProgram&], block, OPCODE_LOGICALNOT)
        disc_id: u32 = ShaderIrProgram_AddInst(program.ref[mutable ShaderIrProgram&], block, OPCODE_DISCARDCOND)
        id_id: u32 = ShaderIrProgram_AddInst(program.ref[mutable ShaderIrProgram&], block, OPCODE_IDENTITY)
        void_id: u32 = ShaderIrProgram_AddInst(program.ref[mutable ShaderIrProgram&], block, OPCODE_VOID)

        b: mutable u32 = 0u32
        i: mutable u32 = 0u32
        assert ShaderIrProgram_FindInst(program, add_id, b.ref[mutable u32&], i.ref[mutable u32&])
        ShaderIrPassInst_SetArgImm(program.blocks[b.usize()].insts[i.usize()].ref[mutable ShaderIrPassInst&], 0u32, 2u32)
        ShaderIrPassInst_SetArgImm(program.blocks[b.usize()].insts[i.usize()].ref[mutable ShaderIrPassInst&], 1u32, 3u32)

        assert ShaderIrProgram_FindInst(program, mul_id, b.ref[mutable u32&], i.ref[mutable u32&])
        ShaderIrPassInst_SetArgImm(program.blocks[b.usize()].insts[i.usize()].ref[mutable ShaderIrPassInst&], 0u32, 7u32)
        ShaderIrPassInst_SetArgImm(program.blocks[b.usize()].insts[i.usize()].ref[mutable ShaderIrPassInst&], 1u32, 1u32)

        assert ShaderIrProgram_FindInst(program, not_id, b.ref[mutable u32&], i.ref[mutable u32&])
        ShaderIrPassInst_SetArgImm(program.blocks[b.usize()].insts[i.usize()].ref[mutable ShaderIrPassInst&], 0u32, 0u32)

        assert ShaderIrProgram_FindInst(program, disc_id, b.ref[mutable u32&], i.ref[mutable u32&])
        ShaderIrPassInst_SetArgImm(program.blocks[b.usize()].insts[i.usize()].ref[mutable ShaderIrPassInst&], 0u32, 1u32)

        ConstantPropagationPass(program.ref[mutable ShaderIrProgram&])
        assert program.stats.constant_folds >= 4u32
        assert inst_invalidated(program, add_id)
        assert inst_invalidated(program, mul_id)
        assert inst_invalidated(program, not_id)

        IdentityRemovalPass(program.ref[mutable ShaderIrProgram&])
        assert program.stats.identity_removed >= 2u32

        DeadCodeEliminationPass(program.ref[mutable ShaderIrProgram&])
        assert program.stats.dead_code_removed >= 1u32

@test
def shader_ir_clip_and_shared_memory_passes() -> void:
    can Abort.Panic:
        program: mutable ShaderIrProgram = ShaderIrProgram_Default()
        runtime: mutable ShaderRuntimeInfo = ShaderRuntimeInfo_Default()
        profile: mutable ShaderPassProfile = ShaderPassProfile_Default()

        program.info.stage <- STAGE_VERTEX
        program.info.stores_clip_distance <- true
        profile.needs_clip_distance_emulation <- true
        InjectClipDistanceAttributes(program.ref[mutable ShaderIrProgram&], runtime.ref[mutable ShaderRuntimeInfo&], profile)
        assert runtime.vs_num_exports == 1u32

        program.info.stage <- STAGE_COMPUTE
        program.info.logical_stage <- LOGICAL_STAGE_FRAGMENT
        runtime.fs_clip_distance_emulation <- true
        runtime.cs_shared_memory_size <- 4096u32
        runtime.cs_workgroup_size_x <- 64u32
        runtime.cs_workgroup_size_y <- 1u32
        runtime.cs_workgroup_size_z <- 1u32
        profile.needs_lds_barriers <- true

        block: u32 = ShaderIrProgram_AddBlock(program.ref[mutable ShaderIrProgram&])
        load_id: u32 = ShaderIrProgram_AddInst(program.ref[mutable ShaderIrProgram&], block, OPCODE_LOADSHAREDU32)
        write_id: u32 = ShaderIrProgram_AddInst(program.ref[mutable ShaderIrProgram&], block, OPCODE_WRITESHAREDU16)
        _ = load_id
        _ = write_id

        ShaderIrProgram_AddSyntaxBlock(program.ref[mutable ShaderIrProgram&], block)
        SharedMemoryBarrierPass(program.ref[mutable ShaderIrProgram&], runtime, profile)
        assert program.stats.shared_barriers_inserted > 0u32

        SharedMemorySimplifyPass(program.ref[mutable ShaderIrProgram&], profile)
        assert program.stats.shared_simplified_rewrites >= 1u32

        profile.max_shared_memory_size <- 1024u32
        SharedMemoryToStoragePass(program.ref[mutable ShaderIrProgram&], runtime, profile)
        assert program.stats.shared_to_storage_rewrites > 0u32
        assert program.info.buffers_count > 0u32

@test
def shader_ir_lowering_and_readlane_and_ssa() -> void:
    can Abort.Panic:
        program: mutable ShaderIrProgram = ShaderIrProgram_Default()
        block: u32 = ShaderIrProgram_AddBlock(program.ref[mutable ShaderIrProgram&])

        fp_id: u32 = ShaderIrProgram_AddInst(program.ref[mutable ShaderIrProgram&], block, OPCODE_FPADDD64)
        pack_id: u32 = ShaderIrProgram_AddInst(program.ref[mutable ShaderIrProgram&], block, OPCODE_PACKDOUBLE2X32)
        fmt_load: u32 = ShaderIrProgram_AddInst(program.ref[mutable ShaderIrProgram&], block, OPCODE_LOADBUFFERFORMATF32)

        wl: u32 = ShaderIrProgram_AddInst(program.ref[mutable ShaderIrProgram&], block, OPCODE_WRITELANE)
        rl: u32 = ShaderIrProgram_AddInst(program.ref[mutable ShaderIrProgram&], block, OPCODE_READLANE)

        set_s: u32 = ShaderIrProgram_AddInst(program.ref[mutable ShaderIrProgram&], block, OPCODE_SETSCALARREGISTER)
        get_s: u32 = ShaderIrProgram_AddInst(program.ref[mutable ShaderIrProgram&], block, OPCODE_GETSCALARREGISTER)

        b: mutable u32 = 0u32
        i: mutable u32 = 0u32

        assert ShaderIrProgram_FindInst(program, pack_id, b.ref[mutable u32&], i.ref[mutable u32&])
        ShaderIrPassInst_SetArgImm(program.blocks[b.usize()].insts[i.usize()].ref[mutable ShaderIrPassInst&], 0u32, 9u32)

        assert ShaderIrProgram_FindInst(program, wl, b.ref[mutable u32&], i.ref[mutable u32&])
        ShaderIrPassInst_SetArgInst(program.blocks[b.usize()].insts[i.usize()].ref[mutable ShaderIrPassInst&], 0u32, 0u32)
        ShaderIrPassInst_SetArgImm(program.blocks[b.usize()].insts[i.usize()].ref[mutable ShaderIrPassInst&], 1u32, 123u32)
        ShaderIrPassInst_SetArgImm(program.blocks[b.usize()].insts[i.usize()].ref[mutable ShaderIrPassInst&], 2u32, 2u32)

        assert ShaderIrProgram_FindInst(program, rl, b.ref[mutable u32&], i.ref[mutable u32&])
        ShaderIrPassInst_SetArgInst(program.blocks[b.usize()].insts[i.usize()].ref[mutable ShaderIrPassInst&], 0u32, wl)
        ShaderIrPassInst_SetArgImm(program.blocks[b.usize()].insts[i.usize()].ref[mutable ShaderIrPassInst&], 1u32, 2u32)

        assert ShaderIrProgram_FindInst(program, set_s, b.ref[mutable u32&], i.ref[mutable u32&])
        ShaderIrPassInst_SetArgImm(program.blocks[b.usize()].insts[i.usize()].ref[mutable ShaderIrPassInst&], 0u32, 5u32)
        ShaderIrPassInst_SetArgImm(program.blocks[b.usize()].insts[i.usize()].ref[mutable ShaderIrPassInst&], 1u32, 88u32)

        assert ShaderIrProgram_FindInst(program, get_s, b.ref[mutable u32&], i.ref[mutable u32&])
        ShaderIrPassInst_SetArgImm(program.blocks[b.usize()].insts[i.usize()].ref[mutable ShaderIrPassInst&], 0u32, 5u32)

        LowerFp64ToFp32(program.ref[mutable ShaderIrProgram&])
        assert inst_opcode(program, fp_id) == OPCODE_FPADD32
        assert program.stats.fp64_lowered >= 2u32

        LowerBufferFormatToRaw(program.ref[mutable ShaderIrProgram&])
        assert inst_opcode(program, fmt_load) == OPCODE_LOADBUFFERF32
        assert program.stats.buffer_format_lowered >= 1u32

        ReadLaneEliminationPass(program.ref[mutable ShaderIrProgram&])
        assert program.stats.readlane_eliminated >= 1u32
        assert inst_replacement(program, rl) == 123u32

        SsaRewritePass(program.ref[mutable ShaderIrProgram&])
        assert program.stats.ssa_reads_rewritten >= 1u32

@test
def shader_ir_resource_info_tess_ring_flatten_parity() -> void:
    can Abort.Panic:
        program: mutable ShaderIrProgram = ShaderIrProgram_Default()
        runtime: mutable ShaderRuntimeInfo = ShaderRuntimeInfo_Default()
        profile: mutable ShaderPassProfile = ShaderPassProfile_Default()
        block: u32 = ShaderIrProgram_AddBlock(program.ref[mutable ShaderIrProgram&])

        buf_inst: u32 = ShaderIrProgram_AddInst(program.ref[mutable ShaderIrProgram&], block, OPCODE_LOADBUFFERU32)
        img_inst: u32 = ShaderIrProgram_AddInst(program.ref[mutable ShaderIrProgram&], block, OPCODE_IMAGEREAD)
        rc_inst: u32 = ShaderIrProgram_AddInst(program.ref[mutable ShaderIrProgram&], block, OPCODE_READCONST)
        rc_buf: u32 = ShaderIrProgram_AddInst(program.ref[mutable ShaderIrProgram&], block, OPCODE_READCONSTBUFFER)
        sh_store: u32 = ShaderIrProgram_AddInst(program.ref[mutable ShaderIrProgram&], block, OPCODE_WRITESHAREDU32)
        ring_inst: u32 = ShaderIrProgram_AddInst(program.ref[mutable ShaderIrProgram&], block, OPCODE_STOREBUFFERU32)

        _ = buf_inst
        _ = img_inst
        _ = ring_inst

        b: mutable u32 = 0u32
        i: mutable u32 = 0u32

        assert ShaderIrProgram_FindInst(program, rc_inst, b.ref[mutable u32&], i.ref[mutable u32&])
        ShaderIrPassInst_SetArgImm(program.blocks[b.usize()].insts[i.usize()].ref[mutable ShaderIrPassInst&], 0u32, 1u32)
        ShaderIrPassInst_SetArgImm(program.blocks[b.usize()].insts[i.usize()].ref[mutable ShaderIrPassInst&], 1u32, 12u32)

        assert ShaderIrProgram_FindInst(program, rc_buf, b.ref[mutable u32&], i.ref[mutable u32&])
        ShaderIrPassInst_SetArgImm(program.blocks[b.usize()].insts[i.usize()].ref[mutable ShaderIrPassInst&], 0u32, 7u32)
        ShaderIrPassInst_SetArgImm(program.blocks[b.usize()].insts[i.usize()].ref[mutable ShaderIrPassInst&], 1u32, TESS_CONST_HS_NUM_PATCH)

        assert ShaderIrProgram_FindInst(program, sh_store, b.ref[mutable u32&], i.ref[mutable u32&])
        ShaderIrPassInst_SetArgImm(program.blocks[b.usize()].insts[i.usize()].ref[mutable ShaderIrPassInst&], 0u32, 64u32)

        ResourceTrackingPass(program.ref[mutable ShaderIrProgram&], profile)
        assert program.stats.resource_sharp_patched >= 1u32
        assert program.stats.resource_args_patched >= 1u32

        CollectShaderInfoPass(program.ref[mutable ShaderIrProgram&], profile)
        assert program.info.uses_dma == true
        assert program.info.buffers_count >= 3u32

        program.info.stage <- STAGE_LOCAL
        RingAccessElimination(program.ref[mutable ShaderIrProgram&], runtime)
        assert program.stats.ring_rewrites >= 1u32

        runtime.hs_ls_stride <- 16u32
        runtime.hs_output_cp_stride <- 32u32
        runtime.hs_is_passthrough <- true
        program.info.logical_stage <- LOGICAL_STAGE_TESSELLATION_CONTROL
        TessellationPreprocess(program.ref[mutable ShaderIrProgram&], runtime.ref[mutable ShaderRuntimeInfo&])
        assert program.stats.tess_constants_replaced >= 1u32

        HullShaderTransform(program.ref[mutable ShaderIrProgram&], runtime)
        assert program.stats.hull_rewrites >= 1u32

        DomainShaderTransform(program.ref[mutable ShaderIrProgram&], runtime)
        assert program.stats.domain_rewrites >= 0u32

        FlattenExtendedUserdataPass(program.ref[mutable ShaderIrProgram&])
        assert program.stats.flatten_readconsts >= 1u32
        assert program.info.srt_walker_generated == true

        info_copy: mutable ShaderIrInfo = program.info
        DumpSrtProgram(info_copy, null, 0u32)
        _ = RegisterWalkerCode(null, 4u32)
        _ = SrtWalkerSignalHandler(null, null)

@test
def shader_ir_helper_contracts_match_cpp_switch_intent() -> void:
    can Abort.Panic:
        load_probe: mutable ShaderIrPassInst = zeroed
        load_probe.opcode <- OPCODE_LOADBUFFERFORMATF32
        store_probe: mutable ShaderIrPassInst = zeroed
        store_probe.opcode <- OPCODE_STOREBUFFERFORMATF32
        assert IsBufferFormatLoad(load_probe)
        assert IsBufferFormatStore(store_probe)

        p: mutable ShaderIrProgram = ShaderIrProgram_Default()
        b0: u32 = ShaderIrProgram_AddBlock(p.ref[mutable ShaderIrProgram&])
        _ = ShaderIrProgram_AddInst(p.ref[mutable ShaderIrProgram&], b0, OPCODE_SHAREDATOMICIADD64)
        _ = ShaderIrProgram_AddInst(p.ref[mutable ShaderIrProgram&], b0, OPCODE_LOADSHAREDU16)
        special: u32 = CalculateSpecialSharedAtomicTypes(p)
        all_types: u32 = CalculateSharedMemoryTypes(p)
        has_special_u64: bool = (special & IR_TYPE_U64) != 0u32
        has_any_u16: bool = (all_types & IR_TYPE_U16) != 0u32
        assert has_special_u64
        assert has_any_u16

@test
def shader_ir_direct_helper_entrypoints_are_covered() -> void:
    can Abort.Panic:
        p: mutable ShaderIrProgram = ShaderIrProgram_Default()
        b0: u32 = ShaderIrProgram_AddBlock(p.ref[mutable ShaderIrProgram&])

        cp_id: u32 = ShaderIrProgram_AddInst(p.ref[mutable ShaderIrProgram&], b0, OPCODE_IADD32)
        bb: mutable u32 = 0u32
        bi: mutable u32 = 0u32
        assert ShaderIrProgram_FindInst(p, cp_id, bb.ref[mutable u32&], bi.ref[mutable u32&])
        ShaderIrPassInst_SetArgImm(p.blocks[bb.usize()].insts[bi.usize()].ref[mutable ShaderIrPassInst&], 0u32, 9u32)
        ShaderIrPassInst_SetArgImm(p.blocks[bb.usize()].insts[bi.usize()].ref[mutable ShaderIrPassInst&], 1u32, 2u32)
        assert ConstantPropagation(p.ref[mutable ShaderIrProgram&], bb, bi)

        lower_id: u32 = ShaderIrProgram_AddInst(p.ref[mutable ShaderIrProgram&], b0, OPCODE_FPADDD64)
        assert ShaderIrProgram_FindInst(p, lower_id, bb.ref[mutable u32&], bi.ref[mutable u32&])
        Lower(p.ref[mutable ShaderIrProgram&], bb, bi)
        assert p.blocks[bb.usize()].insts[bi.usize()].opcode == OPCODE_FPADD32

        info: mutable ShaderIrInfo = zeroed
        visit_inst: mutable ShaderIrPassInst = zeroed
        visit_inst.opcode <- OPCODE_READCONST
        visit_inst.flags_u32 <- 1u32
        Visit(info.ref[mutable ShaderIrInfo&], visit_inst)
        assert info.uses_dma == true
