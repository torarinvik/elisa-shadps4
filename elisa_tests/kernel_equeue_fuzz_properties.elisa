#
# E3 fuzz harness: verifies that null/malformed inputs to equeue event
# accessor and queue management functions never trap, always returning
# the documented default (0 / null / error code).
#
# @property tests require at least one fuzzed param (the framework generates
# random values). For deterministic null-input tests the fuzz param is
# present but unused (its value doesn't affect correctness — the test always
# uses fixed null/invalid inputs).

include "../core/libraries/kernel/equeue.elisa"

# --- Event accessor null-safety (null input -> documented zero/null default) ---

@property
def fuzz_GetEventId_null(_seed: i32) -> bool:
    r: u64 = sceKernelGetEventId(null)
    return r == 0

@property
def fuzz_GetEventFilter_null(_seed: i32) -> bool:
    r: int = sceKernelGetEventFilter(null)
    return r == ORBIS_OK

@property
def fuzz_GetEventData_null(_seed: i32) -> bool:
    r: u64 = sceKernelGetEventData(null)
    return r == 0

@property
def fuzz_GetEventUserData_null(_seed: i32) -> bool:
    r: void&? = sceKernelGetEventUserData(null)
    return r == null

# --- Queue management with invalid handles (vary the invalid handle value) ---

@property
def fuzz_DeleteEqueue_invalid_handle(handle: i32) -> bool:
    # Any handle not in the slot table (table is empty at test init) -> EBADF
    r: int = sceKernelDeleteEqueue(handle.int())
    return r == ORBIS_KERNEL_ERROR_EBADF

@property
def fuzz_AddUserEvent_invalid_handle(handle: i32) -> bool:
    r: int = sceKernelAddUserEvent(handle.int(), 42)
    return r == ORBIS_KERNEL_ERROR_EBADF

@property
def fuzz_AddUserEventEdge_invalid_handle(handle: i32) -> bool:
    r: int = sceKernelAddUserEventEdge(handle.int(), 42)
    return r == ORBIS_KERNEL_ERROR_EBADF

@property
def fuzz_TriggerUserEvent_invalid_handle(handle: i32) -> bool:
    r: int = sceKernelTriggerUserEvent(handle.int(), 0, null)
    return r == ORBIS_KERNEL_ERROR_EBADF

@property
def fuzz_DeleteUserEvent_invalid_handle(handle: i32) -> bool:
    r: int = sceKernelDeleteUserEvent(handle.int(), 0)
    return r == ORBIS_KERNEL_ERROR_EBADF

@property
def fuzz_DeleteHRTimerEvent_invalid_handle(handle: i32) -> bool:
    r: int = sceKernelDeleteHRTimerEvent(handle.int(), 0)
    return r == ORBIS_KERNEL_ERROR_EBADF

@property
def fuzz_DeleteTimerEvent_invalid_handle(handle: i32) -> bool:
    r: int = sceKernelDeleteTimerEvent(handle.int(), 0)
    return r == ORBIS_KERNEL_ERROR_EBADF

# --- WaitEqueue with invalid handle never reaches the ev-null path ---

@property
def fuzz_WaitEqueue_invalid_handle(handle: i32) -> bool:
    r: int = sceKernelWaitEqueue(handle.int(), null, 1, null, null)
    # Invalid handle -> EBADF (before null ev check)
    return r == ORBIS_KERNEL_ERROR_EBADF

# --- CreateEqueue null-ptr args always -> EINVAL ---

@property
def fuzz_CreateEqueue_null_both(_seed: i32) -> bool:
    r: int = sceKernelCreateEqueue(null, null)
    return r == ORBIS_KERNEL_ERROR_EINVAL

# --- posix_kevent with invalid handle -> returns -1 ---

@property
def fuzz_posix_kevent_invalid_handle(handle: i32) -> bool:
    r: int = posix_kevent(handle.int(), null, 0, null, 0, null)
    return r == -1

# --- equeue_supported_filter: 0 is not a valid filter ---

@property
def fuzz_supported_filter_zero(_seed: i32) -> bool:
    return not equeue_supported_filter(0)

# --- equeue_supported_filter: known valid filters always return true ---

@property
def fuzz_supported_filter_user(_seed: i32) -> bool:
    return equeue_supported_filter(EQUEUE_FILTER_USER)

@property
def fuzz_supported_filter_timer(_seed: i32) -> bool:
    return equeue_supported_filter(EQUEUE_FILTER_TIMER)

@property
def fuzz_supported_filter_hrtimer(_seed: i32) -> bool:
    return equeue_supported_filter(EQUEUE_FILTER_HRTIMER)

@property
def fuzz_supported_filter_videoout(_seed: i32) -> bool:
    return equeue_supported_filter(EQUEUE_FILTER_VIDEOOUT)

@property
def fuzz_supported_filter_graphics(_seed: i32) -> bool:
    return equeue_supported_filter(EQUEUE_FILTER_GRAPHICS)
