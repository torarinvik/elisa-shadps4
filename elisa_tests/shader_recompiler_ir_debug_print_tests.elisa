include "../shader_recompiler/ir/debug_print.elisa"
include "../../compiler/runtime/elisacore_std/elisacore_runtime.elisa"

@test
def debug_print_num_format_args_matches_cpp() -> void:
    can Abort.Panic:
        # NumArgsOf(DebugPrint) is 5; one operand is the format string.
        assert ShaderIrDebugPrint_NumFormatArgs() == 4u32

@test
def debug_print_flags_roundtrip() -> void:
    can Abort.Panic:
        assert ShaderIrDebugPrintFlags_NumArgs(ShaderIrDebugPrintFlags_FromNumArgs(3u32)) == 3u32
        assert ShaderIrDebugPrintFlags_NumArgs(0u32) == 0u32
