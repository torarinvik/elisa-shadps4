include "../../compiler/runtime/elisacore_std/elisacore_runtime.elisa"
include "../core/libraries/disc_map/disc_map.elisa"

@test
def disc_map_primary_entrypoints_match_cpp_stubs() -> void:
    ret1: mutable int = 123
    ret2: mutable int = 456
    assert sceDiscMapGetPackageSize(0, ret1.ref[mutable int&], ret2.ref[mutable int&]) == ORBIS_DISC_MAP_ERROR_NO_BITMAP_INFO
    assert sceDiscMapIsRequestOnHDD(null, 0, 0, ret1.ref[mutable int&]) == ORBIS_DISC_MAP_ERROR_NO_BITMAP_INFO
    assert Func_8A828CAEE7EDD5E9(null, 0, 0, ret1.ref[mutable int&], ret2.ref[mutable int&], ret2.ref[mutable int&]) == ORBIS_DISC_MAP_ERROR_NO_BITMAP_INFO
    assert Func_E7EBCE96E92F91F8() == ORBIS_DISC_MAP_ERROR_NO_BITMAP_INFO

@test
def disc_map_flags_helper_zeroes_outputs() -> void:
    flags: mutable int = 9
    ret1: mutable int = 8
    ret2: mutable int = 7
    assert Func_7C980FFB0AA27E7A(null, 0, 0, flags.ref[mutable int&], ret1.ref[mutable int&], ret2.ref[mutable int&]) == ORBIS_OK
    assert flags == 0
    assert ret1 == 0
    assert ret2 == 0
