include "../shader_recompiler/frontend/opcodes_vopc.elisa"
include "../../compiler/runtime/elisacore_std/elisacore_runtime.elisa"

@test
def opcodes_vopc_vintrp_values() -> void:
    can Abort.Panic:
        assert OPCODE_VOPC_V_CMP_F_F32 == 0u32
        assert OPCODE_VOPC_V_CMP_T_F32 == 15u32
        assert OPCODE_VOPC_V_CMPX_CLASS_F64 == 184u32
        assert OPCODE_VOPC_V_CMPX_T_U64 == 247u32
        assert OPCODE_VOPC_OP_RANGE_VOPC == 248u32
        assert OPCODE_VINTRP_V_INTERP_P1_F32 == 0u32
        assert OPCODE_VINTRP_OP_RANGE_VINTRP == 3u32
