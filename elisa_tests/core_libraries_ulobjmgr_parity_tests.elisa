include "../core/libraries/kernel/lib_function_stub.elisa"
include "../../compiler/runtime/elisacore_std/elisacore_runtime.elisa"
include "../core/libraries/ulobjmgr/ulobjmgr.elisa"

@test
def ulobjmgr_register_contracts() -> void:
    can Abort.Panic:
        out: mutable u32 = 123
        assert _sceUlobjmgrRegisterObject(1, 1, out) == ORBIS_OK
        assert out == 0

        assert _sceUlobjmgrRegisterObject(0, 1, out) == POSIX_EINVAL
        assert _sceUlobjmgrRegisterObject(1, 0, out) == POSIX_EINVAL
        assert _sceUlobjmgrRegisterObject(1, 1, null) == POSIX_EINVAL

@test
def ulobjmgr_unregister_contracts() -> void:
    can Abort.Panic:
        assert _sceUlobjmgrUnregisterObject(0) == ORBIS_OK
        assert _sceUlobjmgrUnregisterObject(0x3fff) == ORBIS_OK
        assert _sceUlobjmgrUnregisterObject(0x4000) == POSIX_EINVAL

@test
def ulobjmgr_misc_contracts() -> void:
    can Abort.Panic:
        assert Func_1D9F50D9CFB8054E() == ORBIS_OK
        assert Func_4B07893BBB77A649(1) == ORBIS_OK
        assert Func_4B07893BBB77A649(0) == POSIX_EINVAL

def main() -> int:
    out: mutable u32 = 99
    if _sceUlobjmgrRegisterObject(1, 1, out) != ORBIS_OK:
        return 1
    if out != 0:
        return 2
    if _sceUlobjmgrUnregisterObject(0x4000) != POSIX_EINVAL:
        return 3
    if Func_4B07893BBB77A649(0) != POSIX_EINVAL:
        return 4
    if Func_1D9F50D9CFB8054E() != ORBIS_OK:
        return 5
    return 0
