include "../shader_recompiler/frontend/opcodes_vop3.elisa"
include "../../compiler/runtime/elisacore_std/elisacore_runtime.elisa"

@test
def opcodes_vop3_values() -> void:
    can Abort.Panic:
        assert OPCODE_VOP3_V_CMP_F_F32 == 0u32
        assert OPCODE_VOP3_V_CNDMASK_B32 == 256u32
        assert OPCODE_VOP3_V_NOP == 384u32
        assert OPCODE_VOP3_OP_RANGE_VOP3 == 1024u32
        assert OPCODE_VOP3P_V_PK_MAD_I16 == 0u32
        assert OPCODE_VOP3P_OP_RANGE_VOP3P == 35u32
