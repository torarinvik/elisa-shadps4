include "../../compiler/runtime/elisacore_std/elisacore_runtime.elisa"
include "../video_core/renderer_vulkan/host_passes/common.elisa"
include "../video_core/renderer_vulkan/host_passes/fsr_pass.elisa"
include "../video_core/renderer_vulkan/host_passes/pp_pass.elisa"

def host_passes_make_frame() -> VkPresenterFrame:
    return VkPresenterFrame_new(1920, 1080, 0x1000, 0x1001, 0x1002)

@test
def host_passes_fsr_disabled_and_downscale_bypass() -> void:
    can Abort.Panic:
        HostPass_ResetGlobalsForTests()
        fsr: mutable FsrPass = FsrPass_new()
        FsrPass_Create(fsr, 0x11, 0, 2)
        cmdbuf: mutable HostPassCommandBuffer = HostPassCommandBuffer_new()

        settings: mutable FsrPassSettings = FsrPassSettings_default()
        settings.enable <- false
        out_disabled: u64 = FsrPass_Render(fsr, cmdbuf, 0x77, VkExtent2D_new(960, 540), VkExtent2D_new(1920, 1080), settings, false)
        assert out_disabled == 0x77
        assert not DebugState_GetIsUsingFsr()
        assert cmdbuf.commands.count == 0

        settings.enable <- true
        out_downscale: u64 = FsrPass_Render(fsr, cmdbuf, 0x88, VkExtent2D_new(1920, 1080), VkExtent2D_new(1280, 720), settings, false)
        assert out_downscale == 0x88
        assert not DebugState_GetIsUsingFsr()
        assert cmdbuf.commands.count == 0

@test
def host_passes_fsr_easu_only_contract() -> void:
    can Abort.Panic:
        HostPass_ResetGlobalsForTests()
        HostPass_SetVkHostMarkersEnabled(true)
        fsr: mutable FsrPass = FsrPass_new()
        FsrPass_Create(fsr, 0x22, 0, 1)
        cmdbuf: mutable HostPassCommandBuffer = HostPassCommandBuffer_new()

        settings: mutable FsrPassSettings = FsrPassSettings_default()
        settings.enable <- true
        settings.use_rcas <- false
        out_view: u64 = FsrPass_Render(fsr, cmdbuf, 0x99, VkExtent2D_new(960, 540), VkExtent2D_new(1920, 1080), settings, true)
        assert out_view != 0x99
        assert out_view != 0
        assert DebugState_GetIsUsingFsr()
        assert not fsr.last_used_rcas
        assert fsr.last_easu_constants.Sample[0] == 1
        assert HostPassCommandBuffer_CountKind(cmdbuf, HostPassCommandKind.BindComputePipeline) == 1
        assert HostPassCommandBuffer_CountKind(cmdbuf, HostPassCommandKind.Dispatch) == 1
        assert cmdbuf.commands.count > 0
        assert cmdbuf.commands[0].kind == HostPassCommandKind.BeginDebugLabel
        assert cmdbuf.commands[cmdbuf.commands.count - 1].kind == HostPassCommandKind.EndDebugLabel

@test
def host_passes_fsr_rcas_and_ring_rotation_contract() -> void:
    can Abort.Panic:
        HostPass_ResetGlobalsForTests()
        fsr: mutable FsrPass = FsrPass_new()
        FsrPass_Create(fsr, 0x33, 0, 2)
        cmdbuf: mutable HostPassCommandBuffer = HostPassCommandBuffer_new()
        settings: mutable FsrPassSettings = FsrPassSettings_default()
        settings.enable <- true
        settings.use_rcas <- true
        settings.rcas_attenuation <- 0.25

        first_out: u64 = FsrPass_Render(fsr, cmdbuf, 0x101, VkExtent2D_new(1280, 720), VkExtent2D_new(1920, 1080), settings, true)
        assert fsr.last_used_rcas
        assert fsr.last_rcas_constants.Sample[0] == 1
        assert HostPassCommandBuffer_CountKind(cmdbuf, HostPassCommandKind.Dispatch) == 2
        HostPassCommandBuffer_Clear(cmdbuf)

        second_out: u64 = FsrPass_Render(fsr, cmdbuf, 0x102, VkExtent2D_new(1280, 720), VkExtent2D_new(1920, 1080), settings, true)
        assert second_out != 0
        assert second_out != first_out
        assert fsr.cur_image == 0
        assert HostPassCommandBuffer_CountKind(cmdbuf, HostPassCommandKind.Dispatch) == 2

@test
def host_passes_fsr_resize_invalidate_contract() -> void:
    can Abort.Panic:
        HostPass_ResetGlobalsForTests()
        fsr: mutable FsrPass = FsrPass_new()
        FsrPass_Create(fsr, 0x44, 0, 3)
        assert fsr.available_imgs.count == 3
        FsrPass_ResizeAndInvalidate(fsr, 2560, 1440)
        assert fsr.cur_size.width == 2560
        assert fsr.cur_size.height == 1440
        i: mutable usize = 0
        while i < fsr.available_imgs.count:
            assert fsr.available_imgs[i].dirty
            i <- i + 1

@test
def host_passes_pp_force_color_path_contract() -> void:
    can Abort.Panic:
        HostPass_ResetGlobalsForTests()
        HostPass_SetForcePostProcessColor(true)
        HostPass_SetVkHostMarkersEnabled(true)
        pp: mutable PostProcessingPass = PostProcessingPass_new()
        PostProcessingPass_Create(pp, 0x55, 37)
        cmdbuf: mutable HostPassCommandBuffer = HostPassCommandBuffer_new()
        frame: VkPresenterFrame = host_passes_make_frame()
        settings: PostProcessingPassSettings = PostProcessingPassSettings_default()
        PostProcessingPass_Render(pp, cmdbuf, 0x200, VkExtent2D_new(1280, 720), frame, settings)
        assert HostPass_IsPostProcessForceColorLogged()
        assert HostPassCommandBuffer_CountKind(cmdbuf, HostPassCommandKind.Draw) == 0
        assert HostPassCommandBuffer_CountKind(cmdbuf, HostPassCommandKind.BindGraphicsPipeline) == 0
        assert HostPassCommandBuffer_CountKind(cmdbuf, HostPassCommandKind.BeginRendering) == 1
        assert HostPassCommandBuffer_CountKind(cmdbuf, HostPassCommandKind.EndRendering) == 1
        assert HostPassCommandBuffer_CountKind(cmdbuf, HostPassCommandKind.PipelineBarrier) == 1

@test
def host_passes_pp_normal_draw_contract() -> void:
    can Abort.Panic:
        HostPass_ResetGlobalsForTests()
        pp: mutable PostProcessingPass = PostProcessingPass_new()
        PostProcessingPass_Create(pp, 0x66, 39)
        cmdbuf: mutable HostPassCommandBuffer = HostPassCommandBuffer_new()
        frame: VkPresenterFrame = host_passes_make_frame()
        settings: mutable PostProcessingPassSettings = PostProcessingPassSettings_default()
        settings.gamma <- 1.0
        settings.hdr <- 1
        PostProcessingPass_Render(pp, cmdbuf, 0x201, VkExtent2D_new(1280, 720), frame, settings)
        assert HostPassCommandBuffer_CountKind(cmdbuf, HostPassCommandKind.BindGraphicsPipeline) == 1
        assert HostPassCommandBuffer_CountKind(cmdbuf, HostPassCommandKind.SetViewport) == 1
        assert HostPassCommandBuffer_CountKind(cmdbuf, HostPassCommandKind.SetScissor) == 1
        assert HostPassCommandBuffer_CountKind(cmdbuf, HostPassCommandKind.PushDescriptorSet) == 1
        assert HostPassCommandBuffer_CountKind(cmdbuf, HostPassCommandKind.PushConstants) == 1
        assert HostPassCommandBuffer_CountKind(cmdbuf, HostPassCommandKind.Draw) == 1
        assert HostPassCommandBuffer_CountKind(cmdbuf, HostPassCommandKind.PipelineBarrier) == 1

        push_constants: HostPassCommand? = HostPassCommandBuffer_FirstOfKind(cmdbuf, HostPassCommandKind.PushConstants)
        assert push_constants != null
        assert push_constants.value().gamma == 1.0
        assert push_constants.value().hdr == 1
