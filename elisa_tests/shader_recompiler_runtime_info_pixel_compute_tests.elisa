include "../shader_recompiler/runtime_info_pixel_compute.elisa"
include "../../compiler/runtime/elisacore_std/elisacore_runtime.elisa"

@test
def runtime_info_ps_input_is_default() -> void:
    can Abort.Panic:
        a: mutable PsInput = zeroed
        a.is_default <- true
        a.is_flat <- false
        assert PsInput_IsDefault(a.ref[PsInput&])
        a.is_flat <- true
        assert not PsInput_IsDefault(a.ref[PsInput&])

@test
def runtime_info_compute_equal() -> void:
    can Abort.Panic:
        a: mutable ComputeRuntimeInfo = zeroed
        b: mutable ComputeRuntimeInfo = zeroed
        a.workgroup_size[0usize] <- 8u32
        a.workgroup_size[1usize] <- 4u32
        a.workgroup_size[2usize] <- 1u32
        b.workgroup_size[0usize] <- 8u32
        b.workgroup_size[1usize] <- 4u32
        b.workgroup_size[2usize] <- 1u32
        a.tgid_enable[0usize] <- true
        b.tgid_enable[0usize] <- true
        # shared_memory_size differs but is ignored by equality.
        a.shared_memory_size <- 256u32
        b.shared_memory_size <- 512u32
        assert ComputeRuntimeInfo_Equal(a.ref[ComputeRuntimeInfo&], b.ref[ComputeRuntimeInfo&])
        b.workgroup_size[1usize] <- 16u32
        assert not ComputeRuntimeInfo_Equal(a.ref[ComputeRuntimeInfo&], b.ref[ComputeRuntimeInfo&])

@test
def runtime_info_fragment_equal() -> void:
    can Abort.Panic:
        a: mutable FragmentRuntimeInfo = zeroed
        b: mutable FragmentRuntimeInfo = zeroed
        a.num_inputs <- 2u32
        b.num_inputs <- 2u32
        a.inputs[0usize].param_index <- 3u8
        b.inputs[0usize].param_index <- 3u8
        assert FragmentRuntimeInfo_Equal(a.ref[FragmentRuntimeInfo&], b.ref[FragmentRuntimeInfo&])
        # Differing num_inputs -> false.
        b.num_inputs <- 3u32
        assert not FragmentRuntimeInfo_Equal(a.ref[FragmentRuntimeInfo&], b.ref[FragmentRuntimeInfo&])
        # Reset and differ an input within range -> false.
        b.num_inputs <- 2u32
        b.inputs[0usize].param_index <- 7u8
        assert not FragmentRuntimeInfo_Equal(a.ref[FragmentRuntimeInfo&], b.ref[FragmentRuntimeInfo&])

@test
def runtime_info_gs_max_output_streams() -> void:
    can Abort.Panic:
        assert GsMaxOutputStreams == 4u32
