include "../../compiler/runtime/elisacore_std/elisacore_runtime.elisa"
include "../core/libraries/np/np_profile_dialog/np_profile_dialog_ui.elisa"

@test
def np_profile_dialog_lifecycle_matches_cpp_contract() -> void:
    can Abort.Panic:
        np_profile_dialog_reset_for_tests()
        assert sceNpProfileDialogInitialize() == ORBIS_COMMON_DIALOG_ERROR_NOT_SYSTEM_INITIALIZED

        np_profile_dialog_set_common_dialog_initialized(true)
        assert sceNpProfileDialogInitialize() == ORBIS_COMMON_DIALOG_ERROR_OK
        assert sceNpProfileDialogInitialize() == ORBIS_COMMON_DIALOG_ERROR_ALREADY_INITIALIZED
        assert sceNpProfileDialogGetStatus() == ORBIS_COMMON_DIALOG_STATUS_INITIALIZED

        p: mutable OrbisNpProfileDialogParam = zeroed
        p.mode <- ORBIS_NP_PROFILE_DIALOG_MODE_NORMAL
        p.userId <- 1
        p.targetOnlineId.data[0] <- 84
        p.targetOnlineId.data[1] <- 111
        p.targetOnlineId.data[2] <- 114

        assert sceNpProfileDialogOpen(p) == ORBIS_COMMON_DIALOG_ERROR_OK
        assert sceNpProfileDialogGetStatus() == ORBIS_COMMON_DIALOG_STATUS_RUNNING
        assert g_np_profile_dialog_state.hasAccountId == false
        assert g_np_profile_dialog_state.userId == 1
        assert g_np_profile_dialog_state.onlineId.data[0] == 84

        early_result: mutable OrbisNpProfileDialogResult = zeroed
        assert sceNpProfileDialogGetResult(early_result) == ORBIS_COMMON_DIALOG_ERROR_NOT_FINISHED
        assert sceNpProfileDialogClose() == ORBIS_COMMON_DIALOG_ERROR_OK
        assert sceNpProfileDialogGetStatus() == ORBIS_COMMON_DIALOG_STATUS_FINISHED

        result: mutable OrbisNpProfileDialogResult = zeroed
        assert sceNpProfileDialogGetResult(result) == ORBIS_COMMON_DIALOG_ERROR_OK
        assert result.result == ORBIS_OK
        assert result.userAction == ORBIS_COMMON_DIALOG_RESULT_OK

        assert sceNpProfileDialogTerminate() == ORBIS_COMMON_DIALOG_ERROR_OK
        assert sceNpProfileDialogTerminate() == ORBIS_COMMON_DIALOG_ERROR_NOT_INITIALIZED

@test
def np_profile_dialog_account_id_variant_tracks_state() -> void:
    can Abort.Panic:
        np_profile_dialog_reset_for_tests()
        np_profile_dialog_set_common_dialog_initialized(true)
        assert sceNpProfileDialogInitialize() == ORBIS_COMMON_DIALOG_ERROR_OK

        p: mutable OrbisNpProfileDialogParamA = zeroed
        p.mode <- ORBIS_NP_PROFILE_DIALOG_MODE_GRIEF_REPORT
        p.userId <- 7
        p.targetAccountId <- 0x12345678

        assert sceNpProfileDialogOpenA(p) == ORBIS_COMMON_DIALOG_ERROR_OK
        assert g_np_profile_dialog_state.hasAccountId == true
        assert g_np_profile_dialog_state.accountId == 0x12345678
        assert g_np_profile_dialog_state.mode == ORBIS_NP_PROFILE_DIALOG_MODE_GRIEF_REPORT
        assert g_np_profile_dialog_state.userId == 7

        assert sceNpProfileDialogTerminate() == ORBIS_COMMON_DIALOG_ERROR_OK

@test
def np_profile_dialog_rejects_invalid_null_and_state_edges() -> void:
    can Abort.Panic:
        np_profile_dialog_reset_for_tests()
        assert sceNpProfileDialogOpen(null) == ORBIS_COMMON_DIALOG_ERROR_INVALID_STATE
        assert sceNpProfileDialogClose() == ORBIS_COMMON_DIALOG_ERROR_NOT_INITIALIZED

        np_profile_dialog_set_common_dialog_initialized(true)
        assert sceNpProfileDialogInitialize() == ORBIS_COMMON_DIALOG_ERROR_OK
        assert sceNpProfileDialogOpen(null) == ORBIS_COMMON_DIALOG_ERROR_ARG_NULL
        assert sceNpProfileDialogClose() == ORBIS_COMMON_DIALOG_ERROR_NOT_RUNNING

        p: mutable OrbisNpProfileDialogParam = zeroed
        p.mode <- ORBIS_NP_PROFILE_DIALOG_MODE_FRIEND_REQUEST
        assert sceNpProfileDialogOpen(p) == ORBIS_COMMON_DIALOG_ERROR_OK
        assert sceNpProfileDialogGetResult(null) == ORBIS_COMMON_DIALOG_ERROR_ARG_NULL

@test
def np_profile_dialog_ui_state_matches_cpp_finish_contract() -> void:
    can Abort.Panic:
        np_profile_dialog_reset_for_tests()
        np_profile_dialog_set_common_dialog_initialized(true)
        assert sceNpProfileDialogInitialize() == ORBIS_COMMON_DIALOG_ERROR_OK

        p: mutable OrbisNpProfileDialogParam = zeroed
        p.mode <- ORBIS_NP_PROFILE_DIALOG_MODE_ADD_TO_BLOCK_LIST
        assert sceNpProfileDialogOpen(p) == ORBIS_COMMON_DIALOG_ERROR_OK

        ui: mutable NpProfileDialogUi = NpProfileDialogUi_CreateFromCurrent()
        assert ui.active == true
        assert ui.firstRender == true
        assert NpProfileDialogUi_ModeTitle(p.mode) == "Block List"
        assert NpProfileDialogUi_ModeSubtitle(p.mode) == "Add to Block List"

        NpProfileDialogUi_Tick(ui, 0.25)
        assert ui.firstRender == false
        assert ui.openAlpha == 1.0

        NpProfileDialogUi_Finish(ui, ORBIS_COMMON_DIALOG_RESULT_USER_CANCELED)
        assert ui.active == false
        assert sceNpProfileDialogGetStatus() == ORBIS_COMMON_DIALOG_STATUS_FINISHED
        assert g_np_profile_dialog_result.result == ORBIS_OK
        assert g_np_profile_dialog_result.userAction == ORBIS_COMMON_DIALOG_RESULT_USER_CANCELED

@test
def np_profile_dialog_nids_match_cpp_registration_order() -> void:
    can Abort.Panic:
        assert NP_PROFILE_DIALOG_NIDS_COUNT == 9
        first: NpProfileDialogNidEntry = NpProfileDialog_NidEntryAt(0)
        assert first.nid == "uj9Cz7Tk0cc"
        assert first.lib_name == "libSceNpProfileDialogCompat"
        assert first.symbol_name == "sceNpProfileDialogOpen"

        normal_open: NpProfileDialogNidEntry = NpProfileDialog_NidEntryAt(5)
        assert normal_open.nid == "uj9Cz7Tk0cc"
        assert normal_open.lib_name == "libSceNpProfileDialog"

        last: NpProfileDialogNidEntry = NpProfileDialog_NidEntryAt(8)
        assert last.nid == "haVZE9FgKqE"
        assert last.symbol_name == "sceNpProfileDialogUpdateStatus"

@test
def np_profile_dialog_ui_layout_matches_cpp_constants() -> void:
    can Abort.Panic:
        layout: NpProfileDialogUiLayout = NpProfileDialogUi_Layout(1280.0, 720.0)
        assert layout.card.min.x == 400.0
        assert layout.card.min.y == 195.0
        assert layout.card.max.x == 880.0
        assert layout.card.max.y == 525.0
        assert layout.header.max.y == 239.0
        assert layout.footerTop == 469.0
        assert layout.avatarCenter.x == 640.0
        assert layout.avatarCenter.y == 299.0
        assert layout.closeButton.min.x == 754.0
        assert layout.closeButton.min.y == 480.0
        assert layout.closeButton.max.x == 864.0
        assert layout.closeButton.max.y == 514.0

        scaled: NpProfileDialogColor = NpProfileDialogColor_AlphaScale(NpProfileDialog_ColorOverlay(), 0.5)
        assert scaled.r == 0.0
        assert scaled.g == 0.0
        assert scaled.b == 0.0
        assert scaled.a > 0.324
        assert scaled.a < 0.326

@test
def np_profile_dialog_ui_draw_models_cpp_side_effects() -> void:
    can Abort.Panic:
        np_profile_dialog_reset_for_tests()
        np_profile_dialog_set_common_dialog_initialized(true)
        assert sceNpProfileDialogInitialize() == ORBIS_COMMON_DIALOG_ERROR_OK

        p: mutable OrbisNpProfileDialogParam = zeroed
        p.mode <- ORBIS_NP_PROFILE_DIALOG_MODE_NORMAL
        assert sceNpProfileDialogOpen(p) == ORBIS_COMMON_DIALOG_ERROR_OK

        ui: mutable NpProfileDialogUi = NpProfileDialogUi_CreateFromCurrent()
        first: NpProfileDialogUiDrawResult = NpProfileDialogUi_Draw(ui, 1280.0, 720.0, 0.01, true, false)
        assert first.drew == true
        assert first.requestedFocus == true
        assert first.title == "Profile"
        assert first.subtitle == "Player Profile"
        assert ui.firstRender == false

        second: NpProfileDialogUiDrawResult = NpProfileDialogUi_Draw(ui, 1280.0, 720.0, 0.01, true, false)
        assert second.drew == true
        assert second.requestedFocus == false

        no_nav: NpProfileDialogUiDrawResult = NpProfileDialogUi_Draw(ui, 1280.0, 720.0, 0.01, false, false)
        assert no_nav.drew == true
        assert no_nav.requestedFocus == true

        closed: NpProfileDialogUiDrawResult = NpProfileDialogUi_Draw(ui, 1280.0, 720.0, 0.01, true, true)
        assert closed.drew == true
        assert closed.closeHandled == true
        assert ui.active == false
        assert sceNpProfileDialogGetStatus() == ORBIS_COMMON_DIALOG_STATUS_FINISHED
        assert g_np_profile_dialog_result.userAction == ORBIS_COMMON_DIALOG_RESULT_USER_CANCELED
