include "../core/libraries/save_data/savedata_error.elisa"
include "../../compiler/runtime/elisacore_std/elisacore_runtime.elisa"

@test
def savedata_error_values() -> void:
    can Abort.Panic:
        assert SAVE_DATA_ERROR_OK == 0
        assert SAVE_DATA_ERROR_USER_SERVICE_NOT_INITIALIZED == 0x80960002
        assert SAVE_DATA_ERROR_PARAMETER == 0x809F0000
        assert SAVE_DATA_ERROR_NOT_FOUND == 0x809F0008
        assert SAVE_DATA_ERROR_BROKEN == 0x809F000F
        assert SAVE_DATA_ERROR_BUSY_FOR_SAVING == 0x809F0016
