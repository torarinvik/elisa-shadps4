include "../../compiler/runtime/elisacore_std/elisacore_runtime.elisa"
include "../core/libraries/avplayer/avplayer_harness.elisa"

const AVPLAYER_LOCAL_MP4_FIXTURE: static u8& = "/Users/torarinvikbjarko/Documents/Coding Projects/Go projects/Elisa-core/shadPS4/Games/CUSA05716/movies/Scene_39b_est_shot.mp4"
const AV_PIX_FMT_YUV420P_LOCAL: i32 = 0

global mutable g_avp_open_calls: i32 = 0
global mutable g_avp_close_calls: i32 = 0
global mutable g_avp_size_calls: i32 = 0
global mutable g_avp_read_calls: i32 = 0
global mutable g_avp_last_read_pos: u64 = 0u64
global mutable g_avp_last_read_len: u32 = 0u32
global mutable g_avp_short_read_limit: i32 = -1
global mutable g_avp_force_open_fail: bool = false
global mutable g_avp_video_decode_payload: u8[8388608] = zeroed
global mutable g_avp_audio_decode_payload: u8[1048576] = zeroed
global mutable g_avp_event_count: i32 = 0
global mutable g_avp_event_ids: i32[16] = zeroed

def avp_reset_file_probe():
    g_avp_open_calls <- 0
    g_avp_close_calls <- 0
    g_avp_size_calls <- 0
    g_avp_read_calls <- 0
    g_avp_last_read_pos <- 0u64
    g_avp_last_read_len <- 0u32
    g_avp_short_read_limit <- -1
    g_avp_force_open_fail <- false

def avp_reset_event_probe():
    g_avp_event_count <- 0
    i: mutable int = 0
    while i < 16:
        g_avp_event_ids[i] <- 0
        i <- i + 1

def avp_event_callback(object_ptr: void&?, event_id: i32, source_id: i32, event_data: void&?):
    _ = object_ptr
    _ = source_id
    _ = event_data
    if g_avp_event_count >= 0 and g_avp_event_count < 16:
        g_avp_event_ids[g_avp_event_count] <- event_id
    g_avp_event_count <- g_avp_event_count + 1

def avp_file_open(obj: void&?, name: i8&?) -> i32:
    _ = obj
    _ = name
    g_avp_open_calls <- g_avp_open_calls + 1
    if g_avp_force_open_fail:
        return -1
    return 7

def avp_file_close(obj: void&?) -> i32:
    _ = obj
    g_avp_close_calls <- g_avp_close_calls + 1
    return 0

def avp_file_read_offset(obj: void&?, buf: mutable u8&, pos: u64, length: u32) -> i32:
    _ = obj
    g_avp_read_calls <- g_avp_read_calls + 1
    g_avp_last_read_pos <- pos
    g_avp_last_read_len <- length
    i: mutable u32 = 0u32
    while i < length:
        buf[i.usize()] <- (pos + i.u64()).u8()
        i <- i + 1u32
    if g_avp_short_read_limit >= 0 and length > g_avp_short_read_limit.u32():
        return g_avp_short_read_limit
    return length.i32()

def avp_file_size(obj: void&?) -> u64:
    _ = obj
    g_avp_size_calls <- g_avp_size_calls + 1
    return 16u64

def avp_find_stream_by_type(handle: i32, wanted_type: u32) -> i32:
    count: i32 = avplayer_ffmpeg_stream_count(handle)
    if count <= 0:
        return -1
    i: mutable i32 = 0
    found: mutable i32 = -1
    while i < count and found < 0:
        typ: mutable u32 = 0
        duration: mutable u64 = 0
        start_time: mutable u64 = 0
        video_width: mutable u32 = 0
        video_height: mutable u32 = 0
        audio_channels: mutable u32 = 0
        audio_sample_rate: mutable u32 = 0
        if avplayer_ffmpeg_get_stream_info(handle, i.u32(), typ, duration, start_time, video_width, video_height, audio_channels, audio_sample_rate) == 0:
            if typ == wanted_type:
                found <- i
            else:
                codec_type: mutable i32 = -1
                raw_width: mutable i32 = 0
                raw_height: mutable i32 = 0
                raw_channels: mutable i32 = 0
                raw_sample_rate: mutable i32 = 0
                if avplayer_ffmpeg_get_stream_codecpar_shape(handle, i.u32(), codec_type, raw_width, raw_height, raw_channels, raw_sample_rate) == 0:
                    if wanted_type == AVPLAYER_STREAM_TYPE_VIDEO and raw_width > 0 and raw_height > 0:
                        found <- i
                    elif wanted_type == AVPLAYER_STREAM_TYPE_AUDIO and (raw_channels > 0 or raw_sample_rate > 0):
                        found <- i
        i <- i + 1
    return found

def avp_decode_one_fixture_stream_index(stream_index: i32, payload_is_video: bool) -> bool:
    handle: i32 = avplayer_ffmpeg_open(AVPLAYER_LOCAL_MP4_FIXTURE.cast[i8&?])
    if handle < 0:
        return false

    if stream_index < 0:
        avplayer_ffmpeg_close(handle)
        return false

    decoder: mutable void&? = avplayer_ffmpeg_find_decoder_for_stream(handle, stream_index.u32())
    if decoder == null:
        avplayer_ffmpeg_close(handle)
        return false

    codec_ctx: mutable void&? = avcodec_alloc_context3(decoder)
    if codec_ctx == null:
        avplayer_ffmpeg_close(handle)
        return false

    if avplayer_ffmpeg_copy_stream_params_to_codec_ctx(handle, stream_index.u32(), codec_ctx) < 0:
        avffmpeg_free_codec_context(codec_ctx)
        avplayer_ffmpeg_close(handle)
        return false

    options: mutable void&? = null
    if avcodec_open2(codec_ctx, decoder, options.ref[mutable void&?&]) < 0:
        avffmpeg_free_codec_context(codec_ctx)
        avplayer_ffmpeg_close(handle)
        return false

    _ = avplayer_ffmpeg_start(handle)
    ts: mutable u64 = 0
    audio_samples: mutable u32 = 0
    audio_sample_rate: mutable u32 = 0
    audio_channels: mutable u32 = 0
    video_width: mutable u32 = 0
    video_height: mutable u32 = 0
    video_pitch: mutable u32 = 0
    aspect_num: mutable u32 = 0
    aspect_den: mutable u32 = 0
    rc: i32 = avplayer_ffmpeg_decode_next_ts_copy(handle, stream_index.u32(), codec_ctx, ts, audio_samples, audio_sample_rate, audio_channels, video_width, video_height, video_pitch, aspect_num, aspect_den, null, 0, payload_is_video)

    avffmpeg_free_codec_context(codec_ctx)
    avplayer_ffmpeg_close(handle)

    if rc != 0:
        return false
    if payload_is_video:
        return video_width > 0 and video_height > 0
    return audio_samples > 0 and audio_sample_rate > 0

def avp_decode_one_fixture_stream_index_into_payload(stream_index: i32, payload_is_video: bool, payload: mutable u8&, payload_size: u32) -> bool:
    handle: i32 = avplayer_ffmpeg_open(AVPLAYER_LOCAL_MP4_FIXTURE.cast[i8&?])
    if handle < 0:
        return false

    if stream_index < 0:
        avplayer_ffmpeg_close(handle)
        return false

    decoder: mutable void&? = avplayer_ffmpeg_find_decoder_for_stream(handle, stream_index.u32())
    if decoder == null:
        avplayer_ffmpeg_close(handle)
        return false

    codec_ctx: mutable void&? = avcodec_alloc_context3(decoder)
    if codec_ctx == null:
        avplayer_ffmpeg_close(handle)
        return false

    if avplayer_ffmpeg_copy_stream_params_to_codec_ctx(handle, stream_index.u32(), codec_ctx) < 0:
        avffmpeg_free_codec_context(codec_ctx)
        avplayer_ffmpeg_close(handle)
        return false

    options: mutable void&? = null
    if avcodec_open2(codec_ctx, decoder, options.ref[mutable void&?&]) < 0:
        avffmpeg_free_codec_context(codec_ctx)
        avplayer_ffmpeg_close(handle)
        return false

    _ = avplayer_ffmpeg_start(handle)
    ts: mutable u64 = 0
    audio_samples: mutable u32 = 0
    audio_sample_rate: mutable u32 = 0
    audio_channels: mutable u32 = 0
    video_width: mutable u32 = 0
    video_height: mutable u32 = 0
    video_pitch: mutable u32 = 0
    aspect_num: mutable u32 = 0
    aspect_den: mutable u32 = 0
    rc: i32 = avplayer_ffmpeg_decode_next_ts_copy(handle, stream_index.u32(), codec_ctx, ts, audio_samples, audio_sample_rate, audio_channels, video_width, video_height, video_pitch, aspect_num, aspect_den, payload, payload_size, payload_is_video)

    avffmpeg_free_codec_context(codec_ctx)
    avplayer_ffmpeg_close(handle)

    if rc != 0:
        return false
    if payload_is_video:
        return video_width > 0 and video_height > 0
    return audio_samples > 0 and audio_sample_rate > 0

def avp_decode_one_fixture_stream(wanted_type: u32, payload_is_video: bool) -> bool:
    handle: i32 = avplayer_ffmpeg_open(AVPLAYER_LOCAL_MP4_FIXTURE.cast[i8&?])
    if handle < 0:
        return false
    stream_index: i32 = avp_find_stream_by_type(handle, wanted_type)
    avplayer_ffmpeg_close(handle)
    return avp_decode_one_fixture_stream_index(stream_index, payload_is_video)

def avp_prepare_fixture_handle_for_stream(wanted_type: u32) -> AvPlayerHandle:
    init_data: AvPlayerInitData = build_init_data()
    handle: AvPlayerHandle = sceAvPlayerInit(init_data.ref[mutable AvPlayerInitData&])
    if handle == 0:
        return 0
    if sceAvPlayerAddSource(handle, AVPLAYER_LOCAL_MP4_FIXTURE.cast[i8&?]) != ORBIS_OK:
        _ = sceAvPlayerClose(handle)
        return 0
    probe: i32 = avplayer_ffmpeg_open(AVPLAYER_LOCAL_MP4_FIXTURE.cast[i8&?])
    stream_index: i32 = avp_find_stream_by_type(probe, wanted_type)
    if probe >= 0:
        avplayer_ffmpeg_close(probe)
    if stream_index < 0:
        _ = sceAvPlayerClose(handle)
        return 0
    if sceAvPlayerEnableStream(handle, stream_index.u32()) != ORBIS_OK:
        _ = sceAvPlayerClose(handle)
        return 0
    return handle

def avp_prepare_started_fixture_handle_for_stream(wanted_type: u32) -> AvPlayerHandle:
    handle: AvPlayerHandle = avp_prepare_fixture_handle_for_stream(wanted_type)
    if handle == 0:
        return 0
    if sceAvPlayerStart(handle) != ORBIS_OK:
        _ = sceAvPlayerClose(handle)
        return 0
    return handle

def avp_prepare_fixture_handle() -> AvPlayerHandle:
    return avp_prepare_fixture_handle_for_stream(AVPLAYER_STREAM_TYPE_VIDEO)

def avp_event_seen(event_id: i32) -> bool:
    i: mutable int = 0
    while i < g_avp_event_count and i < 16:
        if g_avp_event_ids[i] == event_id:
            return true
        i <- i + 1
    return false

def avp_event_index(event_id: i32) -> i32:
    i: mutable int = 0
    while i < g_avp_event_count and i < 16:
        if g_avp_event_ids[i] == event_id:
            return i.i32()
        i <- i + 1
    return -1

@test
def avplayer_file_replacement_open_close_contract() -> void:
    can Thread.Spawn, Thread.Join, Abort.Panic:
        avp_reset_file_probe()

        init_data: AvPlayerInitData = build_init_data()
        init_data.file_replacement.object_ptr <- null
        init_data.file_replacement.open <- avp_file_open.cast[void&?]
        init_data.file_replacement.close <- avp_file_close.cast[void&?]
        init_data.file_replacement.read_offset <- avp_file_read_offset.cast[void&?]
        init_data.file_replacement.size <- avp_file_size.cast[void&?]

        handle: AvPlayerHandle = sceAvPlayerInit(init_data.ref[mutable AvPlayerInitData&])
        assert handle != 0
        assert sceAvPlayerAddSource(handle, "elisa://avplayer-callback".cast[i8&?]) == ORBIS_OK
        assert g_avp_open_calls == 1
        assert g_avp_size_calls == 1
        assert g_avp_close_calls == 0
        assert sceAvPlayerClose(handle) == ORBIS_OK
        assert g_avp_close_calls == 1

@test
def avplayer_file_replacement_open_failure_propagates() -> void:
    can Thread.Spawn, Thread.Join, Abort.Panic:
        avp_reset_file_probe()
        g_avp_force_open_fail <- true

        init_data: AvPlayerInitData = build_init_data()
        init_data.file_replacement.object_ptr <- null
        init_data.file_replacement.open <- avp_file_open.cast[void&?]
        init_data.file_replacement.close <- avp_file_close.cast[void&?]
        init_data.file_replacement.read_offset <- avp_file_read_offset.cast[void&?]
        init_data.file_replacement.size <- avp_file_size.cast[void&?]

        handle: AvPlayerHandle = sceAvPlayerInit(init_data.ref[mutable AvPlayerInitData&])
        assert handle != 0
        assert sceAvPlayerAddSource(handle, "elisa://avplayer-callback-fail".cast[i8&?]) == ORBIS_AVPLAYER_ERROR_OPERATION_FAILED
        assert g_avp_open_calls == 1
        assert g_avp_size_calls == 0
        assert g_avp_close_calls == 0
        assert sceAvPlayerClose(handle) == ORBIS_OK
        assert g_avp_close_calls == 0

@test
def avplayer_file_replacement_read_seek_reset_contract() -> void:
    can Thread.Spawn, Thread.Join, Abort.Panic:
        avp_reset_file_probe()

        init_data: AvPlayerInitData = build_init_data()
        init_data.file_replacement.object_ptr <- null
        init_data.file_replacement.open <- avp_file_open.cast[void&?]
        init_data.file_replacement.close <- avp_file_close.cast[void&?]
        init_data.file_replacement.read_offset <- avp_file_read_offset.cast[void&?]
        init_data.file_replacement.size <- avp_file_size.cast[void&?]

        handle: AvPlayerHandle = sceAvPlayerInit(init_data.ref[mutable AvPlayerInitData&])
        assert handle != 0
        assert sceAvPlayerAddSource(handle, "elisa://avplayer-read".cast[i8&?]) == ORBIS_OK
        slot: int = handle - 1

        buf: u8[8] = zeroed
        assert avsrc_file_read_packet(slot, buf[0].ref[mutable u8&], 6) == 6
        assert g_avp_read_calls == 1
        assert g_avp_last_read_pos == 0u64
        assert g_avp_last_read_len == 6u32
        assert avsrc_file_position[slot] == 6u64
        assert buf[0] == 0u8
        assert buf[5] == 5u8

        assert avsrc_file_seek(slot, 4, AVSRC_SEEK_SET) == 4
        assert avsrc_file_read_packet(slot, buf[0].ref[mutable u8&], 20) == 12
        assert g_avp_last_read_pos == 4u64
        assert g_avp_last_read_len == 12u32
        assert avsrc_file_position[slot] == 16u64
        assert avsrc_file_read_packet(slot, buf[0].ref[mutable u8&], 1) == -1

        assert avsrc_file_seek(slot, -5, AVSRC_SEEK_CUR) == 11
        assert avsrc_file_seek(slot, -100, AVSRC_SEEK_CUR) == 0
        assert avsrc_file_seek(slot, -3, AVSRC_SEEK_END) == 13
        assert avsrc_file_seek(slot, 0, AVSRC_AVSEEK_SIZE) == 16
        assert avsrc_file_seek(slot, 0, 99) == -1

        avsrc_file_reset(slot)
        assert avsrc_file_position[slot] == 0u64
        assert sceAvPlayerClose(handle) == ORBIS_OK

@test
def avplayer_file_replacement_replacing_source_closes_previous_fd() -> void:
    can Thread.Spawn, Thread.Join, Abort.Panic:
        avp_reset_file_probe()

        init_data: AvPlayerInitData = build_init_data()
        init_data.file_replacement.object_ptr <- null
        init_data.file_replacement.open <- avp_file_open.cast[void&?]
        init_data.file_replacement.close <- avp_file_close.cast[void&?]
        init_data.file_replacement.read_offset <- avp_file_read_offset.cast[void&?]
        init_data.file_replacement.size <- avp_file_size.cast[void&?]

        handle: AvPlayerHandle = sceAvPlayerInit(init_data.ref[mutable AvPlayerInitData&])
        assert handle != 0
        assert sceAvPlayerAddSource(handle, "elisa://first".cast[i8&?]) == ORBIS_OK
        assert sceAvPlayerAddSource(handle, "elisa://second".cast[i8&?]) == ORBIS_OK
        assert g_avp_open_calls == 2
        assert g_avp_close_calls == 1
        assert sceAvPlayerClose(handle) == ORBIS_OK
        assert g_avp_close_calls == 2

@test
def avplayer_ffmpeg_handle_table_contracts() -> void:
    can Abort.Panic:
        i: mutable int = 0
        while i < AVPLAYER_FFMPEG_MAX_HANDLES:
            avffmpeg_contexts[i] <- null
            avffmpeg_started[i] <- true
            avffmpeg_paused[i] <- true
            avffmpeg_next_ts_audio[i] <- 99
            avffmpeg_next_ts_video[i] <- 99
            i <- i + 1

        assert avplayer_ffmpeg_store_context(null) == -1

        first_ctx: void&? = 1.cast[void&?]
        second_ctx: void&? = 2.cast[void&?]
        assert avplayer_ffmpeg_store_context(first_ctx) == 1
        assert avffmpeg_contexts[0] == first_ctx
        assert avffmpeg_started[0] == false
        assert avffmpeg_paused[0] == false
        assert avffmpeg_next_ts_audio[0] == 0
        assert avffmpeg_next_ts_video[0] == 0

        i <- 1
        while i < AVPLAYER_FFMPEG_MAX_HANDLES:
            avffmpeg_contexts[i] <- (i + 10).cast[void&?]
            i <- i + 1
        assert avplayer_ffmpeg_store_context(second_ctx) == -1

        i <- 0
        while i < AVPLAYER_FFMPEG_MAX_HANDLES:
            avffmpeg_contexts[i] <- null
            i <- i + 1

@test
def avplayer_ffmpeg_local_mp4_decodes_video_when_fixture_exists() -> void:
    can Console.Write, Abort.Panic:
        probe: i32 = avplayer_ffmpeg_open(AVPLAYER_LOCAL_MP4_FIXTURE.cast[i8&?])
        if probe < 0:
            return
        stream_count: i32 = avplayer_ffmpeg_stream_count(probe)
        avplayer_ffmpeg_close(probe)
        assert stream_count > 0

        assert avp_decode_one_fixture_stream(AVPLAYER_STREAM_TYPE_VIDEO, true)

