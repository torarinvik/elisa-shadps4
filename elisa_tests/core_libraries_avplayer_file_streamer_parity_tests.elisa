@test
def avplayer_add_source_ex_validation_matches_cpp() -> void:
    can Thread.Spawn, Thread.Join, Abort.Panic:
        init_data: AvPlayerInitData = build_init_data()
        handle: AvPlayerHandle = sceAvPlayerInit(init_data.ref[mutable AvPlayerInitData&])
        assert handle != 0

        details: AvPlayerSourceDetailsRaw = zeroed
        details_ref: mutable AvPlayerSourceDetails&? = details.ref[mutable AvPlayerSourceDetailsRaw&].cast[mutable AvPlayerSourceDetails&?]
        assert sceAvPlayerAddSourceEx(handle, AVPLAYER_URI_TYPE_SOURCE, null) == ORBIS_AVPLAYER_ERROR_INVALID_PARAMS
        assert sceAvPlayerAddSourceEx(handle, 1u32, details_ref) == ORBIS_AVPLAYER_ERROR_INVALID_PARAMS

        details.uri_name <- 0usize
        details.uri_length <- 0u32
        details.source_type <- AVPLAYER_SOURCE_TYPE_UNKNOWN
        assert sceAvPlayerAddSourceEx(handle, AVPLAYER_URI_TYPE_SOURCE, details_ref) == ORBIS_AVPLAYER_ERROR_INVALID_PARAMS

        details.uri_name <- "video.mp4".cast[usize]
        details.uri_length <- 0u32
        details.source_type <- AVPLAYER_SOURCE_TYPE_UNKNOWN
        assert sceAvPlayerAddSourceEx(handle, AVPLAYER_URI_TYPE_SOURCE, details_ref) == ORBIS_AVPLAYER_ERROR_OPERATION_FAILED

        hls_name: i8&? = "playlist.m3u8".cast[i8&?]
        details.uri_name <- hls_name.cast[usize]
        details.uri_length <- runtime_strlen(hls_name.cast[u8&?]).u32()
        details.source_type <- AVPLAYER_SOURCE_TYPE_UNKNOWN
        assert sceAvPlayerAddSourceEx(handle, AVPLAYER_URI_TYPE_SOURCE, details_ref) == ORBIS_AVPLAYER_ERROR_NOT_SUPPORTED

        assert sceAvPlayerClose(handle) == ORBIS_OK

