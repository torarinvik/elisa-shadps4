@test
def avplayer_current_time_continues_while_paused_like_cpp() -> void:
    can Thread.Spawn, Thread.Join, Thread.Sleep, Abort.Panic:
        handle: AvPlayerHandle = avp_prepare_started_fixture_handle_for_stream(AVPLAYER_STREAM_TYPE_VIDEO)
        assert handle != 0
        t0: u64 = sceAvPlayerCurrentTime(handle)
        avp_spin_wait_ms(15)
        t1: u64 = sceAvPlayerCurrentTime(handle)
        assert t1 >= t0

        assert sceAvPlayerPause(handle) == ORBIS_OK
        p0: u64 = sceAvPlayerCurrentTime(handle)
        avp_spin_wait_ms(15)
        p1: u64 = sceAvPlayerCurrentTime(handle)
        assert p1 >= p0

        assert sceAvPlayerResume(handle) == ORBIS_OK
        avp_spin_wait_ms(15)
        r1: u64 = sceAvPlayerCurrentTime(handle)
        assert r1 >= p1
        assert sceAvPlayerClose(handle) == ORBIS_OK

