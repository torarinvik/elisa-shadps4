        return false

    codec_ctx: mutable void&? = avcodec_alloc_context3(decoder)
    if codec_ctx == null:
        avplayer_ffmpeg_close(handle)
        return false

    if avplayer_ffmpeg_copy_stream_params_to_codec_ctx(handle, stream_index.u32(), codec_ctx) < 0:
        avffmpeg_free_codec_context(codec_ctx)
        avplayer_ffmpeg_close(handle)
        return false

    options: mutable void&? = null
    if avcodec_open2(codec_ctx, decoder, options.ref[mutable void&?&]) < 0:
        avffmpeg_free_codec_context(codec_ctx)
        avplayer_ffmpeg_close(handle)
        return false

    _ = avplayer_ffmpeg_start(handle)
    ts: mutable u64 = 0
    audio_samples: mutable u32 = 0
    audio_sample_rate: mutable u32 = 0
    audio_channels: mutable u32 = 0
    video_width: mutable u32 = 0
    video_height: mutable u32 = 0
    video_pitch: mutable u32 = 0
    aspect_num: mutable u32 = 0
    aspect_den: mutable u32 = 0
    rc: i32 = avplayer_ffmpeg_decode_next_ts_copy(handle, stream_index.u32(), codec_ctx, ts, audio_samples, audio_sample_rate, audio_channels, video_width, video_height, video_pitch, aspect_num, aspect_den, payload, payload_size, payload_is_video)

    avffmpeg_free_codec_context(codec_ctx)
    avplayer_ffmpeg_close(handle)

    if rc != 0:
        return false
    if payload_is_video:
        return video_width > 0 and video_height > 0
    return audio_samples > 0 and audio_sample_rate > 0

def avp_decode_one_raw_fixture_video_frame(handle: i32, stream_index: i32, codec_ctx: void&?, out_frame: mutable void&?) -> bool:
    if handle < 0 or stream_index < 0 or codec_ctx == null or out_frame == null:
        return false
    ctx: void&? = avplayer_ffmpeg_context(handle)
    if ctx == null:
        return false
    pkt: mutable void&? = av_packet_alloc()
    if pkt == null:
        return false
    i: mutable i32 = 0
    found: mutable bool = false
    while i < 512 and not found:
        read_rc: i32 = av_read_frame(ctx, pkt)
        if read_rc < 0:
            i <- 512
        else:
            packet_view: AVPacketPublicPrefix& = pkt.cast[AVPacketPublicPrefix&]
            if packet_view.stream_index == stream_index:
                send_rc: i32 = avcodec_send_packet(codec_ctx, pkt)
                if send_rc >= 0:
                    draining: mutable bool = true
                    while draining and not found:
                        recv_rc: i32 = avcodec_receive_frame(codec_ctx, out_frame)
                        if recv_rc == 0:
                            found <- true
                            draining <- false
                        elif recv_rc == AVERROR_EAGAIN_LINUX or recv_rc == AVERROR_EAGAIN_DARWIN:
                            draining <- false
                        else:
                            draining <- false
            av_packet_unref(pkt)
            i <- i + 1
    avffmpeg_free_packet(pkt)
    return found

def avp_decode_one_raw_fixture_audio_frame(handle: i32, stream_index: i32, codec_ctx: void&?, out_frame: mutable void&?) -> bool:
