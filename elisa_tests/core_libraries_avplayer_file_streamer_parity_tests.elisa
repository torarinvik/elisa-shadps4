@test
def avplayer_start_restarts_active_source_like_cpp() -> void:
    can Thread.Spawn, Thread.Join, Thread.Sleep, Abort.Panic:
        avp_reset_event_probe()
        init_data: AvPlayerInitData = build_init_data()
        init_data.event_replacement.object_ptr <- null
        init_data.event_replacement.event_callback <- avp_event_callback.cast[void&?]
        handle: AvPlayerHandle = sceAvPlayerInit(init_data.ref[mutable AvPlayerInitData&])
        assert handle != 0
        assert sceAvPlayerAddSource(handle, AVPLAYER_LOCAL_MP4_FIXTURE.cast[i8&?]) == ORBIS_OK
        assert sceAvPlayerEnableStream(handle, 0) == ORBIS_OK
        assert sceAvPlayerStart(handle) == ORBIS_OK
        first_play_index: i32 = avp_event_index(AVPLAYER_EVENTS_STATE_PLAY)
        assert first_play_index >= 0

        # Restart while already active should produce Stop then Play in order.
        assert sceAvPlayerStart(handle) == ORBIS_OK
        stop_index: mutable i32 = -1
        second_play_index: mutable i32 = -1
        i: mutable i32 = 0
        while i < g_avp_event_count and i < 16:
            ev: i32 = g_avp_event_ids[i.int()]
            if i > first_play_index and stop_index < 0 and ev == AVPLAYER_EVENTS_STATE_STOP:
                stop_index <- i
            if i > first_play_index and ev == AVPLAYER_EVENTS_STATE_PLAY:
                second_play_index <- i
                i <- g_avp_event_count
            else:
                i <- i + 1
        assert stop_index > first_play_index
        assert second_play_index > stop_index

        assert sceAvPlayerIsActive(handle)
        video: AvPlayerFrameInfoEx = zeroed
        assert sceAvPlayerGetVideoDataEx(handle, video.ref[mutable AvPlayerFrameInfoEx&])
        assert video.p_data != null
        assert sceAvPlayerStop(handle) == ORBIS_OK
        assert sceAvPlayerClose(handle) == ORBIS_OK

