@test
def avplayer_post_init_updates_vdec2_mode_for_future_source_only() -> void:
    can Thread.Spawn, Thread.Join, Abort.Panic:
        init_data: AvPlayerInitData = build_init_data()
        handle: AvPlayerHandle = sceAvPlayerInit(init_data.ref[mutable AvPlayerInitData&])
        assert handle != 0
        slot: int = handle - 1
        assert not g_handle_use_vdec2[slot]
        assert not avsrc_use_vdec2[slot]

        post: AvPlayerPostInitData = zeroed
        post.video_decoder_init.decoder_type_raw <- AVPLAYER_VIDEO_DECODER_TYPE_SOFTWARE2
        assert sceAvPlayerPostInit(handle, post.ref[mutable AvPlayerPostInitData&]) == ORBIS_OK
        assert g_handle_use_vdec2[slot]
        # No source attached yet, so source-side mode mirrors handle mode.
        assert avsrc_use_vdec2[slot]

        assert sceAvPlayerAddSource(handle, AVPLAYER_LOCAL_MP4_FIXTURE.cast[i8&?]) == ORBIS_OK
        assert avsrc_use_vdec2[slot]

        # PostInit after AddSource should not mutate active source mode.
        post.video_decoder_init.decoder_type_raw <- 0u32
        assert sceAvPlayerPostInit(handle, post.ref[mutable AvPlayerPostInitData&]) == ORBIS_OK
        assert not g_handle_use_vdec2[slot]
        assert avsrc_use_vdec2[slot]
        assert sceAvPlayerClose(handle) == ORBIS_OK

@test
def avplayer_post_init_invalid_params() -> void:
