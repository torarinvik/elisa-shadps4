def avp_decode_one_fixture_stream(wanted_type: u32, payload_is_video: bool) -> bool:
    handle: i32 = avplayer_ffmpeg_open(AVPLAYER_LOCAL_MP4_FIXTURE.cast[i8&?])
    if handle < 0:
        return false
    stream_index: i32 = avp_find_stream_by_type(handle, wanted_type)
    avplayer_ffmpeg_close(handle)
    return avp_decode_one_fixture_stream_index(stream_index, payload_is_video)

def avp_prepare_fixture_handle_for_stream(wanted_type: u32) -> AvPlayerHandle:
    init_data: AvPlayerInitData = build_init_data()
    # Keep this helper deterministic: disable implicit auto-start by providing
    # an explicit callback pointer (C++ only auto-starts on null callback or
    # explicit auto_start=true).
    init_data.event_replacement.object_ptr <- null
    init_data.event_replacement.event_callback <- avplayer_null_event_callback.cast[void&?]
    handle: AvPlayerHandle = sceAvPlayerInit(init_data.ref[mutable AvPlayerInitData&])
    if handle == 0:
        return 0
    if sceAvPlayerAddSource(handle, AVPLAYER_LOCAL_MP4_FIXTURE.cast[i8&?]) != ORBIS_OK:
        _ = sceAvPlayerClose(handle)
        return 0
    probe: i32 = avplayer_ffmpeg_open(AVPLAYER_LOCAL_MP4_FIXTURE.cast[i8&?])
    stream_index: i32 = avp_find_stream_by_type(probe, wanted_type)
    if probe >= 0:
        avplayer_ffmpeg_close(probe)
    if stream_index < 0:
        _ = sceAvPlayerClose(handle)
        return 0
    if sceAvPlayerEnableStream(handle, stream_index.u32()) != ORBIS_OK:
        _ = sceAvPlayerClose(handle)
        return 0
    return handle

def avp_prepare_started_fixture_handle_for_stream(wanted_type: u32) -> AvPlayerHandle:
    handle: AvPlayerHandle = avp_prepare_fixture_handle_for_stream(wanted_type)
    if handle == 0:
        return 0
    if sceAvPlayerStart(handle) != ORBIS_OK:
        _ = sceAvPlayerClose(handle)
        return 0
    return handle

def avp_prepare_fixture_handle() -> AvPlayerHandle:
    return avp_prepare_fixture_handle_for_stream(AVPLAYER_STREAM_TYPE_VIDEO)

def avp_event_seen(event_id: i32) -> bool:
    i: mutable int = 0
    while i < g_avp_event_count and i < 64:
        if g_avp_event_ids[i] == event_id:
            return true
        i <- i + 1
    return false

def avp_event_index(event_id: i32) -> i32:
    i: mutable int = 0
    while i < g_avp_event_count and i < 64:
        if g_avp_event_ids[i] == event_id:
            return i.i32()
        i <- i + 1
    return -1

def avp_warning_seen(warning_id: i32) -> bool:
    i: mutable int = 0
    while i < g_avp_warning_count and i < 64:
        if g_avp_warning_values[i] == warning_id:
            return true
        i <- i + 1
    return false

def avp_spin_wait_ms(ms: i64):
    start_ns: i64 = high_resolution_now_ns()
    target_delta: i64 = ms * 1000000
    while (high_resolution_now_ns() - start_ns) < target_delta:
        _ = start_ns

@test
def avplayer_file_replacement_open_close_contract() -> void:
    can Thread.Spawn, Thread.Join, Abort.Panic:
        avp_reset_file_probe()

        init_data: AvPlayerInitData = build_init_data()
        init_data.file_replacement.object_ptr <- null
        init_data.file_replacement.open <- avp_file_open.cast[void&?]
        init_data.file_replacement.close <- avp_file_close.cast[void&?]
        init_data.file_replacement.read_offset <- avp_file_read_offset.cast[void&?]
        init_data.file_replacement.size <- avp_file_size.cast[void&?]

        handle: AvPlayerHandle = sceAvPlayerInit(init_data.ref[mutable AvPlayerInitData&])
        assert handle != 0
        assert sceAvPlayerAddSource(handle, "elisa://avplayer-callback".cast[i8&?]) == ORBIS_OK
        assert g_avp_open_calls == 1
        assert g_avp_size_calls == 1
        assert g_avp_close_calls == 0
        assert sceAvPlayerClose(handle) == ORBIS_OK
        assert g_avp_close_calls == 1

@test
def avplayer_file_replacement_open_failure_propagates() -> void:
    can Thread.Spawn, Thread.Join, Abort.Panic:
        avp_reset_file_probe()
        g_avp_force_open_fail <- true

        init_data: AvPlayerInitData = build_init_data()
        init_data.file_replacement.object_ptr <- null
        init_data.file_replacement.open <- avp_file_open.cast[void&?]
        init_data.file_replacement.close <- avp_file_close.cast[void&?]
        init_data.file_replacement.read_offset <- avp_file_read_offset.cast[void&?]
        init_data.file_replacement.size <- avp_file_size.cast[void&?]

        handle: AvPlayerHandle = sceAvPlayerInit(init_data.ref[mutable AvPlayerInitData&])
        assert handle != 0
        assert sceAvPlayerAddSource(handle, "elisa://avplayer-callback-fail".cast[i8&?]) == ORBIS_AVPLAYER_ERROR_OPERATION_FAILED
        assert g_avp_open_calls == 1
        assert g_avp_size_calls == 0
        assert g_avp_close_calls == 0
        assert sceAvPlayerClose(handle) == ORBIS_OK
        assert g_avp_close_calls == 0

@test
def avplayer_file_replacement_read_seek_reset_contract() -> void:
    can Thread.Spawn, Thread.Join, Abort.Panic:
        avp_reset_file_probe()

        init_data: AvPlayerInitData = build_init_data()
        init_data.file_replacement.object_ptr <- null
        init_data.file_replacement.open <- avp_file_open.cast[void&?]
        init_data.file_replacement.close <- avp_file_close.cast[void&?]
        init_data.file_replacement.read_offset <- avp_file_read_offset.cast[void&?]
        init_data.file_replacement.size <- avp_file_size.cast[void&?]

        handle: AvPlayerHandle = sceAvPlayerInit(init_data.ref[mutable AvPlayerInitData&])
        assert handle != 0
        assert sceAvPlayerAddSource(handle, "elisa://avplayer-read".cast[i8&?]) == ORBIS_OK
        slot: int = handle - 1

        buf: u8[8] = zeroed
        assert avsrc_file_read_packet(slot, buf[0].ref[mutable u8&], 6) == 6
        assert g_avp_read_calls == 1
        assert g_avp_last_read_pos == 0u64
        assert g_avp_last_read_len == 6u32
        assert avsrc_file_position[slot] == 6u64
        assert buf[0] == 0u8
        assert buf[5] == 5u8

        assert avsrc_file_seek(slot, 4, AVSRC_SEEK_SET) == 4
        assert avsrc_file_read_packet(slot, buf[0].ref[mutable u8&], 20) == 12
        assert g_avp_last_read_pos == 4u64
        assert g_avp_last_read_len == 12u32
        assert avsrc_file_position[slot] == 16u64
        assert avsrc_file_read_packet(slot, buf[0].ref[mutable u8&], 1) == -1

        assert avsrc_file_seek(slot, -5, AVSRC_SEEK_CUR) == 11
        assert avsrc_file_seek(slot, -100, AVSRC_SEEK_CUR) == 0
        assert avsrc_file_seek(slot, -3, AVSRC_SEEK_END) == 13
        assert avsrc_file_seek(slot, 0, AVSRC_AVSEEK_SIZE) == 16
        assert avsrc_file_seek(slot, 0, 99) == -1

        avsrc_file_reset(slot)
        assert avsrc_file_position[slot] == 0u64
        assert sceAvPlayerClose(handle) == ORBIS_OK

@test
def avplayer_file_replacement_second_source_is_rejected_like_cpp() -> void:
    can Thread.Spawn, Thread.Join, Abort.Panic:
        avp_reset_file_probe()

        init_data: AvPlayerInitData = build_init_data()
        init_data.file_replacement.object_ptr <- null
        init_data.file_replacement.open <- avp_file_open.cast[void&?]
        init_data.file_replacement.close <- avp_file_close.cast[void&?]
        init_data.file_replacement.read_offset <- avp_file_read_offset.cast[void&?]
        init_data.file_replacement.size <- avp_file_size.cast[void&?]

        handle: AvPlayerHandle = sceAvPlayerInit(init_data.ref[mutable AvPlayerInitData&])
        assert handle != 0
        assert sceAvPlayerAddSource(handle, "elisa://first".cast[i8&?]) == ORBIS_OK
        assert sceAvPlayerAddSource(handle, "elisa://second".cast[i8&?]) == ORBIS_AVPLAYER_ERROR_OPERATION_FAILED
        # C++ keeps the original source alive and does not reopen/close on second add.
        assert g_avp_open_calls == 1
        assert g_avp_close_calls == 0
        assert sceAvPlayerClose(handle) == ORBIS_OK
        assert g_avp_close_calls == 1

@test
def avplayer_ffmpeg_handle_table_contracts() -> void:
    can Abort.Panic:
        i: mutable int = 0
        while i < AVPLAYER_FFMPEG_MAX_HANDLES:
            avffmpeg_contexts[i] <- null
            avffmpeg_started[i] <- true
            avffmpeg_paused[i] <- true
            avffmpeg_next_ts_audio[i] <- 99
            avffmpeg_next_ts_video[i] <- 99
            i <- i + 1

        assert avplayer_ffmpeg_store_context(null) == -1

        first_ctx: void&? = 1.cast[void&?]
        second_ctx: void&? = 2.cast[void&?]
        assert avplayer_ffmpeg_store_context(first_ctx) == 1
        assert avffmpeg_contexts[0] == first_ctx
        assert avffmpeg_started[0] == false
        assert avffmpeg_paused[0] == false
        assert avffmpeg_next_ts_audio[0] == 0
        assert avffmpeg_next_ts_video[0] == 0

        i <- 1
        while i < AVPLAYER_FFMPEG_MAX_HANDLES:
            avffmpeg_contexts[i] <- (i + 10).cast[void&?]
            i <- i + 1
        assert avplayer_ffmpeg_store_context(second_ctx) == -1

        i <- 0
        while i < AVPLAYER_FFMPEG_MAX_HANDLES:
            avffmpeg_contexts[i] <- null
            i <- i + 1

@test
def avplayer_ffmpeg_local_mp4_decodes_video_when_fixture_exists() -> void:
    can Console.Write, Abort.Panic:
        probe: i32 = avplayer_ffmpeg_open(AVPLAYER_LOCAL_MP4_FIXTURE.cast[i8&?])
        if probe < 0:
            return
        stream_count: i32 = avplayer_ffmpeg_stream_count(probe)
        avplayer_ffmpeg_close(probe)
        assert stream_count > 0

        assert avp_decode_one_fixture_stream(AVPLAYER_STREAM_TYPE_VIDEO, true)

@test
def avplayer_ffmpeg_local_mp4_decodes_audio_when_fixture_exists() -> void:
    can Console.Write, Abort.Panic:
        probe: i32 = avplayer_ffmpeg_open(AVPLAYER_LOCAL_MP4_FIXTURE.cast[i8&?])
        if probe < 0:
            return
        stream_count: i32 = avplayer_ffmpeg_stream_count(probe)
        avplayer_ffmpeg_close(probe)
        assert stream_count > 0

        assert avp_decode_one_fixture_stream(AVPLAYER_STREAM_TYPE_AUDIO, false)

@test
def avplayer_ffmpeg_local_mp4_copies_video_payload_when_fixture_exists() -> void:
    can Console.Write, Abort.Panic:
        probe: i32 = avplayer_ffmpeg_open(AVPLAYER_LOCAL_MP4_FIXTURE.cast[i8&?])
        if probe < 0:
            return
        stream_index: i32 = avp_find_stream_by_type(probe, AVPLAYER_STREAM_TYPE_VIDEO)
        avplayer_ffmpeg_close(probe)
        assert stream_index >= 0

