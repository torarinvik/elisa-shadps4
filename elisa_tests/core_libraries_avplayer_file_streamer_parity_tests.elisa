@test
def avplayer_event_callback_reports_ready_then_play_for_started_fixture() -> void:
    can Thread.Spawn, Thread.Join, Thread.Sleep, Abort.Panic:
        avp_reset_event_probe()
        init_data: AvPlayerInitData = build_init_data()
        init_data.event_replacement.object_ptr <- null
        init_data.event_replacement.event_callback <- avp_event_callback.cast[void&?]
        handle: AvPlayerHandle = sceAvPlayerInit(init_data.ref[mutable AvPlayerInitData&])
        assert handle != 0
        assert sceAvPlayerAddSource(handle, AVPLAYER_LOCAL_MP4_FIXTURE.cast[i8&?]) == ORBIS_OK
        assert avp_event_seen(AVPLAYER_EVENTS_STATE_READY)
        assert sceAvPlayerEnableStream(handle, 0) == ORBIS_OK
        assert sceAvPlayerStart(handle) == ORBIS_OK
        assert avp_event_seen(AVPLAYER_EVENTS_STATE_PLAY)
        ready_index: i32 = avp_event_index(AVPLAYER_EVENTS_STATE_READY)
        play_index: i32 = avp_event_index(AVPLAYER_EVENTS_STATE_PLAY)
        assert ready_index >= 0
        assert play_index >= 0
        assert ready_index < play_index
        assert sceAvPlayerClose(handle) == ORBIS_OK

@test
def avplayer_auto_start_enters_active_playback_after_ready() -> void:
    can Thread.Spawn, Thread.Join, Thread.Sleep, Abort.Panic:
        avp_reset_event_probe()
        init_data: AvPlayerInitData = build_init_data()
        init_data.auto_start <- true
        init_data.event_replacement.object_ptr <- null
        init_data.event_replacement.event_callback <- avp_event_callback.cast[void&?]
