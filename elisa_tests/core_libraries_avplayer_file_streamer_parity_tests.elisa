        assert sceAvPlayerPostInit(0, post.ref[mutable AvPlayerPostInitData&]) == ORBIS_AVPLAYER_ERROR_INVALID_PARAMS
        init_data: AvPlayerInitData = build_init_data()
        handle: AvPlayerHandle = sceAvPlayerInit(init_data.ref[mutable AvPlayerInitData&])
        assert handle != 0
        assert sceAvPlayerPostInit(handle, null) == ORBIS_AVPLAYER_ERROR_INVALID_PARAMS
        assert sceAvPlayerClose(handle) == ORBIS_OK

@test
def avplayer_init_requires_all_allocators_like_cpp() -> void:
    can Thread.Spawn, Thread.Join, Abort.Panic:
        init_data: AvPlayerInitData = build_init_data()
        init_data.memory_replacement.allocate_texture <- zeroed
        assert sceAvPlayerInit(init_data.ref[mutable AvPlayerInitData&]) == 0

        init_ex: AvPlayerInitDataEx = zeroed
        init_ex.memory_replacement.allocate <- harness_alloc
        init_ex.memory_replacement.deallocate <- harness_dealloc
        init_ex.memory_replacement.allocate_texture <- harness_alloc
        init_ex.memory_replacement.deallocate_texture <- harness_dealloc
        out_handle: mutable AvPlayerHandle = 0
        assert sceAvPlayerInitEx(init_ex.ref[AvPlayerInitDataEx&], out_handle.ref[mutable AvPlayerHandle&]) == ORBIS_OK
        assert out_handle != 0
        assert sceAvPlayerClose(out_handle) == ORBIS_OK

        init_ex.memory_replacement.deallocate_texture <- zeroed
        out_handle <- 0
        assert sceAvPlayerInitEx(init_ex.ref[AvPlayerInitDataEx&], out_handle.ref[mutable AvPlayerHandle&]) == ORBIS_AVPLAYER_ERROR_INVALID_PARAMS
        assert out_handle == 0
