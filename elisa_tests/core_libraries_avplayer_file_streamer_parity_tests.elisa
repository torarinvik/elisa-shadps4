@test
def avplayer_get_stream_info_zeroes_output_on_failure_like_cpp() -> void:
    can Thread.Spawn, Thread.Join, Abort.Panic:
        init_data: AvPlayerInitData = build_init_data()
        handle: AvPlayerHandle = sceAvPlayerInit(init_data.ref[mutable AvPlayerInitData&])
        assert handle != 0
        assert sceAvPlayerAddSource(handle, AVPLAYER_LOCAL_MP4_FIXTURE.cast[i8&?]) == ORBIS_OK
        stream_count: i32 = sceAvPlayerStreamCount(handle)
        assert stream_count > 0
        bad_stream_id: u32 = (stream_count.u32() + 99u32)
        info: AvPlayerStreamInfo = zeroed
        info.typ <- 0xdeadbeefu32
        info.duration <- 0xffffffffffffffffu64
        assert sceAvPlayerGetStreamInfo(handle, bad_stream_id, info.ref[mutable AvPlayerStreamInfo&]) == ORBIS_AVPLAYER_ERROR_OPERATION_FAILED
        assert sceAvPlayerClose(handle) == ORBIS_OK

