@test
def avplayer_ffmpeg_copy_decoded_payload_respects_nv12_linesize() -> void:
    can Abort.Panic:
        frame: mutable AVFramePublicPrefix = zeroed
        frame.width <- 4
        frame.height <- 2
        frame.linesize[0] <- 8
        frame.linesize[1] <- 8

        y_plane: mutable u8[16] = zeroed
        uv_plane: mutable u8[8] = zeroed
        y_plane[0] <- 1u8
        y_plane[1] <- 2u8
        y_plane[2] <- 3u8
        y_plane[3] <- 4u8
        y_plane[4] <- 0xffu8
        y_plane[5] <- 0xffu8
        y_plane[6] <- 0xffu8
        y_plane[7] <- 0xffu8
        y_plane[8] <- 5u8
        y_plane[9] <- 6u8
        y_plane[10] <- 7u8
        y_plane[11] <- 8u8
        y_plane[12] <- 0xeeu8
        y_plane[13] <- 0xeeu8
        y_plane[14] <- 0xeeu8
        y_plane[15] <- 0xeeu8
        uv_plane[0] <- 10u8
        uv_plane[1] <- 11u8
        uv_plane[2] <- 12u8
        uv_plane[3] <- 13u8
        uv_plane[4] <- 0xddu8
        uv_plane[5] <- 0xddu8
        uv_plane[6] <- 0xddu8
        uv_plane[7] <- 0xddu8

        frame.data[0] <- y_plane[0].ref[mutable u8&]
        frame.data[1] <- uv_plane[0].ref[mutable u8&]

        payload: mutable u8[12] = zeroed
        avffmpeg_copy_decoded_payload(frame.ref[AVFramePublicPrefix&], payload[0].ref[mutable u8&], 12u32, true)

        assert payload[0] == 1u8
        assert payload[1] == 2u8
        assert payload[2] == 3u8
        assert payload[3] == 4u8
        assert payload[4] == 5u8
        assert payload[5] == 6u8
        assert payload[6] == 7u8
        assert payload[7] == 8u8
        assert payload[8] == 10u8
        assert payload[9] == 11u8
        assert payload[10] == 12u8
        assert payload[11] == 13u8

@test
def avplayer_ffmpeg_convert_video_to_nv12_converts_yuv420p_frame() -> void:
    can Abort.Panic:
        frame: mutable void&? = av_frame_alloc()
        assert frame != null

        src: mutable AVFramePublicPrefix& = frame.cast[mutable AVFramePublicPrefix&]
        src.format <- AV_PIX_FMT_YUV420P_LOCAL
        src.width <- 4
        src.height <- 4
        assert av_frame_get_buffer(frame, 0) == 0

        converted: mutable void&? = avffmpeg_convert_video_to_nv12(frame)
        assert converted != null
        assert converted != frame

        out: AVFramePublicPrefix& = converted.cast[AVFramePublicPrefix&]
        assert out.format == AV_PIX_FMT_NV12
        assert out.width == 4
        assert out.height == 4
        assert out.data[0] != null
        assert out.data[1] != null
        assert out.linesize[0] >= 4
        assert out.linesize[1] >= 4

        avffmpeg_free_frame(converted)
        avffmpeg_free_frame(frame)

@test
def avplayer_ffmpeg_convert_audio_to_s16_converts_fltp_frame() -> void:
    can Abort.Panic:
        frame: mutable void&? = av_frame_alloc()
        assert frame != null

        src: mutable AVFramePublicPrefix& = frame.cast[mutable AVFramePublicPrefix&]
        src.format <- AV_SAMPLE_FMT_FLTP
        src.nb_samples <- 4
        src.sample_rate <- 48000
        av_channel_layout_default(src.ch_layout.ref[mutable void&], 2)
        assert av_frame_get_buffer(frame, 0) == 0

        converted: mutable void&? = avffmpeg_convert_audio_to_s16(frame)
        assert converted != null
        assert converted != frame

        out: AVFramePublicPrefix& = converted.cast[AVFramePublicPrefix&]
        assert out.format == AV_SAMPLE_FMT_S16
        assert out.nb_samples == 4
        assert out.sample_rate == 48000
        assert out.ch_layout.nb_channels == 2

        avffmpeg_free_frame(converted)
        avffmpeg_free_frame(frame)

@test
def avplayer_ffmpeg_copy_frame_metadata_and_payload_converts_fltp_to_s16_bytes() -> void:
    can Abort.Panic:
        frame: mutable void&? = av_frame_alloc()
        assert frame != null

        src: mutable AVFramePublicPrefix& = frame.cast[mutable AVFramePublicPrefix&]
        src.format <- AV_SAMPLE_FMT_FLTP
        src.nb_samples <- 4
        src.sample_rate <- 48000
        av_channel_layout_default(src.ch_layout.ref[mutable void&], 2)
        assert av_frame_get_buffer(frame, 0) == 0

        # L channel = +1.0f (0x3f800000), R channel = -1.0f (0xbf800000)
        left: mutable u8&? = src.data[0]
        right: mutable u8&? = src.data[1]
        assert left != null
        assert right != null
        i: mutable u32 = 0
        while i < 4u32:
            base: usize = (i * 4u32).usize()
            left[base + 0usize] <- 0x00u8
            left[base + 1usize] <- 0x00u8
            left[base + 2usize] <- 0x80u8
            left[base + 3usize] <- 0x3fu8
            right[base + 0usize] <- 0x00u8
            right[base + 1usize] <- 0x00u8
            right[base + 2usize] <- 0x80u8
            right[base + 3usize] <- 0xbfu8
            i <- i + 1u32

        payload: mutable u8[16] = zeroed
        out_audio_samples: mutable u32 = 0
        out_audio_sample_rate: mutable u32 = 0
        out_audio_channels: mutable u32 = 0
        out_video_width: mutable u32 = 0
        out_video_height: mutable u32 = 0
        out_video_pitch: mutable u32 = 0
        out_video_aspect_num: mutable u32 = 0
        out_video_aspect_den: mutable u32 = 0
        avffmpeg_copy_frame_metadata_and_payload(frame, payload[0].ref[mutable u8&], 16u32, false, out_audio_samples, out_audio_sample_rate, out_audio_channels, out_video_width, out_video_height, out_video_pitch, out_video_aspect_num, out_video_aspect_den)

        assert out_audio_samples == 4u32
        assert out_audio_sample_rate == 48000u32
        assert out_audio_channels == 2u32
        # Interleaved s16 expected: L=0x7fff, R=0x8000 (little-endian).
        assert payload[0] == 0xffu8
        assert payload[1] == 0x7fu8
        assert payload[2] == 0x00u8
        assert payload[3] == 0x80u8

        avffmpeg_free_frame(frame)

