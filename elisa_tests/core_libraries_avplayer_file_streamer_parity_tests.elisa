        assert handle != 0
        assert sceAvPlayerAddSource(handle, AVPLAYER_LOCAL_MP4_FIXTURE.cast[i8&?]) == ORBIS_OK
        assert sceAvPlayerIsActive(handle)
        # C++ consumes StateReady in the internal autoplay callback and only
        # forwards subsequent state events to the guest callback.
        assert not avp_event_seen(AVPLAYER_EVENTS_STATE_READY)
        assert avp_event_seen(AVPLAYER_EVENTS_STATE_PLAY)
        assert sceAvPlayerClose(handle) == ORBIS_OK

