        assert handle != 0
        audio: AvPlayerFrameInfo = zeroed
        assert sceAvPlayerGetAudioData(handle, audio.ref[mutable AvPlayerFrameInfo&])

        _ = sceAvPlayerClose(handle)

@test
def avplayer_frame_output_struct_layout_matches_cpp() -> void:
    can Abort.Panic:
        assert size_of(AvPlayerStreamDetailsVideo) == 16usize
        assert size_of(AvPlayerStreamDetailsAudio) == 16usize
        assert size_of(AvPlayerStreamDetailsTimedText) == 16usize
        assert size_of(AvPlayerStreamDetails) == 16usize

        assert size_of(AvPlayerStreamDetailsVideoEx) == 80usize
        assert size_of(AvPlayerStreamDetailsAudioEx) == 80usize
        assert size_of(AvPlayerStreamDetailsTimedTextEx) == 80usize
        assert size_of(AvPlayerStreamDetailsEx) == 80usize

        assert size_of(AvPlayerFrameInfo) == 40usize
        assert size_of(AvPlayerStreamInfo) == 40usize
        assert size_of(AvPlayerFrameInfoEx) == 104usize
