        video: AvPlayerFrameInfoEx = zeroed
        assert sceAvPlayerGetVideoDataEx(handle, video.ref[mutable AvPlayerFrameInfoEx&])
        avplayer_controller_tick(slot)
        assert avp_event_seen(AVPLAYER_EVENTS_WARNING_ID)
        assert avp_warning_seen(ORBIS_AVPLAYER_ERROR_WAR_LOOPING_BACK)
        assert sceAvPlayerClose(handle) == ORBIS_OK

@test
def avplayer_buffering_transition_emits_buffering_then_play_events() -> void:
    can Thread.Spawn, Thread.Join, Thread.Sleep, Abort.Panic:
        avp_reset_event_probe()
        init_data: AvPlayerInitData = build_init_data()
        init_data.event_replacement.object_ptr <- null
        init_data.event_replacement.event_callback <- avp_event_callback.cast[void&?]
        handle: AvPlayerHandle = sceAvPlayerInit(init_data.ref[mutable AvPlayerInitData&])
        assert handle != 0
        assert sceAvPlayerAddSource(handle, AVPLAYER_LOCAL_MP4_FIXTURE.cast[i8&?]) == ORBIS_OK
        assert sceAvPlayerEnableStream(handle, 0) == ORBIS_OK
        assert sceAvPlayerStart(handle) == ORBIS_OK
        slot: int = handle - 1
        play_index_before: i32 = avp_event_index(AVPLAYER_EVENTS_STATE_PLAY)
        assert play_index_before >= 0

        avs_update_buffering_state(slot, false, false)
        avplayer_controller_tick(slot)
        avs_update_buffering_state(slot, true, true)
        avplayer_controller_tick(slot)

        buffering_index: mutable i32 = -1
        play_index_after: mutable i32 = -1
        i: mutable i32 = 0
        while i < g_avp_event_count and i < 64:
            ev: i32 = g_avp_event_ids[i.int()]
            if i > play_index_before and buffering_index < 0 and ev == AVPLAYER_EVENTS_STATE_BUFFERING:
                buffering_index <- i
            if i > play_index_before and buffering_index >= 0 and ev == AVPLAYER_EVENTS_STATE_PLAY:
                play_index_after <- i
                i <- g_avp_event_count
            else:
                i <- i + 1
        assert buffering_index > play_index_before
        assert play_index_after > buffering_index
        assert sceAvPlayerClose(handle) == ORBIS_OK

@test
def avplayer_disable_stream_is_stubbed_and_does_not_mutate_source_like_cpp() -> void:
    can Thread.Spawn, Thread.Join, Thread.Sleep, Abort.Panic:
        init_data: AvPlayerInitData = build_init_data()
        handle: AvPlayerHandle = sceAvPlayerInit(init_data.ref[mutable AvPlayerInitData&])
        assert handle != 0
        assert sceAvPlayerAddSource(handle, AVPLAYER_LOCAL_MP4_FIXTURE.cast[i8&?]) == ORBIS_OK
        slot: int = handle - 1
        ffmpeg_handle: i32 = avsrc_ffmpeg_handle[slot]
        video_index: i32 = avp_find_stream_by_type(ffmpeg_handle, AVPLAYER_STREAM_TYPE_VIDEO)
        audio_index: i32 = avp_find_stream_by_type(ffmpeg_handle, AVPLAYER_STREAM_TYPE_AUDIO)
        assert video_index >= 0
        assert audio_index >= 0
        assert sceAvPlayerEnableStream(handle, video_index.u32()) == ORBIS_OK
        assert sceAvPlayerEnableStream(handle, audio_index.u32()) == ORBIS_OK

        # Seed synthetic queue/eof state for both streams and verify disable is a no-op.
        avsrc_video_q_size[slot] <- 2
        avsrc_video_pkt_q_size[slot] <- 1
        avsrc_video_eof[slot] <- true
        avsrc_audio_q_size[slot] <- 3
        avsrc_audio_pkt_q_size[slot] <- 1
        avsrc_audio_eof[slot] <- true

        assert sceAvPlayerDisableStream(handle, video_index.u32()) == ORBIS_OK
        assert avsrc_video_enabled[slot]
        assert avsrc_video_q_size[slot] == 2
        assert avsrc_video_pkt_q_size[slot] == 1
        assert avsrc_video_eof[slot]
        assert avsrc_audio_enabled[slot]
        assert avsrc_audio_q_size[slot] == 3
        assert avsrc_audio_pkt_q_size[slot] == 1
        assert avsrc_audio_eof[slot]

        assert sceAvPlayerClose(handle) == ORBIS_OK

@test
def avplayer_public_api_invalid_handle_contracts() -> void:
    can Abort.Panic:
        bad_handle: AvPlayerHandle = 0
        assert sceAvPlayerStart(bad_handle) == ORBIS_AVPLAYER_ERROR_INVALID_PARAMS
        assert sceAvPlayerStop(bad_handle) == ORBIS_AVPLAYER_ERROR_INVALID_PARAMS
        assert sceAvPlayerPause(bad_handle) == ORBIS_AVPLAYER_ERROR_INVALID_PARAMS
        assert sceAvPlayerResume(bad_handle) == ORBIS_AVPLAYER_ERROR_INVALID_PARAMS
        assert sceAvPlayerJumpToTime(bad_handle, 0u64) == ORBIS_AVPLAYER_ERROR_INVALID_PARAMS
        assert sceAvPlayerSetLooping(bad_handle, true) == ORBIS_AVPLAYER_ERROR_INVALID_PARAMS
        assert sceAvPlayerEnableStream(bad_handle, 0u32) == ORBIS_AVPLAYER_ERROR_INVALID_PARAMS
        assert sceAvPlayerDisableStream(bad_handle, 0u32) == ORBIS_AVPLAYER_ERROR_INVALID_PARAMS
        assert not sceAvPlayerIsActive(bad_handle)
        assert sceAvPlayerCurrentTime(bad_handle) == ORBIS_AVPLAYER_ERROR_INVALID_PARAMS.u64()

