@test
def avplayer_ffmpeg_copy_decoded_payload_respects_nv12_linesize() -> void:
    can Abort.Panic:
        frame: mutable AVFramePublicPrefix = zeroed
        frame.width <- 4
        frame.height <- 2
        frame.linesize[0] <- 8
        frame.linesize[1] <- 8

        y_plane: mutable u8[16] = zeroed
        uv_plane: mutable u8[8] = zeroed
        y_plane[0] <- 1u8
        y_plane[1] <- 2u8
        y_plane[2] <- 3u8
        y_plane[3] <- 4u8
        y_plane[4] <- 0xffu8
        y_plane[5] <- 0xffu8
        y_plane[6] <- 0xffu8
        y_plane[7] <- 0xffu8
        y_plane[8] <- 5u8
        y_plane[9] <- 6u8
        y_plane[10] <- 7u8
        y_plane[11] <- 8u8
        y_plane[12] <- 0xeeu8
        y_plane[13] <- 0xeeu8
        y_plane[14] <- 0xeeu8
        y_plane[15] <- 0xeeu8
        uv_plane[0] <- 10u8
        uv_plane[1] <- 11u8
        uv_plane[2] <- 12u8
        uv_plane[3] <- 13u8
        uv_plane[4] <- 0xddu8
        uv_plane[5] <- 0xddu8
        uv_plane[6] <- 0xddu8
        uv_plane[7] <- 0xddu8

        frame.data[0] <- y_plane[0].ref[mutable u8&]
        frame.data[1] <- uv_plane[0].ref[mutable u8&]

        payload: mutable u8[12] = zeroed
        avffmpeg_copy_decoded_payload(frame.ref[AVFramePublicPrefix&], payload[0].ref[mutable u8&], 12u32, true)

        assert payload[0] == 1u8
        assert payload[1] == 2u8
        assert payload[2] == 3u8
        assert payload[3] == 4u8
        assert payload[4] == 5u8
        assert payload[5] == 6u8
        assert payload[6] == 7u8
        assert payload[7] == 8u8
        assert payload[8] == 10u8
        assert payload[9] == 11u8
        assert payload[10] == 12u8
        assert payload[11] == 13u8

@test
def avplayer_ffmpeg_copy_decoded_payload_supports_aligned_nv12_destination_layout() -> void:
    can Abort.Panic:
        frame: mutable AVFramePublicPrefix = zeroed
        frame.width <- 4
        frame.height <- 2
        frame.linesize[0] <- 4
        frame.linesize[1] <- 4

        y_plane: mutable u8[8] = zeroed
        uv_plane: mutable u8[4] = zeroed
        y_plane[0] <- 1u8
        y_plane[1] <- 2u8
        y_plane[2] <- 3u8
        y_plane[3] <- 4u8
        y_plane[4] <- 5u8
        y_plane[5] <- 6u8
        y_plane[6] <- 7u8
        y_plane[7] <- 8u8
        uv_plane[0] <- 9u8
        uv_plane[1] <- 10u8
        uv_plane[2] <- 11u8
        uv_plane[3] <- 12u8

        frame.data[0] <- y_plane[0].ref[mutable u8&]
        frame.data[1] <- uv_plane[0].ref[mutable u8&]

        payload: mutable u8[384] = zeroed
        avffmpeg_copy_decoded_payload(frame.ref[AVFramePublicPrefix&], payload[0].ref[mutable u8&], 384u32, true)

        # Luma rows are written at aligned (16-byte) row stride.
        assert payload[0] == 1u8
        assert payload[1] == 2u8
        assert payload[2] == 3u8
        assert payload[3] == 4u8
        assert payload[16] == 5u8
        assert payload[17] == 6u8
        assert payload[18] == 7u8
        assert payload[19] == 8u8

        # UV plane starts at aligned luma size: 16 * 16 = 256.
        assert payload[256] == 9u8
        assert payload[257] == 10u8
        assert payload[258] == 11u8
        assert payload[259] == 12u8
        # Padding remains zeroed.
        assert payload[4] == 0u8
        assert payload[20] == 0u8

