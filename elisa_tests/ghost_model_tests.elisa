#
# Dogfood for ghost-state spec refinement (STATIC verification): prove the concrete end-address
# arithmetic of a guest mapping REFINES an abstract model. `model_end` is verification-only (erased
# at codegen, zero layout/constructor impact) and fixes the spec value; the struct invariant ties
# the concrete fields to it, and the accessor proves its concrete computation equals the abstract
# model on every exit. Verified with: elisac -emit semantic -strict -smt (discharges, 0 obligations).
#
# NOTE: ghost models are a STATIC construct — verify with -strict -smt, not -emit test. See
# verification_findings/ghost-model-dogfood.md for the ghost-referencing-ensure runtime-check leak.

include "../../compiler/runtime/elisacore_std/elisacore_runtime.elisa"
include "../common/types.elisa"

struct MappedWindow:
    base: u64
    size: u64
    ghost model_end: u64                          # verification-only spec value, erased at codegen
    invariant self.model_end == self.base + self.size

# The concrete end-address computation is proven to agree with the abstract model — so any code
# trusting model_end is backed by the real arithmetic, checked once here.
def window_end(self: MappedWindow&) -> u64:
    ensure result == self.model_end
    return self.base + self.size
