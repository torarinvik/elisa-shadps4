include "../shader_recompiler/frontend/opcode_unified_vop1.elisa"
include "../../compiler/runtime/elisacore_std/elisacore_runtime.elisa"

@test
def opcode_unified_vop1_values() -> void:
    can Abort.Panic:
        assert OPCODE_V_NOP == OPCODE_MAP_OP_MAP_VOP1
        assert OPCODE_V_MOV_B32 == 1u32 + OPCODE_MAP_OP_MAP_VOP1
        assert OPCODE_V_INTERP_P1_F32 == OPCODE_MAP_OP_MAP_VINTRP
        assert OPCODE_V_INTERP_P2_F32 == 1u32 + OPCODE_MAP_OP_MAP_VINTRP
        assert OPCODE_V_NOP != OPCODE_V_SQRT_F16
