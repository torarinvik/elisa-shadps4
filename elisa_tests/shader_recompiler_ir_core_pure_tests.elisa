include "../../compiler/runtime/elisacore_std/elisacore_runtime.elisa"
include "../shader_recompiler/ir/ir_emitter.elisa"
include "../shader_recompiler/ir/post_order.elisa"

@test
def shader_ir_type_attribute_patch_opcode_core_parity() -> void:
    can Abort.Panic:
        assert ShaderIrType_NameOf(IR_TYPE_VOID) == "Void"
        assert ShaderIrType_AreTypesCompatible(IR_TYPE_OPAQUE, IR_TYPE_U32)
        assert ShaderIrType_AreTypesCompatible(IR_TYPE_U32, IR_TYPE_U32)
        assert not ShaderIrType_AreTypesCompatible(IR_TYPE_U32, IR_TYPE_F32)

        assert ShaderIrAttribute_IsPosition(IR_ATTRIBUTE_POSITION0)
        assert ShaderIrAttribute_IsParam(IR_ATTRIBUTE_PARAM31)
        assert ShaderIrAttribute_IsMrt(IR_ATTRIBUTE_RENDERTARGET7)
        assert ShaderIrAttribute_NameOf(IR_ATTRIBUTE_SAMPLEINDEX) == "SampleIndex"

        assert ShaderIrPatch_IsGeneric(IR_PATCH_COMPONENT0)
        assert ShaderIrPatch_GenericPatchIndex(IR_PATCH_COMPONENT7) == 0u32
        assert ShaderIrPatch_GenericPatchElement(IR_PATCH_COMPONENT7) == 1u32
        assert ShaderIrPatch_NameOf(IR_PATCH_TESSELLATIONLODLEFT) == "TessellationLodLeft"

        assert IR_OPCODE_COUNT > 300u32
        assert ShaderIrOpcode_NameOf(IR_OPCODE_IADD32) == "IAdd32"
        assert ShaderIrOpcode_TypeOf(IR_OPCODE_IADD32) == IR_TYPE_U32
        assert ShaderIrOpcode_NumArgsOf(IR_OPCODE_IADD32) == 2u32
        assert ShaderIrOpcode_ArgTypeOf(IR_OPCODE_IADD32, 0u32) == IR_TYPE_U32

@test
def shader_ir_value_block_program_and_postorder_core_parity() -> void:
    can Abort.Panic:
        info: ShaderIrProgramInfo = ShaderIrProgramInfo(1u32, 0x1122u64)
        program: mutable ShaderIrProgram = ShaderIrProgram_New(info)

        b0: u32 = ShaderIrProgram_AddBlock(program.ref[mutable ShaderIrProgram&])
        b1: u32 = ShaderIrProgram_AddBlock(program.ref[mutable ShaderIrProgram&])
        b2: u32 = ShaderIrProgram_AddBlock(program.ref[mutable ShaderIrProgram&])

        args: mutable ShaderIrValue[6] = zeroed
        args[0] <- ShaderIrValue_FromU32(2u32)
        args[1] <- ShaderIrValue_FromU32(3u32)
        i0: u32 = ShaderIrProgram_AppendInst(program.ref[mutable ShaderIrProgram&], b0, IR_OPCODE_IADD32, args, 2u32, 0u64)
        _ = i0

        ShaderIrBlock_AddBranch(program.blocks[b0.usize()].ref[mutable ShaderIrBlock&], b1, program.blocks[b1.usize()].ref[mutable ShaderIrBlock&])
        ShaderIrBlock_AddBranch(program.blocks[b1.usize()].ref[mutable ShaderIrBlock&], b2, program.blocks[b2.usize()].ref[mutable ShaderIrBlock&])

        root: ShaderIrAbstractSyntaxNode = ShaderIrAbstractSyntaxNode_Block(b0)
        order: ShaderIrBlockList = ShaderIrPostOrder(program, root)
        assert order.count == 3u32

        assert ShaderIrBlock_Size(program.blocks[b0.usize()]) == 1u32
        assert ShaderIrOpcode_NameOf(program.blocks[b0.usize()].insts[0].opcode) == "IAdd32"

@test
def shader_ir_microinstruction_and_emitter_core_parity() -> void:
    can Abort.Panic:
        info: ShaderIrProgramInfo = ShaderIrProgramInfo(2u32, 0x3344u64)
        program: mutable ShaderIrProgram = ShaderIrProgram_New(info)
        b0: u32 = ShaderIrProgram_AddBlock(program.ref[mutable ShaderIrProgram&])

        emitter: mutable ShaderIrEmitter = ShaderIrEmitter_New(b0)

        v1: ShaderIrValue = ShaderIrEmitter_Imm32FromU32(1u32)
        v2: ShaderIrValue = ShaderIrEmitter_Imm32FromU32(2u32)
        _ = v2

        args: mutable ShaderIrValue[6] = zeroed
        args[0] <- v1
        _ = ShaderIrEmitter_EmitNoFlags(program.ref[mutable ShaderIrProgram&], emitter.ref[mutable ShaderIrEmitter&], IR_OPCODE_GETSCC, args, 0u32)
        _ = ShaderIrEmitter_Prologue(program.ref[mutable ShaderIrProgram&], emitter.ref[mutable ShaderIrEmitter&])
        _ = ShaderIrEmitter_Discard_2(program.ref[mutable ShaderIrProgram&], emitter.ref[mutable ShaderIrEmitter&], ShaderIrValue_FromU1(true))

        inst: ShaderIrInst = program.blocks[b0.usize()].insts[1]
        assert ShaderIrInst_MayHaveSideEffects(inst)

        # Build identity/use pair and replace uses.
        args_id: mutable ShaderIrValue[6] = zeroed
        args_id[0] <- ShaderIrValue_FromU32(77u32)
        id_idx: u32 = ShaderIrProgram_AppendInst(program.ref[mutable ShaderIrProgram&], b0, IR_OPCODE_IDENTITY, args_id, 1u32, 0u64)

        args_use: mutable ShaderIrValue[6] = zeroed
        args_use[0] <- ShaderIrValue_FromInst(b0, id_idx)
        args_use[1] <- ShaderIrValue_FromU32(1u32)
        use_idx: u32 = ShaderIrProgram_AppendInst(program.ref[mutable ShaderIrProgram&], b0, IR_OPCODE_IADD32, args_use, 2u32, 0u64)
        _ = use_idx

        ShaderIrProgram_RecomputeUses(program.ref[mutable ShaderIrProgram&])
        assert program.blocks[b0.usize()].insts[id_idx.usize()].use_count > 0u32

        ShaderIrInst_ReplaceUsesWithAndRemove(program.ref[mutable ShaderIrProgram&], b0, id_idx, ShaderIrValue_FromU32(99u32))
        assert program.blocks[b0.usize()].insts[id_idx.usize()].opcode == IR_OPCODE_VOID
