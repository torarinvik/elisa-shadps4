include "../../compiler/runtime/elisacore_std/elisacore_runtime.elisa"
include "../shader_recompiler/ir/ir_emitter.elisa"
include "../shader_recompiler/ir/post_order.elisa"
include "../shader_recompiler/ir/opcodes_tables.elisa"

@test
def shader_ir_type_attribute_patch_opcode_core_parity() -> void:
    can Abort.Panic:
        assert ShaderIrType_NameOf(IR_TYPE_VOID) == "Void"
        assert ShaderIrType_AreTypesCompatible(IR_TYPE_OPAQUE, IR_TYPE_U32)
        assert ShaderIrType_AreTypesCompatible(IR_TYPE_U32, IR_TYPE_U32)
        assert not ShaderIrType_AreTypesCompatible(IR_TYPE_U32, IR_TYPE_F32)

        assert ShaderIrAttribute_IsPosition(IR_ATTRIBUTE_POSITION0)
        assert ShaderIrAttribute_IsParam(IR_ATTRIBUTE_PARAM31)
        assert ShaderIrAttribute_IsMrt(IR_ATTRIBUTE_RENDERTARGET7)
        assert ShaderIrAttribute_NameOf(IR_ATTRIBUTE_SAMPLEINDEX) == "SampleIndex"

        assert ShaderIrPatch_IsGeneric(IR_PATCH_COMPONENT0)
        # Component7 = Component0 + 7; patches group 4 elements each, so it is
        # patch index 7/4 = 1, element 7%4 = 3 (matches shadPS4 C++).
        assert ShaderIrPatch_GenericPatchIndex(IR_PATCH_COMPONENT7) == 1
        assert ShaderIrPatch_GenericPatchElement(IR_PATCH_COMPONENT7) == 3
        assert ShaderIrPatch_NameOf(IR_PATCH_TESSELLATIONLODLEFT) == "TessellationLodLeft"

        assert IR_OPCODE_COUNT > 300
        assert ShaderIrOpcode_NameOf(IR_OPCODE_IADD32) == "IAdd32"
        assert ShaderIrOpcode_TypeOf(IR_OPCODE_IADD32) == IR_TYPE_U32
        assert ShaderIrOpcode_NumArgsOf(IR_OPCODE_IADD32) == 2
        assert ShaderIrOpcode_ArgTypeOf(IR_OPCODE_IADD32, 0) == IR_TYPE_U32

@test
def shader_ir_value_block_program_and_postorder_core_parity() -> void:
    can Abort.Panic:
        info: ShaderIrProgramInfo = ShaderIrProgramInfo(1, 0x1122)
        program: mutable heap ShaderIrProgram& = ShaderIrProgram_New(info)

        b0: u32 = ShaderIrProgram_AddBlock(program)
        b1: u32 = ShaderIrProgram_AddBlock(program)
        b2: u32 = ShaderIrProgram_AddBlock(program)

        args: mutable ShaderIrValue[6] = zeroed
        args[0] <- ShaderIrValue_FromU32(2)
        args[1] <- ShaderIrValue_FromU32(3)
        i0: u32 = ShaderIrProgram_AppendInst(program, b0, IR_OPCODE_IADD32, args, 2, 0)
        _ = i0

        ShaderIrBlock_AddBranch(program.blocks[b0.usize()], b1, program.blocks[b1.usize()])
        ShaderIrBlock_AddBranch(program.blocks[b1.usize()], b2, program.blocks[b2.usize()])

        root: ShaderIrAbstractSyntaxNode = ShaderIrAbstractSyntaxNode_Block(b0)
        order: ShaderIrBlockList = ShaderIrPostOrder(program, root)
        assert order.count == 3

        assert ShaderIrBlock_Size(program.blocks[b0.usize()]) == 1
        assert ShaderIrOpcode_NameOf(program.blocks[b0.usize()].insts[0].opcode) == "IAdd32"

@test
def shader_ir_microinstruction_and_emitter_core_parity() -> void:
    can Abort.Panic:
        info: ShaderIrProgramInfo = ShaderIrProgramInfo(2, 0x3344)
        program: mutable heap ShaderIrProgram& = ShaderIrProgram_New(info)
        b0: u32 = ShaderIrProgram_AddBlock(program)

        emitter: mutable ShaderIrEmitter = ShaderIrEmitter_New(b0)

        v1: ShaderIrValue = ShaderIrEmitter_Imm32FromU32(1)
        v2: ShaderIrValue = ShaderIrEmitter_Imm32FromU32(2)
        _ = v2

        args: mutable ShaderIrValue[6] = zeroed
        args[0] <- v1
        _ = ShaderIrEmitter_EmitNoFlags(program, emitter, IR_OPCODE_GETSCC, args, 0)
        _ = ShaderIrEmitter_Prologue(program, emitter)
        _ = ShaderIrEmitter_Discard_2(program, emitter, ShaderIrValue_FromU1(true))

        inst: ShaderIrInst = program.blocks[b0.usize()].insts[1]
        assert ShaderIrInst_MayHaveSideEffects(inst)

        # Build identity/use pair and replace uses.
        args_id: mutable ShaderIrValue[6] = zeroed
        args_id[0] <- ShaderIrValue_FromU32(77)
        id_idx: u32 = ShaderIrProgram_AppendInst(program, b0, IR_OPCODE_IDENTITY, args_id, 1, 0)

        args_use: mutable ShaderIrValue[6] = zeroed
        args_use[0] <- ShaderIrValue_FromInst(b0, id_idx)
        args_use[1] <- ShaderIrValue_FromU32(1)
        use_idx: u32 = ShaderIrProgram_AppendInst(program, b0, IR_OPCODE_IADD32, args_use, 2, 0)
        _ = use_idx

        ShaderIrProgram_RecomputeUses(program)
        assert program.blocks[b0.usize()].insts[id_idx.usize()].use_count > 0

        ShaderIrInst_ReplaceUsesWithAndRemove(program, b0, id_idx, ShaderIrValue_FromU32(99))
        assert program.blocks[b0.usize()].insts[id_idx.usize()].opcode == IR_OPCODE_VOID

@test
def shader_ir_emitter_accepts_refined_register_indices() -> void:
    can Abort.Panic:
        info: ShaderIrProgramInfo = ShaderIrProgramInfo(2, 0x5566)
        program: mutable heap ShaderIrProgram& = ShaderIrProgram_New(info)
        b0: u32 = ShaderIrProgram_AddBlock(program)
        emitter: mutable ShaderIrEmitter = ShaderIrEmitter_New(b0)

        sgpr: ShaderIrScalarRegIndex = 12
        vgpr: ShaderIrVectorRegIndex = 240

        _ = ShaderIrEmitter_GetScalarRegIndex(program, emitter, sgpr)
        _ = ShaderIrEmitter_SetScalarRegIndex(program, emitter, sgpr, ShaderIrValue_FromU32(99))
        _ = ShaderIrEmitter_GetVectorRegIndex(program, emitter, vgpr)
        _ = ShaderIrEmitter_SetVectorRegIndex(program, emitter, vgpr, ShaderIrValue_FromF32(1.0))

        block: ShaderIrBlock = program.blocks[b0.usize()]
        assert block.inst_count == 5
        assert block.insts[0].opcode == IR_OPCODE_GETSCALARREGISTER
        assert block.insts[0].args[0].type_bits == IR_TYPE_SCALARREG
        assert ShaderIrValue_ScalarReg(block.insts[0].args[0]) == 12

        assert block.insts[1].opcode == IR_OPCODE_SETSCALARREGISTER
        assert ShaderIrValue_ScalarReg(block.insts[1].args[0]) == 12

        assert block.insts[2].opcode == IR_OPCODE_GETVECTORREGISTER
        assert block.insts[2].args[0].type_bits == IR_TYPE_VECTORREG
        assert ShaderIrValue_VectorReg(block.insts[2].args[0]) == 240

        assert block.insts[3].opcode == IR_OPCODE_BITCASTU32F32
        assert block.insts[4].opcode == IR_OPCODE_SETVECTORREGISTER
        assert ShaderIrValue_VectorReg(block.insts[4].args[0]) == 240

@test
def shader_ir_values_roundtrip_refined_register_indices() -> void:
    can Abort.Panic:
        sgpr: ShaderIrScalarRegIndex = 103
        vgpr: ShaderIrVectorRegIndex = 255

        scalar_value: ShaderIrValue = ShaderIrValue_FromScalarRegIndex(sgpr)
        vector_value: ShaderIrValue = ShaderIrValue_FromVectorRegIndex(vgpr)
        scalar_roundtrip: mutable ShaderIrScalarRegIndex = 0
        vector_roundtrip: mutable ShaderIrVectorRegIndex = 0

        assert ShaderIrValue_TryScalarRegIndex(scalar_value, scalar_roundtrip)
        assert ShaderIrValue_ScalarReg(scalar_value) == 103
        _ = ShaderIrValue_ScalarRegIndex(scalar_value)
        assert not ShaderIrValue_TryScalarRegIndex(vector_value, scalar_roundtrip)

        assert ShaderIrValue_TryVectorRegIndex(vector_value, vector_roundtrip)
        assert ShaderIrValue_VectorReg(vector_value) == 255
        _ = ShaderIrValue_VectorRegIndex(vector_value)
        assert not ShaderIrValue_TryVectorRegIndex(scalar_value, vector_roundtrip)

@test
def shader_ir_emitter_refined_f32_register_adapters_are_named_and_bounded() -> void:
    can Abort.Panic:
        info: ShaderIrProgramInfo = ShaderIrProgramInfo(2, 0x7788)
        program: mutable heap ShaderIrProgram& = ShaderIrProgram_New(info)
        b0: u32 = ShaderIrProgram_AddBlock(program)
        emitter: mutable ShaderIrEmitter = ShaderIrEmitter_New(b0)

        sgpr: ShaderIrScalarRegIndex = 103
        vgpr: ShaderIrVectorRegIndex = 255

        _ = ShaderIrEmitter_GetScalarRegIndexF32(program, emitter, sgpr)
        _ = ShaderIrEmitter_SetScalarRegIndexF32(program, emitter, sgpr, ShaderIrValue_FromF32(2.0))
        _ = ShaderIrEmitter_GetVectorRegIndexF32(program, emitter, vgpr)
        _ = ShaderIrEmitter_SetVectorRegIndexF32(program, emitter, vgpr, ShaderIrValue_FromF32(3.0))

        block: ShaderIrBlock = program.blocks[b0.usize()]
        assert block.inst_count == 8
        assert block.insts[0].opcode == IR_OPCODE_GETSCALARREGISTER
        assert ShaderIrValue_ScalarReg(block.insts[0].args[0]) == 103
        assert block.insts[1].opcode == IR_OPCODE_BITCASTF32U32
        assert block.insts[2].opcode == IR_OPCODE_BITCASTU32F32
        assert block.insts[3].opcode == IR_OPCODE_SETSCALARREGISTER
        assert ShaderIrValue_ScalarReg(block.insts[3].args[0]) == 103
        assert block.insts[4].opcode == IR_OPCODE_GETVECTORREGISTER
        assert ShaderIrValue_VectorReg(block.insts[4].args[0]) == 255
        assert block.insts[5].opcode == IR_OPCODE_BITCASTF32U32
        assert block.insts[6].opcode == IR_OPCODE_BITCASTU32F32
        assert block.insts[7].opcode == IR_OPCODE_SETVECTORREGISTER
        assert ShaderIrValue_VectorReg(block.insts[7].args[0]) == 255
