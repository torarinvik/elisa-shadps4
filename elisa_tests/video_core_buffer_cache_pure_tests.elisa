include "../../compiler/runtime/elisacore_std/elisacore_runtime.elisa"
include "../video_core/buffer_cache/region_definitions.elisa"
include "../video_core/buffer_cache/range_set.elisa"
include "../video_core/buffer_cache/region_manager.elisa"
include "../video_core/buffer_cache/memory_tracker.elisa"
include "../video_core/buffer_cache/buffer.elisa"
include "../video_core/buffer_cache/fault_manager.elisa"
include "../video_core/buffer_cache/buffer_cache.elisa"

@test
def video_core_buffer_cache_region_bits_and_manager_contracts() -> void:
    can Abort.Panic, Memory.Allocate:
        bits: mutable RegionBits = zeroed
        RegionBits_Clear(bits)
        assert RegionBits_None(bits)
        RegionBits_SetRange(bits, 4, 8)
        assert RegionBits_Any(bits)
        assert RegionBits_IsSet(bits, 4)
        assert RegionBits_IsSet(bits, 7)
        assert not RegionBits_IsSet(bits, 8)
        RegionBits_UnsetRange(bits, 4, 8)
        assert RegionBits_None(bits)

        manager: mutable RegionManager = RegionManager_New(0x400000)
        RegionManager_ChangeRegionState(manager, REGION_TYPE_GPU, true, 0x401000, 0x3000)
        assert RegionManager_IsRegionModified(manager, REGION_TYPE_GPU, 0x1000, 0x2000)
        out: mutable RegionRangeList = RegionRangeList_New(scratch_arena)
        RegionManager_ForEachModifiedRange(manager, REGION_TYPE_GPU, true, 0x401000, 0x4000, out)
        assert out.ranges.count == 1
        assert out.ranges[0].begin == 0x401000
        assert out.ranges[0].end == 0x404000
        assert not RegionManager_IsRegionModified(manager, REGION_TYPE_GPU, 0x1000, 0x2000)

@test
def video_core_buffer_cache_range_set_contracts() -> void:
    can Abort.Panic, Memory.Allocate:
        set: mutable RangeSet = RangeSet_New(scratch_arena)
        RangeSet_Add(set, 0x1000, 0x1000)
        RangeSet_Add(set, 0x2000, 0x1000)
        assert RangeSet_Contains(set, 0x1000, 0x1800)
        assert RangeSet_Intersects(set, 0x2800, 0x200)
        RangeSet_Subtract(set, 0x1800, 0x400)
        assert not RangeSet_Contains(set, 0x1800, 0x300)
        assert RangeSet_Intersects(set, 0x1000, 0x200)

        map: mutable RangeMap[u32] = RangeMap_New[u32](scratch_arena)
        RangeMap_Add[u32](map, 0x3000, 0x1000, 77)
        assert RangeMap_Contains[u32](map, 0x3000, 0x800)
        RangeMap_Subtract[u32](map, 0x3400, 0x200)
        assert not RangeMap_Contains[u32](map, 0x3400, 0x100)

@test
def video_core_buffer_cache_memory_tracker_contracts() -> void:
    can Abort.Panic, Memory.Allocate:
        tracker: mutable MemoryTracker = MemoryTracker_New(scratch_arena)
        base: u64 = 0x200000
        size: u64 = 0x5000
        MemoryTracker_MarkRegionAsCpuModified(tracker, base, size)
        assert MemoryTracker_IsRegionCpuModified(tracker, base, size)
        MemoryTracker_UnmarkRegionAsGpuModified(tracker, base, size)
        assert not MemoryTracker_IsRegionGpuModified(tracker, base, size)

@test
def video_core_buffer_cache_buffer_and_stream_contracts() -> void:
    can Abort.Panic, Memory.Allocate:
        buf: mutable Buffer = Buffer_New(0x100000, 0x4000, MEMORY_USAGE_STREAM)
        Buffer_IncreaseStreamScore(buf, 5)
        assert Buffer_StreamScore(buf) == 5
        assert Buffer_IsInBounds(buf, 0x100000, 0x100)
        assert not Buffer_IsInBounds(buf, 0x0fffff, 0x100)
        Buffer_SetLRUId(buf, 99)
        assert Buffer_LRUId(buf) == 99
        barrier: BufferBarrier = Buffer_GetBarrier(buf, BUFFER_ACCESS_MEMORY_READ, BUFFER_STAGE_ALL_COMMANDS, 0)
        assert not barrier.valid
        UniqueBuffer_Create(buf.buffer, 0x44, 0x88)
        barrier2: BufferBarrier = Buffer_GetBarrier(buf, BUFFER_ACCESS_TRANSFER_WRITE, BUFFER_STAGE_TRANSFER, 16)
        assert barrier2.valid

        stream: mutable StreamBuffer = StreamBuffer_New(scratch_arena, MEMORY_USAGE_STREAM, 4096)
        mapped: StreamMapResult = StreamBuffer_Map(stream, 256, 64, true)
        assert mapped.ok
        StreamBuffer_Commit(stream, 7)
        assert stream.offset >= 256

@test
def video_core_buffer_cache_surface_contracts() -> void:
    can Abort.Panic, Memory.Allocate:
        cache: mutable BufferCache = BufferCache_New(scratch_arena)
        assert cache.slot_buffers.count >= 1
        assert cache.trigger_gc_memory == BUFFER_CACHE_DEFAULT_TRIGGER_GC_MEMORY.u64()
        assert cache.critical_gc_memory == BUFFER_CACHE_DEFAULT_CRITICAL_GC_MEMORY.u64()

        fill_addr: u64 = 0x300000
        BufferCache_FillBuffer(cache, fill_addr, 0x100, 0xdeadbeef, false)
        assert BufferCache_IsRegionCpuModified(cache, fill_addr, 0x100)

        ref_info: BufferCacheBufferRef = BufferCache_ObtainBuffer(cache, fill_addr, 0x100, true)
        assert ref_info.valid

        BufferCache_CopyBuffer(cache, fill_addr + 0x200, fill_addr, 0x80, false, false)
        assert BufferCache_IsRegionCpuModified(cache, fill_addr + 0x200, 0x80)

        BufferCache_ProcessFaultBuffer(cache)
        assert cache.fault_manager.process_count == 1
        BufferCache_RunGarbageCollector(cache)
        assert cache.gc_run_count == 1
