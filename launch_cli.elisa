include "./common/types.elisa"

struct CliState:
    game_path: mutable static u8&?
    patch_file: mutable static u8&?
    override_root: mutable static u8&?
    add_game_folder: mutable static u8&?
    set_addon_folder: mutable static u8&?
    fullscreen: mutable static u8&?
    wait_pid: mutable int
    has_wait_pid: mutable bool
    game_args: mutable darray[static u8&]
    ignore_game_patch: mutable bool
    big_picture: mutable bool
    show_fps: mutable bool
    config_clean: mutable bool
    config_global: mutable bool
    log_append: mutable bool
    wait_for_debugger: mutable bool

struct ParseResult:
    state: mutable CliState
    should_exit: mutable bool
    exit_code: mutable int

def CliState_New() -> CliState:
    return CliState(null, null, null, null, null, null, 0, false, [], false, false, false, false, false, false, false)

def ParseResult_New() -> ParseResult:
    return ParseResult(CliState_New(), false, 0)

def LaunchCli_ParseIntOrZero(value: static u8&) -> int:
    out: mutable int = 0
    neg: mutable bool = false
    i: mutable usize = 0
    if value.len > 0 and value[0] == '-'.u8():
        neg <- true
        i <- 1
    while i < value.len:
        c: u8 = value[i]
        if c < '0'.u8() or c > '9'.u8():
            return 0
        out <- out * 10 + (c - '0'.u8()).int()
        i <- i + 1
    if neg:
        out <- -out
    return out

def Parse(args: darray[static u8&]) -> ParseResult:
    result: mutable ParseResult = ParseResult_New()
    i: mutable usize = 1
    while i < args.count:
        arg: static u8& = args[i]
        if streq(arg, "--help") == 1 or streq(arg, "-h") == 1:
            result.should_exit <- true
            result.exit_code <- 0
            return result
        if streq(arg, "--big-picture") == 1:
            result.state.big_picture <- true
            i <- i + 1
            continue
        if streq(arg, "--show-fps") == 1:
            result.state.show_fps <- true
            i <- i + 1
            continue
        if streq(arg, "--config-clean") == 1:
            result.state.config_clean <- true
            i <- i + 1
            continue
        if streq(arg, "--config-global") == 1:
            result.state.config_global <- true
            i <- i + 1
            continue
        if streq(arg, "--log-append") == 1:
            result.state.log_append <- true
            i <- i + 1
            continue
        if streq(arg, "--wait-for-debugger") == 1:
            result.state.wait_for_debugger <- true
            i <- i + 1
            continue
        if streq(arg, "--ignore-game-patch") == 1:
            result.state.ignore_game_patch <- true
            i <- i + 1
            continue
        if streq(arg, "--patch-file") == 1 and i + 1 < args.count:
            result.state.patch_file <- args[i + 1]
            i <- i + 2
            continue
        if streq(arg, "--override-root") == 1 and i + 1 < args.count:
            result.state.override_root <- args[i + 1]
            i <- i + 2
            continue
        if streq(arg, "--add-game-folder") == 1 and i + 1 < args.count:
            result.state.add_game_folder <- args[i + 1]
            i <- i + 2
            continue
        if streq(arg, "--set-addon-folder") == 1 and i + 1 < args.count:
            result.state.set_addon_folder <- args[i + 1]
            i <- i + 2
            continue
        if streq(arg, "--fullscreen") == 1 and i + 1 < args.count:
            result.state.fullscreen <- args[i + 1]
            i <- i + 2
            continue
        if streq(arg, "--wait-pid") == 1 and i + 1 < args.count:
            result.state.wait_pid <- LaunchCli_ParseIntOrZero(args[i + 1])
            result.state.has_wait_pid <- true
            i <- i + 2
            continue
        if result.state.game_path == null:
            result.state.game_path <- arg
        else:
            result.state.game_args.push(arg)
        i <- i + 1
    return result
