include "./imgui_big_picture_ffi_bridge.elisa"

global mutable g_imgui_impl_sdlrenderer3_initialized: bool = false

def ImGui_ImplSDLRenderer3_GetBackendData() -> void&?:
    if ImguiBigPictureBridge_GetRendererInitialized() == 0:
        return null
    return 1.cast[void&?]

def Saturate(v: f32) -> f32:
    if v < 0.0:
        return 0.0
    if v > 1.0:
        return 1.0
    return v

def ImGui_ImplSDLRenderer3_Init(renderer: void&?) -> bool:
    ok: int = ImguiBigPictureBridge_SDLRenderer3_Init(renderer)
    g_imgui_impl_sdlrenderer3_initialized <- ok != 0
    return g_imgui_impl_sdlrenderer3_initialized

def ImGui_ImplSDLRenderer3_Shutdown() -> void:
    if g_imgui_impl_sdlrenderer3_initialized:
        ImGui_ImplSDLRenderer3_DestroyDeviceObjects()
        ImguiBigPictureBridge_SDLRenderer3_Shutdown()
    g_imgui_impl_sdlrenderer3_initialized <- false

def ImGui_ImplSDLRenderer3_SetupRenderState(renderer: void&?) -> void:
    ImguiBigPictureBridge_SDLRenderer3_SetupRenderState(renderer)

def SDL_RenderGeometryRaw8BitColor(renderer: void&?, texture: void&?, xy: void&?, xy_stride: int, color: void&?, color_stride: int, uv: void&?, uv_stride: int, num_vertices: int, indices: void&?, num_indices: int, size_indices: int) -> int:
    return ImguiBigPictureBridge_SDLRenderer3_RenderGeometryRaw8BitColor(renderer, texture, xy, xy_stride, color, color_stride, uv, uv_stride, num_vertices, indices, num_indices, size_indices)

def ImGui_ImplSDLRenderer3_NewFrame() -> void:
    if not g_imgui_impl_sdlrenderer3_initialized:
        return
    ImguiBigPictureBridge_SDLRenderer3_NewFrame()
    if ImguiBigPictureBridge_GetRendererFontTextureLive() == 0:
        _ = ImGui_ImplSDLRenderer3_CreateDeviceObjects()

def ImGui_ImplSDLRenderer3_RenderDrawData(draw_data: void&?, renderer: void&?) -> void:
    if not g_imgui_impl_sdlrenderer3_initialized:
        return
    ImGui_ImplSDLRenderer3_SetupRenderState(renderer)
    ImguiBigPictureBridge_SDLRenderer3_RenderDrawData(draw_data, renderer)

def ImGui_ImplSDLRenderer3_CreateFontsTexture() -> bool:
    if not g_imgui_impl_sdlrenderer3_initialized:
        return false
    return ImguiBigPictureBridge_SDLRenderer3_CreateFontsTexture() != 0

def ImGui_ImplSDLRenderer3_DestroyFontsTexture() -> void:
    ImguiBigPictureBridge_SDLRenderer3_DestroyFontsTexture()

def ImGui_ImplSDLRenderer3_CreateDeviceObjects() -> bool:
    if not g_imgui_impl_sdlrenderer3_initialized:
        return false
    ok: bool = ImguiBigPictureBridge_SDLRenderer3_CreateDeviceObjects() != 0
    if ok:
        _ = ImGui_ImplSDLRenderer3_CreateFontsTexture()
    return ok

def ImGui_ImplSDLRenderer3_DestroyDeviceObjects() -> void:
    ImguiBigPictureBridge_SDLRenderer3_DestroyDeviceObjects()
    ImGui_ImplSDLRenderer3_DestroyFontsTexture()
