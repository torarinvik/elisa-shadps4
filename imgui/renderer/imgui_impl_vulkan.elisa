# Based on imgui_impl_vulkan.cpp from Dear ImGui repository

permission Vulkan:
    Init
    Draw
    Memory
    Upload

# ---------------------------------------------------------------------------
# Data structures
# ---------------------------------------------------------------------------

struct ImGuiVkRenderBuffer:
    buffer_memory: mutable u64   # VkDeviceMemory (non-dispatchable handle)
    buffer_size: mutable u64     # VkDeviceSize
    buffer: mutable u64          # VkBuffer

struct ImGuiVkFrameRenderBuffers:
    vertex: mutable ImGuiVkRenderBuffer
    index: mutable ImGuiVkRenderBuffer

struct ImGuiVkInitInfo:
    instance: mutable void&?           # VkInstance
    physical_device: mutable void&?    # VkPhysicalDevice
    device: mutable void&?             # VkDevice
    queue_family: mutable u32
    queue: mutable void&?              # VkQueue
    image_count: mutable u32
    min_allocation_size: mutable u64   # VkDeviceSize
    pipeline_cache: mutable u64        # VkPipelineCache
    subpass: mutable u32
    color_attachment_format: mutable i32  # VkFormat for pipeline_rendering_create_info
    allocator: mutable void&?
    check_vk_result_fn: mutable void&?  # function pointer: void(*)(VkResult)

struct ImGuiVkData:
    init_info: mutable ImGuiVkInitInfo
    buffer_memory_alignment: mutable u64
    descriptor_pool: mutable u64         # VkDescriptorPool
    descriptor_set_layout: mutable u64   # VkDescriptorSetLayout
    pipeline_layout: mutable u64         # VkPipelineLayout
    pipeline: mutable u64                # VkPipeline
    shader_module_vert: mutable u64      # VkShaderModule
    shader_module_frag: mutable u64      # VkShaderModule
    command_pool: mutable u64            # VkCommandPool
    simple_sampler: mutable u64          # VkSampler
    font_memory: mutable u64             # VkDeviceMemory
    font_image: mutable u64              # VkImage
    font_view: mutable u64               # VkImageView
    font_texture: mutable void&?         # ImTextureID
    font_command_buffer: mutable void&?  # VkCommandBuffer (dispatchable)
    render_buf_index: mutable u32
    render_buf_count: mutable u32
    # frame render buffers: stored as opaque pointer to heap-allocated array
    frame_render_buffers: mutable void&?
    enabled_blending: mutable bool

global mutable g_imgui_vk_backend: ImGuiVkData = zeroed

