const SDL_EVENT_MOUSE_WHEEL: u32 = 0x403u32
const SDL_EVENT_MOUSE_BUTTON_DOWN: u32 = 0x401u32
const SDL_EVENT_MOUSE_BUTTON_UP: u32 = 0x402u32
const SDL_EVENT_TEXT_INPUT: u32 = 0x303u32
const SDL_EVENT_KEY_DOWN: u32 = 0x300u32
const SDL_EVENT_KEY_UP: u32 = 0x301u32
const SDL_EVENT_WINDOW_MOUSE_ENTER: u32 = 0x206u32
const SDL_EVENT_WINDOW_MOUSE_LEAVE: u32 = 0x207u32
const SDL_EVENT_WINDOW_FOCUS_GAINED: u32 = 0x208u32
