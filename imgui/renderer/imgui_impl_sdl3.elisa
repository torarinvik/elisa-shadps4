# ImGuiWindowFlags
const ImGuiWindowFlags_NoNav: u32 = 0x40000u32

# ---------------------------------------------------------------------------
# Helper: key modifier update
# ---------------------------------------------------------------------------

def imgui_sdl_update_key_modifiers(sdl_key_mods: u32) -> void:
    can Input.Keyboard:
        io: void&? = imgui_sdl_get_io()
        imgui_sdl_io_add_key_event(io, ImGuiMod_Ctrl, (sdl_key_mods & SDL_KMOD_CTRL) != 0u32)
        imgui_sdl_io_add_key_event(io, ImGuiMod_Shift, (sdl_key_mods & SDL_KMOD_SHIFT) != 0u32)
        imgui_sdl_io_add_key_event(io, ImGuiMod_Alt, (sdl_key_mods & SDL_KMOD_ALT) != 0u32)
        imgui_sdl_io_add_key_event(io, ImGuiMod_Super, (sdl_key_mods & SDL_KMOD_GUI) != 0u32)

def imgui_sdl_get_viewport_for_window_id(window_id: u32) -> void&?:
    if window_id == g_imgui_sdl_data.window_id:
        return imgui_sdl_get_main_viewport()
    return null

# ---------------------------------------------------------------------------
# ProcessEvent
# ---------------------------------------------------------------------------

def ImGui_Sdl_ProcessEvent(event: void&?) -> bool:
    can Window.Event, Input.Mouse, Input.Keyboard, Input.Gamepad:
        io: void&? = imgui_sdl_get_io()
        event_type: u32 = sdl_event_get_type(event)

        if event_type == SDL_EVENT_MOUSE_MOTION:
            viewport: void&? = imgui_sdl_get_viewport_for_window_id(sdl_event_motion_window_id(event))
            if viewport == null:
                return false
            source: int = if sdl_event_motion_which(event) == SDL_TOUCH_MOUSEID: ImGuiMouseSource_TouchScreen else: ImGuiMouseSource_Mouse
            imgui_sdl_io_add_mouse_source_event(io, source)
            mx: f32 = sdl_event_motion_x(event)
            my: f32 = sdl_event_motion_y(event)
            imgui_sdl_io_add_mouse_pos_event(io, mx, my)
            if mx != g_imgui_sdl_data.prev_mouse_pos_x or my != g_imgui_sdl_data.prev_mouse_pos_y:
                g_imgui_sdl_data.prev_mouse_pos_x <- mx
                g_imgui_sdl_data.prev_mouse_pos_y <- my
                if emulator_settings_get_cursor_state() == HideCursorState_Idle:
                    g_imgui_sdl_data.last_cursor_move_time <- g_imgui_sdl_data.time
            return true

        if event_type == SDL_EVENT_MOUSE_WHEEL:
            if imgui_sdl_get_viewport_for_window_id(sdl_event_wheel_window_id(event)) == null:
                return false
            source: int = if sdl_event_wheel_which(event) == SDL_TOUCH_MOUSEID: ImGuiMouseSource_TouchScreen else: ImGuiMouseSource_Mouse
            imgui_sdl_io_add_mouse_source_event(io, source)
            imgui_sdl_io_add_mouse_wheel_event(io, -sdl_event_wheel_x(event), sdl_event_wheel_y(event))
            return true

        if event_type == SDL_EVENT_MOUSE_BUTTON_DOWN or event_type == SDL_EVENT_MOUSE_BUTTON_UP:
            if imgui_sdl_get_viewport_for_window_id(sdl_event_button_window_id(event)) == null:
                return false
            btn: u8 = sdl_event_button_button(event)
            mouse_button: mutable int = -1
            if btn == SDL_BUTTON_LEFT:
                mouse_button <- 0
            if btn == SDL_BUTTON_RIGHT:
                mouse_button <- 1
            if btn == SDL_BUTTON_MIDDLE:
                mouse_button <- 2
            if btn == SDL_BUTTON_X1:
                mouse_button <- 3
            if btn == SDL_BUTTON_X2:
                mouse_button <- 4
            if mouse_button == -1:
                return false
            source: int = if sdl_event_button_which(event) == SDL_TOUCH_MOUSEID: ImGuiMouseSource_TouchScreen else: ImGuiMouseSource_Mouse
            imgui_sdl_io_add_mouse_source_event(io, source)
            is_down: bool = event_type == SDL_EVENT_MOUSE_BUTTON_DOWN
            imgui_sdl_io_add_mouse_button_event(io, mouse_button, is_down)
            if is_down:
                g_imgui_sdl_data.mouse_buttons_down <- g_imgui_sdl_data.mouse_buttons_down | (1 << mouse_button)
            else:
                g_imgui_sdl_data.mouse_buttons_down <- g_imgui_sdl_data.mouse_buttons_down & (1 << mouse_button).bitnot()
            return true

        if event_type == SDL_EVENT_TEXT_INPUT:
            if imgui_sdl_get_viewport_for_window_id(sdl_event_text_window_id(event)) == null:
                return false
            imgui_sdl_io_add_input_characters_utf8(io, sdl_event_text_text(event))
            return true

        if event_type == SDL_EVENT_KEY_DOWN or event_type == SDL_EVENT_KEY_UP:
            if imgui_sdl_get_viewport_for_window_id(sdl_event_key_window_id(event)) == null:
                return false
            imgui_sdl_update_key_modifiers(sdl_event_key_mod(event))
            keycode: i32 = sdl_event_key_key(event)
            scancode: i32 = sdl_event_key_scancode(event)
            key: int = sdl_keycode_to_imgui_key(keycode, scancode)
            imgui_sdl_io_add_key_event(io, key, event_type == SDL_EVENT_KEY_DOWN)
            imgui_sdl_io_set_key_event_native_data(io, key, keycode, scancode)
            return true

        if event_type == SDL_EVENT_WINDOW_MOUSE_ENTER:
            if imgui_sdl_get_viewport_for_window_id(sdl_event_window_window_id(event)) == null:
                return false
            g_imgui_sdl_data.mouse_window_id <- sdl_event_window_window_id(event)
            g_imgui_sdl_data.mouse_pending_leave_frame <- 0
            g_imgui_sdl_data.last_cursor_move_time <- g_imgui_sdl_data.time
            return true

        if event_type == SDL_EVENT_WINDOW_MOUSE_LEAVE:
            if imgui_sdl_get_viewport_for_window_id(sdl_event_window_window_id(event)) == null:
                return false
            g_imgui_sdl_data.mouse_pending_leave_frame <- imgui_sdl_get_frame_count() + 1
            g_imgui_sdl_data.last_cursor_move_time <- g_imgui_sdl_data.time
            return true

        if event_type == SDL_EVENT_WINDOW_FOCUS_GAINED or event_type == SDL_EVENT_WINDOW_FOCUS_LOST:
            if imgui_sdl_get_viewport_for_window_id(sdl_event_window_window_id(event)) == null:
                return false
            imgui_sdl_io_add_focus_event(io, event_type == SDL_EVENT_WINDOW_FOCUS_GAINED)
            return true

        if event_type == SDL_EVENT_GAMEPAD_ADDED or event_type == SDL_EVENT_GAMEPAD_REMOVED:
            g_imgui_sdl_data.want_update_gamepads_list <- true
            return true

        if event_type == SDL_EVENT_CHANGE_CONTROLLER:
            g_imgui_sdl_data.want_update_gamepads_list <- true
            return false

        return false

# ---------------------------------------------------------------------------
# Mouse update helpers
# ---------------------------------------------------------------------------

def imgui_sdl_update_mouse_data() -> void:
    can Input.Mouse, Window.Event:
        io: void&? = imgui_sdl_get_io()
        _ = SDL_CaptureMouse(g_imgui_sdl_data.mouse_buttons_down != 0)
        focused: void&? = SDL_GetKeyboardFocus()
        is_app_focused: bool = g_imgui_sdl_data.window == focused
        if is_app_focused:
            if imgui_sdl_io_get_want_set_mouse_pos(io):
                _ = SDL_WarpMouseInWindow(g_imgui_sdl_data.window, imgui_sdl_io_get_mouse_pos_x(io), imgui_sdl_io_get_mouse_pos_y(io))
            if g_imgui_sdl_data.mouse_buttons_down == 0:
                gx: mutable f32 = 0.0
                gy: mutable f32 = 0.0
                wx: mutable int = 0
                wy: mutable int = 0
                _ = SDL_GetGlobalMouseState(gx.ref[mutable f32&], gy.ref[mutable f32&])
                _ = SDL_GetWindowPosition(focused, wx.ref[mutable int&], wy.ref[mutable int&])
                gx <- gx - wx.f32()
                gy <- gy - wy.f32()
                imgui_sdl_io_add_mouse_pos_event(io, gx, gy)
                if gx != g_imgui_sdl_data.prev_mouse_pos_x or gy != g_imgui_sdl_data.prev_mouse_pos_y:
                    if g_imgui_sdl_data.prev_mouse_pos_x == 0.0 and g_imgui_sdl_data.prev_mouse_pos_y == 0.0:
                        g_imgui_sdl_data.prev_mouse_pos_x <- gx
                        g_imgui_sdl_data.prev_mouse_pos_y <- gy
                        g_imgui_sdl_data.last_cursor_move_time <- g_imgui_sdl_data.time

def imgui_sdl_update_mouse_cursor() -> void:
    can Window.Cursor:
        io: void&? = imgui_sdl_get_io()
        if imgui_sdl_io_get_config_flags(io) & ImGuiConfigFlags_NoMouseCursorChange != 0u32:
            return
        cursor_state: i16 = emulator_settings_get_cursor_state()
        imgui_cursor: int = imgui_sdl_get_mouse_cursor()
        if imgui_sdl_io_get_mouse_draw_cursor(io) or imgui_cursor == ImGuiMouseCursor_None or cursor_state == HideCursorState_Always:
            _ = SDL_HideCursor()
        else:
            freq: u64 = SDL_GetPerformanceFrequency()
            timeout_ticks: u64 = (emulator_settings_get_cursor_hide_timeout() * freq.f64()).u64()
            if cursor_state == HideCursorState_Idle and g_imgui_sdl_data.time - g_imgui_sdl_data.last_cursor_move_time >= timeout_ticks:
                was_visible: bool = SDL_CursorVisible()
                _ = SDL_HideCursor()
                if was_visible:
                    _ = SDL_WarpMouseInWindow(SDL_GetKeyboardFocus(), g_imgui_sdl_data.prev_mouse_pos_x, g_imgui_sdl_data.prev_mouse_pos_y)
            else:
                effective_cursor: void&? = imgui_sdl_get_cursor_from_array(g_imgui_sdl_data.mouse_cursors, imgui_cursor)
                if effective_cursor == null:
                    effective_cursor <- imgui_sdl_get_cursor_from_array(g_imgui_sdl_data.mouse_cursors, ImGuiMouseCursor_Arrow)
                if g_imgui_sdl_data.mouse_last_cursor != effective_cursor:
                    _ = SDL_SetCursor(effective_cursor)
                    g_imgui_sdl_data.mouse_last_cursor <- effective_cursor
                _ = SDL_ShowCursor()

# ---------------------------------------------------------------------------
# Gamepad update
# ---------------------------------------------------------------------------

def imgui_sdl_close_gamepads() -> void:
    can Input.Gamepad:
        if g_imgui_sdl_data.gamepad_mode != ImGui_ImplSDL3_GamepadMode_Manual:
            i: mutable int = 0
            list: void&? = g_imgui_sdl_data.mouse_cursors  # reusing field; gamepads stored separately below
            _ = i
        imgui_sdl_gamepad_list_clear(g_imgui_sdl_data.mouse_last_cursor)  # gamepads list at mouse_last_cursor slot

def imgui_sdl_update_gamepad_button(io: void&?, key: int, gamepad_button: int) -> void:
    can Input.Gamepad:
        merged: mutable bool = false
        i: mutable int = 0
        list: void&? = g_imgui_sdl_data.mouse_last_cursor
        count: int = imgui_sdl_gamepad_list_size(list)
        while i < count:
            gp: void&? = imgui_sdl_gamepad_list_get(list, i)
            if SDL_GetGamepadButton(gp, gamepad_button) != 0u8:
                merged <- true
            i <- i + 1
        imgui_sdl_io_add_key_event(io, key, merged)

def imgui_sdl_saturate(v: f32) -> f32:
    if v < 0.0:
        return 0.0
    if v > 1.0:
        return 1.0
    return v

def imgui_sdl_update_gamepad_analog(io: void&?, key: int, axis_no: int, v0: f32, v1: f32) -> void:
    can Input.Gamepad:
        merged: mutable f32 = 0.0
        i: mutable int = 0
        list: void&? = g_imgui_sdl_data.mouse_last_cursor
        count: int = imgui_sdl_gamepad_list_size(list)
        while i < count:
            gp: void&? = imgui_sdl_gamepad_list_get(list, i)
            raw_val: i16 = SDL_GetGamepadAxis(gp, axis_no)
            vn: f32 = imgui_sdl_saturate((raw_val.f32() - v0) / (v1 - v0))
            if merged < vn:
                merged <- vn
            i <- i + 1
        imgui_sdl_io_add_key_analog_event(io, key, merged > 0.1, merged)

def imgui_sdl_update_gamepads() -> void:
    can Input.Gamepad:
        io: void&? = imgui_sdl_get_io()
        sdl_gamepad_0: void&? = input_get_sdl_gamepad_0()
        list: void&? = g_imgui_sdl_data.mouse_last_cursor
        if g_imgui_sdl_data.want_update_gamepads_list and g_imgui_sdl_data.gamepad_mode != ImGui_ImplSDL3_GamepadMode_Manual:
            if sdl_gamepad_0 != null:
                imgui_sdl_gamepad_list_push(list, sdl_gamepad_0)
                g_imgui_sdl_data.want_update_gamepads_list <- false
            else:
                imgui_sdl_gamepad_list_clear(list)
                count: mutable int = 0
                gamepads_ptr: void&? = SDL_GetGamepads(count.ref[mutable int&])
                _ = gamepads_ptr
                g_imgui_sdl_data.want_update_gamepads_list <- false

        if imgui_sdl_io_get_config_flags(io) & ImGuiConfigFlags_NavEnableGamepad == 0u32:
            return
        imgui_sdl_io_clear_backend_flags_platform(io)
        if imgui_sdl_gamepad_list_size(list) == 0:
            return
        imgui_sdl_io_set_backend_flags_mouse_cursors(io)

        # SDL_GAMEPAD_BUTTON_* and SDL_GAMEPAD_AXIS_* integer constants
        imgui_sdl_update_gamepad_button(io, 0x105, 9)   # ImGuiKey_GamepadStart, SDL_GAMEPAD_BUTTON_START
        imgui_sdl_update_gamepad_button(io, 0x106, 10)  # ImGuiKey_GamepadBack, SDL_GAMEPAD_BUTTON_BACK
        imgui_sdl_update_gamepad_button(io, 0x10A, 2)   # ImGuiKey_GamepadFaceRight (Circle)
        imgui_sdl_update_gamepad_button(io, 0x10B, 3)   # ImGuiKey_GamepadFaceUp (Triangle)
        imgui_sdl_update_gamepad_button(io, 0x10C, 0)   # ImGuiKey_GamepadFaceDown (Cross)
        imgui_sdl_update_gamepad_button(io, 0x10D, 13)  # ImGuiKey_GamepadDpadLeft
        imgui_sdl_update_gamepad_button(io, 0x10E, 14)  # ImGuiKey_GamepadDpadRight
        imgui_sdl_update_gamepad_button(io, 0x10F, 11)  # ImGuiKey_GamepadDpadUp
        imgui_sdl_update_gamepad_button(io, 0x110, 12)  # ImGuiKey_GamepadDpadDown
        imgui_sdl_update_gamepad_button(io, 0x111, 9)   # ImGuiKey_GamepadL1, SDL_GAMEPAD_BUTTON_LEFT_SHOULDER (=9)
        imgui_sdl_update_gamepad_button(io, 0x112, 10)  # ImGuiKey_GamepadR1
        imgui_sdl_update_gamepad_analog(io, 0x113, 4, 0.0, 32767.0)  # L2
        imgui_sdl_update_gamepad_analog(io, 0x114, 5, 0.0, 32767.0)  # R2
        imgui_sdl_update_gamepad_button(io, 0x115, 7)   # L3
        imgui_sdl_update_gamepad_button(io, 0x116, 8)   # R3
        imgui_sdl_update_gamepad_analog(io, 0x117, 0, -8000.0, -32768.0)  # LStickLeft
        imgui_sdl_update_gamepad_analog(io, 0x118, 0, 8000.0, 32767.0)   # LStickRight
        imgui_sdl_update_gamepad_analog(io, 0x119, 1, -8000.0, -32768.0) # LStickUp
        imgui_sdl_update_gamepad_analog(io, 0x11A, 1, 8000.0, 32767.0)   # LStickDown
        imgui_sdl_update_gamepad_analog(io, 0x11B, 2, -8000.0, -32768.0) # RStickLeft
        imgui_sdl_update_gamepad_analog(io, 0x11C, 2, 8000.0, 32767.0)   # RStickRight
        imgui_sdl_update_gamepad_analog(io, 0x11D, 3, -8000.0, -32768.0) # RStickUp
        imgui_sdl_update_gamepad_analog(io, 0x11E, 3, 8000.0, 32767.0)   # RStickDown

# ---------------------------------------------------------------------------
# NewFrame / OnResize
# ---------------------------------------------------------------------------

def ImGui_Sdl_NewFrame(is_reusing_frame: bool) -> void:
    can Window.Event, Input.Mouse, Input.Keyboard, Input.Gamepad:
        io: void&? = imgui_sdl_get_io()
        freq: u64 = SDL_GetPerformanceFrequency()
        current_time: mutable u64 = SDL_GetPerformanceCounter()
        if current_time <= g_imgui_sdl_data.time:
            current_time <- g_imgui_sdl_data.time + 1u64
        dt: f32 = if g_imgui_sdl_data.time > 0u64: ((current_time - g_imgui_sdl_data.time).f64() / freq.f64()).f32() else: 0.016666667
        imgui_sdl_io_set_delta_time(io, dt)
        g_imgui_sdl_data.time <- current_time

        if not is_reusing_frame:
            if current_time <= g_imgui_sdl_data.non_reused_time:
                current_time <- g_imgui_sdl_data.non_reused_time + 1u64
            non_reused_dt: f32 = if g_imgui_sdl_data.non_reused_time > 0u64: ((current_time - g_imgui_sdl_data.non_reused_time).f64() / freq.f64()).f32() else: 0.016666667
            g_imgui_sdl_data.non_reused_time <- current_time
            debug_state_set_frame_delta_time(non_reused_dt)

            count: int = 60
            frame_idx: mutable int = g_imgui_sdl_data.framerate_sec_per_frame_idx
            old_val: f32 = imgui_sdl_framerate_buf_get(g_imgui_sdl_data.framerate_sec_per_frame_buf, frame_idx)
            acc: mutable f32 = g_imgui_sdl_data.framerate_sec_per_frame_acc
            acc <- acc + non_reused_dt - old_val
            imgui_sdl_framerate_buf_set(g_imgui_sdl_data.framerate_sec_per_frame_buf, frame_idx, non_reused_dt)
            g_imgui_sdl_data.framerate_sec_per_frame_acc <- acc
            g_imgui_sdl_data.framerate_sec_per_frame_idx <- (frame_idx + 1) % count
            framerate: f32 = if acc > 0.0: 1.0 / (acc / count.f32()) else: 3.4028235e38
            debug_state_set_framerate(framerate)

        if g_imgui_sdl_data.mouse_pending_leave_frame != 0 and g_imgui_sdl_data.mouse_pending_leave_frame >= imgui_sdl_get_frame_count() and g_imgui_sdl_data.mouse_buttons_down == 0:
            g_imgui_sdl_data.mouse_window_id <- 0u32
            g_imgui_sdl_data.mouse_pending_leave_frame <- 0
            imgui_sdl_io_add_mouse_pos_event(io, -3.4028235e38, -3.4028235e38)

        imgui_sdl_update_mouse_data()
        imgui_sdl_update_mouse_cursor()
        imgui_sdl_update_gamepads()

def ImGui_Sdl_OnResize() -> void:
    can Window.Resize:
        io: void&? = imgui_sdl_get_io()
        w: mutable int = 0
        h: mutable int = 0
        dw: mutable int = 0
        dh: mutable int = 0
        _ = SDL_GetWindowSize(g_imgui_sdl_data.window, w.ref[mutable int&], h.ref[mutable int&])
        if SDL_GetWindowFlags(g_imgui_sdl_data.window) & SDL_WINDOW_MINIMIZED != 0u64:
            w <- 0
            h <- 0
        _ = SDL_GetWindowSizeInPixels(g_imgui_sdl_data.window, dw.ref[mutable int&], dh.ref[mutable int&])
        imgui_sdl_io_set_display_size(io, w.f32(), h.f32())
        if w > 0 and h > 0:
            imgui_sdl_io_set_display_framebuffer_scale(io, dw.f32() / w.f32(), dh.f32() / h.f32())

# ---------------------------------------------------------------------------
# Init / Shutdown
# ---------------------------------------------------------------------------

def ImGui_Sdl_Init(window: void&?) -> bool:
    can Window.Event, Window.Cursor:
        io: void&? = imgui_sdl_get_io()
        imgui_sdl_io_set_backend_platform_name(io, "imgui_impl_sdl3_shadps4")
        imgui_sdl_io_set_backend_flags_mouse_cursors(io)
        imgui_sdl_io_set_backend_flags_set_mouse_pos(io)
        imgui_sdl_io_set_backend_platform_userdata(io, g_imgui_sdl_data.ref[mutable ImGuiSdlData&].cast[void&?])

        g_imgui_sdl_data.window <- window
        g_imgui_sdl_data.window_id <- SDL_GetWindowID(window)
        g_imgui_sdl_data.gamepad_mode <- ImGui_ImplSDL3_GamepadMode_AutoFirst
        g_imgui_sdl_data.want_update_gamepads_list <- true
        g_imgui_sdl_data.mouse_last_cursor <- imgui_sdl_alloc_gamepad_list()
        g_imgui_sdl_data.mouse_cursors <- imgui_sdl_alloc_cursor_array(ImGuiMouseCursor_COUNT)
        g_imgui_sdl_data.framerate_sec_per_frame_buf <- imgui_sdl_alloc_framerate_buf(60)

        imgui_sdl_set_cursor_in_array(g_imgui_sdl_data.mouse_cursors, ImGuiMouseCursor_Arrow, SDL_CreateSystemCursor(SDL_SYSTEM_CURSOR_DEFAULT))
        imgui_sdl_set_cursor_in_array(g_imgui_sdl_data.mouse_cursors, ImGuiMouseCursor_TextInput, SDL_CreateSystemCursor(SDL_SYSTEM_CURSOR_TEXT))
        imgui_sdl_set_cursor_in_array(g_imgui_sdl_data.mouse_cursors, ImGuiMouseCursor_ResizeAll, SDL_CreateSystemCursor(SDL_SYSTEM_CURSOR_MOVE))
        imgui_sdl_set_cursor_in_array(g_imgui_sdl_data.mouse_cursors, ImGuiMouseCursor_ResizeNS, SDL_CreateSystemCursor(SDL_SYSTEM_CURSOR_NS_RESIZE))
        imgui_sdl_set_cursor_in_array(g_imgui_sdl_data.mouse_cursors, ImGuiMouseCursor_ResizeEW, SDL_CreateSystemCursor(SDL_SYSTEM_CURSOR_EW_RESIZE))
        imgui_sdl_set_cursor_in_array(g_imgui_sdl_data.mouse_cursors, ImGuiMouseCursor_ResizeNESW, SDL_CreateSystemCursor(SDL_SYSTEM_CURSOR_NESW_RESIZE))
        imgui_sdl_set_cursor_in_array(g_imgui_sdl_data.mouse_cursors, ImGuiMouseCursor_ResizeNWSE, SDL_CreateSystemCursor(SDL_SYSTEM_CURSOR_NWSE_RESIZE))
        imgui_sdl_set_cursor_in_array(g_imgui_sdl_data.mouse_cursors, ImGuiMouseCursor_Hand, SDL_CreateSystemCursor(SDL_SYSTEM_CURSOR_POINTER))
        imgui_sdl_set_cursor_in_array(g_imgui_sdl_data.mouse_cursors, ImGuiMouseCursor_NotAllowed, SDL_CreateSystemCursor(SDL_SYSTEM_CURSOR_NOT_ALLOWED))

        main_viewport: void&? = imgui_sdl_get_main_viewport()
        imgui_sdl_viewport_set_platform_handle(main_viewport, SDL_GetWindowID(window).cast[void&?])

        return true

def ImGui_Sdl_Shutdown() -> void:
    can Window.Cursor, Input.Gamepad:
        io: void&? = imgui_sdl_get_io()
        if g_imgui_sdl_data.clipboard_text_data != null:
            SDL_free(g_imgui_sdl_data.clipboard_text_data.cast[void&?])
        i: mutable int = 0
        while i < ImGuiMouseCursor_COUNT:
            SDL_DestroyCursor(imgui_sdl_get_cursor_from_array(g_imgui_sdl_data.mouse_cursors, i))
            i <- i + 1
        imgui_sdl_free_cursor_array(g_imgui_sdl_data.mouse_cursors)
        imgui_sdl_free_gamepad_list(g_imgui_sdl_data.mouse_last_cursor)
        imgui_sdl_free_framerate_buf(g_imgui_sdl_data.framerate_sec_per_frame_buf)

        imgui_sdl_io_set_backend_platform_name(io, null)
        imgui_sdl_io_set_backend_platform_userdata(io, null)
        imgui_sdl_io_clear_backend_flags_platform(io)

        g_imgui_sdl_data <- zeroed

def ImGui_Sdl_SetGamepadMode(mode: int, manual_gamepads_array: void&?, manual_gamepads_count: int) -> void:
    can Input.Gamepad:
        imgui_sdl_gamepad_list_clear(g_imgui_sdl_data.mouse_last_cursor)
        if mode == ImGui_ImplSDL3_GamepadMode_Manual:
            i: mutable int = 0
            while i < manual_gamepads_count:
                gp: void&? = imgui_sdl_gamepad_list_get(manual_gamepads_array, i)
                imgui_sdl_gamepad_list_push(g_imgui_sdl_data.mouse_last_cursor, gp)
                i <- i + 1
        else:
            g_imgui_sdl_data.want_update_gamepads_list <- true
        g_imgui_sdl_data.gamepad_mode <- mode
