# Based on imgui_impl_sdl3.cpp from Dear ImGui repository

permission Window:
    Event
    Cursor
    Resize

permission Input:
    Mouse
    Keyboard
    Gamepad

# ---------------------------------------------------------------------------
# Data structures
# ---------------------------------------------------------------------------

struct ImGuiSdlData:
    window: mutable void&?          # SDL_Window*
    window_id: mutable u32          # SDL_WindowID
    time: mutable u64
    non_reused_time: mutable u64
    clipboard_text_data: mutable static u8&?
    ime_window: mutable void&?      # SDL_Window* for IME
    mouse_window_id: mutable u32
    mouse_buttons_down: mutable int
    # mouse_cursors[ImGuiMouseCursor_COUNT] stored as opaque pointer
    mouse_cursors: mutable void&?
    mouse_last_cursor: mutable void&?
    mouse_pending_leave_frame: mutable int
    prev_mouse_pos_x: mutable f32
    prev_mouse_pos_y: mutable f32
    last_cursor_move_time: mutable u64
    gamepad_mode: mutable int
    want_update_gamepads_list: mutable bool
    framerate_sec_per_frame_idx: mutable int
    framerate_sec_per_frame_acc: mutable f32
    # framerate_sec_per_frame[60] stored as opaque pointer
    framerate_sec_per_frame_buf: mutable void&?

global mutable g_imgui_sdl_data: ImGuiSdlData = zeroed

