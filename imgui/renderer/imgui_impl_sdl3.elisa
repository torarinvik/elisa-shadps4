const SDL_BUTTON_MIDDLE: u8 = 2u8
const SDL_BUTTON_X1: u8 = 4u8
const SDL_BUTTON_X2: u8 = 5u8
const SDL_KMOD_CTRL: u32 = 0x00C0u32
const SDL_KMOD_SHIFT: u32 = 0x0003u32
const SDL_KMOD_ALT: u32 = 0x0300u32
const SDL_KMOD_GUI: u32 = 0x0C00u32

