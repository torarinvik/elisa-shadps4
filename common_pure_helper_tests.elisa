@test
def common_hash_combine_matches_cpp_constants() -> void:
    can Abort.Panic:
        assert HashCombine64(0x1234.u64(), 0x5678.u64()) == 0x9f5b0360.u64()
        assert HashCombine32(0x1234.u32(), 0x5678.u32()) == 0x9e3c738a.u32()

@test
def common_alignment_helpers_match_cpp_masks() -> void:
    can Abort.Panic:
        assert IsAligned(0, 0)
        assert not IsAligned(16, 0)
        assert IsAligned(0x4000, 0x4000)
        assert not IsAligned(0x4001, 0x4000)
        assert Is16KBAligned(0x8000)
        assert Is64KBAligned(0x10000)
        assert Is2MBAligned(0x200000)

@test
def common_bit_field_unsigned_and_signed_extract() -> void:
    can Abort.Panic:
        field: mutable BitField = BitField(0, 3, 5)
        BitField_set(field.ref[mutable BitField&], 17)
        assert field.storage == 0x88.u64()
        assert BitField_get(field.ref[BitField&]) == 17

        signed_field: mutable BitField = BitField(0, 3, 5)
        BitField_set_signed(signed_field.ref[mutable BitField&], -3)
        assert signed_field.storage == 0xe8.u64()
        assert BitField_get_signed(signed_field.ref[BitField&]) == -3

@test
def common_string_helpers_are_elisa_owned() -> void:
    can Abort.Panic:
        assert ascii_tolower('A') == 'a'
        assert ascii_tolower('z') == 'z'
        lowered: mutable static u8& = ""
        can Memory.Allocate:
            lowered <- ToLower("AbC123")
        assert lowered[0] == 'a'
        assert lowered[1] == 'b'
        assert lowered[2] == 'c'
        assert lowered[3] == '1'
        assert runtime_strlen(lowered) == 6

        owner: mutable Arena& = scratch_arena.ref[mutable Arena&]
        part: mutable static u8& = ""
        can Memory.Allocate:
            part <- string_substr_in(owner, "alpha", 1, 3)
        assert runtime_strlen(part) == 3
        assert part[0] == 'l'
        assert part[1] == 'p'
        assert part[2] == 'h'

@test
def common_uint128_helpers_are_elisa_owned() -> void:
    can Abort.Panic:
        product: U128Product = Multiply64Into128(0xffffffffffffffff, 2)
        assert product.low == 0xfffffffffffffffe
        assert product.high == 1
        assert MultiplyHigh(0xffffffffffffffff, 0xffffffffffffffff) == 0xfffffffffffffffe
        assert MultiplyAndDivide64(100, 30, 7) == 428

        divided: Div128Result = Divide128On32(U128Product(10, 1), 3)
        assert divided.quotient == 0x5555555555555558
        assert divided.remainder == 2

@test
def common_serdes_byte_roundtrip_is_elisa_owned() -> void:
    can Abort.Panic:
        writer: mutable Writer = Writer_new()
        input: u32 = 0x12345678
        can Memory.Allocate:
            Writer_write(writer.ref[mutable Writer&], input.ref[u32&])
        assert writer.archive.data.count == 4

        reader: mutable Reader = Reader_new(writer.archive.data)
        output: mutable u32 = 0
        Reader_read(reader.ref[mutable Reader&], output.ref[mutable u32&])
        assert output == input

@test
def common_memory_patcher_hex_helpers_are_elisa_owned() -> void:
    can Abort.Panic:
        hex: mutable static u8& = ""
        can Memory.Allocate:
            hex <- toHex(0xab.u64(), 2)
        assert hex[0] == '0'
        assert hex[1] == '0'
        assert hex[2] == 'a'
        assert hex[3] == 'b'
        assert patcher_parse_u64("ff", 16) == 255
        assert patcher_parse_u64("77", 8) == 63

        utf8: mutable static u8& = ""
        can Memory.Allocate:
            utf8 <- patcher_utf8_to_hex("Az")
        assert utf8[0] == '4'
        assert utf8[1] == '1'
        assert utf8[2] == '7'
        assert utf8[3] == 'a'
        assert utf8[4] == '0'
        assert utf8[5] == '0'

@test
def common_bit_array_count_uses_intrinsic_path() -> void:
    can Abort.Panic:
        owner: mutable Arena& = scratch_arena.ref[mutable Arena&]
        bits: mutable BitArray = zeroed
        can Memory.Allocate:
            bits <- BitArray_new(owner, 128)
        BitArray_set(bits.ref[mutable BitArray&], 1)
        BitArray_set(bits.ref[mutable BitArray&], 64)
        BitArray_set(bits.ref[mutable BitArray&], 127)
        assert BitArray_count_true(bits.ref[BitArray&]) == 3

@test
def common_sha1_is_elisa_owned() -> void:
    can Abort.Panic:
        ctx: mutable SHA1Context = SHA1Context_new()
        input: static u8& = "abc"
        SHA1_Update(ctx.ref[mutable SHA1Context&], input[0].ref[u8&], 3)
        digest: SHA1Digest = SHA1_Final(ctx.ref[mutable SHA1Context&])
        assert digest.bytes[0] == 0xa9
        assert digest.bytes[1] == 0x99
        assert digest.bytes[2] == 0x3e
        assert digest.bytes[3] == 0x36
        assert digest.bytes[4] == 0x47
        assert digest.bytes[5] == 0x06
        assert digest.bytes[6] == 0x81
        assert digest.bytes[7] == 0x6a
        assert digest.bytes[8] == 0xba
        assert digest.bytes[9] == 0x3e
        assert digest.bytes[10] == 0x25
        assert digest.bytes[11] == 0x71
        assert digest.bytes[12] == 0x78
        assert digest.bytes[13] == 0x50
        assert digest.bytes[14] == 0xc2
        assert digest.bytes[15] == 0x6c
        assert digest.bytes[16] == 0x9c
        assert digest.bytes[17] == 0xd0
        assert digest.bytes[18] == 0xd8
        assert digest.bytes[19] == 0x9d

@test
def common_number_utils_no_bitcast_shims() -> void:
    can Abort.Panic:
        assert U8ToUnorm(255) > 0.999
        assert S8ToSnorm(127) > 0.999

@test
def common_number_utils_half_conversion_is_elisa_owned() -> void:
    can Abort.Panic:
        assert Uf16ToF32(0x3c00.u16()) > 0.999 and Uf16ToF32(0x3c00.u16()) < 1.001

@test
def common_number_utils_half_sign_is_elisa_owned() -> void:
    can Abort.Panic:
        assert Uf16ToF32(0xc000.u16()) < -1.999 and Uf16ToF32(0xc000.u16()) > -2.001

@test
def common_number_utils_uf10_uf11_are_elisa_owned() -> void:
    can Abort.Panic:
        assert Uf11ToF32(0x03c0) > 0.999 and Uf11ToF32(0x03c0) < 1.001
        assert Uf10ToF32(0x01e0) > 0.999 and Uf10ToF32(0x01e0) < 1.001

@test
def common_discord_store_image_url_is_elisa_owned() -> void:
    can Abort.Panic:
        url: mutable static u8& = ""
        can Memory.Allocate:
            url <- make_playstation_store_image_url("CUSA00000")
        assert runtime_strlen(url) == 101
        assert url[0] == 'h'
        assert url[83] == 'C'
        assert url[91] == '0'
        assert url[92] == '_'
        assert url[100] == 'e'
