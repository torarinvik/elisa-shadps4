include "../compiler/runtime/elisacore_std/elisacore_runtime.elisa"
include "./common/alignment.elisa"
include "./common/hash.elisa"

@test
def common_hash_combine_matches_cpp_constants() -> void:
    can Abort.Panic:
        assert HashCombine64(0x1234.u64(), 0x5678.u64()) == 0x9f5b0360.u64()
        assert HashCombine32(0x1234.u32(), 0x5678.u32()) == 0x9e3c738a.u32()

@test
def common_alignment_helpers_match_cpp_masks() -> void:
    can Abort.Panic:
        assert IsAligned(0, 0)
        assert not IsAligned(16, 0)
        assert IsAligned(0x4000, 0x4000)
        assert not IsAligned(0x4001, 0x4000)
        assert Is16KBAligned(0x8000)
        assert Is64KBAligned(0x10000)
        assert Is2MBAligned(0x200000)
