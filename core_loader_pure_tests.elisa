include "../compiler/runtime/elisacore_std/elisacore_runtime.elisa"
include "./core/loader/elf.elisa"
include "./core/loader/dwarf.elisa"

@test
def loader_self_validation_contracts() -> void:
    can Abort.Panic:
        e: mutable Elf = Elf_new()
        e.self.magic <- 0x1D3D154Fu32
        e.self.version <- 0x00u8
        e.self.mode <- 0x01u8
        e.self.endian <- 0x01u8
        e.self.attributes <- 0x12u8
        e.self.category <- 0x01u8
        e.self.program_type <- 0x01u8
        assert Elf_IsSelfFile(e.ref[Elf&])
        e.self.attributes <- 0x00u8
        assert not Elf_IsSelfFile(e.ref[Elf&])

@test
def loader_elf_validation_contracts() -> void:
    can Abort.Panic:
        e: mutable Elf = Elf_new()
        e.elf_header_value.e_ident.magic[0] <- 0x7Fu8
        e.elf_header_value.e_ident.magic[1] <- 'E'.u8()
        e.elf_header_value.e_ident.magic[2] <- 'L'.u8()
        e.elf_header_value.e_ident.magic[3] <- 'F'.u8()
        e.elf_header_value.e_ident.ei_class <- 0x02u8
        e.elf_header_value.e_ident.ei_data <- 0x01u8
        e.elf_header_value.e_ident.ei_version <- 0x01u8
        e.elf_header_value.e_ident.ei_osabi <- 0x09u8
        e.elf_header_value.e_ident.ei_abiversion <- 0x00u8
        e.elf_header_value.e_type <- ET_SCE_DYNEXEC
        e.elf_header_value.e_machine <- EM_X86_64
        e.elf_header_value.e_version <- EV_CURRENT
        e.elf_header_value.e_phentsize <- size_of(elf_program_header).u16()
        e.elf_header_value.e_shentsize <- 64u16
        assert Elf_IsElfFile(e.ref[Elf&])
        e.elf_header_value.e_shentsize <- 16u16
        assert not Elf_IsElfFile(e.ref[Elf&])

@test
def loader_self_segment_flag_helpers() -> void:
    can Abort.Panic:
        seg: mutable self_segment_header = zeroed
        seg.flags <- (0x123u64 << 20u64) | 0x800u64
        assert SelfSegment_IsBlocked(seg.ref[self_segment_header&])
        assert SelfSegment_GetId(seg.ref[self_segment_header&]) == 0x123u32

@test
def loader_dwarf_decode_rejects_short_header() -> void:
    can Abort.Panic:
        info: mutable EHHeaderInfo = zeroed
        assert not DecodeEHHdr(0u64.uintptr(), 0u64.uintptr(), info.ref[mutable EHHeaderInfo&])

@test
def loader_dwarf_leb128_helpers() -> void:
    can Abort.Panic:
        uleb: mutable u8[2] = [0xE5u8, 0x8Eu8]
        # Append termination byte for value 624485 => E5 8E 26.
        uleb3: mutable u8[3] = [0xE5u8, 0x8Eu8, 0x26u8]
        p1: mutable uintptr = uleb3[0].ref[u8&].uintptr()
        assert Dwarf_ReadULEB128(p1.ref[mutable uintptr&]) == 624485u64

        sleb: mutable u8[1] = [0x7fu8] # -1
        p2: mutable uintptr = sleb[0].ref[u8&].uintptr()
        assert Dwarf_ReadSLEB128(p2.ref[mutable uintptr&]).cast[s64] == (-1).s64()
