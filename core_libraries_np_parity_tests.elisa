@test
def np_manager_signed_out_contracts_match_cpp_defaults() -> void:
    can Abort.Panic:
        user_id: mutable s32 = 0
        assert sceNpGetUserIdByAccountId(123, null) == ORBIS_NP_ERROR_INVALID_ARGUMENT
        assert sceNpGetUserIdByAccountId(123, user_id.ref[mutable s32&]) == ORBIS_NP_ERROR_SIGNED_OUT

        signed_up: mutable bool = true
        assert sceNpHasSignedUp(1, null) == ORBIS_NP_ERROR_INVALID_ARGUMENT
        assert sceNpHasSignedUp(1, signed_up.ref[mutable bool&]) == ORBIS_OK
        assert signed_up == false
