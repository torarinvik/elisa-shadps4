include "../compiler/runtime/elisacore_std/elisacore_runtime.elisa"
include "./core/libraries/np/np.elisa"

@test
def np_web_api2_stub_contracts_match_cpp() -> void:
    can Abort.Panic:
        assert sceNpWebApi2Initialize(1, 0x1000) == ORBIS_OK
        assert sceNpWebApi2InitializeForPresence(1, 0x1000) == ORBIS_OK
        assert sceNpWebApi2Terminate(123) == ORBIS_OK
        assert sceNpWebApi2AbortRequest(-1) == ORBIS_OK
        assert sceNpWebApi2DeleteRequest(-1) == ORBIS_OK
        assert sceNpWebApi2SetRequestTimeout(-1, 30) == ORBIS_OK
        assert sceNpWebApi2GetMemoryPoolStats(99, null) == ORBIS_OK

        assert sceNpWebApi2CreateUserContext(0x8000, 1) == ORBIS_NP_WEBAPI2_ERROR_INVALID_LIB_CONTEXT_ID
        assert sceNpWebApi2CreateUserContext(1, ORBIS_NP_WEBAPI2_USER_SERVICE_USER_ID_INVALID) == ORBIS_NP_WEBAPI2_ERROR_INVALID_ARGUMENT
        assert sceNpWebApi2CreateUserContext(1, 42) == ORBIS_OK

        data: mutable u8[4] = zeroed
        assert sceNpWebApi2ReadData(1, null, 4) == ORBIS_NP_WEBAPI2_ERROR_INVALID_ARGUMENT
        assert sceNpWebApi2ReadData(1, data[0].ref[mutable u8&].cast[mutable void&], 0) == ORBIS_NP_WEBAPI2_ERROR_INVALID_ARGUMENT
        assert sceNpWebApi2ReadData(1, data[0].ref[mutable u8&].cast[mutable void&], 4) == ORBIS_OK
        assert sceNpWebApi2SendRequest() == ORBIS_NP_WEBAPI2_ERROR_NOT_SIGNED_IN

@test
def np_score_registered_stubs_match_cpp_ok_returns() -> void:
    can Abort.Panic:
        assert sceNpScoreCreateNpTitleCtx(1, null) == ORBIS_OK
        assert sceNpScoreCreateNpTitleCtxA(1, 42) == ORBIS_OK
        assert sceNpScoreCreateTitleCtx() == ORBIS_OK
        assert sceNpScoreCreateRequest(123) == ORBIS_OK
        assert sceNpScoreAbortRequest(-1) == ORBIS_OK
        assert sceNpScoreWaitAsync(-1, null) == ORBIS_OK
        assert sceNpScorePollAsync(-1, null) == ORBIS_OK
        assert sceNpScoreSanitizeComment(-1, null, null, null) == ORBIS_OK
        assert sceNpScoreGetFriendsRanking() == ORBIS_OK
        assert sceNpScoreRecordScore() == ORBIS_OK

@test
def np_tus_registered_stubs_match_cpp_ok_returns() -> void:
    can Abort.Panic:
        assert sceNpTusAddAndGetVariable() == ORBIS_OK
        assert sceNpTusDeleteMultiSlotData() == ORBIS_OK
        assert sceNpTusGetFriendsDataStatus() == ORBIS_OK
        assert sceNpTusGetFriendsVariable() == ORBIS_OK
        assert sceNpTusGetMultiSlotVariable() == ORBIS_OK
        assert sceNpTusSetMultiSlotVariable() == ORBIS_OK
        assert sceNpTusTryAndSetVariable() == ORBIS_OK
        assert sceNpTssGetStorage() == ORBIS_OK
        assert sceNpTssGetSmallStorageAsync() == ORBIS_OK

