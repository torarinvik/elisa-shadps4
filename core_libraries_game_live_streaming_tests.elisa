include "../compiler/runtime/elisacore_std/elisacore_runtime.elisa"
include "./core/libraries/error_codes.elisa"
include "./core/libraries/game_live_streaming/gamelivestreaming.elisa"

@test
def game_live_streaming_status_zeroing() -> void:
    can Abort.Panic:
        status: mutable OrbisGameLiveStreamingStatus = zeroed
        status.isOnAir <- true
        status.spectatorCounts <- 123u32
        status.userId <- 77
        status.reserved[0] <- 1u8
        assert sceGameLiveStreamingGetCurrentStatus(status.ref[mutable OrbisGameLiveStreamingStatus&]) == ORBIS_OK
        assert status.isOnAir == false
        assert status.spectatorCounts == 0u32
        assert status.userId == 0
        assert status.reserved[0] == 0u8

@test
def game_live_streaming_stub_calls_return_ok() -> void:
    can Abort.Panic:
        assert sceGameLiveStreamingStartDebugBroadcast() == ORBIS_OK
        assert sceGameLiveStreamingStopDebugBroadcast() == ORBIS_OK
        assert sceGameLiveStreamingInitialize() == ORBIS_OK
        assert sceGameLiveStreamingTerminate() == ORBIS_OK
        assert sceGameLiveStreamingLaunchLiveViewer() == ORBIS_OK
        assert sceGameLiveStreamingLaunchLiveViewerA() == ORBIS_OK

@test
def game_live_streaming_nid_table_matches_cpp() -> void:
    can Abort.Panic:
        assert GAME_LIVE_STREAMING_NIDS_COUNT == 51usize
        first: GameLiveStreamingNidEntry = GameLiveStreaming_NidEntryAt(0usize)
        assert first.nid == "caqgDl+V9qA"
        assert first.lib_name == "libSceGameLiveStreaming_debug"
        direct: GameLiveStreamingNidEntry = GameLiveStreaming_NidEntryAt(47usize)
        assert direct.nid == "caqgDl+V9qA"
        assert direct.lib_name == "libSceGameLiveStreaming_direct_streaming"
        last: GameLiveStreamingNidEntry = GameLiveStreaming_NidEntryAt(50usize)
        assert last.nid == "ysWfX5PPbfc"
        assert last.lib_name == "libSceGameLiveStreamingCompat"
        assert last.symbol_name == "sceGameLiveStreamingLaunchLiveViewer"
