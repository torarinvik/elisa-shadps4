        z[8] <- 8.u8()
        z[9] <- 5.u8()
        z[10] <- 192.u8()
        z[11] <- 85.u8()
        z[12] <- 222.u8()
        z[13] <- 0.u8()
        z[14] <- 165.u8()
        z[15] <- 59.u8()
        z[16] <- 5.u8()
        z[17] <- 35.u8()
        z[18] <- 225.u8()
        z[19] <- 129.u8()
        z[20] <- 198.u8()
        z[21] <- 160.u8()
        z[22] <- 102.u8()
        z[23] <- 255.u8()
        z[24] <- 174.u8()
        z[25] <- 209.u8()
        z[26] <- 251.u8()
        z[27] <- 63.u8()
        z[28] <- 139.u8()
        z[29] <- 84.u8()
        z[30] <- 7.u8()
        z[31] <- 79.u8()
        z[32] <- 93.u8()
        z[33] <- 199.u8()
        z[34] <- 12.u8()
        z[35] <- 139.u8()
        z[36] <- 68.u8()
        z[37] <- 177.u8()
        z[38] <- 49.u8()
        z[39] <- 92.u8()
        z[40] <- 251.u8()
        z[41] <- 129.u8()
        z[42] <- 196.u8()
        z[43] <- 46.u8()
        z[44] <- 149.u8()
        z[45] <- 214.u8()
        z[46] <- 190.u8()
        z[47] <- 137.u8()
        z[48] <- 49.u8()
        z[49] <- 121.u8()
        z[50] <- 88.u8()
        z[51] <- 194.u8()
        z[52] <- 189.u8()
        z[53] <- 160.u8()
        z[54] <- 198.u8()
        z[55] <- 126.u8()
        z[56] <- 97.u8()
        z[57] <- 255.u8()
        z[58] <- 138.u8()
        z[59] <- 31.u8()
        z[60] <- 91.u8()
        z[61] <- 94.u8()
        z[62] <- 74.u8()
        z[63] <- 54.u8()

        assert (((z[2] >> 1.u8()) & 0x3.u8()) == 2.u8())
        out: mutable u8[256] = zeroed
        n: int = PngDec_InflateStored(z.ref[mutable u8&], 64, out.ref[mutable u8&], 256)
        assert n == 200

        assert out[0] == 108.u8()
        assert out[1] == 111.u8()
        assert out[2] == 114.u8()
        assert out[3] == 101.u8()
        assert out[4] == 109.u8()
        assert out[5] == 32.u8()
        assert out[6] == 105.u8()
        assert out[7] == 112.u8()
        assert out[8] == 115.u8()
        assert out[9] == 117.u8()
        assert out[10] == 109.u8()
        assert out[11] == 32.u8()
        assert out[12] == 100.u8()
        assert out[13] == 111.u8()
        assert out[14] == 108.u8()
        assert out[15] == 111.u8()
        assert out[16] == 114.u8()
        assert out[17] == 32.u8()

