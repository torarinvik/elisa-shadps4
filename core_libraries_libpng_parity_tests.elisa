include "../compiler/runtime/elisacore_std/elisacore_runtime.elisa"
include "./core/libraries/libpng/pngdec.elisa"
include "./core/libraries/libpng/pngenc.elisa"
include "./core_libraries_libpng_integration.elisa"

@test
def pngdec_create_query_parse_decode_delete() -> void:
    can Abort.Panic:
        create: mutable OrbisPngDecCreateParam = zeroed
        create.this_size <- size_of(OrbisPngDecCreateParam).u32()
        create.attribute <- 0
        create.max_image_width <- 4096
        assert scePngDecQueryMemorySize(create.ref[OrbisPngDecCreateParam&]) == size_of(OrbisPngDecHandleInternal).i32()

        handle_mem: mutable u8[64] = zeroed
        handle: mutable OrbisPngDecHandle = null
        assert scePngDecCreate(create.ref[OrbisPngDecCreateParam&], handle_mem.ref[mutable u8&] as mutable void&?, 64, handle.ref[mutable OrbisPngDecHandle&]) == ORBIS_OK

        enc_create: mutable OrbisPngEncCreateParam = zeroed
        enc_create.this_size <- size_of(OrbisPngEncCreateParam).u32()
        enc_create.attribute <- ORBIS_PNG_ENC_ATTRIBUTE_NONE
        enc_create.max_image_width <- 4096
        enc_create.max_filter_number <- 5
        enc_handle_mem: mutable u8[64] = zeroed
        enc_handle: mutable OrbisPngEncHandle = null
        assert scePngEncCreate(enc_create.ref[OrbisPngEncCreateParam&], enc_handle_mem.ref[mutable u8&] as mutable void&?, 64, enc_handle.ref[mutable OrbisPngEncHandle&]) == ORBIS_OK

        src_rgba: mutable u8[16] = zeroed
        src_rgba[0] <- 10.u8()
        src_rgba[1] <- 20.u8()
        src_rgba[2] <- 30.u8()
        src_rgba[3] <- 255.u8()
        src_rgba[4] <- 40.u8()
        src_rgba[5] <- 50.u8()
        src_rgba[6] <- 60.u8()
        src_rgba[7] <- 254.u8()
        src_rgba[8] <- 70.u8()
        src_rgba[9] <- 80.u8()
        src_rgba[10] <- 90.u8()
        src_rgba[11] <- 253.u8()
        src_rgba[12] <- 100.u8()
        src_rgba[13] <- 110.u8()
        src_rgba[14] <- 120.u8()
        src_rgba[15] <- 252.u8()

        png_mem: mutable u8[256] = zeroed
        enc: mutable OrbisPngEncEncodeParam = zeroed
        enc.image_mem_addr <- src_rgba.ref[u8&]
        enc.png_mem_addr <- png_mem.ref[mutable u8&]
        enc.image_mem_size <- 16
        enc.png_mem_size <- 256
        enc.image_width <- 2
        enc.image_height <- 2
        enc.image_pitch <- 8
        enc.pixel_format <- ORBIS_PNG_ENC_PIXEL_FORMAT_R8G8B8A8
        enc.color_space <- ORBIS_PNG_ENC_COLOR_SPACE_RGBA
        enc.bit_depth <- 8
        enc.filter_type <- ORBIS_PNG_ENC_FILTER_TYPE_ALL
        enc.compression_level <- 6
        enc_info: mutable OrbisPngEncOutputInfo = zeroed
        assert scePngEncEncode(enc_handle, enc.ref[OrbisPngEncEncodeParam&], enc_info.ref[mutable OrbisPngEncOutputInfo&]) > 45
        assert scePngEncDelete(enc_handle) == ORBIS_OK

        parse_param: mutable OrbisPngDecParseParam = zeroed
        parse_param.png_mem_addr <- png_mem.ref[u8&]
        parse_param.png_mem_size <- enc_info.data_size
        info: mutable OrbisPngDecImageInfo = zeroed
        assert scePngDecParseHeader(parse_param.ref[OrbisPngDecParseParam&], info.ref[mutable OrbisPngDecImageInfo&]) == ORBIS_OK
        assert info.image_width == 2.u32()
        assert info.image_height == 2.u32()
        assert info.bit_depth == 8.u16()
        assert info.color_space == ORBIS_PNG_DEC_COLOR_SPACE_RGBA

        decode_param: mutable OrbisPngDecDecodeParam = zeroed
        out_img: mutable u8[128] = zeroed
        decode_param.png_mem_addr <- png_mem.ref[u8&]
        decode_param.image_mem_addr <- out_img.ref[mutable u8&]
        decode_param.png_mem_size <- enc_info.data_size
        decode_param.image_mem_size <- 128
        decode_param.pixel_format <- ORBIS_PNG_DEC_PIXEL_FORMAT_R8G8B8A8
        decode_param.alpha_value <- 255
        decode_param.image_pitch <- 0
        decoded_wh: int = scePngDecDecode(handle, decode_param.ref[OrbisPngDecDecodeParam&], info.ref[mutable OrbisPngDecImageInfo&])
        assert decoded_wh == ((2 << 16) | 2)
        assert out_img[0] == 10.u8()
        assert out_img[1] == 20.u8()
        assert out_img[2] == 30.u8()
        assert out_img[3] == 255.u8()
        assert scePngDecDelete(handle) == ORBIS_OK

@test
def pngenc_create_encode_delete_and_overflow() -> void:
    can Abort.Panic:
        create: mutable OrbisPngEncCreateParam = zeroed
        create.this_size <- size_of(OrbisPngEncCreateParam).u32()
        create.attribute <- ORBIS_PNG_ENC_ATTRIBUTE_NONE
        create.max_image_width <- 4096
        create.max_filter_number <- 5
        assert scePngEncQueryMemorySize(create.ref[OrbisPngEncCreateParam&]) == size_of(OrbisPngEncHandleInternal).i32()

        handle_mem: mutable u8[64] = zeroed
        handle: mutable OrbisPngEncHandle = null
        assert scePngEncCreate(create.ref[OrbisPngEncCreateParam&], handle_mem.ref[mutable u8&] as mutable void&?, 64, handle.ref[mutable OrbisPngEncHandle&]) == ORBIS_OK

        src: mutable u8[16] = zeroed
        out_small: mutable u8[8] = zeroed
        enc: mutable OrbisPngEncEncodeParam = zeroed
        enc.image_mem_addr <- src.ref[u8&]
        enc.png_mem_addr <- out_small.ref[mutable u8&]
        enc.image_mem_size <- 16
        enc.png_mem_size <- 8
        enc.image_width <- 1
        enc.image_height <- 1
        enc.image_pitch <- 4
        enc.pixel_format <- ORBIS_PNG_ENC_PIXEL_FORMAT_R8G8B8A8
        enc.color_space <- ORBIS_PNG_ENC_COLOR_SPACE_RGBA
        enc.bit_depth <- 8
        enc.filter_type <- ORBIS_PNG_ENC_FILTER_TYPE_ALL
        enc.compression_level <- 6
        out_info: mutable OrbisPngEncOutputInfo = zeroed
        assert scePngEncEncode(handle, enc.ref[OrbisPngEncEncodeParam&], out_info.ref[mutable OrbisPngEncOutputInfo&]) == ORBIS_PNG_ENC_ERROR_DATA_OVERFLOW

        out_ok: mutable u8[128] = zeroed
        enc.png_mem_addr <- out_ok.ref[mutable u8&]
        enc.png_mem_size <- 128
        written: int = scePngEncEncode(handle, enc.ref[OrbisPngEncEncodeParam&], out_info.ref[mutable OrbisPngEncOutputInfo&])
        assert written > 45
        assert out_info.data_size == written.u32()
        assert out_info.processed_height == 1.u32()
        assert out_ok[0] == 137.u8()
        assert out_ok[1] == 80.u8()
        assert out_ok[12] == 73.u8()
        assert out_ok[13] == 72.u8()
        assert out_ok[14] == 68.u8()
        assert out_ok[15] == 82.u8()
        assert scePngEncDelete(handle) == ORBIS_OK

@test
def png_filter_sub_roundtrip() -> void:
    can Abort.Panic:
        enc_create: mutable OrbisPngEncCreateParam = zeroed
        enc_create.this_size <- size_of(OrbisPngEncCreateParam).u32()
        enc_create.attribute <- ORBIS_PNG_ENC_ATTRIBUTE_NONE
        enc_create.max_image_width <- 4096
        enc_create.max_filter_number <- 5
        enc_handle_mem: mutable u8[64] = zeroed
        enc_handle: mutable OrbisPngEncHandle = null
        assert scePngEncCreate(enc_create.ref[OrbisPngEncCreateParam&], enc_handle_mem.ref[mutable u8&] as mutable void&?, 64, enc_handle.ref[mutable OrbisPngEncHandle&]) == ORBIS_OK

        src: mutable u8[16] = zeroed
        src[0] <- 1.u8()
        src[1] <- 2.u8()
        src[2] <- 3.u8()
        src[3] <- 4.u8()
        src[4] <- 10.u8()
        src[5] <- 20.u8()
        src[6] <- 30.u8()
        src[7] <- 40.u8()
        src[8] <- 50.u8()
        src[9] <- 60.u8()
        src[10] <- 70.u8()
        src[11] <- 80.u8()
        src[12] <- 90.u8()
        src[13] <- 100.u8()
        src[14] <- 110.u8()
        src[15] <- 120.u8()

        png_mem: mutable u8[256] = zeroed
        enc: mutable OrbisPngEncEncodeParam = zeroed
        enc.image_mem_addr <- src.ref[u8&]
        enc.png_mem_addr <- png_mem.ref[mutable u8&]
        enc.image_mem_size <- 16
        enc.png_mem_size <- 256
        enc.image_width <- 2
        enc.image_height <- 2
        enc.image_pitch <- 8
        enc.pixel_format <- ORBIS_PNG_ENC_PIXEL_FORMAT_R8G8B8A8
        enc.color_space <- ORBIS_PNG_ENC_COLOR_SPACE_RGBA
        enc.bit_depth <- 8
        enc.filter_type <- ORBIS_PNG_ENC_FILTER_TYPE_SUB
        enc.compression_level <- 6
        out_info: mutable OrbisPngEncOutputInfo = zeroed
        assert scePngEncEncode(enc_handle, enc.ref[OrbisPngEncEncodeParam&], out_info.ref[mutable OrbisPngEncOutputInfo&]) > 45
        assert scePngEncDelete(enc_handle) == ORBIS_OK

        dec_create: mutable OrbisPngDecCreateParam = zeroed
        dec_create.this_size <- size_of(OrbisPngDecCreateParam).u32()
        dec_create.attribute <- 0
        dec_create.max_image_width <- 4096
        dec_mem: mutable u8[64] = zeroed
        dec_handle: mutable OrbisPngDecHandle = null
        assert scePngDecCreate(dec_create.ref[OrbisPngDecCreateParam&], dec_mem.ref[mutable u8&] as mutable void&?, 64, dec_handle.ref[mutable OrbisPngDecHandle&]) == ORBIS_OK

        dec_param: mutable OrbisPngDecDecodeParam = zeroed
        out_img: mutable u8[64] = zeroed
        dec_param.png_mem_addr <- png_mem.ref[u8&]
        dec_param.image_mem_addr <- out_img.ref[mutable u8&]
        dec_param.png_mem_size <- out_info.data_size
        dec_param.image_mem_size <- 64
        dec_param.pixel_format <- ORBIS_PNG_DEC_PIXEL_FORMAT_R8G8B8A8
        dec_param.alpha_value <- 0
        dec_param.image_pitch <- 0
        assert scePngDecDecode(dec_handle, dec_param.ref[OrbisPngDecDecodeParam&], null) == ((2 << 16) | 2)
        assert out_img[0] == 1.u8()
        assert out_img[1] == 2.u8()
        assert out_img[2] == 3.u8()
        assert out_img[3] == 4.u8()
        assert out_img[4] == 10.u8()
        assert out_img[5] == 20.u8()
        assert out_img[6] == 30.u8()
        assert out_img[7] == 40.u8()
        assert scePngDecDelete(dec_handle) == ORBIS_OK

def png_roundtrip_with_filter(filter_type: u16) -> void:
    can Abort.Panic:
        enc_create: mutable OrbisPngEncCreateParam = zeroed
        enc_create.this_size <- size_of(OrbisPngEncCreateParam).u32()
        enc_create.attribute <- ORBIS_PNG_ENC_ATTRIBUTE_NONE
        enc_create.max_image_width <- 4096
        enc_create.max_filter_number <- 5
        enc_handle_mem: mutable u8[64] = zeroed
        enc_handle: mutable OrbisPngEncHandle = null
        assert scePngEncCreate(enc_create.ref[OrbisPngEncCreateParam&], enc_handle_mem.ref[mutable u8&] as mutable void&?, 64, enc_handle.ref[mutable OrbisPngEncHandle&]) == ORBIS_OK

        src: mutable u8[32] = zeroed
        i: u32 = 0
        while i < 32:
            src[i.usize()] <- (i * 7 + 3).u8()
            i <- i + 1

        png_mem: mutable u8[512] = zeroed
        enc: mutable OrbisPngEncEncodeParam = zeroed
        enc.image_mem_addr <- src.ref[u8&]
        enc.png_mem_addr <- png_mem.ref[mutable u8&]
        enc.image_mem_size <- 32
        enc.png_mem_size <- 512
        enc.image_width <- 2
        enc.image_height <- 4
        enc.image_pitch <- 8
        enc.pixel_format <- ORBIS_PNG_ENC_PIXEL_FORMAT_R8G8B8A8
        enc.color_space <- ORBIS_PNG_ENC_COLOR_SPACE_RGBA
        enc.bit_depth <- 8
        enc.filter_type <- filter_type
        enc.compression_level <- 6
        out_info: mutable OrbisPngEncOutputInfo = zeroed
        assert scePngEncEncode(enc_handle, enc.ref[OrbisPngEncEncodeParam&], out_info.ref[mutable OrbisPngEncOutputInfo&]) > 45
        assert scePngEncDelete(enc_handle) == ORBIS_OK

        dec_create: mutable OrbisPngDecCreateParam = zeroed
        dec_create.this_size <- size_of(OrbisPngDecCreateParam).u32()
        dec_create.attribute <- 0
        dec_create.max_image_width <- 4096
        dec_mem: mutable u8[64] = zeroed
        dec_handle: mutable OrbisPngDecHandle = null
        assert scePngDecCreate(dec_create.ref[OrbisPngDecCreateParam&], dec_mem.ref[mutable u8&] as mutable void&?, 64, dec_handle.ref[mutable OrbisPngDecHandle&]) == ORBIS_OK

        dec_param: mutable OrbisPngDecDecodeParam = zeroed
        out_img: mutable u8[64] = zeroed
        dec_param.png_mem_addr <- png_mem.ref[u8&]
        dec_param.image_mem_addr <- out_img.ref[mutable u8&]
        dec_param.png_mem_size <- out_info.data_size
        dec_param.image_mem_size <- 64
        dec_param.pixel_format <- ORBIS_PNG_DEC_PIXEL_FORMAT_R8G8B8A8
        dec_param.alpha_value <- 0
        dec_param.image_pitch <- 0
        assert scePngDecDecode(dec_handle, dec_param.ref[OrbisPngDecDecodeParam&], null) == ((2 << 16) | 4)
        j: u32 = 0
        while j < 32:
            assert out_img[j.usize()] == src[j.usize()]
            j <- j + 1
        assert scePngDecDelete(dec_handle) == ORBIS_OK

@test
def png_filter_up_roundtrip() -> void:
    png_roundtrip_with_filter(ORBIS_PNG_ENC_FILTER_TYPE_UP)

@test
def png_filter_average_roundtrip() -> void:
    png_roundtrip_with_filter(ORBIS_PNG_ENC_FILTER_TYPE_AVERAGE)

@test
def png_filter_paeth_roundtrip() -> void:
    png_roundtrip_with_filter(ORBIS_PNG_ENC_FILTER_TYPE_PAETH)

@test
def png_filter_all_roundtrip() -> void:
    png_roundtrip_with_filter(ORBIS_PNG_ENC_FILTER_TYPE_ALL)

@test
def png_inflate_dynamic_huffman_smoke() -> void:
    can Abort.Panic:
        z: mutable u8[64] = zeroed
        z[0] <- 120.u8()
        z[1] <- 156.u8()
        z[2] <- 205.u8()
        z[3] <- 203.u8()
        z[4] <- 209.u8()
        z[5] <- 9.u8()
        z[6] <- 192.u8()
        z[7] <- 48.u8()
        z[8] <- 8.u8()
        z[9] <- 5.u8()
        z[10] <- 192.u8()
        z[11] <- 85.u8()
        z[12] <- 222.u8()
        z[13] <- 0.u8()
        z[14] <- 165.u8()
        z[15] <- 59.u8()
        z[16] <- 5.u8()
        z[17] <- 35.u8()
        z[18] <- 225.u8()
        z[19] <- 129.u8()
        z[20] <- 198.u8()
        z[21] <- 160.u8()
        z[22] <- 102.u8()
        z[23] <- 255.u8()
        z[24] <- 174.u8()
        z[25] <- 209.u8()
        z[26] <- 251.u8()
        z[27] <- 63.u8()
        z[28] <- 139.u8()
        z[29] <- 84.u8()
        z[30] <- 7.u8()
        z[31] <- 79.u8()
        z[32] <- 93.u8()
        z[33] <- 199.u8()
        z[34] <- 12.u8()
        z[35] <- 139.u8()
        z[36] <- 68.u8()
        z[37] <- 177.u8()
        z[38] <- 49.u8()
        z[39] <- 92.u8()
        z[40] <- 251.u8()
        z[41] <- 129.u8()
        z[42] <- 196.u8()
        z[43] <- 46.u8()
        z[44] <- 149.u8()
        z[45] <- 214.u8()
        z[46] <- 190.u8()
        z[47] <- 137.u8()
        z[48] <- 49.u8()
        z[49] <- 121.u8()
        z[50] <- 88.u8()
        z[51] <- 194.u8()
        z[52] <- 189.u8()
        z[53] <- 160.u8()
        z[54] <- 198.u8()
        z[55] <- 126.u8()
        z[56] <- 97.u8()
        z[57] <- 255.u8()
        z[58] <- 138.u8()
        z[59] <- 31.u8()
        z[60] <- 91.u8()
        z[61] <- 94.u8()
        z[62] <- 74.u8()
        z[63] <- 54.u8()

        assert (((z[2] >> 1.u8()) & 0x3.u8()) == 2.u8())
        out: mutable u8[256] = zeroed
        n: int = PngDec_InflateStored(z.ref[mutable u8&], 64, out.ref[mutable u8&], 256)
        assert n == 200

        assert out[0] == 108.u8()
        assert out[1] == 111.u8()
        assert out[2] == 114.u8()
        assert out[3] == 101.u8()
        assert out[4] == 109.u8()
        assert out[5] == 32.u8()
        assert out[6] == 105.u8()
        assert out[7] == 112.u8()
        assert out[8] == 115.u8()
        assert out[9] == 117.u8()
        assert out[10] == 109.u8()
        assert out[11] == 32.u8()
        assert out[12] == 100.u8()
        assert out[13] == 111.u8()
        assert out[14] == 108.u8()
        assert out[15] == 111.u8()
        assert out[16] == 114.u8()
        assert out[17] == 32.u8()
        assert out[18] == 115.u8()
        assert out[19] == 105.u8()
        assert out[20] == 116.u8()
        assert out[21] == 32.u8()
        assert out[22] == 97.u8()
        assert out[23] == 109.u8()

        assert out[188] == 32.u8()
        assert out[189] == 115.u8()
        assert out[190] == 105.u8()
        assert out[191] == 116.u8()
        assert out[192] == 32.u8()
        assert out[193] == 97.u8()
        assert out[194] == 109.u8()
        assert out[195] == 101.u8()
        assert out[196] == 116.u8()
        assert out[197] == 44.u8()
        assert out[198] == 32.u8()
        assert out[199] == 99.u8()
