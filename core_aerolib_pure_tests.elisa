include "../compiler/runtime/elisacore_std/elisacore_runtime.elisa"
include "./core/aerolib/aerolib.elisa"
include "./core/aerolib/aerolib_nids.elisa"
include "./core/aerolib/aerolib_find.elisa"

@test
def aerolib_string_compare_matches_strcmp_ordering() -> void:
    can Abort.Panic:
        assert AeroLib_StrCmp("abc", "abc") == 0
        assert AeroLib_StrCmp("abc", "abd") < 0
        assert AeroLib_StrCmp("abd", "abc") > 0
        assert AeroLib_StrCmp("ab", "abc") < 0
        assert AeroLib_StrCmp("abc", "ab") > 0

@test
def aerolib_find_by_nid_finds_generated_table_edges() -> void:
    can Abort.Panic:
        first: NidEntry? = FindByNid("++-URPJNZ18")
        assert first != null
        resolved_first: NidEntry = first
        assert AeroLib_StrCmp(resolved_first.name, "_ZN9Inspector17ScriptDebugServer23removeBreakpointActionsEm") == 0

        last: NidEntry? = FindByNid("zzwBT4Nl7t0")
        assert last != null
        resolved_last: NidEntry = last
        assert AeroLib_StrCmp(resolved_last.name, "_ZN3sce2Np9CppWebApi6Common12IntrusivePtrINS2_6VectorINS3_INS1_14SessionManager2V128ResponseGameSessionSpectatorEEEEEE7add_refEv") == 0

        missing: NidEntry? = FindByNid("not-a-real-nid")
        assert missing == null
