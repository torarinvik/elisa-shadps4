                a.end <- a.end.next
                a.end_index <- (a.end_index + 1)
                a.end.global_index <- a.end_index
            state.head_region <- a.end
            state.alloc_region <- a.end
            state.alloc_region_index <- a.end_index
            state.tail_region <- a.end
            packed_store_register_region(a, state, a.end, a.end_index)
            return
        assert((state.alloc_region != null))
        assert((state.tail_region != null))
        capacity: mutable usize = state.preferred_region_capacity
        grown_capacity: usize = (state.alloc_region.capacity * 2)
        if (capacity < grown_capacity):
            capacity <- grown_capacity
        if (capacity < size):
            capacity <- size
        assert((a.end != null))
        a.end.next as & <- new_region_with_owner(capacity, owner_tag)
        a.end <- a.end.next
        a.end_index <- (a.end_index + 1)
        a.end.global_index <- a.end_index
        state.tail_region.owner_next as & <- a.end
        state.tail_region <- a.end
        state.alloc_region <- a.end
        state.alloc_region_index <- a.end_index
        packed_store_register_region(a, state, a.end, a.end_index)

def ctx_packed_store_alloc_fixed_result(a: mutable Arena&, state_bits: mutable void&) -> PackedStoreAllocResult:
    can Memory.Allocate, Abort.Panic:
        assert((state_bits != null))
        state: PackedStoreState& = state_bits.cast[PackedStoreState&]
        owner_tag: uintptr = state_bits.cast[u8&].uintptr()
        size: usize = state.row_words
        assert((size > 0))
        if ((state.alloc_region == null) or ((state.alloc_region.count + size) > state.alloc_region.capacity)):
            ctx_packed_store_alloc_fixed_result_slow(a, owner_tag, state)
        assert((state.alloc_region != null))
        data_base: heap u8& = packed_store_region_data(state.alloc_region)
        offset_bytes: uintptr = ((state.alloc_region.count * size_of(uintptr))).uintptr()
        ptr: heap void& = ((data_base + (state.alloc_region.count * size_of(uintptr)))).cast[heap void&]
        state.alloc_region.count <- (state.alloc_region.count + size)
        state.decode_region <- state.alloc_region
        state.decode_region_index <- state.alloc_region_index
        if (a.end == null):
            a.end as & <- state.alloc_region
            a.end_index <- state.alloc_region_index
        offset_words: uintptr = (offset_bytes / size_of(uintptr).uintptr())
        handle: uintptr = (((state.alloc_region_index.uintptr() << 32.uintptr())) | ((((offset_words + 1.uintptr())) << 1.uintptr())))
        global_index: u32 = state.handles.count.u32()
        needed_rows: usize = (state.handles.count + 1)
        packed_store_ensure_metadata_capacity(a, state, needed_rows)
        in a:
            state.handles.push(handle)
            state.indices.push(global_index)
        return PackedStoreAllocResult(ptr, handle)

def ctx_packed_store_alloc_result(a: mutable Arena&, size_bytes: usize, state_bits: mutable void&) -> PackedStoreAllocResult:
    can Memory.Allocate, Abort.Panic:
        assert((state_bits != null))
        state: PackedStoreState& = state_bits.cast[PackedStoreState&]
        owner_tag: uintptr = state_bits.cast[u8&].uintptr()
        size: usize = ((((size_bytes + size_of(uintptr)) - 1)) / size_of(uintptr))
        if (size > state.row_words):
            state.row_words <- size
            hinted_capacity: usize = (state.row_words * PACKED_STORE_MIN_ROWS_PER_REGION)
            if (state.preferred_region_capacity < hinted_capacity):
                state.preferred_region_capacity <- hinted_capacity
            if (state.preferred_region_capacity < state.row_words):
                state.preferred_region_capacity <- state.row_words
        if ((state.alloc_region == null) or ((state.alloc_region.count + size) > state.alloc_region.capacity)):
            ctx_packed_store_alloc_result_slow(a, size, owner_tag, state)
        assert((state.alloc_region != null))
        data_base: heap u8& = packed_store_region_data(state.alloc_region)
        offset_bytes: uintptr = ((state.alloc_region.count * size_of(uintptr))).uintptr()
        ptr: heap void& = ((data_base + (state.alloc_region.count * size_of(uintptr)))).cast[heap void&]
        state.alloc_region.count <- (state.alloc_region.count + size)
        state.decode_region <- state.alloc_region
        state.decode_region_index <- state.alloc_region_index
        if (a.end == null):
            a.end as & <- state.alloc_region
            a.end_index <- state.alloc_region_index
        offset_words: uintptr = (offset_bytes / size_of(uintptr).uintptr())
        handle: uintptr = (((state.alloc_region_index.uintptr() << 32.uintptr())) | ((((offset_words + 1.uintptr())) << 1.uintptr())))
        global_index: u32 = state.handles.count.u32()
        needed_rows: usize = (state.handles.count + 1)
        packed_store_ensure_metadata_capacity(a, state, needed_rows)
        in a:
            state.handles.push(handle)
            state.indices.push(global_index)
        return PackedStoreAllocResult(ptr, handle)

def ctx_packed_store_alloc_fixed_index_result(a: mutable Arena&, state_bits: mutable void&) -> PackedStoreIndexAllocResult:
    can Memory.Allocate, Abort.Panic:
        result: PackedStoreAllocResult = ctx_packed_store_alloc_fixed_result(a, state_bits)
        state: PackedStoreState& = state_bits.cast[PackedStoreState&]
        assert((state.indices.items != null))
        assert((state.indices.count > 0))
        indices: u32& = state.indices.items
        return PackedStoreIndexAllocResult(result.row, indices[(state.indices.count - 1)])

def ctx_packed_store_alloc_index_result(a: mutable Arena&, size_bytes: usize, state_bits: mutable void&) -> PackedStoreIndexAllocResult:
    can Memory.Allocate, Abort.Panic:
        result: PackedStoreAllocResult = ctx_packed_store_alloc_result(a, size_bytes, state_bits)
        state: PackedStoreState& = state_bits.cast[PackedStoreState&]
        assert((state.indices.items != null))
        assert((state.indices.count > 0))
        indices: u32& = state.indices.items
        return PackedStoreIndexAllocResult(result.row, indices[(state.indices.count - 1)])

def ctx_packed_store_count(state_bits: mutable void&) -> usize:
    assert((state_bits != null))
    state: PackedStoreState& = state_bits.cast[PackedStoreState&]
    return state.handles.count

def ctx_packed_store_index_at(state_bits: mutable void&, index: usize) -> u32:
    assert((state_bits != null))
    state: PackedStoreState& = state_bits.cast[PackedStoreState&]
    assert((state.indices.items != null))
    assert((index < state.indices.count))
    indices: u32& = state.indices.items
    return indices[index]

def ctx_packed_store_view(state_bits: mutable void&, start: usize, end: usize) -> dview[uintptr]:
    assert((state_bits != null))
    state: PackedStoreState& = state_bits.cast[PackedStoreState&]
    handles: darray[uintptr]& = packed_store_handle_table(state)
    return arena_da_view(handles, start, end)

def ctx_packed_store_indices_view[T](state_bits: mutable void&, start: usize, end: usize) -> dview[T]:
    assert((state_bits != null))
    state: PackedStoreState& = state_bits.cast[PackedStoreState&]
    indices: darray[u32]& = packed_store_index_table(state)
    return arena_da_view(indices.cast[darray[T]&], start, end)

def ctx_packed_store_alloc(a: mutable Arena&, size_bytes: usize, state_bits: mutable void&) -> uintptr:
    can Memory.Allocate, Abort.Panic:
        result: PackedStoreAllocResult = ctx_packed_store_alloc_result(a, size_bytes, state_bits)
        return result.handle

struct PackedStoreAllocResult:
    row: mutable heap void&?
    handle: mutable uintptr

struct PackedStoreIndexAllocResult:
    row: mutable heap void&?
    index: mutable u32

struct PackedStoreVariantRows:
    tag: mutable u32
    rows: mutable darray[uintptr]

struct PackedStoreState:
    head_region: mutable heap Region&?
    alloc_region: mutable heap Region&?
    alloc_region_index: mutable usize
    decode_region: mutable heap Region&?
    decode_region_index: mutable usize
    tail_region: mutable heap Region&?
    regions: mutable darray[heap Region&?]
    handles: mutable darray[uintptr]
    indices: mutable darray[u32]
    tags: mutable darray[u32]
    variant_slots: mutable darray[u32]
    variant_rows: mutable darray[PackedStoreVariantRows]
    prefix_words: mutable usize
    prefix_columns: mutable darray[uintptr]
    prefix_column_capacity: mutable usize
    side_words: mutable usize
    side_columns: mutable darray[uintptr]
    side_column_capacity: mutable usize
    row_words: mutable usize
    preferred_region_capacity: mutable usize

def packed_store_handle_table(state: mutable PackedStoreState&) -> mutable darray[uintptr]&:
    return state.handles.ref[darray[uintptr]&]

def packed_store_append_handle(a: mutable Arena&, state: mutable PackedStoreState&, handle: uintptr):
    can Memory.Allocate, Abort.Panic:
        handles: mutable darray[uintptr]& = packed_store_handle_table(state)
        in a:
            handles.push(handle)

def ctx_packed_store_encode(a: mutable Arena&, ptr: void&, state_bits: mutable void&) -> uintptr:
    can Abort.Panic:
        raw: uintptr = ptr.cast[u8&].uintptr()
        if (state_bits != null):
            state: PackedStoreState& = state_bits.cast[PackedStoreState&]
            if (state.alloc_region != null):
                alloc_data_base: heap u8& = packed_store_region_data(state.alloc_region)
                alloc_data_begin: uintptr = alloc_data_base.uintptr()
                alloc_data_end: uintptr = (alloc_data_begin + ((state.alloc_region.capacity * size_of(uintptr))).uintptr())
                if ((raw >= alloc_data_begin) and (raw < alloc_data_end)):
                    alloc_offset_bytes: uintptr = (raw - alloc_data_begin)
                    alloc_offset_words: uintptr = (alloc_offset_bytes / size_of(uintptr).uintptr())
                    return (((state.alloc_region_index.uintptr() << 32.uintptr())) | ((((alloc_offset_words + 1.uintptr())) << 1.uintptr())))
            if (state.decode_region != null):
                decode_data_base: heap u8& = packed_store_region_data(state.decode_region)
                decode_data_begin: uintptr = decode_data_base.uintptr()
                decode_data_end: uintptr = (decode_data_begin + ((state.decode_region.capacity * size_of(uintptr))).uintptr())
                if ((raw >= decode_data_begin) and (raw < decode_data_end)):
                    decode_offset_bytes: uintptr = (raw - decode_data_begin)
                    decode_offset_words: uintptr = (decode_offset_bytes / size_of(uintptr).uintptr())
                    return (((state.decode_region_index.uintptr() << 32.uintptr())) | ((((decode_offset_words + 1.uintptr())) << 1.uintptr())))
            owner_cursor: mutable heap Region&? = state.head_region
            trusted Unsafe.AssumeProgress:
                while (owner_cursor != null):
                    owner_data_base: heap u8& = packed_store_region_data(owner_cursor)
                    owner_data_begin: uintptr = owner_data_base.uintptr()
                    owner_data_end: uintptr = (owner_data_begin + ((owner_cursor.capacity * size_of(uintptr))).uintptr())
                    if ((raw >= owner_data_begin) and (raw < owner_data_end)):
                        owner_offset_bytes: uintptr = (raw - owner_data_begin)
                        owner_offset_words: uintptr = (owner_offset_bytes / size_of(uintptr).uintptr())
                        return (((owner_cursor.global_index.uintptr() << 32.uintptr())) | ((((owner_offset_words + 1.uintptr())) << 1.uintptr())))
                    owner_cursor <- owner_cursor.owner_next
        if (a.end != null):
            end_data_base: heap u8& = packed_store_region_data(a.end)
            end_data_begin: uintptr = end_data_base.uintptr()
            end_data_end: uintptr = (end_data_begin + ((a.end.capacity * size_of(uintptr))).uintptr())
            if ((raw >= end_data_begin) and (raw < end_data_end)):
                end_offset_bytes: uintptr = (raw - end_data_begin)
                end_offset_words: uintptr = (end_offset_bytes / size_of(uintptr).uintptr())
                return (((a.end_index.uintptr() << 32.uintptr())) | ((((end_offset_words + 1.uintptr())) << 1.uintptr())))
        r: mutable heap Region&? = a.begin
        trusted Unsafe.AssumeProgress:
            while (r != null):
                data_base: heap u8& = packed_store_region_data(r)
                data_begin: uintptr = data_base.uintptr()
                data_end: uintptr = (data_begin + ((r.capacity * size_of(uintptr))).uintptr())
                if ((raw >= data_begin) and (raw < data_end)):
                    offset_bytes: uintptr = (raw - data_begin)
                    offset_words: uintptr = (offset_bytes / size_of(uintptr).uintptr())
                    return (((r.global_index.uintptr() << 32.uintptr())) | ((((offset_words + 1.uintptr())) << 1.uintptr())))
                r <- r.next
        panic("packed store encode pointer outside arena")

def ctx_packed_store_decode(a: mutable Arena&, handle: uintptr, state_bits: mutable void&) -> mutable void&:
    can Abort.Panic:
        assert((handle != 0.uintptr()))
        if ((handle & 1.uintptr()) != 0.uintptr()):
            panic("packed store decode cannot materialize inline word handles")
        region_index: usize = ((handle >> 32.uintptr())).usize()
        offset_words_plus_one: usize = ((((handle & 0xffffffff.u64().uintptr())) >> 1.uintptr())).usize()
        assert((offset_words_plus_one > 0))
        if (state_bits != null):
            state: PackedStoreState& = state_bits.cast[PackedStoreState&]
            if ((state.alloc_region != null) and (state.alloc_region_index == region_index)):
                offset_words: usize = (offset_words_plus_one - 1)
                assert((offset_words < state.alloc_region.capacity))
                data_base: heap u8& = packed_store_region_data(state.alloc_region)
                return ((data_base + (offset_words * size_of(uintptr)))).cast[mutable void&]
            if ((state.decode_region != null) and (state.decode_region_index == region_index)):
                offset_words: usize = (offset_words_plus_one - 1)
                assert((offset_words < state.decode_region.capacity))
                data_base: heap u8& = packed_store_region_data(state.decode_region)
                return ((data_base + (offset_words * size_of(uintptr)))).cast[mutable void&]
            indexed_region: heap Region&? = packed_store_lookup_region(state, region_index)
            if (indexed_region != null):
                offset_words: usize = (offset_words_plus_one - 1)
                assert((offset_words < indexed_region.capacity))
                state.decode_region <- indexed_region
                state.decode_region_index <- region_index
                data_base: heap u8& = packed_store_region_data(indexed_region)
                return ((data_base + (offset_words * size_of(uintptr)))).cast[mutable void&]
        r: mutable heap Region&? = a.begin
        i: mutable usize = 0
        if (state_bits != null):
            state: PackedStoreState& = state_bits.cast[PackedStoreState&]
            owner_cursor: mutable heap Region&? = null
            owner_cursor_index: mutable usize = 0
            if ((state.head_region != null) and (state.head_region.global_index <= region_index)):
                owner_cursor <- state.head_region
                owner_cursor_index <- state.head_region.global_index
                r <- state.head_region
                i <- state.head_region.global_index
            if ((state.alloc_region != null) and (state.alloc_region_index <= region_index)):
                if ((owner_cursor == null) or (state.alloc_region_index > owner_cursor_index)):
                    owner_cursor <- state.alloc_region
                    owner_cursor_index <- state.alloc_region_index
                if ((r == null) or (state.alloc_region_index > i)):
                    r <- state.alloc_region
                    i <- state.alloc_region_index
            if ((state.decode_region != null) and (state.decode_region_index <= region_index)):
                if ((owner_cursor == null) or (state.decode_region_index > owner_cursor_index)):
                    owner_cursor <- state.decode_region
                    owner_cursor_index <- state.decode_region_index
                if ((r == null) or (state.decode_region_index > i)):
                    r <- state.decode_region
                    i <- state.decode_region_index
            if (owner_cursor != null):
                trusted Unsafe.AssumeProgress:
                    while ((owner_cursor != null) and (owner_cursor.global_index < region_index)):
                        owner_cursor <- owner_cursor.owner_next
                if ((owner_cursor != null) and (owner_cursor.global_index == region_index)):
                    offset_words: usize = (offset_words_plus_one - 1)
                    assert((offset_words < owner_cursor.capacity))
                    state.decode_region <- owner_cursor
                    state.decode_region_index <- region_index
                    data_base: heap u8& = packed_store_region_data(owner_cursor)
                    return ((data_base + (offset_words * size_of(uintptr)))).cast[mutable void&]
        trusted Unsafe.AssumeProgress:
            while ((i < region_index) and (r != null)):
                r <- r.next
                i <- (i + 1)
        assert((r != null))
        offset_words: usize = (offset_words_plus_one - 1)
        assert((offset_words < r.capacity))
        if (state_bits != null):
            state: PackedStoreState& = state_bits.cast[PackedStoreState&]
            state.decode_region <- r
            state.decode_region_index <- region_index
        data_base: heap u8& = packed_store_region_data(r)
        return ((data_base + (offset_words * size_of(uintptr)))).cast[mutable void&]

def ctx_packed_store_encode_index(a: mutable Arena&, ptr: void&, state_bits: mutable void&) -> u32:
    can Abort.Panic:
        assert((state_bits != null))
        state: PackedStoreState& = state_bits.cast[PackedStoreState&]
        encoded: uintptr = ctx_packed_store_encode(a, ptr, state_bits)
        assert((state.handles.items != null))
        handles: uintptr& = state.handles.items
        for i, handle in state.handles.enumerate():
            if (handle == encoded):
                return i.u32()
        panic("packed store encode index missing handle")

def ctx_packed_store_decode_index(a: mutable Arena&, index: u32, state_bits: mutable void&) -> mutable void&:
    can Abort.Panic:
        assert((state_bits != null))
        state: PackedStoreState& = state_bits.cast[PackedStoreState&]
        index_usize: usize = index.usize()
        assert((index_usize < state.handles.count))
        assert((state.handles.items != null))
        handles: uintptr& = state.handles.items
        return ctx_packed_store_decode(a, handles[index_usize], state_bits)

def packed_store_tag_table(state: mutable PackedStoreState&) -> mutable darray[u32]&:
    return state.tags.ref[darray[u32]&]

def packed_store_append_tag(a: mutable Arena&, state: mutable PackedStoreState&, tag: u32):
    can Memory.Allocate, Abort.Panic:
        tags: mutable darray[u32]& = packed_store_tag_table(state)
        in a:
            tags.push(tag)

def packed_store_append_prefix_words(a: mutable Arena&, state: mutable PackedStoreState&, row: void&):
    can Memory.Allocate, Abort.Panic:
        if (state.prefix_words == 0):
            return
        needed_rows: usize = state.handles.count
        assert((state.prefix_column_capacity >= needed_rows))
        assert((state.prefix_columns.items != null))
        column_ptrs: uintptr& = state.prefix_columns.items
        row_words: uintptr& = row.cast[uintptr&]
        row_index: usize = (needed_rows - 1)
        assert((state.prefix_columns.count >= state.prefix_words))
        if (state.prefix_words == 1):
            assert((column_ptrs[0] != 0.uintptr()))
            column0: mutable uintptr& = column_ptrs[0].cast[heap u8&].cast[uintptr&]
            column0[row_index] <- row_words[0]
            return
        if (state.prefix_words == 2):
            assert((column_ptrs[0] != 0.uintptr()))
            assert((column_ptrs[1] != 0.uintptr()))
            column0: mutable uintptr& = column_ptrs[0].cast[heap u8&].cast[uintptr&]
            column1: mutable uintptr& = column_ptrs[1].cast[heap u8&].cast[uintptr&]
            column0[row_index] <- row_words[0]
            column1[row_index] <- row_words[1]
            return
        if (state.prefix_words == 3):
            assert((column_ptrs[0] != 0.uintptr()))
            assert((column_ptrs[1] != 0.uintptr()))
            assert((column_ptrs[2] != 0.uintptr()))
            column0: mutable uintptr& = column_ptrs[0].cast[heap u8&].cast[uintptr&]
            column1: mutable uintptr& = column_ptrs[1].cast[heap u8&].cast[uintptr&]
            column2: mutable uintptr& = column_ptrs[2].cast[heap u8&].cast[uintptr&]
            column0[row_index] <- row_words[0]
            column1[row_index] <- row_words[1]
            column2[row_index] <- row_words[2]
            return
        for i in 0 ..< state.prefix_words:
            assert((column_ptrs[i] != 0.uintptr()))
            column: mutable uintptr& = column_ptrs[i].cast[heap u8&].cast[uintptr&]
            column[row_index] <- row_words[i]

def packed_store_append_side_words(a: mutable Arena&, state: mutable PackedStoreState&, words: void&):
    can Memory.Allocate, Abort.Panic:
        if (state.side_words == 0):
            return
        needed_rows: usize = state.handles.count
        assert((state.side_column_capacity >= needed_rows))
        assert((state.side_columns.items != null))
        column_ptrs: uintptr& = state.side_columns.items
        source_words: uintptr& = words.cast[uintptr&]
        row_index: usize = (needed_rows - 1)
        assert((state.side_columns.count >= state.side_words))
        if (state.side_words == 1):
            assert((column_ptrs[0] != 0.uintptr()))
            column0: mutable uintptr& = column_ptrs[0].cast[heap u8&].cast[uintptr&]
            column0[row_index] <- source_words[0]
            return
        if (state.side_words == 2):
            assert((column_ptrs[0] != 0.uintptr()))
            assert((column_ptrs[1] != 0.uintptr()))
            column0: mutable uintptr& = column_ptrs[0].cast[heap u8&].cast[uintptr&]
            column1: mutable uintptr& = column_ptrs[1].cast[heap u8&].cast[uintptr&]
            column0[row_index] <- source_words[0]
            column1[row_index] <- source_words[1]
            return
        if (state.side_words == 3):
            assert((column_ptrs[0] != 0.uintptr()))
            assert((column_ptrs[1] != 0.uintptr()))
            assert((column_ptrs[2] != 0.uintptr()))
            column0: mutable uintptr& = column_ptrs[0].cast[heap u8&].cast[uintptr&]
            column1: mutable uintptr& = column_ptrs[1].cast[heap u8&].cast[uintptr&]
            column2: mutable uintptr& = column_ptrs[2].cast[heap u8&].cast[uintptr&]
            column0[row_index] <- source_words[0]
            column1[row_index] <- source_words[1]
            column2[row_index] <- source_words[2]
            return
        for i in 0 ..< state.side_words:
            assert((column_ptrs[i] != 0.uintptr()))
            column: mutable uintptr& = column_ptrs[i].cast[heap u8&].cast[uintptr&]
            column[row_index] <- source_words[i]

def ctx_packed_store_state_new_with_prefix_words(a: mutable Arena&, row_bytes: usize, prefix_words: usize) -> mutable heap void&:
    can Memory.Allocate, Abort.Panic:
        state_bits: heap void& = ctx_packed_store_state_new(a, row_bytes)
        state: heap PackedStoreState& = state_bits.cast[heap PackedStoreState&]
        if (prefix_words < state.row_words):
            state.prefix_words <- prefix_words
        else:
            state.prefix_words <- state.row_words
        return state_bits

def ctx_packed_store_state_new_with_side_words(a: mutable Arena&, row_bytes: usize, side_words: usize) -> mutable heap void&:
