include "../compiler/runtime/elisacore_std/elisacore_runtime.elisa"
include "./core/libraries/system/userservice.elisa"
include "./core/libraries/system/systemservice.elisa"

@test
def system_ffi_bridge_smoke() -> void:
    can Abort.Panic:
        UserService_SetUseFfiBridge(true)
        SystemService_SetUseFfiBridge(true)

        uid: mutable int = -1
        assert sceUserServiceGetInitialUser(uid.ref[mutable int&]) == ORBIS_OK
        assert uid == 1

        users: mutable OrbisUserServiceLoginUserIdList = zeroed
        assert sceUserServiceGetLoginUserIdList(users.ref[mutable void&]) == ORBIS_OK
        assert users.user_id[0] == 1
        assert users.user_id[1] == 2
        assert users.user_id[2] == ORBIS_USER_SERVICE_USER_ID_INVALID
        assert users.user_id[3] == ORBIS_USER_SERVICE_USER_ID_INVALID

        color: mutable u32 = 99
        assert sceUserServiceGetUserColor(2, color.ref[mutable u32&]) == ORBIS_OK
        assert color == 1.u32()
        assert sceUserServiceGetUserColor(999, color.ref[mutable u32&]) == ORBIS_USER_SERVICE_ERROR_INVALID_ARGUMENT

        name_buf: mutable u8[8] = zeroed
        assert sceUserServiceGetUserName(2, name_buf[0].ref[mutable u8&], 5) == ORBIS_USER_SERVICE_ERROR_BUFFER_TOO_SHORT
        assert sceUserServiceGetUserName(2, name_buf[0].ref[mutable u8&], 8) == ORBIS_OK
        assert name_buf[0] == 'U'.u8()
        assert name_buf[1] == 's'.u8()
        assert name_buf[2] == 'e'.u8()
        assert name_buf[3] == 'r'.u8()
        assert name_buf[4] == '2'.u8()
        assert name_buf[5] == 0.u8()

        ue: mutable OrbisUserServiceEvent = zeroed
        assert sceUserServiceGetEvent(ue.ref[mutable void&]) == ORBIS_USER_SERVICE_ERROR_NO_EVENT
        UserService_PushEventForTests(7, 2)
        assert sceUserServiceGetEvent(ue.ref[mutable void&]) == ORBIS_OK
        assert ue.event == 7.u32()
        assert ue.user_id == 2

        st: mutable OrbisSystemServiceStatus = zeroed
        assert sceSystemServiceGetStatus(st.ref[mutable u32&]) == ORBIS_OK
        assert st.event_num == 0

        se: mutable OrbisSystemServiceEvent = zeroed
        assert sceSystemServiceReceiveEvent(se.ref[mutable void&]) == ORBIS_SYSTEM_SERVICE_ERROR_NO_EVENT
        SystemService_PushEventForTests(13)
        assert sceSystemServiceGetStatus(st.ref[mutable u32&]) == ORBIS_OK
        assert st.event_num == 1
        assert sceSystemServiceReceiveEvent(se.ref[mutable void&]) == ORBIS_OK
        assert se.event_type == 13
        load_exec_calls: int = SystemService_FfiGetLoadExecCallCountForTests()
        assert sceSystemServiceLoadExec(null, null) == ORBIS_SYSTEM_SERVICE_ERROR_PARAMETER
        assert SystemService_FfiGetLoadExecCallCountForTests() == load_exec_calls + 1

        UserService_SetUseFfiBridge(false)
        SystemService_SetUseFfiBridge(false)
        uid <- -1
        assert sceUserServiceGetInitialUser(uid.ref[mutable int&]) == ORBIS_OK
        assert uid == 1
