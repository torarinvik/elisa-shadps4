# begin include /Users/torarinvikbjarko/Documents/Coding Projects/Go projects/Elisa-core/compiler/runtime/elisacore_std/test.elisa
# ============================================================
# Test helpers - Elisa core runtime dialect
# ============================================================

def fail(message: cstr):
    can Abort.Panic:
        panic(message)


def assert_true(condition: bool):
    can Abort.Panic:
        if not condition:
            panic("assert_true failed")


def assert_false(condition: bool):
    can Abort.Panic:
        if condition:
            panic("assert_false failed")

def assert_eq[T](actual: T, expected: T):
    can Abort.Panic:
        if actual != expected:
            panic("assert_eq failed")

def assert_ne[T](actual: T, expected: T):
    can Abort.Panic:
        if actual == expected:
            panic("assert_ne failed")


def id_invalid[T]() -> id[T]:
    return 0.u32() as id[T]


def id_valid[T](value: id[T]) -> bool:
    return !value != 0


def assert_id_valid[T](value: id[T]):
    can Abort.Panic:
        assert_true(id_valid[T](value))


def assert_id_invalid[T](value: id[T]):
    can Abort.Panic:
        assert_false(id_valid[T](value))
# end include /Users/torarinvikbjarko/Documents/Coding Projects/Go projects/Elisa-core/compiler/runtime/elisacore_std/test.elisa
