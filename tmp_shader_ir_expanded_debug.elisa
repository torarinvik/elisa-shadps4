const SSA_KIND_VCCHI: u32 = 9
const SSA_KIND_M0: u32 = 10

struct SsaDefTable:
    scalar_values: mutable u32[128]
    scalar_valid: mutable bool[128]
    vector_values: mutable u32[256]
    vector_valid: mutable bool[256]
    goto_values: mutable u32[64]
    goto_valid: mutable bool[64]
    thread_bit_values: mutable u32[128]
    thread_bit_valid: mutable bool[128]
    scc_value: mutable u32
    scc_valid: mutable bool
    exec_value: mutable u32
    exec_valid: mutable bool
    vcc_value: mutable u32
    vcc_valid: mutable bool
    vcc_lo_value: mutable u32
    vcc_lo_valid: mutable bool
    vcc_hi_value: mutable u32
    vcc_hi_valid: mutable bool
    m0_value: mutable u32
    m0_valid: mutable bool

struct SsaPass:
    defs: mutable SsaDefTable


def Def(ssa_pass: SsaPass&, kind: u32, index: u32) -> u32:
    if kind == SSA_KIND_SCALAR and index < SSA_MAX_SCALAR and ssa_pass.defs.scalar_valid[index.usize()]:
        return ssa_pass.defs.scalar_values[index.usize()]
    if kind == SSA_KIND_VECTOR and index < SSA_MAX_VECTOR and ssa_pass.defs.vector_valid[index.usize()]:
        return ssa_pass.defs.vector_values[index.usize()]
    if kind == SSA_KIND_GOTO and index < SSA_MAX_GOTO and ssa_pass.defs.goto_valid[index.usize()]:
        return ssa_pass.defs.goto_values[index.usize()]
    if kind == SSA_KIND_THREAD_BIT and index < SSA_MAX_SCALAR and ssa_pass.defs.thread_bit_valid[index.usize()]:
        return ssa_pass.defs.thread_bit_values[index.usize()]
    if kind == SSA_KIND_SCC and ssa_pass.defs.scc_valid:
        return ssa_pass.defs.scc_value
    if kind == SSA_KIND_EXEC and ssa_pass.defs.exec_valid:
        return ssa_pass.defs.exec_value
    if kind == SSA_KIND_VCC and ssa_pass.defs.vcc_valid:
        return ssa_pass.defs.vcc_value
    if kind == SSA_KIND_VCCLO and ssa_pass.defs.vcc_lo_valid:
        return ssa_pass.defs.vcc_lo_value
    if kind == SSA_KIND_VCCHI and ssa_pass.defs.vcc_hi_valid:
        return ssa_pass.defs.vcc_hi_value
    if kind == SSA_KIND_M0 and ssa_pass.defs.m0_valid:
        return ssa_pass.defs.m0_value
    return 0


def SetDef(ssa_pass: mutable SsaPass&, kind: u32, index: u32, value: u32) -> void:
    if kind == SSA_KIND_SCALAR and index < SSA_MAX_SCALAR:
        ssa_pass.defs.scalar_values[index.usize()] <- value
        ssa_pass.defs.scalar_valid[index.usize()] <- true
        return
    if kind == SSA_KIND_VECTOR and index < SSA_MAX_VECTOR:
        ssa_pass.defs.vector_values[index.usize()] <- value
        ssa_pass.defs.vector_valid[index.usize()] <- true
        return
    if kind == SSA_KIND_GOTO and index < SSA_MAX_GOTO:
        ssa_pass.defs.goto_values[index.usize()] <- value
        ssa_pass.defs.goto_valid[index.usize()] <- true
        return
    if kind == SSA_KIND_THREAD_BIT and index < SSA_MAX_SCALAR:
        ssa_pass.defs.thread_bit_values[index.usize()] <- value
        ssa_pass.defs.thread_bit_valid[index.usize()] <- true
        return
    if kind == SSA_KIND_SCC:
        ssa_pass.defs.scc_value <- value
        ssa_pass.defs.scc_valid <- true
        return
    if kind == SSA_KIND_EXEC:
        ssa_pass.defs.exec_value <- value
        ssa_pass.defs.exec_valid <- true
        return
    if kind == SSA_KIND_VCC:
        ssa_pass.defs.vcc_value <- value
        ssa_pass.defs.vcc_valid <- true
        return
    if kind == SSA_KIND_VCCLO:
        ssa_pass.defs.vcc_lo_value <- value
        ssa_pass.defs.vcc_lo_valid <- true
        return
    if kind == SSA_KIND_VCCHI:
        ssa_pass.defs.vcc_hi_value <- value
        ssa_pass.defs.vcc_hi_valid <- true
        return
    if kind == SSA_KIND_M0:
        ssa_pass.defs.m0_value <- value
        ssa_pass.defs.m0_valid <- true


def WriteVariable(ssa_pass: mutable SsaPass&, kind: u32, index: u32, value: u32) -> void:
    SetDef(ssa_pass, kind, index, value)


def ReadVariable(ssa_pass: SsaPass&, kind: u32, index: u32) -> u32:
    return Def(ssa_pass, kind, index)


def SealBlock(program: mutable ShaderIrProgram&, block_index: u32) -> void:
    if block_index < program.block_count:
        program.blocks[block_index.usize()].is_ssa_sealed <- true


def AddPhiOperands(_pass: mutable SsaPass&, _phi: mutable ShaderIrPassInst&) -> u32:
    if _phi.arg_count == 0:
        return 0
    return _phi.args[0]


def TryRemoveTrivialPhi(ssa_pass: mutable SsaPass&, phi: mutable ShaderIrPassInst&) -> u32:
    _ = ssa_pass
    if phi.opcode != OPCODE_PHI or phi.arg_count == 0:
        return 0

    first: u32 = phi.args[0]
    all_same: mutable bool = true
    i: mutable u32 = 1
    while i < phi.arg_count:
        if phi.args[i.usize()] != first:
            all_same <- false
        i <- i + 1

    if all_same:
        ShaderIrPass_ReplaceWithImm(phi, first)
        return first
    return phi.id


def VisitInst(ssa_pass: mutable SsaPass&, program: mutable ShaderIrProgram&, block_index: u32, inst_index: u32) -> void:
    block: mutable ShaderIrPassBlock& = (&program.blocks[block_index.usize()]).cast[mutable ShaderIrPassBlock&]
    inst: mutable ShaderIrPassInst& = (&block.insts[inst_index.usize()]).cast[mutable ShaderIrPassInst&]
    op: u32 = inst.opcode

    if op == OPCODE_SETTHREADBITSCALARREG:
        if inst.arg_count >= 2:
            WriteVariable(ssa_pass, SSA_KIND_THREAD_BIT, inst.args[0], inst.args[1])
        return

    if op == OPCODE_SETSCALARREGISTER:
        if inst.arg_count >= 2:
            WriteVariable(ssa_pass, SSA_KIND_SCALAR, inst.args[0], inst.args[1])
        return

    if op == OPCODE_SETVECTORREGISTER:
        if inst.arg_count >= 2:
            WriteVariable(ssa_pass, SSA_KIND_VECTOR, inst.args[0], inst.args[1])
        return

    if op == OPCODE_SETGOTOVARIABLE:
        if inst.arg_count >= 2:
            WriteVariable(ssa_pass, SSA_KIND_GOTO, inst.args[0], inst.args[1])
        return

    if op == OPCODE_SETEXEC:
        if inst.arg_count >= 1:
            WriteVariable(ssa_pass, SSA_KIND_EXEC, 0, inst.args[0])
        return

    if op == OPCODE_SETSCC:
        if inst.arg_count >= 1:
            WriteVariable(ssa_pass, SSA_KIND_SCC, 0, inst.args[0])
        return

    if op == OPCODE_SETVCC:
        if inst.arg_count >= 1:
            WriteVariable(ssa_pass, SSA_KIND_VCC, 0, inst.args[0])
        return

    if op == OPCODE_SETVCCLO:
        if inst.arg_count >= 1:
            WriteVariable(ssa_pass, SSA_KIND_VCCLO, 0, inst.args[0])
        return

    if op == OPCODE_SETVCCHI:
        if inst.arg_count >= 1:
            WriteVariable(ssa_pass, SSA_KIND_VCCHI, 0, inst.args[0])
        return

    if op == OPCODE_SETM0:
        if inst.arg_count >= 1:
            WriteVariable(ssa_pass, SSA_KIND_M0, 0, inst.args[0])
        return

    if op == OPCODE_GETTHREADBITSCALARREG:
        if inst.arg_count >= 1:
            ShaderIrPass_ReplaceWithImm(inst, ReadVariable(ssa_pass, SSA_KIND_THREAD_BIT, inst.args[0]))
            program.stats.ssa_reads_rewritten <- program.stats.ssa_reads_rewritten + 1
        return

    if op == OPCODE_GETSCALARREGISTER:
        if inst.arg_count >= 1:
            ShaderIrPass_ReplaceWithImm(inst, ReadVariable(ssa_pass, SSA_KIND_SCALAR, inst.args[0]))
            program.stats.ssa_reads_rewritten <- program.stats.ssa_reads_rewritten + 1
        return

    if op == OPCODE_GETVECTORREGISTER:
        if inst.arg_count >= 1:
            ShaderIrPass_ReplaceWithImm(inst, ReadVariable(ssa_pass, SSA_KIND_VECTOR, inst.args[0]))
            program.stats.ssa_reads_rewritten <- program.stats.ssa_reads_rewritten + 1
        return

    if op == OPCODE_GETGOTOVARIABLE:
        if inst.arg_count >= 1:
            ShaderIrPass_ReplaceWithImm(inst, ReadVariable(ssa_pass, SSA_KIND_GOTO, inst.args[0]))
            program.stats.ssa_reads_rewritten <- program.stats.ssa_reads_rewritten + 1
        return

    if op == OPCODE_GETEXEC:
        ShaderIrPass_ReplaceWithImm(inst, ReadVariable(ssa_pass, SSA_KIND_EXEC, 0))
        program.stats.ssa_reads_rewritten <- program.stats.ssa_reads_rewritten + 1
        return

    if op == OPCODE_GETSCC:
        ShaderIrPass_ReplaceWithImm(inst, ReadVariable(ssa_pass, SSA_KIND_SCC, 0))
        program.stats.ssa_reads_rewritten <- program.stats.ssa_reads_rewritten + 1
        return

    if op == OPCODE_GETVCC:
        ShaderIrPass_ReplaceWithImm(inst, ReadVariable(ssa_pass, SSA_KIND_VCC, 0))
        program.stats.ssa_reads_rewritten <- program.stats.ssa_reads_rewritten + 1
        return

    if op == OPCODE_GETVCCLO:
        ShaderIrPass_ReplaceWithImm(inst, ReadVariable(ssa_pass, SSA_KIND_VCCLO, 0))
        program.stats.ssa_reads_rewritten <- program.stats.ssa_reads_rewritten + 1
        return

    if op == OPCODE_GETVCCHI:
        ShaderIrPass_ReplaceWithImm(inst, ReadVariable(ssa_pass, SSA_KIND_VCCHI, 0))
        program.stats.ssa_reads_rewritten <- program.stats.ssa_reads_rewritten + 1
        return

    if op == OPCODE_GETM0:
        ShaderIrPass_ReplaceWithImm(inst, ReadVariable(ssa_pass, SSA_KIND_M0, 0))
        program.stats.ssa_reads_rewritten <- program.stats.ssa_reads_rewritten + 1
        return

    if op == OPCODE_PHI:
        _ = AddPhiOperands(ssa_pass, inst)
        _ = TryRemoveTrivialPhi(ssa_pass, inst)


def VisitBlock(ssa_pass: mutable SsaPass&, program: mutable ShaderIrProgram&, block_index: u32) -> void:
    if block_index >= program.block_count:
        return
    i: mutable u32 = 0
    while i < program.blocks[block_index.usize()].inst_count:
        VisitInst(ssa_pass, program, block_index, i)
        i <- i + 1
    SealBlock(program, block_index)


def SsaRewritePass(program: mutable ShaderIrProgram&) -> void:
    ssa_pass: mutable SsaPass = zeroed
    if program.post_order_count == 0:
        return
    rev: mutable u32 = program.post_order_count
    while rev > 0:
        rev <- rev - 1
        VisitBlock((&ssa_pass).cast[mutable SsaPass&], program, program.post_order[rev.usize()])
# end include /Users/torarinvikbjarko/Documents/Coding Projects/Go projects/Elisa-core/elisa-shad-ps4-from-scratch/shader_recompiler/ir/passes/ssa_rewrite_pass.elisa
# end include /Users/torarinvikbjarko/Documents/Coding Projects/Go projects/Elisa-core/elisa-shad-ps4-from-scratch/shader_recompiler/ir/passes/ir_passes.elisa

def inst_invalidated(program: ShaderIrProgram&, id: u32) -> bool:
    b: mutable u32 = 0
    i: mutable u32 = 0
    if not ShaderIrProgram_FindInst(program, id, (&b).cast[mutable u32&], (&i).cast[mutable u32&]):
        return false
    return program.blocks[b.usize()].insts[i.usize()].invalidated


def inst_opcode(program: ShaderIrProgram&, id: u32) -> u32:
    b: mutable u32 = 0
    i: mutable u32 = 0
    if not ShaderIrProgram_FindInst(program, id, (&b).cast[mutable u32&], (&i).cast[mutable u32&]):
        return 0
    return program.blocks[b.usize()].insts[i.usize()].opcode


def inst_replacement(program: ShaderIrProgram&, id: u32) -> u32:
    b: mutable u32 = 0
    i: mutable u32 = 0
    if not ShaderIrProgram_FindInst(program, id, (&b).cast[mutable u32&], (&i).cast[mutable u32&]):
        return 0
    return program.blocks[b.usize()].insts[i.usize()].replacement_value

@test
def shader_ir_constant_identity_deadcode_passes() -> void:
    can Abort.Panic:
        program: mutable ShaderIrProgram = ShaderIrProgram_Default()
        block: u32 = ShaderIrProgram_AddBlock((&program).cast[mutable ShaderIrProgram&])

        add_id: u32 = ShaderIrProgram_AddInst((&program).cast[mutable ShaderIrProgram&], block, OPCODE_IADD32)
        mul_id: u32 = ShaderIrProgram_AddInst((&program).cast[mutable ShaderIrProgram&], block, OPCODE_IMUL32)
        not_id: u32 = ShaderIrProgram_AddInst((&program).cast[mutable ShaderIrProgram&], block, OPCODE_LOGICALNOT)
        disc_id: u32 = ShaderIrProgram_AddInst((&program).cast[mutable ShaderIrProgram&], block, OPCODE_DISCARDCOND)
        id_id: u32 = ShaderIrProgram_AddInst((&program).cast[mutable ShaderIrProgram&], block, OPCODE_IDENTITY)
        void_id: u32 = ShaderIrProgram_AddInst((&program).cast[mutable ShaderIrProgram&], block, OPCODE_VOID)

        b: mutable u32 = 0
        i: mutable u32 = 0
        assert ShaderIrProgram_FindInst(program, add_id, (&b).cast[mutable u32&], (&i).cast[mutable u32&])
        ShaderIrPassInst_SetArgImm((&program.blocks[b.usize()].insts[i.usize()]).cast[mutable ShaderIrPassInst&], 0, 2)
        ShaderIrPassInst_SetArgImm((&program.blocks[b.usize()].insts[i.usize()]).cast[mutable ShaderIrPassInst&], 1, 3)

        assert ShaderIrProgram_FindInst(program, mul_id, (&b).cast[mutable u32&], (&i).cast[mutable u32&])
        ShaderIrPassInst_SetArgImm((&program.blocks[b.usize()].insts[i.usize()]).cast[mutable ShaderIrPassInst&], 0, 7)
        ShaderIrPassInst_SetArgImm((&program.blocks[b.usize()].insts[i.usize()]).cast[mutable ShaderIrPassInst&], 1, 1)

        assert ShaderIrProgram_FindInst(program, not_id, (&b).cast[mutable u32&], (&i).cast[mutable u32&])
        ShaderIrPassInst_SetArgImm((&program.blocks[b.usize()].insts[i.usize()]).cast[mutable ShaderIrPassInst&], 0, 0)

        assert ShaderIrProgram_FindInst(program, disc_id, (&b).cast[mutable u32&], (&i).cast[mutable u32&])
        ShaderIrPassInst_SetArgImm((&program.blocks[b.usize()].insts[i.usize()]).cast[mutable ShaderIrPassInst&], 0, 1)

        ConstantPropagationPass((&program).cast[mutable ShaderIrProgram&])
        assert program.stats.constant_folds >= 4
        assert inst_invalidated(program, add_id)
        assert inst_invalidated(program, mul_id)
        assert inst_invalidated(program, not_id)

        IdentityRemovalPass((&program).cast[mutable ShaderIrProgram&])
        assert program.stats.identity_removed >= 2

        DeadCodeEliminationPass((&program).cast[mutable ShaderIrProgram&])
        assert program.stats.dead_code_removed >= 1

@test
def shader_ir_clip_and_shared_memory_passes() -> void:
    can Abort.Panic:
        program: mutable ShaderIrProgram = ShaderIrProgram_Default()
        runtime: mutable ShaderRuntimeInfo = ShaderRuntimeInfo_Default()
        profile: mutable ShaderPassProfile = ShaderPassProfile_Default()

        program.info.stage <- STAGE_VERTEX
        program.info.stores_clip_distance <- true
        profile.needs_clip_distance_emulation <- true
        InjectClipDistanceAttributes((&program).cast[mutable ShaderIrProgram&], (&runtime).cast[mutable ShaderRuntimeInfo&], profile)
        assert runtime.vs_num_exports == 1

        program.info.stage <- STAGE_COMPUTE
        program.info.logical_stage <- LOGICAL_STAGE_FRAGMENT
        runtime.fs_clip_distance_emulation <- true
        runtime.cs_shared_memory_size <- 4096
        runtime.cs_workgroup_size_x <- 64
        runtime.cs_workgroup_size_y <- 1
        runtime.cs_workgroup_size_z <- 1
        profile.needs_lds_barriers <- true

        block: u32 = ShaderIrProgram_AddBlock((&program).cast[mutable ShaderIrProgram&])
        load_id: u32 = ShaderIrProgram_AddInst((&program).cast[mutable ShaderIrProgram&], block, OPCODE_LOADSHAREDU32)
        write_id: u32 = ShaderIrProgram_AddInst((&program).cast[mutable ShaderIrProgram&], block, OPCODE_WRITESHAREDU16)
        _ = load_id
        _ = write_id

        ShaderIrProgram_AddSyntaxBlock((&program).cast[mutable ShaderIrProgram&], block)
        SharedMemoryBarrierPass((&program).cast[mutable ShaderIrProgram&], runtime, profile)
        assert program.stats.shared_barriers_inserted > 0

        SharedMemorySimplifyPass((&program).cast[mutable ShaderIrProgram&], profile)
        assert program.stats.shared_simplified_rewrites >= 1

        profile.max_shared_memory_size <- 1024
        SharedMemoryToStoragePass((&program).cast[mutable ShaderIrProgram&], runtime, profile)
        assert program.stats.shared_to_storage_rewrites > 0
        assert program.info.buffers_count > 0

@test
def shader_ir_lowering_and_readlane_and_ssa() -> void:
    can Abort.Panic:
        program: mutable ShaderIrProgram = ShaderIrProgram_Default()
        block: u32 = ShaderIrProgram_AddBlock((&program).cast[mutable ShaderIrProgram&])

        fp_id: u32 = ShaderIrProgram_AddInst((&program).cast[mutable ShaderIrProgram&], block, OPCODE_FPADDD64)
        pack_id: u32 = ShaderIrProgram_AddInst((&program).cast[mutable ShaderIrProgram&], block, OPCODE_PACKDOUBLE2X32)
        fmt_load: u32 = ShaderIrProgram_AddInst((&program).cast[mutable ShaderIrProgram&], block, OPCODE_LOADBUFFERFORMATF32)

        wl: u32 = ShaderIrProgram_AddInst((&program).cast[mutable ShaderIrProgram&], block, OPCODE_WRITELANE)
        rl: u32 = ShaderIrProgram_AddInst((&program).cast[mutable ShaderIrProgram&], block, OPCODE_READLANE)

        set_s: u32 = ShaderIrProgram_AddInst((&program).cast[mutable ShaderIrProgram&], block, OPCODE_SETSCALARREGISTER)
        get_s: u32 = ShaderIrProgram_AddInst((&program).cast[mutable ShaderIrProgram&], block, OPCODE_GETSCALARREGISTER)

        b: mutable u32 = 0
        i: mutable u32 = 0

        assert ShaderIrProgram_FindInst(program, pack_id, (&b).cast[mutable u32&], (&i).cast[mutable u32&])
        ShaderIrPassInst_SetArgImm((&program.blocks[b.usize()].insts[i.usize()]).cast[mutable ShaderIrPassInst&], 0, 9)

        assert ShaderIrProgram_FindInst(program, wl, (&b).cast[mutable u32&], (&i).cast[mutable u32&])
        ShaderIrPassInst_SetArgInst((&program.blocks[b.usize()].insts[i.usize()]).cast[mutable ShaderIrPassInst&], 0, 0)
        ShaderIrPassInst_SetArgImm((&program.blocks[b.usize()].insts[i.usize()]).cast[mutable ShaderIrPassInst&], 1, 123)
        ShaderIrPassInst_SetArgImm((&program.blocks[b.usize()].insts[i.usize()]).cast[mutable ShaderIrPassInst&], 2, 2)

        assert ShaderIrProgram_FindInst(program, rl, (&b).cast[mutable u32&], (&i).cast[mutable u32&])
        ShaderIrPassInst_SetArgInst((&program.blocks[b.usize()].insts[i.usize()]).cast[mutable ShaderIrPassInst&], 0, wl)
        ShaderIrPassInst_SetArgImm((&program.blocks[b.usize()].insts[i.usize()]).cast[mutable ShaderIrPassInst&], 1, 2)

        assert ShaderIrProgram_FindInst(program, set_s, (&b).cast[mutable u32&], (&i).cast[mutable u32&])
        ShaderIrPassInst_SetArgImm((&program.blocks[b.usize()].insts[i.usize()]).cast[mutable ShaderIrPassInst&], 0, 5)
        ShaderIrPassInst_SetArgImm((&program.blocks[b.usize()].insts[i.usize()]).cast[mutable ShaderIrPassInst&], 1, 88)

        assert ShaderIrProgram_FindInst(program, get_s, (&b).cast[mutable u32&], (&i).cast[mutable u32&])
        ShaderIrPassInst_SetArgImm((&program.blocks[b.usize()].insts[i.usize()]).cast[mutable ShaderIrPassInst&], 0, 5)

        LowerFp64ToFp32((&program).cast[mutable ShaderIrProgram&])
        assert inst_opcode(program, fp_id) == OPCODE_FPADD32
        assert program.stats.fp64_lowered >= 2

        LowerBufferFormatToRaw((&program).cast[mutable ShaderIrProgram&])
        assert inst_opcode(program, fmt_load) == OPCODE_LOADBUFFERF32
        assert program.stats.buffer_format_lowered >= 1

        ReadLaneEliminationPass((&program).cast[mutable ShaderIrProgram&])
        assert program.stats.readlane_eliminated >= 1
        assert inst_replacement(program, rl) == 123

        SsaRewritePass((&program).cast[mutable ShaderIrProgram&])
        assert program.stats.ssa_reads_rewritten >= 1

@test
def shader_ir_resource_info_tess_ring_flatten_parity() -> void:
    can Abort.Panic:
        program: mutable ShaderIrProgram = ShaderIrProgram_Default()
        runtime: mutable ShaderRuntimeInfo = ShaderRuntimeInfo_Default()
        profile: mutable ShaderPassProfile = ShaderPassProfile_Default()
        block: u32 = ShaderIrProgram_AddBlock((&program).cast[mutable ShaderIrProgram&])

        buf_inst: u32 = ShaderIrProgram_AddInst((&program).cast[mutable ShaderIrProgram&], block, OPCODE_LOADBUFFERU32)
        img_inst: u32 = ShaderIrProgram_AddInst((&program).cast[mutable ShaderIrProgram&], block, OPCODE_IMAGEREAD)
        rc_inst: u32 = ShaderIrProgram_AddInst((&program).cast[mutable ShaderIrProgram&], block, OPCODE_READCONST)
        rc_buf: u32 = ShaderIrProgram_AddInst((&program).cast[mutable ShaderIrProgram&], block, OPCODE_READCONSTBUFFER)
        sh_store: u32 = ShaderIrProgram_AddInst((&program).cast[mutable ShaderIrProgram&], block, OPCODE_WRITESHAREDU32)
        ring_inst: u32 = ShaderIrProgram_AddInst((&program).cast[mutable ShaderIrProgram&], block, OPCODE_STOREBUFFERU32)

        _ = buf_inst
        _ = img_inst
        _ = ring_inst

        b: mutable u32 = 0
        i: mutable u32 = 0

        assert ShaderIrProgram_FindInst(program, rc_inst, (&b).cast[mutable u32&], (&i).cast[mutable u32&])
        ShaderIrPassInst_SetArgImm((&program.blocks[b.usize()].insts[i.usize()]).cast[mutable ShaderIrPassInst&], 0, 1)
        ShaderIrPassInst_SetArgImm((&program.blocks[b.usize()].insts[i.usize()]).cast[mutable ShaderIrPassInst&], 1, 12)

        assert ShaderIrProgram_FindInst(program, rc_buf, (&b).cast[mutable u32&], (&i).cast[mutable u32&])
        ShaderIrPassInst_SetArgImm((&program.blocks[b.usize()].insts[i.usize()]).cast[mutable ShaderIrPassInst&], 0, 7)
        ShaderIrPassInst_SetArgImm((&program.blocks[b.usize()].insts[i.usize()]).cast[mutable ShaderIrPassInst&], 1, TESS_CONST_HS_NUM_PATCH)

        assert ShaderIrProgram_FindInst(program, sh_store, (&b).cast[mutable u32&], (&i).cast[mutable u32&])
        ShaderIrPassInst_SetArgImm((&program.blocks[b.usize()].insts[i.usize()]).cast[mutable ShaderIrPassInst&], 0, 64)

        ResourceTrackingPass((&program).cast[mutable ShaderIrProgram&], profile)
        assert program.stats.resource_sharp_patched >= 1
        assert program.stats.resource_args_patched >= 1

        CollectShaderInfoPass((&program).cast[mutable ShaderIrProgram&], profile)
        assert program.info.uses_dma == true
        assert program.info.buffers_count >= 3

        program.info.stage <- STAGE_LOCAL
        RingAccessElimination((&program).cast[mutable ShaderIrProgram&], runtime)
        assert program.stats.ring_rewrites >= 1

        runtime.hs_ls_stride <- 16
        runtime.hs_output_cp_stride <- 32
        runtime.hs_is_passthrough <- true
        program.info.logical_stage <- LOGICAL_STAGE_TESSELLATION_CONTROL
        TessellationPreprocess((&program).cast[mutable ShaderIrProgram&], (&runtime).cast[mutable ShaderRuntimeInfo&])
        assert program.stats.tess_constants_replaced >= 1

        HullShaderTransform((&program).cast[mutable ShaderIrProgram&], runtime)
        assert program.stats.hull_rewrites >= 1

        DomainShaderTransform((&program).cast[mutable ShaderIrProgram&], runtime)
        assert program.stats.domain_rewrites >= 0

        FlattenExtendedUserdataPass((&program).cast[mutable ShaderIrProgram&])
        assert program.stats.flatten_readconsts >= 1
        assert program.info.srt_walker_generated == true

        info_copy: mutable ShaderIrInfo = program.info
        DumpSrtProgram(info_copy, null, 0)
        _ = RegisterWalkerCode(null, 4)
        _ = SrtWalkerSignalHandler(null, null)

@test
def shader_ir_helper_contracts_match_cpp_switch_intent() -> void:
    can Abort.Panic:
        load_probe: mutable ShaderIrPassInst = zeroed
        load_probe.opcode <- OPCODE_LOADBUFFERFORMATF32
        store_probe: mutable ShaderIrPassInst = zeroed
        store_probe.opcode <- OPCODE_STOREBUFFERFORMATF32
        assert IsBufferFormatLoad(load_probe)
        assert IsBufferFormatStore(store_probe)

        p: mutable ShaderIrProgram = ShaderIrProgram_Default()
        b0: u32 = ShaderIrProgram_AddBlock((&p).cast[mutable ShaderIrProgram&])
        _ = ShaderIrProgram_AddInst((&p).cast[mutable ShaderIrProgram&], b0, OPCODE_SHAREDATOMICIADD64)
        _ = ShaderIrProgram_AddInst((&p).cast[mutable ShaderIrProgram&], b0, OPCODE_LOADSHAREDU16)
        special: u32 = CalculateSpecialSharedAtomicTypes(p)
        all_types: u32 = CalculateSharedMemoryTypes(p)
        assert (special & IR_TYPE_U64) != 0
        assert (all_types & IR_TYPE_U16) != 0

@test
def shader_ir_direct_helper_entrypoints_are_covered() -> void:
    can Abort.Panic:
        p: mutable ShaderIrProgram = ShaderIrProgram_Default()
        b0: u32 = ShaderIrProgram_AddBlock((&p).cast[mutable ShaderIrProgram&])

        cp_id: u32 = ShaderIrProgram_AddInst((&p).cast[mutable ShaderIrProgram&], b0, OPCODE_IADD32)
        bb: mutable u32 = 0
        bi: mutable u32 = 0
        assert ShaderIrProgram_FindInst(p, cp_id, (&bb).cast[mutable u32&], (&bi).cast[mutable u32&])
        ShaderIrPassInst_SetArgImm((&p.blocks[bb.usize()].insts[bi.usize()]).cast[mutable ShaderIrPassInst&], 0, 9)
        ShaderIrPassInst_SetArgImm((&p.blocks[bb.usize()].insts[bi.usize()]).cast[mutable ShaderIrPassInst&], 1, 2)
        assert ConstantPropagation((&p).cast[mutable ShaderIrProgram&], bb, bi)

        lower_id: u32 = ShaderIrProgram_AddInst((&p).cast[mutable ShaderIrProgram&], b0, OPCODE_FPADDD64)
        assert ShaderIrProgram_FindInst(p, lower_id, (&bb).cast[mutable u32&], (&bi).cast[mutable u32&])
        Lower((&p).cast[mutable ShaderIrProgram&], bb, bi)
        assert p.blocks[bb.usize()].insts[bi.usize()].opcode == OPCODE_FPADD32

        info: mutable ShaderIrInfo = zeroed
        visit_inst: mutable ShaderIrPassInst = zeroed
        visit_inst.opcode <- OPCODE_READCONST
        visit_inst.flags_u32 <- 1
        Visit((&info).cast[mutable ShaderIrInfo&], visit_inst)
        assert info.uses_dma == true
