const IR_PASS_MAX_ARGS: u32 = 6
const IR_PASS_MAX_INSTS: u32 = 512
const IR_PASS_MAX_BLOCKS: u32 = 96
const IR_PASS_MAX_SYNTAX: u32 = 256
const IR_PASS_INVALID_ID: u32 = 0xFFFFFFFF

const IR_PASS_ARG_NONE: u32 = 0
const IR_PASS_ARG_IMM: u32 = 1
const IR_PASS_ARG_INST: u32 = 2
const IR_PASS_ARG_ATTRIBUTE: u32 = 3
const IR_PASS_ARG_PATCH: u32 = 4
const IR_PASS_ARG_SCALAR: u32 = 5
const IR_PASS_ARG_VECTOR: u32 = 6

const STAGE_VERTEX: u32 = 1
const STAGE_FRAGMENT: u32 = 2
const STAGE_COMPUTE: u32 = 3
const STAGE_LOCAL: u32 = 4
const STAGE_EXPORT: u32 = 5
const STAGE_GEOMETRY: u32 = 6

const LOGICAL_STAGE_VERTEX: u32 = 1
const LOGICAL_STAGE_FRAGMENT: u32 = 2
const LOGICAL_STAGE_TESSELLATION_CONTROL: u32 = 3
const LOGICAL_STAGE_TESSELLATION_EVALUATION: u32 = 4

const IR_TYPE_VOID: u32 = 0
const IR_TYPE_U16: u32 = 1
const IR_TYPE_U32: u32 = 2
const IR_TYPE_U64: u32 = 4
