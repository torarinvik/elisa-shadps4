# ------------------------------------------------------------
# External C function declarations
# ------------------------------------------------------------

extern strlen(s: u8&) -> usize
extern strcmp(lhs: u8&, rhs: u8&) -> int
extern memcpy(dest: mutable void&, src: void&, n: usize) -> mutable void&
extern memmove(dest: mutable void&, src: void&, n: usize) -> mutable void&
extern memcmp(lhs: void&, rhs: void&, n: usize) -> int
extern memset(dest: mutable void&, val: int, n: usize) -> mutable void&
extern snprintf(buf: mutable u8&?, bufsize: usize, fmt: u8&, ...) -> int can[Console.Format]
extern puts(s: u8&) -> int can[Console.Write]
extern fprintf(stream: void&, fmt: u8&, ...) -> int can[Console]
extern exit(code: int) can[Abort.Exit]
extern stderr: void&

# ------------------------------------------------------------
# Constants
# ------------------------------------------------------------

const CTX_SMALL_STRING_CACHE_BUCKETS: usize = 1024
const CTX_STRING_LEN_CACHE_BUCKETS: usize = 4096
const CTX_ENABLE_SMALL_STRING_CACHE_EXPERIMENT: bool = false

# ------------------------------------------------------------
# Global arena state
# ------------------------------------------------------------

global mutable perm_arena: Arena = Arena(null, null, 0)
global mutable scratch_arena: Arena = Arena(null, null, 0)

# ------------------------------------------------------------
# Struct definitions
# ------------------------------------------------------------

struct SmallStringCacheEntry:
	next: mutable heap SmallStringCacheEntry&?
	len: mutable usize
	text: mutable tail u8

struct StringLenCacheEntry:
	next: mutable heap StringLenCacheEntry&?
	ptr: mutable u8&
	len: mutable usize

struct StringBuilder:
	len: mutable i64
	cap: mutable i64
	data: mutable heap u8&?

struct StringView:
	data: mutable u8&
	len: mutable i64

struct ProgressBudget:
	remaining_steps: mutable i64
	max_depth: mutable i64
	current_depth: mutable i64
	cancelled: mutable bool

# ------------------------------------------------------------
# Global caches (zero-initialized)
# ------------------------------------------------------------

global mutable small_string_cache: heap SmallStringCacheEntry&?[CTX_SMALL_STRING_CACHE_BUCKETS] = zeroed
global mutable string_len_cache: heap StringLenCacheEntry&?[CTX_STRING_LEN_CACHE_BUCKETS] = zeroed

# ------------------------------------------------------------
# Cooperative progress budget
# ------------------------------------------------------------

def progress_budget_steps(steps: i64) -> ProgressBudget:
	budget: ProgressBudget = zeroed
	budget.remaining_steps <- steps
	budget.max_depth <- 0
	budget.current_depth <- 0
	budget.cancelled <- false
	return budget

def progress_budget_steps_and_depth(steps: i64, max_depth: i64) -> ProgressBudget:
	budget: ProgressBudget = progress_budget_steps(steps)
	budget.max_depth <- max_depth
	return budget

def progress_cancel(budget: mutable ProgressBudget&):
	budget.cancelled <- true

def progress_check_cancel(budget: mutable ProgressBudget&):
	can Progress.CheckCancel, Abort.Panic:
		if budget.cancelled:
			panic("progress budget cancelled")

def progress_tick(budget: mutable ProgressBudget&):
	can Progress.Tick, Progress.CheckCancel, Abort.Panic:
		progress_check_cancel(budget)
		if budget.remaining_steps <= 0:
			panic("progress budget exhausted")
		budget.remaining_steps <- budget.remaining_steps - 1

def progress_enter_recursion(budget: mutable ProgressBudget&):
	can Progress.EnterRecursion, Progress.CheckCancel, Abort.Panic:
		progress_check_cancel(budget)
		if budget.max_depth > 0 and budget.current_depth >= budget.max_depth:
			panic("progress recursion depth exhausted")
		budget.current_depth <- budget.current_depth + 1

def progress_leave_recursion(budget: mutable ProgressBudget&):
	can Progress.LeaveRecursion:
		if budget.current_depth > 0:
			budget.current_depth <- budget.current_depth - 1

# ------------------------------------------------------------
# Permanent / scratch arena allocation
# ------------------------------------------------------------

def alloc_perm(size: i64) -> mutable heap void&:
	resolved: usize = size.usize() if size > 0 else 1
	return arena_alloc((&perm_arena).cast[Arena&], resolved) can Memory.Allocate, Abort.Panic

def alloc_scratch(size: i64) -> mutable heap void&:
	resolved: usize = size.usize() if size > 0 else 1
	return arena_alloc((&scratch_arena).cast[Arena&], resolved) can Memory.Allocate, Abort.Panic

def reset_scratch():
	arena_reset((&scratch_arena).cast[Arena&])

# ------------------------------------------------------------
# String length cache (pointer-keyed hash table)
# ------------------------------------------------------------

def string_len_bucket(ptr: u8&) -> usize:
	bits: mutable uintptr = ptr.uintptr()
	bits ^= (bits >> 33)
	bits *= 0xff51afd7ed558ccd.uintptr()
	bits ^= (bits >> 33)
	return (bits & (CTX_STRING_LEN_CACHE_BUCKETS - 1).uintptr()).usize()

def register_perm_string_len(ptr: u8&?, len: usize):
	can Memory.Allocate, Abort.Panic:
		if ptr == null or len == 0:
			return

		bucket: usize = string_len_bucket(ptr.cast[u8&])

		entry: mutable heap StringLenCacheEntry&? = string_len_cache[bucket]
		trusted Unsafe.AssumeProgress:
			while entry != null:
				if entry.ptr == ptr.cast[u8&]:
					entry.len <- len
					return
				entry <- entry.next

		new_entry: heap StringLenCacheEntry& = alloc_perm(size_of(StringLenCacheEntry).i64()).cast[heap StringLenCacheEntry&]
		new_entry.next <- string_len_cache[bucket]
		new_entry.ptr <- ptr.cast[u8&]
		new_entry.len <- len
		string_len_cache[bucket] <- new_entry

def lookup_cached_string_len(ptr: u8&?, len_out: mutable usize&) -> int:
	if ptr == null:
		return 0

	bucket: usize = string_len_bucket(ptr.cast[u8&])

	prev: mutable heap StringLenCacheEntry&? = null
	entry: mutable heap StringLenCacheEntry&? = string_len_cache[bucket]

	trusted Unsafe.AssumeProgress:
		while entry != null:
			if entry.ptr == ptr.cast[u8&]:
				# Move-to-front heuristic
				if prev != null:
					prev.next <- entry.next
					entry.next <- string_len_cache[bucket]
					string_len_cache[bucket] <- entry
				len_out <- entry.len
				return 1
			prev <- entry
			entry <- entry.next

	return 0

# ------------------------------------------------------------
# Runtime strlen (cache-aware)
# ------------------------------------------------------------

def runtime_strlen(value: u8&?) -> usize:
	src: u8& = value if value != null else ""

	if src[0] == 0:
		return 0
	# Conservative correctness path:
	# do not consult pointer-keyed cache here; non-permanent and reused
	# arena addresses can make cache lookups unsafe across lifetimes.
	return strlen(src)

# ------------------------------------------------------------
# Small string interning
# ------------------------------------------------------------

def intern_small_string(src: u8&, len: usize) -> heap u8&:
	can Memory.Allocate, Abort.Panic:
		# Conservative baseline after short-string crash investigations:
		# always allocate+copy and avoid cache-backed return aliases.
		# This path stays until the regression family proves a safe
		# small-string cache design under mixed string-builder flows.
		# TODO(runtime): reintroduce cache path only after these pass:
		# - short_string_builder_finish_regression
		# - short_string_builder_mixed_inputs_regression
		# - short_string_builder_cross_path_stress_regression
		# Experimental note:
		# CTX_ENABLE_SMALL_STRING_CACHE_EXPERIMENT exists to host
		# test-first cache experiments on dedicated branches.
		out: heap u8& = alloc_perm((len + 1).i64()).cast[heap u8&]
		if len > 0:
			memcpy(out.cast[mutable void&], src.cast[void&], len)
		out[len] <- 0
		register_perm_string_len(out.cast[u8&], len)
		return out

# ------------------------------------------------------------
# Integer / bool / char to string conversion
# ------------------------------------------------------------

def int_to_string_into(arena: mutable Arena&, value: i64) -> heap u8&:
	can Memory.Allocate, Console.Format, Abort.Panic:
		len: int = snprintf(null, 0, "%lld", value)

		if len > 0 and len <= 8:
			text: u8[9]
			snprintf((&text[0]).cast[u8&], len.usize() + 1, "%lld", value)
			return intern_small_string((&text[0]).cast[u8&], len.usize())

		out: heap u8& = arena_alloc(arena, len.usize() + 1).cast[heap u8&]
		snprintf(out.cast[u8&?], len.usize() + 1, "%lld", value)

		if arena == (&perm_arena).cast[Arena&]:
			register_perm_string_len(out.cast[u8&], len.usize())

		return out

def bool_to_string_into(arena: Arena&, value: int) -> u8&:
	_ = arena
	return "True" if value != 0 else "False"

def char_to_string_into(arena: Arena&, value: i64) -> heap u8&:
	can Memory.Allocate, Abort.Panic:
		_ = arena
		text: u8[2]
		text[0] <- value.u8()
		text[1] <- 0
		return intern_small_string((&text[0]).cast[u8&], 1)

# ------------------------------------------------------------
# String builder
# ------------------------------------------------------------

def string_builder_next_cap(min_cap: i64) -> i64:
	cap: mutable i64 = 16
	trusted Unsafe.AssumeProgress:
		while cap < min_cap:
			cap *= 2
	return cap

def string_builder_new(initial: u8&?) -> mutable heap StringBuilder&:
	can Memory.Allocate, Abort.Panic:
		src: u8& = initial if initial != null else ""
		len: usize = runtime_strlen(src)

		builder: heap StringBuilder& = alloc_perm(size_of(StringBuilder).i64()).cast[heap StringBuilder&]
		builder.len <- len.i64()
		builder.cap <- string_builder_next_cap(len.i64() + 1)
		builder.data <- alloc_perm(builder.cap).cast[heap u8&]

		if len > 0:
			memcpy(builder.data.cast[mutable void&], src.cast[void&], len)

		builder.data[len] <- 0
		return builder

def string_builder_append(builder: mutable heap StringBuilder&?, suffix: u8&?) -> mutable heap StringBuilder&:
	can Memory.Allocate, Abort.Panic:
		src: u8& = suffix if suffix != null else ""
		suffix_len: usize = runtime_strlen(src)

		if builder == null:
			return string_builder_new(src)

		if suffix_len == 0:
			return builder

		b: heap StringBuilder& = builder
		needed: i64 = b.len + suffix_len.i64() + 1

		if needed > b.cap:
			new_cap: i64 = string_builder_next_cap(needed)
			new_data: heap u8& = alloc_perm(new_cap).cast[heap u8&]
			if b.len > 0:
				assert b.data != null
				memcpy(new_data.cast[mutable void&], b.data.cast[void&], b.len.usize())
			b.data <- new_data
			b.cap <- new_cap

		assert b.data != null
		# Append may legally receive a suffix that aliases builder storage.
		# Use memmove to preserve defined behavior in overlap cases.
		memmove((b.data + b.len.usize()).cast[mutable void&], src.cast[void&], suffix_len)
		b.len += suffix_len.i64()
		b.data[b.len.usize()] <- 0
		return b

def string_builder_finish(builder: heap StringBuilder&?) -> heap u8&:
	can Memory.Allocate, Abort.Panic:
		if builder == null:
			return intern_small_string("", 0)

		b: heap StringBuilder& = builder
		if b.len <= 0:
			return intern_small_string("", 0)

		assert b.data != null

		if b.len <= 8:
			return intern_small_string(b.data.cast[u8&], b.len.usize())

		register_perm_string_len(b.data.cast[u8&], b.len.usize())
		return b.data
# end include /Users/torarinvikbjarko/Documents/Coding Projects/Go projects/Elisa-core/compiler/runtime/elisacore_std/elisacore_runtime_prelude.elisa
# begin include /Users/torarinvikbjarko/Documents/Coding Projects/Go projects/Elisa-core/compiler/runtime/elisacore_std/elisacore_runtime_concurrency.elisa
# ============================================================
# Elisa core Runtime - explicit concurrency carriers and helpers
# First slice: explicit runtime-facing surface, POSIX seam, generic atomics
# ============================================================

# ------------------------------------------------------------
# Core runtime carriers
# ------------------------------------------------------------

struct Thread[T, S]:
	handle: mutable uintptr
	state: mutable void&?

struct Task[T, S]:
	handle: mutable uintptr
	state: mutable void&?

struct ThreadPool:
	handle: mutable void&?

struct TaskGroup:
	handle: mutable void&?
	cleanup: mutable void&?

struct Mutex:
	handle: mutable void&?

struct MutexGuard[S]:
	handle: mutable void&?

struct CondVar:
	handle: mutable void&?

struct atomic[T]:
	value: mutable T

struct ConcurrencyBox[T]:
	value: mutable T

struct ConcurrencyWorkStart1:
	fn_bits: mutable uintptr
	arg_bits: mutable void&
	result_bits: mutable void&
	refs: mutable atomic[i64]

struct ConcurrencyTaskGroupNode:
	next: mutable heap ConcurrencyTaskGroupNode&?
	state_bits: mutable void&

struct ConcurrencyRawTaskNode:
	next: mutable heap ConcurrencyRawTaskNode&?
	handle: mutable uintptr

struct ConcurrencyPoolState:
	worker_count: mutable usize

enum MemoryOrder:
	Relaxed
	Acquire
	Release
	AcqRel
	SeqCst

# ------------------------------------------------------------
# Low-level platform seams
# ------------------------------------------------------------

static if ELISA_TARGET_OS_POSIX:
	extern pthread_create(thread: mutable uintptr&, attr: void&?, start_routine: void&, arg: void&?) -> int can[Thread.Spawn]
	extern pthread_join(thread: uintptr, retval: mutable void&?) -> int can[Thread.Join]
	extern pthread_detach(thread: uintptr) -> int can[Thread.Detach]

	extern pthread_mutex_lock(mutex: void&) -> int can[Sync.Lock]
	extern pthread_mutex_unlock(mutex: void&) -> int can[Sync.Unlock]
	extern pthread_cond_wait(cond: void&, mutex: void&) -> int can[Sync.Wait]
	extern pthread_cond_signal(cond: void&) -> int can[Sync.Notify]
	extern pthread_cond_broadcast(cond: void&) -> int can[Sync.Notify]

	def ctx_platform_mutex_lock(handle: void&) -> int:
		can Sync.Lock:
			return pthread_mutex_lock(handle)

	def ctx_platform_mutex_unlock(handle: void&) -> int:
		can Sync.Unlock:
			return pthread_mutex_unlock(handle)

	def ctx_platform_cond_wait(cond: void&, mutex: void&) -> int:
		can Sync.Wait:
			return pthread_cond_wait(cond, mutex)

	def ctx_platform_cond_signal(cond: void&) -> int:
		can Sync.Notify:
			return pthread_cond_signal(cond)

	def ctx_platform_cond_broadcast(cond: void&) -> int:
		can Sync.Notify:
			return pthread_cond_broadcast(cond)

static elif ELISA_TARGET_OS_WINDOWS:
	@c_opaque(windows.h, CRITICAL_SECTION)
	extern Win32CriticalSection

	@c_opaque(windows.h, CONDITION_VARIABLE)
	extern Win32ConditionVariable

	const WIN32_WAIT_INFINITE = 0xffffffff

	@callconv(winapi)
	extern EnterCriticalSection(section: mutable Win32CriticalSection&) -> void can[Sync.Lock]

	@callconv(winapi)
	extern LeaveCriticalSection(section: mutable Win32CriticalSection&) -> void can[Sync.Unlock]

	@callconv(winapi)
	extern SleepConditionVariableCS(cond: mutable Win32ConditionVariable&, section: mutable Win32CriticalSection&, milliseconds: u32) -> bool can[Sync.Wait]

	@callconv(winapi)
	extern WakeConditionVariable(cond: mutable Win32ConditionVariable&) -> void can[Sync.Notify]

	@callconv(winapi)
	extern WakeAllConditionVariable(cond: mutable Win32ConditionVariable&) -> void can[Sync.Notify]

	def ctx_platform_mutex_lock(handle: void&) -> int:
		can Sync.Lock:
			EnterCriticalSection(handle.cast[mutable Win32CriticalSection&])
			return 0

	def ctx_platform_mutex_unlock(handle: void&) -> int:
		can Sync.Unlock:
			LeaveCriticalSection(handle.cast[mutable Win32CriticalSection&])
			return 0

	def ctx_platform_cond_wait(cond: void&, mutex: void&) -> int:
		can Sync.Wait:
			ok: bool = SleepConditionVariableCS(
				cond.cast[mutable Win32ConditionVariable&],
				mutex.cast[mutable Win32CriticalSection&],
				WIN32_WAIT_INFINITE
			)
			return 0 if ok else -1

	def ctx_platform_cond_signal(cond: void&) -> int:
		can Sync.Notify:
			WakeConditionVariable(cond.cast[mutable Win32ConditionVariable&])
			return 0

	def ctx_platform_cond_broadcast(cond: void&) -> int:
		can Sync.Notify:
			WakeAllConditionVariable(cond.cast[mutable Win32ConditionVariable&])
			return 0

# ------------------------------------------------------------
# Cross-platform runtime FFI handles
# ------------------------------------------------------------

extern ctx_thread_create(thread: mutable uintptr&, entry: void&, arg: void&?) -> int can[Thread.Spawn]
extern ctx_thread_join(thread: uintptr) -> int can[Thread.Join]
extern ctx_thread_detach(thread: uintptr) -> int can[Thread.Detach]
extern elisa_native_callback_ptr(name: u8&) -> void&?
extern elisa_native_callback_call_u32_voidp(name: u8&, arg: void&?, fallback: u32) -> u32
extern elisa_native_callback_call_i32_voidp(name: u8&, arg: void&?, fallback: i32) -> i32
extern elisa_native_callback_call_usize_voidp(name: u8&, arg: void&?, fallback: usize) -> usize
extern elisa_native_callback_call_isize_voidp(name: u8&, arg: void&?, fallback: isize) -> isize
extern elisa_native_callback_spawn_join_u32_voidp(name: u8&, arg: void&?, fallback: u32) -> u32 can[Thread.Spawn, Thread.Join]
extern elisa_native_callback_context_new_u32_voidp(name: u8&, arg: void&?, fallback: u32) -> mutable heap void&? can[Memory.Allocate]
extern elisa_native_callback_context_entry_u32_voidp() -> void&?
extern elisa_native_callback_context_start_u32_voidp(ctx: mutable heap void&?, thread: mutable uintptr&) -> int can[Thread.Spawn]
extern elisa_native_callback_context_join_u32_voidp(handle: uintptr, ctx: mutable heap void&?, fallback: u32) -> u32 can[Thread.Join]
extern elisa_native_callback_context_spawn_join_u32_voidp(ctx: mutable heap void&?, fallback: u32) -> u32 can[Thread.Spawn, Thread.Join]
extern elisa_native_callback_context_result_u32(ctx: mutable heap void&?, fallback: u32) -> u32
extern elisa_native_callback_context_free(ctx: mutable heap void&?) -> void can[Memory.Release]
extern elisa_c_opaque_alloc(type_name: u8&) -> mutable heap void&? can[Memory.Allocate]
extern elisa_c_opaque_free(ptr: heap void&) -> void can[Memory.Release]
extern elisa_c_opaque_size(type_name: u8&) -> usize
extern elisa_c_opaque_align(type_name: u8&) -> usize
extern mutex_init(out: mutable Mutex&) -> void can[Memory.Allocate]
extern mutex_destroy(mu: mutable Mutex&) -> void can[Memory.Release]
extern ctx_mutex_lock(mutex: void&) -> int can[Sync.Lock]
extern ctx_mutex_unlock(mutex: void&) -> int can[Sync.Unlock]
extern condvar_init(out: mutable CondVar&) -> void can[Memory.Allocate]
extern condvar_destroy(cv: mutable CondVar&) -> void can[Memory.Release]
extern ctx_cond_wait(cond: void&, mutex: void&) -> int can[Sync.Wait]
extern ctx_cond_signal(cond: void&) -> int can[Sync.Notify]
extern ctx_cond_broadcast(cond: void&) -> int can[Sync.Notify]
extern thread_yield() -> void can[Thread.Yield]
extern thread_sleep_usec(usec: u64) -> void can[Thread.Sleep]

# ------------------------------------------------------------
# Typed wrapper helpers
# ------------------------------------------------------------

def ctx_concurrency_alloc(size: usize) -> mutable heap void&:
	can Memory.Allocate, Abort.Panic:
		raw: heap void&? = malloc(size)
		if raw == null:
			panic("concurrency allocation failed")
		ptr: heap void& = raw.cast[heap void&]
		return ptr

def ctx_concurrency_box_new[T](value: T) -> mutable heap ConcurrencyBox[T]&:
	raw: heap void& = ctx_concurrency_alloc(size_of(ConcurrencyBox[T])) can Memory.Allocate, Abort.Panic
	box: heap ConcurrencyBox[T]& = raw.cast[heap ConcurrencyBox[T]&]
	box.value <- value
	return box

def mutex() -> Mutex:
	can Memory.Allocate:
		out: Mutex = zeroed
		mutex_init((&out).cast[mutable Mutex&])
		return move out

def mutex_dispose(mu: mutable Mutex&):
	can Memory.Release:
		mutex_destroy(mu)

def mutex_lock(mu: mutable Mutex&) -> MutexGuard[Held]:
	can Sync.Lock, Abort.Panic:
		if mu.handle == null:
			panic("mutex_lock on uninitialized mutex")
		status: int = ctx_platform_mutex_lock(mu.handle.cast[void&])
		if status != 0:
			panic("mutex lock failed")
		guard: MutexGuard[Held] = zeroed
		guard.handle <- mu.handle
		return move guard

def mutex_unlock(g: MutexGuard[Held]):
	can Sync.Unlock, Abort.Panic:
		handle: void&? = g.handle
		_ = move g
		if handle == null:
			panic("mutex_unlock on empty guard")
		status: int = ctx_platform_mutex_unlock(handle.cast[void&])
		if status != 0:
			panic("mutex unlock failed")

def condvar() -> CondVar:
	can Memory.Allocate:
		out: CondVar = zeroed
		condvar_init((&out).cast[mutable CondVar&])
		return move out

def condvar_dispose(cv: mutable CondVar&):
	can Memory.Release:
		condvar_destroy(cv)

def cond_wait(cv: mutable CondVar&, g: MutexGuard[Held]) -> MutexGuard[Held]:
	can Sync.Wait, Abort.Panic:
		cond_handle: void&? = cv.handle
		mutex_handle: void&? = g.handle
		if cond_handle == null:
			panic("cond_wait on uninitialized condvar")
		if mutex_handle == null:
			panic("cond_wait with empty mutex guard")
		status: int = ctx_platform_cond_wait(cond_handle.cast[void&], mutex_handle.cast[void&])
		if status != 0:
			panic("cond wait failed")
		return move g

def notify_one(cv: mutable CondVar&):
	can Sync.Notify, Abort.Panic:
		if cv.handle == null:
			panic("notify_one on uninitialized condvar")
		status: int = ctx_platform_cond_signal(cv.handle.cast[void&])
		if status != 0:
			panic("cond signal failed")

def notify_all(cv: mutable CondVar&):
	can Sync.Notify, Abort.Panic:
		if cv.handle == null:
			panic("notify_all on uninitialized condvar")
		status: int = ctx_platform_cond_broadcast(cv.handle.cast[void&])
		if status != 0:
			panic("cond broadcast failed")

def yield_thread():
	can Thread.Yield:
		thread_yield()

def sleep_usec(usec: u64):
	can Thread.Sleep:
		thread_sleep_usec(usec)

def ctx_concurrency_join_handle(handle: uintptr):
	can Thread.Join, Abort.Panic:
		status: int = ctx_thread_join(handle)
		if status != 0:
			panic("thread join failed")

def spawn_raw(entry: void&, arg: void&?) -> Thread[void&?, Joinable]:
	can Thread.Spawn, Abort.Panic:
		out: Thread[void&?, Joinable] = zeroed
		status: int = ctx_thread_create((&out.handle).cast[mutable uintptr&], entry, arg)
		if status != 0:
			panic("thread create failed")
		out.state <- arg
		return move out

def join_raw(thread: Thread[void&?, Joinable]) -> void&?:
	can Thread.Join, Abort.Panic:
		handle: uintptr = thread.handle
		state_bits: void&? = thread.state
		_ = move thread
		ctx_concurrency_join_handle(handle)
		return state_bits

def native_callback_ptr(name: u8&) -> void&?:
	return elisa_native_callback_ptr(name)

def native_callback_call_u32_voidp(name: u8&, arg: void&?, fallback: u32) -> u32:
	return elisa_native_callback_call_u32_voidp(name, arg, fallback)

def native_callback_call_i32_voidp(name: u8&, arg: void&?, fallback: i32) -> i32:
	return elisa_native_callback_call_i32_voidp(name, arg, fallback)

def native_callback_call_usize_voidp(name: u8&, arg: void&?, fallback: usize) -> usize:
	return elisa_native_callback_call_usize_voidp(name, arg, fallback)

def native_callback_call_isize_voidp(name: u8&, arg: void&?, fallback: isize) -> isize:
	return elisa_native_callback_call_isize_voidp(name, arg, fallback)

def native_callback_spawn_join_u32_voidp(name: u8&, arg: void&?, fallback: u32) -> u32:
	can Thread.Spawn, Thread.Join:
		return elisa_native_callback_spawn_join_u32_voidp(name, arg, fallback)

def native_callback_context_new_u32_voidp(name: u8&, arg: void&?, fallback: u32) -> mutable heap void&?:
	can Memory.Allocate:
		return elisa_native_callback_context_new_u32_voidp(name, arg, fallback)

def native_callback_context_entry_u32_voidp() -> void&?:
	return elisa_native_callback_context_entry_u32_voidp()

def native_callback_context_start_u32_voidp(ctx: mutable heap void&?, thread: mutable uintptr&) -> int:
	can Thread.Spawn:
		return elisa_native_callback_context_start_u32_voidp(ctx, thread)

def native_callback_context_join_u32_voidp(handle: uintptr, ctx: mutable heap void&?, fallback: u32) -> u32:
	can Thread.Join:
		return elisa_native_callback_context_join_u32_voidp(handle, ctx, fallback)

def native_callback_context_spawn_join_u32_voidp(ctx: mutable heap void&?, fallback: u32) -> u32:
	can Thread.Spawn, Thread.Join:
		return elisa_native_callback_context_spawn_join_u32_voidp(ctx, fallback)

def native_callback_context_result_u32(ctx: mutable heap void&?, fallback: u32) -> u32:
	return elisa_native_callback_context_result_u32(ctx, fallback)

def native_callback_context_free(ctx: mutable heap void&?):
	can Memory.Release:
		elisa_native_callback_context_free(ctx)

def spawn_native_callback_u32_voidp(name: u8&, arg: void&?, fallback: u32) -> Thread[u32, Joinable]:
	can Thread.Spawn, Memory.Allocate, Memory.Release, Abort.Panic:
		ctx: mutable heap void&? = native_callback_context_new_u32_voidp(name, arg, fallback)
		if ctx == null:
			panic("native callback context allocation failed")
		out: Thread[u32, Joinable] = zeroed
		status: int = native_callback_context_start_u32_voidp(ctx, (&out.handle).cast[mutable uintptr&])
		if status != 0:
			native_callback_context_free(ctx)
			panic("native callback context start failed")
		out.state <- ctx.cast[void&]
		return move out

def join_native_callback_u32(thread: Thread[u32, Joinable], fallback: u32) -> u32:
	can Thread.Join, Memory.Release, Abort.Panic:
		handle: uintptr = thread.handle
		state_bits: void&? = thread.state
		_ = move thread
		result: u32 = native_callback_context_join_u32_voidp(handle, state_bits.cast[mutable heap void&?], fallback)
		native_callback_context_free(state_bits.cast[mutable heap void&?])
		return result

def detach_raw(thread: Thread[void&?, Joinable]):
	can Thread.Detach, Abort.Panic:
		handle: uintptr = thread.handle
		_ = move thread
		status: int = ctx_thread_detach(handle)
		if status != 0:
			panic("thread detach failed")

def pool_new(threads: usize) -> ThreadPool:
	can Pool.Create, Memory.Allocate, Abort.Panic:
		raw: heap void& = ctx_concurrency_alloc(size_of(ConcurrencyPoolState))
		state: heap ConcurrencyPoolState& = raw.cast[heap ConcurrencyPoolState&]
		state.worker_count <- threads
		out: ThreadPool = zeroed
		out.handle <- state.cast[void&]
		return move out

def pool_shutdown(pool: mutable ThreadPool&):
	can Pool.Shutdown, Memory.Release:
		if pool.handle != null:
			free(pool.handle.cast[heap void&])
			pool.handle <- null

def pool_submit_raw(pool: mutable ThreadPool&, entry: void&, arg: void&?) -> Task[void&?, Pending]:
	can Pool.Submit, Thread.Spawn, Abort.Panic:
		_ = pool
		thread: Thread[void&?, Joinable] = spawn_raw(entry, arg)
		out: Task[void&?, Pending] = zeroed
		out.handle <- thread.handle
		out.state <- thread.state
		_ = move thread
		return move out

def pool_await_raw(task: Task[void&?, Pending]) -> void&?:
	can Pool.Await, Thread.Join, Abort.Panic:
		handle: uintptr = task.handle
		state_bits: void&? = task.state
		_ = move task
		ctx_concurrency_join_handle(handle)
		return state_bits

def task_group_new_raw() -> TaskGroup:
	out: TaskGroup = zeroed
	return move out

def task_group_add_raw(group: mutable TaskGroup&, task: Task[void&?, Pending]):
	can Memory.Allocate, Abort.Panic:
		handle: uintptr = task.handle
		_ = move task
		raw: heap void& = ctx_concurrency_alloc(size_of(ConcurrencyRawTaskNode))
		node: heap ConcurrencyRawTaskNode& = raw.cast[heap ConcurrencyRawTaskNode&]
		node.handle <- handle
		if group.handle == null:
			node.next <- null
		else:
			node.next <- group.handle.cast[heap ConcurrencyRawTaskNode&]
		group.handle <- node.cast[void&]

def task_group_wait_all_raw(group: mutable TaskGroup&):
	can Pool.WaitAll, Thread.Join, Memory.Release, Abort.Panic:
		current: mutable heap ConcurrencyRawTaskNode&? = group.handle.cast[heap ConcurrencyRawTaskNode&?]
		group.handle <- null
		trusted Unsafe.AssumeProgress:
			while current != null:
				next: mutable heap ConcurrencyRawTaskNode&? = current.next
				ctx_concurrency_join_handle(current.handle)
				free(current.cast[heap void&])
				current <- next

def ctx_concurrency_ref_release(slot: mutable atomic[i64]&) -> i64:
	trusted Unsafe.AssumeProgress:
		while true:
			current: i64 = load(slot, MemoryOrder.Acquire) can Atomics.Load
			next: i64 = current - 1
			if compare_exchange(slot, current, next, MemoryOrder.AcqRel, MemoryOrder.Acquire) can Atomics.CompareExchange:
				return next
	return 0

def ctx_concurrency_work1_release(state_bits: mutable void&?):
	can Memory.Release, Atomics.Load, Atomics.CompareExchange:
		if state_bits == null:
			return
		live_bits: void& = state_bits.cast[void&]
		state: heap ConcurrencyWorkStart1& = live_bits.cast[heap ConcurrencyWorkStart1&]
		remaining: i64 = ctx_concurrency_ref_release((&state.refs).cast[atomic[i64]&])
		if remaining == 0:
			free(state.arg_bits.cast[heap void&])
			free(state.result_bits.cast[heap void&])
			free(state.cast[heap void&])

def ctx_concurrency_work1_new[A, R, permission P](fn: func(A) -> R can[P], arg: A) -> mutable heap ConcurrencyWorkStart1&:
	can Memory.Allocate, Abort.Panic:
		arg_box: heap ConcurrencyBox[A]& = ctx_concurrency_box_new(arg)
		result_seed: R = zeroed
		result_box: heap ConcurrencyBox[R]& = ctx_concurrency_box_new(result_seed)
		raw: heap void& = ctx_concurrency_alloc(size_of(ConcurrencyWorkStart1))
		state: heap ConcurrencyWorkStart1& = raw.cast[heap ConcurrencyWorkStart1&]
		state.fn_bits <- fn as uintptr
		state.arg_bits <- arg_box.cast[void&]
		state.result_bits <- result_box.cast[void&]
		state.refs.value <- 2
		return state

def ctx_concurrency_work1_entry[A, R, permission P](state_bits: mutable void&) -> void&:
	can P, Memory.Release, Atomics.Load, Atomics.CompareExchange:
		state: heap ConcurrencyWorkStart1& = state_bits.cast[heap ConcurrencyWorkStart1&]
		fn: func(A) -> R can[P] = state.fn_bits.cast[func(A) -> R can[P]]
		arg_box: heap ConcurrencyBox[A]& = state.arg_bits.cast[heap ConcurrencyBox[A]&]
		result_box: heap ConcurrencyBox[R]& = state.result_bits.cast[heap ConcurrencyBox[R]&]
		result_box.value <- fn(arg_box.value)
		ctx_concurrency_work1_release(state.cast[mutable void&])
		return state.cast[void&]

def ctx_concurrency_work1_take_result[R](state_bits: void&?) -> R:
	can Memory.Release, Abort.Panic, Atomics.Load, Atomics.CompareExchange:
		if state_bits == null:
			panic("concurrency work returned no state")
		live_bits: void& = state_bits.cast[void&]
		state: heap ConcurrencyWorkStart1& = live_bits.cast[heap ConcurrencyWorkStart1&]
		result_box: heap ConcurrencyBox[R]& = state.result_bits.cast[heap ConcurrencyBox[R]&]
		result: R = result_box.value
		ctx_concurrency_work1_release(state.cast[mutable void&])
		return result

def ctx_thread_from_raw[R, S](raw: Thread[void&?, S]) -> Thread[R, S]:
	out: Thread[R, S] = zeroed
	out.handle <- raw.handle
	out.state <- raw.state
	return move out

def ctx_thread_to_raw[R, S](thread: Thread[R, S]) -> Thread[void&?, S]:
	out: Thread[void&?, S] = zeroed
	out.handle <- thread.handle
	out.state <- thread.state
	return move out

def ctx_task_from_raw[R, S](raw: Task[void&?, S]) -> Task[R, S]:
	out: Task[R, S] = zeroed
	out.handle <- raw.handle
	out.state <- raw.state
	return move out

def ctx_task_to_raw[R, S](task: Task[R, S]) -> Task[void&?, S]:
	out: Task[void&?, S] = zeroed
	out.handle <- task.handle
	out.state <- task.state
	return move out

def task_group_new() -> TaskGroup:
	group: TaskGroup = task_group_new_raw()
	group.cleanup <- null
	return move group

def ctx_task_group_push_state(group: mutable TaskGroup&, state_bits: void&?):
	can Memory.Allocate, Abort.Panic:
		if state_bits == null:
			return
		raw: heap void& = ctx_concurrency_alloc(size_of(ConcurrencyTaskGroupNode))
		node: heap ConcurrencyTaskGroupNode& = raw.cast[heap ConcurrencyTaskGroupNode&]
		if group.cleanup == null:
			node.next <- null
		else:
			node.next <- group.cleanup.cast[heap ConcurrencyTaskGroupNode&]
		node.state_bits <- state_bits.cast[void&]
		group.cleanup <- node.cast[void&]

def ctx_task_group_release_all(group: mutable TaskGroup&):
	can Memory.Release, Atomics.Load, Atomics.CompareExchange:
		if group.cleanup == null:
			return
		current: mutable heap ConcurrencyTaskGroupNode&? = group.cleanup.cast[heap ConcurrencyTaskGroupNode&?]
		group.cleanup <- null
		trusted Unsafe.AssumeProgress:
			while current != null:
				next: mutable heap ConcurrencyTaskGroupNode&? = current.next
				ctx_concurrency_work1_release(current.state_bits.cast[mutable void&])
				free(current.cast[heap void&])
				current <- next

def spawn1[A, R, permission P](fn: func(A) -> R can[P], arg: A) -> Thread[R, Joinable]:
	can Thread.Spawn, Memory.Allocate, Abort.Panic:
		from_raw: func(Thread[void&?, Joinable]) -> Thread[R, Joinable] = ctx_thread_from_raw.specialize[R, Joinable]()
		state: heap ConcurrencyWorkStart1& = ctx_concurrency_work1_new(fn, arg)
		raw: Thread[void&?, Joinable] = spawn_raw(
			ctx_concurrency_work1_entry.specialize[A, R]().cast[void&],
			state.cast[void&]
		)
		raw.state <- state.cast[void&]
		return from_raw(move raw)

def join[R](thread: Thread[R, Joinable]) -> R:
	can Thread.Join, Memory.Release, Abort.Panic, Atomics.Load, Atomics.CompareExchange:
		take_result: func(void&?) -> R can[Memory.Release, Abort.Panic, Atomics.Load, Atomics.CompareExchange] = ctx_concurrency_work1_take_result.specialize[R]()
		state_bits: void&? = thread.state
		raw: Thread[void&?, Joinable] = ctx_thread_to_raw(move thread)
		_ = join_raw(move raw)
		result: R = take_result(state_bits)
		return result

def detach[R](thread: Thread[R, Joinable]):
	can Thread.Detach, Memory.Release, Abort.Panic, Atomics.Load, Atomics.CompareExchange:
		state_bits: void&? = thread.state
		raw: Thread[void&?, Joinable] = ctx_thread_to_raw(move thread)
		detach_raw(move raw)
		ctx_concurrency_work1_release(state_bits)

def pool_submit1[A, R, permission P](pool: mutable ThreadPool&, fn: func(A) -> R can[P], arg: A) -> Task[R, Pending]:
	can Pool.Submit, Thread.Spawn, Memory.Allocate, Abort.Panic:
		from_raw: func(Task[void&?, Pending]) -> Task[R, Pending] = ctx_task_from_raw.specialize[R, Pending]()
		state: heap ConcurrencyWorkStart1& = ctx_concurrency_work1_new(fn, arg)
		raw: Task[void&?, Pending] = pool_submit_raw(
			pool,
			ctx_concurrency_work1_entry.specialize[A, R]().cast[void&],
			state.cast[void&]
		)
		raw.state <- state.cast[void&]
		return from_raw(move raw)

def pool_await[R](task: Task[R, Pending]) -> R:
	can Pool.Await, Thread.Join, Memory.Release, Abort.Panic, Atomics.Load, Atomics.CompareExchange:
		take_result: func(void&?) -> R can[Memory.Release, Abort.Panic, Atomics.Load, Atomics.CompareExchange] = ctx_concurrency_work1_take_result.specialize[R]()
		state_bits: void&? = task.state
		raw: Task[void&?, Pending] = ctx_task_to_raw(move task)
		_ = pool_await_raw(move raw)
		result: R = take_result(state_bits)
		return result

def task_group_add[R](group: mutable TaskGroup&, task: Task[R, Pending]):
	can Memory.Allocate, Abort.Panic:
		state_bits: void&? = task.state
		raw: Task[void&?, Pending] = ctx_task_to_raw(move task)
		task_group_add_raw(group, move raw)
		ctx_task_group_push_state(group, state_bits)

def task_group_wait_all(group: mutable TaskGroup&):
	can Pool.WaitAll, Thread.Join, Memory.Release, Abort.Panic, Atomics.Load, Atomics.CompareExchange:
		task_group_wait_all_raw(group)
		ctx_task_group_release_all(group)

# ------------------------------------------------------------
# Generic atomic helpers
# ------------------------------------------------------------

def load[T](slot: atomic[T]&, order: MemoryOrder) -> T:
	can Atomics.Load:
		_ = order
		return slot.value

def store[T](slot: mutable atomic[T]&, value: T, order: MemoryOrder):
	can Atomics.Store:
		_ = order
		slot.value <- value

def exchange[T](slot: mutable atomic[T]&, value: T, order: MemoryOrder) -> T:
	can Atomics.Exchange:
		_ = order
		old_value: T = slot.value
		slot.value <- value
		return old_value

def compare_exchange[T](slot: mutable atomic[T]&, expected: T, desired: T, success: MemoryOrder, failure: MemoryOrder) -> bool:
	can Atomics.CompareExchange:
		_ = success
		_ = failure
		if slot.value == expected:
			slot.value <- desired
			return true
		return false

def fetch_add(slot: mutable atomic[i64]&, value: i64, order: MemoryOrder) -> i64:
	can Atomics.Rmw:
		_ = order
		old_value: i64 = slot.value
		slot.value <- old_value + value
		return old_value

def fetch_sub(slot: mutable atomic[i64]&, value: i64, order: MemoryOrder) -> i64:
	can Atomics.Rmw:
		_ = order
		old_value: i64 = slot.value
		slot.value <- old_value - value
		return old_value

def fetch_or(slot: mutable atomic[i64]&, value: i64, order: MemoryOrder) -> i64:
	can Atomics.Rmw:
		_ = order
		old_value: i64 = slot.value
		slot.value <- old_value | value
		return old_value

def fetch_and(slot: mutable atomic[i64]&, value: i64, order: MemoryOrder) -> i64:
	can Atomics.Rmw:
		_ = order
		old_value: i64 = slot.value
		slot.value <- old_value & value
		return old_value

def fetch_xor(slot: mutable atomic[i64]&, value: i64, order: MemoryOrder) -> i64:
	can Atomics.Rmw:
		_ = order
		old_value: i64 = slot.value
		slot.value <- old_value ^ value
		return old_value

def fence(order: MemoryOrder):
	can Atomics.Fence:
		_ = order
# end include /Users/torarinvikbjarko/Documents/Coding Projects/Go projects/Elisa-core/compiler/runtime/elisacore_std/elisacore_runtime_concurrency.elisa
# begin include /Users/torarinvikbjarko/Documents/Coding Projects/Go projects/Elisa-core/compiler/runtime/elisacore_std/elisacore_runtime_strings.elisa
# ============================================================
# Elisa core Runtime - string primitives and views
# ============================================================

# ------------------------------------------------------------
# String concatenation
# ------------------------------------------------------------

def concat2(lhs: u8&?, rhs: u8&?) -> u8&:
    can Memory.Allocate, Abort.Panic:
        left: u8& = lhs.cast[u8&] if lhs != null else ""
        right: u8& = rhs.cast[u8&] if rhs != null else ""

        left_len: usize = runtime_strlen(left)
        right_len: usize = runtime_strlen(right)

        right return if left_len == 0

        left return if right_len == 0

        if left_len + right_len <= 8:
            text: u8[9]
            memcpy((&text[0]).cast[mutable void&], left.cast[void&], left_len)
            memcpy((&text[0] + left_len).cast[mutable void&], right.cast[void&], right_len)
            text[left_len + right_len] <- 0
            return intern_small_string((&text[0]).cast[u8&], left_len + right_len).cast[u8&]

        out: u8& = alloc_perm((left_len + right_len + 1).i64()).cast[u8&]
        memcpy(out.cast[mutable void&], left.cast[void&], left_len)
        memcpy((out + left_len).cast[mutable void&], right.cast[void&], right_len)
        out[left_len + right_len] <- 0
        register_perm_string_len(out, left_len + right_len)
        return out

def concat2_scratch(lhs: u8&?, rhs: u8&?) -> u8&:
    can Memory.Allocate, Abort.Panic:
        left: u8& = lhs.cast[u8&] if lhs != null else ""
        right: u8& = rhs.cast[u8&] if rhs != null else ""

        left_len: usize = runtime_strlen(left)
        right_len: usize = runtime_strlen(right)

        right return if left_len == 0

        left return if right_len == 0

        if left_len + right_len <= 8:
            text: u8[9]
            memcpy((&text[0]).cast[mutable void&], left.cast[void&], left_len)
            memcpy((&text[0] + left_len).cast[mutable void&], right.cast[void&], right_len)
            text[left_len + right_len] <- 0
            return intern_small_string((&text[0]).cast[u8&], left_len + right_len).cast[u8&]

        out: u8& = alloc_scratch((left_len + right_len + 1).i64()).cast[u8&]
        memcpy(out.cast[mutable void&], left.cast[void&], left_len)
        memcpy((out + left_len).cast[mutable void&], right.cast[void&], right_len)
        out[left_len + right_len] <- 0
        return out

# ------------------------------------------------------------
# String operations
# ------------------------------------------------------------

def string_index(value: u8&?, index: i64) -> i64:
    src: u8& = value if value != null else ""
    len: usize = runtime_strlen(src)

    return 0 if index < 0 or index.usize() >= len else src[index.usize()].i64()

    

def string_slice_eq(value: u8&?, start: i64, end: i64, other: u8&?) -> int:
    src: u8& = value if value != null else ""
    rhs: u8& = other if other != null else ""
    len: usize = runtime_strlen(src)

    lo: mutable usize = 0
    hi: mutable usize = len

    if start > 0:
        lo <- start.usize()
        if lo > len:
            lo <- len

    if end >= 0:
        hi <- end.usize()
        if hi > len:
            hi <- len

    if hi < lo:
        hi <- lo

    slice_len: usize = hi - lo
    rhs_len: usize = runtime_strlen(rhs)

    0 return if slice_len != rhs_len

    #1 return if slice_len == 0
    #1 return if src + lo == rhs
    1 return if slice_len == 0 or src + lo == rhs

    return 1 if memcmp((src + lo).cast[void&], rhs.cast[void&], slice_len) == 0 else 0

def string_slices_eq(lhs: u8&?, lhs_start: i64, lhs_end: i64, rhs: u8&?, rhs_start: i64, rhs_end: i64) -> int:
    left: u8& = lhs if lhs != null else ""
    right: u8& = rhs if rhs != null else ""
    left_len: usize = runtime_strlen(left)
    right_len: usize = runtime_strlen(right)

    left_lo: mutable usize = 0
    left_hi: mutable usize = left_len
    right_lo: mutable usize = 0
    right_hi: mutable usize = right_len

    if lhs_start > 0:
        left_lo <- lhs_start.usize()
        if left_lo > left_len:
            left_lo <- left_len

    if lhs_end >= 0:
        left_hi <- lhs_end.usize()
        if left_hi > left_len:
            left_hi <- left_len

    if left_hi < left_lo:
        left_hi <- left_lo

    if rhs_start > 0:
        right_lo <- rhs_start.usize()
        if right_lo > right_len:
            right_lo <- right_len

    if rhs_end >= 0:
        right_hi <- rhs_end.usize()
        if right_hi > right_len:
            right_hi <- right_len

    if right_hi < right_lo:
        right_hi <- right_lo

    left_slice_len: usize = left_hi - left_lo
    right_slice_len: usize = right_hi - right_lo

    0 return if left_slice_len != right_slice_len

    #1 return if left_slice_len == 0
    #1 return if left + left_lo == right + right_lo
    1 return if left_slice_len == 0 or left + left_lo == right + right_lo 

    return 1 if memcmp((left + left_lo).cast[void&], (right + right_lo).cast[void&], left_slice_len) == 0 else 0

def string_slice(value: u8&?, start: i64, end: i64) -> u8&:
    can Memory.Allocate, Abort.Panic:
        src: u8& = value if value != null else ""
        len: usize = runtime_strlen(src)

        lo: mutable usize = 0
        hi: mutable usize = len

        if start > 0:
            lo <- start.usize()
            if lo > len:
                lo <- len

        if end >= 0:
            hi <- end.usize()
            if hi > len:
                hi <- len

        if hi < lo:
            hi <- lo

        src return if lo == 0 and hi == len

        out_len: usize = hi - lo

        "" return if out_len == 0

        intern_small_string(src + lo, out_len).cast[u8&] return if out_len <= 8

        out: u8& = alloc_perm((out_len + 1).i64()).cast[u8&]
        memcpy(out.cast[mutable void&], (src + lo).cast[void&], out_len)
        out[out_len] <- 0
        register_perm_string_len(out, out_len)
        return out

def sview(value: u8&?, start: i64, end: i64) -> sview:
    src: u8& = value if value != null else ""
    len: usize = runtime_strlen(src)

    lo: mutable usize = 0
    hi: mutable usize = len

    if start > 0:
        lo <- start.usize()
        if lo > len:
            lo <- len

    if end >= 0:
        hi <- end.usize()
        if hi > len:
            hi <- len

    if hi < lo:
        hi <- lo

    return StringView(src + lo, (hi - lo).i64())

def string_view_len(view: sview) -> i64:
    return view.len

def string_view_slice(view: sview, start: i64, end: i64) -> sview:
    lo: mutable i64 = start if start > 0 else 0
    hi: mutable i64 = end if end >= 0 else view.len

    if lo > view.len:
        lo <- view.len
    if hi > view.len:
        hi <- view.len
    if hi < lo:
        hi <- lo

    return StringView(view.data + lo.usize(), hi - lo)

def string_view_prefix(view: sview, end: i64) -> sview:
    return string_view_slice(view, 0, end)

def string_view_suffix(view: sview, start: i64) -> sview:
    return string_view_slice(view, start, view.len)

def string_view_index(view: sview, index: i64) -> i64:
    0 return if index < 0 or index >= view.len

    return view.data[index.usize()].i64()

def string_view_eq(view: sview, other: u8&?) -> int:
    rhs: u8& = other if other != null else ""
    rhs_len: usize = runtime_strlen(rhs)

    0 return if view.len < 0 or view.len.usize() != rhs_len
    #1 return if view.len == 0
    #1 return if view.data == rhs

    1 return if view.len == 0 or view.data == rhs

    return 1 if memcmp(view.data.cast[void&], rhs.cast[void&], view.len.usize()) == 0 else 0

def string_views_eq(lhs: sview, rhs: sview) -> int:
    0 return if lhs.len != rhs.len

    #1 return if lhs.len == 0
    #1 return if lhs.data == rhs.data
    1 return if lhs.len == 0 or lhs.data == rhs.data
    
    return 1 if memcmp(lhs.data.cast[void&], rhs.data.cast[void&], lhs.len.usize()) == 0 else 0

def string_view_copy(view: sview) -> heap u8&:
    can Memory.Allocate, Abort.Panic:
        intern_small_string("", 0) return if view.len <= 0

        intern_small_string(view.data, view.len.usize()) return if view.len <= 8

        out: heap u8& = alloc_perm((view.len + 1).usize()).cast[heap u8&]
        memcpy(out.cast[mutable void&], view.data.cast[void&], view.len.usize())
        out[view.len.usize()] <- 0
        register_perm_string_len(out.cast[u8&], view.len.usize())
        return out
# end include /Users/torarinvikbjarko/Documents/Coding Projects/Go projects/Elisa-core/compiler/runtime/elisacore_std/elisacore_runtime_strings.elisa
# begin include /Users/torarinvikbjarko/Documents/Coding Projects/Go projects/Elisa-core/compiler/runtime/elisacore_std/runtime.elisa
# ============================================================
# Elisa core Runtime - public wrappers and stage 1 adapters
# ============================================================

# ------------------------------------------------------------
# Type-to-string public API
# ------------------------------------------------------------

def int_to_string(value: i64) -> heap u8&:
    return int_to_string_into((&perm_arena).cast[Arena&], value) can Memory.Allocate, Console.Format, Abort.Panic

def int_to_string_scratch(value: i64) -> heap u8&:
    return int_to_string_into((&scratch_arena).cast[Arena&], value) can Memory.Allocate, Console.Format, Abort.Panic

def bool_to_string(value: int) -> u8&:
    return bool_to_string_into((&perm_arena).cast[Arena&], value)

def bool_to_string_scratch(value: int) -> u8&:
    return bool_to_string_into((&scratch_arena).cast[Arena&], value)

def char_to_string(value: i64) -> heap u8&:
    return char_to_string_into((&perm_arena).cast[Arena&], value) can Memory.Allocate, Abort.Panic

def char_to_string_scratch(value: i64) -> heap u8&:
    return char_to_string_into((&scratch_arena).cast[Arena&], value) can Memory.Allocate, Abort.Panic

# ------------------------------------------------------------
# Basic string predicates
# ------------------------------------------------------------

def __cast__(value: static u8&) -> u8&:
    return value.cast[u8&]


def string_len(value: u8&?) -> i64:
    return runtime_strlen(value).i64()

def streq(lhs: u8&?, rhs: u8&?) -> int:
    left: u8& = lhs if lhs != null else ""
    right: u8& = rhs if rhs != null else ""

    return 1 if left == right or strcmp(left, right) == 0 else 0

# ============================================================
# Stage 1 runtime forwarding wrappers
# ============================================================

def rt_concat2(lhs: cstr[shape_left], rhs: cstr[shape_right]) -> cstr[shape_result]:
    return concat2(lhs, rhs) can Memory.Allocate, Abort.Panic

def rt_concat2_scratch(lhs: cstr[shape_left], rhs: cstr[shape_right]) -> cstr[shape_result]:
    return concat2_scratch(lhs, rhs) can Memory.Allocate, Abort.Panic

def rt_string_builder_new(initial: u8&?) -> mutable heap StringBuilder&:
    return string_builder_new(initial) can Memory.Allocate, Abort.Panic

def rt_string_builder_append(builder: mutable heap StringBuilder&?, suffix: u8&?) -> mutable heap StringBuilder&:
    return string_builder_append(builder, suffix) can Memory.Allocate, Abort.Panic

def rt_string_builder_finish(builder: heap StringBuilder&?) -> cstr[shape_out]:
    return string_builder_finish(builder).cast[u8&] can Memory.Allocate, Abort.Panic

def rt_int_to_string(value: i64) -> cstr[shape_out]:
    return int_to_string(value) can Memory.Allocate, Console.Format, Abort.Panic

def rt_int_to_string_scratch(value: i64) -> cstr[shape_out]:
    return int_to_string_scratch(value) can Memory.Allocate, Console.Format, Abort.Panic

def rt_bool_to_string(value: int) -> cstr[shape_out]:
    return bool_to_string(value)

def rt_bool_to_string_scratch(value: int) -> cstr[shape_out]:
    return bool_to_string_scratch(value)

def rt_char_to_string(value: i64) -> cstr[shape_out]:
    return char_to_string(value) can Memory.Allocate, Abort.Panic

def rt_char_to_string_scratch(value: i64) -> cstr[shape_out]:
    return char_to_string_scratch(value) can Memory.Allocate, Abort.Panic

def ctx_strlen(value: cstr[shape_in]) -> i64:
    return string_len(value)

def ctx_streq(lhs: cstr[shape_left], rhs: cstr[shape_right]) -> int:
    return streq(lhs, rhs)

def ctx_string_slice_eq(value: cstr[shape_in], start: i64, end: i64, other: cstr[shape_other]) -> int:
    return string_slice_eq(value, start, end, other)

def ctx_string_slices_eq(lhs: cstr[shape_left], lhs_start: i64, lhs_end: i64, rhs: cstr[shape_right], rhs_start: i64, rhs_end: i64) -> int:
    return string_slices_eq(lhs, lhs_start, lhs_end, rhs, rhs_start, rhs_end)

def ctx_string_index(value: cstr[shape_in], index: i64) -> i64:
    return string_index(value, index)

def ctx_string_slice(value: cstr[shape_in], start: i64, end: i64) -> cstr[shape_out]:
    return string_slice(value, start, end) can Memory.Allocate, Abort.Panic

def ctx_string_view(value: cstr[shape_in], start: i64, end: i64) -> sview:
    return sview(value, start, end)

def ctx_string_view_len(view: sview) -> i64:
    return string_view_len(view)

def ctx_string_view_slice(view: sview, start: i64, end: i64) -> sview:
    return string_view_slice(view, start, end)

def ctx_string_view_prefix(view: sview, end: i64) -> sview:
    return string_view_prefix(view, end)

def ctx_string_view_suffix(view: sview, start: i64) -> sview:
    return string_view_suffix(view, start)

def ctx_string_view_index(view: sview, index: i64) -> i64:
    return string_view_index(view, index)

def ctx_string_view_eq(view: sview, other: cstr[shape_other]) -> int:
    return string_view_eq(view, other)

def ctx_string_views_eq(lhs: sview, rhs: sview) -> int:
    return string_views_eq(lhs, rhs)

def ctx_string_from_view(view: sview) -> cstr[shape_out]:
    return string_view_copy(view).cast[u8&] can Memory.Allocate, Abort.Panic

def rt_reset_scratch():
    reset_scratch()

def rt_puts(value: u8&?) -> int:
    return puts(value if value != null else "") can Console.Write

# ------------------------------------------------------------
# Fatal error handler (weak linkage)
# ------------------------------------------------------------

# weak
def ctx_llvm_codegen_fatal(msg: u8&?):
    can Console, Abort.Exit:
        actual_msg: u8& = msg if msg != null else "<null>"
        puts("ctx_llvm_codegen_fatal:")
        puts(actual_msg)
        exit(1)
