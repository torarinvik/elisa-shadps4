struct ShaderIrPassInst:
    id: mutable u32
    opcode: mutable u32
    arg_count: mutable u32
    args: mutable u32[6]
    arg_kinds: mutable u32[6]
    flags_u32: mutable u32
    flags_bool: mutable bool
    has_side_effects: mutable bool
    has_uses: mutable bool
    invalidated: mutable bool
    replaced: mutable bool
    replacement_opcode: mutable u32
    replacement_value: mutable u32

