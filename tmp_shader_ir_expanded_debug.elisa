struct ShaderRuntimeInfo:
    vs_num_exports: mutable u32
    fs_clip_distance_emulation: mutable bool
    fs_num_inputs: mutable u32
    cs_shared_memory_size: mutable u32
    cs_workgroup_size_x: mutable u32
    cs_workgroup_size_y: mutable u32
    cs_workgroup_size_z: mutable u32
    es_vertex_data_size: mutable u32
    gs_output_vertices: mutable u32
    gs_out_vertex_data_size: mutable u32
    gs_mode: mutable u32
    hs_is_passthrough: mutable bool
    hs_ls_stride: mutable u32
    hs_output_cp_stride: mutable u32
    hs_tess_type: mutable u32

struct ShaderPassProfile:
    needs_clip_distance_emulation: mutable bool
    needs_lds_barriers: mutable bool
    supports_workgroup_explicit_memory_layout: mutable bool
    max_shared_memory_size: mutable u32
    supports_buffer_fp32_atomic_min_max: mutable bool
    supports_image_load_store_lod: mutable bool

struct ShaderIrPassStats:
    constant_folds: mutable u32
    dead_code_removed: mutable u32
    identity_removed: mutable u32
    ssa_reads_rewritten: mutable u32
    readlane_eliminated: mutable u32
    shared_barriers_inserted: mutable u32
    shared_simplified_rewrites: mutable u32
    shared_to_storage_rewrites: mutable u32
    resource_sharp_patched: mutable u32
    resource_args_patched: mutable u32
    ring_rewrites: mutable u32
    hull_rewrites: mutable u32
    domain_rewrites: mutable u32
    tess_constants_replaced: mutable u32
    clip_distance_injected: mutable u32
    fp64_lowered: mutable u32
    buffer_format_lowered: mutable u32
    flatten_readconsts: mutable u32

struct ShaderIrProgram:
    info: mutable ShaderIrInfo
    block_count: mutable u32
    blocks: mutable ShaderIrPassBlock[96]
    post_order_count: mutable u32
    post_order: mutable u32[96]
    syntax_count: mutable u32
    syntax_nodes: mutable ShaderIrSyntaxNode[256]
    next_inst_id: mutable u32
    stats: mutable ShaderIrPassStats

def ShaderIrProgram_Default() -> ShaderIrProgram:
    out: mutable ShaderIrProgram = zeroed
    out.next_inst_id <- 1
    out.info.tess_consts_dword_offset <- -1
    out.info.srt_flattened_bufsize_dw <- 16
    return out

def ShaderRuntimeInfo_Default() -> ShaderRuntimeInfo:
    out: mutable ShaderRuntimeInfo = zeroed
    out.cs_workgroup_size_x <- 1
    out.cs_workgroup_size_y <- 1
    out.cs_workgroup_size_z <- 1
    return out

def ShaderPassProfile_Default() -> ShaderPassProfile:
    out: mutable ShaderPassProfile = zeroed
    out.max_shared_memory_size <- 32768
    return out

def ShaderIrProgram_AddBlock(program: mutable ShaderIrProgram&) -> u32:
    if program.block_count >= IR_PASS_MAX_BLOCKS:
        return 0
    index: u32 = program.block_count
    program.blocks[index.usize()] <- zeroed
    program.blocks[index.usize()].cfg_block_id <- index
    program.block_count <- program.block_count + 1
    if program.post_order_count < IR_PASS_MAX_BLOCKS:
        program.post_order[program.post_order_count.usize()] <- index
        program.post_order_count <- program.post_order_count + 1
    return index

def ShaderIrPassInst_SetArgImm(inst: mutable ShaderIrPassInst&, index: u32, value: u32) -> void:
    if index >= IR_PASS_MAX_ARGS:
        return
    inst.arg_kinds[index.usize()] <- IR_PASS_ARG_IMM
    inst.args[index.usize()] <- value
    if index + 1 > inst.arg_count:
        inst.arg_count <- index + 1

def ShaderIrPassInst_SetArgInst(inst: mutable ShaderIrPassInst&, index: u32, value: u32) -> void:
    if index >= IR_PASS_MAX_ARGS:
        return
    inst.arg_kinds[index.usize()] <- IR_PASS_ARG_INST
    inst.args[index.usize()] <- value
    if index + 1 > inst.arg_count:
        inst.arg_count <- index + 1

def ShaderIrPassInst_SetArgAttribute(inst: mutable ShaderIrPassInst&, index: u32, value: u32) -> void:
    if index >= IR_PASS_MAX_ARGS:
        return
    inst.arg_kinds[index.usize()] <- IR_PASS_ARG_ATTRIBUTE
    inst.args[index.usize()] <- value
    if index + 1 > inst.arg_count:
        inst.arg_count <- index + 1

def ShaderIrProgram_AddInst(program: mutable ShaderIrProgram&, block_index: u32, opcode: u32) -> u32:
    if block_index >= program.block_count:
        return 0
    block: mutable ShaderIrPassBlock& = (&program.blocks[block_index.usize()]).cast[mutable ShaderIrPassBlock&]
    if block.inst_count >= IR_PASS_MAX_INSTS:
        return 0
    inst_index: u32 = block.inst_count
    block.inst_count <- block.inst_count + 1
    block.insts[inst_index.usize()] <- zeroed
    block.insts[inst_index.usize()].opcode <- opcode
    block.insts[inst_index.usize()].id <- program.next_inst_id
    program.next_inst_id <- program.next_inst_id + 1
    return block.insts[inst_index.usize()].id

def ShaderIrProgram_AddSyntaxBlock(program: mutable ShaderIrProgram&, block_index: u32) -> void:
    if program.syntax_count >= IR_PASS_MAX_SYNTAX:
        return
    idx: u32 = program.syntax_count
    program.syntax_count <- program.syntax_count + 1
    program.syntax_nodes[idx.usize()] <- zeroed
    program.syntax_nodes[idx.usize()].node_type <- IR_SYNTAX_BLOCK
    program.syntax_nodes[idx.usize()].block_index <- block_index


def ShaderIrProgram_AddSyntaxIf(program: mutable ShaderIrProgram&, cond_inst_id: u32, merge_block_index: u32) -> void:
    if program.syntax_count >= IR_PASS_MAX_SYNTAX:
        return
    idx: u32 = program.syntax_count
    program.syntax_count <- program.syntax_count + 1
    program.syntax_nodes[idx.usize()] <- zeroed
    program.syntax_nodes[idx.usize()].node_type <- IR_SYNTAX_IF
    program.syntax_nodes[idx.usize()].cond_inst_id <- cond_inst_id
    program.syntax_nodes[idx.usize()].merge_block_index <- merge_block_index


def ShaderIrProgram_AddSyntaxEndIf(program: mutable ShaderIrProgram&, merge_block_index: u32) -> void:
    if program.syntax_count >= IR_PASS_MAX_SYNTAX:
        return
    idx: u32 = program.syntax_count
    program.syntax_count <- program.syntax_count + 1
    program.syntax_nodes[idx.usize()] <- zeroed
    program.syntax_nodes[idx.usize()].node_type <- IR_SYNTAX_END_IF
    program.syntax_nodes[idx.usize()].merge_block_index <- merge_block_index


def ShaderIrProgram_FindInst(program: ShaderIrProgram&, inst_id: u32, out_block_index: mutable u32&, out_inst_index: mutable u32&) -> bool:
    b: mutable u32 = 0
    while b < program.block_count:
        i: mutable u32 = 0
        while i < program.blocks[b.usize()].inst_count:
            if program.blocks[b.usize()].insts[i.usize()].id == inst_id:
                out_block_index <- b
                out_inst_index <- i
                return true
            i <- i + 1
        b <- b + 1
    return false


def ShaderIrPassBlock_RemoveInstAt(block: mutable ShaderIrPassBlock&, inst_index: u32) -> bool:
    if inst_index >= block.inst_count:
        return false
    i: mutable u32 = inst_index
    while i + 1 < block.inst_count:
        block.insts[i.usize()] <- block.insts[(i + 1).usize()]
        i <- i + 1
    if block.inst_count > 0:
        block.inst_count <- block.inst_count - 1
        block.insts[block.inst_count.usize()] <- zeroed
    return true


def ShaderIrPass_MarkInvalid(inst: mutable ShaderIrPassInst&) -> void:
    inst.invalidated <- true


def ShaderIrPass_ReplaceWithImm(inst: mutable ShaderIrPassInst&, value: u32) -> void:
    inst.replaced <- true
    inst.replacement_value <- value
    inst.invalidated <- true


def ShaderIrPass_ReplaceOpcode(inst: mutable ShaderIrPassInst&, opcode: u32) -> void:
    inst.replaced <- true
    inst.replacement_opcode <- opcode
    inst.opcode <- opcode


def ShaderIrPass_ArgIsImm(inst: ShaderIrPassInst&, arg_index: u32) -> bool:
    if arg_index >= inst.arg_count:
        return false
    return inst.arg_kinds[arg_index.usize()] == IR_PASS_ARG_IMM


def ShaderIrPass_ArgIsInst(inst: ShaderIrPassInst&, arg_index: u32) -> bool:
    if arg_index >= inst.arg_count:
        return false
    return inst.arg_kinds[arg_index.usize()] == IR_PASS_ARG_INST


def ShaderIrPass_IsLoadShared(opcode: u32) -> bool:
    return opcode == OPCODE_LOADSHAREDU16 or opcode == OPCODE_LOADSHAREDU32 or opcode == OPCODE_LOADSHAREDU64


def ShaderIrPass_IsWriteShared(opcode: u32) -> bool:
    return opcode == OPCODE_WRITESHAREDU16 or opcode == OPCODE_WRITESHAREDU32 or opcode == OPCODE_WRITESHAREDU64


def ShaderIrPass_IsSharedAccess(opcode: u32) -> bool:
    if ShaderIrPass_IsLoadShared(opcode) or ShaderIrPass_IsWriteShared(opcode):
        return true
    return opcode >= OPCODE_SHAREDATOMICIADD32 and opcode <= OPCODE_SHAREDATOMICXOR64


def ShaderIrPass_IsBufferAtomic(opcode: u32) -> bool:
    return opcode >= OPCODE_BUFFERATOMICIADD32 and opcode <= OPCODE_BUFFERATOMICXOR32


def ShaderIrPass_IsBufferStore(opcode: u32) -> bool:
    if opcode == OPCODE_STOREBUFFERU8 or opcode == OPCODE_STOREBUFFERU16 or opcode == OPCODE_STOREBUFFERU32 or opcode == OPCODE_STOREBUFFERU64 or opcode == OPCODE_STOREBUFFERF32 or opcode == OPCODE_STOREBUFFERFORMATF32:
        return true
    return ShaderIrPass_IsBufferAtomic(opcode)


def ShaderIrPass_IsBufferInstruction(opcode: u32) -> bool:
    if opcode == OPCODE_LOADBUFFERU8 or opcode == OPCODE_LOADBUFFERU16 or opcode == OPCODE_LOADBUFFERU32 or opcode == OPCODE_LOADBUFFERU64 or opcode == OPCODE_LOADBUFFERF32 or opcode == OPCODE_LOADBUFFERFORMATF32 or opcode == OPCODE_READCONSTBUFFER:
        return true
    return ShaderIrPass_IsBufferStore(opcode)


def ShaderIrPass_IsImageInstruction(opcode: u32) -> bool:
    if opcode == OPCODE_IMAGEREAD or opcode == OPCODE_IMAGEWRITE or opcode == OPCODE_IMAGEQUERYDIMENSIONS or opcode == OPCODE_IMAGEQUERYLOD or opcode == OPCODE_IMAGESAMPLERAW:
        return true
    return opcode == OPCODE_IMAGEATOMICFMIN32 or opcode == OPCODE_IMAGEATOMICFMAX32


def ShaderIrPass_IsDataRingInstruction(inst: ShaderIrPassInst&) -> bool:
    if inst.opcode == OPCODE_DATALAPPEND or inst.opcode == OPCODE_DATACONSUME:
        return true
    if ShaderIrPass_IsSharedAccess(inst.opcode):
        return inst.flags_bool
    return false


def ShaderIrPopcount(value: u32) -> u32:
    v: mutable u32 = value
    count: mutable u32 = 0
    while v != 0:
        count <- count + (v & 1)
        v <- v >> 1
    return count


def ShaderIrProgram_CountOpcode(program: ShaderIrProgram&, opcode: u32) -> u32:
    total: mutable u32 = 0
    b: mutable u32 = 0
    while b < program.block_count:
        i: mutable u32 = 0
        while i < program.blocks[b.usize()].inst_count:
            if program.blocks[b.usize()].insts[i.usize()].opcode == opcode and not program.blocks[b.usize()].insts[i.usize()].invalidated:
                total <- total + 1
            i <- i + 1
        b <- b + 1
    return total


def ShaderIrProgram_ResetStats(program: mutable ShaderIrProgram&) -> void:
    program.stats <- zeroed
# end include /Users/torarinvikbjarko/Documents/Coding Projects/Go projects/Elisa-core/elisa-shad-ps4-from-scratch/shader_recompiler/ir/passes/pass_model.elisa

def Requires16BitSharedAtomic(inst: ShaderIrPassInst&) -> bool:
    _ = inst
    return false


def Requires64BitSharedAtomic(inst: ShaderIrPassInst&) -> bool:
    return inst.opcode == OPCODE_SHAREDATOMICIADD64 or inst.opcode == OPCODE_SHAREDATOMICISUB64 or inst.opcode == OPCODE_SHAREDATOMICSMIN64 or inst.opcode == OPCODE_SHAREDATOMICUMIN64 or inst.opcode == OPCODE_SHAREDATOMICSMAX64 or inst.opcode == OPCODE_SHAREDATOMICUMAX64 or inst.opcode == OPCODE_SHAREDATOMICINC64 or inst.opcode == OPCODE_SHAREDATOMICDEC64 or inst.opcode == OPCODE_SHAREDATOMICAND64 or inst.opcode == OPCODE_SHAREDATOMICOR64 or inst.opcode == OPCODE_SHAREDATOMICXOR64


def IsNon32BitSharedLoadStore(inst: ShaderIrPassInst&) -> bool:
    return inst.opcode == OPCODE_LOADSHAREDU16 or inst.opcode == OPCODE_LOADSHAREDU64 or inst.opcode == OPCODE_WRITESHAREDU16 or inst.opcode == OPCODE_WRITESHAREDU64


def CalculateSpecialSharedAtomicTypes(program: ShaderIrProgram&) -> u32:
    extra_types: mutable u32 = IR_TYPE_VOID
    b: mutable u32 = 0
    while b < program.block_count:
        i: mutable u32 = 0
        while i < program.blocks[b.usize()].inst_count:
            inst: ShaderIrPassInst = program.blocks[b.usize()].insts[i.usize()]
            if Requires16BitSharedAtomic(inst):
                extra_types <- extra_types | IR_TYPE_U16
            if Requires64BitSharedAtomic(inst):
                extra_types <- extra_types | IR_TYPE_U64
            i <- i + 1
        b <- b + 1
    return extra_types


def SharedMemorySimplifyPass(program: mutable ShaderIrProgram&, profile: ShaderPassProfile&) -> void:
    if program.info.stage != STAGE_COMPUTE or profile.supports_workgroup_explicit_memory_layout:
        return

    atomic_types: u32 = CalculateSpecialSharedAtomicTypes(program)
    if (atomic_types & IR_TYPE_U16) != 0 and (atomic_types & IR_TYPE_U64) != 0:
        return

    b: mutable u32 = 0
    while b < program.block_count:
        block: mutable ShaderIrPassBlock& = (&program.blocks[b.usize()]).cast[mutable ShaderIrPassBlock&]
        i: mutable u32 = 0
        while i < block.inst_count:
            inst: mutable ShaderIrPassInst& = (&block.insts[i.usize()]).cast[mutable ShaderIrPassInst&]
            if IsNon32BitSharedLoadStore(inst):
                if (atomic_types & IR_TYPE_U16) == 0:
                    if inst.opcode == OPCODE_LOADSHAREDU16:
                        ShaderIrPass_ReplaceOpcode(inst, OPCODE_LOADSHAREDU32)
                        program.stats.shared_simplified_rewrites <- program.stats.shared_simplified_rewrites + 1
                    if inst.opcode == OPCODE_WRITESHAREDU16:
                        ShaderIrPass_ReplaceOpcode(inst, OPCODE_WRITESHAREDU32)
                        program.stats.shared_simplified_rewrites <- program.stats.shared_simplified_rewrites + 1
                if (atomic_types & IR_TYPE_U64) == 0:
                    if inst.opcode == OPCODE_LOADSHAREDU64:
                        ShaderIrPass_ReplaceOpcode(inst, OPCODE_LOADSHAREDU32)
                        program.stats.shared_simplified_rewrites <- program.stats.shared_simplified_rewrites + 1
                    if inst.opcode == OPCODE_WRITESHAREDU64:
                        ShaderIrPass_ReplaceOpcode(inst, OPCODE_WRITESHAREDU32)
                        program.stats.shared_simplified_rewrites <- program.stats.shared_simplified_rewrites + 1
            i <- i + 1
        b <- b + 1
# end include /Users/torarinvikbjarko/Documents/Coding Projects/Go projects/Elisa-core/elisa-shad-ps4-from-scratch/shader_recompiler/ir/passes/shared_memory_simplify_pass.elisa
