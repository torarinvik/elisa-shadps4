include "./core/libraries/pad/pad.elisa"

test "pad init/open/get/close lifecycle":
    assert_eq(scePadGetHandle(1, 0, 0), ORBIS_PAD_ERROR_NOT_INITIALIZED)
    assert_eq(scePadInit(), ORBIS_OK)
    h: int = scePadOpen(1, 0, 0, null)
    assert_true(h > 0)
    assert_eq(scePadGetHandle(1, 0, 0), h)
    assert_eq(scePadClose(h), ORBIS_OK)
    assert_eq(scePadClose(h), ORBIS_PAD_ERROR_INVALID_HANDLE)

test "pad validation paths":
    _ = scePadInit()
    assert_eq(scePadOpen(-5, 0, 0, null), ORBIS_DEVICE_SERVICE_ERROR_INVALID_USER)
    h: int = scePadOpen(2, 0, 0, null)
    assert_true(h > 0)
    assert_eq(scePadOpen(2, 0, 0, null), ORBIS_PAD_ERROR_ALREADY_OPENED)
    assert_eq(scePadSetLightBar(h, null), ORBIS_PAD_ERROR_INVALID_ARG)

    dim: OrbisPadLightBarParam = zeroed
    dim.r <- 1
    dim.g <- 1
    dim.b <- 1
    assert_eq(scePadSetLightBar(h, dim.cast[OrbisPadLightBarParam&?]), ORBIS_PAD_ERROR_INVALID_LIGHTBAR_SETTING)

test "pad read/info":
    _ = scePadInit()
    h: int = scePadOpen(3, 0, 0, null)
    d: OrbisPadData = zeroed
    assert_eq(scePadRead(h, d.cast[OrbisPadData&?], 1), 1)
    assert_true(d.connected)
    assert_eq(scePadReadState(h, d.cast[OrbisPadData&?]), ORBIS_OK)

    info: OrbisPadInfo = zeroed
    assert_eq(scePadGetInfo(info.cast[OrbisPadInfo&?]), ORBIS_OK)
    assert_eq(info.unk1, 1u32)
