include "../compiler/runtime/elisacore_std/elisacore_runtime.elisa"
include "./core/libraries/system/userservice.elisa"

@test
def t1() -> void:
    can Abort.Panic:
        uid: mutable int = -1
        assert sceUserServiceGetInitialUser(uid.ref[mutable int&]) == ORBIS_OK

@test
def t2() -> void:
    can Abort.Panic:
        c: mutable u32 = 0
        assert sceUserServiceGetUserColor(1, c.ref[mutable u32&]) == ORBIS_OK

@test
def t3() -> void:
    can Abort.Panic:
        b: mutable u8[8] = zeroed
        assert sceUserServiceGetUserName(1, b[0].ref[mutable u8&], 8) == ORBIS_OK

@test
def t4() -> void:
    can Abort.Panic:
        e: mutable OrbisUserServiceEvent = zeroed
        assert sceUserServiceGetEvent(e.ref[mutable void&]) == ORBIS_USER_SERVICE_ERROR_NO_EVENT
